Cell[TextData[{
 "We have therefore shown that ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubsuperscriptBox[
     StyleBox["Y",
      FontSlant->"Italic"], 
     StyleBox["l",
      FontSlant->"Italic"], 
     SubscriptBox[
      StyleBox["m",
       FontSlant->"Italic"], 
      StyleBox["l",
       FontSlant->"Italic"]]], "(", 
    RowBox[{"\[Theta]", ",", "\[Phi]"}], ")"}], TraditionalForm]],
  CellChangeTimes->{{3.8100544880652375`*^9, 3.8100545041200957`*^9}, {
    3.810054632482561*^9, 3.8100546606919527`*^9}, {3.810054738405748*^9, 
    3.810054754160844*^9}, {3.810055496888957*^9, 3.810055644063492*^9}, {
    3.8101099522060614`*^9, 3.8101100508523717`*^9}, {3.8101101194750385`*^9, 
    3.8101101642963843`*^9}, {3.8107127659519644`*^9, 3.810712781977992*^9}, {
    3.8107128863205147`*^9, 3.8107129246267147`*^9}, 3.810712975971156*^9, 
    3.8107130396874857`*^9, {3.810713072953952*^9, 3.810713077029566*^9}, {
    3.8107138654100857`*^9, 3.810713907959445*^9}, 3.810714092835499*^9, {
    3.8107142057542086`*^9, 3.8107142281878614`*^9}},ExpressionUUID->
  "26d71187-739a-4000-98e8-79ef712d7ec1"],
 " are eigenfunctions of the operator ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox[
    OverscriptBox[
     StyleBox["L",
      FontSlant->"Italic"], "^"],
    FontSlant->"Italic"], 
   StyleBox["z",
    FontSlant->"Italic"]]],
  CellChangeTimes->{{3.8100544880652375`*^9, 3.8100545041200957`*^9}, {
    3.810054632482561*^9, 3.8100546606919527`*^9}, {3.810054738405748*^9, 
    3.810054754160844*^9}, {3.810055496888957*^9, 3.810055644063492*^9}, {
    3.8101099522060614`*^9, 3.8101100508523717`*^9}, {3.8101101194750385`*^9, 
    3.8101101642963843`*^9}, {3.8107127659519644`*^9, 3.810712781977992*^9}, {
    3.8107128863205147`*^9, 3.8107129246267147`*^9}, 3.810712975971156*^9, 
    3.8107130396874857`*^9, {3.810713072953952*^9, 3.810713077029566*^9}, {
    3.8107138654100857`*^9, 3.810713907959445*^9}, 3.810714092835499*^9, {
    3.8107142057542086`*^9, 3.8107142281878614`*^9}},ExpressionUUID->
  "e1e778c6-c5d2-4b44-96bf-79615c98b178"],
 " with eigenvalues of ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["m",
    FontSlant->"Italic"], 
   StyleBox["l",
    FontSlant->"Italic"]]],
  CellChangeTimes->{{3.8100544880652375`*^9, 3.8100545041200957`*^9}, {
    3.810054632482561*^9, 3.8100546606919527`*^9}, {3.810054738405748*^9, 
    3.810054754160844*^9}, {3.810055496888957*^9, 3.810055644063492*^9}, {
    3.8101099522060614`*^9, 3.8101100508523717`*^9}, {3.8101101194750385`*^9, 
    3.8101101642963843`*^9}, {3.8107127659519644`*^9, 3.810712781977992*^9}, {
    3.8107128863205147`*^9, 3.8107129246267147`*^9}, 3.810712975971156*^9, 
    3.8107130396874857`*^9, {3.810713072953952*^9, 3.810713077029566*^9}, {
    3.8107138654100857`*^9, 3.810713907959445*^9}, {3.8107141633674574`*^9, 
    3.8107141929269314`*^9}, {3.842105206901169*^9, 3.8421052148135443`*^9}, {
    3.917086229446878*^9, 3.917086272810526*^9}, 3.917086341525565*^9, {
    3.9170863897335787`*^9, 3.9170863900821447`*^9}},ExpressionUUID->
  "2b1a1326-528c-4668-a844-6b2230726328"],
 " \[HBar]. We can interpret this result as telling us that the value of ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["m",
    FontSlant->"Italic"], 
   StyleBox["l",
    FontSlant->"Italic"]]],
  CellChangeTimes->{{3.8100544880652375`*^9, 3.8100545041200957`*^9}, {
    3.810054632482561*^9, 3.8100546606919527`*^9}, {3.810054738405748*^9, 
    3.810054754160844*^9}, {3.810055496888957*^9, 3.810055644063492*^9}, {
    3.8101099522060614`*^9, 3.8101100508523717`*^9}, {3.8101101194750385`*^9, 
    3.8101101642963843`*^9}, {3.8107127659519644`*^9, 3.810712781977992*^9}, {
    3.8107128863205147`*^9, 3.8107129246267147`*^9}, 3.810712975971156*^9, 
    3.8107130396874857`*^9, {3.810713072953952*^9, 3.810713077029566*^9}, {
    3.8107138654100857`*^9, 3.810713907959445*^9}, {3.8107141633674574`*^9, 
    3.8107141929269314`*^9}, {3.842105206901169*^9, 3.8421052148135443`*^9}, {
    3.917086229446878*^9, 3.917086272810526*^9}, 3.917086341525565*^9, {
    3.9170863897335787`*^9, 3.9170863900821447`*^9}},ExpressionUUID->
  "cd61abb5-45af-4956-b4a0-948b2a61d797"],
 " specifies the magnitude of the ",
 StyleBox["z",
  FontSlant->"Italic"],
 "-component of the angular momentum. We can refer to  ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["m",
    FontSlant->"Italic"], 
   StyleBox["l",
    FontSlant->"Italic"]]],
  CellChangeTimes->{{3.8100544880652375`*^9, 3.8100545041200957`*^9}, {
    3.810054632482561*^9, 3.8100546606919527`*^9}, {3.810054738405748*^9, 
    3.810054754160844*^9}, {3.810055496888957*^9, 3.810055644063492*^9}, {
    3.8101099522060614`*^9, 3.8101100508523717`*^9}, {3.8101101194750385`*^9, 
    3.8101101642963843`*^9}, {3.8107127659519644`*^9, 3.810712781977992*^9}, {
    3.8107128863205147`*^9, 3.8107129246267147`*^9}, 3.810712975971156*^9, 
    3.8107130396874857`*^9, {3.810713072953952*^9, 3.810713077029566*^9}, {
    3.8107138654100857`*^9, 3.810713907959445*^9}, {3.8107141633674574`*^9, 
    3.8107141929269314`*^9}, {3.842105206901169*^9, 3.8421052148135443`*^9}, {
    3.917086229446878*^9, 3.917086272810526*^9}, 3.917086341525565*^9, {
    3.9170863897335787`*^9, 3.9170863900821447`*^9}},ExpressionUUID->
  "a8d39ef0-f48d-4d4c-a85a-b17586deff5b"],
 " as the angular momentum projection quantum number of hydrogen."
}], "Text",
 CellChangeTimes->{{3.81071433224546*^9, 3.810714364582611*^9}, {
  3.810714413348302*^9, 3.810714502413449*^9}, {3.8107145324362507`*^9, 
  3.810714546536392*^9}, {3.9170863716146317`*^9, 3.9170863716146317`*^9}, {
