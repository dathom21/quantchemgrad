c6d171425986"],

Cell[TextData[{
 "increases as ",
 StyleBox["n",
  FontSlant->"Italic"],
 " increases, meaning that the electron on average is found at a greater \
distance from the nucleus."
}], "Text",
 CellChangeTimes->{{3.810724980171528*^9, 3.810724981907578*^9}, {
  3.8107250141111712`*^9, 3.810725016693698*^9}, {3.8107250592006955`*^9, 
  3.8107250779516673`*^9}},ExpressionUUID->"9db38098-f681-4d59-9d08-\
6d5e85c20c8d"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[{
 "The Three ",
 StyleBox["p",
  FontSlant->"Italic"],
 " Orbitals Exhibit Angular Dependence"
}], "Subsubsection",
 CellChangeTimes->{{3.8107192356180935`*^9, 3.8107192389984384`*^9}, {
  3.810720092755737*^9, 3.81072009754844*^9}, {3.8107211801768475`*^9, 
  3.810721196999052*^9}, {3.810723622437487*^9, 3.8107236405152397`*^9}, {
  3.8107254010986814`*^9, 
  3.8107254249521646`*^9}},ExpressionUUID->"3edb1ede-91d2-4705-83d1-\
017f3bc4aca3"],

Cell[TextData[{
 "Now that we have discussed the simplest case of angular dependence where ",
 StyleBox["l",
  FontSlant->"Italic"],
 " = 0, we turn our attention to the case of ",
 StyleBox["l",
  FontSlant->"Italic"],
 " = 1, which correspond to ",
 StyleBox["p",
  FontSlant->"Italic"],
 " atomic orbitals. Here, we have three possible values of ",
 StyleBox["m",
  FontSlant->"Italic"],
 ", which yield three different equations for the spherical harmonics,"
}], "Text",
 CellChangeTimes->{{3.810725440007762*^9, 3.8107254881212473`*^9}, {
  3.810725658478177*^9, 3.8107256751702285`*^9}, {3.8107257110647306`*^9, 
  3.8107257186072593`*^9}},ExpressionUUID->"06f7adaf-a3da-43bc-8ab9-\
99ef4c8539c9"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   SubsuperscriptBox[
    StyleBox["Y",
     FontSlant->"Italic"], "1", "0"], 
   RowBox[{"(", 
    RowBox[{"\[Theta]", ",", "\[Phi]"}], ")"}]}], ",", " ", 
  RowBox[{
   SubsuperscriptBox[
    StyleBox["Y",
     FontSlant->"Italic"], "1", 
    RowBox[{"-", "1"}]], 
   RowBox[{"(", 
    RowBox[{"\[Theta]", ",", "\[Phi]"}], ")"}]}], ",", " ", 
  RowBox[{
   SubsuperscriptBox[
    StyleBox["Y",
     FontSlant->"Italic"], "1", "1"], 
   RowBox[{"(", 
    RowBox[{"\[Theta]", ",", "\[Phi]"}], ")"}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.810112811439228*^9, 3.8101128248442793`*^9}, {
   3.810479494926491*^9, 3.8104795038498344`*^9}, {3.810479572543576*^9, 
