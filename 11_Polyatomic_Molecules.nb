b98b98f1f4f2"],

Cell[TextData[{
 "which combine with either the H 1",
 StyleBox["s",
  FontSlant->"Italic"],
 " orbitals or one of the ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    StyleBox["sp",
     FontSlant->"Italic"], "2"], TraditionalForm]],ExpressionUUID->
  "6e95b3fd-7b5c-4f4f-a17d-69b4a17b852e"],
 " hybrid orbitals of the other carbon. The \[Pi] molecular orbitals are \
formed from the remaining ",
 Cell[BoxData[
  FormBox[
   RowBox[{"2", 
    SubscriptBox["p", "z"]}], TraditionalForm]],ExpressionUUID->
  "b80c9fa4-9c30-4103-96e4-020e5c4b35a2"],
 " orbitals,"
}], "Text",
