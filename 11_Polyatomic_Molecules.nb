Cell[BoxData[
 RowBox[{
  SubscriptBox["\[CapitalPhi]", 
   SuperscriptBox[
    StyleBox["sp",
     FontSlant->"Italic"], "2"]], "=", 
  RowBox[{
   RowBox[{
    SubscriptBox[
     StyleBox["c",
      FontSlant->"Italic"], "1"], 
    SubscriptBox["\[Phi]", 
     RowBox[{"2", 
      StyleBox["s",
       FontSlant->"Italic"]}]]}], "+", 
   RowBox[{
    SubscriptBox[
     StyleBox["c",
      FontSlant->"Italic"], "2"], 
    SubscriptBox["\[Phi]", 
     RowBox[{"2", 
      SubscriptBox[
       StyleBox["p",
        FontSlant->"Italic"], 
       StyleBox["x",
        FontSlant->"Italic"]]}]]}], "+", 
   RowBox[{
    SubscriptBox[
     StyleBox["c",
      FontSlant->"Italic"], "3"], 
    SubscriptBox["\[Phi]", 
     RowBox[{"2", 
      SubscriptBox[
       StyleBox["p",
        FontSlant->"Italic"], 
       StyleBox["y",
        FontSlant->"Italic"]]}]]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8142715408501225`*^9, 3.8142716264528427`*^9}, {
