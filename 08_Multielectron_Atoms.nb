 SuperscriptBox["\[ExponentialE]", 
  RowBox[{"-", 
   StyleBox[
    RowBox[{"\[Alpha]", 
     StyleBox["r",
      FontSlant->"Italic"]}]]}]]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.811593312893673*^9, 3.8115933831661987`*^9}, {
   3.811593458953679*^9, 3.8115934974178753`*^9}, {3.811594043422389*^9, 
   3.8115940850450926`*^9}, {3.8115941212928057`*^9, 3.81159413134099*^9}, {
   3.8115942129312763`*^9, 3.811594213576462*^9}, {3.811594345555955*^9, 
   3.8115943458791523`*^9}, 3.8115943810138807`*^9, {3.8118583015457077`*^9, 
   3.8118583904266043`*^9}, {3.8118668881127214`*^9, 3.811866985652667*^9}, {
   3.81187008170006*^9, 3.8118700849636593`*^9}, {3.8118701593125334`*^9, 
   3.811870219238614*^9}, 
   3.8119451394589987`*^9},ExpressionUUID->"2ba94bb3-274d-a74d-90dc-\
f6eacda1567e"],

Cell[TextData[{
 "Are difficult to evaluate in finding elements of the ",
 StyleBox["H",
  FontWeight->"Bold"],
 " or ",
 StyleBox["S",
  FontWeight->"Bold"],
 " matrices, Gaussian-type orbitals are typically used instead in modern \
computational chemistry. Gaussian-type orbitals take the form"
}], "Text",
 CellChangeTimes->{{3.8118702226521444`*^9, 
  3.8118702827249923`*^9}},ExpressionUUID->"01d6835f-96ad-5d44-837c-\
ee517697a0d9"],

Cell[BoxData[
 RowBox[{
  RowBox[{"\[Phi]", 
   RowBox[{"(", 
    RowBox[{
     StyleBox["r",
      FontSlant->"Italic"], 
     StyleBox[",",
      FontSlant->"Italic"], "\[Theta]", ",", "\[Phi]"}], ")"}]}], "=", 
  RowBox[{
   SubscriptBox[
    StyleBox["N",
     FontSlant->"Italic"], 
    StyleBox["nl",
     FontSlant->"Italic"]], 
   SuperscriptBox[
    StyleBox["r",
     FontSlant->"Italic"], 
    RowBox[{
     StyleBox["n",
      FontSlant->"Italic"], "-", "1"}]], 
   SubsuperscriptBox[
    StyleBox["Y",
     FontSlant->"Italic"], "m", 
    StyleBox["l",
     FontSlant->"Italic"]], 
   RowBox[{"(", 
    RowBox[{"\[Theta]", ",", "\[Phi]"}], ")"}], 
   SuperscriptBox["\[ExponentialE]", 
    RowBox[{"-", 
     SuperscriptBox[
      StyleBox[
       RowBox[{"\[Alpha]", 
        StyleBox["r",
         FontSlant->"Italic"]}]], "2"]}]]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.811593312893673*^9, 3.8115933831661987`*^9}, {
   3.811593458953679*^9, 3.8115934974178753`*^9}, {3.811594043422389*^9, 
   3.8115940850450926`*^9}, {3.8115941212928057`*^9, 3.81159413134099*^9}, {
   3.8115942129312763`*^9, 3.811594213576462*^9}, {3.811594345555955*^9, 
   3.8115943458791523`*^9}, 3.8115943810138807`*^9, {3.8118583015457077`*^9, 
   3.8118583904266043`*^9}, {3.8118668881127214`*^9, 3.811866985652667*^9}, {
   3.81187008170006*^9, 3.8118700849636593`*^9}, {3.8118701593125334`*^9, 
   3.811870201331394*^9}, {3.8118702702857475`*^9, 3.8118702731692486`*^9}, 
   3.8119357193418207`*^9, {3.811945156286234*^9, 
   3.8119451679744034`*^9}},ExpressionUUID->"3402af2b-28e7-8141-9700-\
bed9f3a57fe9"],

Cell[TextData[{
 "The form of these functions is less accurate in replicating the shape of a \
hydrogen-like wavefunction, as shown in Figure 8.1 for the radial component \
of the hydrogen 1s orbital. However, because evaluating the ",
 StyleBox["H",
  FontWeight->"Bold"],
 " or ",
 StyleBox["S",
  FontWeight->"Bold"],
 " matrices is much faster for these functions, they increase the efficiency \
of calculation, and a linear combination of such Gaussian functions can still \
accurately capture the true wavefunction of an orbital."
}], "Text",
 CellChangeTimes->{{3.811870287113448*^9, 3.8118703064354777`*^9}, {
  3.8119312924786835`*^9, 3.8119313780125813`*^9}, {3.8119345157624674`*^9, 
  3.8119345320042086`*^9}, {3.811945207147476*^9, 3.81194520917002*^9}, {
  3.936280623673586*^9, 
  3.936280624162861*^9}},ExpressionUUID->"34314928-2cb3-1349-a8a6-\
31db68d6cc62"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"phi1s", "=", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{"Integrate", "[", 
      RowBox[{
       RowBox[{"Integrate", "[", 
        RowBox[{
         RowBox[{
          SuperscriptBox[
           RowBox[{"(", 
            RowBox[{
             SuperscriptBox[
              RowBox[{"(", 
               RowBox[{"1", "/", 
                RowBox[{"(", 
                 RowBox[{"\[Pi]", "*", 
                  SuperscriptBox["a", "3"]}], ")"}]}], ")"}], 
              RowBox[{"1", "/", "2"}]], "*", 
             SuperscriptBox["\[ExponentialE]", 
              RowBox[{
               RowBox[{"-", "r"}], "/", "a"}]]}], ")"}], "2"], 
          RowBox[{"Sin", "[", "\[Theta]", "]"}]}], ",", 
         RowBox[{"{", 
          RowBox[{"\[Phi]", ",", "0", ",", 
           RowBox[{"2", "\[Pi]"}]}], "}"}]}], "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"\[Theta]", ",", "0", ",", "\[Pi]"}], "}"}]}], "]"}], ")"}], 
    "^", 
    RowBox[{"(", 
     RowBox[{"1", "/", "2"}], ")"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"phigauss", "=", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{"Integrate", "[", 
       RowBox[{
        RowBox[{"Integrate", "[", 
         RowBox[{
          RowBox[{
           SuperscriptBox[
            RowBox[{"(", 
             RowBox[{
              SuperscriptBox[
               RowBox[{"(", 
                RowBox[{
                 RowBox[{"(", 
                  RowBox[{"2", "*", 
                   RowBox[{"(", 
                    RowBox[{"8", "/", 
                    RowBox[{"(", 
                    RowBox[{"9", "\[Pi]", "*", 
                    RowBox[{"a", "^", "2"}]}], ")"}]}], ")"}]}], ")"}], "/", 
                 "\[Pi]"}], ")"}], 
               RowBox[{"3", "/", "4"}]], "*", 
              SuperscriptBox["\[ExponentialE]", 
               RowBox[{
                RowBox[{"-", 
                 RowBox[{"(", 
                  RowBox[{"8", "/", 
                   RowBox[{"(", 
                    RowBox[{"9", "\[Pi]", "*", 
                    RowBox[{"a", "^", "2"}]}], ")"}]}], ")"}]}], 
                SuperscriptBox["r", "2"]}]]}], ")"}], "2"], 
           RowBox[{"Sin", "[", "\[Theta]", "]"}]}], ",", 
          RowBox[{"{", 
           RowBox[{"\[Phi]", ",", "0", ",", 
            RowBox[{"2", "\[Pi]"}]}], "}"}]}], "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"\[Theta]", ",", "0", ",", "\[Pi]"}], "}"}]}], "]"}], ")"}], 
     "^", 
     RowBox[{"(", 
      RowBox[{"1", "/", "2"}], ")"}]}]}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{"Plot", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"phi1s", "/.", 
      RowBox[{"a", "\[Rule]", "1"}]}], ",", 
     RowBox[{"phigauss", "/.", 
      RowBox[{"a", "\[Rule]", "1"}]}]}], "}"}], ",", 
