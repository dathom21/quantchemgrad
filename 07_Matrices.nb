Cell[CellGroupData[{

Cell["Properties of Determinants", "Subsection",
 CellChangeTimes->{{3.8113178590005445`*^9, 
  3.8113178639938707`*^9}},ExpressionUUID->"90c5bd0d-8a07-4c8f-add8-\
f990802d7aaf"],

Cell["\<\
There are a few properties of determinants that are worth highlighting\
\>", "Text",
 CellChangeTimes->{{3.8113178734031873`*^9, 
  3.811317883995852*^9}},ExpressionUUID->"c32eb51b-b8f9-4fe1-a13a-\
fb37909d5590"],

Cell[CellGroupData[{

Cell["The Determinant Does not Change with Matrix Transposition", \
"Subsubsection",
 CellChangeTimes->{{3.811317890501217*^9, 
  3.811317922982376*^9}},ExpressionUUID->"e63f91ff-f31c-45cb-9e7d-\
65fea9b68820"],

Cell["\<\
The determinant of a transpose matrix is equal to the determinant of the \
original matrix. In other words, if we flip the columns and rows in a matrix, \
we get the same determinant. \
\>", "Text",
 CellChangeTimes->{{3.8113179279408627`*^9, 
  3.8113179909652987`*^9}},ExpressionUUID->"39c86adb-1d88-456c-b42d-\
40ab9033a7b7"],

Cell[TextData[{
 "Remember that if we have a matrix ",
 StyleBox["A",
  FontWeight->"Bold"],
 ","
}], "Text",
 CellChangeTimes->{{3.8113179939086103`*^9, 
  3.81131800442636*^9}},ExpressionUUID->"43e55758-e66c-44a0-8fd9-\
7934afddbb88"],

Cell[BoxData[
 RowBox[{
  StyleBox["A",
   FontWeight->"Bold",
   FontSlant->"Plain"], 
  StyleBox["=",
   FontWeight->"Plain",
   FontSlant->"Plain"], 
  RowBox[{"(", "\[NoBreak]", GridBox[{
     {
      SubscriptBox[
       StyleBox["a",
        FontSlant->"Italic"], "11"], 
      SubscriptBox[
       StyleBox["a",
        FontSlant->"Italic"], "12"], 
      SubscriptBox[
       StyleBox["a",
        FontSlant->"Italic"], "13"]},
     {
      SubscriptBox[
       StyleBox["a",
        FontSlant->"Italic"], "21"], 
      SubscriptBox[
       StyleBox["a",
        FontSlant->"Italic"], "22"], 
      SubscriptBox[
       StyleBox["a",
        FontSlant->"Italic"], "23"]},
     {
      SubscriptBox[
       StyleBox["a",
        FontSlant->"Italic"], "31"], 
      SubscriptBox[
       StyleBox["a",
        FontSlant->"Italic"], "32"], 
      SubscriptBox[
       StyleBox["a",
        FontSlant->"Italic"], "33"]}
    }], "\[NoBreak]", ")"}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.811253718311788*^9, 
  3.8112538382526913`*^9}},ExpressionUUID->"879723d4-d58f-426e-b55e-\
d81acb465af3"],

Cell[TextData[{
 "then its transpose ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    StyleBox["A",
     FontSlant->"Plain"], 
    StyleBox["T",
     FontSlant->"Plain"]], TraditionalForm]],
  FontWeight->"Bold",ExpressionUUID->"9bd4f8b7-99a0-4c04-81d9-de1842852ce4"],
 " is given by"
}], "Text",
 CellChangeTimes->{{3.8113180200922136`*^9, 
  3.811318047849637*^9}},ExpressionUUID->"c2af4cd9-6634-4d58-8007-\
fa02ca64ae69"],

