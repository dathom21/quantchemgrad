Cell[CellGroupData[{

Cell["Postulate 3: Observables are Eigenvalues", "Section",
 CellChangeTimes->{{3.808060504164093*^9, 
  3.808060537881735*^9}},ExpressionUUID->"3e6ae344-1451-41be-ac9e-\
3781a3452055"],

Cell[CellGroupData[{

Cell["Statement of the Postulate", "Subsection",
 CellChangeTimes->{{3.8080605570185547`*^9, 
  3.8080605593762374`*^9}},ExpressionUUID->"3bd0671f-7722-4a83-80be-\
113ea0996922"],

Cell[TextData[{
 "For the measurement of an observable associated with the operator ",
 Cell[BoxData[
  FormBox[
   OverscriptBox["A", "^"], TraditionalForm]],ExpressionUUID->
  "75ec6ab8-cbe2-44fc-9cee-ab42c4817258"],
 ", the only observables that can be measured are the eigenvalues ",
 StyleBox["a ",
  FontSlant->"Italic"],
 "that are obtained from the eigenvalue equation"
}], "Text",
 CellChangeTimes->{{3.8080606555925264`*^9, 3.808060720694504*^9}, {
  3.8080607856341257`*^9, 3.8080607866034327`*^9}, {3.914861591249027*^9, 
  3.9148615955711803`*^9}},ExpressionUUID->"603ce72d-345b-417b-b376-\
ac3b204cb5f2"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   OverscriptBox[
    StyleBox["A",
     FontSlant->"Italic"], "^"], "\[Psi]"}], "=", 
  StyleBox[
   RowBox[{
    StyleBox["a",
     FontSlant->"Italic"], "\[Psi]"}]]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8080607357869864`*^9, 
  3.8080607755141954`*^9}},ExpressionUUID->"60bc9166-0b04-4e28-9581-\
c0aabcda89f6"],

Cell[TextData[{
 "In a way, this statement says that the values measured are quantized. In \
the case of equation (3), the wavefunction \[Psi] is an eigenstate (or \
eigenfunction) of the operator ",
 Cell[BoxData[
  FormBox[
   OverscriptBox["A", "^"], TraditionalForm]],ExpressionUUID->
  "1ea276ad-3a10-4701-92e5-a121bd4ef5b6"],
 ". If a system is in this state, measurement will always yield ",
 StyleBox["a",
  FontSlant->"Italic"],
 "."
}], "Text",
 CellChangeTimes->{{3.8080608559791756`*^9, 3.808060963820855*^9}, {
  3.9148616020471306`*^9, 
  3.9148616029405947`*^9}},ExpressionUUID->"6ddbff1d-f67c-4137-8824-\
0abf7842e2ae"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Initial States don\[CloseCurlyQuote]t Have to Be Eigenstates", \
"Subsection",
 CellChangeTimes->{{3.8080611325643697`*^9, 
  3.8080611467217765`*^9}},ExpressionUUID->"ff5c135b-aec6-4743-9289-\
86b528b4bb17"],

Cell[TextData[{
 "Although we can only measure eigenvalues corresponding to eigenstates, the \
postulate does ",
 StyleBox["not",
  FontSlant->"Italic"],
 " say that a system must be in an eigenstate ",
 StyleBox["before",
  FontSlant->"Italic"],
 " measurement. In general, an operator may have many eigenvalues and \
eigenstates given by"
}], "Text",
 CellChangeTimes->{{3.8080611511070232`*^9, 
  3.8080612500962334`*^9}},ExpressionUUID->"c35f0ea7-6188-41e3-bcee-\
e8778bc7175b"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   OverscriptBox[
    StyleBox["A",
     FontSlant->"Italic"], "^"], 
   SubscriptBox["\[Psi]", 
    StyleBox["i",
     FontSlant->"Italic"]]}], "=", 
  RowBox[{
   SubscriptBox[
    StyleBox["a",
     FontSlant->"Italic"], 
    StyleBox["i",
     FontSlant->"Italic"]], 
   SubscriptBox["\[Psi]", 
    StyleBox["i",
     FontSlant->"Italic"]]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8080607357869864`*^9, 3.8080607755141954`*^9}, {
  3.8080612597228193`*^9, 
  3.808061286149102*^9}},ExpressionUUID->"8f7ba522-86d4-473e-aaf6-\
0f25cef59828"],

Cell["\<\
the state of a given system could be a linear combination of these \
eigenstates,\
\>", "Text",
 CellChangeTimes->{{3.808061298828968*^9, 
  3.8080613222053623`*^9}},ExpressionUUID->"1ae3401b-a6cd-46a6-9404-\
77df7faedd13"],

Cell[BoxData[
 RowBox[{"\[Psi]", "=", 
  RowBox[{
   UnderoverscriptBox["\[Sum]", 
    StyleBox["i",
     FontSlant->"Italic"], 
    StyleBox["n",
     FontSlant->"Italic"]], 
   RowBox[{
    SubscriptBox[
     StyleBox["c",
      FontSlant->"Italic"], 
     StyleBox["i",
      FontSlant->"Italic"]], 
    SubscriptBox["\[Psi]", 
     StyleBox["i",
      FontSlant->"Italic"]]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8080607357869864`*^9, 3.8080607755141954`*^9}, {
  3.8080612597228193`*^9, 3.808061286149102*^9}, {3.808061346708061*^9, 
  3.8080613907746305`*^9}, {3.808061427687052*^9, 3.8080614293972893`*^9}, {
  3.808061466627264*^9, 
  3.8080614837205973`*^9}},ExpressionUUID->"4394d29e-9615-4a83-b8e9-\
e3320b7a70b4"],

Cell[TextData[{
 "In this case, we only know that our measurement will return one of the \
values of ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["a",
    FontSlant->"Italic"], 
   StyleBox["i",
    FontSlant->"Italic"]]],
  CellChangeTimes->{{3.8080607357869864`*^9, 3.8080607755141954`*^9}, {
   3.8080612597228193`*^9, 3.808061286149102*^9}},ExpressionUUID->
  "b4b71dc0-6e4b-443e-b273-52f0be94afb0"],
 ", although we can\[CloseCurlyQuote]t say which one. However, we can say the \
probability of each one. More about that in the next postulate."
}], "Text",
 CellChangeTimes->{{3.808061507157228*^9, 3.808061557680842*^9}, {
  3.8080616091997347`*^9, 3.8080616730499215`*^9}, {3.8080617724989815`*^9, 
  3.808061779677829*^9}},ExpressionUUID->"40cb7844-81b8-418b-9c93-\
cb586a401f82"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Wavefunction Collapse", "Subsection",
 CellChangeTimes->{{3.808062033752186*^9, 
  3.808062036378975*^9}},ExpressionUUID->"d60719e7-7542-4130-a119-\
ddd9508c3194"],

Cell[TextData[{
 "Another important part of this postulate is that ",
 StyleBox["after",
  FontSlant->"Italic"],
 " measurement, the wavefunction \[OpenCurlyDoubleQuote]collapses\
\[CloseCurlyDoubleQuote], and the system is in the eigenstate ",
 Cell[BoxData[
  SubscriptBox["\[Psi]", 
   StyleBox["i",
    FontSlant->"Italic"]]],
  CellChangeTimes->{{3.8080607357869864`*^9, 3.8080607755141954`*^9}, {
   3.8080612597228193`*^9, 3.808061286149102*^9}, {3.808061346708061*^9, 
   3.8080613907746305`*^9}, {3.808061427687052*^9, 3.8080614293972893`*^9}, {
   3.808061466627264*^9, 3.8080614837205973`*^9}},ExpressionUUID->
  "ca36e27b-a302-4072-841d-3c9048bce31e"],
 " corresponding to the measured eigenvalue ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["a", "i"], TraditionalForm]],ExpressionUUID->
  "137c0d91-67c6-4485-bc6b-bf570d05aafb"],
 ". This part of the postulate is considered strange and mysterious, but it \
ultimately means that measurement affects the state of the system."
}], "Text",
 CellChangeTimes->{{3.808061782488945*^9, 3.8080618959866867`*^9}, {
  3.8407235516496286`*^9, 3.840723554241497*^9}, {3.840724882742073*^9, 
  3.8407248828301396`*^9}, {3.9344568083899155`*^9, 
  3.9344568085784283`*^9}},ExpressionUUID->"37a8bf7f-dc1f-43b0-a745-\
19d2bef7be5a"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Eigenstates are Orthogonal", "Subsection",
 CellChangeTimes->{{3.808062019718021*^9, 
  3.8080620254293494`*^9}},ExpressionUUID->"ae58b19b-3038-4d85-9ac1-\
921e40c76a71"],

Cell["\<\
Remember that Hermitian operators have orthogonal eigenfunctions (also called \
eigenstates). Because quantum mechanical operators are Hermitian, their \
eigenstates are (or can be chosen to be) orthogonal.\
\>", "Text",
 CellChangeTimes->{{3.8080620408829*^9, 3.8080620931622033`*^9}, {
  3.8407249032859697`*^9, 3.8407249040047164`*^9}, {3.9148617925278816`*^9, 
  3.9148618254140825`*^9}},ExpressionUUID->"7f18dd0a-28e8-430c-882d-\
2478e8f7edbd"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Postulate 4: The Expectation Value", "Section",
 CellChangeTimes->{{3.808062109224345*^9, 
  3.80806214008945*^9}},ExpressionUUID->"768e8707-0cad-4158-8da2-\
00141a360d52"],

Cell[CellGroupData[{

Cell["Statement of the Postulate", "Subsection",
 CellChangeTimes->{{3.808062145273028*^9, 
  3.8080621502365804`*^9}},ExpressionUUID->"4d8be6ae-9633-408d-9f58-\
ee5cc600506c"],

Cell[TextData[{
 "If a system is described by a normalized wavefunction \[Psi] (i.e.,  ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubsuperscriptBox["\[Integral]", 
      RowBox[{"-", "\[Infinity]", " "}], "\[Infinity]"], " ", 
     RowBox[{
      SuperscriptBox["\[Psi]", "\[Star]"], "\[Psi]"}]}], "=", "1"}], 
   TraditionalForm]],ExpressionUUID->"2ac177af-310e-4d56-8c20-698e28f21f67"],
 "), then the average value of the observable corresponding to a given \
quantum mechanical operator ",
 Cell[BoxData[
  FormBox[
   OverscriptBox["A", "^"], TraditionalForm]],ExpressionUUID->
  "d60d74a9-5dcb-426c-93d3-a1344eb9487a"],
 " is given by"
}], "Text",
 CellChangeTimes->{{3.8080621649627943`*^9, 
  3.808062341509244*^9}},ExpressionUUID->"df720dc0-123b-4e2d-a3c8-\
d81adf077e57"],

Cell[BoxData[
 RowBox[{
  RowBox[{"<", 
   StyleBox["A",
    FontSlant->"Italic"], ">"}], " ", "=", 
  RowBox[{
   SubsuperscriptBox["\[Integral]", 
    RowBox[{"-", "\[Infinity]"}], "\[Infinity]"], 
   RowBox[{
    SuperscriptBox["\[Psi]", "\[Star]"], 
    RowBox[{"(", 
     RowBox[{
      StyleBox["r",
       FontWeight->"Bold",
       FontSlant->"Italic"], ",", 
      StyleBox["t",
       FontSlant->"Italic"]}], 
     StyleBox[")",
      FontSlant->"Italic"]}], 
    OverscriptBox[
     StyleBox["A",
      FontSlant->"Italic"], "^"], "\[Psi]", 
    RowBox[{"(", 
     RowBox[{
      StyleBox["r",
       FontWeight->"Bold",
       FontSlant->"Italic"], ",", 
      StyleBox["t",
       FontSlant->"Italic"]}], 
     StyleBox[")",
      FontSlant->"Italic"]}], 
    StyleBox[
     RowBox[{
      StyleBox["d",
       FontSlant->"Italic"], "\[Tau]"}]]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8079664251944246`*^9, 3.8079664343142004`*^9}, {
   3.8079689400739555`*^9, 3.8079689680029573`*^9}, {3.807970315263204*^9, 
   3.8079703215316095`*^9}, {3.807970415909548*^9, 3.807970437015459*^9}, {
