    StyleBox[
     SubscriptBox["v", "x"],
     FontSlant->"Italic"], ")"}]}], "=", 
  RowBox[{
   StyleBox[
    SqrtBox[
     FractionBox[
      StyleBox["M",
       FontSlant->"Italic"], 
      RowBox[{"2", "\[Pi]", " ", 
       StyleBox["RT",
        FontSlant->"Italic"]}]]],
    FontSlant->"Plain"], 
