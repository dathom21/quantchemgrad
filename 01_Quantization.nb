          RowBox[{"FontFamily", "\[Rule]", "\"\<Arial\>\""}], ",", 
          RowBox[{"FontSize", "\[Rule]", "16"}]}], "}"}]}], ",", 
       RowBox[{"PlotStyle", "\[Rule]", 
        RowBox[{"{", 
         RowBox[{"Red", ",", "Blue"}], "}"}]}], ",", 
       RowBox[{"Frame", "\[Rule]", "True"}], ",", 
       RowBox[{"FrameLabel", "\[Rule]", 
        RowBox[{"{", 
         RowBox[{"\"\<\[Lambda] [nm]\>\"", ",", 
          RowBox[{"Row", "[", 
           RowBox[{"{", 
            RowBox[{"\"\<Spectral Radiance [kW \>\"", ",", 
             RowBox[{"Superscript", "[", 
              RowBox[{"\"\<sr\>\"", ",", "\"\<-1\>\""}], "]"}], ",", 
             "\"\< \>\"", ",", 
             RowBox[{"Superscript", "[", 
              RowBox[{"\"\<m\>\"", ",", "\"\<-2\>\""}], "]"}], ",", 
             "\"\< \>\"", ",", " ", 
             RowBox[{"Superscript", "[", 
