          StyleBox["r",
           FontSlant->"Italic"], ")"}], 
         StyleBox["Y",
          FontSlant->"Italic"], 
         RowBox[{"(", 
          RowBox[{"\[Theta]", ",", "\[Phi]"}], ")"}]}], 
        RowBox[{"\[PartialD]", 
         SuperscriptBox["\[Phi]", "2"]}]], ")"}]}]}], "]"}], "-", 
   RowBox[{"2", 
