Cell[CellGroupData[{

Cell["The Harmonic Oscillator as a Model for a Diatomic Molecule", \
"Subsection",
 CellChangeTimes->{{3.8099673330453844`*^9, 3.8099673448804846`*^9}, {
  3.920800898253855*^9, 
  3.9208008994525332`*^9}},ExpressionUUID->"be83b34a-f106-0c40-98dd-\
bef5a30361e5"],

Cell[TextData[{
 "The harmonic oscillator does a good job of modeling the shape of the \
internuclear potential between two atoms. The internuclear potential \
describes how the potential energy ",
 StyleBox["E",
  FontSlant->"Italic"],
 " changes with the distance between the two atoms ",
 StyleBox["r",
  FontSlant->"Italic"],
 ". The solid line in Figure 13.2 shows a typical shape of such an \
internuclear potential for a diatomic molecule. "
}], "Text",
 CellChangeTimes->{{3.809967525642034*^9, 3.809967538668503*^9}, {
  3.809967587973505*^9, 3.8099679988388023`*^9}, {3.920646716111106*^9, 
  3.920646717566512*^9}, {3.920732456286234*^9, 3.9207324577233896`*^9}, {
  3.9399004546827374`*^9, 
  3.939900454949463*^9}},ExpressionUUID->"f7efc61d-b92a-124f-a825-\
e3de04665e06"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"Clear", "[", "k", "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"data", "=", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"x", ",", 
       RowBox[{
        RowBox[{"De", "*", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"1", "-", 
            RowBox[{"Exp", "[", 
             RowBox[{
              RowBox[{"-", "a"}], "*", "x"}], "]"}]}], ")"}], "^", "2"}]}], "/.", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"De", "\[Rule]", "1.5"}], ",", 
          RowBox[{"a", "\[Rule]", "1"}]}], "}"}]}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", 
       RowBox[{"-", "1.5"}], ",", "2", ",", "0.1"}], "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"fit", "=", 
   RowBox[{"NonlinearModelFit", "[", 
    RowBox[{"data", ",", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"1", "/", "2"}], ")"}], "*", "k", "*", 
      RowBox[{"x", "^", "2"}]}], ",", "k", ",", "x"}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{"Plot", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{"De", "*", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"1", "-", 
          RowBox[{"Exp", "[", 
           RowBox[{
            RowBox[{"-", "a"}], "*", "x"}], "]"}]}], ")"}], "^", "2"}]}], "/.", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"De", "\[Rule]", "1.5"}], ",", 
        RowBox[{"a", "\[Rule]", "1"}]}], "}"}]}], ",", 
     RowBox[{
      RowBox[{
       RowBox[{"(", 
        RowBox[{"1", "/", "2"}], ")"}], "*", "k", "*", 
       RowBox[{"x", "^", "2"}]}], "/.", 
      RowBox[{"k", "\[Rule]", 
       RowBox[{
        RowBox[{"fit", "[", "\"\<ParameterTableEntries\>\"", "]"}], "[", 
        RowBox[{"[", 
         RowBox[{"1", ",", "1"}], "]"}], "]"}]}]}]}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"x", ",", 
     RowBox[{"-", "2"}], ",", "5"}], "}"}], ",", 
   RowBox[{"PlotRange", "\[Rule]", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"-", "2"}], ",", "5"}], "}"}], ",", 
      RowBox[{"{", 
