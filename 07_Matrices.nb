  ExpressionUUID->"bbd17b1c-9235-40e4-a3d5-cb11d44d8bbe"],
 " when they mean ",
 Cell[BoxData[
  SuperscriptBox[
   StyleBox["a",
    FontWeight->"Bold",
    FontSlant->"Plain"], 
   StyleBox["H",
    FontWeight->"Bold"]]],
  CellChangeTimes->{{3.8112559638442764`*^9, 3.8112559741396627`*^9}, {
    3.8113221103126726`*^9, 3.811322130222258*^9}, 3.8113221675383205`*^9, {
