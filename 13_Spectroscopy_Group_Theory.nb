Cell[CellGroupData[{

Cell[TextData[{
 "Rotation by 360/",
 StyleBox["n",
  FontSlant->"Italic"],
 " About Axis of Symmetry: ",
 Cell[BoxData[
  FormBox[
   SubscriptBox[
    OverscriptBox["C", "^"], "n"], TraditionalForm]],ExpressionUUID->
  "22345455-e3e2-46eb-bc84-8b623c0d9c28"]
}], "Subsubsection",
 CellChangeTimes->{{3.8162549628369784`*^9, 3.816255011616164*^9}, {
   3.8162550967681465`*^9, 3.8162551606968794`*^9}, 
   3.816256542192726*^9},ExpressionUUID->"50332122-d2c3-4297-b8b0-\
0b5a2db80fa5"],

Cell[TextData[{
 "In this symmetry operation, rotation about an axis by ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["360", "\[Degree]"], "/", 
    StyleBox["n",
     FontSlant->"Italic"]}], TraditionalForm]],ExpressionUUID->
  "6d012b33-78e1-4801-bcef-c0a0e816cd7a"],
 " leaves the molecule unchanged. This process is also known as proper \
rotation. The value of ",
 StyleBox["n",
  FontSlant->"Italic"],
 " is known as the order of the axis, and we label the axis as ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["C", "n"], TraditionalForm]],ExpressionUUID->
  "ea59b360-3655-4f76-989d-3cb4f0cae194"],
 ". Molecules can have more than rotation axis; water has a single ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["C", "2"], TraditionalForm]],ExpressionUUID->
  "d39cf4be-4aaa-41ec-93d0-8899272bbdfe"],
 " axis, whereas ethane contains three ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["C", "2"], TraditionalForm]],ExpressionUUID->
  "a6079bff-9280-436f-8169-14f55b26c922"],
 " axes and one ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["C", "3"], TraditionalForm]],ExpressionUUID->
  "d4344b89-1766-430c-a10b-daf90b46178e"],
 " axis (Figure 13.10). The rotation axis with the highest value of ",
 StyleBox["n",
  FontSlant->"Italic"],
 " is called the principle rotation axis."
}], "Text",
 CellChangeTimes->{{3.816255028085107*^9, 3.816255042224386*^9}, {
   3.816255174929759*^9, 3.81625548899119*^9}, {3.8162568432362146`*^9, 
   3.816256855414302*^9}, 3.9398953418090744`*^9, {3.940090468002058*^9, 
   3.94009046833362*^9}},ExpressionUUID->"1e9da365-a87e-44ba-941a-\
e4ff9e448d48"],

