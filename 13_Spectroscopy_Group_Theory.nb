        RowBox[{"-", "0.6457718232379019`"}], "]"}]}], ",", "0", ",", 
      RowBox[{"Sin", "[", 
       RowBox[{"-", "0.6457718232379019`"}], "]"}]}], "}"}]}]}]}]], "Input",
 CellGroupingRules->{"GroupTogetherGrouping", 8003.},
 InitializationCell->True,
 CellChangeTimes->{{3.7820179878980265`*^9, 3.782018118709156*^9}, 
   3.783082351665434*^9, {3.7832639865029793`*^9, 3.783263999022834*^9}, 
   3.788641533567061*^9},
 CellID->1463192571,ExpressionUUID->"69c6a56b-ee12-43db-94ca-82322890b5da"],

Cell[BoxData[
 RowBox[{
  RowBox[{"hdxbend", "[", "t_", "]"}], ":=", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{"4", "*", 
     RowBox[{"Cos", "[", 
      RowBox[{
       RowBox[{"-", "0.6457718232379019`"}], "+", 
       RowBox[{"(", 
        RowBox[{"0.4", "*", 
         RowBox[{"Sin", "[", 
          RowBox[{"4", "t"}], "]"}]}], ")"}]}], "]"}]}], ",", "0", ",", 
    RowBox[{"4", "*", 
     RowBox[{"Sin", "[", 
