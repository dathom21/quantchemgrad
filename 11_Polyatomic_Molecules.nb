Cell[TextData[{
 StyleBox["Figure 11.6",
  FontWeight->"Bold"],
 ". Schematic representation of the bonding and antibonding \[Pi] molecular \
orbitals of ethene in the H\[UDoubleDot]ckel approximation. Modified from: \
Wikimedia, Mmurali13, Public Domain, \
https://commons.wikimedia.org/wiki/File:Butadiene_Ethene_Cycloaddition123.png"
}], "Affiliation",
 CellChangeTimes->CompressedData["
1:eJxTTMoPSmViYGCQAGIQPeNH5qbXiW8cy6t7doDoiRfCxd8A6ZBDtWA6NlRg
2Ucgzeepug5EC2S27BZIAtJry/eD6DMqRj/fA+kjLKbMH4B0E3PHSv6UN44X
