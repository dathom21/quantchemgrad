  3.921327638682242*^9}},ExpressionUUID->"f2a055f1-e410-4523-a654-\
ff25d31f71fd"],

Cell["Consulting a table of integrals, we observe that ", "Text",
 CellChangeTimes->{{3.921327651641358*^9, 
  3.9213276591719894`*^9}},ExpressionUUID->"771a41b0-040e-4f91-ae31-\
cb373f3cc533"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   SubsuperscriptBox["\[Integral]", "0", "\[Infinity]"], 
   RowBox[{
    SuperscriptBox["\[ExponentialE]", 
     RowBox[{"-", 
      SuperscriptBox[
       StyleBox["bx",
        FontSlant->"Italic"], "2"]}]], 
    RowBox[{"\[DifferentialD]", 
     StyleBox["x",
      FontSlant->"Italic"]}]}]}], "=", 
  RowBox[{
   FractionBox["1", "2"], 
   SqrtBox[
    FractionBox["\[Pi]", 
     StyleBox["b",
      FontSlant->"Italic"]]]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.9157930562642484`*^9, 3.915793118884077*^9}, {
  3.915793154111902*^9, 3.9157931619313087`*^9}, {3.9213277592613125`*^9, 
  3.921327763994608*^9}, {3.9213278279559307`*^9, 
  3.921327831539187*^9}},ExpressionUUID->"961063df-068c-48c9-b331-\
89b6cc1ac641"],

Cell["So we find that ", "Text",
 CellChangeTimes->{{3.9213277732644444`*^9, 
  3.921327774571316*^9}},ExpressionUUID->"cbf64b89-1b41-499c-be97-\
e415f0add483"],

Cell[BoxData[
 RowBox[{
  SubscriptBox[
   StyleBox["Z",
    FontSlant->"Italic"], 
   SubscriptBox["\[CurlyEpsilon]", 
    StyleBox["trans",
     FontSlant->"Italic"]]], "=", 
  RowBox[{
   SuperscriptBox[
    RowBox[{"(", 
     RowBox[{
      FractionBox["1", "2"], 
      SqrtBox[
       FractionBox[
        RowBox[{"8", 
         StyleBox[
          RowBox[{"\[Pi]", 
           StyleBox["m",
            FontSlant->"Italic"]}]], 
         StyleBox[" ",
          FontSlant->"Italic"], 
         SuperscriptBox[
          StyleBox["a",
           FontSlant->"Italic"], "2"]}], 
        SuperscriptBox[
         StyleBox[
          RowBox[{
           StyleBox["\[Beta]",
            FontSlant->"Plain"], 
           StyleBox["h",
            FontSlant->"Italic"]}]], "2"]]]}], ")"}], "3"], "=", 
   RowBox[{
    SuperscriptBox[
     RowBox[{"(", 
      RowBox[{
       FractionBox["2", "2"], 
       StyleBox["a",
        FontSlant->"Italic"], 
       SqrtBox[
        FractionBox[
         RowBox[{"2", "\[Pi]", " ", 
          StyleBox["m",
           FontSlant->"Italic"], 
          StyleBox["  ",
           FontSlant->"Italic"]}], 
         SuperscriptBox[
          StyleBox[
           RowBox[{
            StyleBox["\[Beta]",
             FontSlant->"Plain"], 
            StyleBox["h",
             FontSlant->"Italic"]}]], "2"]]]}], ")"}], "3"], "=", 
    RowBox[{
     SuperscriptBox[
      StyleBox["a",
       FontSlant->"Italic"], "3"], 
     SuperscriptBox[
      RowBox[{"(", 
       FractionBox[
        RowBox[{"2", "\[Pi]", " ", 
         StyleBox["m",
          FontSlant->"Italic"], 
         StyleBox[" ",
          FontSlant->"Italic"], 
         SubscriptBox[
          StyleBox["k",
           FontSlant->"Italic"], 
          StyleBox["B",
           FontSlant->"Italic"]], 
         StyleBox["T",
          FontSlant->"Italic"], 
         StyleBox[" ",
          FontSlant->"Italic"]}], 
        SuperscriptBox[
         StyleBox["h",
          FontSlant->"Italic"], "2"]], ")"}], 
      RowBox[{"3", "/", "2"}]]}]}]}]}]], "DisplayFormulaNumbered",
