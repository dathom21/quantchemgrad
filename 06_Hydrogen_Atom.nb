Cell[TextData[{
 "Because our Coulombic potential also depends on ",
 StyleBox["r",
  FontSlant->"Italic"],
 ", we want to group it with the ",
 StyleBox["R",
  FontSlant->"Italic"],
 "(",
 StyleBox["r",
  FontSlant->"Italic"],
 ") terms, so we rewrite the equation as."
