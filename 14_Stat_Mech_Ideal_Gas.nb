Cell[CellGroupData[{

Cell["One-Dimensional Velocity Distribution", "Subsection",
 CellChangeTimes->{{3.921423220709637*^9, 
  3.921423229798174*^9}},ExpressionUUID->"74bb06d5-6bce-415a-8c48-\
fde28663985a"],

Cell[TextData[{
 "Let us now consider the fraction of particles having a velocity in the \
velocity \[OpenCurlyDoubleQuote]volume\[CloseCurlyDoubleQuote] of ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["v", "x"], "+", 
    RowBox[{"\[DifferentialD]", 
     SubscriptBox["v", "x"]}]}], TraditionalForm]],ExpressionUUID->
  "8e58a3f5-2125-4940-b5e6-fc5dc0ecf7b9"],
 ", ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["v", "y"], "+", 
    RowBox[{"\[DifferentialD]", 
     SubscriptBox["v", "y"]}]}], TraditionalForm]],ExpressionUUID->
  "3108565a-391e-4d54-bbd7-45528f0431c9"],
 ", ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["v", "z"], "+", 
    RowBox[{"\[DifferentialD]", 
     SubscriptBox["v", "z"]}]}], TraditionalForm]],ExpressionUUID->
  "e30df9dd-001b-4ae2-8f77-65bdeb33c449"],
 ". We can describe this fraction by a \[OpenCurlyDoubleQuote]density\
\[CloseCurlyDoubleQuote] of states multiplied by the infinitesimal volume \
element,  ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[CapitalOmega]", "(", 
     RowBox[{
      SubscriptBox["v", "x"], ",", 
      SubscriptBox["v", "y"], ",", 
      SubscriptBox["v", "z"]}], ")"}], 
    RowBox[{"\[DifferentialD]", 
     SubscriptBox["v", "x"]}], 
    RowBox[{"\[DifferentialD]", 
     SubscriptBox["v", "y"]}], 
    RowBox[{"\[DifferentialD]", 
     SubscriptBox["v", "z"]}]}], TraditionalForm]],ExpressionUUID->
  "b4fcd50b-b98d-499c-add5-1fe37dff2226"],
 ". From assumption number five above, we can conclude that the directional \
dependence must be separable,"
}], "Text",
 CellChangeTimes->{{3.9214232449317513`*^9, 3.921423333298358*^9}, {
  3.9214237590624275`*^9, 3.9214238807537355`*^9}, {3.9214863994083695`*^9, 
