      StyleBox["r",
       FontWeight->"Bold",
       FontSlant->"Italic"], 
      StyleBox[")",
       FontSlant->"Italic"]}]}]}]}]}], "\[IndentingNewLine]", 
 RowBox[{"\t\t\t\t\t\t     ", 
  RowBox[{"=", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      SubscriptBox[
       StyleBox["E",
        FontSlant->"Italic"], 
       StyleBox["N",
        FontSlant->"Italic"]], "+", 
      SubscriptBox[
       StyleBox["E",
