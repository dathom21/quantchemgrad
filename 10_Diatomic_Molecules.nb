Cell[TextData[{
 StyleBox["Figure 10.5",
  FontWeight->"Bold"],
 ". Plot of the bonding ( ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Psi]", "+"], TraditionalForm]],ExpressionUUID->
  "79672373-edea-4da5-b47a-e7b1642e2355"],
 ") and antibonding (",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Psi]", "-"], TraditionalForm]],ExpressionUUID->
  "48243932-83e6-4134-9600-91d85089ba20"],
 ") orbitals along the internuclear axis of ",
 Cell[BoxData[
  FormBox[
   SubsuperscriptBox[
    StyleBox["H",
     FontSlant->"Plain"], "2", "+"], TraditionalForm]],ExpressionUUID->
  "f13e6c7f-c939-4765-ab06-a62911e65eee"],
 ". The wavefunctions are plotted in the top row, and the corresponding \
probability functions (",
 Cell[BoxData[
  FormBox[
   RowBox[{"|", 
    SubscriptBox["\[Psi]", "+"], 
    SuperscriptBox["|", "2"]}], TraditionalForm]],ExpressionUUID->
  "c156f128-6449-49e3-91dd-a05db8d52470"],
 " and  ",
 Cell[BoxData[
  FormBox[
   RowBox[{"|", 
    SubscriptBox["\[Psi]", "-"], 
    SuperscriptBox["|", "2"]}], TraditionalForm]],ExpressionUUID->
  "58556a67-3ff6-4b4a-bfc2-5c4e2db79c28"],
 " ) are plotted in the bottom row."
}], "Affiliation",
 CellChangeTimes->{{3.809435027311596*^9, 3.8094350763900714`*^9}, {
   3.80943583474421*^9, 3.8094358359299717`*^9}, {3.8094472165104203`*^9, 
   3.809447281165168*^9}, {3.809510876137825*^9, 3.809510907739876*^9}, {
   3.809968073566992*^9, 3.8099681536568317`*^9}, {3.810557260250428*^9, 
   3.8105572606139913`*^9}, {3.8130835305386977`*^9, 
   3.8130836194514275`*^9}, {3.813224407772764*^9, 3.8132244817756805`*^9}, {
   3.8132354037950773`*^9, 3.813235501614183*^9}, 3.813236418234542*^9, {
   3.81351439000795*^9, 3.8135143988971663`*^9}, {3.813665905470446*^9, 
   3.8136660007466154`*^9}, {3.919512612573656*^9, 3.919512613028652*^9}, {
   3.9374875558302307`*^9, 
   3.937487556479658*^9}},ExpressionUUID->"b9960193-625f-4b6e-945e-\
582d69429731"],

Cell["\<\
We see that in the visualization along the internuclear axis, the probability \
of finding an electron halfway between the two nuclei is nonzero for the \
bonding orbital (corresponding to electron sharing, or the formation of a \
covalent bond), whereas the probability is zero in the antibonding orbital \
(no covalent bond formation). Note that this internuclear plot does not \
capture the full three-dimensional shape of the bonding and antibonding \
orbitals, which can be visualized using the interactive feature in Figure \
10.6.\
\>", "Text",
 CellChangeTimes->{{3.8136657170739956`*^9, 3.813665828839513*^9}, {
  3.8136658739754725`*^9, 3.8136658960518937`*^9}, {3.8136660099807825`*^9, 
  3.813666035728628*^9}, {3.813684535196374*^9, 3.8136845358369093`*^9}, {
  3.9195126249487505`*^9, 3.91951262532419*^9}, {3.9374875708766174`*^9, 
  3.9374875712405415`*^9}},ExpressionUUID->"b5772175-5e7c-4f3b-a0a5-\
42f553de537d"],

