Cell[CellGroupData[{

Cell["Beyond the Two-Electron System", "Subsection",
 CellChangeTimes->{{3.812629104872365*^9, 
  3.812629115951785*^9}},ExpressionUUID->"86d110e6-60c8-4f86-a257-\
872fcc2755c9"],

Cell["\<\
Unfortunately, the convenient separation of the spin and spatial components \
does not hold generally, and we cannot ignore the spin contributions for any \
system with more than two electrons. The question then becomes how to easily \
write a properly antisymmetrized wavefunction for a multielectron system. \
Although it\[CloseCurlyQuote]s not necessary in the case of helium, we can \
still use this two-electron system to illustrate some principles that we can \
apply to larger system. Let\[CloseCurlyQuote]s look again at our normalized, \
antisymmetrized wavefunction for the helium atom,\
\>", "Text",
 CellChangeTimes->{{3.812629118108698*^9, 
  3.8126292578464785`*^9}},ExpressionUUID->"4322405e-cf84-4cdf-be50-\
70693d449fdf"],

Cell[BoxData[
 RowBox[{
  RowBox[{"\[Psi]", 
   RowBox[{"(", 
    RowBox[{
     SubscriptBox[
      StyleBox["r",
       FontWeight->"Bold",
       FontSlant->"Italic"], "1"], ",", 
     SubscriptBox["\[Sigma]", "1"], ",", " ", 
     SubscriptBox[
      StyleBox["r",
       FontWeight->"Bold",
       FontSlant->"Italic"], "2"], ",", 
     SubscriptBox["\[Sigma]", "2"]}], ")"}]}], "=", 
  RowBox[{
   FractionBox["1", 
    SqrtBox["2"]], "[", 
   RowBox[{
    RowBox[{"\[Phi]", 
     RowBox[{"(", 
      SubscriptBox[
       StyleBox["r",
        FontWeight->"Bold",
        FontSlant->"Italic"], "1"], ")"}], "\[Alpha]", 
     RowBox[{"(", 
      SubscriptBox["\[Sigma]", "1"], ")"}], "\[Phi]", 
     RowBox[{"(", 
      SubscriptBox[
       StyleBox["r",
        FontWeight->"Bold",
        FontSlant->"Italic"], "2"], ")"}], "\[Beta]", 
     RowBox[{"(", 
      SubscriptBox["\[Sigma]", "2"], ")"}]}], "-", 
    RowBox[{"\[Phi]", 
     RowBox[{"(", 
      SubscriptBox[
       StyleBox["r",
        FontWeight->"Bold",
        FontSlant->"Italic"], "1"], ")"}], "\[Beta]", 
     RowBox[{"(", 
      SubscriptBox["\[Sigma]", "1"], ")"}], "\[Phi]", 
     RowBox[{"(", 
      SubscriptBox[
       StyleBox["r",
        FontWeight->"Bold",
        FontSlant->"Italic"], "2"], ")"}], "\[Alpha]", 
     RowBox[{"(", 
      SubscriptBox["\[Sigma]", "2"], ")"}]}]}], 
   "]"}]}]], "DisplayFormulaNumbered",
