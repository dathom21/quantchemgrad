    3.8109948950763626`*^9}, {3.8109949491606197`*^9, 3.810995087249513*^9}, {
    3.8109951188614283`*^9, 3.8109951226144466`*^9}, {3.8115998145208507`*^9, 
    3.8115999093225703`*^9}, 3.8119468581508093`*^9, {3.8126173912859564`*^9, 
    3.8126174353481674`*^9}, {3.812617986792708*^9, 3.812617987701547*^9}, {
    3.8126194925193796`*^9, 3.812619503416272*^9}, {3.812619551056244*^9, 
    3.812619564308283*^9}, {3.81263028454834*^9, 3.8126303987426214`*^9}},
  ExpressionUUID->"6036a267-dff6-49f0-8299-8726e71df93f"],
 ", then we have two columns that are the same. Remember that a determinant \
with two columns that are the same returns a value of zero, so the Slater \
determinant also inherently accounts for the Pauli exclusion principle."
}], "Text",
 CellChangeTimes->{{3.8126305808942595`*^9, 3.812630745657671*^9}, {
  3.812630777782395*^9, 3.8126307966107473`*^9}, {3.81263084639583*^9, 
  3.8126308466495886`*^9}, {3.81272276759332*^9, 
  3.8127227681804633`*^9}},ExpressionUUID->"1b9cbeb5-d0e3-479d-872a-\
e8065f27f8e2"],

Cell["\<\
Let\[CloseCurlyQuote]s look at the slightly more complicated example of a \
lithium atom (three electrons). To construct an appropriate antisymmetrized \
wavefunction, we would use the Slater determinant\
\>", "Text",
 CellChangeTimes->{{3.812630883287836*^9, 
  3.8126309183007307`*^9}},ExpressionUUID->"3377abf4-8881-4f09-a126-\
66e576caea4a"],

Cell[BoxData[
 RowBox[{
  RowBox[{"\[Psi]", 
   RowBox[{"(", 
    RowBox[{"1", ",", "2", ",", "3"}], ")"}]}], "=", 
  RowBox[{
   FractionBox["1", 
    SqrtBox[
     RowBox[{"3", "!"}]]], 
   RowBox[{"\[LeftBracketingBar]", GridBox[{
      {
       RowBox[{
        SubscriptBox["\[Phi]", 
         RowBox[{"1", 
          StyleBox["s",
           FontSlant->"Italic"]}]], 
        RowBox[{"(", "1", ")"}], "\[Alpha]", 
        RowBox[{"(", "1", ")"}]}], 
       RowBox[{
        SubscriptBox["\[Phi]", 
         RowBox[{"1", 
          StyleBox["s",
           FontSlant->"Italic"]}]], 
        RowBox[{"(", "1", ")"}], "\[Beta]", 
        RowBox[{"(", "1", ")"}]}], 
       RowBox[{
        SubscriptBox["\[Phi]", 
         RowBox[{"2", 
          StyleBox["s",
           FontSlant->"Italic"]}]], 
        RowBox[{"(", "1", ")"}], "\[Alpha]", 
        RowBox[{"(", "1", ")"}]}]},
      {
       RowBox[{
        SubscriptBox["\[Phi]", 
         RowBox[{"1", 
          StyleBox["s",
           FontSlant->"Italic"]}]], 
        RowBox[{"(", "2", ")"}], "\[Alpha]", 
        RowBox[{"(", "2", ")"}]}], 
       RowBox[{
        SubscriptBox["\[Phi]", 
         RowBox[{"1", 
          StyleBox["s",
           FontSlant->"Italic"]}]], 
        RowBox[{"(", "2", ")"}], "\[Beta]", 
        RowBox[{"(", "2", ")"}]}], 
       RowBox[{
        SubscriptBox["\[Phi]", 
         RowBox[{"2", 
          StyleBox["s",
           FontSlant->"Italic"]}]], 
        RowBox[{"(", "2", ")"}], "\[Alpha]", 
        RowBox[{"(", "2", ")"}]}]},
      {
       RowBox[{
        SubscriptBox["\[Phi]", 
         RowBox[{"1", 
          StyleBox["s",
           FontSlant->"Italic"]}]], 
        RowBox[{"(", "3", ")"}], "\[Alpha]", 
        RowBox[{"(", "3", ")"}]}], 
       RowBox[{
        SubscriptBox["\[Phi]", 
         RowBox[{"1", 
          StyleBox["s",
           FontSlant->"Italic"]}]], 
        RowBox[{"(", "3", ")"}], "\[Beta]", 
        RowBox[{"(", "3", ")"}]}], 
       RowBox[{
        SubscriptBox["\[Phi]", 
         RowBox[{"2", 
          StyleBox["s",
           FontSlant->"Italic"]}]], 
        RowBox[{"(", "3", ")"}], "\[Alpha]", 
        RowBox[{"(", "3", ")"}]}]}
     }], "\[NoBreak]\[NoBreak]", 
    "\[RightBracketingBar]"}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.810112811439228*^9, 3.8101128248442793`*^9}, {
   3.810479494926491*^9, 3.8104795038498344`*^9}, {3.810479572543576*^9, 
   3.8104796147383184`*^9}, {3.8104802055659895`*^9, 
   3.8104802433915305`*^9}, {3.8104802785189395`*^9, 
   3.8104802814214115`*^9}, {3.8109915300785556`*^9, 
   3.8109916793993816`*^9}, {3.810991710031681*^9, 3.8109918292023373`*^9}, {
   3.810994488524798*^9, 3.810994499853472*^9}, {3.8109948928195066`*^9, 
   3.8109948950763626`*^9}, {3.8109949491606197`*^9, 3.810995087249513*^9}, {
   3.8109951188614283`*^9, 3.8109951226144466`*^9}, {3.8115998145208507`*^9, 
   3.8115999093225703`*^9}, 3.8119468581508093`*^9, {3.8126173912859564`*^9, 
   3.8126174353481674`*^9}, {3.812617986792708*^9, 3.812617987701547*^9}, {
   3.8126194925193796`*^9, 3.812619503416272*^9}, {3.812619551056244*^9, 
   3.812619564308283*^9}, {3.812619992990877*^9, 3.8126200208718753`*^9}, 
   3.8126201248430705`*^9, {3.812620163920018*^9, 3.8126201669704065`*^9}, {
   3.8126204678526173`*^9, 3.8126204826728334`*^9}, {3.8126205155312433`*^9, 
   3.81262057853043*^9}, {3.812620660711446*^9, 3.812620661159943*^9}, {
   3.8126208302516937`*^9, 3.8126208466299543`*^9}, {3.812620980916898*^9, 
   3.8126209810859137`*^9}, 3.8126287856964226`*^9, {3.812629271581931*^9, 
   3.8126292755855017`*^9}, {3.8126293423208475`*^9, 3.812629351460653*^9}, {
   3.8126294501142464`*^9, 3.8126295143102984`*^9}, {3.8126295903225517`*^9, 
   3.812629649928158*^9}, {3.8126296948107743`*^9, 3.812629695292021*^9}, {
   3.8126300281015587`*^9, 3.81263005763659*^9}, {3.812630089427315*^9, 
   3.8126301336773043`*^9}, {3.8126301819630384`*^9, 3.8126302619488583`*^9}, 
   3.8126308057010317`*^9, {3.81263092646777*^9, 3.8126310177824636`*^9}, 
   3.812631160225892*^9},ExpressionUUID->"97110b2b-4288-4c36-b1a7-\
a35e05678ea9"],

Cell[TextData[{
 "where we have somewhat arbitrarily assigned the spin state of the 2",
 StyleBox["s",
  FontSlant->"Italic"],
 " electron as \[Alpha], although (in the absence of an external field) the \
two possible states are equivalent."
}], "Text",
 CellChangeTimes->{{3.8126310867168446`*^9, 
  3.8126311425852427`*^9}},ExpressionUUID->"066c97de-7ef6-498a-a88d-\
3cadf7235651"]
}, Open  ]],

Cell[CellGroupData[{

Cell["\<\
Solving for the Approximate Energies of a Slater Determinant Wavefunction\
\>", "Subsection",
 CellChangeTimes->{{3.812629104872365*^9, 3.812629115951785*^9}, {
  3.812631680946392*^9, 3.8126316906071043`*^9}, {3.8126317228295417`*^9, 
  3.812631734252151*^9}},ExpressionUUID->"c671a652-8a01-4dc3-b0ef-\
c379f8ee3428"],

Cell[TextData[{
 "So, we now have a properly antisymmetrized wavefunction for our \
multielectron system, but how do we solve for the energy? Remember that our \
starting assumption, in spite of the more complex formulation, remains the \
same: each electron is described by an individual spin orbital ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Chi]", "i"], TraditionalForm]],ExpressionUUID->
  "69955d9f-19cb-470e-9227-1e9c178054d7"],
 ","
}], "Text",
 CellChangeTimes->{{3.8126983023648243`*^9, 3.8126983300661907`*^9}, {
  3.8126983662996264`*^9, 
  3.812698451795544*^9}},ExpressionUUID->"9bd9888e-147f-493f-b687-\
7921d973c48b"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   SubscriptBox["\[Chi]", 
    StyleBox["i",
     FontSlant->"Italic"]], 
   RowBox[{"(", 
    RowBox[{
     SubscriptBox[
      StyleBox["r",
       FontWeight->"Bold",
       FontSlant->"Italic"], "1"], ",", 
     SubscriptBox["\[Sigma]", "1"]}], ")"}]}], "=", 
  RowBox[{
   SubscriptBox["\[Chi]", 
    StyleBox["i",
     FontSlant->"Italic"]], 
   RowBox[{"(", 
    SubscriptBox[
     StyleBox["x",
      FontWeight->"Bold",
      FontSlant->"Italic"], "1"], ")"}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.812698491186754*^9, 
  3.8126985209309444`*^9}},ExpressionUUID->"be6fd6ee-b609-4c12-8ad4-\
8145e470559f"],

Cell[TextData[{
 "where we are now using  the coordinate ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["x",
    FontWeight->"Bold",
    FontSlant->"Italic"], "1"]],
  CellChangeTimes->{{3.812698491186754*^9, 3.8126985209309444`*^9}},
  ExpressionUUID->"65912e99-2ffb-4224-a59f-4065502f80ba"],
 " to represent both spin and spatial coordinates (following the terminology \
of ",
 ButtonBox["Sherrill",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["http://vergil.chemistry.gatech.edu/notes/hf-intro/node7.html"], None},
  ButtonNote->"http://vergil.chemistry.gatech.edu/notes/hf-intro/node7.html"],
 "). It turns out that solving for the optimal form of ",
 Cell[BoxData[
  SubscriptBox["\[Chi]", 
   StyleBox["i",
    FontSlant->"Italic"]]],
  CellChangeTimes->{{3.812698491186754*^9, 3.8126985209309444`*^9}},
  ExpressionUUID->"db4d3a23-fdf2-4c16-9c3f-f34be776cda7"],
 " (which, remember is usually represented by a linear combination of basis \
functions) involves finding the solutions to a new equation with a special \
effective Hamiltonian, which we call the Fock operator,"
}], "Text",
 CellChangeTimes->{{3.8126985295890756`*^9, 3.8126986372709284`*^9}, {
   3.812699043272112*^9, 3.812699075886733*^9}, 
   3.9177045166566124`*^9},ExpressionUUID->"2068fb53-bed9-42b4-b6a0-\
c230d505df66"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   SubscriptBox[
    StyleBox[
     OverscriptBox["F", "^"],
     FontSlant->"Italic"], 
    StyleBox["i",
     FontSlant->"Italic"]], 
   RowBox[{"(", 
    SubscriptBox[
     StyleBox["x",
      FontWeight->"Bold",
      FontSlant->"Italic"], "1"], ")"}], 
   SubscriptBox["\[Chi]", 
    StyleBox["i",
     FontSlant->"Italic"]], 
   RowBox[{"(", 
    SubscriptBox[
     StyleBox["x",
      FontWeight->"Bold",
      FontSlant->"Italic"], "1"], ")"}]}], "=", 
  RowBox[{
   SubscriptBox["\[Epsilon]", 
    StyleBox["i",
     FontSlant->"Italic"]], 
   SubscriptBox["\[Chi]", 
    StyleBox["i",
     FontSlant->"Italic"]], 
   RowBox[{"(", 
    SubscriptBox[
     StyleBox["x",
      FontWeight->"Bold",
      FontSlant->"Italic"], "1"], ")"}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.810112811439228*^9, 3.8101128248442793`*^9}, {
   3.810479494926491*^9, 3.8104795038498344`*^9}, {3.810479572543576*^9, 
   3.8104796147383184`*^9}, {3.8104802055659895`*^9, 
   3.8104802433915305`*^9}, {3.8104802785189395`*^9, 
   3.8104802814214115`*^9}, {3.8109915300785556`*^9, 
   3.8109916793993816`*^9}, {3.810991710031681*^9, 3.8109918292023373`*^9}, {
   3.810994488524798*^9, 3.810994499853472*^9}, {3.8109948928195066`*^9, 
   3.8109948950763626`*^9}, {3.8109949491606197`*^9, 3.810995087249513*^9}, {
   3.8109951188614283`*^9, 3.8109951226144466`*^9}, {3.8115998145208507`*^9, 
   3.8115999093225703`*^9}, 3.8119468581508093`*^9, {3.811947243706769*^9, 
   3.811947267020794*^9}, {3.8119474358938656`*^9, 3.8119474621815863`*^9}, {
   3.8119475278172007`*^9, 3.811947554332982*^9}, {3.811947616170298*^9, 
   3.8119476213260345`*^9}, {3.8119476732648582`*^9, 3.811947727174863*^9}, {
   3.811947824453816*^9, 3.8119478644680986`*^9}, {3.8126318891761827`*^9, 
   3.8126319287268906`*^9}, {3.812698643216871*^9, 
   3.8126986714190135`*^9}},ExpressionUUID->"2f36f645-6368-494f-b2ea-\
b066de6b1ba0"],

Cell[TextData[{
 "Solving for the eigenvalue energies of each orbital ",
 Cell[BoxData[
  SubscriptBox["\[Epsilon]", 
   StyleBox["i",
    FontSlant->"Italic"]]],
  CellChangeTimes->{{3.810112811439228*^9, 3.8101128248442793`*^9}, {
    3.810479494926491*^9, 3.8104795038498344`*^9}, {3.810479572543576*^9, 
    3.8104796147383184`*^9}, {3.8104802055659895`*^9, 
    3.8104802433915305`*^9}, {3.8104802785189395`*^9, 
    3.8104802814214115`*^9}, {3.8109915300785556`*^9, 
    3.8109916793993816`*^9}, {3.810991710031681*^9, 3.8109918292023373`*^9}, {
    3.810994488524798*^9, 3.810994499853472*^9}, {3.8109948928195066`*^9, 
    3.8109948950763626`*^9}, {3.8109949491606197`*^9, 3.810995087249513*^9}, {
    3.8109951188614283`*^9, 3.8109951226144466`*^9}, {3.8115998145208507`*^9, 
    3.8115999093225703`*^9}, 3.8119468581508093`*^9, {3.811947243706769*^9, 
    3.811947267020794*^9}, {3.8119474358938656`*^9, 3.8119474621815863`*^9}, {
    3.8119475278172007`*^9, 3.811947554332982*^9}, {3.811947616170298*^9, 
    3.8119476213260345`*^9}, {3.8119476732648582`*^9, 3.811947727174863*^9}, {
    3.811947824453816*^9, 3.8119478644680986`*^9}, {3.8126318891761827`*^9, 
    3.8126319287268906`*^9}},ExpressionUUID->
  "97b54b49-cd68-4bd9-a23a-564738bc02ae"],
 " and the eigenvectors wavefunctions ",
 Cell[BoxData[
  SubscriptBox["\[Chi]", 
   StyleBox["i",
    FontSlant->"Italic"]]],
  CellChangeTimes->{{3.810112811439228*^9, 3.8101128248442793`*^9}, {
    3.810479494926491*^9, 3.8104795038498344`*^9}, {3.810479572543576*^9, 
    3.8104796147383184`*^9}, {3.8104802055659895`*^9, 
    3.8104802433915305`*^9}, {3.8104802785189395`*^9, 
    3.8104802814214115`*^9}, {3.8109915300785556`*^9, 
    3.8109916793993816`*^9}, {3.810991710031681*^9, 3.8109918292023373`*^9}, {
    3.810994488524798*^9, 3.810994499853472*^9}, {3.8109948928195066`*^9, 
    3.8109948950763626`*^9}, {3.8109949491606197`*^9, 3.810995087249513*^9}, {
    3.8109951188614283`*^9, 3.8109951226144466`*^9}, {3.8115998145208507`*^9, 
    3.8115999093225703`*^9}, 3.8119468581508093`*^9, {3.811947243706769*^9, 
    3.811947267020794*^9}, {3.8119474358938656`*^9, 3.8119474621815863`*^9}, {
    3.8119475278172007`*^9, 3.811947554332982*^9}, {3.811947616170298*^9, 
    3.8119476213260345`*^9}, {3.8119476732648582`*^9, 3.811947727174863*^9}, {
    3.811947824453816*^9, 3.8119478644680986`*^9}, {3.8126318891761827`*^9, 
    3.8126319287268906`*^9}},ExpressionUUID->
  "ad5fda9f-8fdb-4702-8169-270afa7f3f10"],
 " is known as the Hartree-Fock method. We actually have a system of ",
 StyleBox["N",
  FontSlant->"Italic"],
 " equations, where ",
 StyleBox["N",
  FontSlant->"Italic"],
 " is the number of electrons in our system (",
 StyleBox["i",
  FontSlant->"Italic"],
 " is the iterator ranging from 1 to ",
 StyleBox["N",
  FontSlant->"Italic"],
 "). For each single-electron orbital, the Fock operator is given by"
}], "Text",
 CellChangeTimes->{{3.8126319305050316`*^9, 3.8126320833128757`*^9}, {
  3.812698681774609*^9, 
  3.8126986913979797`*^9}},ExpressionUUID->"938ec466-88ee-40e3-b3ee-\
0270dd88ef7a"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   SubscriptBox[
    StyleBox[
     OverscriptBox["F", "^"],
     FontSlant->"Italic"], 
    StyleBox["i",
     FontSlant->"Italic"]], 
   RowBox[{"(", 
    SubscriptBox[
     StyleBox["x",
      FontWeight->"Bold",
      FontSlant->"Italic"], "1"], ")"}], 
   SubscriptBox["\[Chi]", 
    StyleBox["i",
     FontSlant->"Italic"]], 
   RowBox[{"(", 
    SubscriptBox[
     StyleBox["x",
      FontWeight->"Bold",
      FontSlant->"Italic"], "1"], ")"}]}], "=", 
  RowBox[{
   RowBox[{
    SubscriptBox[
     OverscriptBox[
      StyleBox["h",
       FontSlant->"Italic"], "^"], 
     StyleBox["i",
      FontSlant->"Italic"]], 
    RowBox[{"(", 
     SubscriptBox[
      StyleBox["x",
       FontWeight->"Bold",
       FontSlant->"Italic"], "1"], ")"}], 
    SubscriptBox["\[Chi]", 
     StyleBox["i",
      FontSlant->"Italic"]], 
    RowBox[{"(", 
     SubscriptBox[
      StyleBox["x",
       FontWeight->"Bold",
       FontSlant->"Italic"], "1"], ")"}]}], "+", 
   RowBox[{
    UnderscriptBox["\[Sum]", 
     StyleBox["j",
      FontSlant->"Italic"]], 
    RowBox[{"[", 
     RowBox[{
      RowBox[{
       SubscriptBox[
        StyleBox["J",
         FontSlant->"Italic"], 
        StyleBox["j",
         FontSlant->"Italic"]], 
       RowBox[{"(", 
        SubscriptBox[
         StyleBox["x",
          FontWeight->"Bold",
          FontSlant->"Italic"], "1"], ")"}], 
       SubscriptBox["\[Chi]", 
        StyleBox["i",
         FontSlant->"Italic"]], 
       RowBox[{"(", 
        SubscriptBox[
         StyleBox["x",
          FontWeight->"Bold",
          FontSlant->"Italic"], "1"], ")"}]}], "-", 
      RowBox[{
       SubscriptBox[
        StyleBox["K",
         FontSlant->"Italic"], 
        StyleBox["j",
         FontSlant->"Italic"]], 
       RowBox[{"(", 
        SubscriptBox[
         StyleBox["x",
          FontWeight->"Bold",
          FontSlant->"Italic"], "1"], ")"}], 
       SubscriptBox["\[Chi]", 
        StyleBox["i",
         FontSlant->"Italic"]], 
       RowBox[{"(", 
        SubscriptBox[
         StyleBox["x",
          FontWeight->"Bold",
          FontSlant->"Italic"], "1"], ")"}]}]}], 
     "]"}]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.810112811439228*^9, 3.8101128248442793`*^9}, {
   3.810479494926491*^9, 3.8104795038498344`*^9}, {3.810479572543576*^9, 
   3.8104796147383184`*^9}, {3.8104802055659895`*^9, 
   3.8104802433915305`*^9}, {3.8104802785189395`*^9, 
   3.8104802814214115`*^9}, {3.8109915300785556`*^9, 
   3.8109916793993816`*^9}, {3.810991710031681*^9, 3.8109918292023373`*^9}, {
   3.810994488524798*^9, 3.810994499853472*^9}, {3.8109948928195066`*^9, 
   3.8109948950763626`*^9}, {3.8109949491606197`*^9, 3.810995087249513*^9}, {
   3.8109951188614283`*^9, 3.8109951226144466`*^9}, {3.8115998145208507`*^9, 
   3.8115999093225703`*^9}, 3.8119468581508093`*^9, {3.811947243706769*^9, 
   3.811947267020794*^9}, {3.8119474358938656`*^9, 3.8119474621815863`*^9}, {
   3.8119475278172007`*^9, 3.811947554332982*^9}, {3.811947616170298*^9, 
   3.8119476213260345`*^9}, {3.8119476732648582`*^9, 3.811947727174863*^9}, {
   3.811947824453816*^9, 3.8119478644680986`*^9}, {3.8126318891761827`*^9, 
   3.8126319287268906`*^9}, {3.8126320885581465`*^9, 
   3.8126320931514387`*^9}, {3.81263212732189*^9, 3.8126321318829803`*^9}, {
   3.812632200112808*^9, 3.81263223623812*^9}, {3.8126323303629656`*^9, 
   3.8126323415482616`*^9}, {3.8126323731183147`*^9, 3.8126323762613335`*^9}, 
   3.812632542164563*^9, {3.812632648623914*^9, 3.812632670016735*^9}, {
