Cell[TextData[{
 "For any given wavefunction of the hydrogen atom with quantum numbers ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["m", "l"], TraditionalForm]],ExpressionUUID->
  "be49134d-88bb-476e-9304-84159b37c119"],
 " and ",
 StyleBox["l",
  FontSlant->"Italic"],
 ", we can calculate the magnitude of the total angular momentum as"
}], "Text",
