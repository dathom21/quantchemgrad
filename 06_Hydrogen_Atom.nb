Cell[TextData[{
 "From equation (81), we can see that the spherical harmonics ",
 Cell[BoxData[
  RowBox[{
   SubsuperscriptBox[
    StyleBox["Y",
     FontSlant->"Italic"], 
    StyleBox["l",
     FontSlant->"Italic"], 
