Cell[CellGroupData[{

Cell["Character Tables - A (very) Brief Introduction", "Subsection",
 CellChangeTimes->{{3.816263579388917*^9, 3.8162635875705366`*^9}, {
  3.8162640072181273`*^9, 
  3.8162640080114822`*^9}},ExpressionUUID->"7e14bf32-f137-4a29-bf85-\
1ec72e82b98d"],

Cell[TextData[{
 "Using the flow chart above, we don\[CloseCurlyQuote]t necessarily have to \
identify all of the symmetry operations to find the point group of the \
molecule. Once we know the point group, we can find all of these symmetry \
operations (and a great deal more information) in the point group character \
table. Below is the character table for the point group ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["C", 
    RowBox[{"2", "v"}]], TraditionalForm]],ExpressionUUID->
  "6ddbf58d-292f-4fa6-82fe-c78a41ebde9a"],
 "."
}], "Text",
 CellChangeTimes->{{3.8162635916153765`*^9, 3.816263670693437*^9}, {
  3.8162646197905216`*^9, 3.81626464908867*^9}, {3.8162650398162136`*^9, 
  3.8162650520222034`*^9}, {3.8162658083496885`*^9, 
  3.816265812827588*^9}},ExpressionUUID->"087c0b24-909a-4955-b4b8-\
ca3a8ed2e415"],

Cell[TextData[Cell[BoxData[GridBox[{
   {
    StyleBox[
     SubscriptBox["C", 
      RowBox[{
       StyleBox["2",
        FontSlant->"Plain"], "v"}]],
     FontSlant->"Italic"], 
    OverscriptBox[
     StyleBox["E",
      FontSlant->"Italic"], "^"], 
    SubscriptBox[
     OverscriptBox[
      StyleBox["C",
       FontSlant->"Italic"], "^"], 
     StyleBox["2",
      FontSlant->"Plain"]], 
    RowBox[{
     SubscriptBox[
      OverscriptBox["\[Sigma]", "^"], 
      StyleBox["v",
       FontSlant->"Italic"]], 
     RowBox[{"(", 
      StyleBox["xz",
       FontSlant->"Italic"], ")"}]}], 
    RowBox[{
     SubsuperscriptBox[
      OverscriptBox["\[Sigma]", "^"], 
      StyleBox["v",
       FontSlant->"Italic"], "\[Prime]"], 
     RowBox[{"(", 
      StyleBox["yz",
       FontSlant->"Italic"], ")"}]}], 
    RowBox[{
     RowBox[{"lin", ".", "fns", "."}], ",", 
     RowBox[{"rot", "."}]}], 
    RowBox[{"quadr", ".", " ", "fns", "."}]},
   {
    SubscriptBox[
     StyleBox["A",
      FontSlant->"Italic"], "1"], 
    RowBox[{"+", "1"}], 
    RowBox[{"+", "1"}], 
    RowBox[{"+", "1"}], 
    RowBox[{"+", "1"}], 
    StyleBox["z",
     FontSlant->"Italic"], 
    RowBox[{
     SuperscriptBox[
      StyleBox["x",
       FontSlant->"Italic"], "2"], ",", " ", 
     SuperscriptBox[
      StyleBox["y",
       FontSlant->"Italic"], "2"], ",", " ", 
     SuperscriptBox[
      StyleBox["z",
       FontSlant->"Italic"], "2"]}]},
   {
    SubscriptBox[
     StyleBox["A",
      FontSlant->"Italic"], "2"], 
    RowBox[{"+", "1"}], 
    RowBox[{"+", "1"}], 
    RowBox[{"-", "1"}], 
    RowBox[{"-", "1"}], 
    SubscriptBox[
     StyleBox["R",
      FontSlant->"Italic"], 
     StyleBox["z",
      FontSlant->"Italic"]], 
    StyleBox["xy",
     FontSlant->"Italic"]},
   {
    SubscriptBox[
     StyleBox["B",
      FontSlant->"Italic"], "1"], 
    RowBox[{"+", "1"}], 
    RowBox[{"-", "1"}], 
    RowBox[{"+", "1"}], 
    RowBox[{"-", "1"}], 
    RowBox[{"x", ",", " ", 
     SubscriptBox[
      StyleBox["R",
       FontSlant->"Italic"], 
      StyleBox["y",
       FontSlant->"Italic"]]}], 
    StyleBox["xz",
     FontSlant->"Italic"]},
   {
    SubscriptBox[
     StyleBox["B",
      FontSlant->"Italic"], "2"], 
    RowBox[{"+", "1"}], 
    RowBox[{"-", "1"}], 
    RowBox[{"-", "1"}], 
    RowBox[{"+", "1"}], 
    RowBox[{
     StyleBox["y",
      FontSlant->"Italic"], ",", " ", 
     SubscriptBox[
      StyleBox["R",
       FontSlant->"Italic"], 
      StyleBox["x",
       FontSlant->"Italic"]]}], 
    StyleBox["yz",
     FontSlant->"Italic"]}
  },
  GridBoxDividers->{
   "Columns" -> {False, {True}, False}, 
    "Rows" -> {
     False, {True}, 
      False}}]],ExpressionUUID->"b920eb12-15c9-493e-929e-694450a4031e"]], \
"Text",
 CellChangeTimes->{{3.812816183242498*^9, 3.812816428079652*^9}, {
   3.812816462800923*^9, 3.8128166290840225`*^9}, {3.81281717239036*^9, 
   3.812817174537908*^9}, 3.816263811313341*^9, {3.816263849684681*^9, 
   3.8162641278823185`*^9}, {3.816264332444306*^9, 3.816264332445305*^9}, {
   3.81626441510604*^9, 3.8162645130232286`*^9}, {3.8162645899425573`*^9, 
   3.816264599021124*^9}, {3.816265061448436*^9, 3.816265061449438*^9}, 
   3.816265802987118*^9},ExpressionUUID->"b45a7020-01c2-4be2-9f55-\
20989ef66813"],

Cell[TextData[{
 "You can see that the point group is listed in the top left corner, and the \
following four entries in the top row are the four symmetry operations of the \
point group: ",
 Cell[BoxData[
  OverscriptBox[
   StyleBox["E",
    FontSlant->"Italic"], "^"]],ExpressionUUID->
  "6fce45a0-9cc2-4fe4-81b7-2dd82e478546"],
 ", ",
 Cell[BoxData[
  SubscriptBox[
   OverscriptBox[
    StyleBox["C",
     FontSlant->"Italic"], "^"], 
   StyleBox["2",
    FontSlant->"Plain"]]],ExpressionUUID->
  "4259d853-494a-4513-b77f-f30f613fe3c4"],
 ", ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    OverscriptBox["\[Sigma]", "^"], 
    StyleBox["v",
     FontSlant->"Italic"]], 
   RowBox[{"(", 
    StyleBox["xz",
     FontSlant->"Italic"], ")"}]}]],ExpressionUUID->
  "006dd9c0-99e6-4e08-a281-1e2155c63923"],
 ", and ",
 Cell[BoxData[
  RowBox[{
   SubsuperscriptBox[
    OverscriptBox["\[Sigma]", "^"], 
    StyleBox["v",
     FontSlant->"Italic"], "\[Prime]"], 
   RowBox[{"(", 
    StyleBox["yz",
     FontSlant->"Italic"], ")"}]}]],ExpressionUUID->
  "6e61a7ef-c031-4b0c-ac95-bda463985688"],
 ". Note that for other point groups, multiple symmetry operations of the \
same class can be grouped together in the character table if they have the \
same character (e.g. 2",
 Cell[BoxData[
  SubscriptBox[
   OverscriptBox[
    StyleBox["C",
     FontSlant->"Italic"], "^"], 
   StyleBox["3",
    FontSlant->"Plain"]]],ExpressionUUID->
  "c870e317-84c8-4ddd-ad4f-ed7a2711e3fb"],
 "). "
}], "Text",
 CellChangeTimes->{{3.81626465378237*^9, 3.8162647502225685`*^9}, {
  3.816265112464259*^9, 3.816265122079877*^9}, {3.816265253987571*^9, 
  3.8162655141635094`*^9}, {3.8162655461119766`*^9, 
  3.816265639405922*^9}},ExpressionUUID->"0673e8d4-d1a2-4923-9476-\
fce3b9f1852c"],

Cell[TextData[{
 "To make any sense of the rest of the table, we need to define a few terms. \
The remaining elements in the first column give the labels of the irreducible \
representations of the point group, in this case ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["A",
    FontSlant->"Italic"], "1"]],ExpressionUUID->
  "dc6e72d8-fd92-43bf-8297-fb82cd7f9265"],
 ", ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["A",
    FontSlant->"Italic"], "2"]],ExpressionUUID->
  "c30d5b0c-604c-4d85-bf29-c95f8bc626ab"],
 ", ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["B",
    FontSlant->"Italic"], "1"]],ExpressionUUID->
  "a72f5d31-92ee-487b-9111-52eb96a711fa"],
 ", and ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["B",
    FontSlant->"Italic"], "2"]],ExpressionUUID->
  "f5656d22-6c24-40f8-b67c-2151d4d1ade6"],
 ". An irreducible representation is the simplest possible representation of \
a group that can be used to express all other representations. These \
representations must obey the multiplication rules for the different symmetry \
operations in the group (we won\[CloseCurlyQuote]t discuss these at the \
moment). Ignoring the final two columns, the remaining entries give the \
character of the irreducible representation for each symmetry operation. The \
character is the trace, or sum of the diagonal elements, of a representation \
matrix."
}], "Text",
 CellChangeTimes->{{3.8162656420731196`*^9, 3.8162656932839537`*^9}, {
  3.8162658285129533`*^9, 
  3.8162658654445515`*^9}},ExpressionUUID->"f711f8b1-e597-4a3a-aa68-\
7b0d2dbb1cfc"],

Cell[TextData[{
 "Finally, the last two columns give functions that transform as the \
irreducible representations of the point group. There are the Cartesian axes \
(",
 StyleBox["x",
  FontSlant->"Italic"],
 ", ",
 StyleBox["y",
  FontSlant->"Italic"],
 ", and ",
 StyleBox["z",
  FontSlant->"Italic"],
 "), the rotation axes ",
 Cell[BoxData[
  FormBox[
   RowBox[{"(", 
    RowBox[{
     SubscriptBox["R", "x"], ",", " ", 
     SubscriptBox["R", "y"], ",", " ", 
     RowBox[{"and", " ", 
      SubscriptBox["R", "z"]}]}], ")"}], TraditionalForm]],ExpressionUUID->
  "e18babaa-aabe-446c-ba19-244505c53665"],
 ", and the quadratic Cartesian products ",
 Cell[BoxData[
  RowBox[{
   StyleBox["(",
    FontSlant->"Italic"], 
   RowBox[{
    SuperscriptBox[
     StyleBox["x",
      FontSlant->"Italic"], "2"], ",", " ", 
    SuperscriptBox[
     StyleBox["y",
      FontSlant->"Italic"], "2"], ",", " ", 
    SuperscriptBox[
     StyleBox["z",
      FontSlant->"Italic"], "2"], ",", 
    StyleBox["xy",
     FontSlant->"Italic"], 
    StyleBox[",",
     FontSlant->"Italic"], 
    StyleBox["xz",
     FontSlant->"Italic"], ",", 
    RowBox[{"and", " ", 
     StyleBox["yz",
      FontSlant->"Italic"]}]}], 
   StyleBox[")",
    FontSlant->"Italic"]}]],ExpressionUUID->
  "2fee64d1-62b7-407b-9613-7649b86800c9"],
 ". "
}], "Text",
 CellChangeTimes->{{3.8162658765150166`*^9, 3.8162660361325254`*^9}, {
  3.8477914943110332`*^9, 
  3.847791494940778*^9}},ExpressionUUID->"9cae8659-f251-49bc-8ad1-\
23c747f1950c"],

Cell[TextData[{
 "The ",
 StyleBox["order",
  FontSlant->"Italic"],
 " of the point group is the number of symmetry operations. "
}], "Text",
 CellChangeTimes->{{3.8162661417518296`*^9, 3.8162661564830136`*^9}, {
  3.8162662375776434`*^9, 
  3.8162662416025257`*^9}},ExpressionUUID->"abff0507-0018-44de-b957-\
0d59a9e447af"],

Cell["\<\
If all of this sounds quite complex to you, that\[CloseCurlyQuote]s because \
it is. However, these tables are extremely useful for predicting things like \
the symmetry of molecular orbitals, the symmetry of molecular vibrations, and \
the infrared and Raman activity of vibrations. We don\[CloseCurlyQuote]t have \
too much time to work through lots of examples, but let\[CloseCurlyQuote]s \
see how all of this information applies to molecular vibrations.\
\>", "Text",
 CellChangeTimes->{{3.816266130588843*^9, 3.81626613806931*^9}, {
  3.816266358569414*^9, 3.8162663987208333`*^9}, {3.816266452430073*^9, 
  3.8162664791265106`*^9}},ExpressionUUID->"0b4f4128-1d45-4f5a-bab0-\
60b9ced21f32"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Group Theory and Molecular Vibrations", "Section",
 CellChangeTimes->{{3.8162668998725624`*^9, 
  3.8162669082103343`*^9}},ExpressionUUID->"80c09513-57e3-4da4-a377-\
36f122f13713"],

Cell[CellGroupData[{

Cell["The Vibrations of Molecules are Given by Normal Coordinates", \
"Subsection",
 CellChangeTimes->{{3.81626692050747*^9, 
  3.8162669698499403`*^9}},ExpressionUUID->"04e65f17-fbdd-475b-bb2c-\
cc8d2cfeca06"],

Cell[TextData[{
 "To give the positions of all of the atoms in a molecule requires ",
 StyleBox["3N ",
  FontSlant->"Italic"],
 "coordinates, for example the ",
 StyleBox["x",
  FontSlant->"Italic"],
 ", ",
 StyleBox["y",
  FontSlant->"Italic"],
 ", and ",
 StyleBox["z",
  FontSlant->"Italic"],
 " positions for each atom. We usually say that the molecule has 3",
 StyleBox["N",
  FontSlant->"Italic"],
 " degrees of freedom. We need three degrees of freedom to specify the \
position of the entire molecule relative to some reference, which we call the \
translational degrees of freedom. We require an additional two or three \
degrees of freedom to specify the orientation about a center of mass for a \
linear or nonlinear molecule, respectively. That leaves us with 3",
 StyleBox["N",
  FontSlant->"Italic"],
 "\[Minus]5 or 3",
 StyleBox["N",
  FontSlant->"Italic"],
 "\[Minus]6 vibrational degrees of freedom for linear or nonlinear molecules, \
respectively.  "
}], "Text",
 CellChangeTimes->{{3.8162669836907015`*^9, 
  3.8162672096538787`*^9}},ExpressionUUID->"cca9960d-1ba6-4442-93e0-\
63a49f9c91bc"],

Cell[TextData[{
 "Because the potential energy for nuclear motion in a polyatomic molecule \
doesn\[CloseCurlyQuote]t depend on rotation or translation (in the absence of \
external fields), we can write a Taylor series expansion of the potential \
energy about the equilibrium bond distances. Using some arbitrary set of \
coordinates ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["q", "i"], TraditionalForm]],ExpressionUUID->
  "a3e0426f-04e8-4a12-b737-551a434c46a2"],
 " for the ",
 StyleBox["N",
  FontSlant->"Italic"],
 " vibrational degrees of freedom, the expansion takes the form"
}], "Text",
 CellChangeTimes->{{3.8162673563256063`*^9, 3.8162674441866655`*^9}, {
  3.816267881985133*^9, 
  3.8162679266535673`*^9}},ExpressionUUID->"cb20a14d-6200-49ae-8e2d-\
42b41b7fba7e"],

Cell[BoxData[
 RowBox[{
  StyleBox[
   RowBox[{"\[CapitalDelta]", 
    StyleBox["V",
     FontSlant->"Italic"]}]], "=", 
  RowBox[{
   RowBox[{
    RowBox[{
     StyleBox["V",
      FontSlant->"Italic"], 
     RowBox[{"(", 
      RowBox[{
       SubscriptBox[
        StyleBox["q",
         FontSlant->"Italic"], "1"], ",", " ", 
       SubscriptBox[
        StyleBox["q",
         FontSlant->"Italic"], "2"], ",", "...", ",", 
       SubscriptBox[
        StyleBox["q",
         FontSlant->"Italic"], 
        StyleBox["N",
         FontSlant->"Italic"]]}], ")"}]}], "-", 
    SubscriptBox[
     StyleBox["V",
      FontSlant->"Italic"], "0"]}], "=", 
   RowBox[{
    RowBox[{
     RowBox[{
      FractionBox["1", "2"], 
      RowBox[{
       OverscriptBox[
        UnderscriptBox["\[Sum]", 
         RowBox[{
          StyleBox["i",
           FontSlant->"Italic"], ",", 
          StyleBox["j",
           FontSlant->"Italic"]}]], 
        StyleBox["N",
         FontSlant->"Italic"]], 
       RowBox[{
        RowBox[{"(", 
         FractionBox[
          RowBox[{
           SuperscriptBox["\[PartialD]", "2"], 
           StyleBox["V",
            FontSlant->"Italic"]}], 
          RowBox[{
           RowBox[{"\[PartialD]", 
            SubscriptBox[
             StyleBox["q",
              FontSlant->"Italic"], 
             StyleBox["i",
              FontSlant->"Italic"]]}], 
           RowBox[{"\[PartialD]", 
            SubscriptBox[
             StyleBox["q",
              FontSlant->"Italic"], 
             StyleBox["j",
              FontSlant->"Italic"]]}]}]], ")"}], 
        SubscriptBox[
         StyleBox["q",
          FontSlant->"Italic"], 
         StyleBox["i",
          FontSlant->"Italic"]], 
        SubscriptBox[
         StyleBox["q",
          FontSlant->"Italic"], 
         StyleBox["j",
          FontSlant->"Italic"]]}]}]}], "+"}], 
    "..."}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.816267509382229*^9, 3.816267653848775*^9}, {
  3.816267698278138*^9, 
  3.816267773987756*^9}},ExpressionUUID->"cea575dd-09e3-4409-b61d-\
f5f167df28e3"],

Cell[TextData[{
 "which is the multidimensional equivalent of the anharmonic oscillator \
Taylor series we explored in Lesson 10. Neglecting the higher-order terms is \
equivalent to approximating the potential as that of a harmonic oscillator. \
It turns out that there exists a set of normal coordinates ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["Q", "i"], TraditionalForm]],ExpressionUUID->
  "0d8a9dd2-5f69-442f-8f92-e8fffcd524fd"],
 " such that the potential energy in the harmonic approximation can be \
written as"
}], "Text",
 CellChangeTimes->{{3.816267782989749*^9, 3.8162678351467905`*^9}, {
  3.8162678662735033`*^9, 3.816267869215395*^9}, {3.816267933971691*^9, 
  3.8162679749411187`*^9}},ExpressionUUID->"467e70bc-7fff-4aa4-830d-\
98fd5990db51"],

Cell[BoxData[
 RowBox[{
  StyleBox[
   RowBox[{"\[CapitalDelta]", 
    StyleBox["V",
     FontSlant->"Italic"]}]], "=", 
  RowBox[{
   FractionBox["1", "2"], 
   RowBox[{
    OverscriptBox[
     UnderscriptBox["\[Sum]", 
      StyleBox["i",
       FontSlant->"Italic"]], 
     StyleBox["N",
      FontSlant->"Italic"]], 
    RowBox[{
     RowBox[{"(", 
      FractionBox[
       RowBox[{
        SuperscriptBox["\[PartialD]", "2"], 
        StyleBox["V",
         FontSlant->"Italic"]}], 
       RowBox[{"\[PartialD]", 
        SubsuperscriptBox[
         StyleBox["Q",
          FontSlant->"Italic"], 
         StyleBox["i",
          FontSlant->"Italic"], "2"]}]], ")"}], 
     SubsuperscriptBox[
      StyleBox["Q",
       FontSlant->"Italic"], 
      StyleBox["i",
       FontSlant->"Italic"], "2"]}]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.816267509382229*^9, 3.816267653848775*^9}, {
  3.816267698278138*^9, 3.816267773987756*^9}, {3.816267982347368*^9, 
  3.8162680251627665`*^9}},ExpressionUUID->"51ec9b96-f79f-4f8b-bcc7-\
6f8235785936"],

Cell[TextData[{
 "These normal coordinates are important because there are no cross terms; \
each potential energy coordinate is ",
 StyleBox["normal",
  FontSlant->"Italic"],
 " to the others. We can then write the vibrational Hamiltonian as"
}], "Text",
 CellChangeTimes->{{3.816268047855048*^9, 
  3.8162681142391424`*^9}},ExpressionUUID->"28f6460e-f530-4e5d-84e2-\
611a88bcd3b1"],

Cell[BoxData[
 RowBox[{
  SubscriptBox[
   OverscriptBox[
    StyleBox["H",
     FontSlant->"Italic"], "^"], "vib"], "=", 
  RowBox[{
   OverscriptBox[
    UnderscriptBox["\[Sum]", 
     StyleBox["i",
      FontSlant->"Italic"]], 
    StyleBox["N",
     FontSlant->"Italic"]], 
   RowBox[{
    FractionBox[
     RowBox[{"-", 
      SuperscriptBox["\[HBar]", "2"]}], 
     RowBox[{"2", 
      SubscriptBox[
       StyleBox["m",
        FontSlant->"Italic"], 
       StyleBox["red",
        FontSlant->"Italic"]]}]], 
    RowBox[{
     FractionBox[
      SuperscriptBox["\[PartialD]", "2"], 
      RowBox[{"\[PartialD]", 
       SubsuperscriptBox[
        StyleBox["Q",
         FontSlant->"Italic"], 
        StyleBox["i",
         FontSlant->"Italic"], "2"]}]], 
     RowBox[{"+", 
      FractionBox["1", "2"]}]}], 
    RowBox[{
     OverscriptBox[
      UnderscriptBox["\[Sum]", 
       StyleBox["i",
        FontSlant->"Italic"]], 
      StyleBox["N",
       FontSlant->"Italic"]], 
     RowBox[{
      RowBox[{"(", 
       FractionBox[
        RowBox[{
         SuperscriptBox["\[PartialD]", "2"], 
         StyleBox["V",
          FontSlant->"Italic"]}], 
        RowBox[{"\[PartialD]", 
         SubsuperscriptBox[
          StyleBox["Q",
           FontSlant->"Italic"], 
          StyleBox["i",
           FontSlant->"Italic"], "2"]}]], ")"}], 
      SubsuperscriptBox[
       StyleBox["Q",
        FontSlant->"Italic"], 
       StyleBox["i",
        FontSlant->"Italic"], "2"]}]}]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.816268121876033*^9, 
  3.8162682305566397`*^9}},ExpressionUUID->"df66151e-5845-4313-8edb-\
2ce6551aa24e"],

Cell["\<\
and the eigenfunction of this vibrational Hamiltonian can be written as a \
product of separable nuclear wavefunctions for each normal coordinate,\
\>", "Text",
 CellChangeTimes->{{3.816268253074793*^9, 
  3.816268285147242*^9}},ExpressionUUID->"f2366805-761c-4e4c-a5ac-\
9b18ddd643f7"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   SubscriptBox["\[Psi]", "vib"], 
   RowBox[{"(", 
    RowBox[{
     SubscriptBox[
      StyleBox["Q",
       FontSlant->"Italic"], "1"], ",", " ", 
     SubscriptBox[
      StyleBox["Q",
       FontSlant->"Italic"], "2"], ",", "...", ",", 
     SubscriptBox[
      StyleBox["Q",
       FontSlant->"Italic"], 
      StyleBox["N",
       FontSlant->"Italic"]]}], ")"}]}], "=", 
  RowBox[{
   RowBox[{
    RowBox[{
     SubscriptBox["\[Psi]", 
      SubscriptBox["vib", "1"]], 
     RowBox[{"(", 
      SubscriptBox[
       StyleBox["Q",
        FontSlant->"Italic"], "1"], ")"}], 
     SubscriptBox["\[Psi]", 
      SubscriptBox["vib", "2"]], 
     RowBox[{"(", 
      SubscriptBox[
       StyleBox["Q",
        FontSlant->"Italic"], "2"], ")"}]}], "..."}], 
   SubscriptBox["\[Psi]", 
    SubscriptBox["vib", 
     StyleBox["N",
      FontSlant->"Italic"]]], 
   RowBox[{"(", 
    SubscriptBox[
     StyleBox["Q",
      FontSlant->"Italic"], 
     StyleBox["N",
      FontSlant->"Italic"]], ")"}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.816268121876033*^9, 3.8162682305566397`*^9}, {
  3.816268292637581*^9, 
  3.816268372000382*^9}},ExpressionUUID->"82857c0c-2e88-4f1c-8d04-\
239e2443dba1"],

Cell["The vibrational energy is given by", "Text",
 CellChangeTimes->{{3.8162685238959427`*^9, 3.816268527525455*^9}, {
  3.8162685808065324`*^9, 
  3.816268582551801*^9}},ExpressionUUID->"4c2422b2-34e0-419d-8c3c-\
624d9f620454"],

Cell[BoxData[
 RowBox[{
  SubscriptBox[
   StyleBox["E",
    FontSlant->"Italic"], "vib"], "=", 
  RowBox[{
   OverscriptBox[
    UnderscriptBox["\[Sum]", 
     StyleBox["i",
      FontSlant->"Italic"]], 
    StyleBox["N",
     FontSlant->"Italic"]], 
   RowBox[{
    SubscriptBox[
     StyleBox["hv",
      FontSlant->"Italic"], 
     StyleBox["i",
      FontSlant->"Italic"]], 
    RowBox[{"(", 
     RowBox[{
      SubscriptBox[
       StyleBox["v",
        FontSlant->"Italic"], 
       StyleBox["i",
        FontSlant->"Italic"]], "+", 
      FractionBox["1", "2"]}], ")"}]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.816268121876033*^9, 3.8162682305566397`*^9}, {
  3.816268292637581*^9, 3.816268372000382*^9}, {3.8162685322761936`*^9, 
  3.816268533006519*^9}, {3.8162685744746876`*^9, 
  3.816268634766512*^9}},ExpressionUUID->"ec26de48-3583-4489-a855-\
349d024c2453"],

Cell[TextData[{
 "Thus, in the harmonic approximation, the vibrational motion of a polyatomic \
molecule is given by ",
 StyleBox["N",
  FontSlant->"Italic"],
 " independent harmonic oscillators, each with their own vibrational \
eigenstates."
}], "Text",
 CellChangeTimes->{{3.8162684301704454`*^9, 
  3.816268482478526*^9}},ExpressionUUID->"63f28ae8-707d-43e6-a426-\
ccbf8af39b20"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Normal Coordinates and Irreducible Representations", "Subsection",
 CellChangeTimes->{{3.8162686754527397`*^9, 
  3.8162686850709925`*^9}},ExpressionUUID->"756e14bf-56d5-4fbc-a393-\
cf7070d41e8f"],

Cell[TextData[{
 "But how do we find these normal coordinates? In general, they can be found \
computationally through a matrix diagonalization (eigenvalue problem) scheme. \
However, for molecules belonging to a point group other than ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["C", "1"], TraditionalForm]],ExpressionUUID->
  "3d04ea1c-3d6d-4da8-8e56-60e08b7fa961"],
 " (only identity symmetry operation), the assignment of molecular vibrations \
can be greatly simplified by the application of character tables. In \
addition, the irreducible representations from character tables are often \
employed to label the type of vibration. Let\[CloseCurlyQuote]s take the \
example of the symmetric stretch vibration of water (Figure 13.15). "
}], "Text",
 CellChangeTimes->{{3.816268687826145*^9, 3.816268852936877*^9}, {
   3.8162689384111958`*^9, 3.816268996886475*^9}, 3.939895352720703*^9, {
   3.9400905263088913`*^9, 
   3.9400905265456905`*^9}},ExpressionUUID->"8856bbde-b815-445a-8eed-\
dbd25b48385e"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"oxstr1s", "[", "t_", "]"}], ":=", 
  RowBox[{"{", 
   RowBox[{"0", ",", "0", ",", 
    RowBox[{".12", "*", 
     RowBox[{"Sin", "[", 
      RowBox[{"4", "t"}], "]"}]}]}], "}"}]}]], "Input",
 CellGroupingRules->{"GroupTogetherGrouping", 8003.},
 InitializationCell->True,
 CellChangeTimes->{{3.7820179878980265`*^9, 3.782018118709156*^9}, 
   3.783082351665434*^9, {3.7832639865029793`*^9, 3.783264015008759*^9}, 
   3.788641533566605*^9},
 CellID->488459891,ExpressionUUID->"833202ad-d6f0-413a-8ad8-fc7b2bf38c15"],

Cell[BoxData[
 RowBox[{
  RowBox[{"oxstr2as", "[", "t_", "]"}], ":=", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{".15", "*", 
     RowBox[{"Sin", "[", 
      RowBox[{"4", 
       RowBox[{"(", 
        RowBox[{"t", "-", ".4"}], ")"}]}], "]"}]}], ",", "0", ",", "0"}], 
   "}"}]}]], "Input",
 CellGroupingRules->{"GroupTogetherGrouping", 8003.},
 InitializationCell->True,
 CellChangeTimes->{{3.7820179878980265`*^9, 3.782018118709156*^9}, 
   3.783082351665434*^9, {3.7832639865029793`*^9, 3.783264015008759*^9}, 
   3.788641533566668*^9},
 CellID->1833262269,ExpressionUUID->"d223fa25-0681-4523-8a76-a2504230856c"],

Cell[BoxData[
 RowBox[{
  RowBox[{"oxbend", "[", "t_", "]"}], ":=", 
  RowBox[{"{", 
   RowBox[{"0", ",", "0", ",", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"-", "0.2"}], "*", 
      RowBox[{"Sin", "[", 
       RowBox[{"4", "t"}], "]"}]}], ")"}]}], "}"}]}]], "Input",
 CellGroupingRules->{"GroupTogetherGrouping", 8003.},
 InitializationCell->True,
 CellChangeTimes->{{3.7820179878980265`*^9, 3.782018118709156*^9}, 
   3.783082351665434*^9, {3.7832639865029793`*^9, 3.7832640123765163`*^9}, 
   3.788641533566766*^9},
 CellID->1543097863,ExpressionUUID->"c5dcc194-4a44-4b66-922a-4e5048224837"],

Cell[BoxData[
 RowBox[{
  RowBox[{"hdxstr1s", "[", "t_", "]"}], ":=", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"3.1945420401891713`", ",", "0", ",", 
     RowBox[{"-", "2.407260092608193`"}]}], "}"}], "+", 
   RowBox[{".5", "*", 
    RowBox[{"Sin", "[", 
     RowBox[{"4", "t"}], "]"}], "*", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"Cos", "[", 
       RowBox[{"-", "0.6457718232379019`"}], "]"}], ",", "0", ",", 
      RowBox[{"Sin", "[", 
       RowBox[{"-", "0.6457718232379019`"}], "]"}]}], "}"}]}]}]}]], "Input",
 CellGroupingRules->{"GroupTogetherGrouping", 8003.},
 InitializationCell->True,
 CellChangeTimes->{{3.7820179878980265`*^9, 3.782018118709156*^9}, 
   3.783082351665434*^9, {3.7832639865029793`*^9, 3.783264009339237*^9}, 
   3.7886415335668497`*^9},
 CellID->94132865,ExpressionUUID->"d0eae98b-9167-4b8c-9c54-6732fb8af0eb"],

Cell[BoxData[
 RowBox[{
  RowBox[{"hsxstr1s", "[", "t_", "]"}], ":=", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"-", "3.1945420401891713`"}], ",", "0", ",", 
     RowBox[{"-", "2.407260092608193`"}]}], "}"}], "+", 
   RowBox[{".5", "*", 
    RowBox[{"Sin", "[", 
     RowBox[{"4", "t"}], "]"}], "*", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"-", 
       RowBox[{"Cos", "[", 
        RowBox[{"-", "0.6457718232379019`"}], "]"}]}], ",", "0", ",", 
      RowBox[{"Sin", "[", 
       RowBox[{"-", "0.6457718232379019`"}], "]"}]}], "}"}]}]}]}]], "Input",
 CellGroupingRules->{"GroupTogetherGrouping", 8003.},
 InitializationCell->True,
 CellChangeTimes->{{3.7820179878980265`*^9, 3.782018118709156*^9}, 
   3.783082351665434*^9, {3.7832639865029793`*^9, 3.7832640061102257`*^9}, 
   3.788641533566918*^9},
 CellID->895184421,ExpressionUUID->"62ffa922-250f-46d4-aa1a-a64a4ede3e43"],

Cell[BoxData[
 RowBox[{
  RowBox[{"hdxstr2as", "[", "t_", "]"}], ":=", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"3.1945420401891713`", ",", "0", ",", 
     RowBox[{"-", "2.407260092608193`"}]}], "}"}], "+", 
   RowBox[{".5", "*", 
