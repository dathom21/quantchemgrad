      RowBox[{"fun3", "=", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"i", "==", "4"}], "||", 
            RowBox[{"i", "==", "7"}], "||", 
            RowBox[{"i", "==", "12"}], "||", 
            RowBox[{"i", "==", "14"}], "||", 
            RowBox[{"i", "==", "16"}]}], ",", 
