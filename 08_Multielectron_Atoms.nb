Cell[TextData[{
 "We can see that this operator isn\[CloseCurlyQuote]t so easy to explain. It \
arises from our antisymmetry requirement, and we see that it looks like our \
Coulomb operator, except that we have ",
 StyleBox["exchanged",
  FontSlant->"Italic"],
 " the labels on ",
 Cell[BoxData[
  SubscriptBox["\[Chi]", 
   StyleBox["i",
    FontSlant->"Italic"]]],
  CellChangeTimes->{{3.81263324566302*^9, 3.812633255484535*^9}, {
    3.8126333011776714`*^9, 3.812633336892774*^9}, {3.8126334282013373`*^9, 
    3.8126334287932262`*^9}, {3.812633589311114*^9, 3.8126335903021774`*^9}, 
    3.8126336492865987`*^9, {3.8126338145675697`*^9, 
    3.8126338393056707`*^9}, {3.8126341737960978`*^9, 
    3.8126341807093077`*^9}, {3.812634261038102*^9, 3.8126342859518833`*^9}, {
    3.8126990203095045`*^9, 3.8126990333143563`*^9}, {3.8126992137992897`*^9, 
    3.812699242510311*^9}},ExpressionUUID->
  "9774b43a-21ab-45f2-a180-1e20f23fe1cd"],
 " and ",
 Cell[BoxData[
  SubscriptBox["\[Chi]", 
   StyleBox["j",
    FontSlant->"Italic"]]],
  CellChangeTimes->{{3.81263324566302*^9, 3.812633255484535*^9}, {
    3.8126333011776714`*^9, 3.812633336892774*^9}, {3.8126334282013373`*^9, 
    3.8126334287932262`*^9}, {3.812633589311114*^9, 3.8126335903021774`*^9}, 
    3.8126336492865987`*^9, {3.8126338145675697`*^9, 
    3.8126338393056707`*^9}, {3.8126341737960978`*^9, 
    3.8126341807093077`*^9}, {3.812634261038102*^9, 3.8126342859518833`*^9}, {
    3.8126990203095045`*^9, 3.8126990333143563`*^9}, {3.8126992137992897`*^9, 
    3.812699242510311*^9}},ExpressionUUID->
  "83a7ee65-8750-48e5-a5d2-083655b73cf2"],
 " (but not ",
 Cell[BoxData[
  SubsuperscriptBox["\[Chi]", 
   StyleBox["j",
    FontSlant->"Italic"], "\[Star]"]],
  CellChangeTimes->{{3.81263324566302*^9, 3.812633255484535*^9}, {
    3.8126333011776714`*^9, 3.812633336892774*^9}, {3.8126334282013373`*^9, 
    3.8126334287932262`*^9}, {3.812633589311114*^9, 3.8126335903021774`*^9}, 
    3.8126336492865987`*^9, {3.8126338145675697`*^9, 
    3.8126338393056707`*^9}, {3.8126341737960978`*^9, 
    3.8126341807093077`*^9}, {3.812634261038102*^9, 3.8126342859518833`*^9}, {
    3.8126990203095045`*^9, 3.8126990333143563`*^9}, {3.8126992137992897`*^9, 
    3.812699242510311*^9}},ExpressionUUID->
  "809771ba-740f-4231-8f17-98a40a1a1b82"],
 "). This exchange term represents the difference between the Hartree method \
and the Hartree-Fock method. Physically, one can somewhat think of this term \
as causing an additional repulsion between electrons, so \
it\[CloseCurlyQuote]s sometimes referred to as the \
\[OpenCurlyDoubleQuote]exchange repulsion\[CloseCurlyDoubleQuote] term."
}], "Text",
 CellChangeTimes->{{3.8126342962367597`*^9, 3.8126344000566263`*^9}, {
  3.812634448264284*^9, 3.8126345119760456`*^9}, {3.812699251823045*^9, 
  3.812699260564793*^9}},ExpressionUUID->"e8201af6-9cb9-4290-893e-\
4805003da228"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Obtaining Electronic Energies from the Hartree-Fock Method", \
"Subsection",
 CellChangeTimes->{{3.8127062882846355`*^9, 
  3.8127063047798834`*^9}},ExpressionUUID->"e7cef075-e7e5-4494-8723-\
00a065a20bc2"],

Cell["\<\
We now have an equation to find the energy of each spin orbital,\
\>", "Text",
 CellChangeTimes->{{3.8127063067304497`*^9, 
  3.812706324612065*^9}},ExpressionUUID->"064c4ec2-650e-4ca5-a224-\
2a5dad8c68b3"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   SubscriptBox[
    StyleBox[
     OverscriptBox["F", "^"],
     FontSlant->"Italic"], 
    StyleBox["i",
     FontSlant->"Italic"]], 
   RowBox[{"(", 
    SubscriptBox[
     StyleBox["x",
      FontWeight->"Bold",
      FontSlant->"Italic"], "1"], ")"}], 
   SubscriptBox["\[Chi]", 
    StyleBox["i",
     FontSlant->"Italic"]], 
   RowBox[{"(", 
    SubscriptBox[
     StyleBox["x",
      FontWeight->"Bold",
      FontSlant->"Italic"], "1"], ")"}]}], "=", 
  RowBox[{
   SubscriptBox["\[Epsilon]", 
    StyleBox["i",
     FontSlant->"Italic"]], 
   SubscriptBox["\[Chi]", 
    StyleBox["i",
     FontSlant->"Italic"]], 
   RowBox[{"(", 
    SubscriptBox[
     StyleBox["x",
      FontWeight->"Bold",
      FontSlant->"Italic"], "1"], ")"}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.810112811439228*^9, 3.8101128248442793`*^9}, {
   3.810479494926491*^9, 3.8104795038498344`*^9}, {3.810479572543576*^9, 
   3.8104796147383184`*^9}, {3.8104802055659895`*^9, 
   3.8104802433915305`*^9}, {3.8104802785189395`*^9, 
   3.8104802814214115`*^9}, {3.8109915300785556`*^9, 
   3.8109916793993816`*^9}, {3.810991710031681*^9, 3.8109918292023373`*^9}, {
   3.810994488524798*^9, 3.810994499853472*^9}, {3.8109948928195066`*^9, 
   3.8109948950763626`*^9}, {3.8109949491606197`*^9, 3.810995087249513*^9}, {
   3.8109951188614283`*^9, 3.8109951226144466`*^9}, {3.8115998145208507`*^9, 
   3.8115999093225703`*^9}, 3.8119468581508093`*^9, {3.811947243706769*^9, 
   3.811947267020794*^9}, {3.8119474358938656`*^9, 3.8119474621815863`*^9}, {
   3.8119475278172007`*^9, 3.811947554332982*^9}, {3.811947616170298*^9, 
   3.8119476213260345`*^9}, {3.8119476732648582`*^9, 3.811947727174863*^9}, {
   3.811947824453816*^9, 3.8119478644680986`*^9}, {3.8126318891761827`*^9, 
   3.8126319287268906`*^9}, {3.812698643216871*^9, 
   3.8126986714190135`*^9}},ExpressionUUID->"be8d5f73-0359-4d8f-82f1-\
1a37ed3762a4"],

Cell[TextData[{
 "But this equation doesn\[CloseCurlyQuote]t give us the total energy of the \
system ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["E", 
    StyleBox["HF",
     FontSlant->"Italic"]], TraditionalForm]],ExpressionUUID->
  "3b8e14d1-98da-4ff0-b77f-c8cdf75f7ae9"],
 ". For that, we need to go back to our variational method equation. Assuming \
that our orbital functions ",
 Cell[BoxData[
  SubscriptBox["\[Chi]", 
   StyleBox["i",
    FontSlant->"Italic"]]],
  CellChangeTimes->{{3.810112811439228*^9, 3.8101128248442793`*^9}, {
    3.810479494926491*^9, 3.8104795038498344`*^9}, {3.810479572543576*^9, 
    3.8104796147383184`*^9}, {3.8104802055659895`*^9, 
    3.8104802433915305`*^9}, {3.8104802785189395`*^9, 
    3.8104802814214115`*^9}, {3.8109915300785556`*^9, 
    3.8109916793993816`*^9}, {3.810991710031681*^9, 3.8109918292023373`*^9}, {
    3.810994488524798*^9, 3.810994499853472*^9}, {3.8109948928195066`*^9, 
    3.8109948950763626`*^9}, {3.8109949491606197`*^9, 3.810995087249513*^9}, {
    3.8109951188614283`*^9, 3.8109951226144466`*^9}, {3.8115998145208507`*^9, 
    3.8115999093225703`*^9}, 3.8119468581508093`*^9, {3.811947243706769*^9, 
    3.811947267020794*^9}, {3.8119474358938656`*^9, 3.8119474621815863`*^9}, {
    3.8119475278172007`*^9, 3.811947554332982*^9}, {3.811947616170298*^9, 
    3.8119476213260345`*^9}, {3.8119476732648582`*^9, 3.811947727174863*^9}, {
    3.811947824453816*^9, 3.8119478644680986`*^9}, {3.8126318891761827`*^9, 
    3.8126319287268906`*^9}, {3.812698643216871*^9, 3.8126986714190135`*^9}},
  ExpressionUUID->"2660af08-f02d-4805-b584-4e2eb9c55119"],
 " are normalized, recall that"
}], "Text",
 CellChangeTimes->{{3.812706339115059*^9, 
  3.812706424224761*^9}},ExpressionUUID->"af0595ad-abb5-40dc-93bb-\
d3ac0b19f079"],

Cell[BoxData[
 RowBox[{
  SubscriptBox[
   StyleBox["E",
    FontSlant->"Italic"], 
   StyleBox["HF",
    FontSlant->"Italic"]], "=", 
  RowBox[{
   RowBox[{"\[LeftAngleBracket]", 
    RowBox[{"\[Psi]", "|", 
     SubscriptBox[
      OverscriptBox[
       StyleBox["H",
        FontSlant->"Italic"], "^"], 
      StyleBox["HF",
       FontSlant->"Italic"]], "|", "\[Psi]"}], "\[RightAngleBracket]"}], "=", 
   RowBox[{
    RowBox[{
     OverscriptBox[
      UnderscriptBox["\[Sum]", 
       StyleBox["i",
        FontSlant->"Italic"]], 
      StyleBox["N",
       FontSlant->"Italic"]], 
     RowBox[{"\[LeftAngleBracket]", 
      RowBox[{
       SubscriptBox["\[Chi]", 
        StyleBox["i",
         FontSlant->"Italic"]], "|", 
       SubscriptBox[
        StyleBox[
         OverscriptBox["h", "^"],
         FontSlant->"Italic"], 
        StyleBox["i",
         FontSlant->"Italic"]], "|", 
       SubscriptBox["\[Chi]", 
        StyleBox["i",
         FontSlant->"Italic"]]}], "\[RightAngleBracket]"}]}], "+", 
    RowBox[{
     FractionBox["1", "2"], 
     RowBox[{
      OverscriptBox[
       UnderscriptBox["\[Sum]", 
        StyleBox[
         RowBox[{"i", ",", "j"}],
         FontSlant->"Italic"]], 
       StyleBox["N",
        FontSlant->"Italic"]], 
      RowBox[{"\[LeftAngleBracket]", 
       RowBox[{
        SubscriptBox["\[Chi]", 
         StyleBox["i",
          FontSlant->"Italic"]], "|", 
        RowBox[{
         SubscriptBox[
          StyleBox["J",
           FontSlant->"Italic"], 
          StyleBox["j",
           FontSlant->"Italic"]], "-", 
         SubscriptBox[
          StyleBox["K",
           FontSlant->"Italic"], 
          StyleBox["j",
           FontSlant->"Italic"]]}], "|", 
        SubscriptBox["\[Chi]", 
         StyleBox["i",
          FontSlant->"Italic"]]}], 
       "\[RightAngleBracket]"}]}]}]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.810112811439228*^9, 3.8101128248442793`*^9}, {
   3.810479494926491*^9, 3.8104795038498344`*^9}, {3.810479572543576*^9, 
   3.8104796147383184`*^9}, {3.8104802055659895`*^9, 
   3.8104802433915305`*^9}, {3.8104802785189395`*^9, 
   3.8104802814214115`*^9}, {3.8109915300785556`*^9, 
   3.8109916793993816`*^9}, {3.810991710031681*^9, 3.8109918292023373`*^9}, {
   3.810994488524798*^9, 3.810994499853472*^9}, {3.8109948928195066`*^9, 
   3.8109948950763626`*^9}, {3.8109949491606197`*^9, 3.810995087249513*^9}, {
   3.8109951188614283`*^9, 3.8109951226144466`*^9}, {3.8115998145208507`*^9, 
   3.8115999093225703`*^9}, 3.8119468581508093`*^9, {3.811947243706769*^9, 
   3.811947267020794*^9}, {3.8119474358938656`*^9, 3.8119474621815863`*^9}, {
   3.8119475278172007`*^9, 3.811947554332982*^9}, {3.811947616170298*^9, 
   3.8119476213260345`*^9}, {3.8119476732648582`*^9, 3.811947727174863*^9}, {
   3.811947824453816*^9, 3.8119478644680986`*^9}, {3.8126318891761827`*^9, 
   3.8126319287268906`*^9}, {3.812698643216871*^9, 3.8126986714190135`*^9}, {
   3.8127065219878197`*^9, 3.8127066002469187`*^9}, {3.8127069401179733`*^9, 
   3.8127070269316473`*^9}, {3.8127076858801394`*^9, 3.812707743838921*^9}, {
   3.8127078962878947`*^9, 
   3.8127078968871737`*^9}},ExpressionUUID->"f20d7be3-b20e-4821-92c0-\
3e3acb1a1e27"],

Cell[TextData[{
 "where the factor of 1/2 is needed to account for double summing over ",
 StyleBox["i",
  FontSlant->"Italic"],
 " and ",
 StyleBox["j",
  FontSlant->"Italic"],
 ". Often these equations are written with the integration over spin \
variables already included, which results in an additional factor of 2 before \
the hydrogen-like Hamiltonian and Coulomb operator terms,"
}], "Text",
 CellChangeTimes->{{3.812707816765751*^9, 3.812707884140709*^9}, {
  3.8127079181042504`*^9, 3.8127079276584425`*^9}, {3.812708635852399*^9, 
  3.812708647435524*^9}},ExpressionUUID->"b2d471e7-c171-400c-87f1-\
dc7c84fbf932"],

Cell[BoxData[
 RowBox[{
  SubscriptBox[
   StyleBox["E",
    FontSlant->"Italic"], 
   StyleBox["HF",
    FontSlant->"Italic"]], "=", 
  RowBox[{
   RowBox[{"2", 
    RowBox[{
     OverscriptBox[
      UnderscriptBox["\[Sum]", 
       StyleBox["i",
        FontSlant->"Italic"]], 
      StyleBox["N",
       FontSlant->"Italic"]], 
     RowBox[{"\[LeftAngleBracket]", 
      RowBox[{
       SubscriptBox["\[Phi]", 
        StyleBox["i",
         FontSlant->"Italic"]], "|", 
       SubscriptBox[
        StyleBox[
         OverscriptBox["h", "^"],
         FontSlant->"Italic"], 
        StyleBox["i",
         FontSlant->"Italic"]], "|", 
       SubscriptBox["\[Phi]", 
        StyleBox["i",
         FontSlant->"Italic"]]}], "\[RightAngleBracket]"}]}]}], "+", 
   RowBox[{
    FractionBox["1", "2"], 
    RowBox[{
     OverscriptBox[
      UnderscriptBox["\[Sum]", 
       StyleBox[
        RowBox[{"i", ",", "j"}],
        FontSlant->"Italic"]], 
      StyleBox["N",
       FontSlant->"Italic"]], 
     RowBox[{"\[LeftAngleBracket]", 
      RowBox[{
       SubscriptBox["\[Phi]", 
        StyleBox["i",
         FontSlant->"Italic"]], "|", 
       RowBox[{
        RowBox[{"2", 
         SubscriptBox[
          StyleBox["J",
           FontSlant->"Italic"], 
          StyleBox["j",
           FontSlant->"Italic"]]}], "-", 
        SubscriptBox[
         StyleBox["K",
          FontSlant->"Italic"], 
         StyleBox["j",
          FontSlant->"Italic"]]}], "|", 
       SubscriptBox["\[Phi]", 
        StyleBox["i",
         FontSlant->"Italic"]]}], 
      "\[RightAngleBracket]"}]}]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.810112811439228*^9, 3.8101128248442793`*^9}, {
   3.810479494926491*^9, 3.8104795038498344`*^9}, {3.810479572543576*^9, 
