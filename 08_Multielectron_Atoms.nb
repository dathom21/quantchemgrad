efbfe5c7a9b3"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      SubscriptBox[
       StyleBox["H",
        FontSlant->"Italic"], "11"], "-", 
      RowBox[{
       SubscriptBox[
        StyleBox["E",
         FontSlant->"Italic"], "\[CapitalPhi]"], 
       SubscriptBox[
        StyleBox["S",
         FontSlant->"Italic"], "11"]}]}], ")"}], 
    RowBox[{"(", 
     RowBox[{
      SubscriptBox[
       StyleBox["H",
        FontSlant->"Italic"], "22"], "-", 
      RowBox[{
       SubscriptBox[
        StyleBox["E",
         FontSlant->"Italic"], "\[CapitalPhi]"], 
       SubscriptBox[
        StyleBox["S",
         FontSlant->"Italic"], "22"]}]}], ")"}]}], "-", 
   SuperscriptBox[
    RowBox[{"(", 
     RowBox[{
      SubscriptBox[
       StyleBox["H",
        FontSlant->"Italic"], "12"], "-", 
      RowBox[{
       SubscriptBox[
        StyleBox["E",
