Cell[TextData[{
 "Just as we can have orthogonal functions, we can also have orthogonal \
vectors. Two vectors ",
 StyleBox["a",
  FontWeight->"Bold"],
 " and ",
 StyleBox["b",
  FontWeight->"Bold"],
 " are orthogonal if"
}], "Text",
