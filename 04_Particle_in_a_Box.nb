Cell[CellGroupData[{

Cell["A Particle in a Three-Dimensional Box", "Section",
 CellChangeTimes->{{3.808751838499218*^9, 
  3.8087518822298083`*^9}},ExpressionUUID->"1d3176f0-d388-b14d-b48b-\
dc55ba84ba34"],

Cell["\<\
Now let\[CloseCurlyQuote]s quickly take a look at what happens when we have a \
particle in a three-dimensional box (rather than just on a line that we are \
calling a box). Recall that the three-dimensional time-independent Schr\
\[ODoubleDot]dinger equation is written\
\>", "Text",
 CellChangeTimes->{{3.809357134391607*^9, 3.809357199191784*^9}, {
   3.809357256369438*^9, 3.8093572621089563`*^9}, 
   3.935074971279991*^9},ExpressionUUID->"0bbdfbbe-97aa-e340-9595-\
2aa8e5e77c29"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"-", 
     FractionBox[
      SuperscriptBox["\[HBar]", "2"], 
      RowBox[{"2", 
       StyleBox["m",
        FontSlant->"Italic"]}]]}], 
    RowBox[{
     SuperscriptBox["\[Del]", "2"], "\[Psi]"}], 
    RowBox[{"(", 
     StyleBox["r",
      FontWeight->"Bold",
      FontSlant->"Italic"], 
     StyleBox[")",
      FontSlant->"Italic"]}]}], "+", 
   RowBox[{
    StyleBox["V",
     FontSlant->"Italic"], 
    StyleBox[
     RowBox[{"(", 
      StyleBox["r",
       FontWeight->"Bold"], ")"}],
     FontSlant->"Italic"], "\[Psi]", 
    RowBox[{"(", 
     StyleBox["r",
      FontWeight->"Bold",
      FontSlant->"Italic"], 
     StyleBox[")",
      FontSlant->"Italic"]}]}]}], "=", 
  RowBox[{
   StyleBox["E",
    FontSlant->"Italic"], 
   StyleBox[" ",
    FontSlant->"Italic"], "\[Psi]", 
   RowBox[{"(", 
    StyleBox["r",
     FontWeight->"Bold",
     FontSlant->"Italic"], 
    StyleBox[")",
     FontSlant->"Italic"]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8079664251944246`*^9, 3.8079664343142004`*^9}, {
  3.8079689400739555`*^9, 3.8079689680029573`*^9}, {3.807970315263204*^9, 
  3.8079703215316095`*^9}, {3.807970415909548*^9, 3.807970437015459*^9}, {
  3.8079705221296997`*^9, 3.8079705895237727`*^9}, {3.8079740353167067`*^9, 
  3.807974091342613*^9}},ExpressionUUID->"751a449c-6002-a040-9231-\
4a1b1d465285"],

Cell[TextData[{
 "where the Laplacian operator ",
 Cell[BoxData[
  SuperscriptBox["\[Del]", "2"]],
  CellChangeTimes->{{3.8079664251944246`*^9, 3.8079664343142004`*^9}, {
   3.8079689400739555`*^9, 3.8079689680029573`*^9}, {3.807970315263204*^9, 
   3.8079703215316095`*^9}, {3.807970415909548*^9, 3.807970437015459*^9}, {
   3.8079705221296997`*^9, 3.8079705895237727`*^9}, {3.8079740353167067`*^9, 
   3.807974091342613*^9}},ExpressionUUID->
  "9cfab75b-8c01-cb4f-ac70-57db617d6e99"],
 " is given by"
}], "Text",
 CellChangeTimes->{{3.8093572058989687`*^9, 
  3.8093572359952197`*^9}},ExpressionUUID->"84987593-1ccc-3c47-9f51-\
7cc0c2bbae84"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   SuperscriptBox["\[Del]", "2"], 
   StyleBox["f",
    FontSlant->"Italic"]}], "=", 
  RowBox[{
   RowBox[{"\[Del]", "\[CenterDot]", 
    RowBox[{"\[Del]", 
     StyleBox["f",
      FontSlant->"Italic"]}]}], "=", 
   RowBox[{
    FractionBox[
     RowBox[{
      SuperscriptBox["\[PartialD]", "2"], 
      StyleBox["f",
       FontSlant->"Italic"]}], 
     RowBox[{"\[PartialD]", 
      SuperscriptBox[
       StyleBox["x",
        FontSlant->"Italic"], "2"]}]], "+", 
    FractionBox[
     RowBox[{
      SuperscriptBox["\[PartialD]", "2"], 
      StyleBox["f",
       FontSlant->"Italic"]}], 
     RowBox[{"\[PartialD]", 
      SuperscriptBox["y", "2"]}]], "+", 
    FractionBox[
     RowBox[{
      SuperscriptBox["\[PartialD]", "2"], 
      StyleBox["f",
       FontSlant->"Italic"]}], 
     RowBox[{"\[PartialD]", 
      SuperscriptBox["z", "2"]}]]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8079734359242287`*^9, 3.8079734595866747`*^9}, {
  3.8079735259616528`*^9, 
  3.807973556017437*^9}},ExpressionUUID->"c9487fb4-f34b-3a49-bb03-\
92fad014d765"],

Cell[TextData[{
 "We will call the lengths of the three sides of the box ",
 StyleBox["a",
  FontSlant->"Italic"],
 ", ",
 StyleBox["b",
  FontSlant->"Italic"],
 ", and ",
 StyleBox["c",
  FontSlant->"Italic"],
 " in dimensions ",
 StyleBox["x",
  FontSlant->"Italic"],
 ", ",
 StyleBox["y",
  FontSlant->"Italic"],
 ", and ",
 StyleBox["z",
  FontSlant->"Italic"],
 ", respectively. The potential function is then "
}], "Text",
 CellChangeTimes->{{3.8093572655089383`*^9, 3.8093572803093314`*^9}, {
   3.8093573320275407`*^9, 3.8093573579316044`*^9}, {3.8093574335518374`*^9, 
   3.8093574407192264`*^9}, 
   3.809357487564728*^9},ExpressionUUID->"765b03b3-8927-0d4f-87b5-\
2597637f2fba"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   StyleBox["V",
    FontSlant->"Italic"], 
   RowBox[{
    StyleBox["(",
     FontSlant->"Italic"], 
    RowBox[{
     StyleBox["x",
      FontSlant->"Italic"], ",", 
     StyleBox["y",
      FontSlant->"Italic"], 
     StyleBox[",",
      FontSlant->"Plain"], 
     StyleBox["z",
      FontSlant->"Italic"]}], 
    StyleBox[")",
     FontSlant->"Italic"]}]}], 
  StyleBox["=",
   FontSlant->"Plain"], 
  TagBox[GridBox[{
     {"\[Piecewise]", GridBox[{
        {"0", 
         RowBox[{
          RowBox[{"0", "\[LessEqual]", 
           StyleBox["x",
            FontSlant->"Italic"], "\[LessEqual]", 
           StyleBox["a",
            FontSlant->"Italic"]}], 
          StyleBox[",",
           FontSlant->"Plain"], 
          RowBox[{"0", "\[LessEqual]", 
           StyleBox["y",
            FontSlant->"Italic"], "\[LessEqual]", 
           StyleBox["b",
            FontSlant->"Italic"]}], 
          StyleBox[" ",
           FontSlant->"Plain"], 
          StyleBox[",",
           FontSlant->"Plain"], 
          RowBox[{"0", "\[LessEqual]", 
           StyleBox["z",
            FontSlant->"Italic"], "\[LessEqual]", 
           StyleBox["c",
            FontSlant->"Italic"]}]}]},
        {"\[Infinity]", "otherwise"}
       },
       AllowedDimensions->{2, Automatic},
       Editable->True,
       GridBoxAlignment->{"Columns" -> {{Left}}, "Rows" -> {{Baseline}}},
       GridBoxItemSize->{"Columns" -> {{Automatic}}, "Rows" -> {{1.}}},
       GridBoxSpacings->{"Columns" -> {
           Offset[0.27999999999999997`], {
            Offset[0.84]}, 
           Offset[0.27999999999999997`]}, "Rows" -> {
           Offset[0.2], {
            Offset[0.4]}, 
           Offset[0.2]}},
       Selectable->True]}
    },
    GridBoxAlignment->{"Columns" -> {{Left}}, "Rows" -> {{Baseline}}},
    GridBoxItemSize->{"Columns" -> {{Automatic}}, "Rows" -> {{1.}}},
    GridBoxSpacings->{"Columns" -> {
        Offset[0.27999999999999997`], {
         Offset[0.35]}, 
        Offset[0.27999999999999997`]}, "Rows" -> {
        Offset[0.2], {
         Offset[0.4]}, 
        Offset[0.2]}}],
   "Piecewise",
   DeleteWithContents->True,
   Editable->False,
   SelectWithContents->True,
   Selectable->False,
   StripWrapperBoxes->True]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8081500254077106`*^9, 3.8081500761579385`*^9}, {
  3.8081546281887846`*^9, 3.8081546999821053`*^9}, {3.808155682954118*^9, 
  3.808155703943431*^9}, {3.8082124840916924`*^9, 3.80821249994232*^9}, {
  3.808216958894346*^9, 3.8082169607495317`*^9}, {3.8082170155176687`*^9, 
  3.808217019192315*^9}, {3.808220130082225*^9, 3.8082201337618012`*^9}, {
  3.8082201806000853`*^9, 3.80822018744919*^9}, {3.808220238677119*^9, 
  3.808220270716321*^9}, {3.8082203077757683`*^9, 3.8082203466108446`*^9}, {
  3.8082223775626664`*^9, 3.808222379464031*^9}, {3.808742767636488*^9, 
