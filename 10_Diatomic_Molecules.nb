    3.813672319678033*^9}},ExpressionUUID->
  "a1886741-1531-8145-9d33-5ad170170bfd"],
 " are now centered around multiple nuclei instead of just one nucleus."
}], "Text",
 CellChangeTimes->{{3.813672305857046*^9, 3.8136724591037226`*^9}, 
   3.813672561184024*^9, {3.813672641291936*^9, 
   3.8136726588541684`*^9}},ExpressionUUID->"1c6b9ecf-a3ad-4c47-a3bb-\
e75d36724ebb"],

Cell[TextData[{
 "To provide a more concrete example of this description, let\
\[CloseCurlyQuote]s examine the simplest multielectron diatomic molecule, ",
 Cell[BoxData[
  FormBox[
   SubscriptBox[
    StyleBox["H",
     FontSlant->"Plain"], "2"], TraditionalForm]],ExpressionUUID->
  "564606d5-94b7-4409-ab56-1da0b2d1bc1a"],
 ". We have two electrons and two nuclei in this system, and we want to write \
the wavefunction describing the system as a product of molecular orbital \
wavefunctions. Keep in mind, however, that we still must account for spin, \
and we must have an antisymmetrized wavefunction for the system. We therefore \
use a Slater determinant to construct the wavefunction, with both electrons \
in the ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Psi]", "+"], TraditionalForm]],ExpressionUUID->
  "90f3a9bf-0413-4f8f-8d42-e6d988825da3"],
 " bonding molecular orbital (the lowest-energy spatial orbital),"
}], "Text",
 CellChangeTimes->{{3.8136725702984314`*^9, 3.813672604406892*^9}, {
   3.813672672247134*^9, 3.813672797164459*^9}, {3.813675181971346*^9, 
   3.8136751823161716`*^9}, {3.919512759389027*^9, 3.9195127613370867`*^9}, 
   3.9374876278828297`*^9},ExpressionUUID->"c2a69dc3-35dd-41d6-856a-\
6cbbb5f7d16b"],

Cell[BoxData[
 RowBox[{
  SubscriptBox["\[Psi]", 
   SubscriptBox["H", "2"]], "=", 
  RowBox[{
   FractionBox["1", 
    SqrtBox["2"]], 
   RowBox[{"\[LeftBracketingBar]", "\[NoBreak]", GridBox[{
      {
       RowBox[{
        SubscriptBox["\[Psi]", "+"], 
        RowBox[{"(", "1", ")"}], "\[Alpha]", 
        RowBox[{"(", "1", ")"}]}], 
       RowBox[{
        SubscriptBox["\[Psi]", "+"], 
        RowBox[{"(", "1", ")"}], "\[Beta]", 
        RowBox[{"(", "1", ")"}]}]},
      {
       RowBox[{
        SubscriptBox["\[Psi]", "+"], 
        RowBox[{"(", "2", ")"}], "\[Alpha]", 
        RowBox[{"(", "2", ")"}]}], 
       RowBox[{
        SubscriptBox["\[Psi]", "+"], 
        RowBox[{"(", "2", ")"}], "\[Beta]", 
        RowBox[{"(", "2", ")"}]}]}
     }], "\[NoBreak]", 
    "\[RightBracketingBar]"}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.813669259677831*^9, 3.813669335226798*^9}, {
  3.81366938031122*^9, 3.8136693993538027`*^9}, {3.8136694323059635`*^9, 
  3.8136694361348667`*^9}},ExpressionUUID->"f697d909-ca32-429b-a17a-\
8b3673cbc201"],

Cell["If we evaluate the determinant, we obtain the wavefunction", "Text",
 CellChangeTimes->{{3.813675214263397*^9, 3.8136752538154545`*^9}, {
  3.9374876548379097`*^9, 
  3.937487655771654*^9}},ExpressionUUID->"6fed12d6-4f7f-44f6-bbd0-\
3d3210cc00ec"],

Cell[BoxData[
 RowBox[{
  SubscriptBox["\[Psi]", 
   SubscriptBox["H", "2"]], "=", 
  RowBox[{
   SubscriptBox["\[Psi]", "+"], 
   RowBox[{"(", "1", ")"}], 
   SubscriptBox["\[Psi]", "+"], 
   RowBox[{"(", "2", ")"}], 
   RowBox[{
    FractionBox["1", 
     SqrtBox["2"]], "[", 
    RowBox[{
     RowBox[{"\[Alpha]", 
      RowBox[{"(", "1", ")"}], "\[Beta]", 
      RowBox[{"(", "2", ")"}]}], "-", 
     RowBox[{"\[Alpha]", 
      RowBox[{"(", "2", ")"}], "\[Beta]", 
      RowBox[{"(", "1", ")"}]}]}], "]"}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8132221669142685`*^9, 3.8132221794693403`*^9}, {
   3.8132222690385857`*^9, 3.813222292552426*^9}, {3.8132225103046436`*^9, 
   3.8132225357976294`*^9}, 3.813225530724597*^9, {3.8132268996594105`*^9, 
   3.8132268997936573`*^9}, {3.8132269718506794`*^9, 
   3.8132270598936987`*^9}, {3.813227090063882*^9, 3.8132270928942423`*^9}, {
   3.8132273687054873`*^9, 3.8132273956726027`*^9}, {3.8132274257354927`*^9, 
   3.8132274504676456`*^9}, {3.813227484968296*^9, 3.8132274916733313`*^9}, {
   3.813227717592659*^9, 3.813227799104663*^9}, {3.8132278524338465`*^9, 
   3.813227854764579*^9}, 3.8132279269606223`*^9, {3.8132284806854115`*^9, 
   3.8132285040063257`*^9}, {3.813233670328187*^9, 3.8132336720975046`*^9}, {
   3.8132357631856723`*^9, 3.8132357709170113`*^9}, {3.8136690239902897`*^9, 
   3.8136691495063524`*^9}, {3.8136752574300575`*^9, 
   3.813675260694292*^9}},ExpressionUUID->"b9b30096-8f10-4121-a6c8-\
83b0c74213f3"],

Cell[TextData[{
 "Note that this antisymmetrized wavefunction is very similar to that of the \
helium atom in the Hartree-Fock approximation, only we have replaced the \
hydrogen-like 1",
 StyleBox["s",
  FontSlant->"Italic"],
 " atomic orbital ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Phi]", 
    RowBox[{"1", "s"}]], TraditionalForm]],ExpressionUUID->
  "c6ed07f5-26ed-444a-bd79-d0f8b6edd001"],
 " with the bonding molecular orbital ",
 Cell[BoxData[
  SubscriptBox["\[Psi]", "+"]],
  CellChangeTimes->{{3.8132221669142685`*^9, 3.8132221794693403`*^9}, {
    3.8132222690385857`*^9, 3.813222292552426*^9}, {3.8132225103046436`*^9, 
    3.8132225357976294`*^9}, 3.813225530724597*^9, {3.8132268996594105`*^9, 
    3.8132268997936573`*^9}, {3.8132269718506794`*^9, 
