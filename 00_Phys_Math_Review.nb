Cell[CellGroupData[{

Cell["The Complex Conjugate", "Subsection",
 CellChangeTimes->{{3.808040381284919*^9, 
  3.8080403888156047`*^9}},ExpressionUUID->"9fff9bfe-47c0-418f-b286-\
d720f3d5dfe2"],

Cell[TextData[{
 "The complex conjugate is a concept that we will encounter frequently in \
this course. For a complex number ",
 StyleBox["z",
  FontSlant->"Italic"],
 ","
}], "Text",
 CellChangeTimes->{{3.808040391399122*^9, 3.808040643839892*^9}, {
  3.808040692804758*^9, 3.808040738581745*^9}, {3.839509360321932*^9, 
  3.839509361380593*^9}},ExpressionUUID->"3b49db52-845f-477a-96aa-\
c6fcd4e0c6fc"],

Cell[BoxData[
 RowBox[{
  StyleBox["z",
   FontSlant->"Italic"], 
  StyleBox["=",
   FontSlant->"Plain"], 
  RowBox[{
   StyleBox["x",
    FontSlant->"Italic"], "+", 
   StyleBox[
    RowBox[{"\[ImaginaryI]", 
     StyleBox["y",
      FontSlant->"Italic"]}]]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.839509383262422*^9, 
  3.839509395988185*^9}},ExpressionUUID->"e522b3cd-9a79-4e79-ab2d-\
5417fe91487c"],

Cell[TextData[{
 "the complex conjugate ",
 Cell[BoxData[
  SuperscriptBox[
   StyleBox["z",
    FontSlant->"Italic"], "\[Star]"]],
  CellChangeTimes->{{3.839509424141385*^9, 3.839509452022829*^9}},
  ExpressionUUID->"1b9a6e5d-47bb-4399-8701-dc7d4a9cf920"],
 " is defined as "
}], "Text",
 CellChangeTimes->{{3.8395093732964134`*^9, 3.839509412516292*^9}, {
  3.839509461089035*^9, 
  3.8395094629978333`*^9}},ExpressionUUID->"aaf68644-770b-40f2-ba48-\
23d20309f578"],

Cell[BoxData[
 RowBox[{
  SuperscriptBox[
   StyleBox["z",
    FontSlant->"Italic"], "\[Star]"], 
  StyleBox["=",
   FontSlant->"Plain"], 
  RowBox[{
   StyleBox["x",
    FontSlant->"Italic"], "\[Minus]", 
   StyleBox[
    RowBox[{"\[ImaginaryI]", 
     StyleBox["y",
      FontSlant->"Italic"]}]]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.839509424141385*^9, 
  3.839509487189153*^9}},ExpressionUUID->"2fceadb3-bb7c-4c8d-b26d-\
3b71ef45517e"],

Cell["This concept will be important later on.", "Text",
 CellChangeTimes->{
  3.839509420863961*^9, {3.8395094670611405`*^9, 
   3.839509470528284*^9}},ExpressionUUID->"5cc8fee3-2f69-49ea-b6c4-\
886fa5cc0d88"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Polar Coordinates and the Complex Plane", "Subsection",
 CellChangeTimes->{{3.8074420114667244`*^9, 
  3.80744202204097*^9}},ExpressionUUID->"fc3ec695-237c-4e4e-bb46-\
383ef0bb1040"],

Cell["\<\
If we want to instead multiply two complex numbers, then things are a bit \
more complicated\
\>", "Text",
 CellChangeTimes->{{3.8074408501633205`*^9, 3.8074410545286245`*^9}, {
  3.8074410932371874`*^9, 3.807441190996416*^9}, {3.8074420460243435`*^9, 
  3.8074421253341603`*^9}, {3.839509628384573*^9, 
  3.8395096305257683`*^9}},ExpressionUUID->"308e2d1c-b4e7-4437-85be-\
2f988aa95c9a"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   SubscriptBox[
    StyleBox["z",
     FontSlant->"Italic"], "1"], 
   SubscriptBox[
    StyleBox["z",
     FontSlant->"Italic"], "2"]}], "=", 
  RowBox[{
   RowBox[{"(", 
    RowBox[{
     SubscriptBox[
      StyleBox["x",
       FontSlant->"Italic"], "1"], "+", 
     SubscriptBox[
      StyleBox[
       RowBox[{"\[ImaginaryI]", 
        StyleBox["y",
         FontSlant->"Italic"]}]], "1"]}], ")"}], 
   RowBox[{"(", 
    RowBox[{
     SubscriptBox[
      StyleBox["x",
       FontSlant->"Italic"], "2"], "+", 
     SubscriptBox[
      StyleBox[
       RowBox[{"\[ImaginaryI]", 
        StyleBox["y",
         FontSlant->"Italic"]}]], "2"]}], ")"}]}]}], "\[IndentingNewLine]", 
 RowBox[{"\t", 
  RowBox[{"=", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{
       SubscriptBox[
        StyleBox["x",
         FontSlant->"Italic"], "1"], 
       SubscriptBox[
        StyleBox["x",
         FontSlant->"Italic"], "2"]}], "\[Minus]", 
      RowBox[{
       SubscriptBox[
        StyleBox["y",
         FontSlant->"Italic"], "1"], 
       SubscriptBox[
        StyleBox["y",
         FontSlant->"Italic"], "2"]}]}], ")"}], "+", 
    RowBox[{"\[ImaginaryI]", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{
        SubscriptBox[
         StyleBox["x",
          FontSlant->"Italic"], "1"], 
        SubscriptBox[
         StyleBox["y",
          FontSlant->"Italic"], "2"]}], "+", 
       RowBox[{
        SubscriptBox[
         StyleBox["x",
          FontSlant->"Italic"], "2"], 
        SubscriptBox[
         StyleBox["y",
          FontSlant->"Italic"], "1"]}]}], 
      ")"}]}]}]}]}]}], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.839509657301394*^9, 
  3.8395097608772507`*^9}},ExpressionUUID->"76693401-8491-417b-9431-\
97614cd03b2b"],

Cell["\<\
We can\[CloseCurlyQuote]t really easily represent this equation using the \
vector approach we used for addition. But we can transform to polar \
coordinates using some trigonometric identities, as represented visually in \
Figure 0.4.\
\>", "Text",
 CellChangeTimes->{{3.8395096329646006`*^9, 3.8395096365734367`*^9}, {
  3.8395097677097235`*^9, 3.8395097859910803`*^9}, {3.9144070699148207`*^9, 
