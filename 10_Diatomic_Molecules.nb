YGBgYGBgYGBgYGBgYGBgYGBgYGBgYGBgYGBgYGBgYGBgYPy/4n9TUxM6
    "], {{0, 214.5}, {337.5, 0}}, {0, 255},
    ColorFunction->RGBColor,
    ImageResolution->{96, 96}],
   BoxForm`ImageTag["Byte", ColorSpace -> "RGB", Interleaving -> True],
   Selectable->False],
  DefaultBaseStyle->"ImageGraphics",
  ImageSizeRaw->{337.5, 214.5},
  PlotRange->{{0, 337.5}, {0, 214.5}}]], "Output",
 CellChangeTimes->{{3.813224392707996*^9, 3.813224396349557*^9}},
 CellLabel->"Out[2]=",ExpressionUUID->"23ce119d-01ab-4c6e-867f-ca85bdcc3892"]
}, {2}]],

Cell[TextData[{
 StyleBox["Figure 10.2",
  FontWeight->"Bold"],
 ". Exemplary multidimensional potential energy surface (in this case for \
water) showing how the potential energy changes with degrees of freedom. \
Wikimedia, 2013, AimNature, CC BY-SA 3.0, \
https://commons.wikimedia.org/wiki/File:Potential_Energy_Surface_for_Water.\
png."
}], "Affiliation",
 CellChangeTimes->{{3.809435027311596*^9, 3.8094350763900714`*^9}, {
  3.80943583474421*^9, 3.8094358359299717`*^9}, {3.8094472165104203`*^9, 
  3.809447281165168*^9}, {3.809510876137825*^9, 3.809510907739876*^9}, {
  3.809968073566992*^9, 3.8099681536568317`*^9}, {3.810557260250428*^9, 
  3.8105572606139913`*^9}, {3.8130835305386977`*^9, 3.8130836194514275`*^9}, {
  3.813224407772764*^9, 3.8132244817756805`*^9}, {3.9185832345870714`*^9, 
  3.91858323498123*^9}, {3.93748647145154*^9, 
  3.9374864719113636`*^9}},ExpressionUUID->"4db40497-09b1-497a-ac18-\
240bb74a0620"],

Cell["The nuclear Hamiltonian", "Text",
 CellChangeTimes->{{3.8132236708225884`*^9, 3.813223706294486*^9}, 
   3.8132237438240323`*^9, 
   3.9185832474871225`*^9},ExpressionUUID->"307ab030-7c01-4500-bda7-\
e8a32790bf03"],

Cell[BoxData[
 RowBox[{
  SubscriptBox[
   OverscriptBox[
    StyleBox["H",
     FontSlant->"Italic"], "^"], 
   StyleBox["N",
    FontSlant->"Italic"]], "=", 
  RowBox[{"[", 
   RowBox[{
    RowBox[{
     SubscriptBox[
      OverscriptBox[
       StyleBox["T",
        FontSlant->"Italic"], "^"], 
      StyleBox["N",
       FontSlant->"Italic"]], 
     RowBox[{"(", 
      StyleBox["R",
       FontSlant->"Italic"], 
      StyleBox[")",
       FontSlant->"Italic"]}]}], "+", 
    SubscriptBox[
     StyleBox["E",
      FontSlant->"Italic"], 
     StyleBox["e",
      FontSlant->"Italic"]]}], 
   StyleBox["]",
    FontSlant->"Italic"]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8132221669142685`*^9, 3.8132221794693403`*^9}, {
   3.8132222690385857`*^9, 3.813222292552426*^9}, {3.813223201970694*^9, 
   3.8132232122467637`*^9}, {3.813223607071082*^9, 3.813223609461746*^9}, {
   3.8132237107863455`*^9, 3.81322373031669*^9}, 
   3.813225580580902*^9},ExpressionUUID->"6c1876b2-08ca-4555-8823-\
dd0105e74f43"],

Cell["\<\
can be separated into rotational, vibrational, and translational \
contributions.\
\>", "Text",
 CellChangeTimes->{{3.813223734036147*^9, 3.8132237588901453`*^9}, {
  3.813224516712585*^9, 
  3.813224517925229*^9}},ExpressionUUID->"97a6494c-baf4-4e1e-82f1-\
adcac6882fa1"],

Cell["\<\
In practice, the application of the Born-Oppenheimer approximation to \
predicting molecular structure employs the following steps. \
\>", "Text",
 CellChangeTimes->{{3.813226097156725*^9, 3.8132263848274975`*^9}, 
   3.9185832604564447`*^9},ExpressionUUID->"9930b21d-57e9-4096-8575-\
a6ed3f29f208"],

Cell["\<\
Solve for the electronic energy of a system with a fixed arrangement of the \
nuclei. \
\>", "ItemNumbered",
 CellChangeTimes->{{3.9185832673374615`*^9, 
  3.9185832836973276`*^9}},ExpressionUUID->"224a523c-5eeb-4e0d-b1f1-\
370535dc9279"],

Cell["\<\
Move the nuclei until we find the configuration that gives the lowest \
electronic energy, which gives us what we call typically refer to as the \
low-energy structure of the molecule (for example the minimum in Figure 9.1).\
\>", "ItemNumbered",
 CellChangeTimes->{{3.9185832673374615`*^9, 
  3.9185833135411434`*^9}},ExpressionUUID->"50fe455d-b726-4062-8cf9-\
95810fa88a1f"],

Cell["\<\
Use the nuclear wavefunction and nuclear Hamiltonian to find additional \
properties of the system, such as rotational constants and vibrational \
frequencies. \
\>", "ItemNumbered",
 CellChangeTimes->{{3.9185832673374615`*^9, 
  3.9185833248689713`*^9}},ExpressionUUID->"c55b4966-e2a9-4b5e-af33-\
52481c5d76a5"],

Cell["\<\
All of these approaches are relevant for the ground electronic state; \
calculating excited electronic states typically requires more complicated \
approaches. \
\>", "Text",
 CellChangeTimes->{{3.9185832673374615`*^9, 
  3.9185833196101527`*^9}},ExpressionUUID->"62db96e2-a7e5-4b43-b283-\
721503e12914"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Molecular Orbital Theory and Diatomics", "Section",
 CellChangeTimes->{{3.813225617375743*^9, 3.813225629468442*^9}, {
  3.8132258626804914`*^9, 
  3.813225870188713*^9}},ExpressionUUID->"c05bdc4c-9741-487b-8f44-\
a6ad923eb365"],

Cell["\<\
Now that we have given a broad overview of the Born-Oppenheimer \
approximation, let\[CloseCurlyQuote]s dive into a simple case of a diatomic \
molecule that will introduce us to the concepts of molecular orbital theory \
and the linear combination of atomic orbitals.\
\>", "Text",
 CellChangeTimes->{{3.8132263922165413`*^9, 3.8132264110000057`*^9}, {
  3.8132264784065266`*^9, 3.8132265373480735`*^9}, {3.8132266013465586`*^9, 
  3.813226606973198*^9}, {3.91950396600353*^9, 
  3.919503974887971*^9}},ExpressionUUID->"6388f120-e0af-4b09-bba1-\
48740a9ec617"],

Cell[CellGroupData[{

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   SubsuperscriptBox[
    StyleBox["H",
     FontSlant->"Plain"], "2", "+"], TraditionalForm]],ExpressionUUID->
  "165f6c13-3ddc-4594-8038-448d577c3888"],
 ", LCAO, and MO"
}], "Subsection",
 CellChangeTimes->{{3.8132266459003563`*^9, 
  3.8132266548197384`*^9}},ExpressionUUID->"8083f29b-66c5-4489-ac0c-\
04f067d6bd57"],

Cell[TextData[{
 "Let\[CloseCurlyQuote]s begin with the simplest possible molecule, ",
 Cell[BoxData[
  FormBox[
   SubsuperscriptBox[
    StyleBox["H",
     FontSlant->"Plain"], "2", "+"], TraditionalForm]],ExpressionUUID->
  "a8dc0367-23aa-407d-8211-a6e01dbd1d78"],
 ", which comprises only two protons and one electron. Using the \
Born-Oppenheimer approximation, we can write the electronic Hamiltonian for ",
 Cell[BoxData[
  FormBox[
   SubsuperscriptBox[
    StyleBox["H",
     FontSlant->"Plain"], "2", "+"], TraditionalForm]],ExpressionUUID->
  "07e15cf9-1242-414a-b273-fcb60cb2b547"],
 " as"
}], "Text",
 CellChangeTimes->{{3.813226665703837*^9, 3.8132266991818285`*^9}, {
  3.81322682109072*^9, 
  3.813226871023635*^9}},ExpressionUUID->"9e7a0fb2-a11b-4e44-92da-\
4a05d426746d"],

Cell[BoxData[
 RowBox[{
  SubscriptBox[
   OverscriptBox[
    StyleBox["H",
     FontSlant->"Italic"], "^"], 
   StyleBox["e",
    FontSlant->"Italic"]], "=", 
  RowBox[{
   RowBox[{
    RowBox[{
     SubscriptBox[
      OverscriptBox[
       StyleBox["T",
        FontSlant->"Italic"], "^"], 
      StyleBox["e",
       FontSlant->"Italic"]], 
     RowBox[{"(", 
      StyleBox["r",
       FontSlant->"Italic"], 
      StyleBox[")",
       FontSlant->"Italic"]}]}], "+", 
    RowBox[{
     SubscriptBox[
      OverscriptBox[
       StyleBox["V",
        FontSlant->"Italic"], "^"], 
      StyleBox["eN",
       FontSlant->"Italic"]], 
     RowBox[{"(", 
      RowBox[{
       StyleBox["r",
        FontSlant->"Italic"], 
       StyleBox[",",
        FontSlant->"Plain"], 
       StyleBox["R",
        FontSlant->"Italic"]}], 
      StyleBox[")",
       FontSlant->"Italic"]}]}], "+", 
    RowBox[{
     SubscriptBox[
      OverscriptBox[
       StyleBox["V",
        FontSlant->"Italic"], "^"], 
      StyleBox["NN",
       FontSlant->"Italic"]], 
     RowBox[{"(", 
      StyleBox["R",
       FontSlant->"Italic"], 
      StyleBox[")",
       FontSlant->"Italic"]}]}]}], "=", 
   RowBox[{
    RowBox[{
     RowBox[{"-", 
      FractionBox["1", "2"]}], 
     RowBox[{
      SuperscriptBox["\[Del]", "2"], 
      RowBox[{"-", 
       FractionBox["1", 
        SubscriptBox[
         StyleBox["r",
          FontSlant->"Italic"], 
         StyleBox["A",
          FontSlant->"Italic"]]]}]}]}], "-", 
    FractionBox["1", 
     SubscriptBox[
      StyleBox["r",
       FontSlant->"Italic"], 
      StyleBox["B",
       FontSlant->"Italic"]]], "+", 
    FractionBox["1", 
     StyleBox[
      SubscriptBox["R", "AB"],
      FontSlant->"Italic"]]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8132221669142685`*^9, 3.8132221794693403`*^9}, {
   3.8132222690385857`*^9, 3.813222292552426*^9}, {3.8132225103046436`*^9, 
   3.8132225357976294`*^9}, 3.813225530724597*^9, {3.8132268996594105`*^9, 
   3.8132268997936573`*^9}, {3.8132269718506794`*^9, 
   3.8132270598936987`*^9}, {3.813227090063882*^9, 
   3.8132270928942423`*^9}},ExpressionUUID->"41eb1d72-ea38-314d-9ab0-\
11e78537ac4f"],

Cell[TextData[{
 "where the nuclei are labeled as ",
 StyleBox["A",
  FontSlant->"Italic"],
 " and ",
 StyleBox["B",
  FontSlant->"Italic"],
 " with charge ",
 StyleBox["Z",
  FontSlant->"Italic"],
 " = 1. The first term is the kinetic energy operator of the electron, and \
the second two terms are the attractive interactions of the electron with the \
two nuclei (",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["r",
    FontSlant->"Italic"], 
   StyleBox["A",
    FontSlant->"Italic"]]],
  CellChangeTimes->{{3.8132221669142685`*^9, 3.8132221794693403`*^9}, {
    3.8132222690385857`*^9, 3.813222292552426*^9}, {3.8132225103046436`*^9, 
    3.8132225357976294`*^9}, 3.813225530724597*^9, {3.8132268996594105`*^9, 
    3.8132268997936573`*^9}, {3.8132269718506794`*^9, 
    3.8132270598936987`*^9}, {3.813227090063882*^9, 3.8132270928942423`*^9}, {
    3.9185834681860356`*^9, 3.9185835598910704`*^9}},ExpressionUUID->
  "88656f46-6a18-4940-9dfc-6803706bf649"],
 " and ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["r",
    FontSlant->"Italic"], 
   StyleBox["B",
    FontSlant->"Italic"]]],
  CellChangeTimes->{{3.8132221669142685`*^9, 3.8132221794693403`*^9}, {
    3.8132222690385857`*^9, 3.813222292552426*^9}, {3.8132225103046436`*^9, 
    3.8132225357976294`*^9}, 3.813225530724597*^9, {3.8132268996594105`*^9, 
    3.8132268997936573`*^9}, {3.8132269718506794`*^9, 
    3.8132270598936987`*^9}, {3.813227090063882*^9, 3.8132270928942423`*^9}, {
    3.9185834681860356`*^9, 3.9185835598910704`*^9}},ExpressionUUID->
  "ec039c94-7bb8-4995-b489-621907452d27"],
 " are the distances between the electron and the two nuclei). Because we \
only have two nuclei, we can use the notation ",
 Cell[BoxData[
  RowBox[{
   StyleBox[
    SubscriptBox["R", "AB"],
    FontSlant->"Italic"], "=", 
   StyleBox["R",
    FontSlant->"Italic"]}]],
  CellChangeTimes->{{3.8132221669142685`*^9, 3.8132221794693403`*^9}, {
    3.8132222690385857`*^9, 3.813222292552426*^9}, {3.8132225103046436`*^9, 
    3.8132225357976294`*^9}, 3.813225530724597*^9, {3.8132268996594105`*^9, 
    3.8132268997936573`*^9}, {3.8132269718506794`*^9, 
    3.8132270598936987`*^9}, {3.813227090063882*^9, 3.8132270928942423`*^9}},
  ExpressionUUID->"f1be379d-6c1f-490f-beb4-674b7e88e254"],
 " (the distance between the nuclei) for simplicity. Note that we don\
\[CloseCurlyQuote]t have an interelectronic repulsion term ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    OverscriptBox[
     StyleBox["V",
      FontSlant->"Italic"], "^"], 
    StyleBox["ee",
     FontSlant->"Italic"]], 
   RowBox[{"(", 
    StyleBox["r",
     FontSlant->"Italic"], 
    StyleBox[")",
     FontSlant->"Italic"]}]}]],
  CellChangeTimes->{{3.8130765928719873`*^9, 3.8130766419857407`*^9}, {
    3.813076783365462*^9, 3.813076786478775*^9}, 3.81307681962652*^9, {
    3.813076858567613*^9, 3.8130769013064566`*^9}, {3.813076997386063*^9, 
    3.813077009755924*^9}, {3.8130770864080315`*^9, 3.81307710002981*^9}},
  ExpressionUUID->"3d6891db-46a8-4491-bd3a-b065c65935ad"],
 "because we only have one electron. "
}], "Text",
 CellChangeTimes->{{3.813226902364891*^9, 3.81322694808644*^9}, {
  3.813227064099454*^9, 3.8132270848121147`*^9}, {3.81322711590812*^9, 
  3.81322714650842*^9}, {3.9185835722734985`*^9, 3.918583574996174*^9}, {
  3.9195040580593405`*^9, 
  3.919504139701167*^9}},ExpressionUUID->"b2110264-d7e2-4421-a16e-\
739387380597"],

Cell["\<\
We want to solve the corresponding electronic Schr\[ODoubleDot]dinger \
equation,\
\>", "Text",
 CellChangeTimes->{{3.8132273327690926`*^9, 
  3.8132273608413258`*^9}},ExpressionUUID->"128b8125-3e33-4462-aa75-\
6337e17661da"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   SubscriptBox[
    OverscriptBox[
     StyleBox["H",
      FontSlant->"Italic"], "^"], 
    StyleBox["e",
     FontSlant->"Italic"]], 
   SubscriptBox["\[Psi]", 
    StyleBox["e",
     FontSlant->"Italic"]], 
   RowBox[{"(", 
    RowBox[{
     StyleBox[
      SubscriptBox[
       StyleBox["r",
        FontWeight->"Bold",
        FontSlant->"Italic"], "A"],
      FontWeight->"Bold"], ",", 
     StyleBox[" ",
      FontWeight->"Bold"], 
     RowBox[{
      StyleBox[
       SubscriptBox[
        StyleBox["r",
         FontWeight->"Bold",
         FontSlant->"Italic"], "B"],
       FontWeight->"Bold"], ";", 
      StyleBox[" ",
       FontWeight->"Plain",
       FontSlant->"Italic"], 
      StyleBox["R",
       FontSlant->"Italic"]}]}], ")"}]}], "=", 
  RowBox[{
   SubscriptBox[
    StyleBox["E",
     FontSlant->"Italic"], 
    StyleBox["e",
     FontSlant->"Italic"]], 
   SubscriptBox["\[Psi]", 
    StyleBox["e",
     FontSlant->"Italic"]], 
   RowBox[{"(", 
    RowBox[{
     StyleBox[
      SubscriptBox[
       StyleBox["r",
        FontWeight->"Bold",
        FontSlant->"Italic"], "A"],
      FontWeight->"Bold"], ",", 
     StyleBox[" ",
      FontWeight->"Bold"], 
     RowBox[{
      StyleBox[
       SubscriptBox[
        StyleBox["r",
         FontWeight->"Bold",
         FontSlant->"Italic"], "B"],
       FontWeight->"Bold"], ";", 
      StyleBox[" ",
       FontWeight->"Plain",
       FontSlant->"Italic"], 
      StyleBox["R",
       FontSlant->"Italic"]}]}], ")"}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8132221669142685`*^9, 3.8132221794693403`*^9}, {
   3.8132222690385857`*^9, 3.813222292552426*^9}, {3.8132225103046436`*^9, 
   3.8132225357976294`*^9}, 3.813225530724597*^9, {3.8132268996594105`*^9, 
   3.8132268997936573`*^9}, {3.8132269718506794`*^9, 
   3.8132270598936987`*^9}, {3.813227090063882*^9, 3.8132270928942423`*^9}, {
   3.8132273687054873`*^9, 3.8132273956726027`*^9}, {3.8132274257354927`*^9, 
   3.8132274504676456`*^9}, {3.813227484968296*^9, 3.8132274916733313`*^9}, {
   3.813233648321498*^9, 
   3.8132336553729615`*^9}},ExpressionUUID->"b7803d65-bd35-4feb-a59f-\
2caa85698574"],

Cell[TextData[{
 "for the trial electronic wavefunction ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox["\[Phi]", 
    StyleBox["e",
     FontSlant->"Italic"]], 
   RowBox[{"(", 
    RowBox[{
     StyleBox[
      SubscriptBox[
       StyleBox["r",
        FontWeight->"Bold",
        FontSlant->"Italic"], "A"],
      FontWeight->"Bold"], ",", 
     StyleBox[" ",
      FontWeight->"Bold"], 
     RowBox[{
      StyleBox[
       SubscriptBox[
        StyleBox["r",
         FontWeight->"Bold",
         FontSlant->"Italic"], "B"],
       FontWeight->"Bold"], ";", 
      StyleBox[" ",
       FontWeight->"Plain",
       FontSlant->"Italic"], 
      StyleBox["R",
       FontSlant->"Italic"]}]}], ")"}]}]],
  CellChangeTimes->{{3.8132221669142685`*^9, 3.8132221794693403`*^9}, {
    3.8132222690385857`*^9, 3.813222292552426*^9}, {3.8132225103046436`*^9, 
    3.8132225357976294`*^9}, 3.813225530724597*^9, {3.8132268996594105`*^9, 
    3.8132268997936573`*^9}, {3.8132269718506794`*^9, 
    3.8132270598936987`*^9}, {3.813227090063882*^9, 3.8132270928942423`*^9}, {
    3.8132273687054873`*^9, 3.8132273956726027`*^9}, {3.8132274257354927`*^9, 
    3.8132274504676456`*^9}, {3.813227484968296*^9, 3.8132274916733313`*^9}},
  ExpressionUUID->"fd72373e-9cde-433e-b812-0a93dda4d629"],
 ". "
}], "Text",
 CellChangeTimes->{{3.8132275554274797`*^9, 
  3.8132276171468086`*^9}},ExpressionUUID->"c3cea10b-5f9a-40fc-a8bf-\
5d63f63cfbcd"],

Cell[TextData[{
 "But what form should this trial electronic wavefunction take? We will use \
the linear combination of atomic orbitals (LCAO) approach, in which we \
represent the possible trial wavefunction as a linear combination of the \
atomic orbitals on each atom. For ",
 Cell[BoxData[
  FormBox[
   SubsuperscriptBox[
    StyleBox["H",
     FontSlant->"Plain"], "2", "+"], TraditionalForm]],ExpressionUUID->
  "ba7a5ccd-8cbc-4049-b3e6-35240caea75c"],
 ", we can begin with a simple trial wavefunction composed of only two atomic \
orbitals,"
}], "Text",
 CellChangeTimes->{{3.8132276213229055`*^9, 
  3.81322770853082*^9}},ExpressionUUID->"83da23b9-53d6-4638-b2d1-\
b2127fc990bc"],

Cell[BoxData[
 RowBox[{
  SubscriptBox["\[Psi]", 
   StyleBox["e",
    FontSlant->"Italic"]], "=", 
  RowBox[{
   RowBox[{
    SubscriptBox[
     StyleBox["c",
      FontSlant->"Italic"], "1"], 
    SubscriptBox["\[Phi]", 
     RowBox[{"1", 
      SubscriptBox[
       StyleBox["s",
        FontSlant->"Italic"], 
       StyleBox["A",
        FontSlant->"Italic"]]}]]}], "+", 
   RowBox[{
    SubscriptBox[
     StyleBox["c",
      FontSlant->"Italic"], "2"], 
    SubscriptBox["\[Phi]", 
     RowBox[{"1", 
      SubscriptBox[
       StyleBox["s",
        FontSlant->"Italic"], 
       StyleBox["B",
        FontSlant->"Italic"]]}]]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8132221669142685`*^9, 3.8132221794693403`*^9}, {
   3.8132222690385857`*^9, 3.813222292552426*^9}, {3.8132225103046436`*^9, 
   3.8132225357976294`*^9}, 3.813225530724597*^9, {3.8132268996594105`*^9, 
   3.8132268997936573`*^9}, {3.8132269718506794`*^9, 
   3.8132270598936987`*^9}, {3.813227090063882*^9, 3.8132270928942423`*^9}, {
   3.8132273687054873`*^9, 3.8132273956726027`*^9}, {3.8132274257354927`*^9, 
   3.8132274504676456`*^9}, {3.813227484968296*^9, 3.8132274916733313`*^9}, {
   3.813227717592659*^9, 3.813227799104663*^9}, {3.8132278524338465`*^9, 
   3.813227854764579*^9}, 3.8132279269606223`*^9, {3.81323366169593*^9, 
   3.813233662702242*^9}},ExpressionUUID->"c1bc1397-b051-4e3c-8682-\
ed317083955f"],

Cell[TextData[{
 "In other words, we will try to construct our wavefunction as a linear \
combination of a 1",
 StyleBox["s",
  FontSlant->"Italic"],
 " atomic orbital around proton ",
 StyleBox["A",
  FontSlant->"Italic"],
 " and a 1",
 StyleBox["s",
  FontSlant->"Italic"],
 " atomic orbital around proton ",
 StyleBox["B",
  FontSlant->"Italic"],
 ". "
}], "Text",
 CellChangeTimes->{{3.813227785506302*^9, 3.8132278456528454`*^9}, {
  3.813227948872312*^9, 3.8132279693500476`*^9}, {3.9185836213580856`*^9, 
  3.9185836290120335`*^9}},ExpressionUUID->"c85291b9-854f-4299-9b82-\
8b0369106449"],

Cell[TextData[{
 "To find the values of the weighting coefficients ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["c",
    FontSlant->"Italic"], "1"]],
  CellChangeTimes->{{3.8132221669142685`*^9, 3.8132221794693403`*^9}, {
    3.8132222690385857`*^9, 3.813222292552426*^9}, {3.8132225103046436`*^9, 
    3.8132225357976294`*^9}, 3.813225530724597*^9, {3.8132268996594105`*^9, 
    3.8132268997936573`*^9}, {3.8132269718506794`*^9, 
    3.8132270598936987`*^9}, {3.813227090063882*^9, 3.8132270928942423`*^9}, {
    3.8132273687054873`*^9, 3.8132273956726027`*^9}, {3.8132274257354927`*^9, 
    3.8132274504676456`*^9}, {3.813227484968296*^9, 3.8132274916733313`*^9}, {
    3.813227717592659*^9, 3.813227799104663*^9}, {3.8132278524338465`*^9, 
    3.813227854764579*^9}, 3.8132279269606223`*^9},ExpressionUUID->
  "d832fb68-8d9a-4bdf-892d-1f1c1a90c1e1"],
 " and ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["c",
    FontSlant->"Italic"], "2"]],
  CellChangeTimes->{{3.8132221669142685`*^9, 3.8132221794693403`*^9}, {
    3.8132222690385857`*^9, 3.813222292552426*^9}, {3.8132225103046436`*^9, 
    3.8132225357976294`*^9}, 3.813225530724597*^9, {3.8132268996594105`*^9, 
    3.8132268997936573`*^9}, {3.8132269718506794`*^9, 
    3.8132270598936987`*^9}, {3.813227090063882*^9, 3.8132270928942423`*^9}, {
    3.8132273687054873`*^9, 3.8132273956726027`*^9}, {3.8132274257354927`*^9, 
    3.8132274504676456`*^9}, {3.813227484968296*^9, 3.8132274916733313`*^9}, {
    3.813227717592659*^9, 3.813227799104663*^9}, {3.8132278524338465`*^9, 
    3.813227854764579*^9}, 3.8132279269606223`*^9},ExpressionUUID->
  "9547ec63-dbb5-424b-92d1-2849ccba6d06"],
 ", we would in principle need to solve for the energies and eigenvalues \
using the variational method,"
}], "Text",
 CellChangeTimes->{{3.813227979550091*^9, 
  3.813228029639391*^9}},ExpressionUUID->"3041b47d-5c17-41a1-aeb4-\
910bab492ae9"],

Cell[BoxData[
 RowBox[{
  SubscriptBox[
   StyleBox["E",
    FontSlant->"Italic"], 
   StyleBox["e",
    FontSlant->"Italic"]], "=", 
  FractionBox[
   RowBox[{"\[LeftAngleBracket]", 
    RowBox[{
     RowBox[{
      RowBox[{
       SubscriptBox[
        StyleBox["c",
         FontSlant->"Italic"], "1"], 
       SubscriptBox["\[Phi]", 
        RowBox[{"1", 
         SubscriptBox[
          StyleBox["s",
           FontSlant->"Italic"], 
          StyleBox["A",
           FontSlant->"Italic"]]}]]}], "+", 
      RowBox[{
       SubscriptBox[
        StyleBox["c",
         FontSlant->"Italic"], "2"], 
       SubscriptBox["\[Phi]", 
        RowBox[{"1", 
         SubscriptBox[
          StyleBox["s",
           FontSlant->"Italic"], 
          StyleBox["B",
           FontSlant->"Italic"]]}]]}]}], "|", 
     SubscriptBox[
      OverscriptBox[
       StyleBox["H",
        FontSlant->"Italic"], "^"], 
      StyleBox["e",
       FontSlant->"Italic"]], "|", 
     RowBox[{
      RowBox[{
       SubscriptBox[
        StyleBox["c",
         FontSlant->"Italic"], "1"], 
       SubscriptBox["\[Phi]", 
        RowBox[{"1", 
         SubscriptBox[
          StyleBox["s",
           FontSlant->"Italic"], 
          StyleBox["A",
           FontSlant->"Italic"]]}]]}], "+", 
      RowBox[{
       SubscriptBox[
        StyleBox["c",
         FontSlant->"Italic"], "2"], 
       SubscriptBox["\[Phi]", 
        RowBox[{"1", 
         SubscriptBox[
          StyleBox["s",
           FontSlant->"Italic"], 
          StyleBox["B",
           FontSlant->"Italic"]]}]]}]}]}], "\[RightAngleBracket]"}], 
   RowBox[{"\[LeftAngleBracket]", 
    RowBox[{
     RowBox[{
      RowBox[{
       SubscriptBox[
        StyleBox["c",
         FontSlant->"Italic"], "1"], 
       SubscriptBox["\[Phi]", 
        RowBox[{"1", 
         SubscriptBox[
          StyleBox["s",
           FontSlant->"Italic"], 
          StyleBox["A",
           FontSlant->"Italic"]]}]]}], "+", 
      RowBox[{
       SubscriptBox[
        StyleBox["c",
         FontSlant->"Italic"], "2"], 
       SubscriptBox["\[Phi]", 
        RowBox[{"1", 
         SubscriptBox[
          StyleBox["s",
           FontSlant->"Italic"], 
          StyleBox["B",
           FontSlant->"Italic"]]}]]}]}], "|", 
     RowBox[{
      RowBox[{
       SubscriptBox[
        StyleBox["c",
         FontSlant->"Italic"], "1"], 
       SubscriptBox["\[Phi]", 
        RowBox[{"1", 
         SubscriptBox[
          StyleBox["s",
           FontSlant->"Italic"], 
          StyleBox["A",
           FontSlant->"Italic"]]}]]}], "+", 
      RowBox[{
       SubscriptBox[
        StyleBox["c",
         FontSlant->"Italic"], "2"], 
       SubscriptBox["\[Phi]", 
        RowBox[{"1", 
         SubscriptBox[
          StyleBox["s",
           FontSlant->"Italic"], 
          StyleBox["B",
           FontSlant->"Italic"]]}]]}]}]}], 
    "\[RightAngleBracket]"}]]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.813228038288596*^9, 
  3.813228093385758*^9}},ExpressionUUID->"8379045e-0237-674a-a888-\
3a5533fbd6f3"],

Cell[TextData[{
 "However, for ",
 Cell[BoxData[
  FormBox[
   SubsuperscriptBox[
    StyleBox["H",
     FontSlant->"Plain"], "2", "+"], TraditionalForm]],ExpressionUUID->
  "21f451df-fd70-4738-8cb3-b26aa9152033"],
 ", we can logically reason what the form of our wavefunctions will be. For a \
linear combination of two orbitals, as in this case, we obtain two values of ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["E",
    FontSlant->"Italic"], 
   StyleBox["e",
    FontSlant->"Italic"]]],
  CellChangeTimes->{{3.813228038288596*^9, 3.813228093385758*^9}},
  ExpressionUUID->"4f7838a2-b2a0-42d0-b09f-ecf4a01e89ea"],
 " and two corresponding wavefunctions ",
 Cell[BoxData[
  SubscriptBox["\[Psi]", 
   StyleBox["e",
    FontSlant->"Italic"]]],
  CellChangeTimes->{{3.8132221669142685`*^9, 3.8132221794693403`*^9}, {
    3.8132222690385857`*^9, 3.813222292552426*^9}, {3.8132225103046436`*^9, 
    3.8132225357976294`*^9}, 3.813225530724597*^9, {3.8132268996594105`*^9, 
    3.8132268997936573`*^9}, {3.8132269718506794`*^9, 
    3.8132270598936987`*^9}, {3.813227090063882*^9, 3.8132270928942423`*^9}, {
    3.8132273687054873`*^9, 3.8132273956726027`*^9}, {3.8132274257354927`*^9, 
    3.8132274504676456`*^9}, {3.813227484968296*^9, 3.8132274916733313`*^9}, {
    3.813227717592659*^9, 3.813227799104663*^9}, {3.8132278524338465`*^9, 
    3.813227854764579*^9}, 3.8132279269606223`*^9},ExpressionUUID->
  "407369f2-39ef-4e6e-81ef-c5c0659fe6d6"],
 ". "
}], "Text",
 CellChangeTimes->{{3.8132280962023335`*^9, 3.813228210892675*^9}, {
  3.8135866660055676`*^9, 3.813586668146431*^9}, {3.918583660448203*^9, 
  3.918583678227498*^9}},ExpressionUUID->"1fd77a46-3079-4f70-8e25-\
6d5975163365"],

Cell[TextData[{
 "In  ",
 Cell[BoxData[
  FormBox[
   SubsuperscriptBox[
    StyleBox["H",
     FontSlant->"Plain"], "2", "+"], TraditionalForm]],ExpressionUUID->
  "21d9fdcd-07ad-4164-a296-eb10a4b1cc42"],
 ", we have two identical protons, which means that the probability that the \
electron is near ",
 StyleBox["A",
  FontSlant->"Italic"],
 " must be the same as the probability that it is near ",
 StyleBox["B",
  FontSlant->"Italic"],
 ". Mathematically, we find that "
}], "Text",
 CellChangeTimes->{{3.8132282131083393`*^9, 
  3.8132283035445595`*^9}},ExpressionUUID->"def1dbeb-369a-49a7-ae3e-\
f2f592d0dd28"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   StyleBox["|",
    FontSlant->"Italic"], 
   SubscriptBox[
    StyleBox["c",
     FontSlant->"Italic"], "1"], 
   SuperscriptBox["|", "2"]}], "=", 
  RowBox[{"|", 
   SubscriptBox[
    StyleBox["c",
     FontSlant->"Italic"], "2"], 
   SuperscriptBox["|", "2"]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8132283107726665`*^9, 
  3.8132283395321493`*^9}},ExpressionUUID->"620718fd-a41d-44a8-b03b-\
64e0481cb082"],

Cell["There are two possibilities for fulfilling this requirement,", "Text",
 CellChangeTimes->{{3.8132283436115775`*^9, 
  3.813228357457288*^9}},ExpressionUUID->"46d51803-578d-42ee-b566-\
0118f806a7b6"],

Cell[BoxData[
 RowBox[{
  SubscriptBox[
   StyleBox["c",
    FontSlant->"Italic"], "1"], "=", 
  RowBox[{
   SubscriptBox[
    StyleBox["c",
     FontSlant->"Italic"], "2"], "=", 
   SubscriptBox[
    StyleBox["C",
     FontSlant->"Italic"], "+"]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.813228318719289*^9, 3.8132283201318192`*^9}, {
  3.813228368913943*^9, 3.813228378612753*^9}, {3.8132284193255186`*^9, 
  3.813228437905147*^9}},ExpressionUUID->"ed539ff9-ea5e-4a65-940f-\
8de32c8f7518"],

Cell["or", "Text",
 CellChangeTimes->{{3.81322838167857*^9, 
  3.8132283824105415`*^9}},ExpressionUUID->"a26e014c-1766-4bcd-89c8-\
96c63aca3ce0"],

Cell[BoxData[
 RowBox[{
  SubscriptBox[
   StyleBox["c",
    FontSlant->"Italic"], "1"], "=", 
  RowBox[{
   RowBox[{"-", 
    SubscriptBox[
     StyleBox["c",
      FontSlant->"Italic"], "2"]}], "=", 
   SubscriptBox[
    StyleBox["C",
     FontSlant->"Italic"], "-"]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8132283107726665`*^9, 3.8132283395321493`*^9}, {
  3.8132283853988447`*^9, 3.813228394481428*^9}, {3.8132284416311073`*^9, 
  3.8132284452313457`*^9}},ExpressionUUID->"147734a6-0c3b-48e1-af6a-\
736c595581d7"],

Cell["Thus, our two possible electronic eigenfunctions are", "Text",
 CellChangeTimes->{{3.813228447295823*^9, 
  3.813228471274892*^9}},ExpressionUUID->"dd8afe53-bc98-470d-8908-\
135429d35eb1"],

Cell[BoxData[
 RowBox[{
  SubscriptBox["\[Psi]", "+"], "=", 
  RowBox[{
   SubscriptBox[
    StyleBox["C",
     FontSlant->"Italic"], "+"], 
   RowBox[{"(", 
    RowBox[{
     SubscriptBox["\[Phi]", 
      RowBox[{"1", 
       SubscriptBox[
        StyleBox["s",
         FontSlant->"Italic"], 
        StyleBox["A",
         FontSlant->"Italic"]]}]], "+", 
     SubscriptBox["\[Phi]", 
      RowBox[{"1", 
       SubscriptBox[
        StyleBox["s",
         FontSlant->"Italic"], 
        StyleBox["B",
         FontSlant->"Italic"]]}]]}], ")"}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8132221669142685`*^9, 3.8132221794693403`*^9}, {
   3.8132222690385857`*^9, 3.813222292552426*^9}, {3.8132225103046436`*^9, 
   3.8132225357976294`*^9}, 3.813225530724597*^9, {3.8132268996594105`*^9, 
   3.8132268997936573`*^9}, {3.8132269718506794`*^9, 
   3.8132270598936987`*^9}, {3.813227090063882*^9, 3.8132270928942423`*^9}, {
   3.8132273687054873`*^9, 3.8132273956726027`*^9}, {3.8132274257354927`*^9, 
   3.8132274504676456`*^9}, {3.813227484968296*^9, 3.8132274916733313`*^9}, {
   3.813227717592659*^9, 3.813227799104663*^9}, {3.8132278524338465`*^9, 
   3.813227854764579*^9}, 3.8132279269606223`*^9, {3.8132284806854115`*^9, 
   3.8132285040063257`*^9}, {3.813233670328187*^9, 
   3.8132336720975046`*^9}},ExpressionUUID->"2cc9b2ca-f999-4086-8de8-\
0de8ad006a1b"],

Cell["and", "Text",
 CellChangeTimes->{{3.8132284776197124`*^9, 
  3.813228477809259*^9}},ExpressionUUID->"b3674ac1-2ead-47cf-abb8-\
d30e9b29940b"],

Cell[BoxData[
 RowBox[{
  SubscriptBox["\[Psi]", 
   StyleBox["-",
    FontSlant->"Italic"]], "=", 
  RowBox[{
   SubscriptBox[
    StyleBox["C",
     FontSlant->"Italic"], "-"], 
   RowBox[{"(", 
    RowBox[{
     SubscriptBox["\[Phi]", 
      RowBox[{"1", 
       SubscriptBox[
        StyleBox["s",
         FontSlant->"Italic"], 
        StyleBox["A",
         FontSlant->"Italic"]]}]], "-", 
     SubscriptBox["\[Phi]", 
      RowBox[{"1", 
       SubscriptBox[
        StyleBox["s",
         FontSlant->"Italic"], 
        StyleBox["B",
         FontSlant->"Italic"]]}]]}], 
    StyleBox[")",
     FontSlant->"Italic"]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8132221669142685`*^9, 3.8132221794693403`*^9}, {
   3.8132222690385857`*^9, 3.813222292552426*^9}, {3.8132225103046436`*^9, 
   3.8132225357976294`*^9}, 3.813225530724597*^9, {3.8132268996594105`*^9, 
   3.8132268997936573`*^9}, {3.8132269718506794`*^9, 
   3.8132270598936987`*^9}, {3.813227090063882*^9, 3.8132270928942423`*^9}, {
   3.8132273687054873`*^9, 3.8132273956726027`*^9}, {3.8132274257354927`*^9, 
   3.8132274504676456`*^9}, {3.813227484968296*^9, 3.8132274916733313`*^9}, {
   3.813227717592659*^9, 3.813227799104663*^9}, {3.8132278524338465`*^9, 
   3.813227854764579*^9}, 3.8132279269606223`*^9, {3.8132284860819626`*^9, 
   3.8132285176811366`*^9}, {3.813233674404284*^9, 
   3.813233675974839*^9}},ExpressionUUID->"357b19f3-d136-462a-997d-\
1b6bb9eb81bf"],

Cell["\<\
We call these two wavefunctions molecular orbitals. Because they are composed \
of a linear combination of atomic orbitals, they are more specifically LCAO \
molecular orbitals.\
\>", "Text",
 CellChangeTimes->{{3.8132285388694677`*^9, 3.8132285937018747`*^9}, {
  3.918583701488245*^9, 
  3.9185837022662616`*^9}},ExpressionUUID->"f11a63f5-ba41-42d6-9f0e-\
bbf258161fe7"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[{
 "The Energies of the MOs of ",
 Cell[BoxData[
  FormBox[
   SubsuperscriptBox[
    StyleBox["H",
     FontSlant->"Plain"], "2", "+"], TraditionalForm]],ExpressionUUID->
  "082e535d-2f74-4294-927c-a43b44e38c5b"],
 " - Overlap, Attractive, and Exchanged Attractive Integrals"
}], "Subsection",
 CellChangeTimes->{{3.81323346768791*^9, 3.8132335041342564`*^9}, {
  3.9185837279534407`*^9, 3.9185837489627*^9}, {3.9185838491186705`*^9, 
  3.91858385712325*^9}},ExpressionUUID->"95a38cac-6db2-4cbf-9261-\
419505a600ff"],

Cell[CellGroupData[{

Cell["Wavefunction Normalization", "Subsubsection",
 CellChangeTimes->{{3.81323581739636*^9, 
  3.813235820975356*^9}},ExpressionUUID->"8f16ff35-436f-412c-891a-\
22ee7ac50ac7"],

Cell["\<\
Let\[CloseCurlyQuote]s now look at how we would find the energies of the two \
wavefunctions that we found in the previous section. Along the way, we\
\[CloseCurlyQuote]ll encounter the overlap, nuclear exchanged attractive, and \
nuclear attractive integrals and discuss their meaning. We want to find the \
energy corresponding to each wavefunction using the variational method,\
\>", "Text",
 CellChangeTimes->{{3.8132335064030046`*^9, 3.8132336010760393`*^9}, {
  3.9195042530958347`*^9, 3.9195042584487925`*^9}, {3.9195043025220437`*^9, 
  3.9195043288437176`*^9}},ExpressionUUID->"d5dace66-f3bb-4ce6-b03f-\
d30dfb5bee76"],

Cell[BoxData[
 RowBox[{
  SubscriptBox[
   StyleBox["E",
    FontSlant->"Italic"], "\[PlusMinus]"], "=", 
  FractionBox[
   RowBox[{"\[LeftAngleBracket]", 
    RowBox[{
     SubscriptBox["\[Psi]", "\[PlusMinus]"], "|", 
     SubscriptBox[
      OverscriptBox[
       StyleBox["H",
        FontSlant->"Italic"], "^"], 
      StyleBox["e",
       FontSlant->"Italic"]], "|", 
     SubscriptBox["\[Psi]", "\[PlusMinus]"]}], "\[RightAngleBracket]"}], 
   RowBox[{"\[LeftAngleBracket]", 
    RowBox[{
     SubscriptBox["\[Psi]", "\[PlusMinus]"], "|", 
     SubscriptBox["\[Psi]", "\[PlusMinus]"]}], 
    "\[RightAngleBracket]"}]]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.813228038288596*^9, 3.813228093385758*^9}, {
  3.8132336120692124`*^9, 3.8132336334997315`*^9}, {3.8132336788534994`*^9, 
  3.813233689019577*^9}},ExpressionUUID->"098fcdb0-185d-f743-9ce1-\
884a6d6e118f"],

Cell[TextData[{
 "Remember that the denominator gives us the normalization condition for the \
wavefunction ",
 Cell[BoxData[
  SubscriptBox["\[Psi]", "+"]],
  CellChangeTimes->{{3.813228038288596*^9, 3.813228093385758*^9}, {
   3.8132336120692124`*^9, 3.8132336334997315`*^9}, {3.8132336788534994`*^9, 
   3.8132336830249114`*^9}},ExpressionUUID->
  "f26ec3fa-4818-42be-af77-3425c1611f15"],
 " or ",
 Cell[BoxData[
  SubscriptBox["\[Psi]", "-"]],
  CellChangeTimes->{{3.813228038288596*^9, 3.813228093385758*^9}, {
   3.8132336120692124`*^9, 3.8132336334997315`*^9}, {3.8132336788534994`*^9, 
   3.8132336830249114`*^9}},ExpressionUUID->
  "b0f283f5-1e6e-4534-8476-02d342c79f95"],
 ". For a properly normalized wavefunction, we require that "
}], "Text",
 CellChangeTimes->{{3.8132336998465276`*^9, 3.813233759273113*^9}, {
  3.813233999278825*^9, 
  3.813234020585909*^9}},ExpressionUUID->"7087609d-ff02-4e1d-ae8b-\
bac4eb141c32"],

Cell[BoxData[
 RowBox[{
  RowBox[{"\[LeftAngleBracket]", 
   RowBox[{
    SubscriptBox["\[Psi]", "\[PlusMinus]"], "|", 
    SubscriptBox["\[Psi]", "\[PlusMinus]"]}], "\[RightAngleBracket]"}], "=", 
  "1"}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8132339700710917`*^9, 
  3.813233971172786*^9}},ExpressionUUID->"34fff6d2-e7a7-7e4d-91f5-\
e12198d28b60"],

Cell["If we plug in the form of our trial wavefunction, we obtain", "Text",
 CellChangeTimes->{{3.813234004787648*^9, 
  3.8132340156996346`*^9}},ExpressionUUID->"b09fd257-586b-4023-b33d-\
c5994b0e4e1f"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"\[LeftAngleBracket]", 
   RowBox[{
    SubscriptBox["\[Psi]", "\[PlusMinus]"], "|", 
    SubscriptBox["\[Psi]", "\[PlusMinus]"]}], "\[RightAngleBracket]"}], "=", 
  RowBox[{"\[LeftAngleBracket]", 
   RowBox[{
    RowBox[{
     SubscriptBox[
      StyleBox["C",
       FontSlant->"Italic"], "\[PlusMinus]"], 
     RowBox[{"(", 
      RowBox[{
       SubscriptBox["\[Phi]", 
        RowBox[{"1", 
         SubscriptBox[
          StyleBox["s",
           FontSlant->"Italic"], 
          StyleBox["A",
           FontSlant->"Italic"]]}]], "\[PlusMinus]", 
       SubscriptBox["\[Phi]", 
        RowBox[{"1", 
         SubscriptBox[
          StyleBox["s",
           FontSlant->"Italic"], 
          StyleBox["B",
