Cell[CellGroupData[{

Cell[TextData[{
 "Beyond ",
 Cell[BoxData[
  FormBox[
   SubscriptBox[
    StyleBox["H",
     FontSlant->"Plain"], "2"], TraditionalForm]],ExpressionUUID->
  "757f538b-406f-42eb-a75f-3547b656868b"],
 " - Molecular Orbital Energy Diagrams"
}], "Subsection",
 CellChangeTimes->{{3.8136764035681324`*^9, 
  3.8136764317057924`*^9}},ExpressionUUID->"064431a1-f001-448b-b149-\
d1aa8805ff33"],

Cell[TextData[{
 "To expand this process beyond ",
 Cell[BoxData[
  FormBox[
   SubscriptBox[
    StyleBox["H",
     FontSlant->"Plain"], "2"], TraditionalForm]],ExpressionUUID->
  "d467dcca-0eba-49c1-8e60-6f24993cc77a"],
 ", we increase the size of our Slater determinant to include the required \
spatial molecular orbitals. For example, for ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["He", "2"], TraditionalForm]],ExpressionUUID->
  "d25de447-8fa0-4339-a6b3-a3af875624be"],
 ", the wavefunction would be "
}], "Text",
 CellChangeTimes->{{3.8136764356952496`*^9, 3.813676519952171*^9}, {
  3.8136848905876217`*^9, 3.8136848908211145`*^9}, {3.9374876660022717`*^9, 
  3.9374876698692055`*^9}},ExpressionUUID->"bd3a97cb-dcbc-4b4b-b6af-\
ed6a304f6062"],

Cell[BoxData[
 RowBox[{
  SubscriptBox["\[Psi]", 
   SubscriptBox["H", "2"]], "=", 
  RowBox[{
   FractionBox["1", 
    SqrtBox["24"]], 
   RowBox[{"\[LeftBracketingBar]", "\[NoBreak]", GridBox[{
      {
       RowBox[{
        SubscriptBox["\[Psi]", "+"], 
        RowBox[{"(", "1", ")"}], "\[Alpha]", 
        RowBox[{"(", "1", ")"}]}], 
       RowBox[{
        SubscriptBox["\[Psi]", "+"], 
        RowBox[{"(", "1", ")"}], "\[Beta]", 
        RowBox[{"(", "1", ")"}]}], 
       RowBox[{
        SubscriptBox["\[Psi]", "-"], 
        RowBox[{"(", "1", ")"}], "\[Alpha]", 
        RowBox[{"(", "1", ")"}]}], 
       RowBox[{
        SubscriptBox["\[Psi]", "-"], 
        RowBox[{"(", "1", ")"}], "\[Beta]", 
        RowBox[{"(", "1", ")"}]}]},
      {
       RowBox[{
        SubscriptBox["\[Psi]", "+"], 
        RowBox[{"(", "2", ")"}], "\[Alpha]", 
        RowBox[{"(", "2", ")"}]}], 
       RowBox[{
        SubscriptBox["\[Psi]", "+"], 
        RowBox[{"(", "2", ")"}], "\[Beta]", 
        RowBox[{"(", "2", ")"}]}], 
       RowBox[{
        SubscriptBox["\[Psi]", "-"], 
        RowBox[{"(", "2", ")"}], "\[Alpha]", 
        RowBox[{"(", "2", ")"}]}], 
       RowBox[{
        SubscriptBox["\[Psi]", "-"], 
        RowBox[{"(", "2", ")"}], "\[Beta]", 
        RowBox[{"(", "2", ")"}]}]},
      {
       RowBox[{
        SubscriptBox["\[Psi]", "+"], 
        RowBox[{"(", "3", ")"}], "\[Alpha]", 
        RowBox[{"(", "3", ")"}]}], 
       RowBox[{
        SubscriptBox["\[Psi]", "+"], 
        RowBox[{"(", "3", ")"}], "\[Beta]", 
        RowBox[{"(", "3", ")"}]}], 
       RowBox[{
        SubscriptBox["\[Psi]", "-"], 
        RowBox[{"(", "3", ")"}], "\[Alpha]", 
        RowBox[{"(", "3", ")"}]}], 
       RowBox[{
        SubscriptBox["\[Psi]", "-"], 
        RowBox[{"(", "3", ")"}], "\[Beta]", 
        RowBox[{"(", "3", ")"}]}]},
      {
       RowBox[{
        SubscriptBox["\[Psi]", "+"], 
        RowBox[{"(", "4", ")"}], "\[Alpha]", 
        RowBox[{"(", "4", ")"}]}], 
       RowBox[{
        SubscriptBox["\[Psi]", "+"], 
        RowBox[{"(", "4", ")"}], "\[Beta]", 
        RowBox[{"(", "4", ")"}]}], 
       RowBox[{
        SubscriptBox["\[Psi]", "-"], 
        RowBox[{"(", "4", ")"}], "\[Alpha]", 
        RowBox[{"(", "4", ")"}]}], 
       RowBox[{
        SubscriptBox["\[Psi]", "-"], 
        RowBox[{"(", "4", ")"}], "\[Beta]", 
        RowBox[{"(", "4", ")"}]}]}
     }], "\[NoBreak]\[NoBreak]", 
    "\[RightBracketingBar]"}]}]}]], "DisplayFormula",
 CellChangeTimes->{{3.813669259677831*^9, 3.813669335226798*^9}, {
  3.81366938031122*^9, 3.8136693993538027`*^9}, {3.8136694323059635`*^9, 
  3.8136694361348667`*^9}, {3.81366966395068*^9, 3.813669740821965*^9}, {
  3.8136765297741947`*^9, 3.813676590838539*^9}, {3.81418447967723*^9, 
  3.8141844908236375`*^9}},ExpressionUUID->"7ac953c7-9695-4e9c-8048-\
cc1370883235"],

Cell[TextData[{
 "What happens when we go beyond ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["He", "2"], TraditionalForm]],ExpressionUUID->
  "dbc4854b-999d-4621-aa9f-436a69ec092d"],
 "? We\[CloseCurlyQuote]ve now run out of molecular orbitals, so we need to \
include more atomic orbitals in our trial wavefunctions,"
}], "Text",
 CellChangeTimes->{{3.813676606650166*^9, 
  3.8136766928931103`*^9}},ExpressionUUID->"1baf9146-e461-4702-8621-\
b5d7053099e2"],

