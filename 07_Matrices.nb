Cell[CellGroupData[{

Cell["\<\
Columns or Rows with Sum/Difference Can Be Written as Sum/Difference \
Determinants\
\>", "Subsubsection",
 CellChangeTimes->{{3.811319365540124*^9, 3.8113193896183214`*^9}, {
  3.811319623636093*^9, 
  3.811319624005627*^9}},ExpressionUUID->"7ad6fa2a-af24-49ec-abfd-\
d7f806e436e1"],

Cell["\<\
If all of the elements of a row or all of the elements of a column contain a \
sum or difference term, then the determinant of the matrix can be written as \
the sum or difference of multiple determinants,\
\>", "Text",
 CellChangeTimes->{{3.811319396699548*^9, 
  3.811319441943327*^9}},ExpressionUUID->"fe8cb27e-2a3d-442b-8c82-\
9919d1d3ca16"],

Cell[BoxData[
 RowBox[{
  RowBox[{"\[LeftBracketingBar]", "\[NoBreak]", GridBox[{
     {
      RowBox[{
       SubscriptBox[
        StyleBox["a",
         FontSlant->"Italic"], "11"], "\[PlusMinus]", 
       SubsuperscriptBox[
        StyleBox["a",
         FontSlant->"Italic"], "11", "'"]}], 
      SubscriptBox[
       StyleBox["a",
        FontSlant->"Italic"], "12"], 
      SubscriptBox[
       StyleBox["a",
        FontSlant->"Italic"], "13"]},
     {
      RowBox[{
       SubscriptBox[
        StyleBox["a",
         FontSlant->"Italic"], "21"], "\[PlusMinus]", 
       SubsuperscriptBox[
        StyleBox["a",
         FontSlant->"Italic"], "21", "'"]}], 
      SubscriptBox[
       StyleBox["a",
        FontSlant->"Italic"], "22"], 
      SubscriptBox[
       StyleBox["a",
        FontSlant->"Italic"], "23"]},
     {
      RowBox[{
       SubscriptBox[
        StyleBox["a",
         FontSlant->"Italic"], "31"], "\[PlusMinus]", 
       SubsuperscriptBox[
        StyleBox["a",
         FontSlant->"Italic"], "31", "'"]}], 
      SubscriptBox[
       StyleBox["a",
        FontSlant->"Italic"], "32"], 
      SubscriptBox[
       StyleBox["a",
        FontSlant->"Italic"], "33"]}
    }], "\[NoBreak]", "\[RightBracketingBar]"}], "=", 
  RowBox[{
   RowBox[{"\[LeftBracketingBar]", "\[NoBreak]", GridBox[{
      {
       SubscriptBox[
        StyleBox["a",
         FontSlant->"Italic"], "11"], 
       SubscriptBox[
        StyleBox["a",
         FontSlant->"Italic"], "12"], 
       SubscriptBox[
        StyleBox["a",
         FontSlant->"Italic"], "13"]},
      {
       SubscriptBox[
        StyleBox["a",
         FontSlant->"Italic"], "21"], 
       SubscriptBox[
        StyleBox["a",
         FontSlant->"Italic"], "22"], 
       SubscriptBox[
        StyleBox["a",
         FontSlant->"Italic"], "23"]},
      {
       SubscriptBox[
        StyleBox["a",
         FontSlant->"Italic"], "31"], 
       SubscriptBox[
        StyleBox["a",
         FontSlant->"Italic"], "32"], 
       SubscriptBox[
        StyleBox["a",
         FontSlant->"Italic"], "33"]}
     }], "\[NoBreak]", "\[RightBracketingBar]"}], "\[PlusMinus]", 
   RowBox[{"\[LeftBracketingBar]", "\[NoBreak]", GridBox[{
      {
       SubsuperscriptBox[
        StyleBox["a",
         FontSlant->"Italic"], "11", "'"], 
       SubscriptBox[
        StyleBox["a",
         FontSlant->"Italic"], "12"], 
       SubscriptBox[
        StyleBox["a",
         FontSlant->"Italic"], "13"]},
      {
       SubsuperscriptBox[
        StyleBox["a",
         FontSlant->"Italic"], "21", "'"], 
       SubscriptBox[
        StyleBox["a",
         FontSlant->"Italic"], "22"], 
       SubscriptBox[
        StyleBox["a",
         FontSlant->"Italic"], "23"]},
      {
       SubsuperscriptBox[
        StyleBox["a",
         FontSlant->"Italic"], "31", "'"], 
       SubscriptBox[
        StyleBox["a",
         FontSlant->"Italic"], "32"], 
       SubscriptBox[
        StyleBox["a",
         FontSlant->"Italic"], "33"]}
     }], "\[NoBreak]", 
    "\[RightBracketingBar]"}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.811318113364401*^9, 3.8113181244722557`*^9}, {
  3.811319466560395*^9, 
  3.811319548469142*^9}},ExpressionUUID->"415bd3ae-bbc7-4295-ac44-\
81b490e7452e"]
}, Open  ]],

Cell[CellGroupData[{

Cell["\<\
Adding/Subtracting One Row or Column from Another Doesn\[CloseCurlyQuote]t \
Change the Determinant\
\>", "Subsubsection",
 CellChangeTimes->{{3.811319586534873*^9, 
  3.811319621679126*^9}},ExpressionUUID->"bd57118f-dc2c-4492-aadb-\
5bf9061a3f7a"],

Cell["\<\
If one row or column is added or subtracted from another row or column, then \
the value of the determinant doesn\[CloseCurlyQuote]t change. We again use \
Mathematica to evaluate an example,\
\>", "Text",
 CellChangeTimes->{{3.811319630984969*^9, 
  3.8113196545674477`*^9}},ExpressionUUID->"b97cf032-d7b7-4b0b-943c-\
9da5e32536a6"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"Det", "[", GridBox[{
     {
      SubscriptBox[
       StyleBox["a",
        FontSlant->"Italic"], "11"], 
      SubscriptBox[
       StyleBox["a",
        FontSlant->"Italic"], "12"], 
      SubscriptBox[
       StyleBox["a",
        FontSlant->"Italic"], "13"]},
     {
      SubscriptBox[
       StyleBox["a",
        FontSlant->"Italic"], "21"], 
      SubscriptBox[
       StyleBox["a",
        FontSlant->"Italic"], "22"], 
      SubscriptBox[
       StyleBox["a",
        FontSlant->"Italic"], "23"]},
     {
      SubscriptBox[
       StyleBox["a",
        FontSlant->"Italic"], "31"], 
      SubscriptBox[
       StyleBox["a",
        FontSlant->"Italic"], "32"], 
      SubscriptBox[
       StyleBox["a",
        FontSlant->"Italic"], "33"]}
    }], "]"}], "\[Equal]", 
  RowBox[{"Det", "[", GridBox[{
     {
      RowBox[{
       SubscriptBox[
        StyleBox["a",
         FontSlant->"Italic"], "11"], "+", 
       SubscriptBox[
        StyleBox["a",
         FontSlant->"Italic"], "31"]}], 
      RowBox[{
       SubscriptBox[
        StyleBox["a",
         FontSlant->"Italic"], "12"], "+", 
       SubscriptBox[
        StyleBox["a",
         FontSlant->"Italic"], "32"]}], 
      RowBox[{
       SubscriptBox[
        StyleBox["a",
         FontSlant->"Italic"], "13"], "+", 
       SubscriptBox[
        StyleBox["a",
         FontSlant->"Italic"], "33"]}]},
     {
      SubscriptBox[
       StyleBox["a",
        FontSlant->"Italic"], "21"], 
      SubscriptBox[
       StyleBox["a",
        FontSlant->"Italic"], "22"], 
      SubscriptBox[
       StyleBox["a",
        FontSlant->"Italic"], "23"]},
     {
      SubscriptBox[
       StyleBox["a",
        FontSlant->"Italic"], "31"], 
      SubscriptBox[
       StyleBox["a",
        FontSlant->"Italic"], "32"], 
      SubscriptBox[
       StyleBox["a",
        FontSlant->"Italic"], "33"]}
    }], "]"}]}]], "Input",
 CellChangeTimes->{{3.8113181472109995`*^9, 3.811318156487506*^9}, {
  3.8113190932904644`*^9, 3.811319097465457*^9}, {3.811319671094836*^9, 
  3.811319692767553*^9}},
 CellLabel->"In[19]:=",ExpressionUUID->"a816c2b6-107d-494f-8b6e-137838342466"],

Cell[BoxData["True"], "Output",
 CellChangeTimes->{3.8113196938194995`*^9},
 CellLabel->"Out[19]=",ExpressionUUID->"89c403f4-572a-4671-ab65-5a8cc074a279"]
}, Open  ]]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["\<\
Solving Systems of Equations with Determinants and Cramer\[CloseCurlyQuote]s \
Rule\
\>", "Subsection",
 CellChangeTimes->{{3.8113200697531805`*^9, 
  3.8113200813250875`*^9}},ExpressionUUID->"c89d5c3f-6005-4e64-997c-\
4cc1243e1dab"],

Cell["\<\
Remember that in the introduction to determinants we gave an example of using \
determinants to solve a system of linear algebraic equations. Let\
\[CloseCurlyQuote]s expand that example a bit to a system of three equations \
with three unknowns.\
\>", "Text",
 CellChangeTimes->{{3.8113200971882143`*^9, 
  3.811320139669973*^9}},ExpressionUUID->"b63e1600-134d-431b-9abc-\
e15c4c60188d"],

Cell[BoxData[
 RowBox[{
  SubscriptBox[
   StyleBox["c",
    FontSlant->"Italic"], "1"], "=", 
  RowBox[{
   RowBox[{
    SubscriptBox[
     StyleBox["a",
      FontSlant->"Italic"], "11"], 
    StyleBox["x",
     FontSlant->"Italic"]}], "+", 
   RowBox[{
    SubscriptBox[
     StyleBox["a",
      FontSlant->"Italic"], "12"], 
    StyleBox["y",
     FontSlant->"Italic"]}], "+", 
   RowBox[{
    SubscriptBox[
     StyleBox["a",
      FontSlant->"Italic"], "13"], 
    StyleBox["z",
     FontSlant->"Italic"]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8112579973997173`*^9, 3.8112580336398363`*^9}, {
  3.8112631898678875`*^9, 3.8112632107731953`*^9}, {3.811320159598411*^9, 
  3.8113201667112813`*^9}},ExpressionUUID->"07156d29-698a-488e-ad34-\
f46d6bcd25f1"],

Cell[BoxData[
 RowBox[{
  SubscriptBox[
   StyleBox["c",
    FontSlant->"Italic"], "2"], "=", 
  RowBox[{
   RowBox[{
    SubscriptBox[
     StyleBox["a",
      FontSlant->"Italic"], "21"], 
    StyleBox["x",
     FontSlant->"Italic"]}], "+", 
   RowBox[{
    SubscriptBox[
     StyleBox["a",
      FontSlant->"Italic"], "22"], 
    StyleBox["y",
     FontSlant->"Italic"]}], "+", 
   RowBox[{
    SubscriptBox[
     StyleBox["a",
      FontSlant->"Italic"], "23"], 
    StyleBox["z",
     FontSlant->"Italic"]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8112579973997173`*^9, 3.811258064327943*^9}, {
  3.8112632006902976`*^9, 3.811263219644026*^9}, {3.8113201705906096`*^9, 
  3.8113201839175034`*^9}},ExpressionUUID->"aae71916-266b-4e13-b5cd-\
3059dd8d27d0"],

Cell[BoxData[
 RowBox[{
  SubscriptBox[
   StyleBox["c",
    FontSlant->"Italic"], "3"], "=", 
  RowBox[{
   RowBox[{
    SubscriptBox[
     StyleBox["a",
      FontSlant->"Italic"], "31"], 
    StyleBox["x",
     FontSlant->"Italic"]}], "+", 
   RowBox[{
    SubscriptBox[
     StyleBox["a",
      FontSlant->"Italic"], "32"], 
    StyleBox["y",
     FontSlant->"Italic"]}], "+", 
   RowBox[{
    SubscriptBox[
     StyleBox["a",
      FontSlant->"Italic"], "33"], 
    StyleBox["z",
     FontSlant->"Italic"]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8112579973997173`*^9, 3.811258064327943*^9}, {
  3.8112632006902976`*^9, 3.811263219644026*^9}, {3.811320171431529*^9, 
  3.811320180787525*^9}},ExpressionUUID->"c3132590-89ae-4323-894c-\
9207174f46f6"],

Cell["Here we have an \[OpenCurlyDoubleQuote]answer column\
\[CloseCurlyDoubleQuote] matrix vector ,", "Text",
 CellChangeTimes->{{3.811320186808194*^9, 3.811320195158477*^9}, {
  3.81132024984743*^9, 3.8113202554056406`*^9}, {3.8113204646411657`*^9, 
  3.811320466156288*^9}},ExpressionUUID->"883b5e47-001e-4fb5-a0b4-\
fdfa3a2f23ff"],

Cell[BoxData[
 RowBox[{"(", "\[NoBreak]", GridBox[{
    {
     SubscriptBox[
      StyleBox["c",
       FontSlant->"Italic"], "1"]},
    {
     SubscriptBox[
      StyleBox["c",
       FontSlant->"Italic"], "2"]},
    {
     SubscriptBox[
      StyleBox["c",
       FontSlant->"Italic"], "3"]}
   }], "\[NoBreak]", ")"}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.811253718311788*^9, 3.8112538382526913`*^9}, {
  3.8113202158202267`*^9, 
  3.8113202295187783`*^9}},ExpressionUUID->"7d71c73b-240c-45ba-81c6-\
d54bedc3dc47"],

Cell["a coefficient matrix,", "Text",
 CellChangeTimes->{{3.81132025892863*^9, 
  3.811320262699581*^9}},ExpressionUUID->"9a2a6a9c-f685-4b4e-aefd-\
03fd1f9818ad"],

Cell[BoxData[
 RowBox[{"(", "\[NoBreak]", GridBox[{
    {
     SubscriptBox[
      StyleBox["a",
       FontSlant->"Italic"], "11"], 
     SubscriptBox[
      StyleBox["a",
       FontSlant->"Italic"], "12"], 
     SubscriptBox[
      StyleBox["a",
       FontSlant->"Italic"], "13"]},
    {
     SubscriptBox[
      StyleBox["a",
       FontSlant->"Italic"], "21"], 
     SubscriptBox[
      StyleBox["a",
       FontSlant->"Italic"], "22"], 
     SubscriptBox[
      StyleBox["a",
       FontSlant->"Italic"], "23"]},
    {
     SubscriptBox[
      StyleBox["a",
       FontSlant->"Italic"], "31"], 
     SubscriptBox[
      StyleBox["a",
       FontSlant->"Italic"], "32"], 
     SubscriptBox[
      StyleBox["a",
       FontSlant->"Italic"], "33"]}
   }], "\[NoBreak]", ")"}]], "DisplayFormulaNumbered",
 CellChangeTimes->{
  3.8113202890562525`*^9},ExpressionUUID->"28673c15-b39a-49f9-ae31-\
341f6b1c2ea5"],

Cell["and an \[OpenCurlyDoubleQuote]unknowns\[CloseCurlyDoubleQuote] matrix \
vector,", "Text",
 CellChangeTimes->{{3.8113202924770365`*^9, 3.811320314066161*^9}, {
  3.8113204677651854`*^9, 
  3.8113204690547075`*^9}},ExpressionUUID->"fec37a69-f0f2-4df6-9c59-\
fa657decccf3"],

Cell[BoxData[
 RowBox[{"(", "\[NoBreak]", GridBox[{
    {
     StyleBox["x",
      FontSlant->"Italic"]},
    {
     StyleBox["y",
      FontSlant->"Italic"]},
    {
     StyleBox["z",
      FontSlant->"Italic"]}
   }], "\[NoBreak]", ")"}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.811253718311788*^9, 3.8112538382526913`*^9}, {
  3.8113202158202267`*^9, 3.8113202295187783`*^9}, {3.811320322186149*^9, 
  3.8113203363640575`*^9}},ExpressionUUID->"aea9eb7c-8d29-4997-ad3a-\
c8c306bfdb3a"],

Cell[TextData[{
 "There is a simple way to solve such a system of equations known as Cramer\
\[CloseCurlyQuote]s rule. To solve for a given unknown, we first construct a \
determinant by replacing the column in the coefficient matrix that would \
multiply that unknown with the \[OpenCurlyDoubleQuote]answer column\
\[CloseCurlyDoubleQuote] matrix vector. For example, for ",
 StyleBox["y",
  FontSlant->"Italic"],
 ", we would change equation (56) into"
}], "Text",
 CellChangeTimes->{{3.811320361014484*^9, 
  3.8113205330232673`*^9}},ExpressionUUID->"db99b49d-7d37-4ee6-aa1a-\
575d1ba801d7"],

Cell[BoxData[
 RowBox[{"\[LeftBracketingBar]", "\[NoBreak]", GridBox[{
    {
     SubscriptBox[
      StyleBox["a",
       FontSlant->"Italic"], "11"], 
     RowBox[{
      SubscriptBox[
       StyleBox["c",
        FontSlant->"Italic"], "1"], "\[NoBreak]"}], 
     SubscriptBox[
      StyleBox["a",
       FontSlant->"Italic"], "13"]},
    {
     SubscriptBox[
      StyleBox["a",
       FontSlant->"Italic"], "21"], 
     SubscriptBox[
      StyleBox["c",
       FontSlant->"Italic"], "2"], 
     SubscriptBox[
      StyleBox["a",
       FontSlant->"Italic"], "23"]},
    {
     SubscriptBox[
      StyleBox["a",
       FontSlant->"Italic"], "31"], 
     SubscriptBox[
      StyleBox["c",
       FontSlant->"Italic"], "3"], 
     SubscriptBox[
      StyleBox["a",
       FontSlant->"Italic"], "33"]}
   }], "\[NoBreak]", "\[RightBracketingBar]"}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.81132058058125*^9, 
  3.8113205942868032`*^9}},ExpressionUUID->"4cf24afc-54c6-4a5a-a094-\
59426d9d9174"],

Cell[TextData[{
 "Then we simply divide this determinant by the determinant of the \
coefficient matrix. So, the value of ",
 StyleBox["y",
  FontSlant->"Italic"],
 " is given by"
}], "Text",
 CellChangeTimes->{{3.8113206320532475`*^9, 
  3.8113206543825283`*^9}},ExpressionUUID->"f776f542-ea28-43a8-a901-\
3700d6cf976f"],

Cell[BoxData[
 RowBox[{
  StyleBox["y",
   FontSlant->"Italic"], "=", 
  FractionBox[
   RowBox[{"\[LeftBracketingBar]", "\[NoBreak]", GridBox[{
      {
       SubscriptBox[
        StyleBox["a",
         FontSlant->"Italic"], "11"], 
       RowBox[{
        SubscriptBox[
         StyleBox["c",
          FontSlant->"Italic"], "1"], "\[NoBreak]"}], 
       SubscriptBox[
        StyleBox["a",
         FontSlant->"Italic"], "13"]},
      {
       SubscriptBox[
        StyleBox["a",
         FontSlant->"Italic"], "21"], 
       SubscriptBox[
        StyleBox["c",
         FontSlant->"Italic"], "2"], 
       SubscriptBox[
        StyleBox["a",
         FontSlant->"Italic"], "23"]},
      {
       SubscriptBox[
        StyleBox["a",
         FontSlant->"Italic"], "31"], 
       SubscriptBox[
        StyleBox["c",
         FontSlant->"Italic"], "3"], 
       SubscriptBox[
        StyleBox["a",
         FontSlant->"Italic"], "33"]}
     }], "\[NoBreak]", "\[RightBracketingBar]"}], 
   RowBox[{"\[LeftBracketingBar]", "\[NoBreak]", GridBox[{
      {
       SubscriptBox[
        StyleBox["a",
         FontSlant->"Italic"], "11"], 
       SubscriptBox[
        StyleBox["a",
         FontSlant->"Italic"], "12"], 
       SubscriptBox[
        StyleBox["a",
         FontSlant->"Italic"], "13"]},
      {
       SubscriptBox[
        StyleBox["a",
         FontSlant->"Italic"], "21"], 
       SubscriptBox[
        StyleBox["a",
         FontSlant->"Italic"], "22"], 
       SubscriptBox[
        StyleBox["a",
         FontSlant->"Italic"], "23"]},
      {
       SubscriptBox[
        StyleBox["a",
         FontSlant->"Italic"], "31"], 
       SubscriptBox[
        StyleBox["a",
         FontSlant->"Italic"], "32"], 
       SubscriptBox[
        StyleBox["a",
         FontSlant->"Italic"], "33"]}
     }], "\[NoBreak]", "\[RightBracketingBar]"}]]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8113206702299*^9, 
  3.8113206939951596`*^9}},ExpressionUUID->"21e7e95b-2e3b-4bfd-bff7-\
ee3a7c93669d"],

Cell[TextData[{
 "Similarly, the value of ",
 StyleBox["x",
  FontSlant->"Italic"],
 " is given by"
}], "Text",
 CellChangeTimes->{{3.8113206972271338`*^9, 
  3.8113207031314316`*^9}},ExpressionUUID->"60a6b1dc-f94c-4466-aac8-\
fcd4aeb16a04"],

Cell[BoxData[
 RowBox[{
  StyleBox["x",
   FontSlant->"Italic"], "=", 
  FractionBox[
   RowBox[{"\[LeftBracketingBar]", "\[NoBreak]", GridBox[{
      {
       RowBox[{
        SubscriptBox[
         StyleBox["c",
          FontSlant->"Italic"], "1"], "\[NoBreak]"}], 
       SubscriptBox[
        StyleBox["a",
         FontSlant->"Italic"], "12"], 
       SubscriptBox[
        StyleBox["a",
         FontSlant->"Italic"], "13"]},
      {
       SubscriptBox[
        StyleBox["c",
         FontSlant->"Italic"], "2"], 
       SubscriptBox[
        StyleBox["a",
         FontSlant->"Italic"], "22"], 
       SubscriptBox[
        StyleBox["a",
         FontSlant->"Italic"], "23"]},
      {
       SubscriptBox[
        StyleBox["c",
         FontSlant->"Italic"], "3"], 
       SubscriptBox[
        StyleBox["a",
         FontSlant->"Italic"], "32"], 
       SubscriptBox[
        StyleBox["a",
         FontSlant->"Italic"], "33"]}
     }], "\[NoBreak]", "\[RightBracketingBar]"}], 
   RowBox[{"\[LeftBracketingBar]", "\[NoBreak]", GridBox[{
      {
       SubscriptBox[
        StyleBox["a",
         FontSlant->"Italic"], "11"], 
       SubscriptBox[
        StyleBox["a",
         FontSlant->"Italic"], "12"], 
       SubscriptBox[
        StyleBox["a",
         FontSlant->"Italic"], "13"]},
      {
       SubscriptBox[
        StyleBox["a",
         FontSlant->"Italic"], "21"], 
       SubscriptBox[
        StyleBox["a",
         FontSlant->"Italic"], "22"], 
       SubscriptBox[
        StyleBox["a",
         FontSlant->"Italic"], "23"]},
      {
       SubscriptBox[
        StyleBox["a",
         FontSlant->"Italic"], "31"], 
       SubscriptBox[
        StyleBox["a",
         FontSlant->"Italic"], "32"], 
       SubscriptBox[
        StyleBox["a",
         FontSlant->"Italic"], "33"]}
     }], "\[NoBreak]", "\[RightBracketingBar]"}]]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8113206702299*^9, 
  3.8113207274238405`*^9}},ExpressionUUID->"89d677a5-6d06-42ab-9070-\
13098dd88ba2"],

Cell[TextData[{
 "and the value of ",
 StyleBox["z",
  FontSlant->"Italic"],
 " is given by"
}], "Text",
 CellChangeTimes->{{3.811320730285672*^9, 
  3.81132073451587*^9}},ExpressionUUID->"b7435967-b62f-4729-92fa-\
f9db99f5691c"],

Cell[BoxData[
 RowBox[{
  StyleBox["z",
   FontSlant->"Italic"], "=", 
  FractionBox[
   RowBox[{"\[LeftBracketingBar]", "\[NoBreak]", GridBox[{
      {
       SubscriptBox[
        StyleBox["a",
         FontSlant->"Italic"], "11"], 
       SubscriptBox[
        StyleBox["a",
         FontSlant->"Italic"], "12"], 
       RowBox[{
        SubscriptBox[
         StyleBox["c",
          FontSlant->"Italic"], "1"], "\[NoBreak]"}]},
      {
       SubscriptBox[
        StyleBox["a",
         FontSlant->"Italic"], "21"], 
       SubscriptBox[
        StyleBox["a",
         FontSlant->"Italic"], "22"], 
       SubscriptBox[
        StyleBox["c",
         FontSlant->"Italic"], "2"]},
      {
       SubscriptBox[
        StyleBox["a",
         FontSlant->"Italic"], "31"], 
       SubscriptBox[
        StyleBox["a",
         FontSlant->"Italic"], "32"], 
       SubscriptBox[
        StyleBox["c",
         FontSlant->"Italic"], "3"]}
     }], "\[NoBreak]", "\[RightBracketingBar]"}], 
   RowBox[{"\[LeftBracketingBar]", "\[NoBreak]", GridBox[{
      {
       SubscriptBox[
        StyleBox["a",
         FontSlant->"Italic"], "11"], 
       SubscriptBox[
        StyleBox["a",
         FontSlant->"Italic"], "12"], 
       SubscriptBox[
        StyleBox["a",
         FontSlant->"Italic"], "13"]},
      {
       SubscriptBox[
        StyleBox["a",
         FontSlant->"Italic"], "21"], 
       SubscriptBox[
        StyleBox["a",
         FontSlant->"Italic"], "22"], 
       SubscriptBox[
        StyleBox["a",
         FontSlant->"Italic"], "23"]},
      {
       SubscriptBox[
        StyleBox["a",
         FontSlant->"Italic"], "31"], 
       SubscriptBox[
        StyleBox["a",
         FontSlant->"Italic"], "32"], 
       SubscriptBox[
        StyleBox["a",
         FontSlant->"Italic"], "33"]}
     }], "\[NoBreak]", "\[RightBracketingBar]"}]]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8113206702299*^9, 
  3.8113207532903156`*^9}},ExpressionUUID->"bd43cf77-22b9-43b9-8a90-\
fa52f239ed3b"],

Cell["\<\
This solution is much easier to handle programmatically, and computers are \
also great at performing matrix operations. By the way, if the determinant of \
the coefficient matrix is zero, then that means there is no unique solution. \
There could still be a special solution such as a parametric solution, but \
you can\[CloseCurlyQuote]t find that with this method.\
\>", "Text",
 CellChangeTimes->{{3.811320764647576*^9, 3.8113207970315695`*^9}, {
  3.8113208801979165`*^9, 
  3.8113209513793535`*^9}},ExpressionUUID->"9d2a9256-54b6-4059-9669-\
524eca07e635"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Matrices, Wavefunctions, and Bra-Ket Notation", "Section",
 CellChangeTimes->{{3.81132097425399*^9, 
  3.8113209850394983`*^9}},ExpressionUUID->"1b746586-a982-4ee0-8bb6-\
13a89c1293e1"],

Cell["\<\
Thus far we have been discussing generic properties of matrices and \
determinants that are (for the most part) well-accepted across disciplines \
and used in multiple applications. Now we will discuss the ideas of matrix \
vectors and matrix vector multiplication as it relates to quantum mechanics. \
Perhaps most importantly, we will introduce the Bra-Ket notation developed by \
Dirac. This notation is largely employed only by chemists and physicists.\
\>", "Text",
 CellChangeTimes->{{3.811321345948265*^9, 3.811321603971037*^9}, {
  3.8113216413099575`*^9, 
  3.8113216597136965`*^9}},ExpressionUUID->"9968c668-294d-450c-ae71-\
0af44bbaec07"],

Cell["\<\
As you will see, this terminology can become quite confusing, in part because \
its application is not standardized, and people may mean different things \
with the same symbols. However, when used correctly, it is extremely useful \
and will save a lot of time in working with matrix vectors. In addition, it \
is employed in almost any publication that discusses quantum-mechanical \
concepts, so at least a basic knowledge of the notation is essential for \
discussing and evaluating research in physical chemistry.\
\>", "Text",
 CellChangeTimes->{{3.811321606328405*^9, 3.8113216242219324`*^9}, {
  3.811321666461531*^9, 
  3.811321667028792*^9}},ExpressionUUID->"c86ecd84-8bde-4b3d-a4cc-\
fb237e17f629"],

Cell[CellGroupData[{

Cell["Multiplying Matrix Vectors", "Subsection",
 CellChangeTimes->{{3.8113218647564716`*^9, 
  3.8113218695832877`*^9}},ExpressionUUID->"8f08b1ec-9817-4193-91f8-\
27e1ee6c7df9"],

Cell[CellGroupData[{

Cell["The Inner Product", "Subsubsection",
 CellChangeTimes->{{3.811323677198265*^9, 
  3.811323679355319*^9}},ExpressionUUID->"9fb30913-5acb-4b02-83fb-\
d9e48eac3636"],

Cell["\<\
Let\[CloseCurlyQuote]s start with a few notes about multiplying matrix \
vectors. Note that throughout the rest of this lesson, I will typically use \
the word \[OpenCurlyDoubleQuote]vector\[CloseCurlyDoubleQuote] to mean \
\[OpenCurlyDoubleQuote]a matrix vector in column form\[CloseCurlyDoubleQuote] \
unless otherwise specified. Usually, we would represent a matrix vector in \
column form,\
\>", "Text",
 CellChangeTimes->{{3.8113218734816837`*^9, 3.8113218846095266`*^9}, {
  3.811322007998722*^9, 3.8113220410791535`*^9}, {3.8113220798628416`*^9, 
  3.81132208221717*^9}, {3.81132454738888*^9, 3.8113245940296164`*^9}, {
  3.8113257881008425`*^9, 
  3.811325797966073*^9}},ExpressionUUID->"04858b6c-a433-4236-8fc3-\
08d902636947"],

Cell[BoxData[
 RowBox[{
  StyleBox["a",
   FontWeight->"Bold",
   FontSlant->"Plain"], 
  StyleBox["=",
   FontWeight->"Plain",
   FontSlant->"Plain"], 
  RowBox[{"(", "\[NoBreak]", GridBox[{
     {
      SubscriptBox[
       StyleBox["a",
        FontSlant->"Italic"], "1"]},
     {
      SubscriptBox[
       StyleBox["a",
        FontSlant->"Italic"], "2"]},
     {GridBox[{
        {
         StyleBox[
          SubscriptBox[
           StyleBox["a",
            FontSlant->"Italic"], "3"],
          FontSlant->"Italic"]},
        {"..."},
        {
         SubscriptBox[
          StyleBox["a",
           FontSlant->"Italic"], 
          StyleBox["n",
           FontSlant->"Italic"]]}
       }]}
    }], "\[NoBreak]", ")"}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8112559638442764`*^9, 3.8112559741396627`*^9}, {
   3.8113221103126726`*^9, 3.811322130222258*^9}, 3.8113221675383205`*^9, {
   3.8113249334129887`*^9, 3.811324934647877*^9}, {3.8113258059164143`*^9, 
   3.8113258929390106`*^9}, {3.811327553836673*^9, 
   3.81132755647596*^9}},ExpressionUUID->"4f00a8c0-39fc-4e5a-a50f-\
109742331daa"],

Cell[TextData[{
 "Now, we cannot multiply two column vectors together because, remember, the \
number of columns in the first matrix must equal the number of rows in the \
second matrix. So, when multiplying a column vector ",
 StyleBox["a",
  FontWeight->"Bold"],
 " by another column vector ",
 StyleBox["b",
  FontWeight->"Bold"],
 ", we first take the transpose of ",
 StyleBox["a",
  FontWeight->"Bold"],
 ", ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    StyleBox["a",
     FontWeight->"Bold",
     FontSlant->"Plain"], 
    StyleBox["T",
     FontWeight->"Bold",
     FontSlant->"Plain"]], TraditionalForm]],ExpressionUUID->
  "875c4dd7-45f7-4619-969b-4022fc8c0087"],
 ","
}], "Text",
 CellChangeTimes->{{3.811322175324312*^9, 3.8113222441004405`*^9}, {
  3.811322486451894*^9, 3.8113225591161246`*^9}, {3.811324937486853*^9, 
  3.811324946588846*^9}, {3.811325914056573*^9, 
  3.8113259342821116`*^9}},ExpressionUUID->"16b815f5-6744-4eb8-9627-\
c1a2b27d52da"],

Cell[BoxData[
 RowBox[{
  SuperscriptBox[
   StyleBox["a",
    FontWeight->"Bold",
    FontSlant->"Plain"], 
   StyleBox["T",
    FontWeight->"Bold"]], 
  StyleBox["=",
   FontWeight->"Plain",
   FontSlant->"Plain"], 
  RowBox[{"(", "\[NoBreak]", 
   RowBox[{GridBox[{
      {
       SubscriptBox[
        StyleBox["a",
         FontSlant->"Italic"], "1"], 
       SubscriptBox[
        StyleBox["a",
         FontSlant->"Italic"], "2"], 
       StyleBox[
        SubscriptBox[
         StyleBox["a",
          FontSlant->"Italic"], "3"],
        FontSlant->"Italic"]}
     }], GridBox[{
      {"...", 
       SubscriptBox[
        StyleBox["a",
         FontSlant->"Italic"], 
        StyleBox["n",
         FontSlant->"Italic"]]}
     }]}], ")"}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8112559638442764`*^9, 3.8112559741396627`*^9}, {
   3.8113221103126726`*^9, 3.811322130222258*^9}, 3.8113221675383205`*^9, {
   3.811322570897264*^9, 3.811322611416624*^9}, {3.8113228670247326`*^9, 
   3.8113228928746*^9}, {3.811323398882858*^9, 3.8113234039439344`*^9}, {
   3.811324949086023*^9, 3.8113249497133827`*^9}, {3.811325807986371*^9, 
   3.8113258290877795`*^9}, {3.811325902544961*^9, 3.8113259088007164`*^9}, {
   3.8113275589561496`*^9, 
   3.8113275616572857`*^9}},ExpressionUUID->"4d9c5785-fe4c-46e3-a05b-\
98198ed2d0bd"],

Cell["\<\
Now, let\[CloseCurlyQuote]s say we want the result of our vector \
multiplication to be real, as you will see is often the case because we want \
to get out some measurable quantity or observable. Because the entries of our \
column vectors might be complex, we can ensure a real result if we take the \
complex conjugate of our transposed column vector, \
\>", "Text",
 CellChangeTimes->{{3.811322895626235*^9, 3.811323129763375*^9}, 
   3.81132495682736*^9, {3.8113259670533257`*^9, 
   3.8113259921788282`*^9}},ExpressionUUID->"af37b55c-69d7-4726-b453-\
eb532c12f39c"],

Cell[BoxData[
 RowBox[{
  SuperscriptBox[
   StyleBox["a",
    FontWeight->"Bold",
    FontSlant->"Plain"], 
   StyleBox["H",
    FontWeight->"Bold"]], 
  StyleBox["=",
   FontWeight->"Plain",
   FontSlant->"Plain"], 
  RowBox[{"(", "\[NoBreak]", 
   RowBox[{GridBox[{
      {
       SubsuperscriptBox[
        StyleBox["a",
         FontSlant->"Italic"], "1", "\[Star]"], 
       SubsuperscriptBox[
        StyleBox["a",
         FontSlant->"Italic"], "2", "\[Star]"], 
       StyleBox[
        SubsuperscriptBox[
         StyleBox["a",
          FontSlant->"Italic"], 
         StyleBox["3",
          FontSlant->"Plain"], "\[Star]"],
        FontSlant->"Italic"]}
     }], GridBox[{
      {"...", 
       SubsuperscriptBox[
        StyleBox["a",
         FontSlant->"Italic"], 
        StyleBox["n",
         FontSlant->"Italic"], "\[Star]"]}
     }]}], ")"}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8112559638442764`*^9, 3.8112559741396627`*^9}, {
