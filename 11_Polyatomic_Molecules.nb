 CellID->999963952,ExpressionUUID->"72dca62e-1690-485d-8668-9ccb66d1e047"]
}, {10}]],

Cell[TextData[{
 StyleBox["Figure 11.1",
  FontWeight->"Bold"],
 ". Three-dimensional depiction of hybrid orbitals; the shape of the hybrid \
orbitals is depicted at some boundary surface from the center. Wolfram \
Demonstrations,  Guenther Gsaller (September 2013), CC BY-NC-SA 3.0, \
https://demonstrations.wolfram.com/HybridOrbitalsInOrganicChemistry/",
 StyleBox[".",
  FontWeight->"Bold"]
}], "Affiliation",
 CellChangeTimes->{{3.809435027311596*^9, 3.8094350763900714`*^9}, {
  3.80943583474421*^9, 3.8094358359299717`*^9}, {3.8094472165104203`*^9, 
  3.809447281165168*^9}, {3.809510876137825*^9, 3.809510907739876*^9}, {
  3.809968073566992*^9, 3.8099681536568317`*^9}, {3.810557260250428*^9, 
  3.8105572606139913`*^9}, {3.8130835305386977`*^9, 3.8130836194514275`*^9}, {
  3.813224407772764*^9, 3.8132244817756805`*^9}, {3.814107987969291*^9, 
  3.814108049630145*^9}, {3.814109089245699*^9, 3.8141091270231557`*^9}, {
  3.8141093100266285`*^9, 3.814109310147791*^9}, {3.814109921841116*^9, 
  3.8141099219695177`*^9}, {3.8141099776142817`*^9, 3.8141100720635233`*^9}, {
  3.814117676987705*^9, 3.8141177066264424`*^9}, {3.8142785194696302`*^9, 
  3.814278521090821*^9}, {3.8142785626923523`*^9, 3.814278656139146*^9}, {
  3.9388708653141785`*^9, 
  3.938870865433071*^9}},ExpressionUUID->"ae0d106d-2472-4862-b497-\
8c71309a205f"],

Cell[TextData[{
 "To generate the final molecular orbital, we can then combine the ",
 Cell[BoxData[
  SubscriptBox["\[CapitalPhi]", 
   StyleBox["sp",
    FontSlant->"Italic"]]],
  CellChangeTimes->{{3.8142715408501225`*^9, 3.8142716264528427`*^9}, {
    3.8142716634962983`*^9, 3.81427166385531*^9}, {3.8142717090653296`*^9, 
    3.814271758882024*^9}, {3.8142767976668887`*^9, 3.8142767986447644`*^9}, 
    3.814277116274558*^9, {3.814277180844843*^9, 3.814277221091382*^9}, {
    3.814277457217991*^9, 3.8142774573794937`*^9}, {3.814277728866243*^9, 
    3.814277745715167*^9}},ExpressionUUID->
  "3804adb5-9e31-46a5-a30a-c17b0b4716c4"],
 " hybrid orbital of Be with the 1",
 StyleBox["s",
  FontSlant->"Italic"],
 " atomic orbital of H to generate the molecular orbitals of ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["BeH", "2"], TraditionalForm]],ExpressionUUID->
  "1c22831f-a1b1-4be1-bcb1-2f8522f260e8"],
 "."
}], "Text",
 CellChangeTimes->{{3.814277845642291*^9, 3.814277855997128*^9}, {
  3.8142779146774044`*^9, 
  3.814277963886195*^9}},ExpressionUUID->"215b3022-a56b-4ff7-a00e-\
cd82f6b63d2f"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    StyleBox["sp",
     FontSlant->"Italic"], "2"], TraditionalForm]],ExpressionUUID->
  "e5ac7bcd-d08d-4f8c-8a78-40ac23c951ee"],
 " Hybrid Orbitals of ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["BH", "3"], TraditionalForm]],ExpressionUUID->
  "0ddf628f-53b1-4fec-85dc-e4befaa32c59"]
}], "Subsection",
 CellChangeTimes->{{3.8142780605624695`*^9, 
  3.814278086237917*^9}},ExpressionUUID->"ef200cb2-73c0-44fd-bd47-\
24be4091ee80"],

Cell[TextData[{
 "We can take a similar approach to find the hybrid orbitals associated with \
the trigonal planar molecule ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["BH", "3"], TraditionalForm]],ExpressionUUID->
  "b44df437-b6b6-4e35-91b7-eab268e2eb76"],
 ". In this case, we need to form three bonds, so we construct a linear \
combination of the 2",
 StyleBox["s",
  FontSlant->"Italic"],
 " atomic orbital and two 2",
 StyleBox["p",
  FontSlant->"Italic"],
 " atomic orbitals of boron. Which two 2",
 StyleBox["p",
  FontSlant->"Italic"],
 " atomic orbitals depends on the designation of the bonding plane, but we \
will choose ",
 Cell[BoxData[
  FormBox[
   RowBox[{"2", 
    SubscriptBox["p", "x"]}], TraditionalForm]],ExpressionUUID->
  "a3305055-7b8c-4eca-beac-e1c7d65647fd"],
 " and 2",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "y"], TraditionalForm]],ExpressionUUID->
  "b4528cfe-b5f5-418c-90e3-7d9ba3a68b6b"],
 ". Because we want three equally-spaced hybrid orbitals (angles of ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["120", "\[Degree]"], TraditionalForm]],ExpressionUUID->
  "95c389c0-bfd1-4049-a8d2-0165be19a0d7"],
 " between each), we actually need to think of rotating the 2",
 StyleBox["p",
  FontSlant->"Italic"],
 " orbitals slightly, which results in an asymmetric linear combination of \
the ",
 Cell[BoxData[
  FormBox[
   RowBox[{"2", 
    SubscriptBox["p", "x"]}], TraditionalForm]],ExpressionUUID->
  "63be5bd5-897c-47cb-8ec8-9fd2b01937e3"],
 " and 2",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "y"], TraditionalForm]],ExpressionUUID->
  "8b345329-1bff-4975-82fa-ec7454afa3d6"],
 " orbitals. Without working through all of the details, we find that"
}], "Text",
 CellChangeTimes->{{3.8142786712062316`*^9, 3.8142787359239836`*^9}, {
  3.8142787949818935`*^9, 3.814278882029316*^9}, {3.814278933194335*^9, 
  3.8142790214989595`*^9}, {3.8142790572027655`*^9, 
  3.81427906428693*^9}},ExpressionUUID->"c1d43794-ddfb-4770-b9f3-\
4cbb08626fc2"],

Cell[BoxData[{
 RowBox[{
  SubscriptBox["\[CapitalPhi]", 
   SubsuperscriptBox[
    StyleBox["sp",
     FontSlant->"Italic"], 
    StyleBox["i",
     FontSlant->"Italic"], "2"]], "=", 
  RowBox[{
   FractionBox["1", 
    SqrtBox["3"]], 
   RowBox[{"(", 
    RowBox[{
     SubscriptBox["\[Phi]", 
      RowBox[{"2", 
       StyleBox["s",
        FontSlant->"Italic"]}]], "-", 
     RowBox[{
      SqrtBox["2"], 
      SubscriptBox["\[Phi]", 
       RowBox[{"2", 
        StyleBox[
         SubscriptBox[
          StyleBox["p",
           FontSlant->"Italic"], "x"],
         FontSlant->"Italic"]}]]}]}], ")"}]}]}], "\[IndentingNewLine]", 
 RowBox[{
  SubscriptBox["\[CapitalPhi]", 
   SubsuperscriptBox[
    StyleBox["sp",
     FontSlant->"Italic"], 
    StyleBox["j",
     FontSlant->"Italic"], "2"]], "=", 
  RowBox[{
   RowBox[{
    FractionBox["1", 
     SqrtBox["3"]], 
    SubscriptBox["\[Phi]", 
     RowBox[{"2", 
      StyleBox["s",
       FontSlant->"Italic"]}]]}], "+", 
   RowBox[{
    FractionBox["1", 
     SqrtBox["6"]], 
    RowBox[{"(", 
     RowBox[{
      SubscriptBox["\[Phi]", 
       RowBox[{"2", 
        StyleBox[
         SubscriptBox[
          StyleBox["p",
           FontSlant->"Italic"], "x"],
         FontSlant->"Italic"]}]], "+", 
      RowBox[{
       SqrtBox["3"], 
       SubscriptBox["\[Phi]", 
        RowBox[{"2", 
         StyleBox[
          SubscriptBox[
           StyleBox["p",
            FontSlant->"Italic"], "y"],
          FontSlant->"Italic"]}]]}]}], ")"}]}]}]}], "\[IndentingNewLine]", 
 RowBox[{
  SubscriptBox["\[CapitalPhi]", 
   SubsuperscriptBox[
    StyleBox["sp",
     FontSlant->"Italic"], 
    StyleBox["k",
     FontSlant->"Italic"], "2"]], "=", 
  RowBox[{
   RowBox[{
    FractionBox["1", 
     SqrtBox["3"]], 
    SubscriptBox["\[Phi]", 
     RowBox[{"2", 
      StyleBox["s",
       FontSlant->"Italic"]}]]}], "+", 
   RowBox[{
    FractionBox["1", 
     SqrtBox["6"]], 
    RowBox[{"(", 
     RowBox[{
      SubscriptBox["\[Phi]", 
       RowBox[{"2", 
        StyleBox[
         SubscriptBox[
          StyleBox["p",
           FontSlant->"Italic"], "x"],
         FontSlant->"Italic"]}]], "-", 
      RowBox[{
       SqrtBox["3"], 
       SubscriptBox["\[Phi]", 
        RowBox[{"2", 
         StyleBox[
          SubscriptBox[
           StyleBox["p",
            FontSlant->"Italic"], "y"],
          FontSlant->"Italic"]}]]}]}], ")"}]}]}]}]}], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8142715408501225`*^9, 3.8142716264528427`*^9}, {
   3.8142716634962983`*^9, 3.81427166385531*^9}, {3.8142717090653296`*^9, 
   3.814271758882024*^9}, {3.8142767976668887`*^9, 3.8142767986447644`*^9}, 
   3.814277116274558*^9, {3.814277180844843*^9, 3.814277221091382*^9}, {
   3.814277457217991*^9, 3.8142774573794937`*^9}, {3.814277728866243*^9, 
   3.814277745715167*^9}, {3.8142790776422806`*^9, 3.8142790820653687`*^9}, {
   3.8142791270338016`*^9, 
   3.8142792828377457`*^9}},ExpressionUUID->"8f871034-ad92-45f2-a4ce-\
5ab59d23a7ae"],

Cell[TextData[{
 "Note that the contribution of the 2",
 StyleBox["s",
  FontSlant->"Italic"],
 " orbital is the same for all hybrid orbitals and that the sum of the \
squares of the coefficients for any atomic orbital is equal to 1. These \
orbitals can likewise be visualized in Figure 11.1."
}], "Text",
 CellChangeTimes->{{3.81427930175065*^9, 3.814279376573312*^9}, {
  3.9388708693605995`*^9, 
  3.938870869455881*^9}},ExpressionUUID->"19ee2575-8d93-488c-ae9a-\
39e9e39b3261"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    StyleBox["sp",
     FontSlant->"Italic"], "3"], TraditionalForm]],ExpressionUUID->
  "2b22a843-15b9-4789-bd36-c883dcf90476"],
 " Hybrid Orbitals of ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["CH", "4"], TraditionalForm]],ExpressionUUID->
  "0b95c5ba-d38e-46a6-8024-45dc4386d851"]
}], "Subsection",
 CellChangeTimes->{{3.8142780605624695`*^9, 3.814278086237917*^9}, {
  3.8142793950821037`*^9, 3.8142793955315695`*^9}, {3.814291134016239*^9, 
  3.8142911394739084`*^9}},ExpressionUUID->"a91c3f2e-8019-41d4-bf1d-\
b662ecd76f20"],

Cell[TextData[{
 "Finally, we examine methane, ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["CH", "4"], TraditionalForm]],ExpressionUUID->
  "970757ee-f995-4c16-9098-089fd7c08daa"],
 ", to investigate ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["sp", "3"], TraditionalForm]],ExpressionUUID->
  "264ff1bf-3354-4ab3-9841-a82bc12b906c"],
 " orbital hybridization. Since we need to form four bonds, we combine the 2",
 StyleBox["s",
  FontSlant->"Italic"],
 " atomic orbital with all three 2",
 StyleBox["p",
  FontSlant->"Italic"],
 " atomic orbitals,"
}], "Text",
 CellChangeTimes->{{3.8142799442993917`*^9, 3.814279945329958*^9}, {
  3.8142802521448812`*^9, 3.814280288337753*^9}, {3.814280339542247*^9, 
  3.8142803685514793`*^9}},ExpressionUUID->"bb8346e1-4556-48b6-89d7-\
ea590ccc43df"],

Cell[BoxData[{
 RowBox[{
  SubscriptBox["\[CapitalPhi]", 
   SubsuperscriptBox[
    StyleBox["sp",
     FontSlant->"Italic"], 
    StyleBox["i",
     FontSlant->"Italic"], "3"]], "=", 
  RowBox[{
   FractionBox["1", "2"], 
   RowBox[{"(", 
    RowBox[{
     SubscriptBox["\[Phi]", 
      RowBox[{"2", 
       StyleBox["s",
        FontSlant->"Italic"]}]], "+", 
     SubscriptBox["\[Phi]", 
      RowBox[{"2", 
       StyleBox[
        SubscriptBox[
         StyleBox["p",
          FontSlant->"Italic"], "x"],
        FontSlant->"Italic"]}]], "+", 
     SubscriptBox["\[Phi]", 
      RowBox[{"2", 
       StyleBox[
        SubscriptBox[
         StyleBox["p",
          FontSlant->"Italic"], "y"],
        FontSlant->"Italic"]}]], "+", 
     SubscriptBox["\[Phi]", 
      RowBox[{"2", 
       StyleBox[
        SubscriptBox[
         StyleBox["p",
          FontSlant->"Italic"], "z"],
        FontSlant->"Italic"]}]]}], ")"}]}]}], "\[IndentingNewLine]", 
 RowBox[{
  SubscriptBox["\[CapitalPhi]", 
   SubsuperscriptBox[
    StyleBox["sp",
     FontSlant->"Italic"], 
    StyleBox["j",
     FontSlant->"Italic"], "3"]], "=", 
  RowBox[{
   FractionBox["1", "2"], 
   RowBox[{"(", 
    RowBox[{
     SubscriptBox["\[Phi]", 
      RowBox[{"2", 
       StyleBox["s",
        FontSlant->"Italic"]}]], "-", 
     SubscriptBox["\[Phi]", 
      RowBox[{"2", 
       StyleBox[
        SubscriptBox[
         StyleBox["p",
          FontSlant->"Italic"], "x"],
        FontSlant->"Italic"]}]], "-", 
     SubscriptBox["\[Phi]", 
      RowBox[{"2", 
       StyleBox[
        SubscriptBox[
         StyleBox["p",
          FontSlant->"Italic"], "y"],
        FontSlant->"Italic"]}]], "+", 
     SubscriptBox["\[Phi]", 
      RowBox[{"2", 
       StyleBox[
        SubscriptBox[
         StyleBox["p",
          FontSlant->"Italic"], "z"],
        FontSlant->"Italic"]}]]}], ")"}]}]}], "\[IndentingNewLine]", 
 RowBox[{
  SubscriptBox["\[CapitalPhi]", 
   SubsuperscriptBox[
    StyleBox["sp",
     FontSlant->"Italic"], 
    StyleBox["k",
     FontSlant->"Italic"], "3"]], "=", 
  RowBox[{
   FractionBox["1", "2"], 
   RowBox[{"(", 
    RowBox[{
     SubscriptBox["\[Phi]", 
      RowBox[{"2", 
       StyleBox["s",
        FontSlant->"Italic"]}]], "+", 
     SubscriptBox["\[Phi]", 
      RowBox[{"2", 
       StyleBox[
        SubscriptBox[
         StyleBox["p",
          FontSlant->"Italic"], "x"],
        FontSlant->"Italic"]}]], "-", 
     SubscriptBox["\[Phi]", 
      RowBox[{"2", 
       StyleBox[
        SubscriptBox[
         StyleBox["p",
          FontSlant->"Italic"], "y"],
        FontSlant->"Italic"]}]], "-", 
     SubscriptBox["\[Phi]", 
      RowBox[{"2", 
       StyleBox[
        SubscriptBox[
         StyleBox["p",
          FontSlant->"Italic"], "z"],
        FontSlant->"Italic"]}]]}], ")"}]}]}], "\[IndentingNewLine]", 
 RowBox[{
  SubscriptBox["\[CapitalPhi]", 
   SubsuperscriptBox[
    StyleBox["sp",
     FontSlant->"Italic"], 
    StyleBox["l",
     FontSlant->"Italic"], "3"]], "=", 
  RowBox[{
   FractionBox["1", "2"], 
   RowBox[{"(", 
    RowBox[{
     SubscriptBox["\[Phi]", 
      RowBox[{"2", 
       StyleBox["s",
        FontSlant->"Italic"]}]], "-", 
     SubscriptBox["\[Phi]", 
      RowBox[{"2", 
       StyleBox[
        SubscriptBox[
         StyleBox["p",
          FontSlant->"Italic"], "x"],
        FontSlant->"Italic"]}]], "+", 
     SubscriptBox["\[Phi]", 
      RowBox[{"2", 
       StyleBox[
        SubscriptBox[
         StyleBox["p",
          FontSlant->"Italic"], "y"],
        FontSlant->"Italic"]}]], "-", 
     SubscriptBox["\[Phi]", 
      RowBox[{"2", 
       StyleBox[
        SubscriptBox[
         StyleBox["p",
          FontSlant->"Italic"], "z"],
        FontSlant->"Italic"]}]]}], ")"}]}]}]}], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8142715408501225`*^9, 3.8142716264528427`*^9}, {
   3.8142716634962983`*^9, 3.81427166385531*^9}, {3.8142717090653296`*^9, 
   3.814271758882024*^9}, {3.8142767976668887`*^9, 3.8142767986447644`*^9}, 
   3.814277116274558*^9, {3.814277180844843*^9, 3.814277221091382*^9}, {
   3.814277457217991*^9, 3.8142774573794937`*^9}, {3.814277728866243*^9, 
   3.814277745715167*^9}, {3.8142790776422806`*^9, 3.8142790820653687`*^9}, {
   3.8142791270338016`*^9, 3.8142792828377457`*^9}, {3.8142804083421297`*^9, 
   3.814280517997387*^9}},ExpressionUUID->"9fbc73ab-9f04-42e7-bd06-\
b6572d54346e"],

Cell["\<\
These hybrid orbitals can likewise be visualized in Figure 11.1. Note that in \
all of the cases examined here, the hybrid orbitals are predicted to have the \
same energy.\
\>", "Text",
 CellChangeTimes->{{3.8142805379349914`*^9, 3.814280574003971*^9}, 
   3.814289404671773*^9, {3.938870874302477*^9, 
   3.9388708744293575`*^9}},ExpressionUUID->"a4d37318-0f66-4abb-871b-\
9cb629a07ff2"]
}, Open  ]],

Cell[CellGroupData[{

Cell["The Reality of Hybrid Orbitals", "Subsection",
 CellChangeTimes->{{3.8142805949905405`*^9, 
  3.8142806025888896`*^9}},ExpressionUUID->"5fb1959c-036a-4cfa-b90f-\
5b6ae23697d9"],

Cell["\<\
In reality, the electronic wavefunctions are not constrained to follow the \
rules of hybrid orbitals; the only constraint on the true wavefunction of a \
molecule is that it must satisfy the Schr\[ODoubleDot]dinger equation (and \
also account for spin antisymmetrization). Even in our Hartree-Fock linear \
combination of atomic orbitals approximation, we allow atomic orbitals to mix \
freely,\
\>", "Text",
 CellChangeTimes->{{3.814280605488888*^9, 
  3.814280711536475*^9}},ExpressionUUID->"6b67b0f1-fab8-48cd-9742-\
ed4d8e7de65c"],

Cell[BoxData[
 RowBox[{
  SubscriptBox["\[Psi]", 
   StyleBox["e",
    FontSlant->"Italic"]], "=", 
  RowBox[{
   RowBox[{
    RowBox[{
     SubscriptBox[
      StyleBox["c",
       FontSlant->"Italic"], "1"], 
     SubscriptBox["\[Phi]", 
      RowBox[{"1", 
       SubscriptBox[
        StyleBox["s",
         FontSlant->"Italic"], 
        StyleBox["A",
         FontSlant->"Italic"]]}]]}], "+", 
    RowBox[{
     SubscriptBox[
      StyleBox["c",
       FontSlant->"Italic"], "2"], 
     SubscriptBox["\[Phi]", 
      RowBox[{"1", 
       SubscriptBox[
        StyleBox["s",
         FontSlant->"Italic"], 
        StyleBox["B",
         FontSlant->"Italic"]]}]]}], "+", 
    RowBox[{
     SubscriptBox[
      StyleBox["c",
       FontSlant->"Italic"], "3"], 
     SubscriptBox["\[Phi]", 
      RowBox[{"1", 
       SubscriptBox[
        StyleBox["s",
         FontSlant->"Italic"], 
        StyleBox["C",
         FontSlant->"Italic"]]}]]}], "+", 
    RowBox[{
     SubscriptBox[
      StyleBox["c",
       FontSlant->"Italic"], "4"], 
     SubscriptBox["\[Phi]", 
      RowBox[{"2", 
       SubscriptBox[
        StyleBox["s",
         FontSlant->"Italic"], 
        StyleBox["A",
         FontSlant->"Italic"]]}]]}], "+", 
    RowBox[{
     SubscriptBox[
      StyleBox["c",
       FontSlant->"Italic"], "5"], 
     SubscriptBox["\[Phi]", 
      RowBox[{"2", 
       SubscriptBox[
        StyleBox["s",
         FontSlant->"Italic"], 
        StyleBox["B",
         FontSlant->"Italic"]]}]]}], "+", 
    RowBox[{
     SubscriptBox[
      StyleBox["c",
       FontSlant->"Italic"], "6"], 
     SubscriptBox["\[Phi]", 
      RowBox[{"2", 
       SubscriptBox[
        StyleBox["s",
         FontSlant->"Italic"], 
        StyleBox["C",
         FontSlant->"Italic"]]}]]}], "+", 
    RowBox[{
     SubscriptBox[
      StyleBox["c",
       FontSlant->"Italic"], "7"], 
     SubscriptBox["\[Phi]", 
      RowBox[{"2", 
       SubscriptBox[
        StyleBox["p",
         FontSlant->"Italic"], 
        StyleBox["zA",
         FontSlant->"Italic"]]}]]}], "+", 
    RowBox[{
     SubscriptBox[
      StyleBox["c",
       FontSlant->"Italic"], "8"], 
     SubscriptBox["\[Phi]", 
      RowBox[{"2", 
       SubscriptBox[
        StyleBox["p",
         FontSlant->"Italic"], 
        StyleBox["zB",
         FontSlant->"Italic"]]}]]}], "+"}], 
   "..."}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8132221669142685`*^9, 3.8132221794693403`*^9}, {
   3.8132222690385857`*^9, 3.813222292552426*^9}, {3.8132225103046436`*^9, 
   3.8132225357976294`*^9}, 3.813225530724597*^9, {3.8132268996594105`*^9, 
   3.8132268997936573`*^9}, {3.8132269718506794`*^9, 
   3.8132270598936987`*^9}, {3.813227090063882*^9, 3.8132270928942423`*^9}, {
   3.8132273687054873`*^9, 3.8132273956726027`*^9}, {3.8132274257354927`*^9, 
   3.8132274504676456`*^9}, {3.813227484968296*^9, 3.8132274916733313`*^9}, {
   3.813227717592659*^9, 3.813227799104663*^9}, {3.8132278524338465`*^9, 
   3.813227854764579*^9}, 3.8132279269606223`*^9, {3.81323366169593*^9, 
   3.813233662702242*^9}, {3.813676741631068*^9, 3.813676829221445*^9}, {
   3.8142067350871696`*^9, 
   3.8142067908071504`*^9}},ExpressionUUID->"d9f8de42-3480-4fda-8733-\
67f8fb9e21d2"],

Cell["\<\
Thus, the hybrid orbitals are not necessarily \[OpenCurlyDoubleQuote]real\
\[CloseCurlyDoubleQuote]. They are a useful approximation that enables a \
conceptualization of polyatomic bonding in terms of the familiar atomic \
orbitals. In general, they do a good job of qualitatively accounting for the \
electron distribution in polyatomic molecules.\
\>", "Text",
 CellChangeTimes->{{3.8142807475675116`*^9, 3.8142807845751305`*^9}, {
  3.81428212370731*^9, 
  3.8142821534730935`*^9}},ExpressionUUID->"e2c38fcb-0968-4e14-b9c3-\
6d5b79e3405b"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Accounting for Lone Pairs", "Subsection",
 CellChangeTimes->{{3.814282444024146*^9, 
  3.814282449983309*^9}},ExpressionUUID->"8988907b-a9ce-40bf-a52e-\
1c2afe668c12"],

Cell[TextData[{
 "Up to this point, we have only examined cases in which all of the valence \
electrons on an atom were involved in bonding. Now we must consider how we \
account for lone pairs, or nonbonding electrons, in our orbital hybridization \
scheme. The importance of these lone pair electrons is evidenced in the \
difference between ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["BeH", "2"], TraditionalForm]],ExpressionUUID->
  "33ade675-35c6-4f0d-b76a-8ac9db2b6cda"],
 ", a linear molecule, and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox[
     StyleBox["H",
      FontSlant->"Plain"], "2"], 
    StyleBox["O",
     FontSlant->"Plain"]}], TraditionalForm]],ExpressionUUID->
  "6781dab0-b413-4ad7-8b42-26e739603935"],
 ", a bent molecule with an angle of ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["104.5", "\[Degree]"], TraditionalForm]],ExpressionUUID->
  "88e387cc-5e58-4c65-ae32-50345b861b3f"],
 " between the two O\[Dash]H bonds. "
}], "Text",
 CellChangeTimes->{{3.814282452649274*^9, 3.8142825180753474`*^9}, {
   3.8142825652681084`*^9, 3.8142827305083313`*^9}, {3.8142827669826217`*^9, 
   3.814282798420802*^9}, 3.8142828400130033`*^9, {3.877179576386208*^9, 
   3.877179576386208*^9}},ExpressionUUID->"11c4be22-1540-47ae-a0c6-\
9d3d3f32c6c4"],

Cell[TextData[{
 "You are likely familiar from general chemistry with the conceptual picture \
that the lone-pair electrons on oxygen distort the otherwise tetrahedral \
geometry of four ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    StyleBox["sp",
     FontSlant->"Italic"], "3"], TraditionalForm]],ExpressionUUID->
  "de0df6b3-f26d-4827-beae-6bd03ffb66f5"],
 " hybrid orbitals in ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox[
     StyleBox["H",
      FontSlant->"Plain"], "2"], 
    StyleBox["O",
     FontSlant->"Plain"]}], TraditionalForm]],ExpressionUUID->
  "f87e463b-294d-4d5d-8e76-dca88ca68c52"],
 ". In our linear combination approach, we can account for this distortion by \
altering the weighting factors on the ",
 StyleBox["s",
  FontSlant->"Italic"],
 " and ",
 StyleBox["p",
  FontSlant->"Italic"],
 " contributions to the orbitals. For example, the bonding orbitals could \
then be written as"
}], "Text",
 CellChangeTimes->{{3.8142828209702663`*^9, 3.8142828883177423`*^9}, {
  3.8142829527767425`*^9, 3.8142830058040695`*^9}, {3.81428312510439*^9, 
  3.814283150192467*^9}},ExpressionUUID->"a9e264f6-8b5b-4d65-9a1d-\
68d6e655679e"],

Cell[BoxData[
 RowBox[{
  SubscriptBox["\[CapitalPhi]", "bonding"], "=", 
  RowBox[{
   RowBox[{
    RowBox[{"0.45", 
     SubscriptBox["\[Phi]", 
      RowBox[{"2", 
       StyleBox["s",
        FontSlant->"Italic"]}]]}], "\[PlusMinus]", 
    RowBox[{"0.71", 
     SubscriptBox["\[Phi]", 
      RowBox[{"2", 
       StyleBox[
        SubscriptBox[
         StyleBox["p",
          FontSlant->"Italic"], "y"],
        FontSlant->"Italic"]}]]}]}], "+", 
   RowBox[{"0.55", 
    SubscriptBox["\[Phi]", 
     RowBox[{"2", 
      StyleBox[
       SubscriptBox[
        StyleBox["p",
         FontSlant->"Italic"], "z"],
       FontSlant->"Italic"]}]]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8142715408501225`*^9, 3.8142716264528427`*^9}, {
   3.8142716634962983`*^9, 3.81427166385531*^9}, {3.8142717090653296`*^9, 
   3.814271758882024*^9}, {3.8142767976668887`*^9, 3.8142767986447644`*^9}, 
   3.814277116274558*^9, {3.814277180844843*^9, 3.814277221091382*^9}, {
   3.814277457217991*^9, 3.8142774573794937`*^9}, {3.814277728866243*^9, 
   3.814277745715167*^9}, {3.8142790776422806`*^9, 3.8142790820653687`*^9}, {
   3.8142791270338016`*^9, 3.8142792828377457`*^9}, {3.8142804083421297`*^9, 
   3.814280517997387*^9}, {3.8142831721855536`*^9, 3.814283198397331*^9}, {
   3.814283237440914*^9, 3.814283265697242*^9}, 
   3.8142834702690067`*^9},ExpressionUUID->"5b8615ff-45a6-4f64-b961-\
5e6a985b9d61"],

Cell[TextData[{
 "where the square of each weighting coefficient can be thought of as the \
percentage of ",
 StyleBox["s",
  FontSlant->"Italic"],
 " or ",
 StyleBox["p",
  FontSlant->"Italic"],
 " character. We could similarly construct a set of hybrid orbitals for the \
lone pairs, which would show an increased ",
 StyleBox["s",
  FontSlant->"Italic"],
 "-character in comparison to the bonding orbitals, meaning that the orbitals \
are more spherically symmetric. However, in reality, the two lone pairs \
actually occupy separate orbitals that are not the same in energy or spatial \
distribution."
}], "Text",
 CellChangeTimes->{{3.814283447008311*^9, 
  3.8142836197991304`*^9}},ExpressionUUID->"8e9e9626-c8b3-4ad8-90e2-\
ee2311a25dec"]
}, Open  ]],

Cell[CellGroupData[{

Cell["\<\
Bent Molecules - Linear Variational Method and Walsh Correlation Diagrams\
\>", "Subsection",
 CellChangeTimes->{{3.814283713012993*^9, 
  3.8142837588156*^9}},ExpressionUUID->"63e92e27-fb1f-4895-982c-af0cd8c3d9c2"],

Cell[TextData[{
 "We saw above that if we already know the geometry of a molecule, we can \
construct hybrid orbitals that account for that geometry. However, this \
approach does not explain the origin of the molecular structure in the first \
place. Let\[CloseCurlyQuote]s take the example of molecules with the generic \
structure of ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["AH", "2"], TraditionalForm]],ExpressionUUID->
  "d7fa3995-e34a-4d0b-b4d2-7f6a62f90d7b"],
 ". These include both ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["BeH", "2"], TraditionalForm]],ExpressionUUID->
  "11efba1b-1e20-458c-82c4-f6dbb231fa4d"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox[
     StyleBox["H",
      FontSlant->"Plain"], "2"], 
    StyleBox["O",
     FontSlant->"Plain"]}], TraditionalForm]],ExpressionUUID->
  "9dd2aaa3-0f78-453b-85af-70b939062f19"],
 ". We could write a generic molecular orbital composed of the valence atomic \
orbitals as"
}], "Text",
 CellChangeTimes->{{3.814283762840923*^9, 3.814283824181795*^9}, {
  3.814283961010565*^9, 3.8142840243616233`*^9}, {3.8142840578412514`*^9, 
  3.8142840736762085`*^9}, {3.814289782825465*^9, 
  3.8142897833087435`*^9}},ExpressionUUID->"e0453bab-de79-4084-8378-\
ed595447c89a"],

Cell[BoxData[
 RowBox[{
  SubscriptBox["\[Psi]", "MO"], "=", 
  RowBox[{
   RowBox[{
    SubscriptBox[
     StyleBox["c",
      FontSlant->"Italic"], "1"], 
    SubscriptBox["\[Phi]", 
     RowBox[{"1", 
      SubscriptBox[
       StyleBox["s",
        FontSlant->"Italic"], "Ha"]}]]}], "+", 
   RowBox[{
    SubscriptBox[
     StyleBox["c",
      FontSlant->"Italic"], "2"], 
    SubscriptBox["\[Phi]", 
     RowBox[{"1", 
      SubscriptBox[
       StyleBox["s",
        FontSlant->"Italic"], "Hb"]}]]}], "+", 
   RowBox[{
    SubscriptBox[
     StyleBox["c",
      FontSlant->"Italic"], "3"], 
    SubscriptBox["\[Phi]", 
     RowBox[{
      StyleBox["2",
       FontSlant->"Italic"], 
      SubscriptBox[
       StyleBox["s",
        FontSlant->"Italic"], 
       StyleBox["A",
        FontSlant->"Italic"]]}]]}], "+", 
   RowBox[{
    SubscriptBox[
     StyleBox["c",
      FontSlant->"Italic"], "4"], 
    SubscriptBox["\[Phi]", 
     RowBox[{"2", 
      SubscriptBox[
       StyleBox["p",
        FontSlant->"Italic"], 
       StyleBox["zA",
        FontSlant->"Italic"]]}]]}], "+", 
   RowBox[{
    SubscriptBox[
     StyleBox["c",
      FontSlant->"Italic"], "5"], 
    SubscriptBox["\[Phi]", 
     RowBox[{"2", 
      SubscriptBox[
       StyleBox["p",
        FontSlant->"Italic"], 
       StyleBox["xA",
        FontSlant->"Italic"]]}]]}], "+", 
   RowBox[{
    SubscriptBox[
     StyleBox["c",
      FontSlant->"Italic"], "6"], 
    SubscriptBox["\[Phi]", 
     RowBox[{"2", 
      SubscriptBox[
       StyleBox["p",
        FontSlant->"Italic"], 
       StyleBox["yA",
        FontSlant->"Italic"]]}]]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8132221669142685`*^9, 3.8132221794693403`*^9}, {
   3.8132222690385857`*^9, 3.813222292552426*^9}, {3.8132225103046436`*^9, 
   3.8132225357976294`*^9}, 3.813225530724597*^9, {3.8132268996594105`*^9, 
   3.8132268997936573`*^9}, {3.8132269718506794`*^9, 
   3.8132270598936987`*^9}, {3.813227090063882*^9, 3.8132270928942423`*^9}, {
   3.8132273687054873`*^9, 3.8132273956726027`*^9}, {3.8132274257354927`*^9, 
   3.8132274504676456`*^9}, {3.813227484968296*^9, 3.8132274916733313`*^9}, {
   3.813227717592659*^9, 3.813227799104663*^9}, {3.8132278524338465`*^9, 
   3.813227854764579*^9}, 3.8132279269606223`*^9, {3.81323366169593*^9, 
   3.813233662702242*^9}, {3.813676741631068*^9, 3.813676829221445*^9}, {
   3.8142067350871696`*^9, 3.8142067908071504`*^9}, {3.8142840985673933`*^9, 
   3.814284226200172*^9}},ExpressionUUID->"e6f7187d-dcdc-4ea4-8c68-\
12c2519281d9"],

Cell["\<\
To find the form and energies of these molecular orbitals, we would need to \
solve the equation from the variational method\
\>", "Text",
 CellChangeTimes->{{3.8142842349099803`*^9, 
  3.814284281946615*^9}},ExpressionUUID->"2b255ee9-8342-484a-abc7-\
6724cefbfe99"],

Cell[BoxData[
 RowBox[{
  SubscriptBox[
   StyleBox["E",
    FontSlant->"Italic"], "MO"], "=", 
  FractionBox[
   RowBox[{"\[LeftAngleBracket]", 
    RowBox[{
     SubscriptBox["\[Psi]", "MO"], "|", 
     SubscriptBox[
      OverscriptBox[
       StyleBox["H",
        FontSlant->"Italic"], "^"], 
      StyleBox["e",
       FontSlant->"Italic"]], "|", 
     SubscriptBox["\[Psi]", "MO"]}], "\[RightAngleBracket]"}], 
   RowBox[{"\[LeftAngleBracket]", 
    RowBox[{
     SubscriptBox["\[Psi]", "MO"], "|", 
     SubscriptBox["\[Psi]", "MO"]}], 
    "\[RightAngleBracket]"}]]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.813228038288596*^9, 3.813228093385758*^9}, {
  3.8132336120692124`*^9, 3.8132336334997315`*^9}, {3.8132336788534994`*^9, 
  3.813233689019577*^9}, {3.814284308872406*^9, 
  3.814284319432659*^9}},ExpressionUUID->"a06c8074-7110-407c-bafb-\
becdc6c2c895"],

Cell[TextData[{
 "which would involve (1) finding the Hamiltonian matrix ",
 StyleBox["H",
  FontWeight->"Bold"],
 ", a 6 \[Times] 6 matrix with each entry given by"
