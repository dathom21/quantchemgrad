Cell[CellGroupData[{

Cell["Review: Light as a Wave", "Section",
 CellChangeTimes->{{3.9142356278437667`*^9, 
  3.9142356378314734`*^9}},ExpressionUUID->"c57a649a-ce29-40fd-ada9-\
32528e1f79f4"],

Cell[TextData[{
 "We\[CloseCurlyQuote]ll be discussing light quite a bit at the beginning of \
this course, so let\[CloseCurlyQuote]s take a moment to review the \
\[OpenCurlyDoubleQuote]classical\[CloseCurlyDoubleQuote] description of light \
as a wave that was known at the beginning of the ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["20", "th"], TraditionalForm]],ExpressionUUID->
  "a63fc9d9-da2b-4c9c-b9b3-fb04bea5649d"],
 " century. Light can be understood as an electromagnetic wave traveling \
through space (we\[CloseCurlyQuote]ll find out more about the particle nature \
of light in a moment). It has an electric field vector ",
 StyleBox["E",
  FontWeight->"Bold"],
 " and a magnetic field vector ",
 StyleBox["B",
  FontWeight->"Bold"],
 " that oscillate perpendicular to one another. Figure 1.1 shows an \
illustration for linearly polarized light."
}], "Text",
 CellChangeTimes->{{3.914235679891656*^9, 3.914235769424203*^9}, {
  3.9142358018011303`*^9, 3.914235830833196*^9}, {3.914235862488356*^9, 
  3.914235873687124*^9}, {3.914235914378433*^9, 3.9142359318137503`*^9}, {
  3.914235962653425*^9, 
  3.9142359714945354`*^9}},ExpressionUUID->"a6cdcba3-23aa-40ed-8a47-\
bbb243cb57ca"],

