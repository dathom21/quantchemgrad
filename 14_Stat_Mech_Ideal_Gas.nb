Cell[TextData[{
 StyleBox["Figure 14.1",
  FontWeight->"Bold"],
 ". Maxwell-Boltzmann distribution of speeds for an ideal gas. The \
temperature and molar mass of the gas can be varied with bars at the top. The \
\[OpenCurlyDoubleQuote]fraction of gas\[CloseCurlyDoubleQuote] represents the \
percent of particles with a velocity within the adjustable blue velocities. \
Wolfram Demonstrations, Jan Fiala (March 2011), CC BY-NC-SA, \
https://demonstrations.wolfram.com/TheMaxwellSpeedDistribution/"
}], "Affiliation",
 CellChangeTimes->{{3.809435027311596*^9, 3.8094350763900714`*^9}, {
   3.80943583474421*^9, 3.8094358359299717`*^9}, {3.8094472165104203`*^9, 
   3.809447281165168*^9}, {3.809510876137825*^9, 3.809510907739876*^9}, {
   3.809968073566992*^9, 3.8099681536568317`*^9}, {3.810557260250428*^9, 
   3.8105572606139913`*^9}, {3.8130835305386977`*^9, 
   3.8130836194514275`*^9}, {3.813224407772764*^9, 3.8132244817756805`*^9}, {
   3.8153299652849884`*^9, 3.8153300856368465`*^9}, {3.815486734293851*^9, 
   3.8154867344058456`*^9}, {3.8154879218419533`*^9, 
   3.8154879663632336`*^9}, {3.815923898141548*^9, 3.8159239219760113`*^9}, {
   3.815923956762824*^9, 3.8159240452391195`*^9}, {3.8159247099333353`*^9, 
   3.8159247404817953`*^9}, 3.815994726716399*^9, {3.9208860099869857`*^9, 
   3.9208860126872406`*^9}, {3.921496096111129*^9, 3.9214962066970744`*^9}, {
   3.9415592457656345`*^9, 
   3.941559245891861*^9}},ExpressionUUID->"56c3176d-08ad-4eb4-a453-\
b918d3e7a4aa"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Collision Frequency and Mean Free Path", "Subsection",
 CellChangeTimes->{{3.921423220709637*^9, 3.921423229798174*^9}, {
  3.9214866519054146`*^9, 3.921486667890504*^9}, {3.9214867677009354`*^9, 
  3.921486772100391*^9}, {3.921493656433814*^9, 3.9214936579458504`*^9}, {
  3.921493709767871*^9, 3.921493716136305*^9}, {3.9214963253360496`*^9, 
  3.921496328351034*^9}, {3.921496427222143*^9, 
  3.9214964296410336`*^9}},ExpressionUUID->"b464f8e6-ac94-4f33-a8ca-\
7886d5b86b78"],

Cell["\<\
Now we wish to consider the frequency with which a particle collides with \
other particles in the gas. For this consideration, we will first have to \
accept that the particle is not just a point particle but has some \
cross-sectional area\
\>", "Text",
 CellChangeTimes->{{3.921497513613118*^9, 
  3.921497584621578*^9}},ExpressionUUID->"1f2ab11d-160a-4a00-8bf8-\
8ab0e56dfff0"],

Cell[BoxData[
 RowBox[{"\[Sigma]", "=", 
  RowBox[{"\[Pi]", 
   SuperscriptBox[
    RowBox[{"(", 
     RowBox[{"2", 
      StyleBox["r",
       FontSlant->"Italic"]}], 
     StyleBox[")",
      FontSlant->"Italic"]}], "2"]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.9214975936980705`*^9, 3.9214976019817743`*^9}, {
  3.9226261124519763`*^9, 
  3.9226261181163025`*^9}},ExpressionUUID->"95211225-9691-4fd4-bd7c-\
633fe352f80c"],

Cell[TextData[{
 "Now if we take the average velocity ",
 Cell[BoxData[
  RowBox[{"\[LeftAngleBracket]", 
   StyleBox["v",
    FontSlant->"Italic"], "\[RightAngleBracket]"}]],
  CellChangeTimes->{{3.9214937852602882`*^9, 3.921493903512112*^9}, {
   3.92149407730235*^9, 3.9214940977786603`*^9}},ExpressionUUID->
  "c6423923-817e-461f-80ac-a33a9291efac"],
 ", the cylindrical volume through which the molecule passes in time ",
 "\[CapitalDelta]",
 StyleBox["t",
  FontSlant->"Italic"],
 " is given by",
 " this area multiplied by the ",
 StyleBox["mean ",
  FontSlant->"Italic"],
 "relative speed (the speed of the particle on average in comparison to all \
other particles) ",
 Cell[BoxData[
  FormBox[
   SqrtBox["2"], TraditionalForm]],ExpressionUUID->
  "26b493ff-1fda-4a90-ac06-28cd5ce10966"],
 Cell[BoxData[
  RowBox[{"\[LeftAngleBracket]", 
   StyleBox["v",
    FontSlant->"Italic"], "\[RightAngleBracket]"}]],
  CellChangeTimes->{{3.9214937852602882`*^9, 3.921493903512112*^9}, {
   3.92149407730235*^9, 3.9214940977786603`*^9}},ExpressionUUID->
  "1a9d2e5e-d513-477e-89e1-e6b8d7a26b8f"],
 ","
}], "Text",
 CellChangeTimes->{{3.9214976929558525`*^9, 3.9214978235485992`*^9}, {
  3.921497857668646*^9, 3.9214978991488824`*^9}, {3.921498224086791*^9, 
  3.921498233641818*^9}, {3.9214987039443417`*^9, 
  3.9214987059625144`*^9}},ExpressionUUID->"94b4b936-1eda-4e42-bfec-\
8f420d3cfafa"],

Cell[BoxData[
 RowBox[{
  SubscriptBox[
   StyleBox[
    RowBox[{
     StyleBox["\[CapitalDelta]",
      FontSlant->"Plain"], 
     StyleBox["V",
      FontSlant->"Italic"]}]], "col"], "=", 
  RowBox[{
   FormBox[
    SqrtBox["2"],
    TraditionalForm], "\[Sigma]", 
   RowBox[{"\[LeftAngleBracket]", 
    StyleBox["v",
     FontSlant->"Italic"], "\[RightAngleBracket]"}], 
   StyleBox[
    RowBox[{
     StyleBox["\[CapitalDelta]",
      FontSlant->"Plain"], 
     StyleBox["t",
      FontSlant->"Italic"]}]]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.9214975936980705`*^9, 3.9214976019817743`*^9}, {
   3.9214984195645933`*^9, 3.9214984514536*^9}, {3.921498693790794*^9, 
   3.921498711503212*^9}, 
   3.921498777968139*^9},ExpressionUUID->"906deab5-c86d-48b5-8ca3-\
fb388cac1066"],

Cell[TextData[{
 "We can then calculate the collision rate of an individual particle ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["z", "i"], TraditionalForm]],ExpressionUUID->
  "95f0ff22-8cc1-4ff2-9200-957c6978a558"],
 " as "
}], "Text",
 CellChangeTimes->{{3.9214984589660034`*^9, 3.921498461824927*^9}, {
  3.9214986294068604`*^9, 3.921498640781268*^9}, {3.9214986830604444`*^9, 
  3.921498689864236*^9}, {3.9214987310524454`*^9, 
  3.921498736158702*^9}},ExpressionUUID->"a61740b7-ae01-46db-9910-\
68a8fdbd2251"],

Cell[BoxData[
 RowBox[{
  SubscriptBox[
   StyleBox["z",
    FontSlant->"Italic"], 
   StyleBox["i",
    FontSlant->"Italic"]], "=", 
  RowBox[{
   FractionBox[
    SubscriptBox[
     StyleBox[
      RowBox[{"\[Rho]", 
       StyleBox["\[CapitalDelta]",
        FontSlant->"Plain"], 
       StyleBox["V",
        FontSlant->"Italic"]}]], "col"], 
    StyleBox[
     RowBox[{"\[CapitalDelta]", 
      StyleBox["t",
       FontSlant->"Italic"]}]]], "=", 
   RowBox[{
    FormBox[
     SqrtBox["2"],
     TraditionalForm], "\[Sigma]", 
    RowBox[{"\[LeftAngleBracket]", 
     StyleBox["v",
      FontSlant->"Italic"], "\[RightAngleBracket]"}], 
    "\[Rho]"}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.9214975936980705`*^9, 3.9214976019817743`*^9}, {
  3.9214984195645933`*^9, 3.9214984514536*^9}, {3.921498693790794*^9, 
  3.92149877293792*^9}},ExpressionUUID->"5fc01bd2-9ba8-4cc4-a79a-\
e993e21db043"],

Cell["where ", "Text",
 CellChangeTimes->{{3.921498820567213*^9, 3.921498841621168*^9}, 
   3.9214990063085127`*^9},ExpressionUUID->"0065f8dc-2266-4cd8-abe0-\
7f68a4da6d12"],

Cell[BoxData[
 RowBox[{"\[Rho]", "=", 
  RowBox[{
   FractionBox[
    StyleBox["N",
     FontSlant->"Italic"], 
    StyleBox["V",
     FontSlant->"Italic"]], "=", 
   FractionBox[
    StyleBox["P",
     FontSlant->"Italic"], 
    StyleBox[
     RowBox[{
      SubscriptBox["k", "b"], "T"}],
     FontSlant->"Italic"]]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.9214990115562162`*^9, 
  3.921499025762578*^9}},ExpressionUUID->"b5bf53bb-9ee6-4c67-9cac-\
fa36b5241751"],

Cell[TextData[{
 StyleBox["is the density of the gas. The value ",
  FontSlant->"Plain"],
 Cell[BoxData[
  SubscriptBox[
   StyleBox["z",
    FontSlant->"Italic"], "i"]],
  CellChangeTimes->{{3.9214975936980705`*^9, 3.9214976019817743`*^9}, {
   3.9214984195645933`*^9, 3.9214984514536*^9}, {3.921498693790794*^9, 
   3.92149877293792*^9}},ExpressionUUID->
  "804d5e31-7092-4c31-9e65-5aa8d1fc89da"],
 StyleBox[" gives the collision frequency for a single particle. The total \
collision frequency per unit time per unit volume is then ",
  FontSlant->"Plain"]
}], "Text",
 CellChangeTimes->{{3.9214990544979105`*^9, 3.9214990604707947`*^9}, {
  3.921499109970478*^9, 3.921499131040352*^9}, {3.92150003313011*^9, 
  3.921500036431632*^9}},
 FontSlant->"Italic",ExpressionUUID->"3dd3cc86-029f-4f21-bd16-717464e4572f"],

Cell[BoxData[
 RowBox[{
  SubscriptBox["z", 
   StyleBox["ii",
    FontSlant->"Italic"]], "=", 
  RowBox[{
   FractionBox["1", "2"], 
   SubscriptBox[
    StyleBox["z",
     FontSlant->"Italic"], 
    StyleBox["i",
     FontSlant->"Italic"]], "\[Rho]"}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.9214975936980705`*^9, 3.9214976019817743`*^9}, {
  3.9214984195645933`*^9, 3.9214984514536*^9}, {3.921498693790794*^9, 
  3.92149877293792*^9}, {3.9215000417617273`*^9, 3.9215000868020663`*^9}, {
  3.9229715115190725`*^9, 
  3.9229715115837555`*^9}},ExpressionUUID->"aee36a2c-c5df-4fcc-8c67-\
405340844a39"],

Cell["\<\
where the factor of 1/2 accounts for double-counting of collisions between \
molecules, and the factor \[Rho] accounts for the number of molecules in a \
given unit volume.\
\>", "Text",
 CellChangeTimes->{{3.921500178805654*^9, 
  3.921500214563694*^9}},ExpressionUUID->"e755542a-54ca-44ba-b459-\
42e67a30574a"],

Cell[TextData[{
 "The frequency of collisions with a wall can be calculated in a similar \
manner to ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["z",
    FontSlant->"Italic"], 
   StyleBox["i",
    FontSlant->"Italic"]]],
  CellChangeTimes->{{3.9214975936980705`*^9, 3.9214976019817743`*^9}, {
   3.9214984195645933`*^9, 3.9214984514536*^9}, {3.921498693790794*^9, 
   3.92149877293792*^9}},ExpressionUUID->
  "b5702580-087a-4f6d-908a-96fb4b62697b"],
 ", using the area of the wall rather ",
 StyleBox["A",
  FontSlant->"Italic"],
 " rather than the cross section of the molecule and using the average speed \
of particles approaching a given wall,"
}], "Text",
 CellChangeTimes->{{3.921511624318463*^9, 3.9215116393929873`*^9}, {
  3.9215116767881117`*^9, 3.921511737711965*^9}, {3.9215117747014613`*^9, 
  3.9215117835027018`*^9}, {3.9215131860847178`*^9, 
  3.921513195358212*^9}},ExpressionUUID->"cbf1011b-e682-4b5b-bd7d-\
a93ae12c8605"],

Cell[BoxData[
 RowBox[{
  SubscriptBox[
   StyleBox[
    RowBox[{
     StyleBox["\[CapitalDelta]",
      FontSlant->"Plain"], 
     StyleBox["V",
      FontSlant->"Italic"]}]], "wall"], "=", 
  RowBox[{"(", 
   RowBox[{
    StyleBox["A",
     FontSlant->"Italic"], 
    SubscriptBox[
     RowBox[{"\[LeftAngleBracket]", 
      SubscriptBox[
       StyleBox["v",
        FontSlant->"Italic"], "x"], "\[RightAngleBracket]"}], 
     RowBox[{
      SubscriptBox["v", "x"], ">", "0"}]], 
    StyleBox[
     RowBox[{
      StyleBox["\[CapitalDelta]",
       FontSlant->"Plain"], 
      StyleBox["t",
       FontSlant->"Italic"]}]]}], 
   StyleBox[")",
    FontSlant->"Italic"]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.9214975936980705`*^9, 3.9214976019817743`*^9}, {
   3.9214984195645933`*^9, 3.9214984514536*^9}, {3.921498693790794*^9, 
   3.921498711503212*^9}, 3.921498777968139*^9, {3.9215117398977623`*^9, 
   3.92151176276309*^9}, {3.9215122480120907`*^9, 3.921512249222062*^9}, {
   3.921512437716934*^9, 3.921512440233614*^9}, {3.921512621693006*^9, 
   3.9215126226183987`*^9}, {3.921513073745644*^9, 
   3.921513084718315*^9}},ExpressionUUID->"046ffebc-2045-4488-aeac-\
5c59a928fba2"],

Cell[TextData[{
 "Note that the factor of ",
 Cell[BoxData[
  FormBox[
   SqrtBox["2"], TraditionalForm]],ExpressionUUID->
  "fa11ec04-b96f-42e2-87ce-8ad1317bbff3"],
 " is not included because the wall is stationary, so a relative speed is not \
needed. Recall that  ",
 Cell[BoxData[
  RowBox[{
   StyleBox["f",
    FontSlant->"Italic"], 
   RowBox[{"(", 
    StyleBox[
     SubscriptBox["v", "x"],
     FontSlant->"Italic"], ")"}]}]],
  InitializationCell->True,
  CellChangeTimes->{{3.9212505192469416`*^9, 3.921250534863843*^9}, {
    3.9212507356598735`*^9, 3.9212507676410656`*^9}, {3.9212508673633738`*^9, 
    3.9212509608799176`*^9}, {3.921251060924367*^9, 3.9212511124818687`*^9}, {
    3.9212511504673223`*^9, 3.921251158794492*^9}, {3.9212512029019794`*^9, 
    3.9212512716665497`*^9}, {3.921251348153563*^9, 3.921251397670518*^9}, {
    3.921328606806888*^9, 3.921328654543107*^9}, 3.9213289776454625`*^9, {
    3.921329302517523*^9, 3.921329306297614*^9}, {3.921329571452891*^9, 
    3.921329578612625*^9}, 3.9213296317732787`*^9, {3.9213298724546156`*^9, 
    3.9213298798186703`*^9}, {3.9213300349738455`*^9, 
    3.9213300480959187`*^9}, {3.921330546631791*^9, 3.9213305595573583`*^9}, 
    3.9213306578039947`*^9, 3.92133077659169*^9, {3.921330821603032*^9, 
    3.921330874812805*^9}, {3.9214238904787655`*^9, 3.921423917414671*^9}, {
    3.9214244282577167`*^9, 3.9214244340743675`*^9}, {3.921424481932246*^9, 
    3.9214245032022505`*^9}, {3.921424987482314*^9, 3.921425055638995*^9}, {
    3.921425366857955*^9, 3.921425371156514*^9}, {3.9214256982769957`*^9, 
    3.9214257016055365`*^9}, {3.9214257501539373`*^9, 3.921425767889146*^9}, {
    3.92142603866897*^9, 3.921426048746488*^9}, {3.9214261320689683`*^9, 
    3.9214261722302637`*^9}, {3.921426337008007*^9, 3.9214264736243744`*^9}, {
    3.9214266549853134`*^9, 3.9214266922179117`*^9}, {3.921426724430789*^9, 
    3.9214267981473503`*^9}, 3.9214268670094585`*^9, 3.921432537477965*^9, {
    3.9214334761985445`*^9, 3.921433494744827*^9}, {3.9214335541346235`*^9, 
    3.92143358711337*^9}, {3.9214336750250797`*^9, 3.921433693696782*^9}},
  ExpressionUUID->"f1f53e5a-9273-4973-9628-227212612f7c"],
 "contains both positive and negative velocities, and we want to calculate \
only the average speed for particles approaching the wall, represented above \
by ",
 Cell[BoxData[
  SubscriptBox[
   RowBox[{"\[LeftAngleBracket]", 
    SubscriptBox[
     StyleBox["v",
      FontSlant->"Italic"], "x"], "\[RightAngleBracket]"}], 
   RowBox[{
    SubscriptBox["v", "x"], ">", "0"}]]],
  CellChangeTimes->{{3.9214975936980705`*^9, 3.9214976019817743`*^9}, {
    3.9214984195645933`*^9, 3.9214984514536*^9}, {3.921498693790794*^9, 
    3.921498711503212*^9}, 3.921498777968139*^9, {3.9215117398977623`*^9, 
    3.92151176276309*^9}, {3.9215122480120907`*^9, 3.921512249222062*^9}, {
    3.921512437716934*^9, 3.921512440233614*^9}, {3.921512621693006*^9, 
    3.9215126226183987`*^9}, {3.921513073745644*^9, 3.921513084718315*^9}},
  ExpressionUUID->"aad50f43-b423-4186-bc1a-7ea9928df793"],
 ". This quantity can be calculated as "
}], "Text",
 CellChangeTimes->{{3.9215117994243927`*^9, 3.921511838861263*^9}, {
  3.9215119127487526`*^9, 3.9215119540126286`*^9}, {3.92151199432302*^9, 
  3.9215119982338066`*^9}, {3.921512053324094*^9, 3.921512055104887*^9}, {
  3.9215123882625155`*^9, 3.9215124051988864`*^9}, {3.921512448261692*^9, 
  3.921512460302148*^9}, {3.9215125314388475`*^9, 3.921512585671482*^9}, {
  3.9215130988462563`*^9, 3.9215131431014633`*^9}, {3.9215132201580105`*^9, 
  3.9215132484949484`*^9}},ExpressionUUID->"a0b589e3-9e7f-44e2-9b89-\
ae4dd6c4a61c"],

Cell[BoxData[
 RowBox[{
  SubscriptBox[
   RowBox[{"\[LeftAngleBracket]", 
    SubscriptBox[
     StyleBox["v",
      FontSlant->"Italic"], "x"], "\[RightAngleBracket]"}], 
   RowBox[{
    SubscriptBox["v", "x"], ">", "0"}]], "=", 
  RowBox[{
   RowBox[{
    SuperscriptBox[
     SubscriptBox["\[Integral]", "0"], "\[Infinity]"], 
    RowBox[{
     SubscriptBox[
      StyleBox["v",
       FontSlant->"Italic"], 
      StyleBox["x",
       FontSlant->"Italic"]], 
     StyleBox["f",
      FontSlant->"Italic"], 
     RowBox[{"(", 
      StyleBox[
       SubscriptBox["v", "x"],
       FontSlant->"Italic"], ")"}], 
     RowBox[{"\[DifferentialD]", "x"}]}]}], "=", 
   RowBox[{
    SuperscriptBox[
     SubscriptBox["\[Integral]", "0"], "\[Infinity]"], 
    RowBox[{
     SubscriptBox[
      StyleBox["v",
       FontSlant->"Italic"], 
      StyleBox["x",
       FontSlant->"Italic"]], 
     StyleBox[
      SqrtBox[
       FractionBox[
        StyleBox["m",
         FontSlant->"Italic"], 
        RowBox[{"2", "\[Pi]", " ", 
         SubscriptBox[
          StyleBox["k",
           FontSlant->"Italic"], 
          StyleBox["B",
           FontSlant->"Italic"]], 
         StyleBox["T",
          FontSlant->"Italic"]}]]],
      FontSlant->"Plain"], 
     SuperscriptBox["\[ExponentialE]", 
      RowBox[{
       RowBox[{"-", 
        FractionBox[
         StyleBox["m",
          FontSlant->"Italic"], 
         RowBox[{"2", 
          SubscriptBox[
           StyleBox["k",
            FontSlant->"Italic"], 
           StyleBox["B",
            FontSlant->"Italic"]], 
          StyleBox["T",
           FontSlant->"Italic"]}]]}], 
       SubsuperscriptBox[
        StyleBox["v",
         FontSlant->"Italic"], 
        StyleBox["x",
         FontSlant->"Italic"], "2"]}]], 
     RowBox[{"\[DifferentialD]", "x"}]}]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.921513251532324*^9, 
  3.9215133283243356`*^9}},ExpressionUUID->"1a25085a-882c-4b5e-8076-\
5c038d1d124e"],

Cell[BoxData[
 RowBox[{"\t      ", 
  RowBox[{"=", 
   SqrtBox[
    FractionBox[
     StyleBox[
      RowBox[{
       SubscriptBox["k", "B"], "T"}],
      FontSlant->"Italic"], 
     RowBox[{"2", "\[Pi]", " ", 
      StyleBox["m",
       FontSlant->"Italic"]}]]]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.921513251532324*^9, 3.921513335850873*^9}, {
  3.921513374220827*^9, 
  3.921513400801852*^9}},ExpressionUUID->"3041cb7e-e2d8-4639-9b30-\
716410787d09"],

Cell["\<\
The rate of particles colliding with an area A per unit time is then given by \
\>", "Text",
 CellChangeTimes->{{3.921513135892255*^9, 3.92151313589425*^9}, 
   3.921513417722871*^9},ExpressionUUID->"2a8ab66a-0832-42e1-9995-\
9263e4766b9b"],

Cell[BoxData[
 RowBox[{
  FractionBox[
   SubscriptBox[
    StyleBox[
     RowBox[{"\[Rho]", 
      StyleBox["\[CapitalDelta]",
       FontSlant->"Plain"], 
      StyleBox["V",
       FontSlant->"Italic"]}]], "wall"], 
   StyleBox[
    RowBox[{"\[CapitalDelta]", 
     StyleBox["t",
      FontSlant->"Italic"]}]]], "=", 
  RowBox[{"\[Rho]", " ", 
   StyleBox["A",
    FontSlant->"Italic"], 
   SubscriptBox[
    RowBox[{"\[LeftAngleBracket]", 
     SubscriptBox[
      StyleBox["v",
       FontSlant->"Italic"], "x"], "\[RightAngleBracket]"}], 
    RowBox[{
     SubscriptBox["v", "x"], ">", "0"}]]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.9214975936980705`*^9, 3.9214976019817743`*^9}, {
   3.9214984195645933`*^9, 3.9214984514536*^9}, {3.921498693790794*^9, 
   3.921498711503212*^9}, 3.921498777968139*^9, {3.9215117398977623`*^9, 
   3.92151176276309*^9}, {3.9215122480120907`*^9, 3.921512249222062*^9}, {
   3.921512437716934*^9, 3.921512440233614*^9}, {3.9215126120076637`*^9, 
   3.92151264630375*^9}, {3.921513431748556*^9, 
   3.921513436321143*^9}},ExpressionUUID->"f5eac901-aa27-446d-8218-\
ff300eada43d"],

Cell["\<\
However, we are typically concerned with the rate per unit area rather than \
the rate colliding with a particular area, and this quantity is given by \
\>", "Text",
 CellChangeTimes->{{3.921512649781595*^9, 
  3.921512688319518*^9}},ExpressionUUID->"83c8b965-f963-4f6a-a89a-\
18024ea47777"],

Cell[BoxData[
 RowBox[{
  SubscriptBox[
   StyleBox["z",
    FontSlant->"Italic"], 
   StyleBox["w",
    FontSlant->"Italic"]], "=", 
  RowBox[{
   RowBox[{"\[Rho]", " ", 
    SubscriptBox[
     RowBox[{"\[LeftAngleBracket]", 
      SubscriptBox[
       StyleBox["v",
        FontSlant->"Italic"], "x"], "\[RightAngleBracket]"}], 
     RowBox[{
      SubscriptBox["v", "x"], ">", "0"}]]}], "=", 
   RowBox[{
    RowBox[{
     FractionBox[
      StyleBox["P",
       FontSlant->"Italic"], 
      StyleBox[
       RowBox[{
        SubscriptBox["k", "b"], "T"}],
       FontSlant->"Italic"]], 
     SqrtBox[
      FractionBox[
       StyleBox[
        RowBox[{
         SubscriptBox["k", "B"], "T"}],
        FontSlant->"Italic"], 
       RowBox[{"2", "\[Pi]", " ", 
        StyleBox["m",
         FontSlant->"Italic"]}]]]}], "=", 
    FractionBox[
     StyleBox["P",
      FontSlant->"Italic"], 
     SqrtBox[
      RowBox[{"2", "\[Pi]", " ", 
       StyleBox["m",
        FontSlant->"Italic"], " ", 
       StyleBox[
        SubscriptBox["k", "b"],
        FontSlant->"Italic"], 
       StyleBox["T",
        FontSlant->"Italic"]}]]]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.9214975936980705`*^9, 3.9214976019817743`*^9}, {
  3.9214984195645933`*^9, 3.9214984514536*^9}, {3.921498693790794*^9, 
  3.92149877293792*^9}, {3.9215126968278418`*^9, 3.9215127339735374`*^9}, {
  3.9215134449268894`*^9, 
  3.9215134972078924`*^9}},ExpressionUUID->"0b201205-1d50-4cda-86ac-\
8bc76c3f15b8"],

Cell["\<\
Finally, we can calculate the mean free path of a particle, \[Lambda], which \
is the distance a particle travels on average before experiencing a \
collision. This quantity is given by the average velocity (average distance \
per unit time) divided by the collision frequency (collisions per unit time), \
or in equation form,\
\>", "Text",
 CellChangeTimes->{{3.9215002389342804`*^9, 
  3.921500335873475*^9}},ExpressionUUID->"7ce77162-cc15-48ea-91f9-\
a6ec31974983"],

Cell[BoxData[
 RowBox[{"\[Lambda]", "=", 
  RowBox[{
   FractionBox[
    StyleBox[
     RowBox[{"\[LeftAngleBracket]", "v", "\[RightAngleBracket]"}],
     FontSlant->"Italic"], 
    StyleBox[
     SubscriptBox[
      StyleBox["z",
       FontSlant->"Italic"], 
      StyleBox["i",
       FontSlant->"Italic"]],
     FontSlant->"Italic"]], "=", 
   FractionBox["1", 
    RowBox[{
     FormBox[
      SqrtBox["2"],
      TraditionalForm], "\[Sigma]", " ", 
     "\[Rho]"}]]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.9214990115562162`*^9, 3.921499025762578*^9}, {
  3.92150032487109*^9, 
  3.921500378594785*^9}},ExpressionUUID->"6ee0777e-83df-4d96-8cb2-\
