Cell[CellGroupData[{

Cell["The Classical Wave Equation", "Section",
 CellChangeTimes->{{3.8074594324828715`*^9, 3.8074594487922525`*^9}, {
  3.8076177444720974`*^9, 3.8076177502095847`*^9}, {3.8076315419037385`*^9, 
  3.8076315442771745`*^9}, {3.8076317240690165`*^9, 
  3.8076317343277235`*^9}},ExpressionUUID->"2e1244cd-788e-464b-96da-\
235986134f15"],

Cell[CellGroupData[{

Cell["A Mathematical Description of Waves", "Subsection",
 CellChangeTimes->{{3.8074594553004203`*^9, 3.8074594587465677`*^9}, {
   3.8074596582936935`*^9, 3.8074596656673975`*^9}, {3.8076185232567763`*^9, 
   3.8076185290613766`*^9}, {3.8076317372460513`*^9, 3.807631746239662*^9}, 
   3.8076336519221983`*^9},ExpressionUUID->"231685ff-5496-4cea-8b81-\
44a156f84a43"],

Cell["\<\
The classical wave equation can be used to describe many systems (under the \
right conditions). For a one-dimensional wave it is written\
\>", "Text",
 CellChangeTimes->{{3.8074596692608757`*^9, 3.807459797211029*^9}, {
  3.8076185337605143`*^9, 3.8076185702918506`*^9}, {3.80761872369088*^9, 
  3.807618725241887*^9}, {3.807631749635639*^9, 3.8076318254331856`*^9}, {
  3.8076318799719334`*^9, 3.8076318867767506`*^9}, {3.8078687517020235`*^9, 
  3.807868752581231*^9}, {3.9146656035717783`*^9, 3.914665651255641*^9}, {
  3.933936460472227*^9, 3.9339364609628353`*^9}},
 FontFamily->
  "Source Serif Pro",ExpressionUUID->"d25e3be6-f02a-4de4-b21a-9e1fbca5ee5a"],

Cell[BoxData[
 RowBox[{
  FractionBox[
   RowBox[{
    RowBox[{
     SuperscriptBox["\[PartialD]", "2"], 
     StyleBox["u",
      FontSlant->"Italic"]}], 
    RowBox[{"(", 
     RowBox[{
      StyleBox["x",
       FontSlant->"Italic"], ",", 
      StyleBox["t",
       FontSlant->"Italic"]}], ")"}]}], 
   RowBox[{"\[PartialD]", 
    SuperscriptBox[
     StyleBox["x",
      FontSlant->"Italic"], "2"]}]], "=", 
  RowBox[{
   FractionBox["1", 
    SuperscriptBox[
     StyleBox["v",
      FontSlant->"Italic"], "2"]], 
   FractionBox[
    RowBox[{
     RowBox[{
      SuperscriptBox["\[PartialD]", "2"], 
      StyleBox["u",
       FontSlant->"Italic"]}], 
     RowBox[{"(", 
      RowBox[{
       StyleBox["x",
        FontSlant->"Italic"], ",", 
       StyleBox["t",
        FontSlant->"Italic"]}], ")"}]}], 
    RowBox[{"\[PartialD]", 
     SuperscriptBox[
      StyleBox["t",
       FontSlant->"Italic"], "2"]}]]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.807618646865757*^9, 3.807618686066933*^9}, {
  3.80763181860414*^9, 
  3.807631948535787*^9}},ExpressionUUID->"786b751f-dd72-41ab-a6ee-\
3de006bb597f"],

Cell[TextData[{
 "where ",
 StyleBox["u",
  FontSlant->"Italic"],
 " gives the amplitude of the wave at time",
 StyleBox[" t",
  FontSlant->"Italic"],
 " and position ",
 StyleBox["x",
  FontSlant->"Italic"],
 ", and ",
 StyleBox["v",
  FontSlant->"Italic"],
 " is the wave velocity. This equation is a linear partial differential \
equation, which we\[CloseCurlyQuote]ll discuss in more detail."
}], "Text",
 CellChangeTimes->{{3.9146658192680717`*^9, 
  3.914665834951523*^9}},ExpressionUUID->"e8b966d2-e666-4ce0-9860-\
49e844539749"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Solving the Classical Wave Equation", "Subsection",
 CellChangeTimes->{{3.8076336754001713`*^9, 
  3.807633680699888*^9}},ExpressionUUID->"810853f8-536d-4d2f-9d8b-\
36402fd60919"],

Cell[TextData[{
 "The information we are really after is the form of ",
 StyleBox["u ",
  FontSlant->"Italic"],
 "(",
 StyleBox["x",
  FontSlant->"Italic"],
 ", ",
 StyleBox["t",
  FontSlant->"Italic"],
 " ). In other words, how does our wave change in time and space? To get this \
information, we need to solve equation (1). It turns out, solving such \
equations involves using a lot of tricks that people have figured out over \
many years (or even centuries). The trick we are going to use is known as \
separation of variables."
}], "Text",
 CellChangeTimes->{{3.8076336917414284`*^9, 3.8076338575333366`*^9}, {
  3.9146658683489904`*^9, 
  3.91466587132168*^9}},ExpressionUUID->"c4984c2d-0252-4ce4-a33a-\
d4cd52a86b43"],

Cell["We assume that the solution takes the form", "Text",
 CellChangeTimes->{{3.8076338872065687`*^9, 
  3.807633896102146*^9}},ExpressionUUID->"e85c71f7-f8c5-40e1-9000-\
60714bdb386c"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   StyleBox["u",
    FontSlant->"Italic"], 
   RowBox[{"(", 
    RowBox[{
     StyleBox["x",
      FontSlant->"Italic"], ",", 
     StyleBox["t",
      FontSlant->"Italic"]}], ")"}]}], "=", 
  StyleBox[
   RowBox[{"X", 
    RowBox[{"(", "x", ")"}], "T", 
    RowBox[{"(", "t", ")"}]}],
   FontSlant->"Italic"]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.807633903326398*^9, 
  3.807633933761921*^9}},ExpressionUUID->"85113a5b-ebf7-427d-adee-\
adfacb7ffd93"],

Cell["\<\
meaning we can separate the function into its position-dependent and \
time-dependent parts. Plugging this into equation (1), we get\
\>", "Text",
 CellChangeTimes->{{3.8076339385504236`*^9, 3.8076339625938435`*^9}, {
  3.80763402233044*^9, 
  3.807634027903973*^9}},ExpressionUUID->"b2e0bcfc-9dbd-4e87-b20b-\
0c20ad820fdb"],

Cell[BoxData[
 RowBox[{
  FractionBox[
   RowBox[{
    RowBox[{
     SuperscriptBox["\[PartialD]", "2"], 
     StyleBox["X",
      FontSlant->"Italic"]}], 
    StyleBox[
     RowBox[{"(", "x", ")"}],
     FontSlant->"Italic"], 
    StyleBox["T",
     FontSlant->"Italic"], 
    StyleBox[
     RowBox[{"(", "t", ")"}],
     FontSlant->"Italic"]}], 
   RowBox[{"\[PartialD]", 
    SuperscriptBox[
     StyleBox["x",
      FontSlant->"Italic"], "2"]}]], "=", 
  RowBox[{
   FractionBox["1", 
    SuperscriptBox[
     StyleBox["v",
      FontSlant->"Italic"], "2"]], 
   FractionBox[
    RowBox[{
     RowBox[{
      SuperscriptBox["\[PartialD]", "2"], 
      StyleBox["X",
       FontSlant->"Italic"]}], 
     StyleBox[
      RowBox[{"(", "x", ")"}],
      FontSlant->"Italic"], 
     StyleBox["T",
      FontSlant->"Italic"], 
     StyleBox[
      RowBox[{"(", "t", ")"}],
      FontSlant->"Italic"]}], 
    RowBox[{"\[PartialD]", 
     SuperscriptBox[
      StyleBox["t",
       FontSlant->"Italic"], "2"]}]]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.807634040109483*^9, 
  3.8076340471992087`*^9}},ExpressionUUID->"5c17a699-dc17-4d78-bfdd-\
ff3bf3a56439"],

Cell["\<\
separating out the variables from the partial derivatives gives us\
\>", "Text",
 CellChangeTimes->{{3.807634053983411*^9, 
  3.807634066547357*^9}},ExpressionUUID->"07dca2d0-61ed-4024-b77a-\
35fc98eaf78f"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   StyleBox["T",
    FontSlant->"Italic"], 
   StyleBox[
    RowBox[{"(", "t", ")"}],
    FontSlant->"Italic"], 
   FractionBox[
    RowBox[{
     RowBox[{
      SuperscriptBox["\[DifferentialD]", "2"], 
      StyleBox["X",
       FontSlant->"Italic"]}], 
     StyleBox[
      RowBox[{"(", "x", ")"}],
      FontSlant->"Italic"]}], 
    RowBox[{"\[DifferentialD]", 
     SuperscriptBox[
      StyleBox["x",
       FontSlant->"Italic"], "2"]}]]}], "=", 
  RowBox[{
   StyleBox["X",
    FontSlant->"Italic"], 
   StyleBox[
    RowBox[{"(", "x", ")"}],
    FontSlant->"Italic"], 
   FractionBox["1", 
    SuperscriptBox[
     StyleBox["v",
      FontSlant->"Italic"], "2"]], 
   FractionBox[
    RowBox[{
     RowBox[{
      SuperscriptBox["\[DifferentialD]", "2"], 
      StyleBox["T",
       FontSlant->"Italic"]}], 
     StyleBox[
      RowBox[{"(", "t", ")"}],
      FontSlant->"Italic"]}], 
    RowBox[{"\[DifferentialD]", 
     SuperscriptBox[
      StyleBox["t",
       FontSlant->"Italic"], "2"]}]]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8076340767309113`*^9, 3.807634089019687*^9}, {
  3.807966194903346*^9, 3.8079662070953693`*^9}, {3.9148603911592455`*^9, 
  3.91486041338647*^9}},ExpressionUUID->"f3d42069-fe7c-462f-ae9f-\
edcb59c7b05c"],

Cell[TextData[{
 "collecting the components dependent on ",
 StyleBox["t",
  FontSlant->"Italic"],
 " on one side and the components dependent on ",
 StyleBox["x",
  FontSlant->"Italic"],
 " on the other gives"
}], "Text",
 CellChangeTimes->{{3.8076341153625784`*^9, 
  3.8076341868017654`*^9}},ExpressionUUID->"e44c79e2-4c93-4275-b48d-\
1805fe33a1f9"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   FractionBox["1", 
    StyleBox[
     RowBox[{"X", 
      RowBox[{"(", "x", ")"}]}],
     FontSlant->"Italic"]], 
   FractionBox[
    RowBox[{
     RowBox[{
      SuperscriptBox["\[DifferentialD]", "2"], 
      StyleBox["X",
       FontSlant->"Italic"]}], 
     StyleBox[
      RowBox[{"(", "x", ")"}],
      FontSlant->"Italic"]}], 
    RowBox[{"\[DifferentialD]", 
     SuperscriptBox[
      StyleBox["x",
       FontSlant->"Italic"], "2"]}]]}], "=", 
  RowBox[{
   FractionBox["1", 
    RowBox[{
     SuperscriptBox[
      StyleBox["v",
       FontSlant->"Italic"], "2"], 
     StyleBox["T",
      FontSlant->"Italic"], 
     StyleBox[
      RowBox[{"(", "t", ")"}],
      FontSlant->"Italic"]}]], 
   FractionBox[
    RowBox[{
     RowBox[{
      SuperscriptBox["\[DifferentialD]", "2"], 
      StyleBox["T",
       FontSlant->"Italic"]}], 
     StyleBox[
      RowBox[{"(", "t", ")"}],
      FontSlant->"Italic"]}], 
    RowBox[{"\[DifferentialD]", 
     SuperscriptBox[
      StyleBox["t",
       FontSlant->"Italic"], "2"]}]]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.807634196116152*^9, 3.807634245543498*^9}, {
  3.8079662101286297`*^9, 3.8079662205236874`*^9}, {3.9148604212827945`*^9, 
  3.914860424496277*^9}},ExpressionUUID->"81bffeb3-28ff-486f-b1ae-\
48bca2bd8a1f"],

Cell[TextData[{
 "now this equation can only hold true if both sides are equal to a constant, \
which we will call ",
 StyleBox["K",
  FontSlant->"Italic"],
 ". Now we have"
}], "Text",
 CellChangeTimes->{{3.8076348429932313`*^9, 3.807634946095067*^9}, {
  3.807635162617089*^9, 
  3.8076351673429523`*^9}},ExpressionUUID->"6a525e48-4ff9-4527-a72c-\
58e837194c38"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   FractionBox["1", 
    StyleBox[
     RowBox[{"X", 
      RowBox[{"(", "x", ")"}]}],
     FontSlant->"Italic"]], 
   FractionBox[
    RowBox[{
     RowBox[{
      SuperscriptBox["\[DifferentialD]", "2"], 
      StyleBox["X",
       FontSlant->"Italic"]}], 
     StyleBox[
      RowBox[{"(", "x", ")"}],
      FontSlant->"Italic"]}], 
    RowBox[{"\[DifferentialD]", 
     SuperscriptBox[
      StyleBox["x",
       FontSlant->"Italic"], "2"]}]]}], "=", 
  StyleBox["K",
   FontSlant->"Italic"]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8076349760868444`*^9, 3.807634986573615*^9}, {
   3.807635171537558*^9, 3.807635172875311*^9}, {3.80796622319014*^9, 
   3.8079662263233547`*^9}, 
   3.914860429659281*^9},ExpressionUUID->"ca9cdb4e-371f-470f-890d-\
2dfbe7e875fb"],

Cell["and", "Text",
 CellChangeTimes->{{3.807634991367658*^9, 
  3.8076349915614667`*^9}},ExpressionUUID->"9aa5dd26-0a3c-4e8c-a16c-\
9f70628bd439"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   FractionBox["1", 
    RowBox[{
     SuperscriptBox[
      StyleBox["v",
       FontSlant->"Italic"], "2"], 
     StyleBox["T",
      FontSlant->"Italic"], 
     StyleBox[
      RowBox[{"(", "t", ")"}],
      FontSlant->"Italic"]}]], 
   FractionBox[
    RowBox[{
     RowBox[{
      SuperscriptBox["\[DifferentialD]", "2"], 
      StyleBox["T",
       FontSlant->"Italic"]}], 
     StyleBox[
      RowBox[{"(", "t", ")"}],
      FontSlant->"Italic"]}], 
    RowBox[{"\[DifferentialD]", 
     SuperscriptBox[
      StyleBox["t",
       FontSlant->"Italic"], "2"]}]]}], "=", 
  StyleBox["K",
   FontSlant->"Italic"]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8076350011487913`*^9, 3.8076350055280676`*^9}, {
   3.8076351772221413`*^9, 3.8076351788749323`*^9}, {3.8079662300362196`*^9, 
   3.807966233055497*^9}, 
   3.914860434421173*^9},ExpressionUUID->"369c016b-539d-48b7-80bb-\
e9e302dfff1c"],

Cell[TextData[{
 "We can have three general cases for the value of ",
 StyleBox["K",
  FontSlant->"Italic"]
}], "Text",
 CellChangeTimes->{{3.807635314767945*^9, 
  3.8076353440782814`*^9}},ExpressionUUID->"831e086c-37fc-4e50-ac32-\
5c7771be95b5"],

Cell[TextData[{
 StyleBox["K  ",
  FontSlant->"Italic"],
 "= 0, which is a trivial solution (there is no wave)."
}], "Item",
 CellChangeTimes->{{3.807635365685609*^9, 
  3.8076354025059175`*^9}},ExpressionUUID->"48c0cce0-76fa-4c23-b1e6-\
af196ff9ea7d"],

Cell[TextData[{
 StyleBox["K  >",
  FontSlant->"Italic"],
 " 0"
}], "Item",
 CellChangeTimes->{{3.807635365685609*^9, 
  3.8076354116156187`*^9}},ExpressionUUID->"b0e9e61d-cb4d-4501-abf7-\
92e0b36f0ebc"],

Cell[TextData[{
 "For ",
 StyleBox["K",
  FontSlant->"Italic"],
 "  > 0, we use another trick where we set ",
 StyleBox["K ",
  FontSlant->"Italic"],
 " = ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["k", "2"], TraditionalForm]],ExpressionUUID->
  "b08a2ade-effb-4f10-93b0-90fc026ec585"],
 ". Mathematicians found that the solution for such an equation takes the form"
}], "Text",
 CellChangeTimes->{
  3.8076357115096045`*^9},ExpressionUUID->"8f91cbae-1001-41ec-a088-\
e7f99d541299"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   StyleBox["f",
    FontSlant->"Italic"], 
   RowBox[{"(", 
    StyleBox["x",
     FontSlant->"Italic"], 
    StyleBox[")",
     FontSlant->"Italic"]}]}], "=", 
  RowBox[{
   RowBox[{
    SubscriptBox[
     StyleBox["c",
      FontSlant->"Italic"], "1"], 
    SuperscriptBox["\[ExponentialE]", 
     StyleBox["kx",
      FontSlant->"Italic"]]}], "+", 
   RowBox[{
    SubscriptBox[
     StyleBox["c",
      FontSlant->"Italic"], "2"], 
    SuperscriptBox["\[ExponentialE]", 
     StyleBox[
      RowBox[{"-", "kx"}],
      FontSlant->"Italic"]]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.807635723724142*^9, 3.807635764186651*^9}, {
   3.807635801500595*^9, 3.8076358232640553`*^9}, {3.8076368276781015`*^9, 
   3.807636830444379*^9}, 3.80795662563459*^9, {3.914665951394679*^9, 
   3.9146659565053816`*^9}},ExpressionUUID->"d1c43eff-ad3a-4530-816a-\
015b6c179dfd"],

Cell[TextData[{
 "where ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["c",
    FontSlant->"Italic"], "1"]],
  CellChangeTimes->{{3.807635723724142*^9, 3.807635764186651*^9}, {
   3.807635801500595*^9, 3.8076358232640553`*^9}},ExpressionUUID->
  "89fa48fc-046e-4eeb-9eeb-493e3792a0af"],
 " and ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["c",
    FontSlant->"Italic"], "2"]],
  CellChangeTimes->{{3.807635723724142*^9, 3.807635764186651*^9}, {
   3.807635801500595*^9, 3.8076358232640553`*^9}},ExpressionUUID->
  "3abbbfc4-8afe-4e3f-901c-b48069fbf532"],
 " are constants."
}], "Text",
 CellChangeTimes->{{3.807635825259491*^9, 
  3.8076358473546033`*^9}},ExpressionUUID->"e1427480-558f-4242-985a-\
d5055b6384f5"],

Cell[TextData[{
 StyleBox["K  < ",
  FontSlant->"Italic"],
 "0"
}], "Item",
 CellChangeTimes->{{3.807635365685609*^9, 
  3.8076354189637623`*^9}},ExpressionUUID->"e759a856-dc10-4274-9ada-\
4ae463e762b9"],

Cell[TextData[{
 "For ",
 StyleBox["K",
  FontSlant->"Italic"],
 "  < 0, we instead set ",
 StyleBox["K ",
  FontSlant->"Italic"],
 " = \[Minus]",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["k", "2"], TraditionalForm]],ExpressionUUID->
  "b45e0d21-a437-4ba6-834c-31ad8125b4ce"],
 ". The solution then takes the form"
}], "Text",
 CellChangeTimes->{{3.807635856149242*^9, 
  3.807635895405697*^9}},ExpressionUUID->"e478b8dd-ac2f-49ab-9f43-\
b10dba312f6d"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   StyleBox["f",
    FontSlant->"Italic"], 
   RowBox[{"(", 
    StyleBox["x",
     FontSlant->"Italic"], 
    StyleBox[")",
     FontSlant->"Italic"]}]}], "=", 
  RowBox[{
   RowBox[{
    SubscriptBox[
     StyleBox["c",
      FontSlant->"Italic"], "1"], 
    SuperscriptBox["\[ExponentialE]", 
     StyleBox[
      RowBox[{
       StyleBox["\[ImaginaryI]",
        FontSlant->"Plain"], 
       StyleBox["kx",
        FontSlant->"Italic"]}]]]}], "+", 
   RowBox[{
    SubscriptBox[
     StyleBox["c",
      FontSlant->"Italic"], "2"], 
    SuperscriptBox["\[ExponentialE]", 
     RowBox[{
      StyleBox["-",
       FontSlant->"Italic"], 
      StyleBox[
       RowBox[{
        StyleBox["\[ImaginaryI]",
         FontSlant->"Plain"], 
        StyleBox["kx",
         FontSlant->"Italic"]}]]}]]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8076359069274254`*^9, 3.807635921019413*^9}, {
  3.807636834564494*^9, 3.8076368453051734`*^9}, {3.91466596733453*^9, 
  3.9146659913614044`*^9}},ExpressionUUID->"7ba6ed5b-2af0-4345-81df-\
0a3dd014901e"],

Cell["\<\
you should note that the complex exponentials of equation (9) resemble Euler\
\[CloseCurlyQuote]s formula\
\>", "Text",
 CellChangeTimes->{{3.807635996758321*^9, 3.8076360103772583`*^9}, {
  3.807868974964322*^9, 3.8078689838888206`*^9}, {3.9146659301213665`*^9, 
  3.9146659307293034`*^9}},ExpressionUUID->"481f5329-7121-4bea-b30e-\
b157c8faaf85"]
}, Open  ]]
