  3.9339480412842445`*^9, 
  3.9339480729637947`*^9}},ExpressionUUID->"ab497675-cf1d-48ba-b5e6-\
4ddccaac4c6b"],

Cell[BoxData[
 RowBox[{
  FractionBox[
