Cell[TextData[{
 "Note that this value does not depend on ",
 StyleBox["n",
  FontSlant->"Italic"],
 ", so the average value of the position is always in the center of the box. \
This result makes sense because all of the eigenfunctions are symmetric."
}], "Text",
 CellChangeTimes->{{3.8093538680693502`*^9, 
  3.809353929997422*^9}},ExpressionUUID->"572eba4b-e5a2-4825-a5ba-\
40c1404d0bb1"],

