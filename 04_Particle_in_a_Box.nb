  3.8093574827970333`*^9}},ExpressionUUID->"1af8c1d3-6849-cd4b-b58b-\
e4e3aea7e4ac"],

Cell["The TISE is then written", "Text",
 CellChangeTimes->{{3.809357488749692*^9, 
  3.8093574930042686`*^9}},ExpressionUUID->"2b6f0a8b-0dd6-c340-91cb-\
00f621cddd76"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"-", 
    FractionBox[
     SuperscriptBox["\[HBar]", "2"], 
     RowBox[{"2", 
      StyleBox["m",
       FontSlant->"Italic"]}]]}], 
   RowBox[{
    SuperscriptBox["\[Del]", "2"], "\[Psi]"}], 
   RowBox[{"(", 
    StyleBox["r",
     FontWeight->"Bold",
     FontSlant->"Italic"], 
    StyleBox[")",
     FontSlant->"Italic"]}]}], "=", 
  RowBox[{
   StyleBox["E",
    FontSlant->"Italic"], 
   StyleBox[" ",
    FontSlant->"Italic"], "\[Psi]", 
   RowBox[{"(", 
    StyleBox["r",
     FontWeight->"Bold",
     FontSlant->"Italic"], 
    StyleBox[")",
     FontSlant->"Italic"]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8079664251944246`*^9, 3.8079664343142004`*^9}, {
  3.8079689400739555`*^9, 3.8079689680029573`*^9}, {3.807970315263204*^9, 
  3.8079703215316095`*^9}, {3.807970415909548*^9, 3.807970437015459*^9}, {
  3.8079705221296997`*^9, 3.8079705895237727`*^9}, {3.8079740353167067`*^9, 
  3.807974091342613*^9}, {3.809357372187431*^9, 
  3.809357372582634*^9}},ExpressionUUID->"176137b3-db5c-6a4a-8d8b-\
0e65a6decd51"],

Cell["\<\
inside of the box. If we use separation of variables again, we can write our \
wavefunction as\
\>", "Text",
 CellChangeTimes->{{3.80935738355387*^9, 3.809357398431204*^9}, {
  3.809357500551804*^9, 
  3.8093575231243176`*^9}},ExpressionUUID->"f676e5b9-3d94-554c-a3d3-\
1d0b788243b6"],

Cell[BoxData[
 RowBox[{
  RowBox[{"\[Psi]", 
   RowBox[{
    StyleBox["(",
     FontSlant->"Italic"], 
    RowBox[{
     StyleBox["x",
      FontSlant->"Italic"], ",", 
     StyleBox["y",
      FontSlant->"Italic"], 
     StyleBox[",",
      FontSlant->"Plain"], 
     StyleBox["z",
      FontSlant->"Italic"]}], 
    StyleBox[")",
     FontSlant->"Italic"]}]}], "=", 
  RowBox[{
   StyleBox["X",
    FontSlant->"Italic"], 
   RowBox[{"(", 
    StyleBox["x",
     FontSlant->"Italic"], 
    StyleBox[")",
     FontSlant->"Italic"]}], 
   StyleBox["Y",
    FontSlant->"Italic"], 
   StyleBox[
    RowBox[{"(", "y", ")"}],
    FontSlant->"Italic"], 
   StyleBox["Z",
    FontSlant->"Italic"], 
   StyleBox[
    RowBox[{"(", "z", ")"}],
    FontSlant->"Italic"]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.809357536690065*^9, 
  3.809357564144396*^9}},ExpressionUUID->"b8457471-7b6f-d144-944b-\
d4755de2024a"],

Cell["\<\
without going through all of the math (which you have already done many times \
at this point), we find that we can write the TISE as\
\>", "Text",
 CellChangeTimes->{{3.8093575721671824`*^9, 
  3.8093575939499607`*^9}},ExpressionUUID->"510549cb-3805-d04e-804a-\
734ff7b43e1c"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"-", 
     FractionBox[
      SuperscriptBox["\[HBar]", "2"], 
      RowBox[{"2", 
       StyleBox["m",
        FontSlant->"Italic"]}]]}], 
    FractionBox["1", 
     RowBox[{
      StyleBox["X",
       FontSlant->"Italic"], 
      RowBox[{"(", 
       StyleBox["x",
        FontSlant->"Italic"], 
       StyleBox[")",
        FontSlant->"Italic"]}]}]], 
    FractionBox[
     RowBox[{
      SuperscriptBox[
       StyleBox["d",
        FontSlant->"Italic"], "2"], 
      StyleBox["X",
       FontSlant->"Italic"], 
      StyleBox[
       RowBox[{"(", "x", ")"}],
       FontSlant->"Italic"]}], 
     SuperscriptBox[
      StyleBox["dx",
       FontSlant->"Italic"], "2"]]}], "-", 
   RowBox[{
    FractionBox[
     SuperscriptBox["\[HBar]", "2"], 
     RowBox[{"2", 
      StyleBox["m",
       FontSlant->"Italic"]}]], 
    FractionBox["1", 
     StyleBox[
      RowBox[{"Y", 
       RowBox[{"(", "y", ")"}]}],
      FontSlant->"Italic"]], 
    FractionBox[
     RowBox[{
      SuperscriptBox[
       StyleBox["d",
        FontSlant->"Italic"], "2"], 
      StyleBox["Y",
       FontSlant->"Italic"], 
      StyleBox[
       RowBox[{"(", "y", ")"}],
       FontSlant->"Italic"]}], 
     SuperscriptBox[
      StyleBox["dy",
       FontSlant->"Italic"], "2"]]}], "-", 
   RowBox[{
    FractionBox[
     SuperscriptBox["\[HBar]", "2"], 
     RowBox[{"2", 
      StyleBox["m",
       FontSlant->"Italic"]}]], 
    FractionBox["1", 
     StyleBox[
      RowBox[{"Z", 
       RowBox[{"(", "Z", ")"}]}],
      FontSlant->"Italic"]], 
    FractionBox[
     RowBox[{
      SuperscriptBox[
       StyleBox["d",
        FontSlant->"Italic"], "2"], 
      StyleBox["Z",
       FontSlant->"Italic"], 
      StyleBox[
       RowBox[{"(", "z", ")"}],
       FontSlant->"Italic"]}], 
     SuperscriptBox[
      StyleBox["dz",
       FontSlant->"Italic"], "2"]]}]}], "=", 
  StyleBox["E",
   FontSlant->"Italic"]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.809357608373613*^9, 3.809357671409667*^9}, {
  3.8093577464626737`*^9, 3.809357748276151*^9}, {3.8093578935412965`*^9, 
  3.8093578994903536`*^9}},ExpressionUUID->"71fa00b7-3bcb-394c-89be-\
4f351fcb178b"],

Cell["We can readily separate this into three equations by using", "Text",
 CellChangeTimes->{{3.8093577656759415`*^9, 
  3.8093577730565023`*^9}},ExpressionUUID->"b3a60232-1e92-454f-89f5-\
45b4598e60d5"],

Cell[BoxData[
 RowBox[{
  StyleBox["E",
   FontSlant->"Italic"], 
  StyleBox["=",
   FontSlant->"Plain"], 
  RowBox[{
   SubscriptBox[
    StyleBox["E",
     FontSlant->"Italic"], 
    StyleBox["x",
     FontSlant->"Italic"]], "+", 
   SubscriptBox[
    StyleBox["E",
     FontSlant->"Italic"], 
    StyleBox["y",
     FontSlant->"Italic"]], "+", 
   SubscriptBox[
    StyleBox["E",
     FontSlant->"Italic"], "z"]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.809357783393046*^9, 
  3.8093578165607305`*^9}},ExpressionUUID->"c3625818-828f-eb4a-8a9e-\
8a3e9ed36689"],

Cell["to get", "Text",
 CellChangeTimes->{{3.8093578357324305`*^9, 
  3.809357840283353*^9}},ExpressionUUID->"3364fef0-f264-034c-8067-\
442f34680a1e"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"-", 
    FractionBox[
     SuperscriptBox["\[HBar]", "2"], 
     RowBox[{"2", 
      StyleBox["m",
       FontSlant->"Italic"]}]]}], 
   FractionBox["1", 
    RowBox[{
     StyleBox["X",
      FontSlant->"Italic"], 
     RowBox[{"(", 
      StyleBox["x",
       FontSlant->"Italic"], 
      StyleBox[")",
       FontSlant->"Italic"]}]}]], 
   FractionBox[
    RowBox[{
     SuperscriptBox[
      StyleBox["d",
       FontSlant->"Italic"], "2"], 
     StyleBox["X",
      FontSlant->"Italic"], 
     StyleBox[
      RowBox[{"(", "x", ")"}],
      FontSlant->"Italic"]}], 
    SuperscriptBox[
     StyleBox["dx",
      FontSlant->"Italic"], "2"]]}], "=", 
  SubscriptBox[
   StyleBox["E",
    FontSlant->"Italic"], 
   StyleBox["x",
    FontSlant->"Italic"]]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.809357857151925*^9, 
  3.809357861321807*^9}},ExpressionUUID->"b493c4ce-35c2-f441-a77f-\
5e4e95bb911a"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"-", 
    FractionBox[
     SuperscriptBox["\[HBar]", "2"], 
     RowBox[{"2", 
      StyleBox["m",
       FontSlant->"Italic"]}]]}], 
   FractionBox["1", 
    StyleBox[
     RowBox[{"Y", 
      RowBox[{"(", "y", ")"}]}],
     FontSlant->"Italic"]], 
   FractionBox[
    RowBox[{
     SuperscriptBox[
      StyleBox["d",
       FontSlant->"Italic"], "2"], 
     StyleBox["Y",
      FontSlant->"Italic"], 
     StyleBox[
      RowBox[{"(", "y", ")"}],
      FontSlant->"Italic"]}], 
    SuperscriptBox[
     StyleBox["dy",
      FontSlant->"Italic"], "2"]]}], "=", 
  SubscriptBox[
   StyleBox["E",
    FontSlant->"Italic"], 
   StyleBox["y",
    FontSlant->"Italic"]]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.809357872010935*^9, 
  3.8093578781070642`*^9}},ExpressionUUID->"98ae0013-5ad5-a84a-98aa-\
80ad716b4794"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"-", 
    FractionBox[
     SuperscriptBox["\[HBar]", "2"], 
     RowBox[{"2", 
      StyleBox["m",
       FontSlant->"Italic"]}]]}], 
   FractionBox["1", 
    StyleBox[
     RowBox[{"Z", 
      RowBox[{"(", "Z", ")"}]}],
     FontSlant->"Italic"]], 
   FractionBox[
    RowBox[{
     SuperscriptBox[
      StyleBox["d",
       FontSlant->"Italic"], "2"], 
     StyleBox["Z",
      FontSlant->"Italic"], 
     StyleBox[
      RowBox[{"(", "z", ")"}],
      FontSlant->"Italic"]}], 
    SuperscriptBox[
     StyleBox["dz",
      FontSlant->"Italic"], "2"]]}], "=", 
  SubscriptBox[
   StyleBox["E",
    FontSlant->"Italic"], 
   StyleBox["z",
    FontSlant->"Italic"]]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.809357912796732*^9, 
  3.809357919949381*^9}},ExpressionUUID->"88ca2d21-5557-7f40-b5fc-\
ef2a7fd5c10d"],

Cell[TextData[{
 "By this point, I\[CloseCurlyQuote]m guessing the math is becoming familiar \
to you. We will end up with solutions to each of these equations that look \
the same as our solutions in one dimension, subject to dimension-specific \
quantum numbers ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["n", "x"], ",", 
    SubscriptBox["n", "y"], ",", " ", 
    RowBox[{"and", " ", 
     SubscriptBox["n", "z"]}]}], TraditionalForm]],ExpressionUUID->
  "e63b82b2-cfbe-824d-b8b1-8f28e5092355"],
 "."
}], "Text",
 CellChangeTimes->{{3.8093579231740956`*^9, 
  3.8093580055628223`*^9}},ExpressionUUID->"81a245b7-8428-8a4a-8507-\
2a1da42ddb81"],

Cell["\<\
A conceptually more important point is made by this example, however. Notice \
that we were able to write our TISE as a sum of parts.\
\>", "Text",
 CellChangeTimes->{{3.8093580388034325`*^9, 3.809358058909522*^9}, {
  3.8093581069667854`*^9, 
  3.8093581076452894`*^9}},ExpressionUUID->"fe0e6846-810d-214f-ac45-\
37dd169a1dc1"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   StyleBox[
    OverscriptBox["H", "^"],
    FontSlant->"Italic"], "\[Psi]", 
   RowBox[{"(", 
    RowBox[{
     StyleBox["x",
      FontSlant->"Italic"], ",", 
     StyleBox["y",
      FontSlant->"Italic"], 
     StyleBox[",",
      FontSlant->"Plain"], 
     StyleBox["z",
      FontSlant->"Italic"]}], 
    StyleBox[")",
     FontSlant->"Italic"]}]}], "=", 
  RowBox[{
   StyleBox["E",
    FontSlant->"Italic"], 
   StyleBox[" ",
    FontSlant->"Italic"], "\[Psi]", 
   RowBox[{"(", 
    RowBox[{
     StyleBox["x",
      FontSlant->"Italic"], ",", 
     StyleBox["y",
      FontSlant->"Italic"], 
     StyleBox[",",
      FontSlant->"Plain"], 
     StyleBox["z",
      FontSlant->"Italic"]}], 
    StyleBox[")",
     FontSlant->"Italic"]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8079664251944246`*^9, 3.8079664343142004`*^9}, {
  3.8079689400739555`*^9, 3.8079689680029573`*^9}, {3.807970315263204*^9, 
  3.8079703215316095`*^9}, {3.807970415909548*^9, 3.807970437015459*^9}, {
  3.8079705221296997`*^9, 3.8079705895237727`*^9}, {3.8079740353167067`*^9, 
  3.807974091342613*^9}, {3.809357372187431*^9, 3.809357372582634*^9}, {
  3.809358075717537*^9, 
  3.809358112473858*^9}},ExpressionUUID->"4b2b0a18-6d59-f44a-a2eb-\
b57fa383274d"],

Cell["was written as", "Text",
 CellChangeTimes->{{3.8093581151929893`*^9, 3.80935811797211*^9}, 
   3.809358222377197*^9},ExpressionUUID->"9d85f545-238b-5e4d-970a-\
3dd25761d404"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    StyleBox["(",
     FontSlant->"Italic"], 
    RowBox[{
     StyleBox[
      OverscriptBox[
       SubscriptBox["H", "x"], "^"],
      FontSlant->"Italic"], "+", 
     StyleBox[
      OverscriptBox[
       SubscriptBox["H", "y"], "^"],
      FontSlant->"Italic"], "+", 
     StyleBox[
      OverscriptBox[
       SubscriptBox["H", "z"], "^"],
      FontSlant->"Italic"]}], 
    StyleBox[")",
     FontSlant->"Italic"]}], "\[Psi]", 
   RowBox[{"(", 
    RowBox[{
     StyleBox["x",
      FontSlant->"Italic"], ",", 
     StyleBox["y",
      FontSlant->"Italic"], 
     StyleBox[",",
      FontSlant->"Plain"], 
     StyleBox["z",
      FontSlant->"Italic"]}], 
    StyleBox[")",
     FontSlant->"Italic"]}]}], "=", 
  RowBox[{
   RowBox[{"(", 
    RowBox[{
     StyleBox[
      SubscriptBox[
       StyleBox["E",
        FontSlant->"Italic"], 
       StyleBox["x",
        FontSlant->"Italic"]],
      FontSlant->"Italic"], 
     StyleBox["+",
      FontSlant->"Plain"], 
     StyleBox[
      SubscriptBox[
       StyleBox["E",
        FontSlant->"Italic"], 
       StyleBox["y",
        FontSlant->"Italic"]],
      FontSlant->"Italic"], "+", 
     StyleBox[
      SubscriptBox[
       StyleBox["E",
        FontSlant->"Italic"], "z"],
      FontSlant->"Italic"]}], 
    StyleBox[")",
     FontSlant->"Italic"]}], 
   StyleBox[" ",
    FontSlant->"Italic"], "\[Psi]", 
   RowBox[{"(", 
    RowBox[{
     StyleBox["x",
      FontSlant->"Italic"], ",", 
     StyleBox["y",
      FontSlant->"Italic"], 
     StyleBox[",",
      FontSlant->"Plain"], 
     StyleBox["z",
      FontSlant->"Italic"]}], 
    StyleBox[")",
     FontSlant->"Italic"]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8079664251944246`*^9, 3.8079664343142004`*^9}, {
  3.8079689400739555`*^9, 3.8079689680029573`*^9}, {3.807970315263204*^9, 
  3.8079703215316095`*^9}, {3.807970415909548*^9, 3.807970437015459*^9}, {
  3.8079705221296997`*^9, 3.8079705895237727`*^9}, {3.8079740353167067`*^9, 
