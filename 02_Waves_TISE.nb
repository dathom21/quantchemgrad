 RowBox[{
  RowBox[{
   FractionBox[
    RowBox[{
     RowBox[{
      SuperscriptBox["\[DifferentialD]", "2"], 
      StyleBox["T",
       FontSlant->"Italic"]}], 
     StyleBox[
      RowBox[{"(", "t", ")"}],
      FontSlant->"Italic"]}], 
    RowBox[{"\[DifferentialD]", 
     SuperscriptBox[
      StyleBox["t",
       FontSlant->"Italic"], "2"]}]], "+", 
   RowBox[{
    SubsuperscriptBox["\[Omega]", 
     StyleBox["n",
      FontSlant->"Italic"], "2"], 
    StyleBox["T",
     FontSlant->"Italic"], 
    StyleBox[
     RowBox[{"(", "t", ")"}],
     FontSlant->"Italic"]}]}], 
  StyleBox["=",
   FontSlant->"Plain"], 
  StyleBox["0",
   FontSlant->"Plain"]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.807891093868901*^9, 3.807891147079709*^9}, {
   3.807966267385824*^9, 3.8079662702871714`*^9}, 3.914860484333766*^9, {
   3.9155493136952734`*^9, 
   3.9155493141642838`*^9}},ExpressionUUID->"a0acbe41-e858-48d4-952a-\
6ab3fe2fe1c4"],

Cell[TextData[{
 "Given that equation (12) and equation (30) have the same form, we can solve \
for ",
 StyleBox["T ",
  FontSlant->"Italic"],
 "(",
 StyleBox["t ",
  FontSlant->"Italic"],
 ") the same way we solved for ",
 StyleBox["X ",
  FontSlant->"Italic"],
 "(",
 StyleBox["x",
  FontSlant->"Italic"],
 " ), which gives us"
}], "Text",
 CellChangeTimes->{{3.807891187885374*^9, 3.807891195167428*^9}, {
  3.807891298691382*^9, 3.8078913919196043`*^9}, {3.8078917926656632`*^9, 
  3.8078917964477654`*^9}, {3.914666406303943*^9, 
  3.914666408422075*^9}},ExpressionUUID->"63cf6347-733b-4848-b94e-\
8e53f1a77b0d"],

Cell[BoxData[
 RowBox[{
  StyleBox[
   RowBox[{"T", 
    RowBox[{"(", "t", ")"}]}],
   FontSlant->"Italic"], 
  StyleBox["=",
   FontSlant->"Plain"], 
  RowBox[{
   RowBox[{
    SubsuperscriptBox[
     StyleBox["c",
      FontSlant->"Italic"], "3", "'"], "cos", 
    RowBox[{"(", 
     RowBox[{
      SubscriptBox["\[Omega]", 
       StyleBox["n",
        FontSlant->"Italic"]], 
      StyleBox["t",
       FontSlant->"Italic"]}], ")"}]}], "+", 
   RowBox[{
    SubsuperscriptBox[
     StyleBox["c",
      FontSlant->"Italic"], "4", "'"], "sin", 
    RowBox[{"(", 
     RowBox[{
      SubscriptBox["\[Omega]", 
       StyleBox["n",
        FontSlant->"Italic"]], 
      StyleBox["t",
       FontSlant->"Italic"]}], ")"}]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8078914130996294`*^9, 
  3.807891449640133*^9}},ExpressionUUID->"b97c8f80-78fa-40ca-be57-\
f833b03abfe7"],

Cell[TextData[{
 "However, we don\[CloseCurlyQuote]t have any boundary conditions that will \
further constrain ",
 Cell[BoxData[
  SubsuperscriptBox[
   StyleBox["c",
    FontSlant->"Italic"], "3", "'"]],
  CellChangeTimes->{{3.8078914130996294`*^9, 3.807891449640133*^9}},
  ExpressionUUID->"b347f7d3-454a-422b-8f36-289c26f86668"],
 "and ",
 Cell[BoxData[
  SubsuperscriptBox[
   StyleBox["c",
    FontSlant->"Italic"], "4", "'"]],
  CellChangeTimes->{{3.8078914130996294`*^9, 3.807891449640133*^9}},
  ExpressionUUID->"d6737fb2-7331-4bd6-bf7a-15ba8504cf63"],
 "."
}], "Text",
 CellChangeTimes->{{3.8078914590564575`*^9, 3.8078914905183363`*^9}, 
   3.9146664253039837`*^9},ExpressionUUID->"d983ffb3-9c72-46b3-8ec2-\
bda4ce81bbdb"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Putting it All Together", "Subsection",
 CellChangeTimes->{{3.8078918120492373`*^9, 
  3.807891815174144*^9}},ExpressionUUID->"39cfced3-085a-45d6-a27b-\
cd3ea9787c97"],

Cell["\<\
If we combine our time and spatial dependence, we obtain the solution for the \
vibrating string\
\>", "Text",
 CellChangeTimes->{{3.8078918308459167`*^9, 3.8078918534755154`*^9}, {
  3.807892890608861*^9, 
  3.807892891777752*^9}},ExpressionUUID->"ef56c383-6234-4033-a27b-\
f508c53f6790"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   StyleBox["u",
    FontSlant->"Italic"], 
   RowBox[{"(", 
    RowBox[{
     StyleBox["x",
      FontSlant->"Italic"], ",", 
     StyleBox["t",
      FontSlant->"Italic"]}], ")"}]}], "=", 
  RowBox[{
   StyleBox[
    RowBox[{"X", 
     RowBox[{"(", "x", ")"}], "T", 
     RowBox[{"(", "t", ")"}]}],
    FontSlant->"Italic"], 
   StyleBox["=",
    FontSlant->"Plain"], 
   RowBox[{
    SubsuperscriptBox[
     StyleBox["c",
      FontSlant->"Italic"], "2", "'"], "sin", 
    RowBox[{
     RowBox[{"(", 
      StyleBox[
       FractionBox[
        StyleBox[
         RowBox[{
          StyleBox["n",
           FontSlant->"Italic"], "\[Pi]", 
          StyleBox["x",
           FontSlant->"Italic"]}]], 
        StyleBox["L",
         FontSlant->"Italic"]],
       FontSlant->"Italic"], ")"}], 
     StyleBox["[",
      FontSlant->"Plain"], 
     RowBox[{
      RowBox[{
       SubsuperscriptBox[
        StyleBox["c",
         FontSlant->"Italic"], "3", "'"], "cos", 
       RowBox[{"(", 
        RowBox[{
         SubscriptBox["\[Omega]", 
          StyleBox["n",
           FontSlant->"Italic"]], 
         StyleBox["t",
          FontSlant->"Italic"]}], ")"}]}], "+", 
      RowBox[{
       SubsuperscriptBox[
        StyleBox["c",
         FontSlant->"Italic"], "4", "'"], "sin", 
       RowBox[{"(", 
        RowBox[{
         SubscriptBox["\[Omega]", 
          StyleBox["n",
           FontSlant->"Italic"]], 
         StyleBox["t",
          FontSlant->"Italic"]}], ")"}]}]}], 
     "]"}]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8078918769672112`*^9, 
  3.807891914916436*^9}},ExpressionUUID->"b77c4bb0-ea18-4c81-b1b1-\
1ffdea4b1b9d"],

Cell[TextData[{
 "This is usually written in a more succinct form by utilizing a few more \
mathematical tricks. First, we distribute ",
 Cell[BoxData[
  SubsuperscriptBox[
   StyleBox["c",
    FontSlant->"Italic"], "2", "'"]],
  CellChangeTimes->{{3.8078918769672112`*^9, 3.807891914916436*^9}},
  ExpressionUUID->"d8ed1e77-ec98-49e3-b53c-c527056a3dd1"],
 "and say ",
 Cell[BoxData[
  SubsuperscriptBox[
   StyleBox["c",
    FontSlant->"Italic"], "2", "'"]],
  CellChangeTimes->{{3.8078918769672112`*^9, 3.807891914916436*^9}},
  ExpressionUUID->"c820eda3-b943-4af8-966e-99d53e2c1055"],
 Cell[BoxData[
  SubsuperscriptBox[
   StyleBox["c",
    FontSlant->"Italic"], "3", "'"]],
  CellChangeTimes->{{3.8078918769672112`*^9, 3.807891914916436*^9}},
  ExpressionUUID->"03418488-5858-4ff2-967e-297ef725eb45"],
 "= ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["C", "n"], TraditionalForm]],ExpressionUUID->
  "b5fd068a-5b75-4af1-a98b-3b35c4fc0497"],
 " and ",
 Cell[BoxData[
  SubsuperscriptBox[
   StyleBox["c",
    FontSlant->"Italic"], "2", "'"]],
  CellChangeTimes->{{3.8078918769672112`*^9, 3.807891914916436*^9}},
  ExpressionUUID->"922c5f2b-4f88-4cdc-8657-390bafd90c05"],
 Cell[BoxData[
  SubsuperscriptBox[
   StyleBox["c",
    FontSlant->"Italic"], "4", "'"]],
  CellChangeTimes->{{3.8078918769672112`*^9, 3.807891914916436*^9}},
  ExpressionUUID->"caf3f92e-c347-42ad-82c9-95e267ff4ceb"],
 "= ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["D", "n"], TraditionalForm]],ExpressionUUID->
  "f2190b86-bd06-4f78-b423-6b84d895d820"],
 " to give us"
}], "Text",
 CellChangeTimes->{{3.807892011676668*^9, 3.8078920337778034`*^9}, {
  3.807892126014572*^9, 3.8078921500784426`*^9}, {3.807892185050474*^9, 
  3.807892259477398*^9}},ExpressionUUID->"190c3373-ca4d-4015-bc5c-\
ceedab2c7857"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   StyleBox["u",
    FontSlant->"Italic"], 
   RowBox[{"(", 
    RowBox[{
     StyleBox["x",
      FontSlant->"Italic"], ",", 
     StyleBox["t",
      FontSlant->"Italic"]}], ")"}]}], 
  StyleBox["=",
   FontSlant->"Plain"], 
  RowBox[{
   RowBox[{
    StyleBox["[",
     FontSlant->"Plain"], 
    RowBox[{
     RowBox[{
      SubscriptBox[
       StyleBox["C",
        FontSlant->"Italic"], 
       StyleBox["n",
        FontSlant->"Italic"]], "cos", 
      RowBox[{"(", 
       RowBox[{
        SubscriptBox["\[Omega]", 
         StyleBox["n",
          FontSlant->"Italic"]], 
        StyleBox["t",
         FontSlant->"Italic"]}], ")"}]}], "+", 
     RowBox[{
      SubscriptBox[
       StyleBox["D",
        FontSlant->"Italic"], 
       StyleBox["n",
        FontSlant->"Italic"]], "sin", 
      RowBox[{"(", 
       RowBox[{
        SubscriptBox["\[Omega]", 
         StyleBox["n",
          FontSlant->"Italic"]], 
        StyleBox["t",
         FontSlant->"Italic"]}], ")"}]}]}], "]"}], "sin", 
   RowBox[{"(", 
    StyleBox[
     FractionBox[
      StyleBox[
       RowBox[{
        StyleBox["n",
         FontSlant->"Italic"], "\[Pi]", 
        StyleBox["x",
         FontSlant->"Italic"]}]], 
      StyleBox["L",
       FontSlant->"Italic"]],
     FontSlant->"Italic"], ")"}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8078922685557528`*^9, 
  3.807892313374118*^9}},ExpressionUUID->"cce8ab86-bba6-4449-ad4c-\
918122d11003"],

Cell[TextData[{
 "Next, we further define ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["C",
    FontSlant->"Italic"], 
   StyleBox["n",
    FontSlant->"Italic"]]],
  CellChangeTimes->{{3.8078922685557528`*^9, 3.807892313374118*^9}},
  ExpressionUUID->"a082e839-d878-4006-beeb-73f205a343af"],
 " = ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["A",
    FontSlant->"Italic"], 
   StyleBox["n",
    FontSlant->"Italic"]]],
  CellChangeTimes->{{3.8078922685557528`*^9, 3.807892313374118*^9}},
  ExpressionUUID->"1b2a7fd1-0261-49be-901a-e7a3b5931684"],
 " ",
 Cell[BoxData[
  FormBox[
   RowBox[{"cos", "(", 
    SubscriptBox["\[Phi]", "n"]}], TraditionalForm]],ExpressionUUID->
  "9cfb6e0a-92e8-4c26-a861-42d7b9b41ab1"],
 ") and ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["D",
    FontSlant->"Italic"], 
   StyleBox["n",
    FontSlant->"Italic"]]],
  CellChangeTimes->{{3.8078922685557528`*^9, 3.807892313374118*^9}},
  ExpressionUUID->"ebb917df-00e7-421c-90e7-594ab81c70f0"],
 " = \[Minus]",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["A",
    FontSlant->"Italic"], 
   StyleBox["n",
    FontSlant->"Italic"]]],
  CellChangeTimes->{{3.8078922685557528`*^9, 3.807892313374118*^9}},
  ExpressionUUID->"8103d449-2da2-4f9e-a716-3358b4696082"],
 " ",
 Cell[BoxData[
  FormBox[
   RowBox[{"sin", "(", 
    SubscriptBox["\[Phi]", "n"]}], TraditionalForm]],ExpressionUUID->
  "b3f4c664-94fd-4971-8b48-5d8c5e9706ae"],
 ") to give "
}], "Text",
 CellChangeTimes->{{3.8078923318937054`*^9, 3.80789233500152*^9}, {
  3.807892408003213*^9, 
  3.8078925628645205`*^9}},ExpressionUUID->"982cfd55-af61-4ae8-acbb-\
0ab830a6140f"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
         SubscriptBox[
          StyleBox["C",
           FontSlant->"Italic"], 
          StyleBox["n",
           FontSlant->"Italic"]], "cos", 
         RowBox[{"(", 
          RowBox[{
           SubscriptBox["\[Omega]", 
            StyleBox["n",
             FontSlant->"Italic"]], 
           StyleBox["t",
            FontSlant->"Italic"]}], ")"}]}], "+", 
        RowBox[{
         SubscriptBox[
          StyleBox["D",
           FontSlant->"Italic"], 
          StyleBox["n",
           FontSlant->"Italic"]], "sin", 
         RowBox[{"(", 
          RowBox[{
           SubscriptBox["\[Omega]", 
            StyleBox["n",
             FontSlant->"Italic"]], 
           StyleBox["t",
            FontSlant->"Italic"]}], ")"}]}]}], "=", 
       RowBox[{
        SubscriptBox[
         StyleBox["A",
          FontSlant->"Italic"], 
         StyleBox["n",
          FontSlant->"Italic"]], " ", 
        FormBox[
         RowBox[{"cos", "(", 
          SubscriptBox["\[Phi]", "n"]}],
         TraditionalForm]}]}], ")"}], "cos", 
     RowBox[{"(", 
      RowBox[{
       SubscriptBox["\[Omega]", 
        StyleBox["n",
         FontSlant->"Italic"]], 
       StyleBox["t",
        FontSlant->"Italic"]}], ")"}]}], "\[Minus]", 
    RowBox[{
     SubscriptBox[
      StyleBox["A",
       FontSlant->"Italic"], 
      StyleBox["n",
       FontSlant->"Italic"]], " ", 
     FormBox[
      RowBox[{"sin", "(", 
       SubscriptBox["\[Phi]", "n"]}],
      TraditionalForm]}]}], ")"}], "sin", 
  RowBox[{"(", 
   RowBox[{
    SubscriptBox["\[Omega]", 
     StyleBox["n",
      FontSlant->"Italic"]], 
    StyleBox["t",
     FontSlant->"Italic"]}], ")"}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8078925680403695`*^9, 
  3.8078926198106723`*^9}},ExpressionUUID->"7e074137-113c-4fe3-a490-\
c736c28a4158"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Phi]", "n"], TraditionalForm]],ExpressionUUID->
  "9a0c4928-ff6e-46e6-9ee3-dea651807eb8"],
 " will end up being a ",
 StyleBox["phase shift",
  FontSlant->"Italic"],
 " that shifts the wave start point in time. ",
 "Ok, now we can employ another trick, the cosine sum trigonometric identity,"
}], "Text",
 CellChangeTimes->{{3.8078926458726654`*^9, 3.8078926667818537`*^9}, {
  3.914666499132855*^9, 
  3.914666553528203*^9}},ExpressionUUID->"6e1d09a5-04f8-4ee3-b1af-\
6fae940cda6c"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"cos", 
        RowBox[{"(", 
         RowBox[{
          StyleBox["a",
           FontSlant->"Italic"], "+", 
          StyleBox["b",
           FontSlant->"Italic"]}], ")"}]}], "=", 
       FormBox[
        RowBox[{"cos", "(", "a"}],
        TraditionalForm]}], ")"}], "cos", 
     RowBox[{"(", "b", ")"}]}], "\[Minus]", " ", 
    FormBox[
     RowBox[{"sin", "(", "a"}],
     TraditionalForm]}], ")"}], "sin", 
  RowBox[{"(", 
   StyleBox["b",
    FontSlant->"Italic"], ")"}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.807892683431179*^9, 
  3.8078927289461265`*^9}},ExpressionUUID->"b8283d73-e595-441a-aa42-\
d79051fba455"],

Cell["to transform equation (34) into", "Text",
 CellChangeTimes->{{3.8078927402881145`*^9, 3.807892745164486*^9}, {
  3.914666527856258*^9, 
  3.914666529123394*^9}},ExpressionUUID->"ab2373bb-33f1-4b8c-a3f0-\
4a1d62311736"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
         SubscriptBox[
          StyleBox["A",
           FontSlant->"Italic"], 
          StyleBox["n",
           FontSlant->"Italic"]], " ", 
         FormBox[
          RowBox[{"cos", "(", 
           SubscriptBox["\[Phi]", "n"]}],
          TraditionalForm]}], ")"}], "cos", 
       RowBox[{"(", 
        RowBox[{
         SubscriptBox["\[Omega]", 
          StyleBox["n",
           FontSlant->"Italic"]], 
         StyleBox["t",
          FontSlant->"Italic"]}], ")"}]}], "\[Minus]", 
      RowBox[{
       SubscriptBox[
        StyleBox["A",
         FontSlant->"Italic"], 
        StyleBox["n",
         FontSlant->"Italic"]], " ", 
       FormBox[
        RowBox[{"sin", "(", 
         SubscriptBox["\[Phi]", "n"]}],
        TraditionalForm]}]}], ")"}], "sin", 
    RowBox[{"(", 
     RowBox[{
      SubscriptBox["\[Omega]", 
       StyleBox["n",
        FontSlant->"Italic"]], 
      StyleBox["t",
       FontSlant->"Italic"]}], ")"}]}], "=", 
   RowBox[{
    SubscriptBox[
     StyleBox["A",
      FontSlant->"Italic"], 
     StyleBox["n",
      FontSlant->"Italic"]], 
    FormBox[
     RowBox[{"cos", "(", 
      RowBox[{
       RowBox[{
        SubscriptBox["\[Omega]", 
         StyleBox["n",
          FontSlant->"Italic"]], 
        StyleBox["t",
         FontSlant->"Italic"]}], "+", 
       SubscriptBox["\[Phi]", "n"]}]}],
     TraditionalForm]}]}], ")"}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.807892762789991*^9, 
  3.807892796199061*^9}},ExpressionUUID->"71146511-d1aa-4a01-b352-\
30c56610afb0"],

Cell["Finally, we can now write our  solutions as", "Text",
 CellChangeTimes->{{3.807892806567815*^9, 3.807892848864623*^9}, 
   3.8078929084180098`*^9},ExpressionUUID->"e2322bd5-c6e7-4fe3-9d5d-\
0501d29b1f15"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{
     SubscriptBox[
      StyleBox["u",
       FontSlant->"Italic"], 
      StyleBox["n",
       FontSlant->"Italic"]], 
     RowBox[{"(", 
      RowBox[{
       StyleBox["x",
        FontSlant->"Italic"], ",", 
       StyleBox["t",
        FontSlant->"Italic"]}], ")"}]}], "=", 
    RowBox[{
     SubscriptBox[
      StyleBox["A",
       FontSlant->"Italic"], 
      StyleBox["n",
       FontSlant->"Italic"]], 
     FormBox[
      RowBox[{"cos", "(", 
       RowBox[{
        RowBox[{
         SubscriptBox["\[Omega]", 
          StyleBox["n",
           FontSlant->"Italic"]], 
         StyleBox["t",
          FontSlant->"Italic"]}], "+", 
        SubscriptBox["\[Phi]", "n"]}]}],
      TraditionalForm]}]}], ")"}], "sin", 
  RowBox[{"(", 
   StyleBox[
    FractionBox[
     StyleBox[
      RowBox[{
       StyleBox["n",
        FontSlant->"Italic"], "\[Pi]", 
       StyleBox["x",
        FontSlant->"Italic"]}]], 
     StyleBox["L",
      FontSlant->"Italic"]],
    FontSlant->"Italic"], ")"}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.807892830790923*^9, 3.8078928322380443`*^9}, {
  3.8078929269492884`*^9, 3.8078929444713492`*^9}, {3.807893239099507*^9, 
  3.8078932393973813`*^9}},ExpressionUUID->"ba04a80c-2e5d-438f-8d59-\
66b7a437730f"],

Cell[TextData[{
 "We\[CloseCurlyQuote]ve gone through the work to write our equation this way \
for a reason. It helps provide a physical meaning to each component of the \
solution. ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["A",
    FontSlant->"Italic"], 
   StyleBox["n",
    FontSlant->"Italic"]]],
  CellChangeTimes->{{3.807892830790923*^9, 3.8078928322380443`*^9}, {
   3.8078929269492884`*^9, 3.8078929444713492`*^9}},ExpressionUUID->
  "9854a87f-119b-4aab-b3c7-c89688d470c6"],
 " is the amplitude of the wave, ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Omega]", 
    StyleBox["n",
     FontSlant->"Italic"]], TraditionalForm]],
  CellChangeTimes->{{3.807892830790923*^9, 3.8078928322380443`*^9}, {
   3.8078929269492884`*^9, 3.8078929444713492`*^9}},ExpressionUUID->
  "415d92cc-b7bb-4fa9-94f0-805f9e76759c"],
 StyleBox[" ",
  FontSlant->"Italic"],
 "is the angular frequency of the wave, and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Phi]", "n"], TraditionalForm]],
  CellChangeTimes->{{3.807892830790923*^9, 3.8078928322380443`*^9}, {
   3.8078929269492884`*^9, 3.8078929444713492`*^9}},ExpressionUUID->
  "ec86fbf5-40d5-42c7-ad08-c247b9397474"],
 StyleBox[" ",
  FontSlant->"Italic"],
 "is the phase shift (meaning a moving of the \[OpenCurlyDoubleQuote]starting\
\[CloseCurlyDoubleQuote] time of the wave oscillation). Now, each integer \
value of ",
 StyleBox["n",
  FontSlant->"Italic"],
 " gives a specific solution, which are known as the ",
 StyleBox["normal modes",
  FontSlant->"Italic"],
 ".  The case of ",
 StyleBox["n",
  FontSlant->"Italic"],
 " = 1 is known as the ",
 StyleBox["harmonic",
  FontSlant->"Italic"],
 " or ",
 StyleBox["fundamental",
  FontSlant->"Italic"],
 ", and the cases of ",
 StyleBox["n ",
  FontSlant->"Italic"],
 "> 1 are known as ",
 StyleBox["overtones",
  FontSlant->"Italic"],
 ". When you pluck a string on a musical instrument, these are the \
frequencies of oscillations that give you the musical note.\n\nHowever, as \
you will see in the next section, the values of ",
 StyleBox["n",
  FontSlant->"Italic"],
 " don\[CloseCurlyQuote]t cover all of the possible solutions."
}], "Text",
 CellChangeTimes->{{3.807892947469327*^9, 3.8078931542781415`*^9}, {
  3.807893247336772*^9, 3.807893273831455*^9}, {3.807893557319259*^9, 
  3.807893652168104*^9}, {3.8087393049880433`*^9, 
  3.80873930633206*^9}},ExpressionUUID->"e2077d76-5547-493e-92e1-\
5a6837e982a0"]
}, Open  ]],

Cell[CellGroupData[{

Cell["The General Solution and the Principle of Superposition", "Subsection",
 CellChangeTimes->{{3.8078936717688537`*^9, 
  3.8078936817151036`*^9}},ExpressionUUID->"9def84d2-9018-45b7-ad29-\
62a397076cde"],

Cell[TextData[{
 "We said at the beginning of this lesson that the wave equation was a ",
 StyleBox["linear",
  FontSlant->"Italic"],
 " partial differential equation (PDE). Simply put, a linear PDE is one in \
which the solution is not raised to a power. In our case, that means that \
only ",
 StyleBox["u ",
  FontSlant->"Italic"],
 "(",
 StyleBox["x",
  FontSlant->"Italic"],
 ",",
 StyleBox["t ",
  FontSlant->"Italic"],
 ") appears in the wave equation (1), not for example ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["u", "2"], TraditionalForm]],ExpressionUUID->
  "18fde98f-094b-4769-a21a-090c7d818ca5"],
 StyleBox[" ",
  FontSlant->"Italic"],
 "(",
 StyleBox["x",
  FontSlant->"Italic"],
 ",",
 StyleBox["t ",
  FontSlant->"Italic"],
 Cell[BoxData[
  FormBox[")", TraditionalForm]],ExpressionUUID->
  "23d978e2-91ba-4467-9e91-ac1f5a0a3066"],
 " or ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["u", "3"], TraditionalForm]],ExpressionUUID->
  "bd181bf5-f1ac-4581-91e7-b319decaf62f"],
 StyleBox[" ",
  FontSlant->"Italic"],
 "(",
 StyleBox["x",
  FontSlant->"Italic"],
 ",",
 StyleBox["t ",
  FontSlant->"Italic"],
 Cell[BoxData[
  FormBox[")", TraditionalForm]],ExpressionUUID->
  "c44c98e1-7d5b-43bc-b78a-c46804ee949a"],
 ". Linear PDEs have an important property: ",
 StyleBox["for any two solutions of the equation, the sum of the solutions is \
also a solution",
  FontWeight->"Bold"],
 ".",
 StyleBox[" ",
  FontWeight->"Bold"],
 "For our vibrating string example, then, the ",
 StyleBox["general",
  FontSlant->"Italic"],
 " solution is actually"
}], "Text",
 CellChangeTimes->{{3.807893690321861*^9, 3.8078937320604687`*^9}, {
  3.807893811904297*^9, 3.8078939207562866`*^9}, {3.807893951319068*^9, 
  3.807894149689635*^9}, {3.9146665847190876`*^9, 
