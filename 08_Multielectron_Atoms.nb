        StyleBox["H",
         FontSlant->"Italic"], 
        StyleBox["NN",
         FontSlant->"Italic"]]}
     }], "\[NoBreak]", ")"}], 
   RowBox[{"(", "\[NoBreak]", GridBox[{
      {
       SubscriptBox[
        StyleBox["a",
         FontSlant->"Italic"], "1"]},
      {
       SubscriptBox[
        StyleBox["a",
         FontSlant->"Italic"], "2"]},
      {GridBox[{
         {"..."},
         {
          SubscriptBox[
           StyleBox["a",
            FontSlant->"Italic"], 
           StyleBox["N",
            FontSlant->"Italic"]]}
        }]}
     }], "\[NoBreak]", ")"}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8118618430168495`*^9, 
  3.8118620957461214`*^9}},ExpressionUUID->"1678ee24-c05f-bd48-b979-\
03f14f384ad6"],

Cell[TextData[{
 "where there are ",
 StyleBox["N",
  FontSlant->"Italic"],
 " basis functions."
}], "Text",
 CellChangeTimes->{{3.8118620588108263`*^9, 
  3.811862063274436*^9}},ExpressionUUID->"f168e555-e4cd-3945-83ef-\
c334d63cc5a8"],

Cell[CellGroupData[{

Cell["\<\
Finding the Energies and Wavefunctions of the Linear Variational Method\
\>", "Subsubsection",
 CellChangeTimes->{{3.8118665545337086`*^9, 
  3.8118665737248154`*^9}},ExpressionUUID->"61e7060b-4fad-9140-8cda-\
f838a59016c5"],

Cell[TextData[{
 "We can now minimize our trial energy ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["E",
    FontSlant->"Italic"], "\[CapitalPhi]"]],
  CellChangeTimes->{{3.811593312893673*^9, 3.8115933831661987`*^9}, {
   3.811593458953679*^9, 3.8115934974178753`*^9}, {3.8115936143121653`*^9, 
   3.811593715195953*^9}, {3.811594208013258*^9, 3.811594210677987*^9}, {
   3.811594342816991*^9, 3.8115943434093456`*^9}, {3.811594623901507*^9, 
   3.811594670874273*^9}, {3.8115948564704037`*^9, 3.8115948589878416`*^9}, {
   3.8115949257053156`*^9, 3.811594926820971*^9}, {3.8118594909971013`*^9, 
   3.8118595100044374`*^9}, {3.811861225074663*^9, 3.8118612380287175`*^9}, {
   3.811861337070103*^9, 3.811861354268696*^9}},ExpressionUUID->
  "59a0e8c9-5f4f-0f4d-bb26-016f43edf683"],
 " by varying the weighting coefficients of our basis functions ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["a",
    FontSlant->"Italic"], 
   StyleBox["n",
    FontSlant->"Italic"]]],
  CellChangeTimes->{{3.811593312893673*^9, 3.8115933831661987`*^9}, {
   3.811593458953679*^9, 3.8115934974178753`*^9}, {3.8115936143121653`*^9, 
   3.811593715195953*^9}, {3.811594208013258*^9, 3.811594210677987*^9}, {
   3.811594342816991*^9, 3.8115943434093456`*^9}, {3.811594623901507*^9, 
   3.811594670874273*^9}, {3.8115948564704037`*^9, 3.8115948589878416`*^9}, {
   3.8115949257053156`*^9, 3.811594926820971*^9}, {3.8118594909971013`*^9, 
   3.8118595100044374`*^9}, {3.811861225074663*^9, 3.8118612380287175`*^9}, {
   3.811861337070103*^9, 3.811861354268696*^9}},ExpressionUUID->
  "4b6e668e-0a40-b748-aee7-31634fa26732"],
 ". Specifically, we want to find the minimum value of ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["E",
    FontSlant->"Italic"], "\[CapitalPhi]"]],
  CellChangeTimes->{{3.811593312893673*^9, 3.8115933831661987`*^9}, {
   3.811593458953679*^9, 3.8115934974178753`*^9}, {3.8115936143121653`*^9, 
   3.811593715195953*^9}, {3.811594208013258*^9, 3.811594210677987*^9}, {
   3.811594342816991*^9, 3.8115943434093456`*^9}, {3.811594623901507*^9, 
   3.811594670874273*^9}, {3.8115948564704037`*^9, 3.8115948589878416`*^9}, {
   3.8115949257053156`*^9, 3.811594926820971*^9}, {3.8118594909971013`*^9, 
   3.8118595100044374`*^9}, {3.811861225074663*^9, 3.8118612380287175`*^9}, {
   3.811861337070103*^9, 3.811861354268696*^9}},ExpressionUUID->
  "807fba3b-e9cf-3740-9487-de275695be56"],
 " for each coefficient ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["a",
    FontSlant->"Italic"], 
   StyleBox["k",
    FontSlant->"Italic"]]],
  CellChangeTimes->{{3.811593312893673*^9, 3.8115933831661987`*^9}, {
   3.811593458953679*^9, 3.8115934974178753`*^9}, {3.8115936143121653`*^9, 
   3.811593715195953*^9}, {3.811594208013258*^9, 3.811594210677987*^9}, {
   3.811594342816991*^9, 3.8115943434093456`*^9}, {3.811594623901507*^9, 
   3.811594670874273*^9}, {3.8115948564704037`*^9, 3.8115948589878416`*^9}, {
   3.8115949257053156`*^9, 3.811594926820971*^9}, {3.8118594909971013`*^9, 
   3.8118595100044374`*^9}, {3.811861225074663*^9, 3.8118612380287175`*^9}, {
   3.811861337070103*^9, 3.811861354268696*^9}},ExpressionUUID->
  "ce8cc7b3-7c52-7342-905f-033b66623d33"],
 ". Since minima occur where the first derivative is equal to zero, we can \
express this condition mathematically by"
}], "Text",
 CellChangeTimes->{{3.8118614060133204`*^9, 3.8118614100572805`*^9}, {
  3.8118614991158857`*^9, 3.811861581361933*^9}, {3.811862119918707*^9, 
  3.8118621304452534`*^9}, {3.811862345143149*^9, 3.8118624198256245`*^9}, {
