Cell[TextData[{
 "where ",
 StyleBox["R",
  FontWeight->"Bold",
  FontSlant->"Italic"],
 " represents the position of the nucleus, ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["r", "1"], TraditionalForm]],ExpressionUUID->
  "fe9a40fb-e028-4d5f-80e9-9f636e362667"],
 " represents the position of electron 1, and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["r", "2"], TraditionalForm]],ExpressionUUID->
  "4bb9c61c-a347-414c-a348-87188551d121"],
 " represents the position of electron 2. In equation (133), we have three \
Laplacian operators: one with respect to the nucleus (",
 Cell[BoxData[
  SuperscriptBox["\[Del]", "2"]],
  CellChangeTimes->{{3.810112811439228*^9, 3.8101128248442793`*^9}, {
   3.810479494926491*^9, 3.8104795038498344`*^9}, {3.810479572543576*^9, 
   3.8104796147383184`*^9}, {3.8104802055659895`*^9, 
   3.8104802433915305`*^9}, {3.8104802785189395`*^9, 
   3.8104802814214115`*^9}, {3.8109915300785556`*^9, 
   3.8109916793993816`*^9}, {3.810991710031681*^9, 3.8109918292023373`*^9}},
  ExpressionUUID->"1979b958-9fd9-4b0e-9348-6c1b1cbc199e"],
 "), one with respect to electron 1 (",
 Cell[BoxData[
  SubsuperscriptBox["\[Del]", "1", "2"]],
  CellChangeTimes->{{3.810112811439228*^9, 3.8101128248442793`*^9}, {
   3.810479494926491*^9, 3.8104795038498344`*^9}, {3.810479572543576*^9, 
   3.8104796147383184`*^9}, {3.8104802055659895`*^9, 
   3.8104802433915305`*^9}, {3.8104802785189395`*^9, 
   3.8104802814214115`*^9}, {3.8109915300785556`*^9, 
   3.8109916793993816`*^9}, {3.810991710031681*^9, 3.8109918292023373`*^9}, {
   3.810994488524798*^9, 3.810994499853472*^9}},ExpressionUUID->
  "6a71252e-d9d0-4d7c-8c91-3d91aba551d9"],
 "), and one with respect to electron 2 (",
 Cell[BoxData[
  SubsuperscriptBox["\[Del]", "2", "2"]],
  CellChangeTimes->{{3.810112811439228*^9, 3.8101128248442793`*^9}, {
   3.810479494926491*^9, 3.8104795038498344`*^9}, {3.810479572543576*^9, 
   3.8104796147383184`*^9}, {3.8104802055659895`*^9, 
   3.8104802433915305`*^9}, {3.8104802785189395`*^9, 
   3.8104802814214115`*^9}, {3.8109915300785556`*^9, 
   3.8109916793993816`*^9}, {3.810991710031681*^9, 3.8109918292023373`*^9}, {
   3.810994488524798*^9, 3.810994499853472*^9}},ExpressionUUID->
  "fcd606a3-09f4-4df2-90a0-8f29be6c5fa7"],
 "). The potential term likewise consists of three terms, with the first two \
giving the attraction between the nucleus and each electron (note that the \
factor of 2 in the numerator comes from the fact that there are two protons \
in the nucleus) and the final term giving the repulsion between the two \
electrons. "
}], "Text",
 CellChangeTimes->{{3.810994384611277*^9, 3.810994656740177*^9}, {
  3.8109967824416504`*^9, 
  3.8109967825478735`*^9}},ExpressionUUID->"af3c2bf9-75bc-4932-9de1-\
e7f736e45995"],

Cell[TextData[{
 "Note that we no longer have a two-particle system that we can easily \
represent with a simple reduced mass. However, because  ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    StyleBox["M",
     FontSlant->"Italic"], ">>", 
    SubscriptBox["m", "e"]}], TraditionalForm]],ExpressionUUID->
  "e982a83b-a82f-48d9-9285-cde8ff8166cc"],
 ", we can use the approximation that the nucleus is in a fixed position and \
solve the time-independent Schr\[ODoubleDot]dinger equation for electron \
position relative to the nucleus. With this approximation, equation (134) \
becomes"
}], "Text",
 CellChangeTimes->{{3.8109946597773657`*^9, 3.8109948782979903`*^9}, {
  3.8109949287597003`*^9, 3.810994931696643*^9}, {3.810996789322976*^9, 
  3.8109967897580814`*^9}, {3.8421100807423115`*^9, 3.8421100814041686`*^9}, {
  3.9176998150991583`*^9, 
  3.917699815535822*^9}},ExpressionUUID->"a3870246-dbcd-419c-92c0-\
89b676e3c102"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    FractionBox[
     RowBox[{"-", 
      SuperscriptBox["\[HBar]", "2"]}], 
     RowBox[{"2", 
      StyleBox[
       SubscriptBox["m", "e"],
       FontSlant->"Italic"]}]], 
    RowBox[{"(", 
     RowBox[{
      SubsuperscriptBox["\[Del]", "1", "2"], 
      RowBox[{"+", 
       SubsuperscriptBox["\[Del]", "2", "2"]}]}], ")"}], "\[Psi]", 
    RowBox[{"(", 
     RowBox[{
      SubscriptBox[
       StyleBox["r",
        FontWeight->"Bold",
        FontSlant->"Italic"], "1"], ",", " ", 
      SubscriptBox[
       StyleBox["r",
        FontWeight->"Bold",
        FontSlant->"Italic"], "2"]}], ")"}]}], "-", 
   RowBox[{
    FractionBox[
     RowBox[{"2", 
      SuperscriptBox[
       StyleBox["e",
        FontSlant->"Italic"], "2"]}], 
     RowBox[{"4", 
      SubscriptBox["\[Pi]\[Epsilon]", "0"]}]], 
    RowBox[{"(", 
     RowBox[{
      FractionBox["1", 
       SubscriptBox[
        StyleBox["r",
         FontSlant->"Italic"], 
        StyleBox["1",
         FontSlant->"Plain"]]], "+", 
      FractionBox["1", 
       SubscriptBox[
        StyleBox["r",
         FontSlant->"Italic"], 
        StyleBox["2",
         FontSlant->"Plain"]]]}], ")"}], "\[Psi]", 
    RowBox[{"(", 
     RowBox[{
      SubscriptBox[
       StyleBox["r",
        FontWeight->"Bold",
        FontSlant->"Italic"], "1"], ",", 
      SubscriptBox[
       StyleBox["r",
        FontWeight->"Bold",
        FontSlant->"Italic"], "2"]}], ")"}]}], "+", 
   RowBox[{
    FractionBox[
     SuperscriptBox[
      StyleBox["e",
       FontSlant->"Italic"], "2"], 
     RowBox[{"4", 
      SubscriptBox["\[Pi]\[Epsilon]", "0"], 
      RowBox[{"\[LeftBracketingBar]", 
       RowBox[{
        StyleBox[
         SubscriptBox[
          StyleBox["r",
           FontWeight->"Bold",
           FontSlant->"Italic"], 
          StyleBox["1",
           FontSlant->"Plain"]],
         FontWeight->"Bold",
         FontSlant->"Italic"], 
        StyleBox["-",
         FontWeight->"Bold",
         FontSlant->"Italic"], 
        SubscriptBox[
         StyleBox["r",
          FontWeight->"Bold",
          FontSlant->"Italic"], "2"]}], "\[RightBracketingBar]"}]}]], 
    "\[Psi]", 
    RowBox[{"(", 
     RowBox[{
      SubscriptBox[
       StyleBox["r",
        FontWeight->"Bold",
        FontSlant->"Italic"], "1"], ",", 
      SubscriptBox[
       StyleBox["r",
        FontWeight->"Bold",
        FontSlant->"Italic"], "2"]}], ")"}]}]}], "=", 
  RowBox[{
   StyleBox[
    RowBox[{
     StyleBox["E",
      FontSlant->"Italic"], "\[Psi]"}]], 
   RowBox[{"(", 
    RowBox[{
     SubscriptBox[
      StyleBox["r",
       FontWeight->"Bold",
       FontSlant->"Italic"], "1"], ",", 
     SubscriptBox[
      StyleBox["r",
       FontWeight->"Bold",
       FontSlant->"Italic"], "2"]}], ")"}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.810112811439228*^9, 3.8101128248442793`*^9}, {
  3.810479494926491*^9, 3.8104795038498344`*^9}, {3.810479572543576*^9, 
  3.8104796147383184`*^9}, {3.8104802055659895`*^9, 3.8104802433915305`*^9}, {
  3.8104802785189395`*^9, 3.8104802814214115`*^9}, {3.8109915300785556`*^9, 
  3.8109916793993816`*^9}, {3.810991710031681*^9, 3.8109918292023373`*^9}, {
  3.810994488524798*^9, 3.810994499853472*^9}, {3.8109948928195066`*^9, 
  3.8109948950763626`*^9}, {3.8109949491606197`*^9, 3.810995087249513*^9}, {
  3.8109951188614283`*^9, 
  3.8109951226144466`*^9}},ExpressionUUID->"0134b1ff-d128-46ea-8ca1-\
58c96daa0294"],

Cell[TextData[{
 "Note that ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["r",
    FontWeight->"Bold",
    FontSlant->"Italic"], "1"]],
  CellChangeTimes->{{3.810112811439228*^9, 3.8101128248442793`*^9}, {
   3.810479494926491*^9, 3.8104795038498344`*^9}, {3.810479572543576*^9, 
   3.8104796147383184`*^9}, {3.8104802055659895`*^9, 
   3.8104802433915305`*^9}, {3.8104802785189395`*^9, 
   3.8104802814214115`*^9}, {3.8109915300785556`*^9, 
   3.8109916793993816`*^9}, {3.810991710031681*^9, 3.8109918292023373`*^9}, {
   3.810994488524798*^9, 3.810994499853472*^9}, {3.8109948928195066`*^9, 
   3.8109948950763626`*^9}, {3.8109949491606197`*^9, 3.810995087249513*^9}, {
   3.8109951188614283`*^9, 3.8109951226144466`*^9}},ExpressionUUID->
  "8ecfb606-8e9e-4166-b8d4-aed324869a50"],
 " and ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["r",
    FontWeight->"Bold",
    FontSlant->"Italic"], "2"]],
  CellChangeTimes->{{3.810112811439228*^9, 3.8101128248442793`*^9}, {
   3.810479494926491*^9, 3.8104795038498344`*^9}, {3.810479572543576*^9, 
   3.8104796147383184`*^9}, {3.8104802055659895`*^9, 
   3.8104802433915305`*^9}, {3.8104802785189395`*^9, 
   3.8104802814214115`*^9}, {3.8109915300785556`*^9, 
   3.8109916793993816`*^9}, {3.810991710031681*^9, 3.8109918292023373`*^9}, {
   3.810994488524798*^9, 3.810994499853472*^9}, {3.8109948928195066`*^9, 
   3.8109948950763626`*^9}, {3.8109949491606197`*^9, 3.810995087249513*^9}, {
   3.8109951188614283`*^9, 3.8109951226144466`*^9}},ExpressionUUID->
  "e8075e18-21eb-473f-9a66-aebf3e1aab55"],
 " in equation (135) give the position of electrons 1 and 2 with respect to \
the nucleus. "
}], "Text",
 CellChangeTimes->{{3.8109951450801463`*^9, 3.810995179972243*^9}, {
  3.810996793157736*^9, 3.810996793890316*^9}, {3.842110094021139*^9, 
  3.842110094148868*^9}},ExpressionUUID->"7c4decb0-8287-4a84-833b-\
7f22db0d61a8"],

Cell["\<\
Even with this simplification, we cannot solve this TISE exactly because of \
the presence of the interelectronic repulsion term, \
\>", "Text",
 CellChangeTimes->{{3.810995183141138*^9, 
  3.8109952148819017`*^9}},ExpressionUUID->"ace9db9f-7ded-4241-89fb-\
3ae5af1a445b"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   SubscriptBox[
    StyleBox["V",
     FontSlant->"Italic"], 
    RowBox[{"1", ",", "2"}]], 
   RowBox[{"(", 
    SubscriptBox[
     StyleBox["r",
      FontSlant->"Italic"], 
     RowBox[{"1", ",", "2"}]], ")"}]}], "=", 
  RowBox[{
   FractionBox[
    SuperscriptBox[
     StyleBox["e",
      FontSlant->"Italic"], "2"], 
    RowBox[{"4", 
     SubscriptBox["\[Pi]\[Epsilon]", "0"], 
     SubscriptBox[
      StyleBox["r",
       FontSlant->"Italic"], 
      RowBox[{"1", ",", "2"}]]}]], "=", 
   FractionBox[
    SuperscriptBox[
     StyleBox["e",
      FontSlant->"Italic"], "2"], 
    RowBox[{"4", 
     SubscriptBox["\[Pi]\[Epsilon]", "0"], 
     RowBox[{"\[LeftBracketingBar]", 
      RowBox[{
       StyleBox[
        SubscriptBox[
         StyleBox["r",
          FontWeight->"Bold",
          FontSlant->"Italic"], 
         StyleBox["1",
          FontSlant->"Plain"]],
        FontWeight->"Bold",
        FontSlant->"Italic"], 
       StyleBox["-",
        FontWeight->"Bold",
        FontSlant->"Italic"], 
       SubscriptBox[
        StyleBox["r",
         FontWeight->"Bold",
         FontSlant->"Italic"], "2"]}], 
      "\[RightBracketingBar]"}]}]]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{
  3.8109952450169563`*^9, {3.810995373934389*^9, 
   3.810995457877651*^9}},ExpressionUUID->"92920910-ed4c-40af-a356-\
57b39d406d81"],

Cell[TextData[{
 "Because this term depends simultaneously on the position of electron 1, ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["r",
    FontWeight->"Bold",
    FontSlant->"Italic"], "1"]],
  CellChangeTimes->{{3.810112811439228*^9, 3.8101128248442793`*^9}, {
   3.810479494926491*^9, 3.8104795038498344`*^9}, {3.810479572543576*^9, 
   3.8104796147383184`*^9}, {3.8104802055659895`*^9, 
   3.8104802433915305`*^9}, {3.8104802785189395`*^9, 
   3.8104802814214115`*^9}, {3.8109915300785556`*^9, 
   3.8109916793993816`*^9}, {3.810991710031681*^9, 3.8109918292023373`*^9}, {
   3.810994488524798*^9, 3.810994499853472*^9}, {3.8109948928195066`*^9, 
   3.8109948950763626`*^9}, {3.8109949491606197`*^9, 3.810995087249513*^9}, {
   3.8109951188614283`*^9, 3.8109951226144466`*^9}},ExpressionUUID->
  "4959939f-d530-4b2a-848e-81d32505d958"],
 ", and the position of electron 2, ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["r",
    FontWeight->"Bold",
    FontSlant->"Italic"], "2"]],
  CellChangeTimes->{3.8109952450169563`*^9},ExpressionUUID->
  "1d8d8905-df43-4fa0-9d2e-c1e32c2534e0"],
 ", we cannot use a separation of variables technique, and we cannot solve \
the equation exactly. Therefore, we have to resort to approximation methods \
and numerical solutions to find the answer. These approaches will be the next \
topic in the course."
}], "Text",
 CellChangeTimes->{{3.810995270142267*^9, 3.8109953024714346`*^9}, {
  3.81099535990126*^9, 3.8109953713026276`*^9}, {3.8109954697190933`*^9, 
  3.8109955067184625`*^9}},ExpressionUUID->"70f03a91-656d-4264-85af-\
22361f8f8b49"]
}, Open  ]]
}, Open  ]]
},
