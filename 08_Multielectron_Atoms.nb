Cell["\<\
Note that we could also represent this result in matrix form,\
\>", "Text",
 CellChangeTimes->{{3.8118618202954044`*^9, 
  3.8118618285917544`*^9}},ExpressionUUID->"5ec3ce5a-de36-ef46-a213-\
397fb391a5f8"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   SubscriptBox[
    StyleBox["E",
     FontSlant->"Italic"], "\[CapitalPhi]"], 
   RowBox[{"(", "\[NoBreak]", 
    RowBox[{GridBox[{
       {
        SubsuperscriptBox[
         StyleBox["a",
          FontSlant->"Italic"], "1", "\[Star]"], 
        SubsuperscriptBox[
         StyleBox["a",
          FontSlant->"Italic"], "2", "\[Star]"]}
      }], GridBox[{
       {"...", 
        SubsuperscriptBox[
         StyleBox["a",
          FontSlant->"Italic"], 
         StyleBox["N",
          FontSlant->"Italic"], "\[Star]"]}
      }]}], ")"}], 
   RowBox[{"(", "\[NoBreak]", GridBox[{
      {
       SubscriptBox[
        StyleBox["S",
         FontSlant->"Italic"], "11"], 
       SubscriptBox[
        StyleBox["S",
         FontSlant->"Italic"], "12"], "...", 
       SubscriptBox[
        StyleBox["S",
         FontSlant->"Italic"], 
        RowBox[{"1", 
         StyleBox["N",
          FontSlant->"Italic"]}]]},
      {
       SubscriptBox[
        StyleBox["S",
         FontSlant->"Italic"], "21"], 
       SubscriptBox[
        StyleBox["S",
         FontSlant->"Italic"], "22"], "...", 
       SubscriptBox[
        StyleBox["S",
         FontSlant->"Italic"], 
        RowBox[{"2", 
         StyleBox["N",
          FontSlant->"Italic"]}]]},
      {"...", "...", "...", "..."},
      {
       SubscriptBox[
        StyleBox["S",
         FontSlant->"Italic"], 
        StyleBox[
         RowBox[{
          StyleBox["N",
           FontSlant->"Italic"], "1"}]]], 
       SubscriptBox[
        StyleBox["S",
         FontSlant->"Italic"], 
        StyleBox[
         RowBox[{
          StyleBox["N",
           FontSlant->"Italic"], "2"}]]], "...", 
       SubscriptBox[
        StyleBox["S",
         FontSlant->"Italic"], 
        StyleBox["NN",
         FontSlant->"Italic"]]}
     }], "\[NoBreak]", ")"}], 
   RowBox[{"(", "\[NoBreak]", GridBox[{
      {
       SubscriptBox[
        StyleBox["a",
         FontSlant->"Italic"], "1"]},
      {
       SubscriptBox[
        StyleBox["a",
         FontSlant->"Italic"], "2"]},
      {GridBox[{
         {"..."},
         {
          SubscriptBox[
           StyleBox["a",
            FontSlant->"Italic"], 
           StyleBox["N",
            FontSlant->"Italic"]]}
        }]}
     }], "\[NoBreak]", ")"}]}], "=", 
  RowBox[{
   RowBox[{"(", "\[NoBreak]", 
    RowBox[{GridBox[{
       {
        SubsuperscriptBox[
         StyleBox["a",
          FontSlant->"Italic"], "1", "\[Star]"], 
        SubsuperscriptBox[
         StyleBox["a",
          FontSlant->"Italic"], "2", "\[Star]"]}
      }], GridBox[{
       {"...", 
        SubsuperscriptBox[
         StyleBox["a",
          FontSlant->"Italic"], 
         StyleBox["N",
          FontSlant->"Italic"], "\[Star]"]}
      }]}], ")"}], 
   RowBox[{"(", "\[NoBreak]", GridBox[{
      {
       SubscriptBox[
        StyleBox["H",
         FontSlant->"Italic"], "11"], 
       SubscriptBox[
        StyleBox["H",
         FontSlant->"Italic"], "12"], "...", 
       SubscriptBox[
        StyleBox["H",
         FontSlant->"Italic"], 
        RowBox[{"1", 
         StyleBox["N",
          FontSlant->"Italic"]}]]},
      {
       SubscriptBox[
        StyleBox["H",
         FontSlant->"Italic"], "21"], 
       SubscriptBox[
        StyleBox["H",
         FontSlant->"Italic"], "22"], "...", 
       SubscriptBox[
        StyleBox["H",
         FontSlant->"Italic"], 
        RowBox[{"2", 
         StyleBox["N",
          FontSlant->"Italic"]}]]},
      {"...", "...", "...", "..."},
      {
       SubscriptBox[
        StyleBox["H",
         FontSlant->"Italic"], 
        StyleBox[
         RowBox[{
          StyleBox["N",
           FontSlant->"Italic"], "1"}]]], 
       SubscriptBox[
        StyleBox["H",
         FontSlant->"Italic"], 
