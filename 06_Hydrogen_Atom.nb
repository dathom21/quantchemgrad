Cell[BoxData[
 RowBox[{
  RowBox[{
   SubsuperscriptBox["\[Integral]", 
    RowBox[{"-", "1"}], "1"], 
   RowBox[{
    SuperscriptBox[
     RowBox[{"(", 
      RowBox[{
       SubscriptBox[
        StyleBox["N",
         FontSlant->"Italic"], 
        SubscriptBox[
         StyleBox["lm",
          FontSlant->"Italic"], 
         StyleBox["l",
          FontSlant->"Italic"]]], 
       SubsuperscriptBox[
        StyleBox["P",
         FontSlant->"Italic"], 
        StyleBox["l",
         FontSlant->"Italic"], 
        RowBox[{"\[LeftBracketingBar]", 
         SubscriptBox[
          StyleBox["m",
           FontSlant->"Italic"], 
          StyleBox["l",
           FontSlant->"Italic"]], "\[RightBracketingBar]"}]], 
       RowBox[{"(", "\[Chi]", ")"}]}], ")"}], "2"], "d\[Chi]"}]}], "=", 
  RowBox[{
   RowBox[{
    SubsuperscriptBox[
     StyleBox["N",
      FontSlant->"Italic"], 
     SubscriptBox[
      StyleBox["lm",
       FontSlant->"Italic"], 
      StyleBox["l",
       FontSlant->"Italic"]], "2"], 
    RowBox[{
     SubsuperscriptBox["\[Integral]", "0", "\[Pi]"], 
     RowBox[{
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{
         SubsuperscriptBox[
          StyleBox["P",
           FontSlant->"Italic"], 
          StyleBox["l",
           FontSlant->"Italic"], 
          RowBox[{"\[LeftBracketingBar]", 
           SubscriptBox[
            StyleBox["m",
             FontSlant->"Italic"], 
            StyleBox["l",
             FontSlant->"Italic"]], "\[RightBracketingBar]"}]], 
         RowBox[{"(", "cos\[Theta]", ")"}]}], ")"}], "2"], "sin\[Theta]", " ", 
      RowBox[{
       StyleBox["\[DifferentialD]",
        FontSlant->"Plain"], "\[Theta]"}]}]}]}], "=", 
   "1"}]}]], "DisplayFormulaNumbered",
