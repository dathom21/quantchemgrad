   3.810713077029566*^9}},ExpressionUUID->"4adbc84d-9fd1-4daf-8249-\
9d49aca3af52"],

Cell[TextData[{
 "We can see that the formula for ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox[
    OverscriptBox[
     StyleBox["L",
      FontSlant->"Italic"], "^"],
    FontSlant->"Italic"], 
   StyleBox["z",
    FontSlant->"Italic"]]],
  CellChangeTimes->{{3.8100544880652375`*^9, 3.8100545041200957`*^9}, {
    3.810054632482561*^9, 3.8100546606919527`*^9}, {3.810054738405748*^9, 
    3.810054754160844*^9}, {3.810055496888957*^9, 3.810055644063492*^9}, {
    3.8101099522060614`*^9, 3.8101100508523717`*^9}, {3.8101101194750385`*^9, 
    3.8101101642963843`*^9}, {3.8107127659519644`*^9, 3.810712781977992*^9}, {
    3.8107128863205147`*^9, 3.8107129246267147`*^9}, 3.810712975971156*^9, 
    3.8107130396874857`*^9, {3.810713072953952*^9, 3.810713077029566*^9}},
  ExpressionUUID->"4e3c78ea-c67b-49ac-a77b-1620837a78c1"],
 " is relatively simple, requiring only a partial derivative with respect to \
\[Phi]. If we look back at our spherical harmonics functions, ",
 Cell[BoxData[
  RowBox[{
   SubsuperscriptBox[
    StyleBox["Y",
     FontSlant->"Italic"], 
    StyleBox["l",
     FontSlant->"Italic"], 
    SubscriptBox[
     StyleBox["m",
      FontSlant->"Italic"], 
     StyleBox["l",
      FontSlant->"Italic"]]], 
   RowBox[{"(", 
    RowBox[{"\[Theta]", ",", "\[Phi]"}], ")"}]}]],
  CellChangeTimes->{{3.810112811439228*^9, 3.8101128248442793`*^9}, {
    3.810479494926491*^9, 3.8104795038498344`*^9}, {3.810479572543576*^9, 
    3.8104796147383184`*^9}, {3.8104802055659895`*^9, 
    3.8104802433915305`*^9}, {3.8104802785189395`*^9, 
    3.8104802814214115`*^9}, {3.810480477782269*^9, 3.8104805471507206`*^9}, {
    3.8104805927965565`*^9, 3.810480633017248*^9}, {3.8104807595294323`*^9, 
    3.8104809538100047`*^9}, {3.8104811300285854`*^9, 
    3.8104811403007636`*^9}, {3.8104812580010843`*^9, 
    3.8104813317580833`*^9}, {3.81048146789211*^9, 3.8104815557630205`*^9}, {
    3.8104817202872114`*^9, 3.8104817438715935`*^9}, 3.810481790764664*^9, 
    3.810481836241686*^9, {3.810481926951917*^9, 3.810481935802024*^9}, {
    3.8104820720505495`*^9, 3.8104821860076323`*^9}, {3.810482833577834*^9, 
    3.810482856592573*^9}, {3.810650687465464*^9, 3.8106507334315205`*^9}, 
    3.810651925937356*^9, {3.810652128872187*^9, 3.810652287868311*^9}},
  ExpressionUUID->"a5768a2e-8635-4e03-921c-89c916d575b0"],
 ", we notice that the \[Phi] dependence only occurs in terms of the form ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["\[ExponentialE]", 
     RowBox[{
      SubscriptBox[
       StyleBox[
        RowBox[{"\[ImaginaryI]", 
         StyleBox["m",
          FontSlant->"Italic"]}]], "l"], 
      StyleBox["\[Phi]",
       FontSlant->"Plain"]}]], " "}], TraditionalForm]],ExpressionUUID->
  "fe66fd3d-5fc9-4e02-bec6-ff3b4bb3a9f9"],
 ", where ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["m", "l"], TraditionalForm]],ExpressionUUID->
  "a97e5c95-a810-48a0-9745-ee6263d69958"],
 StyleBox[" ",
  FontSlant->"Italic"],
 " is one of the quantum numbers. If we apply the operator ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox[
    OverscriptBox[
     StyleBox["L",
      FontSlant->"Italic"], "^"],
    FontSlant->"Italic"], 
   StyleBox["z",
    FontSlant->"Italic"]]],
  CellChangeTimes->{{3.8100544880652375`*^9, 3.8100545041200957`*^9}, {
    3.810054632482561*^9, 3.8100546606919527`*^9}, {3.810054738405748*^9, 
    3.810054754160844*^9}, {3.810055496888957*^9, 3.810055644063492*^9}, {
    3.8101099522060614`*^9, 3.8101100508523717`*^9}, {3.8101101194750385`*^9, 
    3.8101101642963843`*^9}, {3.8107127659519644`*^9, 3.810712781977992*^9}, {
    3.8107128863205147`*^9, 3.8107129246267147`*^9}, 3.810712975971156*^9, 
    3.8107130396874857`*^9, {3.810713072953952*^9, 3.810713077029566*^9}},
  ExpressionUUID->"fb826a97-fbc1-486e-925c-1ae5b49e42dd"],
 " to a function of this form, we find that "
}], "Text",
 CellChangeTimes->{{3.8107135036496925`*^9, 3.8107135829591274`*^9}, {
  3.810713618107924*^9, 3.810713634478414*^9}, {3.8107136670829287`*^9, 
  3.810713788057347*^9}, {3.8107141450689077`*^9, 3.8107141607882595`*^9}, {
  3.810727308891925*^9, 3.810727309491725*^9}, {3.8421052052095075`*^9, 
  3.8421052052095075`*^9}, {3.9170862070799136`*^9, 
  3.917086221032357*^9}},ExpressionUUID->"27cd111e-1121-4b51-97d2-\
2b134f178683"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   SubscriptBox[
    StyleBox[
     OverscriptBox[
      StyleBox["L",
       FontSlant->"Italic"], "^"],
     FontSlant->"Italic"], 
    StyleBox["z",
     FontSlant->"Italic"]], 
   SuperscriptBox["\[ExponentialE]", 
    RowBox[{
     StyleBox["\[ImaginaryI]",
      FontSlant->"Plain"], 
     StyleBox[" ",
      FontSlant->"Plain"], 
     StyleBox[
      SubscriptBox["m", "l"],
      FontSlant->"Italic"], 
     StyleBox["\[Phi]",
      FontSlant->"Plain"]}]]}], " ", "=", 
  RowBox[{
   RowBox[{
    RowBox[{"-", "\[ImaginaryI]\[HBar]"}], 
    RowBox[{
     FractionBox["\[PartialD]", 
      RowBox[{"\[PartialD]", "\[Phi]"}]], 
     FormBox[
      RowBox[{
       SuperscriptBox["\[ExponentialE]", 
        RowBox[{
         SubscriptBox[
          StyleBox[
           RowBox[{
            StyleBox["\[ImaginaryI]",
             FontSlant->"Plain"], 
            StyleBox["m",
             FontSlant->"Italic"]}]], "l"], 
         StyleBox["\[Phi]",
          FontSlant->"Plain"]}]], " "}],
      TraditionalForm]}]}], "=", 
   RowBox[{
    SubscriptBox[
     StyleBox["m",
      FontSlant->"Italic"], 
     StyleBox["l",
      FontSlant->"Italic"]], 
    StyleBox[" ",
     FontSlant->"Italic"], 
    SuperscriptBox["\[HBar]\[ExponentialE]", 
     RowBox[{
      SubscriptBox[
       StyleBox[
        RowBox[{
         StyleBox["\[ImaginaryI]",
          FontSlant->"Plain"], 
         StyleBox["m",
          FontSlant->"Italic"]}]], 
       StyleBox["l",
        FontSlant->"Italic"]], 
      StyleBox["\[Phi]",
       FontSlant->"Plain"]}]], "  "}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8100544880652375`*^9, 3.8100545041200957`*^9}, {
   3.810054632482561*^9, 3.8100546606919527`*^9}, {3.810054738405748*^9, 
   3.810054754160844*^9}, {3.810055496888957*^9, 3.810055644063492*^9}, {
   3.8101099522060614`*^9, 3.8101100508523717`*^9}, {3.8101101194750385`*^9, 
   3.8101101642963843`*^9}, {3.8107127659519644`*^9, 3.810712781977992*^9}, {
   3.8107128863205147`*^9, 3.8107129246267147`*^9}, 3.810712975971156*^9, 
   3.8107130396874857`*^9, {3.810713072953952*^9, 3.810713077029566*^9}, {
   3.8107138654100857`*^9, 3.810713907959445*^9}, {3.8107141633674574`*^9, 
   3.8107141929269314`*^9}, {3.842105206901169*^9, 3.8421052148135443`*^9}, {
   3.917086229446878*^9, 3.917086272810526*^9}, 3.917086341525565*^9, {
   3.9170863897335787`*^9, 
   3.9170863900821447`*^9}},ExpressionUUID->"e55b1d91-04ff-4f7a-8b95-\
965671f74e30"],

Cell[TextData[{
 "Because the result of operating on these functions with ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox[
    OverscriptBox[
     StyleBox["L",
      FontSlant->"Italic"], "^"],
    FontSlant->"Italic"], 
   StyleBox["z",
    FontSlant->"Italic"]]],
  CellChangeTimes->{{3.8100544880652375`*^9, 3.8100545041200957`*^9}, {
    3.810054632482561*^9, 3.8100546606919527`*^9}, {3.810054738405748*^9, 
    3.810054754160844*^9}, {3.810055496888957*^9, 3.810055644063492*^9}, {
    3.8101099522060614`*^9, 3.8101100508523717`*^9}, {3.8101101194750385`*^9, 
    3.8101101642963843`*^9}, {3.8107127659519644`*^9, 3.810712781977992*^9}, {
    3.8107128863205147`*^9, 3.8107129246267147`*^9}, 3.810712975971156*^9, 
    3.8107130396874857`*^9, {3.810713072953952*^9, 3.810713077029566*^9}},
  ExpressionUUID->"dd9cc374-5306-4dd3-b0bb-36c55ce4a08b"],
 " yields a constant multiplied by the original function, we can say that \
functions of this form are eigenfunctions of ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox[
    OverscriptBox[
     StyleBox["L",
      FontSlant->"Italic"], "^"],
    FontSlant->"Italic"], 
   StyleBox["z",
    FontSlant->"Italic"]]],
  CellChangeTimes->{{3.8100544880652375`*^9, 3.8100545041200957`*^9}, {
    3.810054632482561*^9, 3.8100546606919527`*^9}, {3.810054738405748*^9, 
    3.810054754160844*^9}, {3.810055496888957*^9, 3.810055644063492*^9}, {
    3.8101099522060614`*^9, 3.8101100508523717`*^9}, {3.8101101194750385`*^9, 
    3.8101101642963843`*^9}, {3.8107127659519644`*^9, 3.810712781977992*^9}, {
    3.8107128863205147`*^9, 3.8107129246267147`*^9}, 3.810712975971156*^9, 
    3.8107130396874857`*^9, {3.810713072953952*^9, 3.810713077029566*^9}},
  ExpressionUUID->"60a54be2-7fca-4e78-8e6e-206484ca0d05"],
 ". As we said that the \[Phi] dependence of ",
 Cell[BoxData[
  RowBox[{
   SubsuperscriptBox[
    StyleBox["Y",
     FontSlant->"Italic"], 
    StyleBox["l",
     FontSlant->"Italic"], 
    SubscriptBox[
     StyleBox["m",
      FontSlant->"Italic"], 
     StyleBox["l",
      FontSlant->"Italic"]]], 
   RowBox[{"(", 
    RowBox[{"\[Theta]", ",", "\[Phi]"}], ")"}]}]],
  CellChangeTimes->{{3.810112811439228*^9, 3.8101128248442793`*^9}, {
