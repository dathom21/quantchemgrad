            FontSlant->"Italic"], "21"]}]}], 
        RowBox[{
         RowBox[{
          SubscriptBox[
           StyleBox["b",
            FontSlant->"Italic"], "21"], 
          SubscriptBox[
           StyleBox["a",
            FontSlant->"Italic"], "12"]}], "+", 
         RowBox[{
          SubscriptBox[
           StyleBox["b",
            FontSlant->"Italic"], "22"], 
          SubscriptBox[
           StyleBox["a",
            FontSlant->"Italic"], "22"]}]}]}
      }], "\[NoBreak]", ")"}], 
    RowBox[{"(", "\[NoBreak]", GridBox[{
       {
        SubscriptBox[
         StyleBox["x",
          FontSlant->"Italic"], "1"]},
       {
        SubscriptBox[
         StyleBox["y",
          FontSlant->"Italic"], "1"]}
      }], "\[NoBreak]", ")"}]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.811253718311788*^9, 3.8112538382526913`*^9}, {
  3.811257050877017*^9, 3.811257053063272*^9}, {3.8112583347089105`*^9, 
  3.8112583446657734`*^9}, {3.811258452245489*^9, 3.811258475053415*^9}, {
  3.8112586202324114`*^9, 3.8112586538448534`*^9}, {3.811258938711089*^9, 
  3.8112590189254713`*^9}, {3.8112590576493874`*^9, 3.8112590588875027`*^9}, {
  3.8113354399352074`*^9, 
  3.811335444950405*^9}},ExpressionUUID->"4041e8b4-28d0-48e8-b86f-\
4003e4a3c182"],

Cell["\<\
In a more simplistic form using bold capital letters to represent matrices, \
we could write the transformation matrix as\
\>", "Text",
 CellChangeTimes->{{3.811259090499899*^9, 
  3.8112591233464937`*^9}},ExpressionUUID->"f1e7d2af-43c3-4a84-b746-\
ed2f03daba6b"],

Cell[BoxData[
 RowBox[{
  StyleBox["C",
   FontWeight->"Bold"], 
  StyleBox["=",
   FontWeight->"Plain"], 
  StyleBox["BA",
   FontWeight->"Bold"]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8112591386810617`*^9, 
  3.811259150969136*^9}},ExpressionUUID->"ec7a4512-5ddc-4c06-977f-\
11fdb700faab"],

Cell[TextData[{
 "When we multiply two matrices ",
 StyleBox["B",
  FontWeight->"Bold"],
 " and ",
 StyleBox["A",
  FontWeight->"Bold"],
 " together, we obtain the matrix ",
 StyleBox["C ",
  FontWeight->"Bold"],
 " with elements ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["c", 
    StyleBox["ij",
     FontSlant->"Italic"]], TraditionalForm]],ExpressionUUID->
  "91b84343-1fb2-4c3e-a788-9e1ef05c77fa"],
 " given by"
}], "Text",
 CellChangeTimes->{{3.8112591627493*^9, 
  3.811259244539358*^9}},ExpressionUUID->"34f0610a-747c-4ee7-8861-\
585ab00c9b2a"],

Cell[BoxData[
 RowBox[{
  SubscriptBox[
   StyleBox["c",
    FontSlant->"Italic"], 
   StyleBox["ij",
    FontSlant->"Italic"]], "=", 
  RowBox[{
   UnderscriptBox["\[Sum]", 
    StyleBox["k",
     FontSlant->"Italic"],
    LimitsPositioning->False], 
   RowBox[{
    SubscriptBox[
     StyleBox["b",
      FontSlant->"Italic"], 
     StyleBox["ik",
      FontSlant->"Italic"]], 
    SubscriptBox[
     StyleBox["a",
      FontSlant->"Italic"], 
     StyleBox["kj",
      FontSlant->"Italic"]]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8112579973997173`*^9, 3.8112580336398363`*^9}, {
  3.8112585414323387`*^9, 3.811258542104349*^9}, {3.81125857991893*^9, 
  3.8112585934293423`*^9}, {3.8112587303048716`*^9, 3.81125874131851*^9}, {
  3.8112588034274178`*^9, 3.81125886017966*^9}, {3.8112592583100834`*^9, 
  3.8112592949319563`*^9}, {3.811259336625536*^9, 
  3.8112594312945747`*^9}},ExpressionUUID->"9ddd46bb-52f3-4d02-829b-\
b28311d92e09"],

Cell[TextData[{
 "Sometimes it\[CloseCurlyQuote]s easier to evaluate the relationship \
visually by noticing that each position is obtained by sequentially \
multiplying each element in a row of ",
 StyleBox["B",
  FontWeight->"Bold"],
 " by each element in a column of ",
 StyleBox["A",
  FontWeight->"Bold"],
 " and then adding together. To complete this type of matrix multiplication, \
we must meet the condition that the number of columns of the first matrix is \
equal to the number of rows of the second matrix."
}], "Text",
 CellChangeTimes->{{3.811259540169299*^9, 3.8112596165728307`*^9}, {
  3.811322452218878*^9, 3.8113224530754423`*^9}, {3.8421629457669325`*^9, 
  3.842162947383194*^9}},ExpressionUUID->"dd4d07c6-f8e5-465e-877a-\
e3b4d55c21de"],

Cell["\<\
 When multiplying matrices together, we once again have the constraint that \
the commutative law is not necessarily obeyed, that is\
\>", "Text",
 CellChangeTimes->{{3.8112596295180826`*^9, 3.811259636843335*^9}, {
  3.811259673154049*^9, 3.8112596826545773`*^9}, {3.811259752143126*^9, 
  3.8112597974736013`*^9}, {3.811322400343935*^9, 
  3.8113224513350725`*^9}},ExpressionUUID->"8a578040-da23-4b2f-a51b-\
1c4aecf7b926"],

Cell[BoxData[
 RowBox[{
  StyleBox["BA",
   FontWeight->"Bold"], "\[NotEqual]", 
  StyleBox["AB",
   FontWeight->"Bold"]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8112591386810617`*^9, 3.811259150969136*^9}, {
  3.8112598074758043`*^9, 
  3.8112598326160436`*^9}},ExpressionUUID->"619b90f7-bd23-41b9-99b6-\
7a77c4e31a34"],

Cell["\<\
Just as we saw for operators, we can have a matrix commutator\
\>", "Text",
 CellChangeTimes->{{3.811259837793014*^9, 
  3.8112598475847335`*^9}},ExpressionUUID->"10cac905-2895-4a03-8ba1-\
a9fd57b30bc0"],

Cell[BoxData[
 RowBox[{
  RowBox[{"[", 
   RowBox[{
    StyleBox["A",
     FontWeight->"Bold"], ",", 
    StyleBox["B",
     FontWeight->"Bold"]}], "]"}], "=", 
  StyleBox[
   RowBox[{"AB", "-", "BA"}],
   FontWeight->"Bold"]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8112591386810617`*^9, 3.811259150969136*^9}, {
  3.8112598074758043`*^9, 3.8112598326160436`*^9}, {3.8112598644007344`*^9, 
  3.8112598802845387`*^9}},ExpressionUUID->"c81c0887-2736-4634-abc1-\
8741dd8a5152"],

Cell["\<\
If the commutator yields a value of zero, then the matrices are said to \
commute.\
\>", "Text",
 CellChangeTimes->{{3.811259888981724*^9, 3.811259902579772*^9}, {
  3.8112614450749893`*^9, 
  3.811261446644967*^9}},ExpressionUUID->"3f6a0811-1df4-42ec-a75b-\
64aff6fd017e"],

Cell[TextData[{
 "Another quirk of matrix multiplication that does not occur with scalar \
multiplication is that one can obtain zero as an answer without either of the \
matrices containing zero. In equation form, we write a matrix where all \
elements are zero as ",
 StyleBox["O",
  FontWeight->"Bold"],
 ". We can find that "
}], "Text",
 CellChangeTimes->{{3.81126143569809*^9, 
  3.8112615368265266`*^9}},ExpressionUUID->"e035c7d4-175a-4ea1-aad3-\
9eddb5a9a6d4"],

Cell[BoxData[
 StyleBox[
  RowBox[{"AB", "=", "O"}],
  FontWeight->"Bold"]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8112591386810617`*^9, 3.811259150969136*^9}, {
  3.8112598074758043`*^9, 3.8112598326160436`*^9}, {3.8112598644007344`*^9, 
  3.8112598802845387`*^9}, {3.8112615457602863`*^9, 
  3.81126154943351*^9}},ExpressionUUID->"1fba070d-e9db-4b8a-a95d-\
842d6cd6c262"],

Cell[TextData[{
 "without ",
 StyleBox["A",
  FontWeight->"Bold"],
 StyleBox[" ",
  FontWeight->"Bold",
  FontSlant->"Italic"],
 "or ",
 StyleBox["B",
  FontWeight->"Bold"],
 " being equal to ",
 StyleBox["O",
  FontWeight->"Bold"],
 ". McQuarrie and Simon provides the example of"
}], "Text",
 CellChangeTimes->{{3.8112615526543007`*^9, 3.811261599290562*^9}, 
   3.936182773025261*^9},ExpressionUUID->"38c1ddac-b1f2-4df3-ab21-\
985067e82f34"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"(", "\[NoBreak]", GridBox[{
      {"1", "1"},
      {"2", "2"}
     }], "\[NoBreak]", ")"}], 
   RowBox[{"(", "\[NoBreak]", GridBox[{
      {
       RowBox[{"-", "1"}], "1"},
      {"1", 
       RowBox[{"-", "1"}]}
     }], "\[NoBreak]", ")"}]}], "=", 
  RowBox[{
   RowBox[{"(", "\[NoBreak]", GridBox[{
      {
       RowBox[{
        RowBox[{"-", "1"}], "+", "1"}], 
       RowBox[{"1", "-", "1"}]},
      {
       RowBox[{
        RowBox[{"-", "2"}], "+", "2"}], 
       RowBox[{"2", "-", "2"}]}
     }], "\[NoBreak]", ")"}], "=", 
   RowBox[{"(", "\[NoBreak]", GridBox[{
      {"0", "0"},
      {"0", "0"}
     }], "\[NoBreak]", ")"}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.811261617086681*^9, 
  3.8112617606312156`*^9}},ExpressionUUID->"3743344f-fbfd-4d4a-9911-\
65c01ce49180"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Direct Product of Matrices", "Subsubsection",
 CellChangeTimes->{{3.81125731786572*^9, 3.8112573251265087`*^9}, {
  3.8112604189255323`*^9, 
  3.811260422798058*^9}},ExpressionUUID->"fbbe6c7a-b43b-49fb-8d65-\
5ecbb934971b"],

Cell[TextData[{
 "There is a less-common type of matrix multiplication known as the direct \
product. For two matrices ",
 StyleBox["A",
  FontWeight->"Bold"],
 " and ",
 StyleBox["B",
  FontWeight->"Bold"],
 ", the direct product is defined as "
}], "Text",
 CellChangeTimes->{{3.8112604261620317`*^9, 
  3.8112604932721777`*^9}},ExpressionUUID->"8b2fc8e3-42b8-4222-8ce4-\
c67c7ec6d565"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   StyleBox["A",
    FontWeight->"Bold",
    FontSlant->"Plain"], "\[TensorProduct]", 
   StyleBox["B",
    FontWeight->"Bold"]}], 
  StyleBox["=",
   FontWeight->"Plain",
   FontSlant->"Plain"], 
  RowBox[{
   RowBox[{
    RowBox[{"(", "\[NoBreak]", GridBox[{
       {
        SubscriptBox[
         StyleBox["a",
          FontSlant->"Italic"], "11"], 
        SubscriptBox[
         StyleBox["a",
          FontSlant->"Italic"], "12"]},
       {
        SubscriptBox[
         StyleBox["a",
          FontSlant->"Italic"], "21"], 
        SubscriptBox[
         StyleBox["a",
          FontSlant->"Italic"], "22"]}
      }], "\[NoBreak]", ")"}], "\[TensorProduct]", 
    RowBox[{"(", "\[NoBreak]", GridBox[{
       {
        SubscriptBox[
         StyleBox["b",
          FontSlant->"Italic"], "11"], 
        SubscriptBox[
         StyleBox["b",
          FontSlant->"Italic"], "12"]},
       {
        SubscriptBox[
         StyleBox["b",
          FontSlant->"Italic"], "21"], 
        SubscriptBox[
         StyleBox["b",
          FontSlant->"Italic"], "22"]}
      }], "\[NoBreak]", ")"}]}], "=", 
   RowBox[{
    RowBox[{"(", "\[NoBreak]", GridBox[{
       {
        RowBox[{
         SubscriptBox[
          StyleBox["a",
           FontSlant->"Italic"], "11"], 
         StyleBox["B",
          FontWeight->"Bold"]}], 
        RowBox[{
         SubscriptBox[
          StyleBox["a",
           FontSlant->"Italic"], "12"], 
         StyleBox["B",
          FontWeight->"Bold"]}]},
       {
        RowBox[{
         SubscriptBox[
          StyleBox["a",
           FontSlant->"Italic"], "21"], 
         StyleBox["B",
          FontWeight->"Bold"]}], 
        RowBox[{
         SubscriptBox[
          StyleBox["a",
           FontSlant->"Italic"], "22"], 
         StyleBox["B",
          FontWeight->"Bold"]}]}
      }], "\[NoBreak]", ")"}], "=", 
    TagBox[
     RowBox[{"(", "\[NoBreak]", GridBox[{
        {
         RowBox[{
          SubscriptBox[
           StyleBox["a",
            FontSlant->"Italic"], "11"], " ", 
          SubscriptBox[
           StyleBox["b",
            FontSlant->"Italic"], "11"]}], 
         RowBox[{
          SubscriptBox[
           StyleBox["a",
            FontSlant->"Italic"], "11"], " ", 
          SubscriptBox[
           StyleBox["b",
            FontSlant->"Italic"], "12"]}], 
         RowBox[{
          SubscriptBox[
           StyleBox["a",
            FontSlant->"Italic"], "12"], " ", 
          SubscriptBox[
           StyleBox["b",
            FontSlant->"Italic"], "11"]}], 
         RowBox[{
          SubscriptBox[
           StyleBox["a",
            FontSlant->"Italic"], "12"], " ", 
          SubscriptBox[
           StyleBox["b",
            FontSlant->"Italic"], "12"]}]},
        {
         RowBox[{
          SubscriptBox[
           StyleBox["a",
            FontSlant->"Italic"], "11"], " ", 
          SubscriptBox[
           StyleBox["b",
            FontSlant->"Italic"], "21"]}], 
         RowBox[{
          SubscriptBox[
           StyleBox["a",
            FontSlant->"Italic"], "11"], 
          StyleBox[" ",
           FontSlant->"Italic"], 
          SubscriptBox[
           StyleBox["b",
            FontSlant->"Italic"], "22"]}], 
         RowBox[{
          SubscriptBox[
           StyleBox["a",
            FontSlant->"Italic"], "12"], " ", 
          SubscriptBox[
           StyleBox["b",
            FontSlant->"Italic"], "21"]}], 
         RowBox[{
          SubscriptBox[
           StyleBox["a",
            FontSlant->"Italic"], "12"], " ", 
          SubscriptBox[
           StyleBox["b",
            FontSlant->"Italic"], "22"]}]},
        {
         RowBox[{
          SubscriptBox[
           StyleBox["a",
            FontSlant->"Italic"], "21"], " ", 
          SubscriptBox[
           StyleBox["b",
            FontSlant->"Italic"], "11"]}], 
         RowBox[{
          SubscriptBox[
           StyleBox["a",
            FontSlant->"Italic"], "21"], " ", 
          SubscriptBox[
           StyleBox["b",
            FontSlant->"Italic"], "12"]}], 
         RowBox[{
          SubscriptBox[
           StyleBox["a",
            FontSlant->"Italic"], "22"], " ", 
          SubscriptBox[
           StyleBox["b",
            FontSlant->"Italic"], "11"]}], 
         RowBox[{
          SubscriptBox[
           StyleBox["a",
            FontSlant->"Italic"], "22"], " ", 
          SubscriptBox[
           StyleBox["b",
            FontSlant->"Italic"], "12"]}]},
        {
         RowBox[{
          SubscriptBox[
           StyleBox["a",
            FontSlant->"Italic"], "21"], " ", 
          SubscriptBox[
           StyleBox["b",
            FontSlant->"Italic"], "21"]}], 
         RowBox[{
          SubscriptBox[
           StyleBox["a",
            FontSlant->"Italic"], "21"], " ", 
          SubscriptBox[
           StyleBox["b",
            FontSlant->"Italic"], "22"]}], 
         RowBox[{
          SubscriptBox[
           StyleBox["a",
            FontSlant->"Italic"], "22"], " ", 
          SubscriptBox[
           StyleBox["b",
            FontSlant->"Italic"], "21"]}], 
         RowBox[{
          SubscriptBox[
           StyleBox["a",
            FontSlant->"Italic"], "22"], " ", 
          SubscriptBox[
           StyleBox["b",
            FontSlant->"Italic"], "22"]}]}
       },
       GridBoxAlignment->{"Columns" -> {{Center}}, "Rows" -> {{Baseline}}},
       GridBoxSpacings->{"Columns" -> {
           Offset[0.27999999999999997`], {
            Offset[0.7]}, 
           Offset[0.27999999999999997`]}, "Rows" -> {
           Offset[0.2], {
            Offset[0.4]}, 
           Offset[0.2]}}], "\[NoBreak]", ")"}],
     Function[BoxForm`e$, 
      MatrixForm[BoxForm`e$]]]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.811253718311788*^9, 3.8112538382526913`*^9}, {
   3.811257050877017*^9, 3.811257053063272*^9}, {3.8112605051906323`*^9, 
   3.811260573432273*^9}, 3.811260670918002*^9, {3.811261022447711*^9, 
   3.8112610452294564`*^9}},ExpressionUUID->"5a859332-9848-495c-a0d6-\
198331931039"],

Cell[TextData[{
 "Note that if ",
 StyleBox["A",
  FontWeight->"Bold"],
 " is an ",
 StyleBox["n",
  FontSlant->"Italic"],
 " \[Cross] ",
 StyleBox["m",
  FontSlant->"Italic"],
 " matrix, and ",
 StyleBox["B",
  FontWeight->"Bold"],
 " is a ",
 StyleBox["p",
  FontSlant->"Italic"],
 " \[Cross]",
 StyleBox["q",
  FontSlant->"Italic"],
 " matrix, then ",
 StyleBox["A",
  FontWeight->"Bold"],
 "\[TensorProduct]",
 StyleBox["B",
  FontWeight->"Bold"],
 " is a ",
 StyleBox["pm",
  FontSlant->"Italic"],
 " \[Cross] ",
 StyleBox["qn",
  FontSlant->"Italic"],
 " matrix. In the case of two vectors, this type of multiplication is often \
referred to as an outer product, and in the case of two matrices, it can also \
be referred to as a Kronecker product. These types of operations are \
especially common in group theory."
}], "Text",
 CellChangeTimes->{{3.811260807631856*^9, 3.811260831991973*^9}, {
  3.8112608697756624`*^9, 3.811261002749386*^9}, {3.811261054410636*^9, 
  3.8112611070295362`*^9}, {3.842248890616727*^9, 
  3.8422488910776873`*^9}},ExpressionUUID->"cdd5861d-80fb-4594-810a-\
ed1f5f3fb7ba"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Special Cases of Matrix Multiplication", "Subsubsection",
 CellChangeTimes->{{3.811261811652293*^9, 3.8112618189631205`*^9}, {
  3.811262654124528*^9, 3.8112626558587165`*^9}, {3.811262704584033*^9, 
  3.811262708272787*^9}},ExpressionUUID->"0d945c28-f3b3-41e0-83d0-\
599fa18a96fd"],

Cell["\<\
We can perform a special case of matrix multiplication when we multiply a \
square matrix by the identity matrix. This operation leaves the original \
matrix unaltered and is known as the identity transformation. For our typical \
example matrix of\
\>", "Text",
 CellChangeTimes->{{3.811262176240604*^9, 3.811262190232025*^9}, {
  3.81126224332171*^9, 
  3.8112623227378273`*^9}},ExpressionUUID->"6b923f11-f891-4308-8d66-\
58c7af9f8be7"],

Cell[BoxData[
 RowBox[{
  StyleBox["A",
   FontWeight->"Bold",
   FontSlant->"Plain"], 
  StyleBox["=",
   FontWeight->"Plain",
   FontSlant->"Plain"], 
  RowBox[{"(", "\[NoBreak]", GridBox[{
     {
      SubscriptBox[
       StyleBox["a",
        FontSlant->"Italic"], "11"], 
      SubscriptBox[
       StyleBox["a",
        FontSlant->"Italic"], "12"]},
     {
      SubscriptBox[
       StyleBox["a",
        FontSlant->"Italic"], "21"], 
      SubscriptBox[
       StyleBox["a",
        FontSlant->"Italic"], "22"]}
    }], "\[NoBreak]", ")"}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.811253718311788*^9, 3.8112538382526913`*^9}, {
  3.811257050877017*^9, 
  3.811257053063272*^9}},ExpressionUUID->"1dac6e51-7b05-4709-91dc-\
39a0d9333cfa"],

Cell["we find that", "Text",
 CellChangeTimes->{{3.811262327298366*^9, 
  3.8112623282414627`*^9}},ExpressionUUID->"6dd1a7d6-ebdd-444d-8081-\
8ab0df437153"],

Cell[BoxData[
 RowBox[{
  StyleBox["AI",
   FontWeight->"Bold",
   FontSlant->"Plain"], 
  StyleBox["=",
   FontWeight->"Plain",
   FontSlant->"Plain"], 
  RowBox[{
   RowBox[{
    RowBox[{"(", "\[NoBreak]", GridBox[{
       {
        SubscriptBox[
         StyleBox["a",
          FontSlant->"Italic"], "11"], 
        SubscriptBox[
         StyleBox["a",
          FontSlant->"Italic"], "12"]},
       {
        SubscriptBox[
         StyleBox["a",
          FontSlant->"Italic"], "21"], 
        SubscriptBox[
         StyleBox["a",
          FontSlant->"Italic"], "22"]}
      }], "\[NoBreak]", ")"}], 
    RowBox[{"(", "\[NoBreak]", GridBox[{
       {"1", "0"},
       {"0", "1"}
      }], "\[NoBreak]", ")"}]}], "=", 
   RowBox[{"(", "\[NoBreak]", GridBox[{
      {
       SubscriptBox[
        StyleBox["a",
         FontSlant->"Italic"], "11"], 
       SubscriptBox[
        StyleBox["a",
         FontSlant->"Italic"], "12"]},
      {
       SubscriptBox[
        StyleBox["a",
         FontSlant->"Italic"], "21"], 
       SubscriptBox[
        StyleBox["a",
         FontSlant->"Italic"], "22"]}
     }], "\[NoBreak]", ")"}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.811253718311788*^9, 3.8112538382526913`*^9}, {
  3.811257050877017*^9, 3.811257053063272*^9}, {3.8112623334671025`*^9, 
  3.8112623551968336`*^9}},ExpressionUUID->"39017b4e-5960-4f03-a015-\
f92b58157377"],

Cell["Note also that", "Text",
 CellChangeTimes->{{3.8112623792752185`*^9, 
  3.8112623805507946`*^9}},ExpressionUUID->"89067343-cfdb-4f0c-9713-\
3d7d4ca232ac"],

Cell[BoxData[
 RowBox[{
  StyleBox["AI",
   FontWeight->"Bold",
   FontSlant->"Plain"], 
  StyleBox["=",
   FontWeight->"Plain",
   FontSlant->"Plain"], 
  StyleBox["IA",
   FontWeight->"Bold"]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.811253718311788*^9, 3.8112538382526913`*^9}, {
  3.811257050877017*^9, 3.811257053063272*^9}, {3.8112623334671025`*^9, 
  3.8112623551968336`*^9}, {3.81126239257867*^9, 
  3.811262399404647*^9}},ExpressionUUID->"b3cd17af-ee4d-4f80-ac5a-\
7893f2c9cf30"],

Cell["\<\
The reasons why you might want to perform such an operation may seem obscure, \
but rest assured that it does come up.\
\>", "Text",
 CellChangeTimes->{{3.8112624025375175`*^9, 
  3.8112624270065155`*^9}},ExpressionUUID->"b089fb58-fab9-47f3-9aad-\
2abf81c699a5"],

Cell[TextData[{
 "Another important matrix multiplication operation involves multiplying a \
matrix by its inverse. The inverse of a matrix ",
 StyleBox["A",
  FontWeight->"Bold"],
 " is written as ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    StyleBox["A",
     FontWeight->"Bold",
     FontSlant->"Plain"], 
    RowBox[{"-", "1"}]], TraditionalForm]],ExpressionUUID->
  "fa715511-219d-48df-a1ca-c72793f54e83"],
 " and is defined by the equation"
}], "Text",
 CellChangeTimes->{{3.8112624609299335`*^9, 3.811262479684967*^9}, {
  3.81126253973409*^9, 
  3.8112625879902725`*^9}},ExpressionUUID->"d7f91156-9f72-47c7-bcf1-\
6ead7a574dac"],

Cell[BoxData[
 RowBox[{
  SuperscriptBox[
   StyleBox["AA",
    FontWeight->"Bold",
    FontSlant->"Plain"], 
   RowBox[{"-", "1"}]], "=", 
  StyleBox["I",
   FontWeight->"Bold"]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.811253718311788*^9, 3.8112538382526913`*^9}, {
  3.811257050877017*^9, 3.811257053063272*^9}, {3.8112623334671025`*^9, 
  3.8112623551968336`*^9}, {3.81126239257867*^9, 3.811262399404647*^9}, {
  3.8112625967879906`*^9, 
  3.8112626146785884`*^9}},ExpressionUUID->"926029ed-6508-4881-abda-\
ec8f56e9874c"]
}, Open  ]]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Determinants", "Section",
 CellChangeTimes->{{3.8112627911267624`*^9, 
  3.811262792571612*^9}},ExpressionUUID->"64bede95-80e8-4ff1-9e55-\
6ff2908da189"],

Cell[CellGroupData[{

Cell["Introduction to the Determinant", "Subsection",
 CellChangeTimes->{{3.8112630551091595`*^9, 
  3.811263059049713*^9}},ExpressionUUID->"0a39a632-8b96-49b5-84fc-\
aa83962c008c"],

Cell[TextData[{
 "We saw in the previous section how we could represent a transformation of \
coordinate systems by a matrix multiplying the original coordinates. Now we \
consider the matrix representation of a series of ",
 StyleBox["n",
  FontSlant->"Italic"],
 " equations that we would like to solve for ",
 StyleBox["n",
  FontSlant->"Italic"],
 " unknowns. Take a not-so-complicated case where ",
 StyleBox["n",
  FontSlant->"Italic"],
 " = 2,"
}], "Text",
 CellChangeTimes->{{3.81126307331894*^9, 
  3.811263172655336*^9}},ExpressionUUID->"bd43c062-7d8c-49ee-b558-\
2d9f918806a0"],

Cell[BoxData[
 RowBox[{
  SubscriptBox[
   StyleBox["c",
    FontSlant->"Italic"], "1"], "=", 
  RowBox[{
   RowBox[{
    SubscriptBox[
     StyleBox["a",
      FontSlant->"Italic"], "11"], 
    StyleBox["x",
     FontSlant->"Italic"]}], "+", 
   RowBox[{
    SubscriptBox[
     StyleBox["a",
      FontSlant->"Italic"], "12"], 
    StyleBox["y",
     FontSlant->"Italic"]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8112579973997173`*^9, 3.8112580336398363`*^9}, {
  3.8112631898678875`*^9, 
  3.8112632107731953`*^9}},ExpressionUUID->"716846c1-961c-49af-ab07-\
d316f013f0ec"],

Cell[BoxData[
 RowBox[{
  SubscriptBox[
   StyleBox["c",
    FontSlant->"Italic"], "2"], "=", 
  RowBox[{
   RowBox[{
    SubscriptBox[
     StyleBox["a",
      FontSlant->"Italic"], "21"], 
    StyleBox["x",
     FontSlant->"Italic"]}], "+", 
   RowBox[{
    SubscriptBox[
     StyleBox["a",
      FontSlant->"Italic"], "22"], 
    StyleBox["y",
     FontSlant->"Italic"]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8112579973997173`*^9, 3.811258064327943*^9}, {
  3.8112632006902976`*^9, 
  3.811263219644026*^9}},ExpressionUUID->"5d86b26f-25ae-4682-8591-\
753752c0b4f6"],

Cell[TextData[{
 "where we want to solve for ",
 StyleBox["x",
  FontSlant->"Italic"],
 " and ",
 StyleBox["y",
  FontSlant->"Italic"],
 ", and ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["a",
    FontSlant->"Italic"], "11"]],
  CellChangeTimes->{{3.8112579973997173`*^9, 3.8112580336398363`*^9}, {
   3.8112631898678875`*^9, 3.8112632107731953`*^9}},ExpressionUUID->
  "9c6fe6ec-2828-4fb1-bb5d-4c06cd510010"],
 ",",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["a",
    FontSlant->"Italic"], "12"]],
  CellChangeTimes->{{3.8112579973997173`*^9, 3.8112580336398363`*^9}, {
   3.8112631898678875`*^9, 3.8112632107731953`*^9}},ExpressionUUID->
  "370e8aee-6bab-4a8c-9834-35fa8a5c1b4d"],
 ",",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["a",
    FontSlant->"Italic"], "21"]],
  CellChangeTimes->{{3.8112579973997173`*^9, 3.811258064327943*^9}, {
   3.8112632006902976`*^9, 3.811263219644026*^9}},ExpressionUUID->
  "0cc85df4-ef1d-4d59-9ef8-54f7ca7c2f11"],
 ",",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["a",
    FontSlant->"Italic"], "22"]],
  CellChangeTimes->{{3.8112579973997173`*^9, 3.811258064327943*^9}, {
   3.8112632006902976`*^9, 3.811263219644026*^9}},ExpressionUUID->
  "a61f2e2e-f770-4779-bf9f-814b47401035"],
 ", ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["c",
    FontSlant->"Italic"], "1"]],
  CellChangeTimes->{{3.8112579973997173`*^9, 3.8112580336398363`*^9}, {
   3.8112631898678875`*^9, 3.8112632107731953`*^9}},ExpressionUUID->
  "dee4f6d9-611a-463d-adc7-867d451fb0e4"],
 ", and ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["c",
    FontSlant->"Italic"], "2"]],
  CellChangeTimes->{{3.8112579973997173`*^9, 3.8112580336398363`*^9}, {
   3.8112631898678875`*^9, 3.8112632107731953`*^9}},ExpressionUUID->
  "f49dea99-f090-4109-99b2-b475f817920a"],
 " are all known constants. Similar to the case of the transformation in the \
previous section, we can write this set of equations in matrix form as"
}], "Text",
 CellChangeTimes->{{3.811263234599491*^9, 
  3.8112633328187075`*^9}},ExpressionUUID->"c6abbaa4-ba66-46d8-96d9-\
af397bfd23c2"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(", "\[NoBreak]", GridBox[{
     {
      SubscriptBox[
       StyleBox["c",
        FontSlant->"Italic"], "1"]},
     {
      SubscriptBox[
       StyleBox["c",
        FontSlant->"Italic"], "2"]}
    }], "\[NoBreak]", ")"}], 
  StyleBox["=",
   FontWeight->"Plain",
   FontSlant->"Plain"], 
  RowBox[{
   RowBox[{
    RowBox[{"(", "\[NoBreak]", GridBox[{
       {
        SubscriptBox[
         StyleBox["a",
          FontSlant->"Italic"], "11"], 
        SubscriptBox[
         StyleBox["a",
          FontSlant->"Italic"], "12"]},
       {
        SubscriptBox[
         StyleBox["a",
          FontSlant->"Italic"], "21"], 
        SubscriptBox[
         StyleBox["a",
          FontSlant->"Italic"], "22"]}
      }], "\[NoBreak]", ")"}], 
    RowBox[{"(", "\[NoBreak]", GridBox[{
       {
        StyleBox["x",
         FontSlant->"Italic"]},
       {
        StyleBox["y",
         FontSlant->"Italic"]}
      }], "\[NoBreak]", ")"}]}], "=", 
   RowBox[{"(", "\[NoBreak]", GridBox[{
      {
       RowBox[{
        RowBox[{
         SubscriptBox[
          StyleBox["a",
           FontSlant->"Italic"], "11"], 
         StyleBox["x",
          FontSlant->"Italic"]}], "+", 
        RowBox[{
         SubscriptBox[
          StyleBox["a",
           FontSlant->"Italic"], "12"], 
         StyleBox["y",
          FontSlant->"Italic"]}]}]},
      {
       RowBox[{
        RowBox[{
         SubscriptBox[
          StyleBox["a",
           FontSlant->"Italic"], "21"], 
         StyleBox["x",
          FontSlant->"Italic"]}], "+", 
        RowBox[{
         SubscriptBox[
          StyleBox["a",
           FontSlant->"Italic"], "22"], 
         StyleBox["y",
          FontSlant->"Italic"]}]}]}
     }], "\[NoBreak]", ")"}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.811253718311788*^9, 3.8112538382526913`*^9}, {
  3.811257050877017*^9, 3.811257053063272*^9}, {3.8112583347089105`*^9, 
  3.8112583446657734`*^9}, {3.811258452245489*^9, 3.811258475053415*^9}, {
  3.8112633512956667`*^9, 
  3.8112633785905485`*^9}},ExpressionUUID->"76df1131-b67e-485f-80ab-\
b2c89802ee25"],

Cell[TextData[{
 "If we want to solve these equations for ",
 StyleBox["x",
  FontSlant->"Italic"],
 " and ",
 StyleBox["y",
  FontSlant->"Italic"],
 " using a traditional method, we could multiply equation (35) by ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["a",
    FontSlant->"Italic"], "22"]],
  CellChangeTimes->{{3.8112579973997173`*^9, 3.811258064327943*^9}, {
   3.8112632006902976`*^9, 3.811263219644026*^9}},ExpressionUUID->
  "3057a3c1-b2db-4744-947a-c417d25770f7"],
 " and equation (36) by ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["a",
    FontSlant->"Italic"], "12"]],
  CellChangeTimes->{{3.8112579973997173`*^9, 3.8112580336398363`*^9}, {
   3.8112631898678875`*^9, 3.8112632107731953`*^9}},ExpressionUUID->
  "b645f329-042a-49ed-8c53-b5d3b7b5437e"],
 " and then subtract,"
}], "Text",
 CellChangeTimes->{{3.8112637086490054`*^9, 
  3.8112638600399065`*^9}},ExpressionUUID->"75f203d1-05f7-42d1-b280-\
96a142ed7711"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    SubscriptBox[
     StyleBox["a",
      FontSlant->"Italic"], "22"], 
    SubscriptBox[
     StyleBox["c",
      FontSlant->"Italic"], "1"]}], "-", 
   RowBox[{
    SubscriptBox[
     StyleBox["a",
      FontSlant->"Italic"], "12"], 
    SubscriptBox[
     StyleBox["c",
      FontSlant->"Italic"], "2"]}]}], "=", 
  RowBox[{
   RowBox[{"(", 
    RowBox[{
     RowBox[{
      SubscriptBox[
       StyleBox["a",
        FontSlant->"Italic"], "11"], 
      SubscriptBox[
       StyleBox["a",
        FontSlant->"Italic"], "22"]}], "-", 
     RowBox[{
      SubscriptBox[
       StyleBox["a",
        FontSlant->"Italic"], "12"], 
      SubscriptBox[
       StyleBox["a",
        FontSlant->"Italic"], "21"]}]}], ")"}], 
   StyleBox["x",
    FontSlant->"Italic"]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8112579973997173`*^9, 3.8112580336398363`*^9}, {
  3.8112631898678875`*^9, 3.8112632107731953`*^9}, {3.8112638887305593`*^9, 
  3.8112639009445176`*^9}, {3.811263938688391*^9, 
  3.811263978756982*^9}},ExpressionUUID->"c2209137-ac83-4fbd-849f-\
94d153f671c2"],

Cell[TextData[{
 "By multiplying equation (35) by ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["a",
    FontSlant->"Italic"], "21"]],
  CellChangeTimes->{{3.8112579973997173`*^9, 3.811258064327943*^9}, {
   3.8112632006902976`*^9, 3.811263219644026*^9}},ExpressionUUID->
  "3f18b268-9ebb-4ad1-b2a6-e5e2336a261d"],
 " and equation (36) by ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["a",
    FontSlant->"Italic"], "11"]],
  CellChangeTimes->{{3.8112579973997173`*^9, 3.8112580336398363`*^9}, {
   3.8112631898678875`*^9, 3.8112632107731953`*^9}},ExpressionUUID->
  "49d5a3ab-3d8e-4523-8597-7c8762cfff86"],
 " and then subtracting, we get a similar equation that we can solve for ",
 StyleBox["y",
  FontSlant->"Italic"],
 ","
}], "Text",
 CellChangeTimes->{{3.8112640905784516`*^9, 
  3.8112641627010965`*^9}},ExpressionUUID->"c3676e29-619d-4254-a465-\
be47e13abddd"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    SubscriptBox[
     StyleBox["a",
      FontSlant->"Italic"], "11"], 
    SubscriptBox[
     StyleBox["c",
      FontSlant->"Italic"], "2"]}], "-", 
   RowBox[{
    SubscriptBox[
     StyleBox["a",
      FontSlant->"Italic"], "21"], 
    SubscriptBox[
     StyleBox["c",
      FontSlant->"Italic"], "1"]}]}], "=", 
  RowBox[{
   RowBox[{"(", 
    RowBox[{
     RowBox[{
      SubscriptBox[
       StyleBox["a",
        FontSlant->"Italic"], "11"], 
      SubscriptBox[
       StyleBox["a",
        FontSlant->"Italic"], "22"]}], "-", 
     RowBox[{
      SubscriptBox[
       StyleBox["a",
        FontSlant->"Italic"], "12"], 
      SubscriptBox[
       StyleBox["a",
        FontSlant->"Italic"], "21"]}]}], ")"}], 
   StyleBox["y",
    FontSlant->"Italic"]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8112579973997173`*^9, 3.8112580336398363`*^9}, {
  3.8112631898678875`*^9, 3.8112632107731953`*^9}, {3.8112638887305593`*^9, 
  3.8112639009445176`*^9}, {3.811263938688391*^9, 3.811263978756982*^9}, {
  3.8112641688236957`*^9, 3.811264184795977*^9}, {3.8112642524322915`*^9, 
  3.811264274574235*^9}},ExpressionUUID->"cdc553f0-9d65-4ffc-b8d8-\
39b42c0181ed"],

Cell[TextData[{
 "Notice that the term ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    SubscriptBox[
     StyleBox["a",
      FontSlant->"Italic"], "11"], 
    SubscriptBox[
     StyleBox["a",
      FontSlant->"Italic"], "22"]}], "-", 
   RowBox[{
    SubscriptBox[
     StyleBox["a",
      FontSlant->"Italic"], "12"], 
    SubscriptBox[
     StyleBox["a",
      FontSlant->"Italic"], "21"]}]}]],
  CellChangeTimes->{{3.8112579973997173`*^9, 3.8112580336398363`*^9}, {
   3.8112631898678875`*^9, 3.8112632107731953`*^9}, {3.8112638887305593`*^9, 
   3.8112639009445176`*^9}, {3.811263938688391*^9, 3.811263978756982*^9}, {
   3.8112641688236957`*^9, 3.811264184795977*^9}, {3.8112642524322915`*^9, 
   3.811264274574235*^9}},ExpressionUUID->
  "7812ce8c-d5e0-400c-a043-96cb49557cc0"],
 " appears in both equations. It turns out that this quantity represents the \
determinant of our matrix ",
 StyleBox["A",
  FontWeight->"Bold"],
 ","
}], "Text",
 CellChangeTimes->{{3.8112643047920303`*^9, 
  3.811264365856537*^9}},ExpressionUUID->"5d50016d-5499-499b-8fc3-\
358a7c7733b2"],

Cell[BoxData[
 RowBox[{
  RowBox[{"det", " ", 
   StyleBox["A",
    FontWeight->"Bold"]}], 
  StyleBox["=",
   FontWeight->"Plain",
   FontSlant->"Plain"], 
  RowBox[{
   RowBox[{"\[LeftBracketingBar]", GridBox[{
      {
       SubscriptBox[
        StyleBox["a",
         FontSlant->"Italic"], "11"], 
       SubscriptBox[
        StyleBox["a",
         FontSlant->"Italic"], "12"]},
      {
       SubscriptBox[
        StyleBox["a",
         FontSlant->"Italic"], "21"], 
       SubscriptBox[
        StyleBox["a",
         FontSlant->"Italic"], "22"]}
     }], "\[NoBreak]", "\[RightBracketingBar]"}], "=", 
   RowBox[{
    RowBox[{
     SubscriptBox[
      StyleBox["a",
       FontSlant->"Italic"], "11"], 
     SubscriptBox[
      StyleBox["a",
       FontSlant->"Italic"], "22"]}], "-", 
    RowBox[{
     SubscriptBox[
      StyleBox["a",
       FontSlant->"Italic"], "12"], 
     SubscriptBox[
      StyleBox["a",
       FontSlant->"Italic"], "21"]}]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.811253718311788*^9, 3.8112538382526913`*^9}, {
  3.811257050877017*^9, 3.811257053063272*^9}, {3.8112583347089105`*^9, 
  3.8112583446657734`*^9}, {3.811258452245489*^9, 3.811258475053415*^9}, {
  3.8112633512956667`*^9, 3.8112633785905485`*^9}, {3.811264373097485*^9, 
  3.8112644329333887`*^9}},ExpressionUUID->"9ac7aee0-da07-4540-a446-\
dfa37ce07f33"],

Cell["\<\
If we look closely at the form our solutions, we may see that \
\>", "Text",
 CellChangeTimes->{{3.8112647212627726`*^9, 
  3.811264729375184*^9}},ExpressionUUID->"613db26e-7bb3-47cc-9e43-\
18d8fc114f21"],

Cell[BoxData[
 RowBox[{
  StyleBox["x",
   FontSlant->"Italic"], "=", 
  RowBox[{
   FractionBox[
    RowBox[{
     RowBox[{
      SubscriptBox[
       StyleBox["a",
        FontSlant->"Italic"], "22"], 
      SubscriptBox[
       StyleBox["c",
        FontSlant->"Italic"], "1"]}], "-", 
     RowBox[{
      SubscriptBox[
       StyleBox["a",
        FontSlant->"Italic"], "12"], 
      SubscriptBox[
       StyleBox["c",
        FontSlant->"Italic"], "2"]}]}], 
    RowBox[{
     RowBox[{
      SubscriptBox[
       StyleBox["a",
        FontSlant->"Italic"], "11"], 
      SubscriptBox[
       StyleBox["a",
        FontSlant->"Italic"], "22"]}], "-", 
     RowBox[{
      SubscriptBox[
       StyleBox["a",
        FontSlant->"Italic"], "12"], 
      SubscriptBox[
       StyleBox["a",
        FontSlant->"Italic"], "21"]}]}]], "=", 
   FractionBox[
    RowBox[{"\[LeftBracketingBar]", GridBox[{
       {
        SubscriptBox[
         StyleBox["c",
          FontSlant->"Italic"], "1"], 
        SubscriptBox[
         StyleBox["a",
          FontSlant->"Italic"], "12"]},
       {
        SubscriptBox[
         StyleBox["c",
          FontSlant->"Italic"], "2"], 
        SubscriptBox[
         StyleBox["a",
          FontSlant->"Italic"], "22"]}
      }], "\[NoBreak]", "\[RightBracketingBar]"}], 
    RowBox[{"\[LeftBracketingBar]", GridBox[{
       {
        SubscriptBox[
         StyleBox["a",
          FontSlant->"Italic"], "11"], 
        SubscriptBox[
         StyleBox["a",
          FontSlant->"Italic"], "12"]},
       {
        SubscriptBox[
         StyleBox["a",
          FontSlant->"Italic"], "21"], 
        SubscriptBox[
         StyleBox["a",
          FontSlant->"Italic"], "22"]}
      }], "\[NoBreak]", 
     "\[RightBracketingBar]"}]]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8112579973997173`*^9, 3.8112580336398363`*^9}, {
  3.8112631898678875`*^9, 3.8112632107731953`*^9}, {3.8112638887305593`*^9, 
  3.8112639009445176`*^9}, {3.811263938688391*^9, 3.811263978756982*^9}, {
  3.8112647554222155`*^9, 
  3.8112648146591043`*^9}},ExpressionUUID->"2edd9a0e-7a43-4fad-8a42-\
e8fcb09ae051"],

Cell["and ", "Text",
 CellChangeTimes->{{3.8112648256060963`*^9, 
  3.8112648261459885`*^9}},ExpressionUUID->"968eda9c-c9ad-478b-bb62-\
b33ad130d7db"],

Cell[BoxData[
 RowBox[{
  StyleBox["y",
   FontSlant->"Italic"], "=", 
  RowBox[{
   FractionBox[
    RowBox[{
     RowBox[{
      SubscriptBox[
       StyleBox["a",
        FontSlant->"Italic"], "11"], 
      SubscriptBox[
       StyleBox["c",
        FontSlant->"Italic"], "2"]}], "-", 
     RowBox[{
      SubscriptBox[
       StyleBox["a",
        FontSlant->"Italic"], "21"], 
      SubscriptBox[
       StyleBox["c",
        FontSlant->"Italic"], "1"]}]}], 
    RowBox[{
     RowBox[{
      SubscriptBox[
       StyleBox["a",
        FontSlant->"Italic"], "11"], 
      SubscriptBox[
       StyleBox["a",
        FontSlant->"Italic"], "22"]}], "-", 
     RowBox[{
      SubscriptBox[
       StyleBox["a",
        FontSlant->"Italic"], "12"], 
      SubscriptBox[
       StyleBox["a",
        FontSlant->"Italic"], "21"]}]}]], "=", 
   FractionBox[
    RowBox[{"\[LeftBracketingBar]", GridBox[{
       {
        SubscriptBox[
         StyleBox["a",
          FontSlant->"Italic"], "11"], 
        SubscriptBox[
         StyleBox["c",
          FontSlant->"Italic"], "1"]},
       {
        SubscriptBox[
         StyleBox["a",
          FontSlant->"Italic"], "21"], 
        SubscriptBox[
         StyleBox["c",
          FontSlant->"Italic"], "2"]}
      }], "\[NoBreak]", "\[RightBracketingBar]"}], 
    RowBox[{"\[LeftBracketingBar]", GridBox[{
       {
        SubscriptBox[
         StyleBox["a",
          FontSlant->"Italic"], "11"], 
        SubscriptBox[
         StyleBox["a",
          FontSlant->"Italic"], "12"]},
       {
        SubscriptBox[
         StyleBox["a",
          FontSlant->"Italic"], "21"], 
        SubscriptBox[
         StyleBox["a",
          FontSlant->"Italic"], "22"]}
      }], "\[NoBreak]", 
     "\[RightBracketingBar]"}]]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8112579973997173`*^9, 3.8112580336398363`*^9}, {
  3.8112631898678875`*^9, 3.8112632107731953`*^9}, {3.8112638887305593`*^9, 
  3.8112639009445176`*^9}, {3.811263938688391*^9, 3.811263978756982*^9}, {
  3.8112641688236957`*^9, 3.811264184795977*^9}, {3.8112642524322915`*^9, 
  3.811264274574235*^9}, {3.811264840078515*^9, 
  3.8112648754011626`*^9}},ExpressionUUID->"8890ef89-0f91-4adf-a7db-\
571163c8215e"],

Cell["\<\
Thus, determinants provide an easy way to solve a system of equations. We \
will see that we can expand this result to a larger number of equations and \
unknowns.\
\>", "Text",
 CellChangeTimes->{{3.8112648852445283`*^9, 
  3.8112649560246325`*^9}},ExpressionUUID->"b2ca1ad5-1b95-47de-8197-\
fe3247c82877"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Determinants of Larger Matrices", "Subsection",
 CellChangeTimes->{{3.8112630551091595`*^9, 3.811263059049713*^9}, {
  3.8112651399512525`*^9, 
  3.81126515044245*^9}},ExpressionUUID->"b233b62c-ab97-4a4b-9d37-\
678265eda829"],

Cell[TextData[{
 "The determinant is only defined for square matrices but can be calculated \
for any ",
 StyleBox["n",
  FontSlant->"Italic"],
 " \[Cross] ",
 StyleBox["n",
  FontSlant->"Italic"],
 " matrix with any value of ",
 StyleBox["n",
  FontSlant->"Italic"],
 " . We can write out the determinant of a 3 \[Cross] 3 matrix as"
}], "Text",
 CellChangeTimes->{{3.8112651536851788`*^9, 3.811265260013297*^9}, {
  3.842249512838415*^9, 
  3.8422495274173627`*^9}},ExpressionUUID->"e55e4e28-4bbb-4785-aa4f-\
65d34868e9cb"],

Cell[BoxData[
 RowBox[{
  RowBox[{"\[LeftBracketingBar]", "\[NoBreak]", GridBox[{
     {
      SubscriptBox[
       StyleBox["a",
        FontSlant->"Italic"], "11"], 
      SubscriptBox[
       StyleBox["a",
        FontSlant->"Italic"], "12"], 
      SubscriptBox[
       StyleBox["a",
        FontSlant->"Italic"], "13"]},
     {
      SubscriptBox[
       StyleBox["a",
        FontSlant->"Italic"], "21"], 
      SubscriptBox[
       StyleBox["a",
        FontSlant->"Italic"], "22"], 
      SubscriptBox[
       StyleBox["a",
        FontSlant->"Italic"], "23"]},
     {
      SubscriptBox[
       StyleBox["a",
        FontSlant->"Italic"], "31"], 
      SubscriptBox[
       StyleBox["a",
        FontSlant->"Italic"], "32"], 
      SubscriptBox[
       StyleBox["a",
        FontSlant->"Italic"], "33"]}
    }], "\[NoBreak]", "\[RightBracketingBar]"}], "=", 
  RowBox[{
   RowBox[{
    SubscriptBox[
     StyleBox["a",
      FontSlant->"Italic"], "11"], " ", 
    SubscriptBox[
     StyleBox["a",
      FontSlant->"Italic"], "22"], " ", 
    SubscriptBox[
     StyleBox["a",
      FontSlant->"Italic"], "33"]}], "-", 
   RowBox[{
    SubscriptBox[
     StyleBox["a",
      FontSlant->"Italic"], "11"], " ", 
    SubscriptBox[
     StyleBox["a",
      FontSlant->"Italic"], "23"], " ", 
    SubscriptBox[
     StyleBox["a",
      FontSlant->"Italic"], "32"]}], "+", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{
       SubscriptBox[
        StyleBox["a",
         FontSlant->"Italic"], "12"], " ", 
       SubscriptBox[
        StyleBox["a",
         FontSlant->"Italic"], "21"], " ", 
       SubscriptBox[
        StyleBox["a",
         FontSlant->"Italic"], "33"]}], "\[Minus]", 
      RowBox[{
       SubscriptBox[
        StyleBox["a",
         FontSlant->"Italic"], "12"], " ", 
       SubscriptBox[
        StyleBox["a",
         FontSlant->"Italic"], "23"], " ", 
       SubscriptBox[
        StyleBox["a",
         FontSlant->"Italic"], "31"]}]}], ")"}], 
    RowBox[{"(", 
     RowBox[{"\[Minus]", "1"}], ")"}]}], "+", 
   RowBox[{
    SubscriptBox[
     StyleBox["a",
      FontSlant->"Italic"], "13"], " ", 
    SubscriptBox[
     StyleBox["a",
      FontSlant->"Italic"], "21"], " ", 
    SubscriptBox[
     StyleBox["a",
      FontSlant->"Italic"], "32"]}], "-", 
   RowBox[{
    SubscriptBox[
     StyleBox["a",
      FontSlant->"Italic"], "13"], " ", 
    SubscriptBox[
     StyleBox["a",
      FontSlant->"Italic"], "22"], " ", 
    SubscriptBox[
     StyleBox["a",
      FontSlant->"Italic"], "31"]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.811265305025379*^9, 3.8112653809186306`*^9}, {
   3.8112654151611004`*^9, 3.811265446871749*^9}, 3.8112654923119383`*^9, {
   3.8112655542772503`*^9, 3.8112655555933075`*^9}, {3.8112656177694793`*^9, 
   3.811265623875159*^9}, {3.8422496335074034`*^9, 3.8422496570251303`*^9}, 
   3.8422496897991652`*^9},ExpressionUUID->"9559ff3c-b714-476d-8c0e-\
55e44c1b6b7b"],

Cell[TextData[{
 "You can calculate the determinant of a matrix by using the cofactors. The \
cofactor ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["C",
    FontSlant->"Italic"], 
   StyleBox["ij",
    FontSlant->"Italic"]]],
  CellChangeTimes->{{3.8112579973997173`*^9, 3.8112580336398363`*^9}, {
   3.8112631898678875`*^9, 3.8112632107731953`*^9}},ExpressionUUID->
  "7030ddcb-c380-4e8f-aefa-6ead6ae12520"],
 " of a matrix element ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["a",
    FontSlant->"Italic"], 
   StyleBox["ij",
    FontSlant->"Italic"]]],
  CellChangeTimes->{{3.811265305025379*^9, 3.8112653809186306`*^9}, {
    3.8112654151611004`*^9, 3.811265446871749*^9}, 3.8112654923119383`*^9, {
    3.8112655542772503`*^9, 3.8112655555933075`*^9}, {3.8112656177694793`*^9, 
    3.811265623875159*^9}},ExpressionUUID->
  "081c36f9-3136-4265-ad5e-ad1e754ec030"],
 " is a determinant of dimensions ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"(", 
    RowBox[{
     StyleBox["n",
      FontSlant->"Italic"], "-", "1"}], ")"}], "\[Cross]", 
   RowBox[{"(", 
    RowBox[{
     StyleBox["n",
      FontSlant->"Italic"], "-", "1"}], ")"}]}]],
  CellChangeTimes->{{3.811265305025379*^9, 3.8112653809186306`*^9}, {
    3.8112654151611004`*^9, 3.811265446871749*^9}, 3.8112654923119383`*^9, {
    3.8112655542772503`*^9, 3.8112655555933075`*^9}, {3.8112656177694793`*^9, 
    3.811265623875159*^9}},ExpressionUUID->
  "92e83d72-cd8d-4fc3-bc96-2d7c8c8bf58f"],
 "formed by deleting the row and column of ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["a",
    FontSlant->"Italic"], 
   StyleBox["ij",
    FontSlant->"Italic"]]],
  CellChangeTimes->{{3.811265305025379*^9, 3.8112653809186306`*^9}, {
    3.8112654151611004`*^9, 3.811265446871749*^9}, 3.8112654923119383`*^9, {
    3.8112655542772503`*^9, 3.8112655555933075`*^9}, {3.8112656177694793`*^9, 
    3.811265623875159*^9}},ExpressionUUID->
  "6f159bdb-c44a-4d03-9f8e-f91019a49aef"],
 " and multiplying by ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    RowBox[{"(", 
     RowBox[{"-", "1"}], ")"}], 
    RowBox[{"i", "+", "j"}]], TraditionalForm]],ExpressionUUID->
  "813e7d3c-4fd1-4317-9a5c-81ceb3961522"],
 ". So you could write the determinant of the matrix in equation (43) as"
}], "Text",
 CellChangeTimes->{{3.811265701331678*^9, 3.8112657021708956`*^9}, {
  3.8112657778919363`*^9, 3.811265958884903*^9}, {3.8112660044266634`*^9, 
