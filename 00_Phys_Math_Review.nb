    False, $CellContext`R$218204$$ = False, $CellContext`comp$218205$$ = 
    False, $CellContext`m$218206$$ = 0}, 
    DynamicBox[Manipulate`ManipulateBoxes[
     1, StandardForm, 
      "Variables" :> {$CellContext`comp$$ = False, $CellContext`F$$ = 
        False, $CellContext`m$$ = 0.05, $CellContext`R$$ = 
        False, $CellContext`tmax$$ = 0}, "ControllerVariables" :> {
        Hold[$CellContext`tmax$$, $CellContext`tmax$218202$$, 0], 
        Hold[$CellContext`F$$, $CellContext`F$218203$$, False], 
        Hold[$CellContext`R$$, $CellContext`R$218204$$, False], 
        Hold[$CellContext`comp$$, $CellContext`comp$218205$$, False], 
        Hold[$CellContext`m$$, $CellContext`m$218206$$, 0]}, 
      "OtherVariables" :> {
       Typeset`show$$, Typeset`bookmarkList$$, Typeset`bookmarkMode$$, 
        Typeset`animator$$, Typeset`animvar$$, Typeset`name$$, 
        Typeset`specs$$, Typeset`size$$, Typeset`update$$, Typeset`initDone$$,
         Typeset`skipInitDone$$}, "Body" :> 
      Module[{$CellContext`sol$, $CellContext`\[Theta]$, $CellContext`t$}, \
$CellContext`sol$ = 
         NDSolve[{
           Derivative[2][$CellContext`\[Theta]$][$CellContext`t$] == (-9.81) 
             Sin[
               $CellContext`\[Theta]$[$CellContext`t$]], 
            Derivative[1][$CellContext`\[Theta]$][0] == 
            0, $CellContext`\[Theta]$[0] == (-Pi)/
             2}, $CellContext`\[Theta]$, {$CellContext`t$, 
            0, $CellContext`tmax$$}]; 
        With[{$CellContext`\[CurlyPhi]$ = ReplaceAll[
             $CellContext`\[Theta]$[$CellContext`tmax$$], 
             First[$CellContext`sol$]], $CellContext`\[Omega]$ = ReplaceAll[
             Derivative[1][$CellContext`\[Theta]$][$CellContext`tmax$$], 
             First[$CellContext`sol$]], $CellContext`g$ = 9.81}, 
          Pane[
           Graphics[{
             Point[{0, 0}], 
             Text["O", {0, 0}, {-2, -2}], Gray, {
              ColorData["WebSafe"]["#99CC00"], 
              Opacity[0.6], 
              Disk[{0, 0}, 1, {-Pi, $CellContext`\[CurlyPhi]$ - Pi/2}]}, {
              PointSize[
               Sqrt[$CellContext`m$$/20]], 
              Point[{
                Sin[$CellContext`\[CurlyPhi]$], -
                Cos[$CellContext`\[CurlyPhi]$]}]}, {
              Dashing[{0.01, 0.01}], 
              Circle[{0, 0}, 1, {-Pi, 0}]}, 
             If[$CellContext`F$$ == True, {
               Thickness[0.008], 
               ColorData["WebSafe"]["#3399CC"], 
               Arrow[{{
                  Sin[$CellContext`\[CurlyPhi]$], -
                  Cos[$CellContext`\[CurlyPhi]$]}, (-1 + $CellContext`m$$ \
$CellContext`\[Omega]$^2 + ($CellContext`g$ $CellContext`m$$) 
                   Cos[$CellContext`\[CurlyPhi]$]) {-
                   Sin[$CellContext`\[CurlyPhi]$], 
                   Cos[$CellContext`\[CurlyPhi]$]}}], 
               Text[
               "\!\(\*OverscriptBox[\(T\), \(\[RightArrow]\)]\)", (-1 + \
$CellContext`m$$ $CellContext`\[Omega]$^2 + ($CellContext`g$ $CellContext`m$$)
                    Cos[$CellContext`\[CurlyPhi]$]) {-
                  Sin[$CellContext`\[CurlyPhi]$], 
                  Cos[$CellContext`\[CurlyPhi]$]}, {-2, -1}], 
               Arrow[{{
                  Sin[$CellContext`\[CurlyPhi]$], -
                  Cos[$CellContext`\[CurlyPhi]$]}, {
                  
                  Sin[$CellContext`\[CurlyPhi]$], (-$CellContext`g$) \
$CellContext`m$$ - Cos[$CellContext`\[CurlyPhi]$]}}], 
               Text[
               "\!\(\*SubscriptBox[\(m\), \
\(\[InvisibleSpace]\)]\)\!\(\*OverscriptBox[\(\( \)\(g\)\), \
\(\[RightArrow]\)]\)", {
                 
                 Sin[$CellContext`\[CurlyPhi]$], (-$CellContext`g$) \
$CellContext`m$$ - Cos[$CellContext`\[CurlyPhi]$]}, {-1, 1}]}, 
              Line[{{0, 0}, {
                 Sin[$CellContext`\[CurlyPhi]$], -
                 Cos[$CellContext`\[CurlyPhi]$]}}]], 
             If[$CellContext`comp$$ == True, {
               Thickness[0.008], 
               ColorData["WebSafe"]["#FF9933"], 
               Arrow[{{
                  Sin[$CellContext`\[CurlyPhi]$], -
                  Cos[$CellContext`\[CurlyPhi]$]}, (
                  1 - $CellContext`m$$ $CellContext`\[Omega]$^2) {
                   Sin[$CellContext`\[CurlyPhi]$], -
                   Cos[$CellContext`\[CurlyPhi]$]}}], 
               Text[
               "\!\(\*OverscriptBox[SubscriptBox[\(R\), \(\[UpTee]\)], \(\
\[RightArrow]\)]\)", (1 - $CellContext`m$$ $CellContext`\[Omega]$^2) {
                  Sin[$CellContext`\[CurlyPhi]$], -
                  Cos[$CellContext`\[CurlyPhi]$]}, {-2, -1}], 
               Arrow[{{
                  Sin[$CellContext`\[CurlyPhi]$], -
                  Cos[$CellContext`\[CurlyPhi]$]}, {(
                   1 - ($CellContext`g$ $CellContext`m$$) 
                   Cos[$CellContext`\[CurlyPhi]$]) 
                  Sin[$CellContext`\[CurlyPhi]$], -
                   Cos[$CellContext`\[CurlyPhi]$] - ($CellContext`g$ \
$CellContext`m$$) Sin[$CellContext`\[CurlyPhi]$]^2}}], 
               Text[
               "\!\(\*OverscriptBox[SubscriptBox[\(R\), \(//\)], \(\
\[RightArrow]\)]\)", {(1 - ($CellContext`g$ $CellContext`m$$) 
                  Cos[$CellContext`\[CurlyPhi]$]) 
                 Sin[$CellContext`\[CurlyPhi]$], -
                  Cos[$CellContext`\[CurlyPhi]$] - ($CellContext`g$ \
$CellContext`m$$) Sin[$CellContext`\[CurlyPhi]$]^2}, {-2, -1}]}, 
              Point[{0, 0}]], 
             If[$CellContext`R$$ == True, {{
                Thickness[0.008], 
                ColorData["WebSafe"]["#CC0099"], 
                Arrow[{{
                   Sin[$CellContext`\[CurlyPhi]$], -
                   Cos[$CellContext`\[CurlyPhi]$]}, {(
                    1 - $CellContext`m$$ $CellContext`\[Omega]$^2 - \
($CellContext`g$ $CellContext`m$$) Cos[$CellContext`\[CurlyPhi]$]) 
                   Sin[$CellContext`\[CurlyPhi]$], (-$CellContext`g$) \
$CellContext`m$$ + 
                   Cos[$CellContext`\[CurlyPhi]$] (-1 + $CellContext`m$$ \
$CellContext`\[Omega]$^2 + ($CellContext`g$ $CellContext`m$$) 
                    Cos[$CellContext`\[CurlyPhi]$])}}], 
                Text[
                "\!\(\*OverscriptBox[\(R\), \(\[RightArrow]\)]\)", {(
                   1 - $CellContext`m$$ $CellContext`\[Omega]$^2 - \
($CellContext`g$ $CellContext`m$$) Cos[$CellContext`\[CurlyPhi]$]) 
                  Sin[$CellContext`\[CurlyPhi]$], (-$CellContext`g$) \
$CellContext`m$$ + 
                  Cos[$CellContext`\[CurlyPhi]$] (-1 + $CellContext`m$$ \
$CellContext`\[Omega]$^2 + ($CellContext`g$ $CellContext`m$$) 
                    Cos[$CellContext`\[CurlyPhi]$])}, {-2, -1}]}, 
               If[$CellContext`F$$ == True, {
                 Dashing[{0.01, 0.008}], 
                 Line[{{
                    
                    Sin[$CellContext`\[CurlyPhi]$], (-$CellContext`g$) \
$CellContext`m$$ - Cos[$CellContext`\[CurlyPhi]$]}, {(
                    1 - $CellContext`m$$ $CellContext`\[Omega]$^2 - \
($CellContext`g$ $CellContext`m$$) Cos[$CellContext`\[CurlyPhi]$]) 
                    Sin[$CellContext`\[CurlyPhi]$], (-$CellContext`g$) \
$CellContext`m$$ + 
                    Cos[$CellContext`\[CurlyPhi]$] (-1 + $CellContext`m$$ \
$CellContext`\[Omega]$^2 + ($CellContext`g$ $CellContext`m$$) 
                    Cos[$CellContext`\[CurlyPhi]$])}}], 
                 
                 Line[{{(
                    1 - $CellContext`m$$ $CellContext`\[Omega]$^2 - \
($CellContext`g$ $CellContext`m$$) Cos[$CellContext`\[CurlyPhi]$]) 
                    Sin[$CellContext`\[CurlyPhi]$], (-$CellContext`g$) \
$CellContext`m$$ + 
                    Cos[$CellContext`\[CurlyPhi]$] (-1 + $CellContext`m$$ \
$CellContext`\[Omega]$^2 + ($CellContext`g$ $CellContext`m$$) 
                    Cos[$CellContext`\[CurlyPhi]$])}, {(
                    1 - $CellContext`m$$ $CellContext`\[Omega]$^2 - \
($CellContext`g$ $CellContext`m$$) Cos[$CellContext`\[CurlyPhi]$]) 
                    Sin[$CellContext`\[CurlyPhi]$], 
                    Cos[$CellContext`\[CurlyPhi]$] (-1 + $CellContext`m$$ \
$CellContext`\[Omega]$^2 + ($CellContext`g$ $CellContext`m$$) 
                    Cos[$CellContext`\[CurlyPhi]$])}}]}, 
                PointSize[0.01], 
                Point[{0, 0}]]}, {
               PointSize[0.01], 
               Point[{0, 0}]}]}, PlotRange -> {{-1.1, 1.2}, {-1.7, 0.6}}, 
            ImageSize -> {500, 400}], {500, 400}]]], 
      "Specifications" :> {{{$CellContext`tmax$$, 0, "time in second"}, 0, 
         1.184, 0.001, Appearance -> "Labeled", ImageSize -> 
         Tiny}, {{$CellContext`F$$, False, "show forces"}, {
         False, True}}, {{$CellContext`R$$, False, 
          "resultant \!\(\*OverscriptBox[\(R\), \(\[RightArrow]\)]\)"}, {
         False, True}}, {{$CellContext`comp$$, False, 
          "normal and tangential"}, {
         False, True}}, {{$CellContext`m$$, 0.05, "mass m kg"}, 0.02, 0.05, 
         0.001, Appearance -> "Labeled", ImageSize -> Tiny}}, 
      "Options" :> {
       ControlPlacement -> Top, AutorunSequencing -> {2, 3, 4, 5}}, 
      "DefaultOptions" :> {ControllerLinking -> True}],
     ImageSizeCache->{
      598.6385714285715, {290.60660513581536`, 296.91173238328486`}},
