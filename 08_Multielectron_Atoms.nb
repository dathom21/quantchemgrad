   3.8119468581508093`*^9},ExpressionUUID->"aa9dab24-c089-493f-bfb3-\
78c0d51b3cb0"],

Cell["\<\
As we saw in the last section, this approximation is not strictly correct, \
and we also need to account for spin. Furthermore, we must make sure that the \
form of our wavefunction is consistent with the antisymmetric exchange \
condition, so we must write\
\>", "Text",
 CellChangeTimes->{{3.81262803367276*^9, 
  3.8126281171465435`*^9}},ExpressionUUID->"2e39ff0e-872c-4d29-a073-\
e71deb574c03"],

Cell[BoxData[
 RowBox[{
  RowBox[{"\[Psi]", 
   RowBox[{"(", 
    RowBox[{
     SubscriptBox[
      StyleBox["r",
       FontWeight->"Bold",
       FontSlant->"Italic"], "1"], ",", 
     SubscriptBox["\[Sigma]", "1"], ",", " ", 
     SubscriptBox[
      StyleBox["r",
       FontWeight->"Bold",
       FontSlant->"Italic"], "2"], ",", 
     SubscriptBox["\[Sigma]", "2"]}], ")"}]}], "=", 
  RowBox[{
   FractionBox["1", 
    SqrtBox["2"]], "\[Phi]", 
   RowBox[{"(", 
    SubscriptBox[
     StyleBox["r",
      FontWeight->"Bold",
      FontSlant->"Italic"], "1"], ")"}], "\[Phi]", 
   RowBox[{
    RowBox[{"(", 
     SubscriptBox[
      StyleBox["r",
       FontWeight->"Bold",
       FontSlant->"Italic"], "2"], ")"}], "[", 
    RowBox[{
     RowBox[{"\[Alpha]", 
      RowBox[{"(", 
       SubscriptBox["\[Sigma]", "1"], ")"}], "\[Beta]", 
      RowBox[{"(", 
       SubscriptBox["\[Sigma]", "2"], ")"}]}], "-", 
     RowBox[{"\[Beta]", 
      RowBox[{"(", 
       SubscriptBox["\[Sigma]", "1"], ")"}], "\[Alpha]", 
      RowBox[{"(", 
       SubscriptBox["\[Sigma]", "2"], ")"}]}]}], 
    "]"}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.810112811439228*^9, 3.8101128248442793`*^9}, {
