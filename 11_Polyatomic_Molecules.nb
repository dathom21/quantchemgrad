Cell[TextData[{
 StyleBox["Figure 11.2",
  FontWeight->"Bold"],
 ". Molecular orbitals of ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["BeH", "2"], TraditionalForm]],ExpressionUUID->
  "be4494d1-f967-478d-ba74-2e97bf6b82c3"],
 ". Modified from: Wikimedia, Chem540f09grp5, Public Domain, \
https://commons.wikimedia.org/wiki/File:Walshdiagram.gif"
}], "Affiliation",
 CellChangeTimes->{{3.809435027311596*^9, 3.8094350763900714`*^9}, {
  3.80943583474421*^9, 3.8094358359299717`*^9}, {3.8094472165104203`*^9, 
  3.809447281165168*^9}, {3.809510876137825*^9, 3.809510907739876*^9}, {
  3.809968073566992*^9, 3.8099681536568317`*^9}, {3.810557260250428*^9, 
  3.8105572606139913`*^9}, {3.8130835305386977`*^9, 3.8130836194514275`*^9}, {
  3.813224407772764*^9, 3.8132244817756805`*^9}, {3.814107987969291*^9, 
  3.814108049630145*^9}, {3.814109089245699*^9, 3.8141091270231557`*^9}, {
  3.8141093100266285`*^9, 3.814109310147791*^9}, {3.814109921841116*^9, 
  3.8141099219695177`*^9}, {3.8141099776142817`*^9, 3.8141100720635233`*^9}, {
  3.814117676987705*^9, 3.8141177066264424`*^9}, {3.8142785194696302`*^9, 
  3.814278521090821*^9}, {3.8142785626923523`*^9, 3.814278656139146*^9}, {
  3.814286321864889*^9, 3.8142863720594077`*^9}, {3.938870881737112*^9, 
  3.9388708818327904`*^9}},ExpressionUUID->"74c19e40-a895-40da-9eba-\
ee4cc11233b3"],

Cell[TextData[{
 "As the H\[Dash]A\[Dash]H bond angle changes, the molecular orbitals will \
also change. For example, before the two 2",
 StyleBox["p",
  FontSlant->"Italic"],
 " orbitals that were orthogonal to the internuclear axis will begin to \
overlap with the hydrogen 1",
 StyleBox["s",
  FontSlant->"Italic"],
 " orbitals, leading to new mixing of the orbitals and new solutions to the \
eigenvalue problem. We can visualize these changes by plotting the energies \
of the molecular orbitals as a function of the bond angle in what is known as \
a Walsh correlation diagram. "
}], "Text",
 CellChangeTimes->{{3.8142864222393236`*^9, 3.8142865633914347`*^9}, {
  3.814286596190406*^9, 3.8142866052093945`*^9}, {3.814286722352617*^9, 
  3.814286794696253*^9}, {3.8142869479708767`*^9, 
  3.814287052056858*^9}},ExpressionUUID->"79af4c6f-a949-4b3c-9f28-\
f15c853a182f"],

