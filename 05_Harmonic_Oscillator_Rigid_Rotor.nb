Cell[CellGroupData[{

Cell["Plotting the Solutions", "Subsection",
 CellChangeTimes->{{3.8095094581569195`*^9, 
  3.80950946046171*^9}},ExpressionUUID->"7b772762-14f8-4a66-a420-\
ac4a48fc782b"],

Cell[TextData[{
 "Shown below are the first six wavefunctions and energies for the \
quantum-mechanical harmonic oscillator. Notice that, once again, we observe a \
zero-point energy for the lowest-energy state. The square of the \
wavefunction, ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[RightBracketingBar]", 
    RowBox[{"\[Psi]", "(", "x", ")"}], 
    SuperscriptBox["\[LeftBracketingBar]", "2"]}], TraditionalForm]],
  ExpressionUUID->"4a4972a0-1087-4114-bd8b-5a882b9ac91f"],
 ", is also shown below."
}], "Text",
 CellChangeTimes->{{3.8095106981032867`*^9, 3.809510782579401*^9}, {
  3.8099694591910567`*^9, 
  3.809969461536403*^9}},ExpressionUUID->"978447fd-7230-42a9-b9ad-\
d253fa89fa82"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"h", "=", "1"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"\[Mu]", "=", "1"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"k", "=", "1"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"\[Nu]", "=", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{"1", "/", 
      RowBox[{"(", 
       RowBox[{"2", "*", "\[Pi]"}], ")"}]}], ")"}], "*", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{"k", "/", "\[Mu]"}], ")"}], "^", 
     RowBox[{"(", 
      RowBox[{"1", "/", "2"}], ")"}]}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"\[Alpha]", "=", 
   SuperscriptBox[
    RowBox[{"(", 
     FractionBox[
      RowBox[{"4", 
       SuperscriptBox["\[Pi]", "2"], "*", "k", 
       StyleBox["*",
        FontSlant->"Italic"], "\[Mu]"}], 
      SuperscriptBox["h", "2"]], ")"}], 
    RowBox[{"(", 
     RowBox[{"1", "/", "2"}], ")"}]]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"norm", "=", 
   RowBox[{
    FractionBox["1", 
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{
        SuperscriptBox["2", "n"], 
        RowBox[{"n", "!"}]}], ")"}], 
      RowBox[{"(", 
       RowBox[{"1", "/", "2"}], ")"}]]], 
    SuperscriptBox[
     RowBox[{"(", 
      FractionBox["\[Alpha]", "\[Pi]"], ")"}], 
     RowBox[{"1", "/", "4"}]]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"energies", "=", "\[IndentingNewLine]", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"h", 
      StyleBox["*",
       FontSlant->"Italic"], 
      StyleBox["\[Nu]",
       FontSlant->"Plain"], 
      StyleBox["*",
       FontSlant->"Plain"], 
      RowBox[{"(", 
       RowBox[{"n", "+", 
        FractionBox["1", "2"]}], ")"}]}], ",", 
     RowBox[{"{", 
      RowBox[{"n", ",", "0", ",", "5"}], "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Eplotlabels", "=", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"\"\<(\>\"", "<>", 
      RowBox[{"ToString", "[", 
       RowBox[{"InputForm", "[", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{"2", "n"}], "+", "1"}], ")"}], "/", "2"}], "]"}], "]"}], 
      "<>", "\"\<)\>\""}], ",", 
     RowBox[{"{", 
      RowBox[{"n", ",", "0", ",", "5"}], "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"energiesplot", "=", "\[IndentingNewLine]", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{
          RowBox[{"-", 
           RowBox[{"(", 
            RowBox[{"1", "/", "2"}], ")"}]}], "*", 
          RowBox[{"(", 
           RowBox[{"n", "+", "1"}], ")"}]}], ",", 
         RowBox[{"energies", "[", 
          RowBox[{"[", 
           RowBox[{"n", "+", "1"}], "]"}], "]"}]}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{
          RowBox[{"(", 
           RowBox[{"1", "/", "2"}], ")"}], "*", 
          RowBox[{"(", 
           RowBox[{"n", "+", "1"}], ")"}]}], ",", 
         RowBox[{"energies", "[", 
          RowBox[{"[", 
           RowBox[{"n", "+", "1"}], "]"}], "]"}]}], "}"}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"n", ",", "0", ",", "5"}], "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"potential", "=", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{"1", "/", "2"}], ")"}], "*", "k", "*", 
    RowBox[{"x", "^", "2"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"wf", "=", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"0.05", "*", "norm", "*", 
       RowBox[{"HermiteH", "[", 
        RowBox[{"n", ",", 
         RowBox[{
          SuperscriptBox["\[Alpha]", 
           RowBox[{"1", "/", "2"}]], "x"}]}], "]"}], "*", 
       RowBox[{"Exp", "[", 
        RowBox[{
         RowBox[{"-", "\[Alpha]"}], "*", 
         RowBox[{
          RowBox[{"x", "^", "2"}], "/", "2"}]}], "]"}]}], "+", 
      RowBox[{"energies", "[", 
       RowBox[{"[", 
        RowBox[{"n", "+", "1"}], "]"}], "]"}]}], ",", 
     RowBox[{"{", 
      RowBox[{"n", ",", "0", ",", "5"}], "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"wfsquared", "=", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"(", 
        RowBox[{"0.25", "*", "norm", "*", 
         RowBox[{"HermiteH", "[", 
          RowBox[{"n", ",", 
           RowBox[{
            SuperscriptBox["\[Alpha]", 
             RowBox[{"1", "/", "2"}]], "x"}]}], "]"}], "*", 
         RowBox[{"Exp", "[", 
          RowBox[{
           RowBox[{"-", "\[Alpha]"}], "*", 
           RowBox[{
            RowBox[{"x", "^", "2"}], "/", "2"}]}], "]"}]}], ")"}], "^", "2"}],
       "+", 
      RowBox[{"energies", "[", 
       RowBox[{"[", 
        RowBox[{"n", "+", "1"}], "]"}], "]"}]}], ",", 
     RowBox[{"{", 
      RowBox[{"n", ",", "0", ",", "5"}], "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{"Show", "[", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"Plot", "[", 
    RowBox[{"potential", ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", 
       RowBox[{"-", "100"}], ",", "100"}], "}"}], ",", 
     RowBox[{"PlotRange", "\[Rule]", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"-", "2"}], ",", "2"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"-", "0.01"}], ",", "0.95"}], "}"}]}], "}"}]}], ",", 
     RowBox[{"BaseStyle", "\[Rule]", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"FontFamily", "\[Rule]", "\"\<Arial\>\""}], ",", 
        RowBox[{"FontSize", "\[Rule]", "16"}]}], "}"}]}], ",", 
     RowBox[{"PlotStyle", "\[Rule]", 
      RowBox[{"Directive", "[", 
       RowBox[{"Black", ",", 
        RowBox[{"PointSize", "[", "Large", "]"}]}], "]"}]}], ",", 
     RowBox[{"AxesStyle", "\[Rule]", 
      RowBox[{"Directive", "[", 
       RowBox[{"Thick", ",", "Black"}], "]"}]}], ",", 
     RowBox[{"TicksStyle", "\[Rule]", 
      RowBox[{"Directive", "[", 
       RowBox[{"Black", ",", " ", "Thick"}], "]"}]}], ",", 
     RowBox[{"Ticks", "\[Rule]", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"{", 
          RowBox[{"0", ",", "\"\<0\>\""}], "}"}], "}"}], ",", 
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{
            RowBox[{"energies", "[", 
             RowBox[{"[", 
              RowBox[{"n", "+", "1"}], "]"}], "]"}], ",", 
            RowBox[{
             RowBox[{"Eplotlabels", "[", 
              RowBox[{"[", 
               RowBox[{"n", "+", "1"}], "]"}], "]"}], "<>", 
             "\"\<\!\(\*StyleBox[\"h\",FontSlant->\"Italic\"]\)\[Nu]\>\""}]}],
            "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"n", ",", "0", ",", "5"}], "}"}]}], "]"}]}], "}"}]}], ",", 
     RowBox[{"ImageSize", "\[Rule]", "Large"}], ",", " ", 
     RowBox[{"Exclusions", "\[Rule]", "None"}], ",", 
     RowBox[{"AxesOrigin", "\[Rule]", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"-", "2"}], ",", "0"}], "}"}]}], ",", 
     RowBox[{"AxesLabel", "\[Rule]", 
      RowBox[{"{", 
       RowBox[{
       "\"\<\!\(\*StyleBox[\"x\",FontSlant->\"Italic\"]\)\>\"", ",", 
        "\"\<\!\(\*StyleBox[\"E\",FontWeight->\"Plain\",FontSlant->\"Italic\"]\
\)\>\""}], "}"}]}], ",", 
     RowBox[{"Filling", "\[Rule]", "0"}], ",", 
     RowBox[{"FillingStyle", "->", 
      RowBox[{"HatchFilling", "[", 
       RowBox[{
        RowBox[{"-", "Pi"}], "/", "4"}], "]"}]}]}], "]"}], 
   "\[IndentingNewLine]", ",", "\[IndentingNewLine]", 
   RowBox[{"ListLinePlot", "[", 
    RowBox[{
     RowBox[{"energiesplot", "[", 
      RowBox[{"[", 
       RowBox[{"1", ";;", "6"}], "]"}], "]"}], ",", 
     RowBox[{"PlotStyle", "->", 
      RowBox[{"Directive", "[", "Gray", "]"}]}]}], "]"}], 
   "\[IndentingNewLine]", ",", "\[IndentingNewLine]", 
   RowBox[{"Plot", "[", 
    RowBox[{
