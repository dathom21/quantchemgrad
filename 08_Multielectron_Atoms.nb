    3.8126319287268906`*^9}, {3.812698643216871*^9, 3.8126986714190135`*^9}, {
    3.8127065219878197`*^9, 3.8127066002469187`*^9}, {3.8127069401179733`*^9, 
    3.8127070269316473`*^9}, {3.8127076858801394`*^9, 3.812707743838921*^9}, {
    3.8127078962878947`*^9, 3.8127078968871737`*^9}, {3.8127079338490696`*^9, 
    3.8127079744320726`*^9}},ExpressionUUID->
  "9f402cb9-53cb-4c7b-81eb-af47981c2176"],
 " terms appear twice for each orbital (once for each electron), and the \
exchange term only appears once (exchange between electrons of the same spin \
state)."
}], "Text",
 CellChangeTimes->{{3.8127086103801317`*^9, 3.812708663144354*^9}, {
  3.8127226616839437`*^9, 3.8127227423972397`*^9}, {3.812722878863551*^9, 
  3.812722879767829*^9}, {3.8127237077965975`*^9, 3.812723715470023*^9}, {
  3.844182615583497*^9, 3.844182617332614*^9}, {3.8441826541382513`*^9, 
  3.844182654838891*^9}},ExpressionUUID->"3929f58d-3f6a-4472-a300-\
583f6d77be6d"]
}, Open  ]],

Cell[CellGroupData[{

Cell["The Linear Variational Method", "Subsection",
 CellChangeTimes->{{3.8118578309715767`*^9, 
  3.811857838278859*^9}},ExpressionUUID->"c1c4f83d-3589-be41-a6a3-\
2467ebeab1e6"],

Cell["\<\
It turns out that a particularly useful form of the trial wavefunction is a \
linear combination of linearly independent basis functions,\
\>", "Text",
 CellChangeTimes->{{3.8118579343656874`*^9, 3.8118579634174657`*^9}, {
  3.8118579993510046`*^9, 3.811858000486391*^9}, {3.8118582516514053`*^9, 
  3.8118582577015085`*^9}},ExpressionUUID->"ab333106-afa7-334a-8c56-\
6976552cbd3d"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"|", "\[CapitalPhi]"}], "\[RightAngleBracket]"}], "=", 
     RowBox[{
      RowBox[{
       UnderscriptBox["\[Sum]", 
        StyleBox["n",
         FontSlant->"Italic"]], 
       SubscriptBox[
        StyleBox["a",
         FontSlant->"Italic"], 
        StyleBox["n",
         FontSlant->"Italic"]]}], "|", 
      SubscriptBox["\[Phi]", 
       StyleBox["n",
        FontSlant->"Italic"]]}]}], "\[RightAngleBracket]"}], "                                       ",
    "\[CapitalPhi]"}], "=", 
  RowBox[{
   UnderscriptBox["\[Sum]", 
    StyleBox["n",
     FontSlant->"Italic"]], 
   RowBox[{
    SubscriptBox[
     StyleBox["a",
      FontSlant->"Italic"], 
     StyleBox["n",
      FontSlant->"Italic"]], 
    SubscriptBox["\[Phi]", 
     StyleBox["n",
      FontSlant->"Italic"]]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.811593312893673*^9, 3.8115933831661987`*^9}, {
   3.811593458953679*^9, 3.8115934974178753`*^9}, {3.811594043422389*^9, 
   3.8115940850450926`*^9}, {3.8115941212928057`*^9, 3.81159413134099*^9}, {
   3.8115942129312763`*^9, 3.811594213576462*^9}, {3.811594345555955*^9, 
   3.8115943458791523`*^9}, 3.8115943810138807`*^9, {3.8118583015457077`*^9, 
   3.8118583904266043`*^9}},ExpressionUUID->"a89e046c-0206-f341-8321-\
3890d9e0d1f6"],

Cell[TextData[{
 "where \[CapitalPhi] is our trial wavefunction, and ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["a",
    FontSlant->"Italic"], 
   StyleBox["n",
    FontSlant->"Italic"]]],
  CellChangeTimes->{{3.811593312893673*^9, 3.8115933831661987`*^9}, {
    3.811593458953679*^9, 3.8115934974178753`*^9}, {3.811594043422389*^9, 
    3.8115940850450926`*^9}, {3.8115941212928057`*^9, 3.81159413134099*^9}, {
    3.8115942129312763`*^9, 3.811594213576462*^9}, {3.811594345555955*^9, 
    3.8115943458791523`*^9}, 3.8115943810138807`*^9, {3.8118583015457077`*^9, 
    3.8118583904266043`*^9}},ExpressionUUID->
  "bd299817-73d0-d748-964e-ac27a18a15af"],
 " are the weighting coefficients of each basis function ",
 Cell[BoxData[
  SubscriptBox["\[Phi]", 
   StyleBox["n",
    FontSlant->"Italic"]]],
  CellChangeTimes->{{3.811593312893673*^9, 3.8115933831661987`*^9}, {
    3.811593458953679*^9, 3.8115934974178753`*^9}, {3.811594043422389*^9, 
    3.8115940850450926`*^9}, {3.8115941212928057`*^9, 3.81159413134099*^9}, {
    3.8115942129312763`*^9, 3.811594213576462*^9}, {3.811594345555955*^9, 
    3.8115943458791523`*^9}, 3.8115943810138807`*^9, {3.8118583015457077`*^9, 
    3.8118583904266043`*^9}},ExpressionUUID->
  "9df2a5f6-9110-7241-8bad-9b997c521902"],
 ". Unlike our proof of the variational principle, the ",
 Cell[BoxData[
  SubscriptBox["\[Phi]", 
   StyleBox["n",
    FontSlant->"Italic"]]],
  CellChangeTimes->{{3.811593312893673*^9, 3.8115933831661987`*^9}, {
    3.811593458953679*^9, 3.8115934974178753`*^9}, {3.811594043422389*^9, 
    3.8115940850450926`*^9}, {3.8115941212928057`*^9, 3.81159413134099*^9}, {
    3.8115942129312763`*^9, 3.811594213576462*^9}, {3.811594345555955*^9, 
    3.8115943458791523`*^9}, 3.8115943810138807`*^9, {3.8118583015457077`*^9, 
    3.8118583904266043`*^9}},ExpressionUUID->
  "f9830f5d-d3e0-5b43-b98e-8e4a4982b342"],
 " basis functions are ",
 StyleBox["not",
  FontSlant->"Italic"],
 " the true eigenstates of the Hamiltonian (we cannot know the true \
eigenstates in practice because we cannot solve the TISE analytically). As we \
will see later, they usually have a radial component that takes the form of a \
decaying exponential (as in the ",
 StyleBox["s",
  FontSlant->"Italic"],
 " orbitals of the hydrogen atom) or a Gaussian function. They could, \
however, take any form in principle."
}], "Text",
 CellChangeTimes->{{3.8118584044428205`*^9, 3.8118584238779984`*^9}, {
  3.8118584543862715`*^9, 
  3.811858795140456*^9}},ExpressionUUID->"d3fd74fc-8e9b-4048-8d14-\
a67a67c1ef94"],

Cell[TextData[{
 "Remember that we want to optimize our trial wavefunction \[CapitalPhi] to \
achieve the lowest possible energy ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["E", "\[CapitalPhi]"], TraditionalForm]],ExpressionUUID->
  "5cb96f87-e361-174e-a992-8d727ae4ac17"],
 ". First, we need to see how we calculate ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["E", "\[CapitalPhi]"], TraditionalForm]],ExpressionUUID->
  "055c0386-bfba-6746-90ff-806844b36f42"],
 ", "
}], "Text",
 CellChangeTimes->{{3.81185879955068*^9, 
  3.8118588624015465`*^9}},ExpressionUUID->"0817f24e-a798-5145-8a37-\
28b78d644ee7"],

Cell[BoxData[
 RowBox[{
  SubscriptBox[
   StyleBox["E",
    FontSlant->"Italic"], "\[CapitalPhi]"], "=", 
  RowBox[{
   RowBox[{
    FractionBox[
     RowBox[{"\[LeftAngleBracket]", 
      RowBox[{"\[CapitalPhi]", "|", 
       OverscriptBox[
        StyleBox["H",
         FontSlant->"Italic"], "^"], "|", "\[CapitalPhi]"}], 
      "\[RightAngleBracket]"}], 
     RowBox[{
      RowBox[{"\[LeftAngleBracket]", 
       RowBox[{"\[CapitalPhi]", "|", "\[CapitalPhi]"}], 
       "\[RightAngleBracket]"}], "  "}]], "                                           ", 
    SubscriptBox[
     StyleBox["E",
      FontSlant->"Italic"], "\[CapitalPhi]"]}], "=", 
   FractionBox[
    RowBox[{"\[Integral]", 
     RowBox[{
      SuperscriptBox["\[CapitalPhi]", "\[Star]"], " ", 
      OverscriptBox[
       StyleBox["H",
        FontSlant->"Italic"], "^"], "\[CapitalPhi]", " ", "d\[Tau]"}]}], 
    RowBox[{"\[Integral]", 
     RowBox[{
      SuperscriptBox["\[CapitalPhi]", "\[Star]"], "\[CapitalPhi]", " ", 
      "d\[Tau]"}]}]]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.811593312893673*^9, 3.8115933831661987`*^9}, {
  3.811593458953679*^9, 3.8115934974178753`*^9}, {3.8115936143121653`*^9, 
  3.811593715195953*^9}, {3.811594208013258*^9, 3.811594210677987*^9}, {
  3.811594342816991*^9, 3.8115943434093456`*^9}, {3.811594623901507*^9, 
  3.811594670874273*^9}, {3.8115948564704037`*^9, 3.8115948589878416`*^9}, {
  3.8115949257053156`*^9, 3.811594926820971*^9}, {3.8118594909971013`*^9, 
  3.8118595100044374`*^9}, {3.811861225074663*^9, 
  3.8118612380287175`*^9}},ExpressionUUID->"9a2b4914-414d-2b48-8b18-\
ddc0e6909e32"],

Cell[TextData[{
 "Just as in the variational proof, we address the numerator first. \
Substitution of the definition of \[CapitalPhi] in terms of ",
 Cell[BoxData[
  SubscriptBox["\[Phi]", 
   StyleBox["n",
    FontSlant->"Italic"]]],
  CellChangeTimes->{{3.811593312893673*^9, 3.8115933831661987`*^9}, {
   3.811593458953679*^9, 3.8115934974178753`*^9}, {3.8115936143121653`*^9, 
   3.811593715195953*^9}, {3.811594208013258*^9, 3.811594210677987*^9}, {
   3.811594342816991*^9, 3.8115943434093456`*^9}, {3.811594623901507*^9, 
   3.811594670874273*^9}, {3.8115947420473485`*^9, 3.8115947734245424`*^9}, {
   3.811594861515888*^9, 3.8115948828180823`*^9}, {3.8115949210585313`*^9, 
   3.8115949642239265`*^9}, {3.8118595150245304`*^9, 3.8118595640674267`*^9}},
  ExpressionUUID->"fdc5dc54-f480-3f41-ba3b-e5a345dd2b87"],
 " yields"
}], "Text",
 CellChangeTimes->{{3.8115946911781216`*^9, 3.811594727699502*^9}, {
  3.811595187165801*^9, 3.811595192022772*^9}, {3.8118597022098293`*^9, 
  3.811859750453951*^9}},ExpressionUUID->"86a4ada1-3456-674d-9c0b-\
df6b6111e914"],

Cell[BoxData[
 RowBox[{
  RowBox[{"\[LeftAngleBracket]", 
   RowBox[{"\[CapitalPhi]", "|", 
    OverscriptBox[
     StyleBox["H",
      FontSlant->"Italic"], "^"], "|", "\[CapitalPhi]"}], 
   "\[RightAngleBracket]"}], "=", 
  RowBox[{
   RowBox[{
    RowBox[{"\[LeftAngleBracket]", 
     RowBox[{
      RowBox[{
       UnderscriptBox["\[Sum]", 
        StyleBox["n",
         FontSlant->"Italic"]], 
       RowBox[{
        SubscriptBox[
         StyleBox["a",
          FontSlant->"Italic"], 
         StyleBox["n",
          FontSlant->"Italic"]], 
        SubscriptBox["\[Phi]", 
         StyleBox["n",
          FontSlant->"Italic"]]}]}], " ", "|", 
      OverscriptBox[
       StyleBox["H",
        FontSlant->"Italic"], "^"], "|", 
      RowBox[{
       UnderscriptBox["\[Sum]", 
        StyleBox["m",
         FontSlant->"Italic"]], 
       RowBox[{
        SubscriptBox[
         StyleBox["a",
          FontSlant->"Italic"], 
         StyleBox["m",
          FontSlant->"Italic"]], 
        SubscriptBox["\[Phi]", 
         StyleBox["m",
          FontSlant->"Italic"]]}]}]}], "\[RightAngleBracket]"}], "                           ", 
    RowBox[{"\[Integral]", 
     RowBox[{
      SuperscriptBox["\[CapitalPhi]", "\[Star]"], " ", 
      OverscriptBox[
       StyleBox["H",
        FontSlant->"Italic"], "^"], "\[CapitalPhi]", " ", "d\[Tau]"}]}]}], 
   "=", 
   RowBox[{"\[Integral]", 
    RowBox[{
     UnderscriptBox["\[Sum]", 
      StyleBox["n",
       FontSlant->"Italic"]], 
     RowBox[{
      SubsuperscriptBox[
       StyleBox["a",
        FontSlant->"Italic"], 
       StyleBox["n",
        FontSlant->"Italic"], "\[Star]"], 
      SubsuperscriptBox["\[Phi]", 
       StyleBox["n",
        FontSlant->"Italic"], "\[Star]"], " ", 
      OverscriptBox[
       StyleBox["H",
        FontSlant->"Italic"], "^"], 
      RowBox[{
       UnderscriptBox["\[Sum]", 
        StyleBox["m",
         FontSlant->"Italic"]], 
       RowBox[{
        SubscriptBox[
         StyleBox["a",
          FontSlant->"Italic"], 
         StyleBox["m",
          FontSlant->"Italic"]], 
        SubscriptBox["\[Phi]", 
         StyleBox["m",
          FontSlant->"Italic"]], " ", 
        "d\[Tau]"}]}]}]}]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.811593312893673*^9, 3.8115933831661987`*^9}, {
  3.811593458953679*^9, 3.8115934974178753`*^9}, {3.8115936143121653`*^9, 
  3.811593715195953*^9}, {3.811594208013258*^9, 3.811594210677987*^9}, {
  3.811594342816991*^9, 3.8115943434093456`*^9}, {3.811594623901507*^9, 
  3.811594670874273*^9}, {3.8115947420473485`*^9, 3.8115947734245424`*^9}, {
  3.811594861515888*^9, 3.8115948828180823`*^9}, {3.8115949210585313`*^9, 
  3.8115949642239265`*^9}, {3.8118595150245304`*^9, 3.8118595640674267`*^9}, {
  3.8118598956194797`*^9, 
  3.8118599140327373`*^9}},ExpressionUUID->"8cb79192-61d9-f647-90d5-\
68a910cc7f8a"],

Cell[BoxData[
 RowBox[{"\t\t  ", 
  RowBox[{"=", 
   RowBox[{
    RowBox[{
     UnderscriptBox["\[Sum]", 
      StyleBox["n",
       FontSlant->"Italic"]], 
     RowBox[{
      UnderscriptBox["\[Sum]", 
       StyleBox["m",
        FontSlant->"Italic"]], 
      RowBox[{
       SubsuperscriptBox[
        StyleBox["a",
         FontSlant->"Italic"], 
        StyleBox["n",
         FontSlant->"Italic"], "\[Star]"], 
       SubscriptBox[
        StyleBox["a",
         FontSlant->"Italic"], 
        StyleBox["m",
         FontSlant->"Italic"]], 
       RowBox[{"\[LeftAngleBracket]", 
        RowBox[{
         SubscriptBox["\[Phi]", 
          StyleBox["n",
           FontSlant->"Italic"]], " ", "|", 
         OverscriptBox[
          StyleBox["H",
           FontSlant->"Italic"], "^"], "|", 
         SubscriptBox["\[Phi]", 
          StyleBox["m",
           FontSlant->"Italic"]]}], "\[RightAngleBracket]"}]}]}]}], 
    "                                               ", "=", 
    RowBox[{
     UnderscriptBox["\[Sum]", 
      StyleBox["n",
       FontSlant->"Italic"]], 
     RowBox[{
      UnderscriptBox["\[Sum]", 
       StyleBox["m",
        FontSlant->"Italic"]], 
      RowBox[{
       SubsuperscriptBox[
        StyleBox["a",
         FontSlant->"Italic"], 
        StyleBox["n",
         FontSlant->"Italic"], "\[Star]"], 
       SubscriptBox[
        StyleBox["a",
         FontSlant->"Italic"], 
        StyleBox["m",
         FontSlant->"Italic"]], 
       RowBox[{"\[Integral]", 
        RowBox[{
         SubsuperscriptBox["\[Phi]", 
          StyleBox["n",
           FontSlant->"Italic"], "\[Star]"], " ", 
         OverscriptBox[
          StyleBox["H",
           FontSlant->"Italic"], "^"], 
         SubscriptBox["\[Phi]", 
          StyleBox["m",
           FontSlant->"Italic"]], " ", 
         "d\[Tau]"}]}]}]}]}]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.811593312893673*^9, 3.8115933831661987`*^9}, {
  3.811593458953679*^9, 3.8115934974178753`*^9}, {3.8115936143121653`*^9, 
  3.811593715195953*^9}, {3.811594208013258*^9, 3.811594210677987*^9}, {
  3.811594342816991*^9, 3.8115943434093456`*^9}, {3.811594623901507*^9, 
  3.811594670874273*^9}, {3.8115947420473485`*^9, 3.8115947734245424`*^9}, {
  3.811594861515888*^9, 3.8115948828180823`*^9}, {3.8115949210585313`*^9, 
  3.8115949642239265`*^9}, {3.8118595150245304`*^9, 3.8118595640674267`*^9}, {
  3.8118597688527746`*^9, 3.81185977694464*^9}, {3.811859929959675*^9, 
  3.8118600030689287`*^9}},ExpressionUUID->"9997d26e-32f3-c548-9390-\
e2e299713cf2"],

Cell[TextData[{
 "Since our basis functions are not necessarily eigenfunctions, we cannot \
convert ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    RowBox[{
     OverscriptBox[
      StyleBox["H",
       FontSlant->"Italic"], "^"], "|", 
     SubscriptBox["\[Phi]", 
      StyleBox["m",
       FontSlant->"Italic"]]}], "\[RightAngleBracket]"}], " "}]],
  CellChangeTimes->{{3.811593312893673*^9, 3.8115933831661987`*^9}, {
   3.811593458953679*^9, 3.8115934974178753`*^9}, {3.8115936143121653`*^9, 
   3.811593715195953*^9}, {3.811594208013258*^9, 3.811594210677987*^9}, {
   3.811594342816991*^9, 3.8115943434093456`*^9}, {3.811594623901507*^9, 
   3.811594670874273*^9}, {3.8115947420473485`*^9, 3.8115947734245424`*^9}, {
   3.811594861515888*^9, 3.8115948828180823`*^9}, {3.8115949210585313`*^9, 
   3.8115949642239265`*^9}, {3.8118595150245304`*^9, 
   3.8118595640674267`*^9}, {3.8118597688527746`*^9, 3.81185977694464*^9}, {
   3.811859929959675*^9, 3.8118600030689287`*^9}},ExpressionUUID->
  "61ceea6a-2a52-c544-ba84-631f0a10a9ba"],
 "to ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    SubscriptBox[
     StyleBox["E",
      FontSlant->"Italic"], 
     StyleBox["m",
      FontSlant->"Italic"]], "|", 
    SubscriptBox["\[Phi]", 
     StyleBox["m",
      FontSlant->"Italic"]]}], "\[RightAngleBracket]"}]],
  CellChangeTimes->{{3.811593312893673*^9, 3.8115933831661987`*^9}, {
   3.811593458953679*^9, 3.8115934974178753`*^9}, {3.8115936143121653`*^9, 
   3.811593715195953*^9}, {3.811594208013258*^9, 3.811594210677987*^9}, {
   3.811594342816991*^9, 3.8115943434093456`*^9}, {3.811594623901507*^9, 
   3.811594670874273*^9}, {3.8115947420473485`*^9, 3.8115947734245424`*^9}, {
   3.811594861515888*^9, 3.8115948828180823`*^9}, {3.8115949210585313`*^9, 
   3.8115949642239265`*^9}, {3.8118595150245304`*^9, 
   3.8118595640674267`*^9}, {3.8118597688527746`*^9, 3.81185977694464*^9}, {
   3.811859929959675*^9, 3.8118600030689287`*^9}},ExpressionUUID->
  "46e6aaca-a711-674a-a720-a3bca1d0c43c"],
 ". However, note that ",
 Cell[BoxData[
  RowBox[{"\[LeftAngleBracket]", 
   RowBox[{
    SubscriptBox["\[Phi]", 
     StyleBox["n",
      FontSlant->"Italic"]], " ", "|", 
    OverscriptBox[
     StyleBox["H",
      FontSlant->"Italic"], "^"], "|", 
    SubscriptBox["\[Phi]", 
     StyleBox["m",
      FontSlant->"Italic"]]}], "\[RightAngleBracket]"}]],ExpressionUUID->
  "6c4b94b9-028c-2f42-bd26-f542ae32c8cc"],
 " resembles our definition of the elements of the matrix representation of \
an operator in Lesson 07, so we write"
}], "Text",
 CellChangeTimes->{{3.811860114150919*^9, 3.8118602188868456`*^9}, {
  3.811860250147683*^9, 3.8118602512011385`*^9}, {3.811860315152761*^9, 
  3.811860334942859*^9}, {3.8118603951159325`*^9, 3.8118604035981865`*^9}, {
  3.9362803400126762`*^9, 
  3.9362803401305447`*^9}},ExpressionUUID->"2b6e000e-91d8-4748-bc60-\
de4b1363dd5e"],

Cell[BoxData[
 RowBox[{"\t", 
  RowBox[{
   SubscriptBox[
    StyleBox["H",
     FontSlant->"Italic"], 
    StyleBox["nm",
     FontSlant->"Italic"]], "=", 
   RowBox[{
    RowBox[{
     RowBox[{"\[LeftAngleBracket]", 
      RowBox[{
       SubscriptBox["\[Phi]", 
        StyleBox["n",
         FontSlant->"Italic"]], " ", "|", 
       OverscriptBox[
        StyleBox["H",
         FontSlant->"Italic"], "^"], "|", 
       SubscriptBox["\[Phi]", 
        StyleBox["m",
         FontSlant->"Italic"]]}], "\[RightAngleBracket]"}], "                                                                    ", 
     SubscriptBox[
      StyleBox["H",
       FontSlant->"Italic"], 
      StyleBox["nm",
       FontSlant->"Italic"]]}], "=", 
    RowBox[{"\[Integral]", 
     RowBox[{
      SubsuperscriptBox["\[Phi]", 
       StyleBox["n",
        FontSlant->"Italic"], "\[Star]"], " ", 
      OverscriptBox[
       StyleBox["H",
        FontSlant->"Italic"], "^"], 
      SubscriptBox["\[Phi]", 
       StyleBox["m",
        FontSlant->"Italic"]], " ", "d\[Tau]", 
      "                        "}]}]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.811593312893673*^9, 3.8115933831661987`*^9}, {
   3.811593458953679*^9, 3.8115934974178753`*^9}, {3.8115936143121653`*^9, 
