  3.9144157453743067`*^9}},ExpressionUUID->"6232f838-8a17-4c90-a65a-\
a28835af2ef4"],

Cell["We have have the Hamiltonian for this system", "Text",
 CellChangeTimes->{{3.914415751972911*^9, 3.914415754195343*^9}, {
  3.914416245978095*^9, 
  3.914416251082069*^9}},ExpressionUUID->"2d852867-6d04-4d11-ab66-\
95382650759e"],

Cell[BoxData[
 RowBox[{
  StyleBox["H",
   FontSlant->"Italic"], "=", 
  RowBox[{
   RowBox[{
    FractionBox["1", "2"], 
    SuperscriptBox[
     StyleBox["ml",
      FontSlant->"Italic"], "2"], 
    SuperscriptBox[
     RowBox[{"(", 
