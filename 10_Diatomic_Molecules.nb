  3.813507067206438*^9}},ExpressionUUID->"c5af655c-418d-4882-b606-\
c7a05e454581"],

Cell["\<\
Combining the analysis of the first and second terms in the energy \
expression, we obtain\
\>", "Text",
 CellChangeTimes->{{3.813507070563546*^9, 
  3.8135070801683807`*^9}},ExpressionUUID->"e2c73e85-bef1-41a4-adb1-\
89fbe4561332"],

Cell[BoxData[{
 RowBox[{
  SubscriptBox[
   StyleBox["E",
    FontSlant->"Italic"], "\[PlusMinus]"], "=", 
  RowBox[{
   RowBox[{"\[LeftAngleBracket]", 
    RowBox[{
     SubscriptBox["\[Psi]", "\[PlusMinus]"], "|", 
     SubscriptBox[
      OverscriptBox[
       StyleBox["H",
        FontSlant->"Italic"], "^"], 
      StyleBox["e",
       FontSlant->"Italic"]], "|", 
     SubscriptBox["\[Psi]", "\[PlusMinus]"]}], "\[RightAngleBracket]"}], "=", 
   RowBox[{
    FractionBox["1", 
     RowBox[{"1", "\[PlusMinus]", 
      StyleBox["S",
       FontSlant->"Italic"]}]], "[", 
    RowBox[{
     RowBox[{"\[LeftAngleBracket]", 
      RowBox[{
       SubscriptBox["\[Phi]", 
        RowBox[{"1", 
         SubscriptBox[
          StyleBox["s",
           FontSlant->"Italic"], 
          StyleBox["A",
           FontSlant->"Italic"]]}]], "|", 
       SubscriptBox[
        OverscriptBox[
         StyleBox["H",
          FontSlant->"Italic"], "^"], 
        StyleBox["e",
         FontSlant->"Italic"]], "|", 
       SubscriptBox["\[Phi]", 
        RowBox[{"1", 
         SubscriptBox[
          StyleBox["s",
           FontSlant->"Italic"], 
          StyleBox["A",
           FontSlant->"Italic"]]}]]}], "\[RightAngleBracket]"}], 
     "\[PlusMinus]", 
     RowBox[{"\[LeftAngleBracket]", 
      RowBox[{
       SubscriptBox["\[Phi]", 
        RowBox[{"1", 
         SubscriptBox[
          StyleBox["s",
           FontSlant->"Italic"], 
          StyleBox["A",
           FontSlant->"Italic"]]}]], "|", 
       SubscriptBox[
        OverscriptBox[
         StyleBox["H",
          FontSlant->"Italic"], "^"], 
        StyleBox["e",
         FontSlant->"Italic"]], "|", 
       SubscriptBox["\[Phi]", 
        RowBox[{"1", 
         SubscriptBox[
          StyleBox["s",
           FontSlant->"Italic"], 
          StyleBox["B",
           FontSlant->"Italic"]]}]]}], "\[RightAngleBracket]"}]}], 
    "]"}]}]}], "\[IndentingNewLine]", 
 RowBox[{"\t\t\t       ", 
  RowBox[{"=", 
   RowBox[{
    FractionBox["1", 
     RowBox[{"1", "\[PlusMinus]", 
      StyleBox["S",
       FontSlant->"Italic"]}]], "[", 
    RowBox[{
     SubscriptBox[
      StyleBox["E",
       FontSlant->"Italic"], 
      RowBox[{"1", 
       StyleBox["s",
        FontSlant->"Italic"]}]], "+", 
     StyleBox["N",
      FontSlant->"Italic"], "+", 
     RowBox[{
      FractionBox["1", 
       StyleBox["R",
        FontSlant->"Italic"]], "\[PlusMinus]", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         SubscriptBox[
          StyleBox["E",
           FontSlant->"Italic"], 
          RowBox[{"1", 
           StyleBox["s",
            FontSlant->"Italic"]}]], 
         StyleBox["S",
          FontSlant->"Italic"]}], "+", 
        StyleBox["M",
         FontSlant->"Italic"], "+", 
        RowBox[{
         FractionBox["1", 
          StyleBox["R",
           FontSlant->"Italic"]], 
         StyleBox["S",
          FontSlant->"Italic"]}]}], 
       StyleBox[")",
        FontSlant->"Italic"]}]}]}], "]"}]}]}], "\[IndentingNewLine]", 
 RowBox[{"\t\t\t       ", 
  RowBox[{"=", 
   RowBox[{
    FractionBox["1", 
     RowBox[{"1", "\[PlusMinus]", 
      StyleBox["S",
       FontSlant->"Italic"]}]], "[", 
    RowBox[{
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        SubscriptBox[
         StyleBox["E",
          FontSlant->"Italic"], 
         RowBox[{"1", 
          StyleBox["s",
           FontSlant->"Italic"]}]], "+", 
        FractionBox["1", 
         StyleBox["R",
          FontSlant->"Italic"]]}], ")"}], 
      RowBox[{"(", 
       RowBox[{"1", "\[PlusMinus]", 
        StyleBox["S",
         FontSlant->"Italic"]}], ")"}]}], "+", 
     RowBox[{"(", 
      RowBox[{
       StyleBox["N",
        FontSlant->"Italic"], "\[PlusMinus]", 
       StyleBox["M",
        FontSlant->"Italic"]}], 
      StyleBox[")",
       FontSlant->"Italic"]}]}], "]"}]}]}]}], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8132221669142685`*^9, 3.8132221794693403`*^9}, {
   3.8132222690385857`*^9, 3.813222292552426*^9}, {3.8132225103046436`*^9, 
   3.8132225357976294`*^9}, 3.813225530724597*^9, {3.8132268996594105`*^9, 
   3.8132268997936573`*^9}, {3.8132269718506794`*^9, 
   3.8132270598936987`*^9}, {3.813227090063882*^9, 3.8132270928942423`*^9}, {
   3.8132273687054873`*^9, 3.8132273956726027`*^9}, {3.8132274257354927`*^9, 
   3.8132274504676456`*^9}, {3.813227484968296*^9, 3.8132274916733313`*^9}, {
   3.813227717592659*^9, 3.813227799104663*^9}, {3.8132278524338465`*^9, 
   3.813227854764579*^9}, 3.8132279269606223`*^9, {3.8132284806854115`*^9, 
   3.8132285040063257`*^9}, {3.813233670328187*^9, 3.8132336720975046`*^9}, {
   3.8132357631856723`*^9, 3.8132357709170113`*^9}, {3.813427542982295*^9, 
   3.8134276318539715`*^9}, {3.8134276920016794`*^9, 
   3.8134278213405004`*^9}, {3.8134283865881367`*^9, 3.813428403776387*^9}, {
   3.813507095369198*^9, 3.8135071521384816`*^9}, {3.8135072121390505`*^9, 
   3.813507271850775*^9}, {3.8135073131273375`*^9, 3.8135073672520795`*^9}, {
   3.8135074193963223`*^9, 3.813507420933642*^9}, {3.813510658719367*^9, 
   3.813510668707844*^9}},ExpressionUUID->"d81f0ce9-f44b-564b-b062-\
7d045f68f2cb"],

Cell["Simplifying, we obtain", "Text",
 CellChangeTimes->{{3.8135074231777725`*^9, 
  3.8135074275237494`*^9}},ExpressionUUID->"272e8914-1406-4464-ae71-\
80355da78f87"],

Cell[BoxData[
 RowBox[{
  SubscriptBox[
   StyleBox["E",
    FontSlant->"Italic"], "\[PlusMinus]"], "=", 
  RowBox[{
   SubscriptBox[
    StyleBox["E",
     FontSlant->"Italic"], 
    RowBox[{"1", 
     StyleBox["s",
      FontSlant->"Italic"]}]], "+", 
   FractionBox["1", 
    StyleBox["R",
     FontSlant->"Italic"]], "+", 
   FractionBox[
    RowBox[{
     StyleBox["N",
      FontSlant->"Italic"], "\[PlusMinus]", 
     StyleBox["M",
      FontSlant->"Italic"]}], 
    RowBox[{"1", "\[PlusMinus]", 
     StyleBox["S",
      FontSlant->"Italic"]}]]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.813507432429942*^9, 3.8135074361176004`*^9}, {
  3.81351045057891*^9, 
  3.8135104513772106`*^9}},ExpressionUUID->"135a1789-3966-724d-aff8-\
25c4ac8aa965"],

Cell[TextData[{
 "Let\[CloseCurlyQuote]s investigate the difference between this value and \
the energy of an isolated proton and hydrogen atom. When the two nuclei are \
infinitely far apart (and the electron is localized on one nucleus, giving us \
a hydrogen atom and a proton), the energy is simply ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["E",
    FontSlant->"Italic"], 
   RowBox[{"1", 
    StyleBox["s",
     FontSlant->"Italic"]}]]],
  CellChangeTimes->{{3.813507432429942*^9, 3.8135074361176004`*^9}},
  ExpressionUUID->"14458bf2-6904-4aec-87c1-ea59dd4e223c"],
 " because the other terms go to zero at infinite separation. Thus, the \
difference in energy obtained by bringing the two nuclei together is"
}], "Text",
 CellChangeTimes->{{3.8135090021956363`*^9, 
  3.8135091827026467`*^9}},ExpressionUUID->"077e1085-9ec6-486b-a800-\
821812c93044"],

Cell[BoxData[
 RowBox[{
  SubscriptBox[
   StyleBox[
    RowBox[{
     StyleBox["\[CapitalDelta]",
      FontSlant->"Plain"], 
     StyleBox["E",
      FontSlant->"Italic"]}]], "\[PlusMinus]"], "=", 
  RowBox[{
   FractionBox["1", 
    StyleBox["R",
     FontSlant->"Italic"]], "+", 
   FractionBox[
    RowBox[{
     StyleBox["N",
      FontSlant->"Italic"], "\[PlusMinus]", 
     StyleBox["M",
      FontSlant->"Italic"]}], 
    RowBox[{"1", "\[PlusMinus]", 
     StyleBox["S",
      FontSlant->"Italic"]}]]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.813507432429942*^9, 3.8135074361176004`*^9}, {
  3.8135091949215007`*^9, 3.813509209133624*^9}, {3.8135104440980787`*^9, 
  3.813510445328018*^9}, {3.8135124438242655`*^9, 
  3.813512446296191*^9}},ExpressionUUID->"0aa75de0-4f58-ea4f-b5ec-\
327a11eede22"],

Cell[TextData[{
 "If one evaluates the attractive potential ",
 StyleBox["N",
  FontSlant->"Italic"],
 ", which, remember, gives the attraction between a ",
 Cell[BoxData[
  SubscriptBox["\[Phi]", 
   RowBox[{"1", 
    SubscriptBox[
     StyleBox["s",
      FontSlant->"Italic"], 
     StyleBox["A",
      FontSlant->"Italic"]]}]]],
  CellChangeTimes->{{3.8135052923220196`*^9, 3.813505326944688*^9}, {
   3.813505358543342*^9, 3.813505384859789*^9}, {3.813505426726184*^9, 
   3.8135054412132916`*^9}, {3.8135055231751776`*^9, 3.813505529922575*^9}, {
   3.8135055732207823`*^9, 3.8135055842599134`*^9}, {3.8135060188703766`*^9, 
   3.813506040845706*^9}, {3.8135068161426926`*^9, 3.813506824462853*^9}},
  ExpressionUUID->"597cb63e-42ca-6b40-9e6a-578f4345961e"],
 " electron and nucleus ",
 StyleBox["B",
  FontSlant->"Italic"],
 " (or vice versa), one obtains"
}], "Text",
 CellChangeTimes->{{3.8135096955869827`*^9, 
  3.813509814954363*^9}},ExpressionUUID->"4ac93235-570d-9644-b8f8-\
0dcba33cbc28"],

Cell[BoxData[
 RowBox[{
  StyleBox["N",
   FontSlant->"Italic"], 
  StyleBox["=",
   FontSlant->"Plain"], 
  RowBox[{
   RowBox[{
    StyleBox["-",
     FontSlant->"Plain"], 
    RowBox[{"\[LeftAngleBracket]", 
     RowBox[{
      SubscriptBox["\[Phi]", 
       RowBox[{"1", 
        SubscriptBox[
         StyleBox["s",
          FontSlant->"Italic"], 
         StyleBox["A",
          FontSlant->"Italic"]]}]], "|", 
      FractionBox["1", 
       SubscriptBox[
        StyleBox["r",
         FontSlant->"Italic"], 
        StyleBox["B",
         FontSlant->"Italic"]]], "|", 
      SubscriptBox["\[Phi]", 
       RowBox[{"1", 
        SubscriptBox[
         StyleBox["s",
          FontSlant->"Italic"], 
         StyleBox["A",
          FontSlant->"Italic"]]}]]}], "\[RightAngleBracket]"}]}], "=", 
   RowBox[{
    FractionBox[
     RowBox[{"-", "1"}], 
     StyleBox["R",
      FontSlant->"Italic"]], "[", 
    RowBox[{"1", "-", 
     RowBox[{
      SuperscriptBox["\[ExponentialE]", 
       RowBox[{
        RowBox[{"-", "2"}], " ", 
        StyleBox["R",
         FontSlant->"Italic"]}]], " ", 
      RowBox[{"(", 
       RowBox[{"1", "+", 
        StyleBox["R",
         FontSlant->"Italic"]}], ")"}]}]}], 
    "]"}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.813507432429942*^9, 3.8135074361176004`*^9}, {
   3.8135091949215007`*^9, 3.813509209133624*^9}, {3.813509824619856*^9, 
   3.8135098689724555`*^9}, {3.813509920694948*^9, 3.813509923773433*^9}, 
   3.813509974134482*^9},ExpressionUUID->"9db60268-138d-bd40-a379-\
81888fd1829e"],

Cell[TextData[{
 "similarly if one evaluates ",
 StyleBox["M",
  FontSlant->"Italic"],
 ", the exchanged equivalent of ",
 StyleBox["N",
  FontSlant->"Italic"],
 ", one obtains"
}], "Text",
 CellChangeTimes->{{3.813509883164273*^9, 3.8135099027999754`*^9}, {
  3.813509933818575*^9, 
  3.813509963409306*^9}},ExpressionUUID->"373939f9-eb03-294c-8533-\
240135cf3935"],

Cell[BoxData[
 RowBox[{
  StyleBox["M",
   FontSlant->"Italic"], "=", 
  RowBox[{
   RowBox[{"-", 
    RowBox[{"\[LeftAngleBracket]", 
     RowBox[{
      SubscriptBox["\[Phi]", 
       RowBox[{"1", 
        SubscriptBox[
         StyleBox["s",
          FontSlant->"Italic"], 
         StyleBox["A",
          FontSlant->"Italic"]]}]], "|", 
      FractionBox["1", 
       SubscriptBox[
        StyleBox["r",
         FontSlant->"Italic"], 
        StyleBox["A",
         FontSlant->"Italic"]]], "|", 
      SubscriptBox["\[Phi]", 
       RowBox[{"1", 
        SubscriptBox[
         StyleBox["s",
          FontSlant->"Italic"], 
         StyleBox["B",
          FontSlant->"Italic"]]}]]}], "\[RightAngleBracket]"}]}], "=", 
   RowBox[{
    RowBox[{"-", 
     SuperscriptBox["\[ExponentialE]", 
      RowBox[{"-", 
       StyleBox["R",
        FontSlant->"Italic"]}]]}], " ", 
    RowBox[{"(", 
     RowBox[{"1", "+", 
      StyleBox["R",
       FontSlant->"Italic"]}], ")"}]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8135052923220196`*^9, 3.813505326944688*^9}, {
   3.813505358543342*^9, 3.813505384859789*^9}, {3.813505426726184*^9, 
   3.8135054412132916`*^9}, {3.8135055231751776`*^9, 3.813505529922575*^9}, {
   3.8135055732207823`*^9, 3.8135055842599134`*^9}, {3.8135058497344227`*^9, 
   3.8135058576204896`*^9}, {3.8135099658556185`*^9, 3.813510006391326*^9}, 
   3.8135107190591316`*^9},ExpressionUUID->"64e1a0b7-0923-f44b-a026-\
01946e8a9167"],

Cell["Finally, the overlap integral expression is given by", "Text",
 CellChangeTimes->{{3.813510109102438*^9, 3.813510112559112*^9}, {
  3.8135103312573233`*^9, 
  3.813510333992753*^9}},ExpressionUUID->"50b12fe3-4eb1-f141-b7a9-\
b0ad0e280425"],

Cell[BoxData[
 RowBox[{
  StyleBox["S",
   FontSlant->"Italic"], 
  StyleBox["=",
   FontSlant->"Plain"], 
  RowBox[{
   SuperscriptBox["\[ExponentialE]", 
    RowBox[{"-", 
     StyleBox["R",
      FontSlant->"Italic"]}]], 
   RowBox[{"(", 
    RowBox[{"1", "+", 
     StyleBox["R",
      FontSlant->"Italic"], "+", 
     FractionBox[
      SuperscriptBox[
       StyleBox["R",
        FontSlant->"Italic"], "2"], "3"]}], 
    ")"}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.813510343852669*^9, 
  3.8135103736592655`*^9}},ExpressionUUID->"b8b72b7c-e851-074d-b967-\
9143734e5316"],

Cell[TextData[{
 "Using these expressions, we can plot ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox[
    RowBox[{
     StyleBox["\[CapitalDelta]",
      FontSlant->"Plain"], 
     StyleBox["E",
      FontSlant->"Italic"]}]], "+"]],
  CellChangeTimes->{{3.813507432429942*^9, 3.8135074361176004`*^9}, {
   3.8135091949215007`*^9, 3.813509209133624*^9}},ExpressionUUID->
  "ea266bee-fd37-4eb5-9097-1f313acf13d8"],
 " and ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox[
    RowBox[{
     StyleBox["\[CapitalDelta]",
      FontSlant->"Plain"], 
     StyleBox["E",
      FontSlant->"Italic"]}]], "-"]],
  CellChangeTimes->{{3.813507432429942*^9, 3.8135074361176004`*^9}, {
   3.8135091949215007`*^9, 3.813509209133624*^9}},ExpressionUUID->
  "e602b048-c009-49b9-9f9a-5fd978eb1768"],
 " as a function of the internuclear distance ",
 StyleBox["R",
  FontSlant->"Italic"],
 ", as shown in Figure 10.4."
}], "Text",
 CellChangeTimes->{{3.8135104074980354`*^9, 3.81351043585487*^9}, 
   3.8135118558078904`*^9, {3.919512505889479*^9, 3.9195125130245676`*^9}, {
   3.937487452402174*^9, 
   3.9374874526802444`*^9}},ExpressionUUID->"5360baac-a39a-49b9-87f4-\
bafc88a25ab9"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   StyleBox["nuc",
    FontSlant->"Plain"], "=", 
   RowBox[{
    FractionBox[
     RowBox[{"-", "1"}], 
     StyleBox["R",
      FontSlant->"Italic"]], 
    RowBox[{"(", 
     RowBox[{"1", "-", 
      RowBox[{
       SuperscriptBox["\[ExponentialE]", 
        RowBox[{
         RowBox[{"-", "2"}], " ", 
         StyleBox["R",
          FontSlant->"Italic"]}]], " ", 
       RowBox[{"(", 
        RowBox[{"1", "+", 
         StyleBox["R",
          FontSlant->"Italic"]}], ")"}]}]}], ")"}]}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"exc", "=", 
   RowBox[{
    RowBox[{"-", 
     SuperscriptBox["\[ExponentialE]", 
      RowBox[{"-", 
       StyleBox["R",
        FontSlant->"Italic"]}]]}], " ", 
    RowBox[{"(", 
     RowBox[{"1", "+", 
      StyleBox["R",
       FontSlant->"Italic"]}], ")"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"ovlp", "=", 
   RowBox[{
    SuperscriptBox["\[ExponentialE]", 
     RowBox[{"-", 
      StyleBox["R",
       FontSlant->"Italic"]}]], 
    RowBox[{"(", 
     RowBox[{"1", "+", 
      StyleBox["R",
       FontSlant->"Italic"], "+", 
      FractionBox[
       SuperscriptBox[
        StyleBox["R",
         FontSlant->"Italic"], "2"], "3"]}], ")"}]}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"deleplus", "=", 
   RowBox[{
    FractionBox["1", 
     StyleBox["R",
      FontSlant->"Italic"]], "+", 
    FractionBox[
     RowBox[{"nuc", "+", "exc"}], 
     RowBox[{"1", "+", "ovlp"}]]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"deleminus", "=", 
   RowBox[{
    FractionBox["1", 
     StyleBox["R",
      FontSlant->"Italic"]], "+", 
    FractionBox[
     RowBox[{"nuc", "-", "exc"}], 
     RowBox[{"1", "-", "ovlp"}]]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"Plot", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"deleplus", ",", "deleminus", ",", "0"}], "}"}], ",", " ", 
   RowBox[{"{", 
    RowBox[{"R", ",", "0.05", ",", "6.1"}], "}"}], ",", 
   RowBox[{"PlotRange", "\[Rule]", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"1", ",", "6"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"-", "0.1"}], ",", "0.2"}], "}"}]}], "}"}]}], ",", 
   "\[IndentingNewLine]", 
   RowBox[{"BaseStyle", "\[Rule]", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"FontFamily", "\[Rule]", "\"\<Arial\>\""}], ",", 
      RowBox[{"FontSize", "\[Rule]", "16"}]}], "}"}]}], ",", 
   RowBox[{"PlotStyle", "\[Rule]", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"Directive", "[", 
