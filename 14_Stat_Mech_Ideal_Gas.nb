 RowBox[{
  RowBox[{
   SubscriptBox[
    StyleBox["Z",
     FontSlant->"Italic"], 
    StyleBox["E",
     FontSlant->"Italic"]], 
   StyleBox[
    RowBox[{"(", 
     RowBox[{"N", ",", "V", ",", "T"}], ")"}],
    FontSlant->"Italic"]}], 
  StyleBox["=",
   FontSlant->"Plain"], 
  FractionBox[
   SuperscriptBox[
    RowBox[{
     StyleBox["[",
      FontSlant->"Plain"], 
     RowBox[{
      SubscriptBox[
       StyleBox["Z",
        FontSlant->"Italic"], 
