e344ae2319fe"],

Cell[TextData[{
 "In other words, the square of the angular momentum takes on discrete values \
given by the quantum number ",
 StyleBox["l",
  FontSlant->"Italic"],
 ", and ",
 StyleBox["l",
  FontSlant->"Italic"],
 " is therefore often called the angular momentum quantum number."
}], "Text",
 CellChangeTimes->{{3.8106616683964014`*^9, 3.810661692614563*^9}, {
  3.81071264513527*^9, 
  3.81071265822711*^9}},ExpressionUUID->"79cb0947-fe4a-49ca-bba0-\
c33254e3017f"],

Cell[TextData[{
 "Let\[CloseCurlyQuote]s turn our attention now to the angular momentum \
components along the coordinates ",
 StyleBox["x",
  FontSlant->"Italic"],
 ", ",
 StyleBox["y",
  FontSlant->"Italic"],
 ", and ",
 StyleBox["z",
  FontSlant->"Italic"],
 ". Recall from our review of vectors and angular momentum in the rigid rotor \
lesson and our definition of quantum-mechanical operators in the postulates \
of quantum mechanics that"
}], "Text",
 CellChangeTimes->{{3.8106617706321993`*^9, 3.8106618469635525`*^9}, {
  3.917086158655816*^9, 
  3.9170861752516403`*^9}},ExpressionUUID->"7a34be2f-5a30-4503-8b70-\
f15b93bc2a87"],

Cell[BoxData[
 RowBox[{
  SubscriptBox[
   OverscriptBox[
    StyleBox["L",
     FontSlant->"Italic"], "^"], 
   StyleBox["x",
    FontSlant->"Italic"]], "=", 
  RowBox[{
   RowBox[{"(", 
    RowBox[{
     RowBox[{
      StyleBox["y",
       FontSlant->"Italic"], 
      SubscriptBox[
       OverscriptBox[
        StyleBox["P",
         FontSlant->"Italic"], "^"], 
       StyleBox["z",
        FontSlant->"Italic"]]}], "-", 
     RowBox[{
      StyleBox["z",
       FontSlant->"Italic"], 
      SubscriptBox[
       OverscriptBox[
        StyleBox["P",
         FontSlant->"Italic"], "^"], 
       StyleBox["y",
        FontSlant->"Italic"]]}]}], ")"}], "=", 
   RowBox[{
    RowBox[{"-", "\[ImaginaryI]\[HBar]"}], 
    RowBox[{"(", 
     RowBox[{
      StyleBox["y",
       FontSlant->"Italic"], 
      RowBox[{
       FractionBox["\[PartialD]", 
        RowBox[{"\[PartialD]", 
         StyleBox["z",
          FontSlant->"Italic"]}]], 
       RowBox[{"-", 
        StyleBox["z",
         FontSlant->"Italic"]}]}], 
      FractionBox["\[PartialD]", 
       RowBox[{"\[PartialD]", 
        StyleBox["y",
         FontSlant->"Italic"]}]]}], ")"}]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8100544880652375`*^9, 3.8100545041200957`*^9}, {
