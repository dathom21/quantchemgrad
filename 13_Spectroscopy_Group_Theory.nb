            SubscriptBox["\[Omega]", 
             StyleBox["mk",
              FontSlant->"Italic"]], "-", "\[Omega]"}], ")"}], 
          StyleBox[" ",
           FontSlant->"Italic"], 
          RowBox[{
           StyleBox["t",
            FontSlant->"Italic"], "/", "2"}]}]]}]}], 
      RowBox[{"2", "\[ImaginaryI]", 
       RowBox[{"(", 
        RowBox[{
         SubscriptBox["\[Omega]", "mk"], "-", "\[Omega]"}], ")"}]}]], 
     "]"}]}]}]}], "\[IndentingNewLine]", 
