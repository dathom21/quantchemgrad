  3.809358075717537*^9, 3.8093581887919407`*^9}, {3.809358225472412*^9, 
  3.8093582316374474`*^9}},ExpressionUUID->"b0cfd779-faa4-cb4b-91d6-\
849d82579ad2"],

Cell["where", "Text",
 CellChangeTimes->{{3.809358242279255*^9, 
  3.8093582426257696`*^9}},ExpressionUUID->"4f1924b5-773c-6e45-971f-\
ef579cab9c46"],

Cell[BoxData[
 RowBox[{
  StyleBox[
   OverscriptBox[
    SubscriptBox["H", "x"], "^"],
   FontSlant->"Italic"], 
  StyleBox["=",
   FontSlant->"Plain"], 
  RowBox[{
   RowBox[{"-", 
    FractionBox[
     SuperscriptBox[
      StyleBox["\[HBar]",
       FontSlant->"Plain"], "2"], 
     RowBox[{"2", 
      StyleBox["m",
       FontSlant->"Italic"]}]]}], 
   FractionBox[
    SuperscriptBox["\[PartialD]", "2"], 
    RowBox[{"\[PartialD]", 
     SuperscriptBox[
      StyleBox["x",
       FontSlant->"Italic"], "2"]}]]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.809358251318143*^9, 3.8093582598599453`*^9}, {
  3.809358386011687*^9, 
  3.809358408549386*^9}},ExpressionUUID->"6d60d13a-9d77-d242-abf5-\
7f0bb5cd2acd"],

Cell[BoxData[
 RowBox[{
  StyleBox[
   OverscriptBox[
    SubscriptBox["H", "y"], "^"],
   FontSlant->"Italic"], 
  StyleBox["=",
   FontSlant->"Plain"], 
  RowBox[{
   RowBox[{"-", 
    FractionBox[
     SuperscriptBox[
      StyleBox["\[HBar]",
       FontSlant->"Plain"], "2"], 
     RowBox[{"2", 
      StyleBox["m",
       FontSlant->"Italic"]}]]}], 
   FractionBox[
    SuperscriptBox["\[PartialD]", "2"], 
    RowBox[{"\[PartialD]", 
     SuperscriptBox[
      StyleBox["y",
       FontSlant->"Italic"], "2"]}]]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.809358251318143*^9, 3.8093582598599453`*^9}, {
  3.809358386011687*^9, 
  3.80935842459219*^9}},ExpressionUUID->"e2d0bcf3-3792-6344-b843-\
8743156ce2d7"],

Cell[BoxData[
 RowBox[{
  StyleBox[
   OverscriptBox[
    SubscriptBox["H", "z"], "^"],
   FontSlant->"Italic"], 
  StyleBox["=",
   FontSlant->"Plain"], 
  RowBox[{
   RowBox[{"-", 
    FractionBox[
     SuperscriptBox[
      StyleBox["\[HBar]",
       FontSlant->"Plain"], "2"], 
     RowBox[{"2", 
      StyleBox["m",
       FontSlant->"Italic"]}]]}], 
   FractionBox[
    SuperscriptBox["\[PartialD]", "2"], 
    RowBox[{"\[PartialD]", 
     SuperscriptBox[
      StyleBox["z",
       FontSlant->"Italic"], "2"]}]]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.809358251318143*^9, 3.8093582598599453`*^9}, {
  3.809358386011687*^9, 
  3.809358427899873*^9}},ExpressionUUID->"f5b85e87-649e-d24d-b985-\
b2756cee19de"],

Cell[TextData[{
 "when we have such a ",
 StyleBox["separable",
  FontSlant->"Italic"],
 " Hamiltonian, we can find the final eigenfunctions as the product of the \
eigenfunctions for each part of the Hamiltonian, as in the separation of \
variables"
}], "Text",
 CellChangeTimes->{{3.809358456719951*^9, 3.8093585289874983`*^9}, {
  3.809358560152422*^9, 
  3.809358561214997*^9}},ExpressionUUID->"51a5149e-ad27-fc42-948f-\
04b3beb03363"],

Cell[BoxData[
 RowBox[{
  RowBox[{"\[Psi]", 
   RowBox[{
    StyleBox["(",
     FontSlant->"Italic"], 
    RowBox[{
     StyleBox["x",
      FontSlant->"Italic"], ",", 
     StyleBox["y",
      FontSlant->"Italic"], 
     StyleBox[",",
      FontSlant->"Plain"], 
     StyleBox["z",
      FontSlant->"Italic"]}], 
    StyleBox[")",
     FontSlant->"Italic"]}]}], "=", 
  RowBox[{
   StyleBox["X",
    FontSlant->"Italic"], 
   RowBox[{"(", 
    StyleBox["x",
     FontSlant->"Italic"], 
    StyleBox[")",
     FontSlant->"Italic"]}], 
   StyleBox["Y",
    FontSlant->"Italic"], 
   StyleBox[
    RowBox[{"(", "y", ")"}],
    FontSlant->"Italic"], 
   StyleBox["Z",
    FontSlant->"Italic"], 
   StyleBox[
    RowBox[{"(", "z", ")"}],
    FontSlant->"Italic"]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.809357536690065*^9, 
  3.809357564144396*^9}},ExpressionUUID->"bacbe371-7cda-654a-922c-\
dde4349f352b"],

Cell["\<\
In addition, the energies of the system are just the sum of the eigenvalues \
for each part of the Hamiltonian,\
\>", "Text",
 CellChangeTimes->{{3.809358533574648*^9, 
  3.809358563297288*^9}},ExpressionUUID->"47cd3638-a94e-5741-989c-\
4ee9d49cd224"],

Cell[BoxData[
 RowBox[{
  StyleBox["E",
   FontSlant->"Italic"], 
  StyleBox["=",
   FontSlant->"Plain"], 
  RowBox[{
   SubscriptBox[
    StyleBox["E",
     FontSlant->"Italic"], 
    StyleBox["x",
     FontSlant->"Italic"]], "+", 
   SubscriptBox[
    StyleBox["E",
     FontSlant->"Italic"], 
    StyleBox["y",
     FontSlant->"Italic"]], "+", 
   SubscriptBox[
    StyleBox["E",
     FontSlant->"Italic"], "z"]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.809357783393046*^9, 
  3.8093578165607305`*^9}},ExpressionUUID->"62d45c6e-aa12-5543-bc2a-\
57538cc5dc66"],

Cell["\<\
In this way, we can reduce complicated problems in quantum mechanics (such as \
the many components of the energy of a molecule) to several simpler problems.\
\>", "Text",
 CellChangeTimes->{{3.809358578165701*^9, 
  3.8093586148860703`*^9}},ExpressionUUID->"44475a58-6965-4943-9eb8-\
e74502c24faf"]
}, Open  ]]
}, Open  ]]
},
