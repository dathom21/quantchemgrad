Cell[CellGroupData[{

Cell["Simple Pendulum - Hamiltonian mechanics", "Subsection",
 CellChangeTimes->{{3.914414878862956*^9, 
  3.9144148862237887`*^9}},ExpressionUUID->"06e35fb9-e086-468c-a6d2-\
7431a9e58338"],

Cell[TextData[{
 "We can also describe our pendulum system using an alternate formulation \
known as Hamiltonian mechanics. In this approach, we first want to identify \
the ",
 StyleBox["Hamiltonian",
  FontSlant->"Italic"],
 " for the system, which (in the cases we care about) is the sum of the \
kinetic energy ",
 StyleBox["T",
  FontSlant->"Italic"],
 " and the potential energy ",
 StyleBox["V",
  FontSlant->"Italic"],
 ","
}], "Text",
 CellChangeTimes->{{3.9144148894919715`*^9, 3.914414955232006*^9}, {
  3.914414998432023*^9, 
  3.9144150137632875`*^9}},ExpressionUUID->"6daf9064-803c-4e69-a6a9-\
f649eb089ad8"],

Cell[BoxData[
 RowBox[{
  StyleBox["H",
   FontSlant->"Italic"], "=", 
  RowBox[{
   StyleBox["T",
    FontSlant->"Italic"], "+", 
   StyleBox["V",
    FontSlant->"Italic"]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.9144110221722584`*^9, 3.9144110251791077`*^9}, {
  3.9144111820235987`*^9, 3.9144112064138207`*^9}, {3.9144112438703938`*^9, 
  3.9144112575699005`*^9}, {3.914411336972353*^9, 3.9144113705117893`*^9}, {
  3.9144114056902256`*^9, 3.9144114238165298`*^9}, {3.9144149904644547`*^9, 
  3.914414994963703*^9}},ExpressionUUID->"00c86a1b-c958-4fd3-beb2-\
9c574ca62d15"],

Cell["For the simple pendulum, the kinetic energy is given by", "Text",
 CellChangeTimes->{{3.9144150827719984`*^9, 3.91441508324697*^9}, {
  3.914415121615303*^9, 
  3.914415131187031*^9}},ExpressionUUID->"600321e4-9582-4ebd-abf2-\
e133765661e7"],

Cell[BoxData[
 RowBox[{
  StyleBox["T",
   FontSlant->"Italic"], "=", 
  RowBox[{
   RowBox[{
    FractionBox["1", "2"], 
    SuperscriptBox[
     StyleBox["mv",
      FontSlant->"Italic"], "2"]}], "=", 
   RowBox[{
    RowBox[{
     FractionBox["1", "2"], 
     StyleBox["m",
      FontSlant->"Italic"], " ", 
     SuperscriptBox[
      RowBox[{"(", 
       FractionBox[
        RowBox[{"\[DifferentialD]", 
         StyleBox["s",
          FontSlant->"Italic"]}], 
        RowBox[{"\[DifferentialD]", 
         StyleBox["t",
          FontSlant->"Italic"]}]], ")"}], "2"]}], "=", 
    RowBox[{
     FractionBox["1", "2"], 
     SuperscriptBox[
      StyleBox["ml",
       FontSlant->"Italic"], "2"], 
     SuperscriptBox[
      RowBox[{"(", 
       FractionBox[
        RowBox[{"\[DifferentialD]", "\[Theta]"}], 
        RowBox[{"\[DifferentialD]", 
         StyleBox["t",
          FontSlant->"Italic"]}]], ")"}], 
      "2"]}]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.9144110221722584`*^9, 3.9144110251791077`*^9}, {
  3.9144111820235987`*^9, 3.9144112064138207`*^9}, {3.9144112438703938`*^9, 
  3.9144112575699005`*^9}, {3.914411336972353*^9, 3.9144113705117893`*^9}, {
  3.9144114056902256`*^9, 3.9144114238165298`*^9}, {3.9144149904644547`*^9, 
  3.914414994963703*^9}, {3.9144151599124594`*^9, 
  3.9144152483186803`*^9}},ExpressionUUID->"2c05012c-8ab7-4b16-8f8d-\
b4a2dee757cc"],

Cell["\<\
where we have used equation (4) in the last transformation again.\
\>", "Text",
 CellChangeTimes->{{3.914415253977902*^9, 3.914415261309645*^9}, {
  3.9339479247493763`*^9, 
  3.9339479248913918`*^9}},ExpressionUUID->"3c631e6e-5abe-4a34-82f3-\
66489dce0d85"],

Cell[TextData[{
 "The potential energy of the pendulum, using the lowest point in the arc as ",
 Cell[BoxData[
  FormBox[
   RowBox[{"y", "=", "0"}], TraditionalForm]],ExpressionUUID->
  "d05db994-ffc2-4565-ab58-301c84f15022"],
 ", is given by"
}], "Text",
 CellChangeTimes->{{3.914415333442422*^9, 
  3.9144153653633156`*^9}},ExpressionUUID->"7fed013b-fe61-4707-af00-\
14c6c80baa31"],

Cell[BoxData[
 RowBox[{
  StyleBox["V",
   FontSlant->"Italic"], "=", 
  RowBox[{
   StyleBox["mgy",
    FontSlant->"Italic"], "=", 
   RowBox[{
    StyleBox["mgl",
     FontSlant->"Italic"], 
    StyleBox["[",
     FontSlant->"Italic"], 
    StyleBox[
     RowBox[{"1", "-", 
      RowBox[{"cos", 
       RowBox[{"(", "\[Theta]", ")"}]}]}],
     FontSlant->"Plain"], 
    StyleBox["]",
     FontSlant->"Plain"]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.9144110221722584`*^9, 3.9144110251791077`*^9}, {
  3.9144111820235987`*^9, 3.9144112064138207`*^9}, {3.9144112438703938`*^9, 
