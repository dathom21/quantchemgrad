      SuperscriptBox["\[ExponentialE]", 
       StyleBox[
        RowBox[{"\[ImaginaryI]\[Omega]", 
         StyleBox["t",
          FontSlant->"Italic"]}]]], "+", 
      SuperscriptBox["\[ExponentialE]", 
       RowBox[{"-", 
        StyleBox[
         RowBox[{"\[ImaginaryI]\[Omega]", 
          StyleBox["t",
           FontSlant->"Italic"]}]]}]]}], 
     ")"}]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8079712935412436`*^9, 3.8079714900326514`*^9}, {
