Cell[TextData[{
 StyleBox["Figure 11.3",
  FontWeight->"Bold"],
 ". Walsh Correlation Diagram for an ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["AH", "2"], TraditionalForm]],ExpressionUUID->
  "4b26665e-ad07-4102-8db9-7d67be1b08b1"],
 " Molecule. Wikimedia, Chem540f09grp5, Public Domain, \
https://commons.wikimedia.org/wiki/File:Walsh_diagram_intro.svg"
}], "Affiliation",
 CellChangeTimes->CompressedData["
1:eJxTTMoPSmViYGAQBmIQPeNH5qbXiW8cy6t7doDoiRfCxd8A6ZBDtWA6NlRg
2Ucgzeepug5EC2S27BZIAtJry/eD6DMqRj/fA+kjLKbMH4B0E3PHSv6UN44X
l04G08y2gYYPM944ShTl2YDoml0/fqlmvnFMuGTBogak81nqs65mvXFU0zIp
AtFH7qh/AdEb9z74AaJVbh3gvwakt+w6AqZzXlnFgGgvNnswbbTCOBlEJ3Ew
5YNoj9nzVW8B6YvcIZog2oz9/TqN7DeOjC+U1oPoA+phW0D0o2KWAyBaZ611
nQ6QXv2ssQVEP2+7fRBETyprPgmijwQsPXMm4q2jQ+RKMA0AkaGbNg==
  "],ExpressionUUID->"88acfa9c-afb6-44d9-b045-2e7b0463b219"],

Cell[TextData[{
 "The Walsh correlation diagram for the states ",
 Cell[BoxData[
  FormBox[
   RowBox[{"2", 
    SubscriptBox["\[Sigma]", "g"]}], TraditionalForm]],ExpressionUUID->
  "4434f550-b3f6-40c2-ab3e-5def50cf001c"],
 ", ",
 Cell[BoxData[
  FormBox[
   RowBox[{"1", 
    SubscriptBox["\[Sigma]", "u"]}], TraditionalForm]],ExpressionUUID->
  "6c84c50b-0e16-4cec-b429-db2bf120abfb"],
 ", and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"1", 
    SubscriptBox["\[Pi]", "u"]}], TraditionalForm]],ExpressionUUID->
  "c97e4098-d76f-4dbc-bc00-2131dffbf6cb"],
 " are shown in Figure 11.3 (the energies of the higher-energy states does \
not change dramatically). Note that the nomenclature employed to referred to \
these orbitals also changes; we cannot use the \[Sigma] and \[Pi] labels \
anymore, so we use the labels ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["a", "1"], TraditionalForm]],ExpressionUUID->
  "033269ce-99f1-4bcb-a462-ffd402fe3553"],
 ", ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["b", "2"], TraditionalForm]],ExpressionUUID->
  "3b80a7b6-c907-4454-b5e0-e8c08ba2c104"],
 ", and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["b", "1"], TraditionalForm]],ExpressionUUID->
  "4e1e0c09-a649-40f9-a9e7-5e31f73da432"],
 " (these are symmetry labels related to the point group, but we haven\
\[CloseCurlyQuote]t discussed this nomenclature yet). As the bond angle \
changes, the bonding ",
 Cell[BoxData[
  FormBox[
   RowBox[{"2", 
    SubscriptBox["\[Sigma]", "g"]}], TraditionalForm]],ExpressionUUID->
  "b0379c14-89c9-4687-b97e-6de7b49af923"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"1", 
    SubscriptBox["\[Sigma]", "u"]}], TraditionalForm]],ExpressionUUID->
  "1f0424d1-45bd-4144-86a1-22b5be836ad2"],
 " orbitals increase in energy, whereas one of the two ",
 Cell[BoxData[
  FormBox[
   RowBox[{"1", 
    SubscriptBox["\[Pi]", "u"]}], TraditionalForm]],ExpressionUUID->
  "45b57ae7-e9f0-4a3a-bf2c-5f7885f3f66b"],
 " orbitals (the one that now overlaps with the H 1",
 StyleBox["s",
  FontSlant->"Italic"],
 " orbitals) decreases in energy. "
}], "Text",
 CellChangeTimes->{{3.8142869429512763`*^9, 3.8142869445240803`*^9}, {
  3.8142870546758623`*^9, 3.814287154977876*^9}, {3.9388708893829365`*^9, 
  3.9388708894927864`*^9}},ExpressionUUID->"bf15d24f-ed9a-4cb3-b21a-\
1e75e1d8af27"],

Cell[TextData[{
 "Because the relative energy of these orbitals changes with bond angle, \
which bond angle is favored is determined by the number of valence electrons \
that occupy these molecular orbitals. For example, ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["BeH", "2"], TraditionalForm]],ExpressionUUID->
  "d0e4cef3-5525-46ee-afc4-649e4cf2164a"],
 " has four valence electrons, and the lowest total energy for the electrons \
will be achieved in the linear state (H\[Dash]A\[Dash]H bond angle of ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["180", "\[Degree]"], TraditionalForm]],ExpressionUUID->
  "409ec2c8-ba41-4178-aae6-1ae7e6c9c725"],
 "). In contrast, a water molecule has eight valence electrons. Because the \
decrease in energy of the ",
 Cell[BoxData[
  FormBox[
   RowBox[{"1", 
    SubscriptBox["\[Pi]", "u"]}], TraditionalForm]],ExpressionUUID->
  "f5003421-0d01-4137-80ec-a9dc93db9e8d"],
 " orbital is much greater than the increase in energy of the ",
 Cell[BoxData[
  FormBox[
   RowBox[{"2", 
    SubscriptBox["\[Sigma]", "g"]}], TraditionalForm]],ExpressionUUID->
  "bf15b33b-ef49-4dec-ac3c-42a2354dec37"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"1", 
    SubscriptBox["\[Sigma]", "u"]}], TraditionalForm]],ExpressionUUID->
  "2834e1fc-61b0-4f43-a323-bddda956a6f2"],
 " orbitals as the bond angle decreases, the lowest total energy of the \
electrons is achieved in a bent configuration, meaning ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox[
     StyleBox["H",
      FontSlant->"Plain"], "2"], 
    StyleBox["O",
     FontSlant->"Plain"]}], TraditionalForm]],ExpressionUUID->
  "f35e0e25-c3b8-46ff-a918-c5e0e36dc037"],
 " adopts a bent conformation. The angle at which the electron energy is \
minimized can be found through experiment or computation to be ",
 Cell[BoxData[
  FormBox[
   RowBox[{"~", 
    SuperscriptBox["104.5", "\[Degree]"]}], TraditionalForm]],ExpressionUUID->
  "3fe72338-c366-4085-9356-aea6eab484c9"],
 ". The molecular orbital diagram of is shown in Figure 11.4. Notice that the \
mixing of the orbitals is much more complex because of the new interactions \
between the 2",
 StyleBox["p",
  FontSlant->"Italic"],
 " orbitals and the H 1",
 StyleBox["s",
  FontSlant->"Italic"],
 " orbitals. "
}], "Text",
 CellChangeTimes->{{3.8142871630696735`*^9, 3.8142871634820576`*^9}, {
  3.8142872135473137`*^9, 3.814287559798912*^9}, {3.814287887117634*^9, 
  3.814287902466782*^9}, {3.814287963061921*^9, 3.8142880415240717`*^9}, {
  3.938870894412554*^9, 
  3.9388708945382233`*^9}},ExpressionUUID->"f519888a-11bb-4968-b4b2-\
e15edd73caf3"],

Cell[CellGroupData[{

