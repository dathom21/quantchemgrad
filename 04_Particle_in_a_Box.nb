Cell[TextData[{
 "Below is a plot of the wavefunctions, ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["\[Psi]",
    FontSlant->"Plain"], 
   StyleBox["n",
    FontSlant->"Italic"]]],
  CellChangeTimes->{{3.8078710533079896`*^9, 3.8078710768513994`*^9}, {
    3.8078712094225693`*^9, 3.8078712100284305`*^9}, {3.808745227603225*^9, 
    3.8087452448174677`*^9}, {3.8087452815607195`*^9, 3.808745289480257*^9}, 
    3.8087453853954077`*^9, {3.808746637680484*^9, 3.8087466430035295`*^9}, {
    3.808746850914447*^9, 3.808746866254322*^9}, 3.808748454489255*^9},
  ExpressionUUID->"5c2df6c9-24e6-421a-bc08-fdea80733531"],
 ", for ",
 StyleBox["n",
  FontSlant->"Italic"],
 " = 1 through 4, with each wavefunction plotted with an offset of ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["E", "n"], TraditionalForm]],ExpressionUUID->
  "1d944220-02c2-41f0-824c-95c7ba5a3f99"],
 " for the corresponding value of ",
 StyleBox["n",
  FontSlant->"Italic"],
 ". Note that the scale of the wavefunctions (i.e., the correct amplitude) is \
not shown, but you can see the shape and location of maxima and nodes. These \
are the same types of solutions as we saw for the vibrating string."
}], "Text",
 CellChangeTimes->{{3.808751098881364*^9, 3.808751291197479*^9}, {
  3.8087514194588275`*^9, 
  3.8087514294136343`*^9}},ExpressionUUID->"a8e49e75-ab42-44b2-8786-\
113da4782645"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"a", "=", "1"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"h", "=", "1"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"m", "=", "1"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"energies", "=", "\[IndentingNewLine]", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{"n", "^", "2"}], "*", 
          RowBox[{"h", "^", "2"}]}], ")"}], "/", 
        RowBox[{"(", 
         RowBox[{"8", "*", "m", "*", 
          RowBox[{"a", "^", "2"}]}], ")"}]}], ",", 
       RowBox[{"{", 
        RowBox[{"n", ",", "1", ",", "4"}], "}"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"energiesplot", "=", "\[IndentingNewLine]", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"0", ",", 
           RowBox[{"energies", "[", 
            RowBox[{"[", "n", "]"}], "]"}]}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"a", ",", 
           RowBox[{"energies", "[", 
            RowBox[{"[", "n", "]"}], "]"}]}], "}"}]}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"n", ",", "1", ",", "4"}], "}"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"potential", "=", 
     RowBox[{"Piecewise", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"{", 
         RowBox[{"0", ",", 
          RowBox[{"0", "\[LessEqual]", "x", "\[LessEqual]", "1"}]}], "}"}], 
        "}"}], ",", "1000"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"wf", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"0.1", "*", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"2", "/", "a"}], ")"}], "^", 
          RowBox[{"(", 
           RowBox[{"1", "/", "2"}], ")"}]}], 
         RowBox[{"Sin", "[", 
          RowBox[{"n", "*", "Pi", "*", 
           RowBox[{"x", "/", "a"}]}], "]"}]}], "+", 
        RowBox[{"energies", "[", 
         RowBox[{"[", "n", "]"}], "]"}]}], ",", 
       RowBox[{"{", 
        RowBox[{"n", ",", "1", ",", "4"}], "}"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{"Show", "[", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"Plot", "[", 
      RowBox[{"potential", ",", 
       RowBox[{"{", 
        RowBox[{"x", ",", 
         RowBox[{"-", "1"}], ",", "3"}], "}"}], ",", 
       RowBox[{"PlotRange", "\[Rule]", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{
            RowBox[{"-", "0.2"}], ",", "1.2"}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"-", "0.1"}], ",", "2.5"}], "}"}]}], "}"}]}], ",", 
       RowBox[{"BaseStyle", "\[Rule]", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"FontFamily", "\[Rule]", "\"\<Arial\>\""}], ",", 
          RowBox[{"FontSize", "\[Rule]", "16"}]}], "}"}]}], ",", 
       RowBox[{"PlotStyle", "\[Rule]", 
        RowBox[{"Directive", "[", 
         RowBox[{"Black", ",", 
          RowBox[{"PointSize", "[", "Large", "]"}]}], "]"}]}], ",", 
       RowBox[{"AxesStyle", "\[Rule]", 
        RowBox[{"Directive", "[", 
         RowBox[{"Thick", ",", "Black"}], "]"}]}], ",", 
       RowBox[{"TicksStyle", "\[Rule]", 
        RowBox[{"Directive", "[", 
         RowBox[{"Black", ",", " ", "Thick"}], "]"}]}], ",", 
       RowBox[{"Ticks", "\[Rule]", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{
              RowBox[{"-", "0.5"}], ",", 
              "\"\<-\!\(\*StyleBox[\"L\",FontSlant->\"Italic\"]\)\>\""}], 
             "}"}], ",", 
            RowBox[{"{", 
             RowBox[{"0", ",", "\"\<0\>\""}], "}"}], ",", 
            RowBox[{"{", 
             RowBox[{
             "1", ",", 
              "\"\<\!\(\*StyleBox[\"a\",FontSlant->\"Italic\"]\)\>\""}], 
             "}"}]}], "}"}], ",", 
          RowBox[{"Table", "[", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{
              RowBox[{"energies", "[", 
               RowBox[{"[", "n", "]"}], "]"}], ",", 
              RowBox[{"Subscript", "[", 
               RowBox[{
               "\"\<\!\(\*StyleBox[\"E\",FontWeight->\"Plain\",FontSlant->\"\
Italic\"]\)\>\"", ",", 
                RowBox[{"ToString", "[", "n", "]"}]}], "]"}]}], "}"}], ",", 
            RowBox[{"{", 
             RowBox[{"n", ",", "1", ",", "4"}], "}"}]}], "]"}]}], "}"}]}], 
       ",", 
       RowBox[{"ImageSize", "\[Rule]", "Large"}], ",", " ", 
       RowBox[{"Exclusions", "\[Rule]", "None"}], ",", 
       RowBox[{"AxesOrigin", "\[Rule]", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"-", "0.2"}], ",", "0"}], "}"}]}], ",", 
       RowBox[{"AxesLabel", "\[Rule]", 
        RowBox[{"{", 
         RowBox[{
         "\"\<\!\(\*StyleBox[\"x\",FontSlant->\"Italic\"]\)\>\"", ",", 
          "\"\<\!\(\*StyleBox[\"E\",FontWeight->\"Plain\",FontSlant->\"Italic\
\"]\)\>\""}], "}"}]}], ",", 
       RowBox[{"Filling", "\[Rule]", "0"}], ",", 
       RowBox[{"FillingStyle", "->", 
        RowBox[{"HatchFilling", "[", 
         RowBox[{
          RowBox[{"-", "Pi"}], "/", "4"}], "]"}]}]}], "]"}], 
     "\[IndentingNewLine]", ",", "\[IndentingNewLine]", 
     RowBox[{"ListLinePlot", "[", 
      RowBox[{
       RowBox[{"energiesplot", "[", 
        RowBox[{"[", 
         RowBox[{"1", ";;", "4"}], "]"}], "]"}], ",", 
       RowBox[{"PlotStyle", "->", 
        RowBox[{"Directive", "[", "Black", "]"}]}]}], "]"}], 
     "\[IndentingNewLine]", ",", "\[IndentingNewLine]", 
     RowBox[{"Plot", "[", 
      RowBox[{
       RowBox[{"wf", "[", 
        RowBox[{"[", 
         RowBox[{"1", ";;", "4"}], "]"}], "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"x", ",", "0", ",", "1"}], "}"}], ",", 
       RowBox[{"PlotRange", "\[Rule]", "All"}], ",", 
       RowBox[{"PlotStyle", "\[Rule]", "Thick"}]}], "]"}]}], 
    "\[IndentingNewLine]", "]"}]}]}]], "Input",
