   3.813229968713693*^9}, {3.814288465919678*^9, 3.814288498409215*^9}, {
   3.814636952260304*^9, 3.814636995339671*^9}, {3.815487650569769*^9, 
   3.815487712163282*^9}, {3.816617665797143*^9, 3.8166176937560153`*^9}, {
   3.921498119881857*^9, 
   3.921498170171694*^9}},ExpressionUUID->"d798701f-e692-475c-97c1-\
4f4c62345e54"],

Cell["\<\
calculate average values of variables using the kinetic theory of gases.\
\>", "Item",
 CellChangeTimes->{{3.8064070512118487`*^9, 3.806407140810502*^9}, {
   3.806408610343565*^9, 3.806408617904147*^9}, {3.8073525627645454`*^9, 
   3.8073526042919364`*^9}, {3.807352643248372*^9, 3.807352705404586*^9}, {
   3.80735276187842*^9, 3.8073527619871445`*^9}, {3.8073727459330997`*^9, 
   3.807372756665514*^9}, {3.8074586909710197`*^9, 3.807458700034519*^9}, {
   3.8076176285544367`*^9, 3.807617651036692*^9}, {3.8076306829401093`*^9, 
   3.8076306994297547`*^9}, 3.8078687260107346`*^9, {3.8079576272140217`*^9, 
   3.8079576676434283`*^9}, {3.80797841228898*^9, 3.807978446780261*^9}, {
   3.8080486103698187`*^9, 3.808048610391286*^9}, {3.8080647453616076`*^9, 
   3.8080647633147755`*^9}, {3.808741242202327*^9, 3.8087412770872917`*^9}, {
   3.8087415311739216`*^9, 3.8087415963248796`*^9}, {3.8095121420011387`*^9, 
   3.8095121793867736`*^9}, {3.8101220245692396`*^9, 3.810122097014723*^9}, {
   3.8104852592189817`*^9, 3.8104852979846115`*^9}, {3.8113311817051487`*^9, 
   3.8113312357719307`*^9}, {3.8116062119325094`*^9, 
   3.8116062211372156`*^9}, {3.8116062590685043`*^9, 3.811606289079325*^9}, {
   3.8119504030831833`*^9, 3.81195044504438*^9}, {3.8132299281835947`*^9, 
   3.813229968713693*^9}, {3.814288465919678*^9, 3.814288498409215*^9}, {
   3.814636952260304*^9, 3.814636995339671*^9}, {3.815487650569769*^9, 
   3.815487712163282*^9}, {3.816617665797143*^9, 3.8166176937560153`*^9}, {
   3.921498119881857*^9, 
   3.9214981878950577`*^9}},ExpressionUUID->"c563952e-b586-495f-8167-\
11c6f5a035df"],

Cell["\<\
compute collision frequencies and mean free path of gases using kinetic \
theory.\
\>", "Item",
 CellChangeTimes->{{3.8064070512118487`*^9, 3.806407140810502*^9}, {
   3.806408610343565*^9, 3.806408617904147*^9}, {3.8073525627645454`*^9, 
   3.8073526042919364`*^9}, {3.807352643248372*^9, 3.807352705404586*^9}, {
   3.80735276187842*^9, 3.8073527619871445`*^9}, {3.8073727459330997`*^9, 
   3.807372756665514*^9}, {3.8074586909710197`*^9, 3.807458700034519*^9}, {
   3.8076176285544367`*^9, 3.807617651036692*^9}, {3.8076306829401093`*^9, 
   3.8076306994297547`*^9}, 3.8078687260107346`*^9, {3.8079576272140217`*^9, 
   3.8079576676434283`*^9}, {3.80797841228898*^9, 3.807978446780261*^9}, {
   3.8080486103698187`*^9, 3.808048610391286*^9}, {3.8080647453616076`*^9, 
   3.8080647633147755`*^9}, {3.808741242202327*^9, 3.8087412770872917`*^9}, {
   3.8087415311739216`*^9, 3.8087415963248796`*^9}, {3.8095121420011387`*^9, 
   3.8095121793867736`*^9}, {3.8101220245692396`*^9, 3.810122097014723*^9}, {
   3.8104852592189817`*^9, 3.8104852979846115`*^9}, {3.8113311817051487`*^9, 
   3.8113312357719307`*^9}, {3.8116062119325094`*^9, 
   3.8116062211372156`*^9}, {3.8116062590685043`*^9, 3.811606289079325*^9}, {
   3.8119504030831833`*^9, 3.81195044504438*^9}, {3.8132299281835947`*^9, 
   3.813229968713693*^9}, {3.814288465919678*^9, 3.814288498409215*^9}, {
   3.814636952260304*^9, 3.814636995339671*^9}, {3.815487650569769*^9, 
   3.815487712163282*^9}, {3.816617665797143*^9, 3.8166176937560153`*^9}, {
   3.921498119881857*^9, 
   3.9214982038623095`*^9}},ExpressionUUID->"126178b6-400c-4c5c-92d7-\
c69ee7917982"]
}, Open  ]],

Cell[CellGroupData[{

Cell["States of a System", "Section",
 CellChangeTimes->{{3.8166021377775984`*^9, 3.816602143799884*^9}, {
  3.8166025858666277`*^9, 
  3.816602588103957*^9}},ExpressionUUID->"f307d8b7-26f2-4114-97f0-\
fa177b1d2d96"],

Cell["\<\
Let\[CloseCurlyQuote]s investigate the possible states of a system and define \
some terms that we would use to describe a generic system.\
\>", "Text",
 CellChangeTimes->{{3.8166026250590067`*^9, 
  3.816602642436257*^9}},ExpressionUUID->"07948a6b-c6ef-4715-9126-\
3cb01e723985"],

Cell[CellGroupData[{

Cell["Microstates and Macrostates", "Subsection",
 CellChangeTimes->{{3.8166025947147417`*^9, 
  3.8166025979116325`*^9}},ExpressionUUID->"8e21b472-c937-45e7-b2c0-\
7afaf59f4258"],

Cell[TextData[{
 "When we describe a system, we are typically using some collection of \
variables. Some of these variables describe a specific component of the \
system, which we will call ",
 StyleBox["microscopic",
  FontSlant->"Italic"],
 " variables. Other variables may describe properties of the entire system, \
which we will call ",
 StyleBox["macroscopic",
  FontSlant->"Italic"],
 " variables. Take the example of an ideal gas: microscopic variables would \
be the position and momentum of the individual gas molecules, whereas \
macroscopic variables would be properties such as energy, pressure, and \
volume."
}], "Text",
 CellChangeTimes->{{3.81660260053551*^9, 3.816602815305255*^9}, {
  3.8166182929517527`*^9, 3.816618293530142*^9}, {3.921245014189463*^9, 
  3.9212450484882097`*^9}},ExpressionUUID->"e02654b6-b42a-4660-9cba-\
438f7853d6ee"],

Cell["\<\
Now we are ready to define the microstate of a system: a microstate is given \
by the values of all of the microscopic variables that describe a system. \
Taking the ideal gas example once more, the microstate would be described by \
the position and velocity of all of the molecules or atoms. For the purposes \
of this course, we assume that these states are discrete (changing from \
discrete to continuous just means making the step size between states to be \
infinitely small).\
\>", "Text",
 CellChangeTimes->{{3.8166028527535224`*^9, 3.816603018534164*^9}, 
   3.8479829097130723`*^9, {3.8795209357310133`*^9, 3.8795209367304926`*^9}, {
   3.921245073771095*^9, 
   3.9212450763582444`*^9}},ExpressionUUID->"009ad48f-604d-49f1-a0dc-\
efd53eb668e4"],

Cell["\<\
There is often an immeasurably large number of microstates for a system, and \
identifying any one of these microstates would be extremely difficult \[Dash] \
imagine trying to measure the position and momentum of every molecule in a \
chamber filled with an ideal gas. That\[CloseCurlyQuote]s one reason we tend \
to describe systems by their macroscopic variables, which give a much more \
tractable and measurable set of variables. In addition, there may be multiple \
microstates that can be described by the same set of macroscopic variables, \
and we call the overall state of the system a macrostate. In other words, a \
macrostate is given by the values of all of the macroscopic variables that \
describe a system.\
\>", "Text",
 CellChangeTimes->{{3.8166030356008863`*^9, 
  3.816603277678857*^9}},ExpressionUUID->"58116338-c584-4186-b921-\
db721ebdbfe4"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Density of States", "Subsection",
 CellChangeTimes->{{3.8166033000599656`*^9, 
  3.816603301792419*^9}},ExpressionUUID->"83018336-08a1-42e2-a251-\
feb5d18ef121"],

Cell["\<\
As we just mentioned, there are usually many microstates that correspond to a \
given macrostate. We therefore define the quantity known as the density of \
states, which tells us the number of possible microstates for a given \
macrostate. We call it a density because it\[CloseCurlyQuote]s a measure of \
the number of states per unit \[OpenCurlyDoubleQuote]volume\
\[CloseCurlyDoubleQuote] of the space given by the macroscopic variables. We \
give this parameter the symbol \[CapitalOmega].\
\>", "Text",
 CellChangeTimes->{{3.816603388492911*^9, 3.8166035654900084`*^9}, {
  3.8166036027768583`*^9, 3.8166036389255743`*^9}, {3.8166036792727947`*^9, 
  3.8166036932232385`*^9}},ExpressionUUID->"01b08039-ad85-4564-823b-\
1421edce72e6"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[{
 "Postulate of Equal ",
 StyleBox["a priori",
  FontSlant->"Italic"],
 " Probabilities"
}], "Subsection",
 CellChangeTimes->{{3.816604565333928*^9, 
  3.8166045734164605`*^9}},ExpressionUUID->"22b5f241-50cd-41e3-952d-\
f23d9c1d92af"],

Cell[TextData[{
 "An important assumption for basic statistical mechanics is the postulate of \
equal ",
 StyleBox["a priori",
  FontSlant->"Italic"],
 " probabilities. This assumption states that a system has an equal \
probability of being in any microstate associated with a given macrostate. \
That means that the system does not favor any configuration that gives a \
certain macroscopic result. If a system satisfies this postulate, then we say \
that the system is in equilibrium."
}], "Text",
 CellChangeTimes->{{3.816604576186308*^9, 3.8166046682955875`*^9}, {
  3.816605062677153*^9, 3.8166050769467278`*^9}, {3.9214197322960167`*^9, 
  3.9214197345116167`*^9}},ExpressionUUID->"9ae1dc6e-b9f1-44e5-b4f7-\
461346565211"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Probabilities and Averages", "Subsection",
 CellChangeTimes->{{3.8166051600593243`*^9, 
  3.8166051694475746`*^9}},ExpressionUUID->"e351200a-026e-4161-8adf-\
533eacc391ca"],

Cell["\<\
We are often interested in the probability of a system being in a given \
state, so we have to think about how we define the set of possible states. \
For this course, we will apply an ensemble average approach. Imagine that you \
have a large number of copies of a system that are all in the same macrostate \
but which may have different microstates.  Within this ensemble, the \
probability of a microstate is given by the fraction of systems in that \
microstate relative to the total number of possible microstates. All of these \
microstates together form the statistical ensemble of the system.\
\>", "Text",
 CellChangeTimes->{{3.8166051770797653`*^9, 3.816605218936465*^9}, {
  3.921245230340471*^9, 
  3.9212455197204027`*^9}},ExpressionUUID->"c809b7e4-5bef-4d59-89d6-\
737f6430e6be"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["\<\
Probabilities, the Boltzmann Distribution, and Average Values\
\>", "Section",
 CellChangeTimes->{{3.8166061915992727`*^9, 3.8166062001448755`*^9}, {
   3.8166171310996428`*^9, 3.8166171448975058`*^9}, 3.921245618147767*^9, {
   3.921245679840007*^9, 3.921245680636515*^9}, {3.9212471210870857`*^9, 
   3.9212471222681017`*^9}, {3.9212519377776556`*^9, 
   3.921251948195799*^9}},ExpressionUUID->"a21b4e91-4fb2-4ae3-9652-\
2b1d12aadce3"],

Cell["\<\
We will now use several simple assumptions to obtain an expression for the \
probability of microstates and macrostates. We will also use this approach to \
arrive at the expression for the famous Boltzmann distribution.\
\>", "Text",
 CellChangeTimes->{{3.92124569677647*^9, 3.9212457249397*^9}, {
  3.921245755168206*^9, 3.9212457718240314`*^9}, {3.9214197724046288`*^9, 
  3.9214197729912224`*^9}},ExpressionUUID->"cf1d75e5-0baa-41ce-ab20-\
5b1eb80cf78c"],

Cell[CellGroupData[{

Cell["System and Surroundings", "Subsection",
 CellChangeTimes->{{3.816606235349147*^9, 
  3.816606238470067*^9}},ExpressionUUID->"38d9033d-cb61-47dd-be00-\
60384b3332ba"],

Cell["\<\
Let us first introduce the idea of a system and its surroundings, a concept \
with which you might be familiar from previous courses in thermodynamics. We \
define the total energy as\
\>", "Text",
 CellChangeTimes->{{3.816606240275381*^9, 
  3.816606304256604*^9}},ExpressionUUID->"fdec311a-70fb-4235-b1d9-\
6717f410c70c"],

Cell[BoxData[
 RowBox[{
  SubscriptBox[
   StyleBox["E",
    FontSlant->"Italic"], "tot"], "=", 
  RowBox[{
   SubscriptBox[
    StyleBox["E",
     FontSlant->"Italic"], "sys"], "+", 
   SubscriptBox[
    StyleBox["E",
     FontSlant->"Italic"], "surr"], "+", 
   SubscriptBox[
    StyleBox["E",
     FontSlant->"Italic"], "interact"]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.816606313917019*^9, 
  3.816606348170246*^9}},ExpressionUUID->"a1b5aad0-559a-4bd9-8805-\
cacae9f9046d"],

Cell[TextData[{
 "where ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["E",
    FontSlant->"Italic"], "tot"]],
  CellChangeTimes->{{3.816606313917019*^9, 3.816606348170246*^9}},
  ExpressionUUID->"d7e32d97-0a16-42e2-b52b-0b6e08269aa4"],
 " is the total energy, ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["E",
    FontSlant->"Italic"], "sys"]],
  CellChangeTimes->{{3.816606313917019*^9, 3.816606348170246*^9}},
  ExpressionUUID->"5ff6d1ca-381c-46eb-9d8c-dda3cbb411f2"],
 " is the energy of the system of interest, ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["E",
    FontSlant->"Italic"], "surr"]],
  CellChangeTimes->{{3.816606313917019*^9, 3.816606348170246*^9}},
  ExpressionUUID->"6280ab99-aed8-4f2d-94cc-61652994d5f0"],
 " is the energy of the surroundings, and ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["E",
    FontSlant->"Italic"], "interact"]],
  CellChangeTimes->{{3.816606313917019*^9, 3.816606348170246*^9}},
  ExpressionUUID->"10866bb5-0df0-486e-bb93-01d0d93292d0"],
 " is the energy of interaction between the system and its surroundings."
}], "Text",
 CellChangeTimes->{{3.8166063511178713`*^9, 
  3.816606425940915*^9}},ExpressionUUID->"95606bae-6b4e-4dc5-93f4-\
adf893500cf5"],

Cell["\<\
The first assumption that we make is that the energy of interaction is very \
small, so we can approximately write the energy as\
\>", "Text",
 CellChangeTimes->{{3.8166064415911283`*^9, 3.8166064515189257`*^9}, {
  3.8166065219278297`*^9, 
  3.8166065408341303`*^9}},ExpressionUUID->"50d0ba65-f827-48d3-a666-\
1eee40885892"],

Cell[BoxData[
 RowBox[{
  SubscriptBox[
   StyleBox["E",
    FontSlant->"Italic"], "tot"], "\[TildeTilde]", 
  RowBox[{
   SubscriptBox[
    StyleBox["E",
     FontSlant->"Italic"], "sys"], "+", 
   SubscriptBox[
    StyleBox["E",
     FontSlant->"Italic"], "surr"]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.816606313917019*^9, 3.816606348170246*^9}, {
  3.8166065472626705`*^9, 
  3.8166065528425016`*^9}},ExpressionUUID->"437e619c-a4f1-41a0-ad40-\
fc08645123e4"],

Cell["\<\
Secondly, we assume that the total density of states can be written as the \
product of the density of states of the system and surroundings,\
\>", "Text",
 CellChangeTimes->{{3.816606578462632*^9, 
  3.8166066033709946`*^9}},ExpressionUUID->"f4257d1b-24f2-46fc-923d-\
4ff52b45010f"],

Cell[BoxData[
 RowBox[{
  SubscriptBox["\[CapitalOmega]", "tot"], "\[TildeTilde]", 
  RowBox[{
   SubscriptBox["\[CapitalOmega]", "sys"], 
   SubscriptBox["\[CapitalOmega]", "surr"]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.816606313917019*^9, 3.816606348170246*^9}, {
  3.8166065472626705`*^9, 3.8166065528425016`*^9}, {3.816607096263274*^9, 
  3.8166071319089766`*^9}},ExpressionUUID->"18657b29-813c-4a8b-a4eb-\
2aab5d8e0087"],

Cell[TextData[{
 "which is another way of saying that the system and surroundings don\
\[CloseCurlyQuote]t strongly interact (just like a small value of ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["E",
    FontSlant->"Italic"], "interact"]],
  CellChangeTimes->{{3.816606313917019*^9, 3.816606348170246*^9}},
  ExpressionUUID->"5e4c2b30-0bfd-465b-85a1-c15e8c7e244e"],
 ")."
}], "Text",
 CellChangeTimes->{{3.816607147453282*^9, 
  3.8166071747419167`*^9}},ExpressionUUID->"5ebdd8d3-f1ef-4fa4-94b6-\
860a366a1dc0"],

Cell["\<\
As a final assumption, we state that the natural logarithm of the density of \
states of the surroundings has an approximately linear dependence on the \
energy of the surroundings,\
\>", "Text",
 CellChangeTimes->{{3.816607301555297*^9, 3.8166073996217275`*^9}, 
   3.921419824585557*^9},ExpressionUUID->"45cfdc1e-a74e-4563-9eb4-\
b8e775934db5"],

Cell[BoxData[
 RowBox[{
  RowBox[{"ln", 
   RowBox[{"(", 
    RowBox[{
     SubscriptBox["\[CapitalOmega]", "surr"], 
     RowBox[{"(", 
      SubscriptBox[
       StyleBox["E",
        FontSlant->"Italic"], "surr"], ")"}]}], ")"}]}], "\[TildeTilde]", 
  RowBox[{"\[Alpha]", "+", 
   SubscriptBox[
    StyleBox[
     RowBox[{"\[Beta]", 
      StyleBox["E",
       FontSlant->"Italic"]}]], "surr"]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.816606313917019*^9, 3.816606348170246*^9}, {
  3.8166065472626705`*^9, 3.8166065528425016`*^9}, {3.8166074110975957`*^9, 
  3.816607456388423*^9}},ExpressionUUID->"3c7cfc8a-a3b8-4e89-8b8a-\
aedbdc3bdd0a"],

Cell[TextData[{
 "This assumption is generally valid if ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["E",
    FontSlant->"Italic"], "surr"]],
  CellChangeTimes->{{3.816606313917019*^9, 3.816606348170246*^9}, {
   3.8166065472626705`*^9, 3.8166065528425016`*^9}, {3.8166074110975957`*^9, 
   3.816607456388423*^9}},ExpressionUUID->
  "8482b222-beb6-4ed6-8165-f915b3a000b0"],
 " doesn\[CloseCurlyQuote]t change very much, which implies that the \
surroundings are much bigger than the system and are thus unaffected by \
changes in the system."
}], "Text",
 CellChangeTimes->{{3.8166074925178385`*^9, 
  3.816607549720132*^9}},ExpressionUUID->"1bb7b80c-808a-4ee0-8f12-\
1758b882e022"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Probability of a System Microstate", "Subsection",
 CellChangeTimes->{{3.8166076313519244`*^9, 
  3.8166076365415983`*^9}},ExpressionUUID->"6c2786ac-e48a-4777-92ac-\
e44306c18d9b"],

Cell[TextData[{
 "Now we want to find the probability that the system is in a certain \
microstate given the macrostate of the system plus surroundings. The total \
possible microstates are given by ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox["\[CapitalOmega]", "tot"], 
   RowBox[{"(", 
    SubscriptBox[
     StyleBox["E",
      FontSlant->"Italic"], "tot"], ")"}]}]],
  CellChangeTimes->{{3.816606313917019*^9, 3.816606348170246*^9}, {
   3.8166065472626705`*^9, 3.8166065528425016`*^9}, {3.816607096263274*^9, 
   3.8166071319089766`*^9}},ExpressionUUID->
  "828cc1da-8ad8-434f-9b04-cb1d59a09ea3"],
 ". Because ",
 Cell[BoxData[
  SubscriptBox["\[CapitalOmega]", "sys"]],
  CellChangeTimes->{{3.816606313917019*^9, 3.816606348170246*^9}, {
   3.8166065472626705`*^9, 3.8166065528425016`*^9}, {3.816607096263274*^9, 
   3.8166071319089766`*^9}},ExpressionUUID->
  "9f8f77d9-d3ac-40e0-9f14-c562b335199e"],
 " and ",
 Cell[BoxData[
  SubscriptBox["\[CapitalOmega]", "surr"]],ExpressionUUID->
  "e22c17de-6002-4d01-afa9-21c5fa4d1d23"],
 " are independent and have a constant product ",
 Cell[BoxData[
  SubscriptBox["\[CapitalOmega]", "tot"]],
  CellChangeTimes->{{3.816606313917019*^9, 3.816606348170246*^9}, {
   3.8166065472626705`*^9, 3.8166065528425016`*^9}, {3.816607096263274*^9, 
   3.8166071319089766`*^9}},ExpressionUUID->
  "04efb7a9-9445-4bd2-b619-c52d4ef5c64b"],
 ", specifying ",
 Cell[BoxData[
  SubscriptBox["\[CapitalOmega]", "surr"]],ExpressionUUID->
  "2a6dc052-ad12-4865-8197-c9f08839aeae"],
 " also indirectly defines  ",
 Cell[BoxData[
  SubscriptBox["\[CapitalOmega]", "sys"]],
  CellChangeTimes->{{3.816606313917019*^9, 3.816606348170246*^9}, {
   3.8166065472626705`*^9, 3.8166065528425016`*^9}, {3.816607096263274*^9, 
   3.8166071319089766`*^9}},ExpressionUUID->
  "fbb6bcf9-246c-40d9-b54e-9698fd799423"],
 ". Therefore, the number of microstates that have the ",
 StyleBox["system",
  FontSlant->"Italic"],
 " in a given microstate can be specified by"
}], "Text",
 CellChangeTimes->{{3.8166076545826044`*^9, 3.8166077903998766`*^9}, {
  3.816607869618592*^9, 3.816607959358178*^9}, {3.8166080801668124`*^9, 
  3.816608264173895*^9}, {3.9212458992883368`*^9, 3.921245899962549*^9}, {
  3.921419911740264*^9, 3.9214199130792403`*^9}, {3.921419947071705*^9, 
  3.9214200130596666`*^9}},ExpressionUUID->"1f620077-37d5-40fe-ae66-\
3c400973798f"],

Cell[BoxData[
 RowBox[{
  SubscriptBox["\[CapitalOmega]", "surr"], 
  RowBox[{"(", 
   SubscriptBox[
    StyleBox["E",
     FontSlant->"Italic"], "surr"], ")"}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.816606313917019*^9, 3.816606348170246*^9}, {
  3.8166065472626705`*^9, 3.8166065528425016`*^9}, {3.816607096263274*^9, 
  3.8166071319089766`*^9}, {3.8166082792077055`*^9, 
  3.816608293099399*^9}},ExpressionUUID->"833f1d89-8654-4c6a-bcf8-\
305afc7aed62"],

Cell["Because the energies are additive (equation 2), we have that", "Text",
 CellChangeTimes->{{3.816608307366105*^9, 3.8166083282979207`*^9}, {
  3.9214199398047085`*^9, 
  3.9214199443727536`*^9}},ExpressionUUID->"e31ec3e1-aece-4e66-9aba-\
8bda868651e8"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   SubscriptBox["\[CapitalOmega]", "surr"], 
   RowBox[{"(", 
    SubscriptBox[
     StyleBox["E",
      FontSlant->"Italic"], "surr"], ")"}]}], "=", 
  RowBox[{
   SubscriptBox["\[CapitalOmega]", "surr"], 
   RowBox[{"(", 
    RowBox[{
     SubscriptBox[
      StyleBox["E",
       FontSlant->"Italic"], 
      StyleBox["tot",
       FontSlant->"Italic"]], "-", 
     SubscriptBox[
      StyleBox["E",
       FontSlant->"Italic"], "sys"]}], ")"}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.816606313917019*^9, 3.816606348170246*^9}, {
  3.8166065472626705`*^9, 3.8166065528425016`*^9}, {3.816607096263274*^9, 
  3.8166071319089766`*^9}, {3.8166082792077055`*^9, 3.816608293099399*^9}, {
  3.816608332410132*^9, 
  3.8166083462110634`*^9}},ExpressionUUID->"6c382dc9-c433-4a59-b478-\
44da4d6728d9"],

Cell["Finally, based on our linearity assumption, we have that", "Text",
 CellChangeTimes->{{3.81660838534805*^9, 
  3.81660839472323*^9}},ExpressionUUID->"4bdfe8ed-e353-43ef-93f4-\
cb84d4e8bab9"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   SubscriptBox["\[CapitalOmega]", "surr"], 
   RowBox[{"(", 
    SubscriptBox[
     StyleBox["E",
      FontSlant->"Italic"], "surr"], ")"}]}], "=", 
  SuperscriptBox["\[ExponentialE]", 
   RowBox[{"\[Alpha]", "+", 
    SubscriptBox[
     StyleBox[
      RowBox[{"\[Beta]", 
       StyleBox["E",
        FontSlant->"Italic"]}]], "surr"]}]]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.816606313917019*^9, 3.816606348170246*^9}, {
  3.8166065472626705`*^9, 3.8166065528425016`*^9}, {3.816607096263274*^9, 
  3.8166071319089766`*^9}, {3.8166082792077055`*^9, 3.816608293099399*^9}, {
  3.816608332410132*^9, 3.8166083462110634`*^9}, {3.8166084113469725`*^9, 
  3.8166084137878127`*^9}},ExpressionUUID->"5741f075-45a6-4e8c-8b2d-\
191fc64c37d4"],

Cell["\<\
Now, note that the probability of the system being in a given microstate is \
proportional to the density of states of the surrounding,\
\>", "Text",
 CellChangeTimes->{{3.8166085155095367`*^9, 3.816608569326377*^9}, {
  3.8166086025615854`*^9, 
  3.8166086147560883`*^9}},ExpressionUUID->"9cd51b40-4e29-44b9-8604-\
eb0c8ab49d2b"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    StyleBox["p",
     FontSlant->"Italic"], 
    RowBox[{
     StyleBox["(",
      FontSlant->"Italic"], 
     SubscriptBox[
      StyleBox["E",
       FontSlant->"Italic"], "sys"], ")"}]}], "\[Proportional]", 
   RowBox[{
    SubscriptBox["\[CapitalOmega]", "surr"], 
    RowBox[{"(", 
     RowBox[{
      SubscriptBox[
       StyleBox["E",
        FontSlant->"Italic"], "tot"], "-", 
      SubscriptBox[
       StyleBox["E",
        FontSlant->"Italic"], "sys"]}], ")"}]}]}], "=", 
  SuperscriptBox["\[ExponentialE]", 
   RowBox[{"\[Alpha]", "+", 
    RowBox[{"\[Beta]", 
     RowBox[{"(", 
      RowBox[{
       SubscriptBox[
        StyleBox["E",
         FontSlant->"Italic"], "tot"], "-", 
       SubscriptBox[
        StyleBox["E",
         FontSlant->"Italic"], "sys"]}], 
      ")"}]}]}]]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.816606313917019*^9, 3.816606348170246*^9}, {
  3.8166065472626705`*^9, 3.8166065528425016`*^9}, {3.816607096263274*^9, 
  3.8166071319089766`*^9}, {3.8166082792077055`*^9, 3.816608293099399*^9}, {
  3.816608332410132*^9, 3.8166083462110634`*^9}, {3.8166084113469725`*^9, 
  3.8166084137878127`*^9}, {3.8166085853535995`*^9, 
  3.8166086653266125`*^9}},ExpressionUUID->"af04752c-130c-42e4-b4d7-\
14a4262445bd"],

Cell["\<\
This result is logical if we remember that the density of states is \
essentially stating how many microstates there are for a given energy, so the \
probability will be proportional to this density.  If we take the natural \
logarithm of both sides of equation (8), we obtain\
\>", "Text",
 CellChangeTimes->{{3.816608799494191*^9, 3.8166088116426573`*^9}, {
  3.921246002417602*^9, 3.9212460436983366`*^9}, {3.9212461547059364`*^9, 
  3.9212461633078737`*^9}, {3.940941118062315*^9, 
  3.9409411249763546`*^9}},ExpressionUUID->"9957ff75-b2d9-44f8-978f-\
17c1b2914f0c"],

Cell[BoxData[
 RowBox[{
  RowBox[{"ln", "[", 
   RowBox[{
    SubscriptBox["\[CapitalOmega]", "surr"], 
    RowBox[{"(", 
     RowBox[{
      SubscriptBox[
       StyleBox["E",
        FontSlant->"Italic"], "tot"], "-", 
      SubscriptBox[
       StyleBox["E",
        FontSlant->"Italic"], "sys"]}], ")"}]}], "]"}], "=", 
  RowBox[{"\[Alpha]", "+", 
   RowBox[{"\[Beta]", 
    RowBox[{"(", 
     RowBox[{
      SubscriptBox[
       StyleBox["E",
        FontSlant->"Italic"], "tot"], "-", 
      SubscriptBox[
       StyleBox["E",
        FontSlant->"Italic"], "sys"]}], ")"}]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.816606313917019*^9, 3.816606348170246*^9}, {
   3.8166065472626705`*^9, 3.8166065528425016`*^9}, {3.816607096263274*^9, 
   3.8166071319089766`*^9}, {3.8166082792077055`*^9, 3.816608293099399*^9}, {
   3.816608332410132*^9, 3.8166083462110634`*^9}, {3.8166084113469725`*^9, 
   3.8166084137878127`*^9}, {3.8166085853535995`*^9, 
   3.8166086653266125`*^9}, {3.8166088264224434`*^9, 
   3.8166088426463857`*^9}, {3.816608894346527*^9, 3.816608903756837*^9}, 
   3.9212461986358933`*^9},ExpressionUUID->"ce6adf66-d67c-4665-b0e3-\
9595e661d6c7"],

Cell["\<\
Then, if we take the derivative with respect to energy, we obtain\
\>", "Text",
 CellChangeTimes->{{3.816608905770305*^9, 3.8166089224242244`*^9}, {
  3.816608981517026*^9, 3.816608983673538*^9}, {3.8166090202848873`*^9, 
  3.816609024720733*^9}},ExpressionUUID->"908af48a-5d97-430c-91e5-\
11d43908e198"],

Cell[BoxData[
 RowBox[{"\[Beta]", "=", 
  FractionBox[
   RowBox[{"\[PartialD]", 
    RowBox[{"ln", "[", 
     RowBox[{
      SubscriptBox["\[CapitalOmega]", "surr"], 
      RowBox[{"(", 
       RowBox[{
        SubscriptBox[
         StyleBox["E",
          FontSlant->"Italic"], "tot"], "-", 
        SubscriptBox[
         StyleBox["E",
          FontSlant->"Italic"], "sys"]}], ")"}]}], "]"}]}], 
   RowBox[{"\[PartialD]", 
    RowBox[{"(", 
     RowBox[{
      SubscriptBox[
       StyleBox["E",
        FontSlant->"Italic"], "tot"], "-", 
      SubscriptBox[
       StyleBox["E",
        FontSlant->"Italic"], "sys"]}], ")"}]}]]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.816606313917019*^9, 3.816606348170246*^9}, {
   3.8166065472626705`*^9, 3.8166065528425016`*^9}, {3.816607096263274*^9, 
   3.8166071319089766`*^9}, {3.8166082792077055`*^9, 3.816608293099399*^9}, {
   3.816608332410132*^9, 3.8166083462110634`*^9}, {3.8166084113469725`*^9, 
   3.8166084137878127`*^9}, {3.8166085853535995`*^9, 
   3.8166086653266125`*^9}, {3.8166088264224434`*^9, 
   3.8166088426463857`*^9}, {3.816608894346527*^9, 3.816608903756837*^9}, {
   3.8166090357324424`*^9, 3.81660909242737*^9}, 
   3.9212462230998273`*^9},ExpressionUUID->"0f523da7-aab4-4ca0-95bc-\
67eff1d67876"],

Cell["We now introduce a new variable and constant,", "Text",
 CellChangeTimes->{{3.816609122212395*^9, 
  3.8166091462297244`*^9}},ExpressionUUID->"7716b5ea-e68f-41a8-829d-\
2451a86a21e0"],

Cell[BoxData[
 RowBox[{
  FractionBox["1", 
   RowBox[{
    SubscriptBox[
     StyleBox["k",
      FontSlant->"Italic"], 
     StyleBox["B",
      FontSlant->"Italic"]], 
    StyleBox["T",
     FontSlant->"Italic"]}]], "=", 
  RowBox[{"\[Beta]", "=", 
   FractionBox[
    RowBox[{"\[PartialD]", 
     RowBox[{"ln", "[", 
      RowBox[{
       SubscriptBox["\[CapitalOmega]", "surr"], 
       RowBox[{"(", 
        RowBox[{
         SubscriptBox[
          StyleBox["E",
           FontSlant->"Italic"], "tot"], "-", 
         SubscriptBox[
          StyleBox["E",
           FontSlant->"Italic"], "sys"]}], ")"}]}], "]"}]}], 
    RowBox[{"\[PartialD]", 
     RowBox[{"(", 
      RowBox[{
       SubscriptBox[
        StyleBox["E",
         FontSlant->"Italic"], "tot"], "-", 
       SubscriptBox[
        StyleBox["E",
         FontSlant->"Italic"], "sys"]}], 
      ")"}]}]]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.816606313917019*^9, 3.816606348170246*^9}, {
  3.8166065472626705`*^9, 3.8166065528425016`*^9}, {3.816607096263274*^9, 
  3.8166071319089766`*^9}, {3.8166082792077055`*^9, 3.816608293099399*^9}, {
  3.816608332410132*^9, 3.8166083462110634`*^9}, {3.8166084113469725`*^9, 
  3.8166084137878127`*^9}, {3.8166085853535995`*^9, 3.8166086653266125`*^9}, {
  3.8166088264224434`*^9, 3.8166088426463857`*^9}, {3.816608894346527*^9, 
  3.816608903756837*^9}, {3.8166090357324424`*^9, 3.81660909242737*^9}, {
  3.816609150867611*^9, 3.8166091576017056`*^9}, {3.9212462604868855`*^9, 
  3.9212462741217575`*^9}},ExpressionUUID->"6998db4e-b712-4fd7-ba9a-\
bf754e9b3e59"],

Cell[TextData[{
 "where ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["k",
    FontSlant->"Italic"], 
   StyleBox["B",
    FontSlant->"Italic"]]],
  CellChangeTimes->{{3.816606313917019*^9, 3.816606348170246*^9}, {
   3.8166065472626705`*^9, 3.8166065528425016`*^9}, {3.816607096263274*^9, 
   3.8166071319089766`*^9}, {3.8166082792077055`*^9, 3.816608293099399*^9}, {
   3.816608332410132*^9, 3.8166083462110634`*^9}, {3.8166084113469725`*^9, 
   3.8166084137878127`*^9}, {3.8166085853535995`*^9, 
   3.8166086653266125`*^9}, {3.8166088264224434`*^9, 
   3.8166088426463857`*^9}, {3.816608894346527*^9, 3.816608903756837*^9}, {
   3.8166090357324424`*^9, 3.81660909242737*^9}, {3.816609150867611*^9, 
   3.8166091576017056`*^9}, {3.9212462604868855`*^9, 3.921246260805328*^9}},
  ExpressionUUID->"24bd3b4b-bb94-40d3-862c-cb3825370115"],
 " is Boltzmann\[CloseCurlyQuote]s constant, and ",
 StyleBox["T",
  FontSlant->"Italic"],
 " is the temperature."
}], "Text",
 CellChangeTimes->{{3.8166091622486773`*^9, 3.816609181528555*^9}, 
   3.9212462671716423`*^9},ExpressionUUID->"633a34d7-7686-4688-8f2c-\
f9ec07f32073"],

Cell[TextData[{
 "With our new constants \[Beta] and ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["k",
    FontSlant->"Italic"], 
   StyleBox["B",
    FontSlant->"Italic"]]],
  CellChangeTimes->{{3.816606313917019*^9, 3.816606348170246*^9}, {
   3.8166065472626705`*^9, 3.8166065528425016`*^9}, {3.816607096263274*^9, 
   3.8166071319089766`*^9}, {3.8166082792077055`*^9, 3.816608293099399*^9}, {
   3.816608332410132*^9, 3.8166083462110634`*^9}, {3.8166084113469725`*^9, 
   3.8166084137878127`*^9}, {3.8166085853535995`*^9, 
   3.8166086653266125`*^9}, {3.8166088264224434`*^9, 
   3.8166088426463857`*^9}, {3.816608894346527*^9, 3.816608903756837*^9}, {
   3.8166090357324424`*^9, 3.81660909242737*^9}, {3.816609150867611*^9, 
   3.8166091576017056`*^9}, {3.9212462604868855`*^9, 3.921246260805328*^9}},
  ExpressionUUID->"029c4e72-bef9-4cbd-a25d-2f865bd9cf14"],
 " in hand, we return to our probability expression in equation (8). Because ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["E",
    FontSlant->"Italic"], "tot"]],
  CellChangeTimes->{{3.816606313917019*^9, 3.816606348170246*^9}, {
   3.8166065472626705`*^9, 3.8166065528425016`*^9}, {3.816607096263274*^9, 
   3.8166071319089766`*^9}, {3.8166082792077055`*^9, 3.816608293099399*^9}, {
   3.816608332410132*^9, 3.8166083462110634`*^9}, {3.8166084113469725`*^9, 
   3.8166084137878127`*^9}, {3.8166085853535995`*^9, 3.8166086653266125`*^9}},
  ExpressionUUID->"9dd5ca5a-fbed-42e6-b669-37e07da7b0ba"],
 " must be constant, and \[Alpha] is also a constant, we find that the \
probability must obey the proportionality"
}], "Text",
 CellChangeTimes->{{3.816608636984954*^9, 3.816608639061941*^9}, {
  3.8166086705191545`*^9, 3.816608701403414*^9}, {3.9212463784897146`*^9, 
  3.921246411060747*^9}},ExpressionUUID->"75f5a48b-c495-4829-bd6f-\
6996ed831da3"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   StyleBox["p",
    FontSlant->"Italic"], 
   RowBox[{
    StyleBox["(",
     FontSlant->"Italic"], 
    SubscriptBox[
     StyleBox["E",
      FontSlant->"Italic"], "sys"], ")"}]}], "\[Proportional]", 
  RowBox[{
   SubscriptBox["\[CapitalOmega]", "surr"], 
   RowBox[{"(", 
    RowBox[{
     SubscriptBox[
      StyleBox["E",
       FontSlant->"Italic"], "tot"], "-", 
     SubscriptBox[
      StyleBox["E",
       FontSlant->"Italic"], "sys"]}], ")"}]}], "\[Proportional]", 
  SuperscriptBox["\[ExponentialE]", 
   RowBox[{"-", 
    SubscriptBox[
     StyleBox[
      RowBox[{"\[Beta]", 
       StyleBox["E",
        FontSlant->"Italic"]}]], "sys"]}]]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.816606313917019*^9, 3.816606348170246*^9}, {
  3.8166065472626705`*^9, 3.8166065528425016`*^9}, {3.816607096263274*^9, 
  3.8166071319089766`*^9}, {3.8166082792077055`*^9, 3.816608293099399*^9}, {
  3.816608332410132*^9, 3.8166083462110634`*^9}, {3.8166084113469725`*^9, 
  3.8166084137878127`*^9}, {3.8166085853535995`*^9, 3.8166086653266125`*^9}, {
  3.816608708567449*^9, 
  3.8166087156576424`*^9}},ExpressionUUID->"5a56de02-26db-4fb9-9b45-\
d0d0323fc097"],

Cell["Or, using the temperature definition,", "Text",
 CellChangeTimes->{{3.8166091987171545`*^9, 
  3.8166092049434547`*^9}},ExpressionUUID->"09b34a5a-498c-427b-93f5-\
6b27dbd00c2e"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   StyleBox["p",
    FontSlant->"Italic"], 
   RowBox[{
    StyleBox["(",
     FontSlant->"Italic"], 
    SubscriptBox[
     StyleBox["E",
      FontSlant->"Italic"], "sys"], ")"}]}], "\[Proportional]", 
  SuperscriptBox["\[ExponentialE]", 
   RowBox[{
    RowBox[{
     RowBox[{"-", 
      SubscriptBox[
       StyleBox["E",
        FontSlant->"Italic"], "sys"]}], "/", 
     StyleBox[
      SubscriptBox[
       StyleBox["k",
        FontSlant->"Italic"], 
       StyleBox["B",
        FontSlant->"Italic"]],
      FontSlant->"Italic"]}], 
    StyleBox["T",
     FontSlant->"Italic"]}]]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.816606313917019*^9, 3.816606348170246*^9}, {
   3.8166065472626705`*^9, 3.8166065528425016`*^9}, {3.816607096263274*^9, 
   3.8166071319089766`*^9}, {3.8166082792077055`*^9, 3.816608293099399*^9}, {
   3.816608332410132*^9, 3.8166083462110634`*^9}, {3.8166084113469725`*^9, 
   3.8166084137878127`*^9}, {3.8166085853535995`*^9, 
   3.8166086653266125`*^9}, {3.816608708567449*^9, 3.8166087156576424`*^9}, {
   3.8166092184739776`*^9, 3.8166092268161383`*^9}, 
   3.9212464955540795`*^9},ExpressionUUID->"e92d1d09-1ee3-4f93-a7ca-\
59e93c96eee9"],

Cell[TextData[{
 "If we are comparing two states ",
 StyleBox["A",
  FontSlant->"Italic"],
 " and ",
 StyleBox["B",
  FontSlant->"Italic"],
 ", the ratio of probability for finding the system in those two states is \
given by the ",
 StyleBox["Boltzmann factor",
  FontWeight->"Bold"],
 ","
}], "Text",
 CellChangeTimes->{{3.9212465027174726`*^9, 3.9212465959348993`*^9}, 
   3.921246768088726*^9},ExpressionUUID->"4e80d68a-15d9-4f01-9f1c-\
3644ccdf9f3d"],

Cell[BoxData[
 RowBox[{
  FractionBox[
   SubscriptBox[
    StyleBox["p",
     FontSlant->"Italic"], "B"], 
   SubscriptBox[
    StyleBox["p",
     FontSlant->"Italic"], "A"]], "=", 
  SuperscriptBox["\[ExponentialE]", 
   RowBox[{
    RowBox[{
     RowBox[{"-", 
      RowBox[{"(", 
       RowBox[{
        SubscriptBox[
         StyleBox["E",
          FontSlant->"Italic"], "B"], "-", 
        SubscriptBox[
         StyleBox["E",
          FontSlant->"Italic"], "A"]}], ")"}]}], "/", 
     StyleBox[
      SubscriptBox[
       StyleBox["k",
        FontSlant->"Italic"], 
       StyleBox["B",
        FontSlant->"Italic"]],
      FontSlant->"Italic"]}], 
    StyleBox["T",
     FontSlant->"Italic"]}]]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.816606313917019*^9, 3.816606348170246*^9}, {
   3.8166065472626705`*^9, 3.8166065528425016`*^9}, {3.816607096263274*^9, 
   3.8166071319089766`*^9}, {3.8166082792077055`*^9, 3.816608293099399*^9}, {
   3.816608332410132*^9, 3.8166083462110634`*^9}, {3.8166084113469725`*^9, 
   3.8166084137878127`*^9}, {3.8166085853535995`*^9, 
   3.8166086653266125`*^9}, {3.816608708567449*^9, 3.8166087156576424`*^9}, {
   3.8166092184739776`*^9, 3.8166092268161383`*^9}, 3.9212464955540795`*^9, {
   3.9212466153988075`*^9, 3.921246645478285*^9}, {3.921246748717478*^9, 
   3.921246753732299*^9}},ExpressionUUID->"c679491f-cfdc-4c05-9903-\
12e5895fa84c"],

Cell[TextData[{
 "This equation tells us that the probability of finding a system in \
microstate ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["E", "i"], TraditionalForm]],ExpressionUUID->
  "3861a349-211d-481e-b545-f13599d5f54d"],
 " decays exponentially with increasing ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["E", "i"], TraditionalForm]],ExpressionUUID->
  "14903931-7453-4fd6-8b4e-ccd8fac018d4"],
 " for a given temperature of the system. "
}], "Text",
 CellChangeTimes->{
  3.9212467817696223`*^9},ExpressionUUID->"62068395-e90f-4af9-805b-\
b96990c78173"],

Cell["\<\
The Boltzmann factor provides a straightforward method to determine the \
relative populations of microstates. However, we can also determine the \
absolute population if we normalize equation (13), which we can do using the \
condition that the total probability is equal to one\
\>", "Text",
 CellChangeTimes->{{3.8166087271660614`*^9, 3.8166087615016165`*^9}, 
   3.8166091901323013`*^9, {3.8166092607465935`*^9, 3.816609287230299*^9}, {
   3.921246806256157*^9, 
   3.9212468509687653`*^9}},ExpressionUUID->"5d749b26-8059-4f80-b727-\
1f212ea4b6fb"],

Cell[BoxData[
 RowBox[{
  StyleBox["Z",
   FontSlant->"Italic"], "=", 
  RowBox[{
   RowBox[{"\[Sum]", 
    SuperscriptBox["\[ExponentialE]", 
     RowBox[{
      RowBox[{
       RowBox[{"-", 
        SubscriptBox[
         StyleBox["E",
          FontSlant->"Italic"], "sys"]}], "/", 
       StyleBox[
        SubscriptBox[
         StyleBox["k",
          FontSlant->"Italic"], 
         StyleBox["B",
          FontSlant->"Italic"]],
        FontSlant->"Italic"]}], 
      StyleBox["T",
       FontSlant->"Italic"]}]]}], "=", "1"}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.816606313917019*^9, 3.816606348170246*^9}, {
   3.8166065472626705`*^9, 3.8166065528425016`*^9}, {3.816607096263274*^9, 
   3.8166071319089766`*^9}, {3.8166082792077055`*^9, 3.816608293099399*^9}, {
   3.816608332410132*^9, 3.8166083462110634`*^9}, {3.8166084113469725`*^9, 
   3.8166084137878127`*^9}, {3.8166085853535995`*^9, 
   3.8166086653266125`*^9}, {3.816608708567449*^9, 3.8166087156576424`*^9}, {
   3.8166092184739776`*^9, 3.8166092268161383`*^9}, {3.816609322899888*^9, 
   3.8166093317568235`*^9}, {3.8166149504232464`*^9, 3.816614951907629*^9}, 
   3.92124685792043*^9},ExpressionUUID->"67a1fe72-3dcf-4504-9ac6-\
96961dd349d4"],

Cell[TextData[{
 "where the sum is over all microstates, and we have assigned this sum to the \
variable ",
 StyleBox["Z",
  FontSlant->"Italic"],
 ", the ",
 StyleBox["partition function",
  FontSlant->"Italic"],
 " of the system. The final equation for the probability is then"
}], "Text",
 CellChangeTimes->{{3.8166149433638887`*^9, 3.816614962453189*^9}, {
  3.8166150130737224`*^9, 
  3.816615053750064*^9}},ExpressionUUID->"892ee675-7793-4cac-abba-\
8090107d92c8"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   StyleBox["p",
    FontSlant->"Italic"], 
   RowBox[{
    StyleBox["(",
     FontSlant->"Italic"], 
    SubscriptBox[
     StyleBox["E",
      FontSlant->"Italic"], "sys"], ")"}]}], "=", 
  RowBox[{
   FractionBox[
    SuperscriptBox["\[ExponentialE]", 
     RowBox[{
      RowBox[{
       RowBox[{"-", 
        SubscriptBox[
         StyleBox["E",
          FontSlant->"Italic"], "sys"]}], "/", 
       StyleBox[
        SubscriptBox[
         StyleBox["k",
          FontSlant->"Italic"], 
         StyleBox["B",
          FontSlant->"Italic"]],
        FontSlant->"Italic"]}], 
      StyleBox["T",
       FontSlant->"Italic"]}]], 
    RowBox[{"\[Sum]", 
     SuperscriptBox["\[ExponentialE]", 
      RowBox[{
       RowBox[{
        RowBox[{"-", 
         SubscriptBox[
          StyleBox["E",
           FontSlant->"Italic"], "sys"]}], "/", 
        StyleBox[
         SubscriptBox[
          StyleBox["k",
           FontSlant->"Italic"], 
          StyleBox["B",
           FontSlant->"Italic"]],
         FontSlant->"Italic"]}], 
       StyleBox["T",
        FontSlant->"Italic"]}]]}]], "=", 
   FractionBox[
    SuperscriptBox["\[ExponentialE]", 
     RowBox[{
      RowBox[{
       RowBox[{"-", 
        SubscriptBox[
         StyleBox["E",
          FontSlant->"Italic"], "sys"]}], "/", 
       StyleBox[
        SubscriptBox[
         StyleBox["k",
          FontSlant->"Italic"], 
         StyleBox["B",
          FontSlant->"Italic"]],
        FontSlant->"Italic"]}], 
      StyleBox["T",
       FontSlant->"Italic"]}]], 
    StyleBox["Z",
     FontSlant->"Italic"]]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.816606313917019*^9, 3.816606348170246*^9}, {
  3.8166065472626705`*^9, 3.8166065528425016`*^9}, {3.816607096263274*^9, 
  3.8166071319089766`*^9}, {3.8166082792077055`*^9, 3.816608293099399*^9}, {
  3.816608332410132*^9, 3.8166083462110634`*^9}, {3.8166084113469725`*^9, 
  3.8166084137878127`*^9}, {3.8166085853535995`*^9, 3.8166086653266125`*^9}, {
  3.816608708567449*^9, 3.8166087156576424`*^9}, {3.8166092184739776`*^9, 
  3.8166092268161383`*^9}, {3.8166150630343227`*^9, 3.816615085830597*^9}, {
  3.9212468651851816`*^9, 
  3.9212468696509485`*^9}},ExpressionUUID->"d8f0f142-f8f6-424d-b80c-\
c1cf3a5d1af6"],

Cell["This equation is in fact the Boltzmann distribution! ", "Text",
 CellChangeTimes->{{3.8166151547631645`*^9, 3.8166151753835382`*^9}, {
   3.8166153975865774`*^9, 3.816615404234041*^9}, {3.8166167045599174`*^9, 
   3.81661671020793*^9}, 3.921245736583801*^9, {3.9212464599027615`*^9, 
   3.9212464894777813`*^9}, 
   3.9212468780395975`*^9},ExpressionUUID->"2ea2e743-a454-4db0-b817-\
20f6704652bc"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Probability of a Macrostate", "Subsection",
 CellChangeTimes->{{3.81661604236942*^9, 
  3.8166160496818204`*^9}},ExpressionUUID->"2179695a-258d-47e9-9704-\
41354bdccc4f"],

Cell["\<\
To calculate the probability of a macrostate, we now take the sum over the \
probabilities of all of the individual microstates,\
\>", "Text",
 CellChangeTimes->{{3.816616057544656*^9, 
  3.8166160952068343`*^9}},ExpressionUUID->"c1e7ef6c-2642-4428-9234-\
358b116b119d"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   SubscriptBox[
    StyleBox["p",
     FontSlant->"Italic"], "macro"], 
   RowBox[{
    StyleBox["(",
     FontSlant->"Italic"], 
    SubscriptBox[
     StyleBox["E",
      FontSlant->"Italic"], 
     StyleBox["i",
      FontSlant->"Italic"]], ")"}]}], "=", 
  RowBox[{
   FractionBox["1", 
    StyleBox["Z",
     FontSlant->"Italic"]], 
   RowBox[{
    UnderscriptBox["\[Sum]", 
     StyleBox["i",
      FontSlant->"Italic"]], 
    SuperscriptBox["\[ExponentialE]", 
     RowBox[{
      RowBox[{
       RowBox[{"-", 
        SubscriptBox[
         StyleBox["E",
          FontSlant->"Italic"], 
         StyleBox["i",
          FontSlant->"Italic"]]}], "/", 
       StyleBox[
        SubscriptBox[
         StyleBox["k",
          FontSlant->"Italic"], 
         StyleBox["B",
          FontSlant->"Italic"]],
        FontSlant->"Italic"]}], 
      StyleBox["T",
       FontSlant->"Italic"]}]]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.816606313917019*^9, 3.816606348170246*^9}, {
   3.8166065472626705`*^9, 3.8166065528425016`*^9}, {3.816607096263274*^9, 
   3.8166071319089766`*^9}, {3.8166082792077055`*^9, 3.816608293099399*^9}, {
   3.816608332410132*^9, 3.8166083462110634`*^9}, {3.8166084113469725`*^9, 
   3.8166084137878127`*^9}, {3.8166085853535995`*^9, 
   3.8166086653266125`*^9}, {3.816608708567449*^9, 3.8166087156576424`*^9}, {
   3.8166092184739776`*^9, 3.8166092268161383`*^9}, {3.8166150630343227`*^9, 
   3.816615085830597*^9}, {3.816616110276949*^9, 3.816616155206115*^9}, {
   3.8166163400205307`*^9, 3.816616367547614*^9}, {3.816616645609131*^9, 
   3.8166166525614524`*^9}, 
   3.921246993660638*^9},ExpressionUUID->"fc5dc7cf-62d8-4388-ad50-\
ce20f4ef683c"],

Cell[TextData[{
 "Note that in equation (17), we are summing over all the states ",
 StyleBox["i",
  FontSlant->"Italic"],
 " with the same energy ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["E", "i"], TraditionalForm]],ExpressionUUID->
  "4ba130a8-1601-4111-a0b7-0f6cd4e41803"],
 ". Because every term in the sum has the same form, we can replace the sum \
by a multiplication by the number of microstates,"
}], "Text",
 CellChangeTimes->{{3.8166162678733253`*^9, 3.8166163125056567`*^9}, 
   3.816616947345847*^9, {3.9212469524033937`*^9, 
   3.921246975468826*^9}},ExpressionUUID->"4fbbf686-8e21-4153-ae22-\
157595d95609"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   SubscriptBox[
    StyleBox["p",
     FontSlant->"Italic"], "macro"], 
   RowBox[{
    StyleBox["(",
     FontSlant->"Italic"], 
    SubscriptBox[
     StyleBox["E",
      FontSlant->"Italic"], 
     StyleBox["i",
      FontSlant->"Italic"]], ")"}]}], "=", 
  RowBox[{
   FractionBox["1", 
    StyleBox["Z",
     FontSlant->"Italic"]], "\[CapitalOmega]", 
   RowBox[{"(", 
    SubscriptBox[
     StyleBox["E",
      FontSlant->"Italic"], 
     StyleBox["i",
      FontSlant->"Italic"]], ")"}], 
   SuperscriptBox["\[ExponentialE]", 
    RowBox[{
     RowBox[{
      RowBox[{"-", 
       SubscriptBox[
        StyleBox["E",
         FontSlant->"Italic"], 
        StyleBox["i",
         FontSlant->"Italic"]]}], "/", 
      StyleBox[
       SubscriptBox[
        StyleBox["k",
         FontSlant->"Italic"], 
        StyleBox["B",
         FontSlant->"Italic"]],
       FontSlant->"Italic"]}], 
     StyleBox["T",
      FontSlant->"Italic"]}]]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.816606313917019*^9, 3.816606348170246*^9}, {
   3.8166065472626705`*^9, 3.8166065528425016`*^9}, {3.816607096263274*^9, 
   3.8166071319089766`*^9}, {3.8166082792077055`*^9, 3.816608293099399*^9}, {
   3.816608332410132*^9, 3.8166083462110634`*^9}, {3.8166084113469725`*^9, 
   3.8166084137878127`*^9}, {3.8166085853535995`*^9, 
   3.8166086653266125`*^9}, {3.816608708567449*^9, 3.8166087156576424`*^9}, {
   3.8166092184739776`*^9, 3.8166092268161383`*^9}, {3.8166150630343227`*^9, 
   3.816615085830597*^9}, {3.816616110276949*^9, 3.816616155206115*^9}, {
   3.8166166489593244`*^9, 3.8166166626353316`*^9}, 
   3.921246995160177*^9},ExpressionUUID->"3eeeba3d-2b98-423e-8b84-\
b964d929cba7"],

Cell[TextData[{
 "If we then define the entropy ",
 StyleBox["S",
  FontSlant->"Italic"],
 " as"
}], "Text",
 CellChangeTimes->{{3.816616756452175*^9, 
  3.816616772025946*^9}},ExpressionUUID->"0095169c-0d5b-44cb-a155-\
97aca9f3a3b0"],

Cell[BoxData[
 RowBox[{
  StyleBox["S",
   FontSlant->"Italic"], "=", 
  RowBox[{
   StyleBox[
    SubscriptBox[
     StyleBox["k",
      FontSlant->"Italic"], 
     StyleBox["B",
      FontSlant->"Italic"]],
    FontSlant->"Italic"], 
   StyleBox[" ",
    FontSlant->"Italic"], "ln", 
   RowBox[{"(", 
    RowBox[{"\[CapitalOmega]", 
     RowBox[{"(", 
      SubscriptBox[
       StyleBox["E",
        FontSlant->"Italic"], 
       StyleBox["i",
        FontSlant->"Italic"]], ")"}]}], ")"}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.816606313917019*^9, 3.816606348170246*^9}, {
  3.8166065472626705`*^9, 3.8166065528425016`*^9}, {3.816607096263274*^9, 
  3.8166071319089766`*^9}, {3.8166082792077055`*^9, 3.816608293099399*^9}, {
  3.816608332410132*^9, 3.8166083462110634`*^9}, {3.8166084113469725`*^9, 
  3.8166084137878127`*^9}, {3.8166085853535995`*^9, 3.8166086653266125`*^9}, {
  3.816608708567449*^9, 3.8166087156576424`*^9}, {3.8166092184739776`*^9, 
  3.8166092268161383`*^9}, {3.8166150630343227`*^9, 3.816615085830597*^9}, {
  3.816616110276949*^9, 3.816616155206115*^9}, {3.8166166489593244`*^9, 
  3.8166166626353316`*^9}, {3.8166167824482536`*^9, 3.816616806292636*^9}, {
  3.92124701195755*^9, 
  3.9212470155373087`*^9}},ExpressionUUID->"e6976c20-2b14-4e43-8244-\
cdc43fc28572"],

Cell["then we can write the macrostate probability as", "Text",
 CellChangeTimes->{{3.816616817617316*^9, 
  3.8166168229591155`*^9}},ExpressionUUID->"06efad46-2e3c-4021-a870-\
7647648232e0"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   SubscriptBox[
    StyleBox["p",
     FontSlant->"Italic"], "macro"], 
   RowBox[{
    StyleBox["(",
     FontSlant->"Italic"], 
    SubscriptBox[
     StyleBox["E",
      FontSlant->"Italic"], 
     StyleBox["i",
      FontSlant->"Italic"]], ")"}]}], "=", 
  RowBox[{
   FractionBox["1", 
    StyleBox["Z",
     FontSlant->"Italic"]], 
   SuperscriptBox["\[ExponentialE]", 
    RowBox[{
     RowBox[{
      RowBox[{"-", 
       RowBox[{"(", 
        RowBox[{
         SubscriptBox[
          StyleBox["E",
           FontSlant->"Italic"], 
          StyleBox["i",
           FontSlant->"Italic"]], "-", 
         StyleBox["TS",
          FontSlant->"Italic"]}], ")"}]}], "/", 
      StyleBox[
       SubscriptBox[
        StyleBox["k",
         FontSlant->"Italic"], 
        StyleBox["B",
         FontSlant->"Italic"]],
       FontSlant->"Italic"]}], 
     StyleBox["T",
      FontSlant->"Italic"]}]]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.816606313917019*^9, 3.816606348170246*^9}, {
   3.8166065472626705`*^9, 3.8166065528425016`*^9}, {3.816607096263274*^9, 
   3.8166071319089766`*^9}, {3.8166082792077055`*^9, 3.816608293099399*^9}, {
   3.816608332410132*^9, 3.8166083462110634`*^9}, {3.8166084113469725`*^9, 
   3.8166084137878127`*^9}, {3.8166085853535995`*^9, 
   3.8166086653266125`*^9}, {3.816608708567449*^9, 3.8166087156576424`*^9}, {
   3.8166092184739776`*^9, 3.8166092268161383`*^9}, {3.8166150630343227`*^9, 
   3.816615085830597*^9}, {3.816616110276949*^9, 3.816616155206115*^9}, {
   3.8166166489593244`*^9, 3.8166166626353316`*^9}, {3.8166168333031716`*^9, 
   3.816616842854848*^9}, 
   3.9212470067519464`*^9},ExpressionUUID->"93376384-ff70-4042-afbe-\
4832c9aa9ad0"],

Cell["\<\
Note that the entropy is a definition of the number of microstates that give \
a certain macrostate.\
\>", "Text",
 CellChangeTimes->{{3.8166169002715654`*^9, 3.816616926168542*^9}, {
  3.921247041682638*^9, 
  3.921247049814977*^9}},ExpressionUUID->"1550c611-8e96-404e-a35e-\
d8d68b507979"]
}, Open  ]],

Cell[CellGroupData[{

Cell["General Form of Probabilities", "Subsection",
 CellChangeTimes->{{3.8166171001709757`*^9, 
  3.81661710688667*^9}},ExpressionUUID->"733eb2ed-a50d-44df-808d-\
8d6f412b0c13"],

Cell["\<\
We now see that  probabilities of different macro- and microstates can be \
summarized succinctly in the form\
\>", "Text",
 CellChangeTimes->{{3.8166171108893147`*^9, 3.81661712504459*^9}, {
  3.816617202125498*^9, 
  3.8166172559448166`*^9}},ExpressionUUID->"06cdae17-20ab-42b4-ad57-\
7c16a5435cc4"],

Cell[BoxData[
 RowBox[{
  StyleBox["p",
   FontSlant->"Italic"], 
  StyleBox["=",
   FontSlant->"Italic"], 
  FractionBox[
   SuperscriptBox["\[ExponentialE]", 
    RowBox[{
     RowBox[{
      RowBox[{"-", "\[CapitalPhi]"}], "/", 
      StyleBox[
       SubscriptBox[
        StyleBox["k",
         FontSlant->"Italic"], 
        StyleBox["B",
         FontSlant->"Italic"]],
       FontSlant->"Italic"]}], 
     StyleBox["T",
      FontSlant->"Italic"]}]], 
   StyleBox["Z",
    FontSlant->"Italic"]]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.816606313917019*^9, 3.816606348170246*^9}, {
  3.8166065472626705`*^9, 3.8166065528425016`*^9}, {3.816607096263274*^9, 
  3.8166071319089766`*^9}, {3.8166082792077055`*^9, 3.816608293099399*^9}, {
  3.816608332410132*^9, 3.8166083462110634`*^9}, {3.8166084113469725`*^9, 
  3.8166084137878127`*^9}, {3.8166085853535995`*^9, 3.8166086653266125`*^9}, {
  3.816608708567449*^9, 3.8166087156576424`*^9}, {3.8166092184739776`*^9, 
  3.8166092268161383`*^9}, {3.8166150630343227`*^9, 3.816615085830597*^9}, {
  3.8166172290084677`*^9, 3.8166172362795367`*^9}, {3.9213283815213747`*^9, 
  3.921328383026229*^9}},ExpressionUUID->"23675a5b-9a8b-4936-ab9b-\
b88aef733df1"],

Cell["where ", "Text",
 CellChangeTimes->{{3.816617241284031*^9, 
  3.81661725866881*^9}},ExpressionUUID->"aa09bcd2-48ae-42b6-9d1b-\
166917edbdf9"],

Cell[BoxData[
 RowBox[{
  StyleBox["Z",
   FontSlant->"Italic"], 
  StyleBox["=",
   FontSlant->"Italic"], 
  RowBox[{"\[Sum]", 
   SuperscriptBox["\[ExponentialE]", 
    RowBox[{
     RowBox[{
      RowBox[{"-", "\[CapitalPhi]"}], "/", 
      StyleBox[
       SubscriptBox[
        StyleBox["k",
         FontSlant->"Italic"], 
        StyleBox["B",
         FontSlant->"Italic"]],
       FontSlant->"Italic"]}], 
     StyleBox["T",
      FontSlant->"Italic"]}]]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.816606313917019*^9, 3.816606348170246*^9}, {
   3.8166065472626705`*^9, 3.8166065528425016`*^9}, {3.816607096263274*^9, 
   3.8166071319089766`*^9}, {3.8166082792077055`*^9, 3.816608293099399*^9}, {
   3.816608332410132*^9, 3.8166083462110634`*^9}, {3.8166084113469725`*^9, 
   3.8166084137878127`*^9}, {3.8166085853535995`*^9, 
   3.8166086653266125`*^9}, {3.816608708567449*^9, 3.8166087156576424`*^9}, {
   3.8166092184739776`*^9, 3.8166092268161383`*^9}, {3.8166150630343227`*^9, 
   3.816615085830597*^9}, {3.8166172290084677`*^9, 3.8166172362795367`*^9}, {
   3.81661726771554*^9, 3.8166172792306194`*^9}, 
   3.9213283856651073`*^9},ExpressionUUID->"189f12ae-8433-403a-8fad-\
3e408115cc95"],

Cell["\<\
We then define different thermodynamic potentials \[CapitalPhi] in which the \
macro and microstates depend on different variables,\
\>", "Text",
 CellChangeTimes->{{3.8166172936477833`*^9, 
  3.8166173233033133`*^9}},ExpressionUUID->"a97cc7c3-8741-463e-97f7-\
01fdabada46f"],

Cell[BoxData[
 RowBox[{"\t\t        ", 
  RowBox[{
   RowBox[{
    RowBox[{"Enthalpy", ":", " ", 
     StyleBox["H",
      FontSlant->"Italic"]}], "=", 
    RowBox[{
     StyleBox["E",
      FontSlant->"Italic"], 
     StyleBox["+",
      FontSlant->"Plain"], 
     StyleBox["PV",
      FontSlant->"Italic"]}]}], 
   StyleBox["\[IndentingNewLine]",
    FontSlant->"Italic"], 
   RowBox[{
    RowBox[{"Helmholtz", " ", "Free", " ", 
     RowBox[{"Energy", ":", " ", 
      StyleBox["A",
       FontSlant->"Italic"]}]}], "=", 
    RowBox[{
     StyleBox["E",
      FontSlant->"Italic"], 
     StyleBox["-",
      FontSlant->"Plain"], 
     StyleBox["TS",
      FontSlant->"Italic"]}]}], 
   StyleBox["\[IndentingNewLine]",
    FontSlant->"Italic"], 
   StyleBox["         ",
    FontSlant->"Italic"], 
   RowBox[{
    RowBox[{"Gibbs", " ", "Free", " ", 
     RowBox[{"Energy", ":", " ", 
      StyleBox["G",
       FontSlant->"Italic"]}]}], "=", 
    RowBox[{
     StyleBox["E",
      FontSlant->"Italic"], 
     StyleBox["+",
      FontSlant->"Plain"], 
     StyleBox["PV",
      FontSlant->"Italic"], 
     StyleBox["-",
      FontSlant->"Italic"], 
     StyleBox["TS",
      FontSlant->"Italic"]}]}], 
   StyleBox["\[IndentingNewLine]",
    FontSlant->"Italic"], "\t   ", 
   RowBox[{
    RowBox[{"Grand", " ", 
     RowBox[{"Potential", ":", " ", 
      SubscriptBox["\[CapitalPhi]", 
       StyleBox["G",
        FontSlant->"Italic"]]}]}], "=", 
    RowBox[{
     StyleBox["E",
      FontSlant->"Italic"], 
     StyleBox["-",
      FontSlant->"Italic"], 
     StyleBox[
      RowBox[{"\[Mu]", 
       StyleBox["N",
        FontSlant->"Italic"]}]], "\[Minus]", 
     StyleBox["TS",
      FontSlant->"Italic"]}]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.816606313917019*^9, 3.816606348170246*^9}, {
  3.8166065472626705`*^9, 3.8166065528425016`*^9}, {3.816607096263274*^9, 
  3.8166071319089766`*^9}, {3.8166082792077055`*^9, 3.816608293099399*^9}, {
  3.816608332410132*^9, 3.8166083462110634`*^9}, {3.8166084113469725`*^9, 
  3.8166084137878127`*^9}, {3.8166085853535995`*^9, 3.8166086653266125`*^9}, {
  3.816608708567449*^9, 3.8166087156576424`*^9}, {3.8166092184739776`*^9, 
  3.8166092268161383`*^9}, {3.8166150630343227`*^9, 3.816615085830597*^9}, {
  3.8166172290084677`*^9, 3.8166172362795367`*^9}, {3.81661726771554*^9, 
  3.8166172792306194`*^9}, {3.816617337338519*^9, 3.816617475699975*^9}, {
  3.8166919377167797`*^9, 
  3.8166919382041245`*^9}},ExpressionUUID->"d2598016-49d7-4b54-b149-\
6c98cd3dae59"],

Cell["\<\
so you can see how the more familiar thermodynamic quantities are related to \
the statistical foundation we\[CloseCurlyQuote]ve developed here.\
\>", "Text",
 CellChangeTimes->{{3.816617480424941*^9, 
  3.8166175024013815`*^9}},ExpressionUUID->"ce4f4094-c906-4c9c-87ce-\
e912dfbfe9ff"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Average of a Variable", "Subsection",
 CellChangeTimes->{{3.816691975448209*^9, 
  3.8166919784690084`*^9}},ExpressionUUID->"8cff5c1a-876a-4279-892e-\
70c5d15452f0"],

Cell[TextData[{
 "Consider some variable ",
 StyleBox["x",
  FontSlant->"Italic"],
 ". Its average value ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[LeftAngleBracket]", "x", "\[RightAngleBracket]"}], 
   TraditionalForm]],ExpressionUUID->"1bc51479-24de-4de1-9543-7512e40d25d3"],
 " is given by the sum over each possible value of ",
 StyleBox["x",
  FontSlant->"Italic"],
 " multiplied by the probability of that value,"
}], "Text",
 CellChangeTimes->{{3.921250229004294*^9, 
  3.921250302916671*^9}},ExpressionUUID->"45df755e-ee8b-4523-8772-\
1e4b9869fd9e"],

Cell[BoxData[
 RowBox[{
  RowBox[{"\[LeftAngleBracket]", 
   StyleBox["x",
    FontSlant->"Italic"], "\[RightAngleBracket]"}], "=", 
  RowBox[{"\[Sum]", 
   StyleBox[
    RowBox[{
     SubscriptBox[
      StyleBox["x",
       FontSlant->"Italic"], "i"], 
     SubscriptBox[
      StyleBox["p",
       FontSlant->"Italic"], "i"]}],
    FontSlant->"Italic"]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8166919972466764`*^9, 
  3.8166920356564937`*^9}},ExpressionUUID->"0bd854a8-8292-4f9d-84f8-\
6389e40411f4"],

Cell[TextData[{
 "For systems described by a thermodynamic potential \[CapitalPhi], we know \
that the probability of a state is given by equation (21), so the average \
value of ",
 StyleBox["x",
  FontSlant->"Italic"],
 " is given by"
}], "Text",
 CellChangeTimes->{{3.8795253021844673`*^9, 3.8795253201912203`*^9}, {
  3.9212503081365557`*^9, 3.9212503268683596`*^9}, {3.9212503599076595`*^9, 
  3.9212503978116026`*^9}, {3.941022203938757*^9, 
  3.94102220416004*^9}},ExpressionUUID->"3aad0fa2-6158-4ba5-b737-\
eb813656ac52"],

Cell[BoxData[
 RowBox[{
  RowBox[{"\[LeftAngleBracket]", 
   StyleBox["x",
    FontSlant->"Italic"], "\[RightAngleBracket]"}], "=", 
  RowBox[{"\[Sum]", 
   StyleBox[
    FractionBox[
     RowBox[{
      SubscriptBox[
       StyleBox["x",
        FontSlant->"Italic"], "i"], 
      SuperscriptBox[
       StyleBox["\[ExponentialE]",
        FontSlant->"Plain"], 
       RowBox[{
        RowBox[{
         RowBox[{"-", 
          StyleBox["\[CapitalPhi]",
           FontSlant->"Plain"]}], "/", 
         StyleBox[
          SubscriptBox[
           StyleBox["k",
            FontSlant->"Italic"], 
           StyleBox["B",
            FontSlant->"Italic"]],
          FontSlant->"Italic"]}], 
        StyleBox["T",
         FontSlant->"Italic"]}]]}], 
     StyleBox["Z",
      FontSlant->"Italic"]],
    FontSlant->"Italic"]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8166919972466764`*^9, 3.8166920356564937`*^9}, {
   3.81669208517715*^9, 3.816692097666179*^9}, 
   3.941022207347782*^9},ExpressionUUID->"da705f41-24e5-45ec-aca2-\
74099036e137"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Average of Potentials", "Subsection",
 CellChangeTimes->{{3.8166921229227505`*^9, 
  3.816692127281649*^9}},ExpressionUUID->"e6231b3c-3ede-4ce0-b241-\
e462866915c2"],

Cell["\<\
For the average value of a potential, we can use the same concept.\
\>", "Text",
 CellChangeTimes->{{3.9212504022724524`*^9, 
  3.9212504131205344`*^9}},ExpressionUUID->"66ec421a-9c17-4517-8561-\
c3ab8d889584"],

Cell[BoxData[
 RowBox[{
  RowBox[{"\[LeftAngleBracket]", "\[Phi]", "\[RightAngleBracket]"}], "=", 
  RowBox[{
   RowBox[{"\[Sum]", 
    StyleBox[
     FractionBox[
      SuperscriptBox[
       StyleBox["\[Phi]\[ExponentialE]",
        FontSlant->"Plain"], 
       RowBox[{
        RowBox[{"-", 
         StyleBox["\[CapitalPhi]",
          FontSlant->"Plain"]}], "/", 
        StyleBox["kT",
         FontSlant->"Italic"]}]], 
      StyleBox["Z",
       FontSlant->"Italic"]],
     FontSlant->"Italic"]}], 
   StyleBox["=",
    FontSlant->"Plain"], 
   RowBox[{"\[Sum]", 
    StyleBox[
     FractionBox[
      SuperscriptBox[
       StyleBox["\[Phi]\[ExponentialE]",
        FontSlant->"Plain"], 
       RowBox[{"-", 
        StyleBox["\[Beta]\[CapitalPhi]",
         FontSlant->"Plain"]}]], 
      StyleBox["Z",
       FontSlant->"Italic"]],
     FontSlant->"Italic"]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8166921420647564`*^9, 3.8166922409967766`*^9}, 
   3.921250482764883*^9, 
   3.9212505275400047`*^9},ExpressionUUID->"d35ddd1d-e818-4235-b66e-\
6506f17cd732"],

Cell["\<\
where the sum is over the possible values of \[Phi]. We can take advantage of \
the observation that\
\>", "Text",
 CellChangeTimes->{{3.921250484703654*^9, 3.921250504387495*^9}, {
  3.9212505389690733`*^9, 
  3.9212505496201844`*^9}},ExpressionUUID->"73f6fffd-ca8c-49d3-890e-\
9f2d0b5bd001"],

Cell[BoxData[
 RowBox[{
  RowBox[{"\[LeftAngleBracket]", "\[Phi]", "\[RightAngleBracket]"}], 
  StyleBox["=",
   FontSlant->"Plain"], 
  RowBox[{
   RowBox[{"\[Sum]", 
    StyleBox[
     FractionBox[
      SuperscriptBox[
       StyleBox["\[Phi]\[ExponentialE]",
        FontSlant->"Plain"], 
       RowBox[{"-", 
        StyleBox["\[Beta]\[CapitalPhi]",
         FontSlant->"Plain"]}]], 
      StyleBox["Z",
       FontSlant->"Italic"]],
     FontSlant->"Italic"]}], 
   StyleBox["=",
    FontSlant->"Italic"], 
   RowBox[{
    StyleBox["-",
     FontSlant->"Italic"], 
    FractionBox[
     RowBox[{
      RowBox[{"\[PartialD]", "ln"}], 
      RowBox[{"(", 
       StyleBox["Z",
        FontSlant->"Italic"], ")"}]}], 
     RowBox[{"\[PartialD]", "\[Beta]"}]]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.9212505192469416`*^9, 
  3.921250534863843*^9}},ExpressionUUID->"c1f02e4e-af8d-423f-8d8e-\
929e47d24363"],

Cell["\<\
which means that we can readily calculate the average value of a potential \
from the partition function.\
\>", "Text",
 CellChangeTimes->{{3.8166922503636694`*^9, 3.816692260505607*^9}, {
  3.9212505722673264`*^9, 3.9212505838002987`*^9}, {3.9214206636818447`*^9, 
  3.921420670171015*^9}},ExpressionUUID->"f0f9e8d1-c020-46cc-bbac-\
fe7d4742eab9"]
}, Open  ]],

Cell[CellGroupData[{

Cell["The Average Ensemble Energy", "Subsection",
 CellChangeTimes->{{3.8166921229227505`*^9, 3.816692127281649*^9}, {
  3.921250642815049*^9, 
  3.9212506489881787`*^9}},ExpressionUUID->"40c7c8b8-ace7-4c20-b572-\
f5dad4f2a336"],

Cell[TextData[{
 "We can now apply the potential average approach to obtain the average \
ensemble energy. If we consider a system in which the energy ",
 StyleBox["E",
  FontSlant->"Italic"],
 " depends on the number of particles ",
 StyleBox["N",
  FontSlant->"Italic"],
 " and the volume ",
 StyleBox["V",
  FontSlant->"Italic"],
 ", then we obtain"
}], "Text",
 CellChangeTimes->{{3.9212506529502897`*^9, 
  3.9212507281636353`*^9}},ExpressionUUID->"4ecb12f2-02b1-4d38-b0a4-\
9ab55333ef68"],

Cell[BoxData[
 RowBox[{
  RowBox[{"\[LeftAngleBracket]", 
   StyleBox["E",
    FontSlant->"Italic"], "\[RightAngleBracket]"}], 
  StyleBox["=",
   FontSlant->"Plain"], 
  RowBox[{
   RowBox[{
    StyleBox["-",
     FontSlant->"Italic"], 
    SubscriptBox[
     RowBox[{
      StyleBox["(",
       FontSlant->"Italic"], 
      FractionBox[
       RowBox[{
        RowBox[{"\[PartialD]", "ln"}], 
        RowBox[{"(", 
         StyleBox["Z",
          FontSlant->"Italic"], ")"}]}], 
       RowBox[{"\[PartialD]", "\[Beta]"}]], ")"}], 
     RowBox[{
      StyleBox["N",
       FontSlant->"Italic"], ",", 
      StyleBox["V",
       FontSlant->"Italic"]}]]}], "=", 
   RowBox[{
    SubscriptBox["\[Sum]", 
     StyleBox["j",
      FontSlant->"Italic"]], 
    StyleBox[
     FractionBox[
      RowBox[{
       SubscriptBox["E", "j"], 
       RowBox[{"(", 
        RowBox[{"N", ",", "V"}], ")"}], 
       SuperscriptBox[
        StyleBox["\[ExponentialE]",
         FontSlant->"Plain"], 
        RowBox[{
         RowBox[{"-", 
          SubscriptBox[
           StyleBox[
            RowBox[{
             StyleBox["\[Beta]",
              FontSlant->"Plain"], 
             StyleBox["E",
              FontSlant->"Italic"]}]], "j"]}], 
         RowBox[{"(", 
          RowBox[{"N", ",", "V"}], ")"}]}]]}], 
      StyleBox["Z",
       FontSlant->"Italic"]],
     FontSlant->"Italic"]}]}]}]], "DisplayFormulaNumbered",
 InitializationCell->True,
 CellChangeTimes->{{3.9212505192469416`*^9, 3.921250534863843*^9}, {
  3.9212507356598735`*^9, 3.9212507676410656`*^9}, {3.9212508673633738`*^9, 
  3.9212509608799176`*^9}, {3.921251060924367*^9, 3.9212511124818687`*^9}, {
  3.9212511504673223`*^9, 3.921251158794492*^9}, {3.9212512029019794`*^9, 
  3.9212512716665497`*^9}, {3.921251348153563*^9, 
  3.921251397670518*^9}},ExpressionUUID->"ea81da27-c97c-4f7e-bcc1-\
8b83a8b62a30"],

Cell[TextData[{
 "Note that here the sum is over all microstates, not just those with a given \
energy ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["E", "i"], TraditionalForm]],ExpressionUUID->
  "4b5644ed-148b-4669-9b27-97071b4807cd"],
 "."
}], "Text",
 CellChangeTimes->{{3.9212512160484924`*^9, 3.921251219745363*^9}, {
  3.9212512736489897`*^9, 
  3.921251285841352*^9}},ExpressionUUID->"cfa3fcf3-7d32-4156-973a-\
4a78935bc423"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Application of Statistical Mechanics to an Ideal Gas Model", "Section",
 CellChangeTimes->{{3.8166061915992727`*^9, 3.8166062001448755`*^9}, {
   3.8166171310996428`*^9, 3.8166171448975058`*^9}, 3.921245618147767*^9, {
   3.921245679840007*^9, 3.921245680636515*^9}, {3.9212471210870857`*^9, 
   3.9212471222681017`*^9}, {3.9212519377776556`*^9, 3.921251948195799*^9}, {
   3.921252206058749*^9, 
   3.921252225285902*^9}},ExpressionUUID->"f9f60bf1-502a-447a-9557-\
81b4444c64e6"],

Cell[CellGroupData[{

Cell["Translational Partition Function of an Ideal Gas Particle", "Subsection",
 CellChangeTimes->{{3.9212522366426954`*^9, 3.9212522481626863`*^9}, {
  3.921328459949397*^9, 
  3.921328462397443*^9}},ExpressionUUID->"16220d36-d51d-4e85-9a15-\
3ff40a2b20bf"],

Cell["\<\
Consider an ideal gas in which the individual molecules experience no \
interaction with one another other than elastic collisions. We stated \
previously in the course that we can write the energy of an individual \
molecule as the sum of its rotational, vibrational, electronic, and \
translational energy,\
\>", "Text",
 CellChangeTimes->{{3.9212522511259117`*^9, 3.921252341778092*^9}, {
  3.921252487303395*^9, 3.921252489263988*^9}, {3.921327245059301*^9, 
  3.9213272459092245`*^9}},ExpressionUUID->"26ad8e2f-e0a2-4790-a363-\
097c0df6526f"],

Cell[BoxData[
 RowBox[{
  SubscriptBox["\[CurlyEpsilon]", 
   StyleBox["tot",
    FontSlant->"Italic"]], "=", 
  RowBox[{
   SubscriptBox["\[CurlyEpsilon]", 
    StyleBox["e",
     FontSlant->"Italic"]], "+", 
   SubscriptBox["\[CurlyEpsilon]", 
    StyleBox["vib",
     FontSlant->"Italic"]], "+", 
   SubscriptBox["\[CurlyEpsilon]", 
    StyleBox["rot",
     FontSlant->"Italic"]], "+", 
   SubscriptBox["\[CurlyEpsilon]", 
    StyleBox["trans",
     FontSlant->"Italic"]]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.81307809350165*^9, 3.8130781609264364`*^9}, 
   3.8130782039890594`*^9, {3.813078272672757*^9, 3.8130783323990836`*^9}, {
   3.8130788081537347`*^9, 3.8130788107416773`*^9}, {3.813082960788761*^9, 
   3.8130829717709465`*^9}, {3.8130830114286995`*^9, 
   3.8130830511844254`*^9}, {3.813083923369066*^9, 3.813083930891937*^9}, {
   3.8132222114766717`*^9, 3.8132222127335887`*^9}, {3.8132271828852577`*^9, 
   3.8132271927822623`*^9}, {3.8153289813630953`*^9, 
   3.8153289864065866`*^9}, {3.8153291213105726`*^9, 3.815329121718901*^9}, {
   3.815329313356747*^9, 3.815329332339172*^9}, {3.9212525059353724`*^9, 
   3.9212525089979534`*^9}, {3.9212525521652126`*^9, 
   3.921252578236678*^9}},ExpressionUUID->"455b3b6a-ff14-4c6b-b795-\
451f02d75fff"],

Cell[TextData[{
 "where we are using the symbol \[CurlyEpsilon] to differentiate between the \
energy of an individual atom or molecule and the energy of the system ",
 StyleBox["E",
  FontSlant->"Italic"],
 ". ",
 " The corresponding partition function of an individual molecule is given by"
}], "Text",
 CellChangeTimes->{{3.921252365794587*^9, 3.921252415063674*^9}, {
  3.9212524945227427`*^9, 3.921252499084896*^9}, {3.9212525831947193`*^9, 
  3.9212526433670917`*^9}, {3.9212527071657324`*^9, 
  3.921252711905715*^9}},ExpressionUUID->"efa55b2c-7f58-487c-a9b5-\
0b1b168074b5"],

Cell[BoxData[
 RowBox[{
  SubscriptBox[
   StyleBox["Z",
    FontSlant->"Italic"], "\[CurlyEpsilon]"], 
  StyleBox["=",
   FontSlant->"Italic"], 
  RowBox[{
   SubscriptBox[
    StyleBox["Z",
     FontSlant->"Italic"], 
    SubscriptBox["\[CurlyEpsilon]", 
     StyleBox["e",
      FontSlant->"Italic"]]], 
   SubscriptBox[
    StyleBox["Z",
     FontSlant->"Italic"], 
    SubscriptBox["\[CurlyEpsilon]", 
     StyleBox["vib",
      FontSlant->"Italic"]]], 
   SubscriptBox[
    StyleBox["Z",
     FontSlant->"Italic"], 
    SubscriptBox["\[CurlyEpsilon]", 
     StyleBox["rot",
      FontSlant->"Italic"]]], 
   SubscriptBox[
    StyleBox["Z",
     FontSlant->"Italic"], 
    SubscriptBox["\[CurlyEpsilon]", 
     StyleBox["trans",
      FontSlant->"Italic"]]]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.816606313917019*^9, 3.816606348170246*^9}, {
  3.8166065472626705`*^9, 3.8166065528425016`*^9}, {3.816607096263274*^9, 
  3.8166071319089766`*^9}, {3.8166082792077055`*^9, 3.816608293099399*^9}, {
  3.816608332410132*^9, 3.8166083462110634`*^9}, {3.8166084113469725`*^9, 
  3.8166084137878127`*^9}, {3.8166085853535995`*^9, 3.8166086653266125`*^9}, {
  3.816608708567449*^9, 3.8166087156576424`*^9}, {3.8166092184739776`*^9, 
  3.8166092268161383`*^9}, {3.8166150630343227`*^9, 3.816615085830597*^9}, {
  3.8166172290084677`*^9, 3.8166172362795367`*^9}, {3.81661726771554*^9, 
  3.8166172792306194`*^9}, {3.921252657969633*^9, 
  3.921252700157872*^9}},ExpressionUUID->"bf217ecf-f5ba-487f-9c61-\
4beddff0a30e"],

Cell[TextData[{
 "Up to this point, we have focused on the electronic, vibrational, and \
rotational energies. Now we will turn to the translational energy and \
partition function. Consider a particle constrained to move in a \
three-dimensional box with sides of equal length ",
 StyleBox["a",
  FontSlant->"Italic"],
 ". Recall that the energies of a particle in a one-dimensional \
\[OpenCurlyDoubleQuote]box\[CloseCurlyDoubleQuote] were given by"
}], "Text",
 CellChangeTimes->{{3.9212527169239917`*^9, 3.921252800563387*^9}, {
  3.921252881972081*^9, 
  3.921252897020467*^9}},ExpressionUUID->"f6e8a69a-61fd-4f41-b966-\
6021564e169f"],

Cell[BoxData[
 RowBox[{
  SubscriptBox[
   StyleBox["\[CurlyEpsilon]",
    FontSlant->"Italic"], 
   SubscriptBox[
    StyleBox["n",
     FontSlant->"Italic"], "x"]], "=", 
  FractionBox[
   RowBox[{
    SubsuperscriptBox[
     StyleBox["n",
      FontSlant->"Italic"], 
     StyleBox["x",
      FontSlant->"Italic"], "2"], 
    SuperscriptBox[
     StyleBox["h",
      FontSlant->"Italic"], "2"]}], 
   RowBox[{"8", 
    SuperscriptBox[
     StyleBox["ma",
      FontSlant->"Italic"], "2"]}]]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.808746256152788*^9, 3.8087463361701956`*^9}, {
  3.808746369787464*^9, 3.808746370563246*^9}, {3.8087464007367125`*^9, 
  3.808746411975296*^9}, {3.921252901820755*^9, 
  3.921252933764389*^9}},ExpressionUUID->"3529d7c2-360e-429d-ba04-\
e917bbbfdfc3"],

Cell[TextData[{
 "We won\[CloseCurlyQuote]t go through the details here, but it can be shown \
that the energy of a particle in a three-dimensional box involves expanding \
this expression to three dimensions ",
 StyleBox["x",
  FontSlant->"Italic"],
 ", ",
 StyleBox["y",
  FontSlant->"Italic"],
 ", and ",
 StyleBox["z",
  FontSlant->"Italic"],
 ", so we obtain"
}], "Text",
 CellChangeTimes->{{3.921252921518835*^9, 3.9212530040046835`*^9}, {
  3.9212531097679176`*^9, 3.921253112035982*^9}, {3.921338661391363*^9, 
  3.921338681115571*^9}},ExpressionUUID->"d2c32111-e001-4815-9b24-\
4ab66907ae4d"],

Cell[BoxData[
 RowBox[{
  SubscriptBox[
   StyleBox["\[CurlyEpsilon]",
    FontSlant->"Italic"], 
   StyleBox["trans",
    FontSlant->"Italic"]], "=", 
  RowBox[{
   FractionBox[
    SuperscriptBox[
     StyleBox["h",
      FontSlant->"Italic"], "2"], 
    RowBox[{"8", 
     SuperscriptBox[
      StyleBox["ma",
       FontSlant->"Italic"], "2"]}]], 
   RowBox[{"(", 
    RowBox[{
     SubsuperscriptBox[
      StyleBox["n",
       FontSlant->"Italic"], 
      StyleBox["x",
       FontSlant->"Italic"], "2"], "+", 
     SubsuperscriptBox[
      StyleBox["n",
       FontSlant->"Italic"], 
      StyleBox["y",
       FontSlant->"Italic"], "2"], "+", 
     SubsuperscriptBox[
      StyleBox["n",
       FontSlant->"Italic"], 
      StyleBox["z",
       FontSlant->"Italic"], "2"]}], ")"}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.808746256152788*^9, 3.8087463361701956`*^9}, {
  3.808746369787464*^9, 3.808746370563246*^9}, {3.8087464007367125`*^9, 
  3.808746411975296*^9}, {3.921252901820755*^9, 3.921252933764389*^9}, {
  3.921253009455393*^9, 
  3.9212530327772245`*^9}},ExpressionUUID->"7ea54c45-fc6d-44dc-8b5e-\
6b3e6471d282"],

Cell[TextData[{
 "where ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["n", "x"], ",", 
    SubscriptBox["n", "y"], ",", " ", 
    RowBox[{"and", " ", 
     SubscriptBox["n", "z"]}]}], TraditionalForm]],ExpressionUUID->
  "59dd7b43-7fb2-4276-8dcc-9767ae581e42"],
 " can take on integer values from 1 to infinity. We can then obtain the \
translational partition function of a particle as"
}], "Text",
 CellChangeTimes->{{3.9212530530508733`*^9, 3.9212530787398725`*^9}, {
  3.9212531218963842`*^9, 
  3.921253159442338*^9}},ExpressionUUID->"d6ab1a9a-1a93-4220-850f-\
6efb7b1744d2"],

Cell[BoxData[
 RowBox[{
  SubscriptBox[
   StyleBox["Z",
    FontSlant->"Italic"], 
   SubscriptBox["\[CurlyEpsilon]", 
    StyleBox["trans",
     FontSlant->"Italic"]]], "=", 
  RowBox[{
   RowBox[{"\[Sum]", 
    SuperscriptBox["\[ExponentialE]", 
     RowBox[{"-", 
      SubscriptBox["\[Beta]\[CurlyEpsilon]", 
       StyleBox["trans",
        FontSlant->"Italic"]]}]]}], "=", 
   RowBox[{
    SubscriptBox["\[Sum]", 
     SubscriptBox[
      StyleBox["n",
       FontSlant->"Italic"], "x"]], 
    RowBox[{
     SubscriptBox["\[Sum]", 
      SubscriptBox[
       StyleBox["n",
        FontSlant->"Italic"], "y"]], 
     RowBox[{
      SubscriptBox["\[Sum]", 
       SubscriptBox[
        StyleBox["n",
         FontSlant->"Italic"], "z"]], 
      SuperscriptBox["\[ExponentialE]", 
       RowBox[{
        RowBox[{"-", "\[Beta]"}], 
        FractionBox[
         SuperscriptBox[
          StyleBox["h",
           FontSlant->"Italic"], "2"], 
         RowBox[{"8", 
          SuperscriptBox[
           StyleBox["ma",
            FontSlant->"Italic"], "2"]}]], 
        RowBox[{"(", 
         RowBox[{
          SubsuperscriptBox[
           StyleBox["n",
            FontSlant->"Italic"], 
           StyleBox["x",
            FontSlant->"Italic"], "2"], "+", 
          SubsuperscriptBox[
           StyleBox["n",
            FontSlant->"Italic"], 
           StyleBox["y",
            FontSlant->"Italic"], "2"], "+", 
          SubsuperscriptBox[
           StyleBox["n",
            FontSlant->"Italic"], 
           StyleBox["z",
            FontSlant->"Italic"], "2"]}], 
         ")"}]}]]}]}]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.816606313917019*^9, 3.816606348170246*^9}, {
  3.8166065472626705`*^9, 3.8166065528425016`*^9}, {3.816607096263274*^9, 
  3.8166071319089766`*^9}, {3.8166082792077055`*^9, 3.816608293099399*^9}, {
  3.816608332410132*^9, 3.8166083462110634`*^9}, {3.8166084113469725`*^9, 
