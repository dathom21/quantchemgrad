Cell[TextData[{
 StyleBox["Figure 13.9",
  FontWeight->"Bold"],
 ". Carbamic acid has no axis, plane, or point of symmetry and thus has only \
the identity symmetry element."
}], "Affiliation",
 CellChangeTimes->{{3.809435027311596*^9, 3.8094350763900714`*^9}, {
   3.80943583474421*^9, 3.8094358359299717`*^9}, {3.8094472165104203`*^9, 
