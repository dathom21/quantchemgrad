    3.811870201331394*^9}, {3.811935703417695*^9, 3.8119357133826056`*^9}, {
    3.8119449835579224`*^9, 3.8119450568130407`*^9}},ExpressionUUID->
  "b481361e-e417-3346-a18d-11f33d60dea7"],
 " is a normalization constant."
}], "Text",
