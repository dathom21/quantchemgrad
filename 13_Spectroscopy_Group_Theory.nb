   3.8163425884784684`*^9}, {3.8163434094080753`*^9, 
   3.816343418013234*^9}},ExpressionUUID->"f46cb170-c14e-4f11-a3d9-\
6bf6932ba8ca"],

Cell[TextData[{
 "where ",
 Cell[BoxData[
  SubscriptBox["\[Psi]", 
   RowBox[{"1", "vib"}]]],
  CellChangeTimes->{{3.8079712935412436`*^9, 3.8079714900326514`*^9}, {
    3.8080650361338077`*^9, 3.808065078586836*^9}, {3.8080651294863386`*^9, 
    3.8080651662446632`*^9}, {3.8080655103101*^9, 3.808065549470801*^9}, {
    3.8080655874181037`*^9, 3.8080655997397223`*^9}, {3.80806586302172*^9, 
