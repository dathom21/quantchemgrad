    3.8106610794321012`*^9}, {3.8106611250786457`*^9, 
    3.8106611896874313`*^9}, {3.810661579097098*^9, 3.8106616142945995`*^9}, {
    3.8107159413646593`*^9, 3.810716006004163*^9}},ExpressionUUID->
  "7167fb64-5621-4902-b166-8d7c970473d8"],
 " points somewhere on a circle with a ",
 StyleBox["z",
  FontSlant->"Italic"],
 "-component ",
 Cell[BoxData[
  FormBox[
   SubscriptBox[
    StyleBox["L",
     FontWeight->"Bold"], "z"], TraditionalForm]],ExpressionUUID->
  "584585d3-b4ae-4df3-b3c4-366834136db9"],
 " of magnitude m\[HBar]. The projection of the angular momentum in the ",
 StyleBox["x-y",
  FontSlant->"Italic"],
 " plane yields a circle of radius ",
 Cell[BoxData[
  SuperscriptBox[
   RowBox[{"\[HBar]", "[", 
    RowBox[{
     RowBox[{
      StyleBox["l",
       FontSlant->"Italic"], 
      RowBox[{
