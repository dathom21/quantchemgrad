   RowBox[{"(", 
    StyleBox["t",
     FontSlant->"Italic"], ")"}]}], "=", 
  RowBox[{
   RowBox[{
    FractionBox[
     SubsuperscriptBox[
      StyleBox["V",
       FontSlant->"Italic"], 
      StyleBox["mk",
       FontSlant->"Italic"], "2"], 
     SuperscriptBox["\[HBar]", "2"]], "2", "\[Pi]", " ", "\[Delta]", 
    RowBox[{"(", 
