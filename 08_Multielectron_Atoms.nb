   3.8118606500807743`*^9},ExpressionUUID->"34081365-5812-bc4e-80b5-\
d53bdadd72ed"],

Cell["So we obtain", "Text",
 CellChangeTimes->{{3.811860500748001*^9, 
  3.8118605021024933`*^9}},ExpressionUUID->"e9c036d0-c50c-a847-a27f-\
068beef8cab0"],

Cell[BoxData[
 RowBox[{
  RowBox[{"\[LeftAngleBracket]", 
   RowBox[{"\[CapitalPhi]", "|", 
    OverscriptBox[
     StyleBox["H",
      FontSlant->"Italic"], "^"], "|", "\[CapitalPhi]"}], 
   "\[RightAngleBracket]"}], "=", 
  RowBox[{
   RowBox[{
    UnderscriptBox["\[Sum]", 
     StyleBox["n",
      FontSlant->"Italic"]], 
    RowBox[{
     UnderscriptBox["\[Sum]", 
      StyleBox["m",
       FontSlant->"Italic"]], 
     RowBox[{
      SubsuperscriptBox[
       StyleBox["a",
        FontSlant->"Italic"], 
       StyleBox["n",
        FontSlant->"Italic"], "\[Star]"], 
      SubscriptBox[
       StyleBox["a",
        FontSlant->"Italic"], 
       StyleBox["m",
        FontSlant->"Italic"]], " ", 
      SubscriptBox[
       StyleBox["H",
        FontSlant->"Italic"], 
       StyleBox["nm",
        FontSlant->"Italic"]], "                                              ", 
      RowBox[{"\[Integral]", 
       RowBox[{
        SuperscriptBox["\[CapitalPhi]", "\[Star]"], " ", 
        OverscriptBox[
         StyleBox["H",
          FontSlant->"Italic"], "^"], "\[CapitalPhi]", " ", 
        "d\[Tau]"}]}]}]}]}], "=", 
   RowBox[{
    UnderscriptBox["\[Sum]", 
     StyleBox["n",
      FontSlant->"Italic"]], 
    RowBox[{
     UnderscriptBox["\[Sum]", 
      StyleBox["m",
       FontSlant->"Italic"]], 
     RowBox[{
      SubsuperscriptBox[
       StyleBox["a",
        FontSlant->"Italic"], 
       StyleBox["n",
        FontSlant->"Italic"], "\[Star]"], 
      SubscriptBox[
       StyleBox["a",
        FontSlant->"Italic"], 
       StyleBox["m",
        FontSlant->"Italic"]], " ", 
      SubscriptBox[
       StyleBox["H",
        FontSlant->"Italic"], 
       StyleBox["nm",
        FontSlant->"Italic"]]}]}]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.811593312893673*^9, 3.8115933831661987`*^9}, {
  3.811593458953679*^9, 3.8115934974178753`*^9}, {3.8115936143121653`*^9, 
