Cell[TextData[{
 StyleBox["Figure 8.4",
  FontWeight->"Bold"],
 ". Quantization of the angular momentum of the hydrogen atom. Shown are the \
vector representations of ",
 StyleBox["l",
  FontSlant->"Italic"],
 " = 2 and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["m", "l"], TraditionalForm]],ExpressionUUID->
  "40ff72a0-1c44-49ec-99ca-dee1f0129900"],
 " = \[Minus]2, \[Minus]1, 0, 1, and 2. For a given value of ",
 StyleBox["l",
  FontSlant->"Italic"],
 " and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["m", "l"], TraditionalForm]],ExpressionUUID->
  "8bec8806-731d-49dc-8891-06cf0b13fecd"],
 ", the angular momentum vector ",
 StyleBox["L",
  FontWeight->"Bold",
  FontSlant->"Italic"],
 " of magnitude  ",
 Cell[BoxData[
  SuperscriptBox[
   RowBox[{"\[HBar]", "[", 
    RowBox[{
     StyleBox["l",
      FontSlant->"Italic"], 
     RowBox[{
      StyleBox["(",
       FontSlant->"Italic"], 
      RowBox[{
       StyleBox["l",
        FontSlant->"Italic"], "+", "1"}], ")"}]}], "]"}], 
   RowBox[{"1", "/", "2"}]]],
  CellChangeTimes->{{3.810112811439228*^9, 3.8101128248442793`*^9}, {
    3.810479494926491*^9, 3.8104795038498344`*^9}, {3.810479572543576*^9, 
    3.8104796147383184`*^9}, {3.8104802055659895`*^9, 
