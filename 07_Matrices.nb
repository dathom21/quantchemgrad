Cell[BoxData[
 RowBox[{
  RowBox[{"\[LeftAngleBracket]", 
   RowBox[{
    StyleBox[
     SubscriptBox[
      StyleBox["\[CapitalPsi]",
       FontWeight->"Bold"], "a"],
     FontWeight->"Bold"], ",", 
    StyleBox[
     SubscriptBox[
      StyleBox["\[CapitalPsi]",
       FontWeight->"Bold"], "b"],
     FontWeight->"Bold"]}], "\[RightAngleBracket]"}], "=", 
  RowBox[{
   UnderscriptBox[
    OverscriptBox["\[Sum]", 
     StyleBox["n",
      FontSlant->"Italic"]], 
    RowBox[{
     StyleBox["i",
      FontSlant->"Italic"], "=", "1"}]], 
   RowBox[{
    SubsuperscriptBox[
     StyleBox["a",
      FontSlant->"Italic"], 
     StyleBox["i",
      FontSlant->"Italic"], "\[Star]"], " ", 
    SubscriptBox[
     StyleBox["b",
      FontSlant->"Italic"], 
     StyleBox["i",
      FontSlant->"Italic"]]}]}]}]], "DisplayFormulaNumbered",
