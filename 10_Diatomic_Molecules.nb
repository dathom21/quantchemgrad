Cell[TextData[{
 StyleBox["Figure 10.8",
  FontWeight->"Bold"],
 ". Schematic representation of the formation of the \[Sigma] bonds from \
different combinations of atomic orbitals (",
 StyleBox["s",
  FontSlant->"Italic"],
 ", ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "z"], TraditionalForm]],ExpressionUUID->
  "62e997e2-daca-4d61-a0ab-4bafa264d534"],
 ", ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["d", 
    SuperscriptBox["z", "2"]], TraditionalForm]],ExpressionUUID->
  "34e90601-2504-4629-b96d-3baaf1e06ddd"],
 ", or ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["d", 
    RowBox[{
     SuperscriptBox["x", "2"], "-", 
     SuperscriptBox["y", "2"]}]], TraditionalForm]],ExpressionUUID->
  "87d72a80-5e09-480e-abc3-6647c7e57121"],
 ") or hybridized atomic orbitals (not yet discussed, ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    StyleBox["sp",
     FontSlant->"Italic"], "n"], TraditionalForm]],ExpressionUUID->
  "96ea26dc-0162-422e-82ee-64b1b53b413d"],
 "). CCoil  (2008) , Wikimedia Commons, CC BY-SA 3.0, \
https://commons.wikimedia.org/wiki/File:Sigma-bonds-2D.svg."
}], "Affiliation",
 CellChangeTimes->CompressedData["
1:eJxTTMoPSmViYGCQAGIQPeNH5qbXiW8cy6t7doDoiRfCxd8A6ZBDtWA6NlRg
2Ucgzeepug5EP9i1klMq+Y3jPDdZHhB9wJqvywxIZ3gETwDRKatTZoDo3bMc
Z4L5eheOmQPpsjc+p0C0n5/FRRDdenT2FRAdtplH9g2QPiRrCqbDLvOkxqa8
cdwf4dAAopc8eDIFRO/S+DoVROte8dgGoucZ7NoJoo9Z7LkBogumMN4F0V3b
ggPNMt44im+qA9PVp4vCQPS2YpFwEG26LaUWRE/Z86gZRBsV205oBtIaHasn
g2idhuAZIPpUsvMiEP3zUsph1qw3jpydXNdA9Jru9PhrQDpls3wCiF5wYk2b
nslbxyaV7nYQzSOuMANER/bWLwTR6ywyl4Fov9L5a0G0zta5ctVhbx0d/JaB
aQCterqD
  "],ExpressionUUID->"fcf52175-8519-411b-93c8-90133ccafeb4"],

Cell[TextData[{
 "The ",
 Cell[BoxData[
  FormBox[
   RowBox[{"2", 
    SubscriptBox["p", "x"]}], TraditionalForm]],ExpressionUUID->
  "d5269639-7ff6-4ab3-b9d9-2de95543c13e"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"2", 
    SubscriptBox["p", "y"]}], TraditionalForm]],ExpressionUUID->
  "4750e9b0-6184-4978-b52f-4e858abe9c3c"],
 " atomic orbitals will not lie along the internuclear axis, and the linear \
combination of either ",
 Cell[BoxData[
  FormBox[
   RowBox[{"2", 
    SubscriptBox["p", 
     SubscriptBox[
      StyleBox["x",
       FontSlant->"Italic"], "A"]]}], TraditionalForm]],ExpressionUUID->
  "ad5e1b4d-1736-4588-a7f8-d4daaebe483a"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"2", 
    SubscriptBox["p", 
     SubscriptBox[
      StyleBox["x",
       FontSlant->"Italic"], "B"]]}], TraditionalForm]],ExpressionUUID->
  "f613f7b0-4290-4f1a-8617-82ee65bfc260"],
 " or  ",
 Cell[BoxData[
  FormBox[
   RowBox[{"2", 
    SubscriptBox["p", 
     SubscriptBox[
      StyleBox["y",
       FontSlant->"Italic"], "A"]]}], TraditionalForm]],ExpressionUUID->
  "9060a69d-e1b7-409c-bbf3-04c6beb3a83d"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"2", 
    SubscriptBox["p", 
     SubscriptBox[
      StyleBox["y",
       FontSlant->"Italic"], "B"]]}], TraditionalForm]],ExpressionUUID->
  "f074af45-55a1-4b1d-9d64-dc5686913e39"],
 " will generate a set of \[Pi] orbitals with a nodal plane along the \
internuclear axis. This formation of \[Pi] orbitals is illustrated for the \
combination of  ",
 Cell[BoxData[
  FormBox[
   RowBox[{"2", 
    SubscriptBox["p", 
     StyleBox["xA",
      FontSlant->"Italic"]]}], TraditionalForm]],ExpressionUUID->
  "3825b65b-6c96-4217-a6d9-4e81d7852420"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"2", 
    SubscriptBox["p", 
     StyleBox["xB",
      FontSlant->"Italic"]]}], TraditionalForm]],ExpressionUUID->
  "88456047-04f3-46b7-bb15-38d0f18f0715"],
 " in the top of Figure 10.9. The antibonding ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[Pi]", "\[Star]"], TraditionalForm]],ExpressionUUID->
  "d19c3e25-a0fe-4eb0-aac6-d1cda43d0f0f"],
 " is illustrated in the bottom of Figure 10.9. There are two sets of \[Pi] \
orbitals, oriented either along the ",
 StyleBox["x",
  FontSlant->"Italic"],
 " or ",
 StyleBox["y",
  FontSlant->"Italic"],
 " axis.  Note that there is no combination of ",
 Cell[BoxData[
  FormBox[
   RowBox[{"2", 
    SubscriptBox["p", 
     StyleBox["xA",
      FontSlant->"Italic"]]}], TraditionalForm]],ExpressionUUID->
  "02cf8ddc-0e31-4bbf-88fd-c03d78b8b442"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"2", 
    SubscriptBox["p", 
     StyleBox["yB",
      FontSlant->"Italic"]]}], TraditionalForm]],ExpressionUUID->
  "edf16818-5486-4cde-a6d1-fec9e827af33"],
 " because these functions are (to first approximation) spatially orthogonal \
(they don\[CloseCurlyQuote]t overlap)."
}], "Text",
 CellChangeTimes->{{3.8136828696788836`*^9, 3.8136830427236176`*^9}, {
  3.813683190408862*^9, 3.8136831910847054`*^9}, {3.813683308617442*^9, 
  3.8136833697519407`*^9}, {3.8136834056154823`*^9, 3.813683409239093*^9}, {
  3.9196729438346252`*^9, 3.9196729768698697`*^9}, {3.9196731033151913`*^9, 
  3.9196731732636523`*^9}, {3.9374878466627865`*^9, 
  3.937487853102337*^9}},ExpressionUUID->"6870ca8a-2433-487d-ab00-\
a0ab4aa53a28"],

