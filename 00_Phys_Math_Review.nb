Cell[TextData[{
 "This equation describes ",
 StyleBox["simple harmonic motion",
  FontSlant->"Italic"],
 " and has a highly characteristic form of solution. We will return to \
solving these types of equations later in the course, but the solutions take \
the form "
}], "Text",
 CellChangeTimes->{{3.914412938670701*^9, 
  3.9144130264378276`*^9}},ExpressionUUID->"a3687bd3-b6fd-4576-be36-\
e0d731fe2bef"],

