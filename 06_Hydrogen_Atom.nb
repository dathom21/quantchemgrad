      FontSlant->"Plain"], 
     StyleBox["z",
      FontSlant->"Italic"]}]}], "=", 
   RowBox[{
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       StyleBox["r",
        FontSlant->"Italic"], 
       StyleBox[" ",
        FontSlant->"Italic"], 
       StyleBox["sin\[Theta]",
        FontSlant->"Plain"], 
       StyleBox[" ",
        FontSlant->"Plain"], 
       StyleBox[
        RowBox[{"\[DifferentialD]", "\[Phi]"}],
        FontSlant->"Plain"]}], ")"}], 
     RowBox[{"(", 
      RowBox[{
       StyleBox["r",
        FontSlant->"Italic"], 
       StyleBox[" ",
        FontSlant->"Italic"], 
       RowBox[{
        StyleBox["\[DifferentialD]",
         FontSlant->"Plain"], "\[Theta]"}]}], ")"}], 
