             FontSlant->"Italic"]}], 
           RowBox[{"(", 
            StyleBox["r",
             FontSlant->"Italic"], ")"}], 
           StyleBox["Y",
            FontSlant->"Italic"], 
           RowBox[{"(", 
            RowBox[{"\[Theta]", ",", "\[Phi]"}], ")"}]}], 
          RowBox[{"\[PartialD]", "\[Theta]"}]]}], ")"}]}]}], "+", 
     RowBox[{
      FractionBox["1", 
       RowBox[{
        SuperscriptBox["sin", "2"], 
        RowBox[{"(", "\[Theta]", ")"}]}]], 
      RowBox[{"(", 
       FractionBox[
        RowBox[{
         RowBox[{
          SuperscriptBox["\[PartialD]", "2"], 
          StyleBox["R",
           FontSlant->"Italic"]}], 
