Cell[TextData[{
 "The reason for this transformation is to represent the complex exponentials \
using only real values, which makes them easier to interpret and plot. Again, \
you can visualize the  ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "x"], TraditionalForm]],ExpressionUUID->
  "40965d9e-70bb-456f-8ea6-68541cde19bc"],
 " and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "y"], TraditionalForm]],ExpressionUUID->
  "ed347d4e-3a34-4a94-810c-e8e8d29cb0c1"],
 " atomic orbitals in Figure 6.4. You can see that they have the same shape \
as the ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "z"], TraditionalForm]],ExpressionUUID->
  "cdd9f1ea-22d5-4851-b65e-9c3b8d6936ea"],
 " orbital, but they are oriented about the ",
 StyleBox["x-",
  FontSlant->"Italic"],
 " or ",
 StyleBox["y",
  FontSlant->"Italic"],
 "-axis rather than the ",
 StyleBox["z",
  FontSlant->"Italic"],
 "-axis."
}], "Text",
 CellChangeTimes->{{3.8109857231670628`*^9, 3.810985839874942*^9}, {
  3.917100727601615*^9, 
  3.917100728912098*^9}},ExpressionUUID->"9dc49846-0b17-4a68-982d-\
5ec81366786a"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[{
 "The Five ",
 StyleBox["d",
  FontSlant->"Italic"],
 " Orbitals Are Represented by Linear Combinations of Spherical Harmonics"
}], "Subsubsection",
 CellChangeTimes->{{3.8107192356180935`*^9, 3.8107192389984384`*^9}, {
  3.810720092755737*^9, 3.81072009754844*^9}, {3.8107211801768475`*^9, 
  3.810721196999052*^9}, {3.810723622437487*^9, 3.8107236405152397`*^9}, {
  3.8107254010986814`*^9, 3.8107254249521646`*^9}, {3.8109859321201744`*^9, 
  3.8109859565496674`*^9}},ExpressionUUID->"a065a5b3-df3b-44d0-83f5-\
4f98e38f6f20"],

Cell[TextData[{
 "The spherical harmonics where the orbital angular momentum quantum number ",
 StyleBox["l",
  FontSlant->"Italic"],
 " = 2 correspond to the ",
 StyleBox["d",
  FontSlant->"Italic"],
 " atomic orbitals. Because there are five possible values of ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["m", "l"], TraditionalForm]],ExpressionUUID->
  "eb752a57-d844-4284-89fe-0a0eff1a3deb"],
 " for ",
 StyleBox["l",
  FontSlant->"Italic"],
 " = 2 (",
 Cell[BoxData[
  FormBox[
   SubscriptBox["m", "l"], TraditionalForm]],ExpressionUUID->
  "a8ee7498-16fc-46cf-b0d3-14afaf5f752b"],
 " = \[Minus]2, \[Minus]1, 0, 1, and 2), there are five possible atomic \
orbitals. As with the ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "x"], TraditionalForm]],ExpressionUUID->
  "d42789c0-66ba-48a2-9bcb-7d3dbb455d1e"],
 " and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "y"], TraditionalForm]],ExpressionUUID->
  "215a99bf-9bef-4258-82e6-8809843f79a3"],
 ", the typical depiction of the ",
 StyleBox["d",
  FontSlant->"Italic"],
 " atomic orbitals involves a linear combination of the ",
 Cell[BoxData[
  RowBox[{
   SubsuperscriptBox[
    StyleBox["Y",
     FontSlant->"Italic"], "2", 
    SubscriptBox[
     StyleBox["m",
      FontSlant->"Italic"], 
     StyleBox["l",
      FontSlant->"Italic"]]], 
   RowBox[{"(", 
    RowBox[{"\[Theta]", ",", "\[Phi]"}], ")"}]}]],
  CellChangeTimes->{{3.810112811439228*^9, 3.8101128248442793`*^9}, {
    3.810479494926491*^9, 3.8104795038498344`*^9}, {3.810479572543576*^9, 
    3.8104796147383184`*^9}, {3.8104802055659895`*^9, 
    3.8104802433915305`*^9}, {3.8104802785189395`*^9, 
    3.8104802814214115`*^9}, {3.810480477782269*^9, 3.8104805471507206`*^9}, {
    3.8104805927965565`*^9, 3.810480633017248*^9}, {3.8104807595294323`*^9, 
    3.8104809538100047`*^9}, {3.8104811300285854`*^9, 
    3.8104811403007636`*^9}, {3.8104812580010843`*^9, 
