Cell[TextData[{
 StyleBox["Figure 5.8",
  FontWeight->"Bold"],
 ". Rigid-rotor model, Roflmaostc, Wikipedia 2020, CC-BY-SA 4.0, \
https://commons.wikimedia.org/wiki/File:Rigid_rotor_point_masses.svg"
}], "Affiliation",
 CellChangeTimes->{{3.809435027311596*^9, 3.8094350763900714`*^9}, {
  3.80943583474421*^9, 3.8094358359299717`*^9}, {3.8094472165104203`*^9, 
  3.809447281165168*^9}, {3.810054221304062*^9, 3.8100542409148703`*^9}, {
  3.8101125924447937`*^9, 3.8101126426025887`*^9}, {3.8101127071459217`*^9, 
  3.810112714050138*^9}, {3.810115126505663*^9, 3.8101151266187673`*^9}, {
  3.915801087044256*^9, 
  3.9158010883699694`*^9}},ExpressionUUID->"1f25a73f-1ea6-4012-959c-\
f8ff5bfe61b3"],

Cell["As stated above, the center of mass is the point at which", "Text",
 CellChangeTimes->{{3.8101127629350033`*^9, 3.810112805035315*^9}, {
  3.915801190758237*^9, 
  3.9158011930596795`*^9}},ExpressionUUID->"adf39696-0b1e-4d7e-a68f-\
a521e143c94d"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   SubscriptBox[
    StyleBox["m",
     FontSlant->"Italic"], "1"], 
   SubscriptBox[
    StyleBox["r",
     FontSlant->"Italic"], "1"]}], "=", 
  RowBox[{
   SubscriptBox[
    StyleBox["m",
     FontSlant->"Italic"], "2"], 
   SubscriptBox[
    StyleBox["r",
     FontSlant->"Italic"], "2"]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.810112811439228*^9, 
  3.8101128248442793`*^9}},ExpressionUUID->"1f77613a-9ae7-49d3-9253-\
38fd35713d45"],

Cell[TextData[{
 "Let\[CloseCurlyQuote]s now consider rotation about the center of mass. Both \
masses will rotate in a circle at the same angular speed \[Omega] but with \
different radii ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["r", "1"], TraditionalForm]],ExpressionUUID->
  "77b46b84-24ca-4bff-8852-6e1fbe59ea59"],
 " and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["r", "2"], TraditionalForm]],ExpressionUUID->
  "cbbd7364-10b2-4d55-9c0d-8bf617a3f358"],
 ". We can then define the total rotational kinetic energy as the sum of the \
kinetic energy of each mass,"
}], "Text",
 CellChangeTimes->{{3.8101130245933857`*^9, 3.810113031598013*^9}, {
  3.810113094329752*^9, 
  3.8101131997857656`*^9}},ExpressionUUID->"e3064549-618e-4866-ad54-\
e9a504001c6b"],

Cell[BoxData[
 RowBox[{
  StyleBox["T",
   FontSlant->"Italic"], "=", 
  RowBox[{
   RowBox[{
    FractionBox[
     RowBox[{
      SubscriptBox[
       StyleBox["m",
        FontSlant->"Italic"], "1"], 
      SubsuperscriptBox[
       StyleBox["r",
        FontSlant->"Italic"], "1", "2"], 
      SuperscriptBox["\[Omega]", "2"]}], "2"], "+", 
    FractionBox[
     RowBox[{
      SubscriptBox[
       StyleBox["m",
        FontSlant->"Italic"], "2"], 
      SubsuperscriptBox[
       StyleBox["r",
        FontSlant->"Italic"], "2", "2"], 
      SuperscriptBox["\[Omega]", "2"]}], "2"]}], "=", 
   RowBox[{
    FractionBox["1", "2"], 
    RowBox[{"(", 
     RowBox[{
      RowBox[{
       SubscriptBox[
        StyleBox["m",
         FontSlant->"Italic"], "1"], 
       SubsuperscriptBox[
        StyleBox["r",
         FontSlant->"Italic"], "1", "2"]}], "+", 
      RowBox[{
       SubscriptBox[
        StyleBox["m",
         FontSlant->"Italic"], "2"], 
       SubsuperscriptBox[
        StyleBox["r",
         FontSlant->"Italic"], "2", "2"]}]}], ")"}], 
    SuperscriptBox["\[Omega]", "2"]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.810108783183482*^9, 3.810108815266238*^9}, {
  3.8101088632448235`*^9, 3.8101088893706894`*^9}, {3.8101114824558687`*^9, 
  3.810111559886958*^9}, {3.8101132073667517`*^9, 3.810113282146639*^9}, {
  3.9158012420452943`*^9, 
  3.9158012480901976`*^9}},ExpressionUUID->"97a4a21d-66eb-4cca-aa92-\
ef9926be35e1"],

Cell["\<\
In this form, it is easier to see that we can then write the moment of \
inertia of the entire system as\
\>", "Text",
 CellChangeTimes->{{3.81011328928522*^9, 
  3.8101133034998217`*^9}},ExpressionUUID->"2ead13f5-b459-4542-bb11-\
1001c362c8c8"],

Cell[BoxData[
 RowBox[{
  StyleBox["I",
   FontSlant->"Italic"], 
  StyleBox["=",
   FontSlant->"Plain"], 
  RowBox[{
   RowBox[{
    SubscriptBox[
     StyleBox["m",
      FontSlant->"Italic"], "1"], 
    SubsuperscriptBox[
     StyleBox["r",
      FontSlant->"Italic"], "1", "2"]}], "+", 
   RowBox[{
    SubscriptBox[
     StyleBox["m",
      FontSlant->"Italic"], "2"], 
    SubsuperscriptBox[
     StyleBox["r",
      FontSlant->"Italic"], "2", "2"]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8100544880652375`*^9, 3.8100545041200957`*^9}, {
   3.810054632482561*^9, 3.8100546606919527`*^9}, {3.810054738405748*^9, 
   3.810054754160844*^9}, {3.8101095281443005`*^9, 3.810109574197364*^9}, {
   3.810110302377673*^9, 3.81011033119788*^9}, {3.81011042226412*^9, 
   3.8101104310884852`*^9}, {3.8101105613940926`*^9, 3.810110566931136*^9}, {
   3.810110941872168*^9, 3.8101110800488815`*^9}, 
   3.8101133155103245`*^9},ExpressionUUID->"04be295d-1d84-496f-a6c2-\
31128e25874f"],

Cell["and then write the rotational kinetic energy as", "Text",
 CellChangeTimes->{{3.8101133297721863`*^9, 
  3.810113351993456*^9}},ExpressionUUID->"fba83c4b-1dfc-4a26-9efc-\
b4c2235b49b6"],

Cell[BoxData[
 RowBox[{
  StyleBox["T",
   FontSlant->"Italic"], "=", 
  RowBox[{
   FractionBox["1", "2"], 
   SuperscriptBox[
    StyleBox[
     RowBox[{
      StyleBox["I",
       FontSlant->"Italic"], "\[Omega]"}]], 
    "2"]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.810108783183482*^9, 3.810108815266238*^9}, {
  3.8101088632448235`*^9, 3.8101088893706894`*^9}, {3.8101114824558687`*^9, 
  3.810111559886958*^9}, {3.8101132073667517`*^9, 3.810113282146639*^9}, {
  3.810113340959403*^9, 3.8101133457491274`*^9}, {3.9158012559551315`*^9, 
  3.9158012568764963`*^9}},ExpressionUUID->"1051d8e2-f4de-4381-9976-\
927fd4924cda"],

Cell["\<\
Using the center of mass definition (equation 52) and the concept of a \
relative coordinate system,\
\>", "Text",
 CellChangeTimes->{{3.810113362865734*^9, 3.8101133682096214`*^9}, {
  3.810113425311859*^9, 3.8101134414754753`*^9}, {3.8101141940528436`*^9, 
  3.810114228921681*^9}, {3.810115941456604*^9, 3.8101159417772646`*^9}, {
  3.9158012648599043`*^9, 3.9158012650548344`*^9}, {3.9161625716621876`*^9, 
  3.9161625718459454`*^9}, {3.935146727960634*^9, 
  3.9351467283664*^9}},ExpressionUUID->"042f29cb-261e-4597-ba64-488b6aa1b57e"],

Cell[BoxData[
 RowBox[{
  StyleBox["r",
   FontSlant->"Italic"], "=", 
  RowBox[{
   SubscriptBox[
    StyleBox["r",
     FontSlant->"Italic"], "1"], "+", 
   SubscriptBox[
    StyleBox["r",
     FontSlant->"Italic"], "2"]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.810113459805457*^9, 
  3.81011348114777*^9}},ExpressionUUID->"6702f132-9176-4671-88a0-\
3ee4a8616b13"],

Cell["we can rewrite equation (53) as", "Text",
 CellChangeTimes->{{3.8101134440893884`*^9, 3.8101134465289345`*^9}, {
  3.810113485863845*^9, 3.810113489400313*^9}, {3.8101159469352026`*^9, 
  3.810115947533907*^9}, {3.9158012982550564`*^9, 3.9158012983778934`*^9}, {
  3.916162575272066*^9, 
  3.916162575446187*^9}},ExpressionUUID->"31cf5690-6911-4cd7-9a58-\
8de67e836a3e"],

Cell[BoxData[
 RowBox[{
  StyleBox["I",
   FontSlant->"Italic"], 
  StyleBox["=",
   FontSlant->"Plain"], 
  RowBox[{
   RowBox[{
    RowBox[{"(", 
     FractionBox[
      RowBox[{
       SubscriptBox[
        StyleBox["m",
         FontSlant->"Italic"], "1"], 
       SubscriptBox[
        StyleBox["m",
         FontSlant->"Italic"], "2"]}], 
      RowBox[{
       SubscriptBox[
        StyleBox["m",
         FontSlant->"Italic"], "1"], "+", 
       SubscriptBox[
        StyleBox["m",
         FontSlant->"Italic"], "2"]}]], ")"}], 
    SuperscriptBox[
     RowBox[{"(", 
      RowBox[{
       SubscriptBox[
        StyleBox["r",
         FontSlant->"Italic"], "1"], "+", 
       SubscriptBox[
        StyleBox["r",
         FontSlant->"Italic"], "2"]}], ")"}], "2"]}], "=", 
   SuperscriptBox[
    StyleBox[
     RowBox[{"\[Mu]", 
      StyleBox["r",
       FontSlant->"Italic"]}]], "2"]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8100544880652375`*^9, 3.8100545041200957`*^9}, {
   3.810054632482561*^9, 3.8100546606919527`*^9}, {3.810054738405748*^9, 
   3.810054754160844*^9}, {3.8101095281443005`*^9, 3.810109574197364*^9}, {
   3.810110302377673*^9, 3.81011033119788*^9}, {3.81011042226412*^9, 
   3.8101104310884852`*^9}, {3.8101105613940926`*^9, 3.810110566931136*^9}, {
   3.810110941872168*^9, 3.8101110800488815`*^9}, 3.8101133155103245`*^9, {
   3.810113494547086*^9, 3.810113538835008*^9}, 3.8101135907593746`*^9, {
   3.8101142031650095`*^9, 
   3.8101142093375626`*^9}},ExpressionUUID->"94af1744-c1c8-4654-a647-\
f9c16adde1c3"],

Cell["\<\
Just as in the case of two masses on a spring, we can now represent our two \
fixed, rotating masses as a single system. The magnitude of the angular \
momentum can written as \
\>", "Text",
 CellChangeTimes->{{3.8101142436483245`*^9, 3.810114269594753*^9}, {
   3.8101143433844814`*^9, 3.810114361018783*^9}, 
   3.9158013085733337`*^9},ExpressionUUID->"1f5b737e-c0fa-418d-a841-\
742ef132b1b1"],

