e0adc7f6f2f3"],

Cell[CellGroupData[{

Cell["The Reduced Mass", "Subsection",
 CellChangeTimes->{{3.810479300424015*^9, 
  3.81047930364119*^9}},ExpressionUUID->"4afbc05e-81c0-4045-b901-\
91cf26e7a416"],

Cell[TextData[{
 "The hydrogen atom comprises only two particles: one proton and one \
electron. We are interested in solving the time-independent \
Schr\[ODoubleDot]dinger equation for this system. We need to solve the \
equation for both particles as a function of their orientation about the \
center of mass, but as we saw with the rigid rotor and harmonic oscillator, \
we can greatly simplify the system if we use a reduced mass \[Mu] that is \
located a distance ",
 StyleBox["r",
  FontSlant->"Italic"],
 " from the center of mass. Recall that the center of mass is given as the \
point at which"
}], "Text",
 CellChangeTimes->{{3.8104780850264416`*^9, 3.810478158007231*^9}, {
  3.810478188272515*^9, 3.810478213897179*^9}, {3.810478256457456*^9, 
  3.8104783444208865`*^9}, {3.8104783834411936`*^9, 3.810478390185643*^9}, {
  3.8104784829177494`*^9, 3.810478540472525*^9}, {3.8104785733790383`*^9, 
  3.810478609883218*^9}, {3.810478734228631*^9, 
  3.8104787474310246`*^9}},ExpressionUUID->"cec021a2-32d5-4bbd-bad3-\
85e10b34e64c"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   SubscriptBox[
    StyleBox["m",
     FontSlant->"Italic"], "1"], 
   SubscriptBox[
    StyleBox["r",
     FontSlant->"Italic"], "1"]}], "=", 
  RowBox[{
   SubscriptBox[
    StyleBox["m",
     FontSlant->"Italic"], "2"], 
   SubscriptBox[
    StyleBox["r",
     FontSlant->"Italic"], "2"]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.810112811439228*^9, 
  3.8101128248442793`*^9}},ExpressionUUID->"5ff8ddef-6191-4f21-b465-\
ef07887a37b0"],

Cell["Because the proton mass,", "Text",
 CellChangeTimes->{{3.810478748468439*^9, 
  3.8104787508802724`*^9}},ExpressionUUID->"5487c2dc-e153-4a1c-919b-\
aa8e28b333ae"],

Cell[BoxData[
 RowBox[{
  StyleBox[
   SubscriptBox["m", "p"],
   FontSlant->"Italic"], "=", 
  RowBox[{
   RowBox[{"1.00727647", " ", "Da"}], "=", 
   RowBox[{"1.6726219", "\[Times]", 
    SuperscriptBox["10", 
     RowBox[{"-", "27"}]], " ", "kg"}]}]}]], "DisplayFormula",
 CellChangeTimes->{{3.810478631362033*^9, 3.8104786806047573`*^9}, {
  3.8104788639280605`*^9, 3.8104788641706834`*^9}},
 FontSize->18,ExpressionUUID->"2d4a9ac3-0b68-4602-8e94-1f2f6c78506e"],

