  3.9146037796453476`*^9}},ExpressionUUID->"e0c32ce7-ecda-451d-b957-\
b9d5937951fd"],

Cell[TextData[{
 "then taking the derivative of equation (21) with respect to ",
 StyleBox["t",
  FontSlant->"Italic"],
 ", we obtain"
}], "Text",
 CellChangeTimes->{{3.914416672409033*^9, 3.9144166923534822`*^9}, {
  3.9144167582072535`*^9, 3.9144167584365435`*^9}, {3.9339480505389957`*^9, 
  3.93394807869178*^9}},ExpressionUUID->"fa9ad8aa-a4f7-48f6-ac09-\
4934b806e6b3"],

Cell[BoxData[
 RowBox[{
  FractionBox[
   RowBox[{
    SuperscriptBox["\[DifferentialD]", "2"], "\[Theta]"}], 
   RowBox[{"\[DifferentialD]", 
    SuperscriptBox[
     StyleBox["t",
      FontSlant->"Italic"], "2"]}]], "=", 
  RowBox[{
   FractionBox[
    StyleBox["1",
     FontSlant->"Italic"], 
    SuperscriptBox[
     StyleBox["ml",
      FontSlant->"Italic"], "2"]], 
   RowBox[{"(", 
    FractionBox[
     RowBox[{"\[DifferentialD]", 
      StyleBox["p",
       FontSlant->"Italic"]}], 
