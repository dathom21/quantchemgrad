    3.8126319287268906`*^9}, {3.812698643216871*^9, 3.8126986714190135`*^9}, {
    3.8127065219878197`*^9, 3.8127066002469187`*^9}, {3.8127069401179733`*^9, 
    3.8127070269316473`*^9}, {3.8127076858801394`*^9, 3.812707743838921*^9}, {
    3.8127078962878947`*^9, 3.8127078968871737`*^9}, {3.8127079338490696`*^9, 
