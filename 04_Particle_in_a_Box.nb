Cell[TextData[{
 "Looking at the graphs of  ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[RightBracketingBar]", 
    RowBox[{
     SubscriptBox[
      StyleBox["\[Psi]",
       FontSlant->"Plain"], 
      StyleBox["n",
       FontSlant->"Italic"]], "(", 
     StyleBox["x",
      FontSlant->"Italic"], ")"}], 
    SuperscriptBox["\[LeftBracketingBar]", "2"]}], TraditionalForm]],
