\)\!\(\*StyleBox[\" \
\",FontSlant->\"Italic\"]\)\!\(\*StyleBox[\"(\",FontSlant->\"Italic\"]\)\!\(\*\
SuperscriptBox[\(\[Alpha]\), \
\(1/2\)]\)\!\(\*StyleBox[\"x\",FontSlant->\"Italic\"]\))\>\""}], "}"}]}], 
     "]"}], ",", 
    RowBox[{"BaseStyle", "\[Rule]", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"FontFamily", "\[Rule]", "\"\<Arial\>\""}], ",", 
       RowBox[{"FontSize", "\[Rule]", "18"}]}], "}"}]}], ",", 
