Cell[BoxData[
 RowBox[{
  RowBox[{"OrbitalModel", "[", "n_", "]"}], ":=", 
  RowBox[{"Block", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "pairs", ",", "fun", ",", "fun1", ",", "fun2", ",", "fun3", ",", "fun4", 
      ",", "a", ",", "b", ",", "i", ",", "l", ",", "m", ",", "y1", ",", "y2", 
      ",", "y3", ",", "\[Theta]", ",", "\[Phi]"}], "}"}], ",", 
    RowBox[{
     RowBox[{"pairs", "=", 
      RowBox[{"Flatten", "[", 
       RowBox[{
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"i", ",", "j"}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"i", ",", "0", ",", "5"}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"j", ",", "0", ",", "i"}], "}"}]}], "]"}], ",", "1"}], 
       "]"}]}], ";", "\n", 
     RowBox[{"fun", "=", 
      RowBox[{"{", "}"}]}], ";", "\n", 
     RowBox[{"Do", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"l", "=", 
         RowBox[{"pairs", "[", 
          RowBox[{"[", 
           RowBox[{"i", ",", "1"}], "]"}], "]"}]}], ";", "\n", 
        RowBox[{"m", "=", 
         RowBox[{"pairs", "[", 
          RowBox[{"[", 
           RowBox[{"i", ",", "2"}], "]"}], "]"}]}], ";", "\n", 
        RowBox[{"a", "=", 
         RowBox[{"SphericalHarmonicY", "[", 
          RowBox[{"l", ",", 
           RowBox[{"-", "m"}], ",", "\[Theta]", ",", "\[Phi]"}], "]"}]}], ";",
         "\n", 
        RowBox[{"b", "=", 
         RowBox[{"SphericalHarmonicY", "[", 
          RowBox[{"l", ",", "m", ",", "\[Theta]", ",", "\[Phi]"}], "]"}]}], 
        ";", "\n", 
        RowBox[{"y1", "=", "b"}], ";", "\n", 
        RowBox[{"y2", "=", 
         RowBox[{"ExpToTrig", "[", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{"a", "-", "b"}], ")"}], "/", 
           RowBox[{"Sqrt", "[", "2", "]"}]}], "]"}]}], ";", "\n", 
        RowBox[{"y3", "=", 
         RowBox[{"ExpToTrig", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"(", 
             RowBox[{"a", "+", "b"}], ")"}], "/", 
            RowBox[{"Sqrt", "[", "2", "]"}]}], "/", "I"}], "]"}]}], ";", "\n", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"m", "==", "0"}], ",", 
          RowBox[{"AppendTo", "[", 
           RowBox[{"fun", ",", "y1"}], "]"}], ",", 
          RowBox[{"AppendTo", "[", 
           RowBox[{"fun", ",", 
            RowBox[{"{", 
             RowBox[{"y2", ",", "y3"}], "}"}]}], "]"}]}], "]"}], ";", "\n", 
        RowBox[{"fun1", "=", 
         RowBox[{"Flatten", "[", 
          RowBox[{"fun", ",", "1"}], "]"}]}]}], ",", 
       RowBox[{"{", 
        RowBox[{"i", ",", "1", ",", 
         RowBox[{"Length", "[", "pairs", "]"}]}], "}"}]}], "]"}], ";", "\n", 
     RowBox[{"fun2", "=", 
      RowBox[{"Take", "[", 
       RowBox[{"fun1", ",", "16"}], "]"}]}], ";", "\n", 
     RowBox[{"fun3", "=", 
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"i", "==", "4"}], "||", 
           RowBox[{"i", "==", "7"}], "||", 
           RowBox[{"i", "==", "12"}], "||", 
           RowBox[{"i", "==", "14"}], "||", 
           RowBox[{"i", "==", "16"}]}], ",", 
          RowBox[{"-", 
           RowBox[{"fun2", "[", 
            RowBox[{"[", "i", "]"}], "]"}]}], ",", 
          RowBox[{"fun2", "[", 
           RowBox[{"[", "i", "]"}], "]"}]}], "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"i", ",", "1", ",", "16"}], "}"}]}], "]"}]}], ";", "\n", 
     RowBox[{"fun4", "=", 
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"i", "==", "8"}], "||", 
           RowBox[{"i", "==", "9"}], "||", 
           RowBox[{"i", "==", "13"}], "||", 
           RowBox[{"i", "==", "14"}]}], ",", 
          RowBox[{
           RowBox[{"fun3", "[", 
            RowBox[{"[", "i", "]"}], "]"}], "*", "I"}], ",", 
          RowBox[{"fun3", "[", 
           RowBox[{"[", "i", "]"}], "]"}]}], "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"i", ",", "1", ",", "16"}], "}"}]}], "]"}]}], ";", "\n", 
     RowBox[{"fun4", "[", 
      RowBox[{"[", "n", "]"}], "]"}]}]}], "]"}]}]], "Input",
 CellGroupingRules->{"GroupTogetherGrouping", 9574.},
 InitializationCell->True,
 CellChangeTimes->{{3.586946977816477*^9, 3.5869470062739553`*^9}, {
   3.586953196972035*^9, 3.586953242070891*^9}, {3.586957679095481*^9, 
   3.586957713262815*^9}, {3.586957875930149*^9, 3.586957882894834*^9}, {
   3.586958424119018*^9, 3.586958449898819*^9}, {3.586959900437353*^9, 
