        StyleBox["H",
         FontSlant->"Italic"], "^"], 
       RowBox[{"(", 
        StyleBox["1",
         FontSlant->"Plain"], ")"}]],
      FontSlant->"Italic"], 
     StyleBox["|",
      FontSlant->"Italic"], 
     SuperscriptBox["\[Psi]", 
      RowBox[{"(", "0", ")"}]]}], "\[RightAngleBracket]"}]}], "=", 
  RowBox[{
   RowBox[{
    SuperscriptBox[
     StyleBox["E",
      FontSlant->"Italic"], 
