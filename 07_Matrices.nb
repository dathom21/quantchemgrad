Cell[TextData[{
 "which, if  ",
 Cell[BoxData[
  RowBox[{
   StyleBox[
    SubscriptBox[
     StyleBox["\[CapitalPsi]",
      FontWeight->"Bold"], 
     StyleBox["a",
      FontWeight->"Bold",
      FontSlant->"Italic"]],
    FontWeight->"Bold"], 
   StyleBox["=",
    FontWeight->"Bold"], 
   SubscriptBox[
    StyleBox["\[CapitalPsi]",
