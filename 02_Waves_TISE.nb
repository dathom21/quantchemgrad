Cell[TextData[{
 "Take note of the interesting phenomenon that just happened: ",
 StyleBox["simply by imposing some boundary conditions, \
we\[CloseCurlyQuote]ve ended up with a series of solutions that are \
differentiated by some integer ",
  FontWeight->"Bold"],
 StyleBox["n",
  FontWeight->"Bold",
  FontSlant->"Italic"],
 ". We will see a similar result time and again when dealing with quantum \
mechanical systems. "
}], "Text",
 CellChangeTimes->{{3.807872331995488*^9, 3.8078723333699875`*^9}, {
  3.8078901564517546`*^9, 3.807890306643409*^9}, {3.8078903574952602`*^9, 
  3.807890392398267*^9}, {3.840284261732484*^9, 
  3.8402842631968727`*^9}},ExpressionUUID->"14d8c426-8f54-4ae0-ad3c-\
c28cac3264c3"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Time Dependence of the Vibrating String", "Subsection",
 CellChangeTimes->{{3.8078904320525713`*^9, 
  3.807890439743148*^9}},ExpressionUUID->"82679647-8084-4062-8cb0-\
c444f1e1355f"],

Cell[TextData[{
 "In the previous section, we used our boundary conditions to obtain \
solutions for the spatial part of the wave equation ",
 StyleBox["X ",
  FontSlant->"Italic"],
 "(",
 StyleBox["x ",
  FontSlant->"Italic"],
 "). What about the time component? Recall that in our separation of \
variables formulation, the time portion ",
 StyleBox["T",
  FontSlant->"Italic"],
 " (",
 StyleBox["t ",
  FontSlant->"Italic"],
 ") takes the form"
}], "Text",
 CellChangeTimes->{{3.8078904510326796`*^9, 3.807890476090347*^9}, {
   3.807890553763851*^9, 3.807890602956653*^9}, {3.807890635894803*^9, 
   3.807890672354899*^9}, 
   3.807892882851849*^9},ExpressionUUID->"dc9450c3-4081-4093-a74b-\
b2e193ec02c3"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   FractionBox["1", 
    RowBox[{
     SuperscriptBox[
      StyleBox["v",
       FontSlant->"Italic"], "2"], 
     StyleBox["T",
      FontSlant->"Italic"], 
     StyleBox[
      RowBox[{"(", "t", ")"}],
      FontSlant->"Italic"]}]], 
   FractionBox[
    RowBox[{
     RowBox[{
      SuperscriptBox["\[DifferentialD]", "2"], 
      StyleBox["T",
       FontSlant->"Italic"]}], 
     StyleBox[
      RowBox[{"(", "t", ")"}],
      FontSlant->"Italic"]}], 
    RowBox[{"\[DifferentialD]", 
     SuperscriptBox[
      StyleBox["t",
       FontSlant->"Italic"], "2"]}]]}], "=", 
  StyleBox["K",
   FontSlant->"Italic"]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{
  3.807890678089633*^9, {3.8079662504944983`*^9, 3.807966255369707*^9}, 
   3.914860476364992*^9},ExpressionUUID->"736a50c3-e35c-4f40-80e8-\
7e3edc6a6f05"],

Cell["or, rearranging,", "Text",
 CellChangeTimes->{{3.807890681763529*^9, 
  3.807890687220386*^9}},ExpressionUUID->"5769f666-7a96-429b-80d6-\
2482920977c5"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   FractionBox[
    RowBox[{
     RowBox[{
      SuperscriptBox["\[DifferentialD]", "2"], 
      StyleBox["T",
       FontSlant->"Italic"]}], 
     StyleBox[
      RowBox[{"(", "t", ")"}],
      FontSlant->"Italic"]}], 
    RowBox[{"\[DifferentialD]", 
     SuperscriptBox[
      StyleBox["t",
       FontSlant->"Italic"], "2"]}]], "-", 
   RowBox[{
    SuperscriptBox[
     StyleBox["Kv",
      FontSlant->"Italic"], "2"], 
    StyleBox["T",
     FontSlant->"Italic"], 
    StyleBox[
     RowBox[{"(", "t", ")"}],
     FontSlant->"Italic"]}]}], 
  StyleBox["=",
   FontSlant->"Plain"], 
  StyleBox["0",
   FontSlant->"Plain"]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.807890694543213*^9, 3.807890710774332*^9}, {
   3.807966256844878*^9, 3.807966260197942*^9}, 
   3.9148604792693667`*^9},ExpressionUUID->"cf2e4305-5c88-46a1-bc71-\
938af936d2f2"],

Cell[TextData[{
 "well, we already solved for ",
 StyleBox["K ",
  FontSlant->"Italic"],
 " = \[Minus]",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["k", "2"], TraditionalForm]],ExpressionUUID->
  "55443a5b-b30b-46d7-b609-aa60f9aa3bc6"],
 " = ",
 Cell[BoxData[
  RowBox[{"\[Minus]", 
   SuperscriptBox[
    RowBox[{"(", 
     FractionBox[
      StyleBox[
       RowBox[{
        StyleBox["n",
         FontSlant->"Italic"], "\[Pi]"}]], 
      StyleBox["L",
       FontSlant->"Italic"]], ")"}], "2"]}]],
  CellChangeTimes->{{3.8078715379595222`*^9, 3.8078715606925907`*^9}},
  ExpressionUUID->"9a4079b0-1808-41da-b9e4-e975b54c9f18"],
 " in the spatial dependence (equation (24)), so now we can write"
}], "Text",
 CellChangeTimes->{{3.8078907873181686`*^9, 3.8078907983619285`*^9}, {
  3.8078908394688206`*^9, 3.8078909145962954`*^9}, {3.807891774217248*^9, 
  3.807891774336585*^9}, {3.914666373679925*^9, 
  3.9146663841579485`*^9}},ExpressionUUID->"9c658d69-e65b-4b4d-ae1e-\
5cbb53e32d02"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   FractionBox[
    RowBox[{
     RowBox[{
      SuperscriptBox["\[DifferentialD]", "2"], 
      StyleBox["T",
       FontSlant->"Italic"]}], 
     StyleBox[
      RowBox[{"(", "t", ")"}],
      FontSlant->"Italic"]}], 
    RowBox[{"\[DifferentialD]", 
     SuperscriptBox[
      StyleBox["t",
       FontSlant->"Italic"], "2"]}]], "+", 
   RowBox[{
    SuperscriptBox[
     RowBox[{"(", 
      FractionBox[
       StyleBox[
        RowBox[{
         StyleBox["nv",
          FontSlant->"Italic"], "\[Pi]"}]], 
