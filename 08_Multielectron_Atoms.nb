Cell[TextData[{
 "If we multiply both sides of the equation by ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    StyleBox["S",
     FontWeight->"Bold",
     FontSlant->"Plain"], 
    RowBox[{"-", "1"}]], TraditionalForm]],ExpressionUUID->
  "8d41a291-c6bd-134c-b8ee-285421ba978c"],
 " so that we have ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox[
     StyleBox["SS",
      FontWeight->"Bold",
      FontSlant->"Plain"], 
     RowBox[{"-", "1"}]], "=", 
    StyleBox["I",
     FontWeight->"Bold",
     FontSlant->"Plain"]}], TraditionalForm]],ExpressionUUID->
  "acd58034-a284-8b4e-82d3-3bfcaaf901c6"],
 ", we obtain"
}], "Text",
 CellChangeTimes->{{3.811865784995104*^9, 
  3.81186585154276*^9}},ExpressionUUID->"09cef826-92d2-e946-97c4-\
fc45492bccf3"],

