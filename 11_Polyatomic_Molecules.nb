     RowBox[{"Molecule", "[", "\"\<ethene\>\"", "]"}], ",", 
     RowBox[{"Molecule", "[", "\"\<butadiene\>\"", "]"}], ",", 
     RowBox[{"Molecule", "[", "\"\<benzene\>\"", "]"}]}], "}"}]}], 
  ";"}], "\[IndentingNewLine]", 
