4c5a61494f4f"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   SuperscriptBox[
    RowBox[{"\[LeftBracketingBar]", 
     SubscriptBox[
      StyleBox["c",
       FontSlant->"Italic"], "2"], "\[RightBracketingBar]"}], "2"], 
   RowBox[{"(", 
    FractionBox[
     StyleBox["a",
      FontSlant->"Italic"], 
     StyleBox[
      RowBox[{
       StyleBox["n",
        FontSlant->"Italic"], 
       StyleBox["\[Pi]",
        FontSlant->"Plain"]}]]], ")"}], 
   RowBox[{
    SubsuperscriptBox["\[Integral]", "0", 
     StyleBox[
      RowBox[{
       StyleBox["n",
        FontSlant->"Italic"], "\[Pi]"}]]], 
    RowBox[{
     SuperscriptBox["sin", "2"], 
     RowBox[{"(", 
      StyleBox["z",
       FontSlant->"Italic"], ")"}], 
     StyleBox["dz",
      FontSlant->"Italic"]}]}]}], "=", 
  RowBox[{
   RowBox[{
    SuperscriptBox[
     RowBox[{"\[LeftBracketingBar]", 
      SubscriptBox[
       StyleBox["c",
        FontSlant->"Italic"], "2"], "\[RightBracketingBar]"}], "2"], 
    RowBox[{"(", 
     FractionBox[
      StyleBox["a",
