Cell[BoxData[
 RowBox[{
  FractionBox[
   FormBox[
    RowBox[{"\[DifferentialD]", 
     RowBox[{"ln", "[", 
      RowBox[{"f", "(", 
       StyleBox[
        SubscriptBox["v", "x"],
        FontSlant->"Italic"], ")"}], "]"}]}],
    TraditionalForm], 
   RowBox[{
    SubscriptBox[
     StyleBox["v",
      FontSlant->"Italic"], 
     StyleBox["x",
      FontSlant->"Italic"]], 
    RowBox[{"\[DifferentialD]", 
     SubscriptBox["v", "x"]}]}]], "=", 
  RowBox[{
   RowBox[{
    FractionBox["1", 
     SubscriptBox[
      StyleBox["v",
       FontSlant->"Italic"], 
      StyleBox["x",
       FontSlant->"Italic"]]], 
    FractionBox[
     FormBox[
      RowBox[{"\[DifferentialD]", 
       RowBox[{"ln", "[", 
        RowBox[{"f", "(", 
         StyleBox[
          SubscriptBox["v", "x"],
          FontSlant->"Italic"], ")"}], "]"}]}],
      TraditionalForm], 
     RowBox[{
      RowBox[{"\[DifferentialD]", 
       StyleBox["f",
        FontSlant->"Italic"]}], 
      StyleBox[
       RowBox[{"(", 
        SubscriptBox["v", "x"], ")"}],
       FontSlant->"Italic"]}]], 
    FractionBox[
     FormBox[
      RowBox[{"\[DifferentialD]", 
