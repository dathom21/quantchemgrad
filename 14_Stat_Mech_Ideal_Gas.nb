    3.921330874812805*^9}, {3.9214238904787655`*^9, 3.921423917414671*^9}, {
    3.9214244282577167`*^9, 3.9214244340743675`*^9}, {3.921424481932246*^9, 
    3.9214245032022505`*^9}, {3.921424987482314*^9, 3.921425055638995*^9}, {
    3.921425366857955*^9, 3.921425371156514*^9}, {3.9214256982769957`*^9, 
    3.9214257016055365`*^9}, {3.9214257501539373`*^9, 3.921425767889146*^9}, {
    3.92142603866897*^9, 3.921426048746488*^9}, {3.9214261320689683`*^9, 
    3.9214261722302637`*^9}, {3.921426337008007*^9, 3.9214264736243744`*^9}, {
    3.9214266549853134`*^9, 3.9214266922179117`*^9}, {3.921426724430789*^9, 
    3.9214267981473503`*^9}, 3.9214268670094585`*^9, 3.921432537477965*^9, {
    3.9214327258996105`*^9, 3.9214328179317846`*^9}},ExpressionUUID->
  "6da93782-1e23-4497-8507-96cc9db76aa9"],
 " we obtained from the statistical mechanical analysis of an ideal gas \
(equation 54) combined with the expression"
}], "Text",
 CellChangeTimes->{{3.921432823528539*^9, 3.921432824831332*^9}, {
   3.9214328756810317`*^9, 3.92143292090049*^9}, {3.921432967333393*^9, 
   3.9214330162200346`*^9}, {3.921433093563159*^9, 3.9214330967510204`*^9}, {
   3.921491740502135*^9, 3.9214917433966475`*^9}, 
   3.9214917987682796`*^9},ExpressionUUID->"1fd81acd-53e6-4943-90b0-\
e439af415542"],

Cell[BoxData[
 FormBox[
  RowBox[{
   SuperscriptBox["v", "2"], "=", 
   RowBox[{
    SubsuperscriptBox["v", "x", "2"], "+", 
    SubsuperscriptBox["v", "y", "2"], "+", 
    SubsuperscriptBox["v", "z", "2"]}]}], 
  TraditionalForm]], "DisplayFormulaNumbered",
 InitializationCell->True,
 CellChangeTimes->{{3.9212505192469416`*^9, 3.921250534863843*^9}, {
