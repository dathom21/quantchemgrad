Cell[CellGroupData[{

Cell["The Maxwell-Boltzmann Distribution", "Subsection",
 CellChangeTimes->{{3.921423220709637*^9, 3.921423229798174*^9}, {
  3.9214866519054146`*^9, 3.921486667890504*^9}, {3.9214867677009354`*^9, 
  3.921486772100391*^9}},ExpressionUUID->"46cf4f4b-eea1-4e0f-b79c-\
fa2f4d027222"],

Cell[TextData[{
 "We now turn from the one-dimensional distribution of velocities to the \
three-dimensional distribution of speeds. For this we want to find the \
distribution of speeds in the range ",
 Cell[BoxData[
  FormBox[
   RowBox[{"v", "+", 
    RowBox[{"\[DifferentialD]", "v"}]}], TraditionalForm]],ExpressionUUID->
  "8af63e3f-b6ec-42eb-9e19-efee27290e61"],
 ", which is given by"
}], "Text",
 CellChangeTimes->{{3.92148677723522*^9, 
  3.921486861922471*^9}},ExpressionUUID->"271281b9-8f01-4757-9ec5-\
ec8c7b72b6e5"],

Cell[BoxData[
 FormBox[
  StyleBox[
   RowBox[{
    RowBox[{
     RowBox[{
      StyleBox["F",
       FontSlant->"Italic"], "(", 
      StyleBox["v",
       FontSlant->"Italic"], ")"}], 
     RowBox[{"\[DifferentialD]", "v"}]}], "=", 
    RowBox[{
     RowBox[{
      RowBox[{"\[CapitalOmega]", "(", 
       RowBox[{
        SubscriptBox["v", "x"], ",", 
        SubscriptBox["v", "y"], ",", 
        SubscriptBox["v", "z"]}], ")"}], 
      RowBox[{"\[DifferentialD]", 
       SubscriptBox["v", "x"]}], 
      RowBox[{"\[DifferentialD]", 
       SubscriptBox["v", "y"]}], 
      RowBox[{"\[DifferentialD]", 
       SubscriptBox["v", "z"]}]}], "=", 
     RowBox[{
      RowBox[{
       StyleBox["f",
        FontSlant->"Italic"], "(", 
       StyleBox[
        SubscriptBox["v", "x"],
        FontSlant->"Italic"], ")"}], 
      RowBox[{
       StyleBox["f",
        FontSlant->"Italic"], "(", 
       StyleBox[
        SubscriptBox["v", "y"],
        FontSlant->"Italic"], ")"}], 
      RowBox[{
       StyleBox["f",
        FontSlant->"Italic"], "(", 
       StyleBox[
        SubscriptBox["v", "z"],
        FontSlant->"Italic"], ")"}], 
      RowBox[{"\[DifferentialD]", 
       SubscriptBox["v", "x"]}], 
      RowBox[{"\[DifferentialD]", 
       SubscriptBox["v", "y"]}], 
      RowBox[{"\[DifferentialD]", 
       SubscriptBox["v", "z"]}]}]}]}],
   FontFamily->"Consolas",
   FontWeight->"Normal"], TraditionalForm]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.9214868678665485`*^9, 3.921486915370578*^9}, {
  3.921487004700838*^9, 
  3.921487017141794*^9}},ExpressionUUID->"58e9e18c-303b-4e7b-b3b4-\
365fcd0c183f"],

Cell[TextData[{
 "We already found an expression for ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    StyleBox["f",
     FontSlant->"Italic"], "(", 
    StyleBox[
     SubscriptBox["v", "i"],
     FontSlant->"Italic"], ")"}], TraditionalForm]],
  CellChangeTimes->{{3.9214868678665485`*^9, 3.921486915370578*^9}, {
   3.921487004700838*^9, 3.921487017141794*^9}},ExpressionUUID->
  "a3c701db-2a80-48a2-bec0-24d88ef9817c"],
 " in the last section, so we have"
}], "Text",
 CellChangeTimes->{{3.9214870200212755`*^9, 
  3.9214870481566143`*^9}},ExpressionUUID->"44d56cc0-a71f-48ca-9e88-\
495539006161"],

Cell[BoxData[
 FormBox[
  StyleBox[
   RowBox[{
    RowBox[{
     RowBox[{
      StyleBox["F",
       FontSlant->"Italic"], "(", 
      StyleBox["v",
       FontSlant->"Italic"], ")"}], 
     RowBox[{"\[DifferentialD]", "v"}]}], "=", 
    RowBox[{
     SuperscriptBox[
      RowBox[{"(", 
       FractionBox[
        StyleBox["m",
         FontSlant->"Italic"], 
        RowBox[{"2", "\[Pi]", " ", 
         SubscriptBox[
          StyleBox["k",
           FontSlant->"Italic"], 
          StyleBox["B",
           FontSlant->"Italic"]], 
         StyleBox["T",
          FontSlant->"Italic"]}]], ")"}], 
      RowBox[{"3", "/", "2"}]], 
     SuperscriptBox["\[ExponentialE]", 
      RowBox[{
       RowBox[{"-", 
        FractionBox[
         StyleBox["m",
          FontSlant->"Italic"], 
         RowBox[{"2", 
          SubscriptBox[
           StyleBox["k",
            FontSlant->"Italic"], 
           StyleBox["B",
            FontSlant->"Italic"]], 
          StyleBox["T",
           FontSlant->"Italic"]}]]}], 
       RowBox[{"(", 
        RowBox[{
         SubsuperscriptBox[
          StyleBox["v",
           FontSlant->"Italic"], 
          StyleBox["x",
           FontSlant->"Italic"], "2"], "+", 
         SubsuperscriptBox[
          StyleBox["v",
           FontSlant->"Italic"], 
          StyleBox["y",
           FontSlant->"Italic"], "2"], "+", 
         SubsuperscriptBox[
          StyleBox["v",
           FontSlant->"Italic"], 
          StyleBox["z",
           FontSlant->"Italic"], "2"]}], ")"}]}]], 
     RowBox[{"\[DifferentialD]", 
      SubscriptBox["v", "x"]}], 
     RowBox[{"\[DifferentialD]", 
      SubscriptBox["v", "y"]}], 
     RowBox[{"\[DifferentialD]", 
      SubscriptBox["v", "z"]}]}]}],
   FontFamily->"Consolas",
   FontWeight->"Normal"], TraditionalForm]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.9214868678665485`*^9, 3.921486915370578*^9}, {
   3.921487004700838*^9, 3.921487017141794*^9}, {3.92148708655623*^9, 
   3.9214871164217806`*^9}, {3.921487148041726*^9, 3.921487166400375*^9}, 
   3.921487283917535*^9, {3.9214875882284756`*^9, 
   3.9214875909493403`*^9}},ExpressionUUID->"b516632e-c5d3-437e-9c26-\
682dadb26df5"],

Cell[TextData[{
 "Now we want to convert from coordinates ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["v", "x"], TraditionalForm]],
  CellChangeTimes->{{3.9214868678665485`*^9, 3.921486915370578*^9}, {
   3.921487004700838*^9, 3.921487017141794*^9}, {3.92148708655623*^9, 
   3.9214871164217806`*^9}, {3.921487148041726*^9, 3.921487166400375*^9}},
  ExpressionUUID->"c14f9a9b-d89b-4d01-bb17-c4b5877cfade"],
 ", ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["v", "y"], TraditionalForm]],
  CellChangeTimes->{{3.9214868678665485`*^9, 3.921486915370578*^9}, {
   3.921487004700838*^9, 3.921487017141794*^9}, {3.92148708655623*^9, 
   3.9214871164217806`*^9}, {3.921487148041726*^9, 3.921487166400375*^9}},
  ExpressionUUID->"09c9ac84-a7be-4220-b402-0ff2a7632fba"],
 ", and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["v", "z"], TraditionalForm]],
  CellChangeTimes->{{3.9214868678665485`*^9, 3.921486915370578*^9}, {
   3.921487004700838*^9, 3.921487017141794*^9}, {3.92148708655623*^9, 
   3.9214871164217806`*^9}, {3.921487148041726*^9, 3.921487166400375*^9}},
  ExpressionUUID->"cb66471a-9252-45fb-be9b-1154c585a42f"],
 " to a speed coordinate ",
 StyleBox["v",
  FontSlant->"Italic"],
 ". We can use ",
 StyleBox[" ",
  FontSlant->"Italic"]
}], "Text",
 CellChangeTimes->{{3.9214872521146765`*^9, 
  3.921487302418676*^9}},ExpressionUUID->"0c1d2996-e0c1-4515-9e9a-\
4f3c8a1e4588"],

Cell[BoxData[
 FormBox[
  RowBox[{
   SuperscriptBox["v", "2"], "=", 
   RowBox[{
    SubsuperscriptBox["v", "x", "2"], "+", 
    SubsuperscriptBox["v", "y", "2"], "+", 
    SubsuperscriptBox["v", "z", "2"]}]}], 
  TraditionalForm]], "DisplayFormulaNumbered",
 InitializationCell->True,
 CellChangeTimes->{{3.9212505192469416`*^9, 3.921250534863843*^9}, {
   3.9212507356598735`*^9, 3.9212507676410656`*^9}, {3.9212508673633738`*^9, 
   3.9212509608799176`*^9}, {3.921251060924367*^9, 3.9212511124818687`*^9}, {
   3.9212511504673223`*^9, 3.921251158794492*^9}, {3.9212512029019794`*^9, 
   3.9212512716665497`*^9}, {3.921251348153563*^9, 3.921251397670518*^9}, {
   3.921328606806888*^9, 3.921328654543107*^9}, 3.9213289776454625`*^9, {
   3.921329302517523*^9, 3.921329306297614*^9}, {3.921329571452891*^9, 
   3.921329578612625*^9}, 3.9213296317732787`*^9, {3.9213298724546156`*^9, 
   3.9213298798186703`*^9}, {3.9213300349738455`*^9, 
   3.9213300480959187`*^9}, {3.921330546631791*^9, 3.9213305595573583`*^9}, 
   3.9213306578039947`*^9, 3.92133077659169*^9, {3.921330821603032*^9, 
   3.921330874812805*^9}, {3.9214238904787655`*^9, 3.921423917414671*^9}, {
   3.9214242444723015`*^9, 3.921424280314675*^9}, {3.9214243115840964`*^9, 
   3.921424385815443*^9}, {3.92148733780931*^9, 3.9214873546367817`*^9}, {
   3.9214877705425777`*^9, 
   3.9214877772510476`*^9}},ExpressionUUID->"0d7ab96d-d542-4d53-93d1-\
9c051d13e9c7"],

Cell[TextData[{
 "to convert the velocity coordinates. We also need to convert the volume \
element ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"\[DifferentialD]", 
    StyleBox[
     SubscriptBox["v", "x"],
     FontSlant->"Italic"]}], 
   RowBox[{"\[DifferentialD]", 
    StyleBox[
     SubscriptBox["v", "y"],
     FontSlant->"Italic"]}], 
   RowBox[{"\[DifferentialD]", 
    StyleBox[
     SubscriptBox["v", "z"],
     FontSlant->"Italic"]}]}]],
  CellChangeTimes->{{3.9214868678665485`*^9, 3.921486915370578*^9}, {
    3.921487004700838*^9, 3.921487017141794*^9}, {3.92148708655623*^9, 
    3.9214871164217806`*^9}, {3.921487148041726*^9, 3.921487166400375*^9}, 
    3.921487283917535*^9},ExpressionUUID->
  "0e935089-06fd-4302-9b56-2d4783964e34"],
 ". To do so, we can use the velocity spherical coordinates conversion"
}], "Text",
 CellChangeTimes->{{3.9214873571203184`*^9, 3.9214873873441324`*^9}, {
  3.921487513668589*^9, 3.9214875518625517`*^9}, {3.921487619596195*^9, 
  3.92148762054373*^9}, {3.921487705769411*^9, 3.9214877128959723`*^9}, {
  3.9214877855776534`*^9, 
  3.9214877906720495`*^9}},ExpressionUUID->"4f5b520e-3a32-4748-9e99-\
e8863a3e7a99"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"\[DifferentialD]", 
    StyleBox[
     SubscriptBox["v", "x"],
     FontSlant->"Italic"]}], 
   RowBox[{"\[DifferentialD]", 
    StyleBox[
     SubscriptBox["v", "y"],
     FontSlant->"Italic"]}], 
   RowBox[{"\[DifferentialD]", 
    StyleBox[
     SubscriptBox["v", "z"],
     FontSlant->"Italic"]}]}], 
  StyleBox["=",
   FontSlant->"Plain"], 
  RowBox[{
   StyleBox["4",
    FontSlant->"Plain"], 
   SuperscriptBox[
    StyleBox[
     RowBox[{"\[Pi]", 
      StyleBox["v",
       FontSlant->"Italic"]}]], "2"], 
   RowBox[{"\[DifferentialD]", 
    StyleBox["v",
     FontSlant->"Italic"]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.921487571761608*^9, 
  3.9214876015886374`*^9}},ExpressionUUID->"b5171999-1867-4e2c-aebd-\
ba6ec1ec19b2"],

Cell["\<\
which allows us to directly convert the velocity components (direction \
dependence) to a speed (no direction dependence). We then obtain\
\>", "Text",
 CellChangeTimes->{{3.9214876231490707`*^9, 3.9214876890794106`*^9}, {
  3.9214877252996407`*^9, 
  3.921487726949129*^9}},ExpressionUUID->"b8d6e42b-a2e7-4879-9be3-\
50d43db4258e"],

Cell[BoxData[
 FormBox[
  StyleBox[
   RowBox[{
    RowBox[{
     RowBox[{
      StyleBox["F",
       FontSlant->"Italic"], "(", 
      StyleBox["v",
       FontSlant->"Italic"], ")"}], 
     RowBox[{"\[DifferentialD]", "v"}]}], "=", 
    RowBox[{
     StyleBox["4",
      FontSlant->"Plain"], "\[Pi]", " ", 
     SuperscriptBox[
      RowBox[{"(", 
       FractionBox[
        StyleBox["m",
         FontSlant->"Italic"], 
        RowBox[{"2", "\[Pi]", " ", 
         SubscriptBox[
          StyleBox["k",
           FontSlant->"Italic"], 
          StyleBox["B",
           FontSlant->"Italic"]], 
         StyleBox["T",
          FontSlant->"Italic"]}]], ")"}], 
      RowBox[{"3", "/", "2"}]], 
     SuperscriptBox[
      StyleBox["v",
       FontSlant->"Italic"], "2"], 
     SuperscriptBox["\[ExponentialE]", 
      RowBox[{
       RowBox[{"-", 
        FractionBox[
         StyleBox["m",
          FontSlant->"Italic"], 
         RowBox[{"2", 
          SubscriptBox[
           StyleBox["k",
            FontSlant->"Italic"], 
           StyleBox["B",
            FontSlant->"Italic"]], 
          StyleBox["T",
           FontSlant->"Italic"]}]]}], 
       SuperscriptBox[
        StyleBox["v",
         FontSlant->"Italic"], "2"]}]], 
     RowBox[{"\[DifferentialD]", 
      StyleBox["v",
       FontSlant->"Italic"]}]}]}],
   FontFamily->"Consolas",
   FontWeight->"Normal"], TraditionalForm]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.9214868678665485`*^9, 3.921486915370578*^9}, {
   3.921487004700838*^9, 3.921487017141794*^9}, {3.92148708655623*^9, 
   3.9214871164217806`*^9}, {3.921487148041726*^9, 3.921487166400375*^9}, 
   3.921487283917535*^9, {3.9214875882284756`*^9, 3.9214875909493403`*^9}, {
   3.9214877382503366`*^9, 3.9214877583701577`*^9}, {3.9214878425725827`*^9, 
   3.921487870455839*^9}},ExpressionUUID->"29501323-33c9-4812-bf3f-\
f0a98dabf6ba"],

Cell[TextData[{
 "which is the Maxwell-Boltzmann distribution of speeds. This distribution \
gives the probability of a particle in the gas having a speed in range ",
 Cell[BoxData[
  FormBox[
   RowBox[{"v", "+", 
    RowBox[{"\[DifferentialD]", "v"}]}], TraditionalForm]],ExpressionUUID->
  "16e03ade-bf37-4dbe-ab17-336bcc025bd9"],
 ". We can also write this equation in the form of molar mass and gas \
constant rather than particle mass and Boltzmann constant,"
}], "Text",
 CellChangeTimes->{{3.9214879183803325`*^9, 3.9214879262789297`*^9}, {
  3.921487966663384*^9, 
  3.9214880655965786`*^9}},ExpressionUUID->"e372ea3d-6069-4f5f-b6cd-\
e4ac7e0fae6d"],

Cell[BoxData[
 FormBox[
  StyleBox[
   RowBox[{
    RowBox[{
     RowBox[{
      StyleBox["F",
       FontSlant->"Italic"], "(", 
      StyleBox["v",
       FontSlant->"Italic"], ")"}], 
     RowBox[{"\[DifferentialD]", "v"}]}], "=", 
    RowBox[{
     StyleBox["4",
      FontSlant->"Plain"], "\[Pi]", " ", 
     SuperscriptBox[
      RowBox[{"(", 
       FractionBox["M", 
        RowBox[{"2", "\[Pi]", " ", 
         StyleBox[
          RowBox[{"R", 
           StyleBox["T",
            FontSlant->"Italic"]}]]}]], ")"}], 
      RowBox[{"3", "/", "2"}]], 
     SuperscriptBox[
      StyleBox["v",
       FontSlant->"Italic"], "2"], 
     SuperscriptBox["\[ExponentialE]", 
      RowBox[{
       RowBox[{"-", 
        FractionBox[
         StyleBox["M",
          FontSlant->"Italic"], 
         RowBox[{"2", 
          StyleBox[
           RowBox[{"R", 
            StyleBox["T",
             FontSlant->"Italic"]}]]}]]}], 
       SuperscriptBox[
        StyleBox["v",
         FontSlant->"Italic"], "2"]}]], 
     RowBox[{"\[DifferentialD]", 
      StyleBox["v",
       FontSlant->"Italic"]}]}]}],
   FontFamily->"Consolas",
   FontWeight->"Normal"], TraditionalForm]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.9214868678665485`*^9, 3.921486915370578*^9}, {
