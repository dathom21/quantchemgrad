        StyleBox["B",
         FontSlant->"Italic"]]}]]}], "\[RightAngleBracket]"}], "=", 
   RowBox[{"\[Integral]", 
    RowBox[{
     SubsuperscriptBox["\[Phi]", 
      RowBox[{"1", 
       SubscriptBox[
        StyleBox["s",
         FontSlant->"Italic"], 
        StyleBox["B",
         FontSlant->"Italic"]]}], "\[Star]"], 
     SubscriptBox["\[Phi]", 
      RowBox[{"1", 
       SubscriptBox[
        StyleBox["s",
         FontSlant->"Italic"], 
        StyleBox["A",
         FontSlant->"Italic"]]}]], 
     RowBox[{"\[DifferentialD]", "\[Tau]"}]}]}]}]}]], "DisplayFormulaNumbered",
