Cell[TextData[{
 StyleBox["Figure 11.7",
  FontWeight->"Bold"],
 ". Molecular orbitals of ",
 StyleBox["cis",
  FontSlant->"Italic"],
 "-1,3,-butadiene calculated at the HF/6-31G* level of theory in Spartan \
\[OpenCurlyQuote]04. Wikimedia, Benjah-bmm27, Public Domain, \
https://commons.wikimedia.org/wiki/File:Butadiene-pi-MOs-Spartan-3D-balls.png"
}], "Affiliation",
 CellChangeTimes->CompressedData["
1:eJxTTMoPSmViYGCQBGIQPeNH5qbXiW8cy6t7doDoiRfCxd8A6ZBDtWA6NlRg
2Ucgzeepug5EC2S27BZIAtJry/eD6DMqRj/fA+kjLKbMH4B0E3PHSv6UN44X
l04G08y2gYYPM944ShTl2YDoml0/fqlmvnFMuGTBogak81nqs65mvXFU0zIp
AtFH7qh/AdEb9z74AaJVbh3gvwakt+w6AqZzXlnFgGgvNnswbbTCOBlEJ3Ew
5YNoj9nzVW8B6YvcIZog2oz9/TqN7DeOjC+U1oPoA+phW0D0o2KWAyBaZ611
nQ6QXv2ssQVEP2+7fRBETyprPgmiG4qOeOkCaSuNE2D6xYZvoSA66AlLPIiW
ObnCrwhI632WCgTRbBdOmswB0ourDO1A9I4WBlcQfc1C2QtEp6xVtVwGpFdk
LXQA0Q8mP7t4JuKtY4PcKzANANI9ybQ=
  "],ExpressionUUID->"0c6c8aa6-2d47-4d5e-9c80-3b5291ddf8f2"],

Cell["\<\
Note that the molecular orbitals are not confined to a single double bond but \
rather are delocalized across the entire molecule. This delocalization also \
produces an energetic stabilization, which can be calculated as the \
difference between the energies of the H\[UDoubleDot]ckel MOs and localized \
double bond energies, given by the energies calculated for ethene multiplied \
by the number of double bonds. For the case of two localized double bonds, \
this would be\
\>", "Text",
 CellChangeTimes->{{3.8145355839542904`*^9, 3.8145356147026505`*^9}, {
  3.814535694947399*^9, 3.8145357459586*^9}, {3.8145358276284103`*^9, 
  3.814535857637878*^9}, {3.814535890991727*^9, 
  3.814535905902293*^9}},ExpressionUUID->"f937faac-a594-4874-9120-\
b1d09337bc15"],

Cell[BoxData[
 RowBox[{
  RowBox[{"2", "\[Times]", 
   SubscriptBox[
    StyleBox["E",
     FontSlant->"Italic"], 
    SubscriptBox["\[Pi]", "ethene"]]}], "=", 
  RowBox[{
   RowBox[{"2", "[", 
    RowBox[{
     RowBox[{"2", "\[Alpha]"}], "+", 
     RowBox[{"2", "\[Beta]"}]}], "]"}], "=", 
   RowBox[{
    RowBox[{"4", "\[Alpha]"}], "+", 
    RowBox[{"4", "\[Beta]"}]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.814535914316809*^9, 3.8145359498976755`*^9}, {
  3.8145360756032934`*^9, 
  3.814536083226504*^9}},ExpressionUUID->"579fd57b-3d91-4b58-a131-\
844bc1fefcea"],

Cell["\<\
where have taken twice the sum of the energy of the two electrons in the \
bonding orbital of ethene. By a similar approach, the energy of the electrons \
in butadiene is then\
\>", "Text",
 CellChangeTimes->{{3.814535952896762*^9, 3.814535953291915*^9}, {
  3.8145360082808857`*^9, 
  3.8145360575334187`*^9}},ExpressionUUID->"2b2d6552-9d65-4d93-94f8-\
99e11d7cfcd8"],

Cell[BoxData[
 RowBox[{
  SubscriptBox[
   StyleBox["E",
    FontSlant->"Italic"], 
   SubscriptBox["\[Pi]", "butadiene"]], " ", "=", 
  RowBox[{
   RowBox[{
    RowBox[{"2", "[", " ", 
     RowBox[{"\[Alpha]", "+", 
      RowBox[{
       FractionBox["1", "2"], " ", "\[Beta]", 
       RowBox[{"(", 
        RowBox[{"1", "+", 
         SqrtBox["5"]}], " ", ")"}]}]}], "]"}], "+", 
    RowBox[{"2", "[", " ", 
     RowBox[{"\[Alpha]", "-", 
      RowBox[{
       FractionBox["1", "2"], "\[Beta]", 
       RowBox[{"(", " ", 
        RowBox[{"1", "-", 
         SqrtBox["5"]}], " ", ")"}]}]}], "]"}]}], "=", 
   RowBox[{
    RowBox[{"4", "\[Alpha]"}], "+", 
    RowBox[{"4.47", "\[Beta]"}]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.811593312893673*^9, 3.8115933831661987`*^9}, {
   3.811593458953679*^9, 3.8115934974178753`*^9}, {3.8115936143121653`*^9, 
   3.811593715195953*^9}, {3.811594208013258*^9, 3.811594210677987*^9}, {
   3.811594342816991*^9, 3.8115943434093456`*^9}, {3.811594623901507*^9, 
   3.811594670874273*^9}, {3.8115948564704037`*^9, 3.8115948589878416`*^9}, {
   3.8115949257053156`*^9, 3.811594926820971*^9}, {3.8118594909971013`*^9, 
   3.8118595100044374`*^9}, {3.811861225074663*^9, 3.8118612380287175`*^9}, {
   3.811861337070103*^9, 3.811861354268696*^9}, {3.8118616010571704`*^9, 
   3.8118616623290653`*^9}, {3.811861807987365*^9, 3.811861813069888*^9}, {
   3.811862169852538*^9, 3.8118621746446657`*^9}, {3.811862556259386*^9, 
   3.811862623167489*^9}, 3.8118626599418736`*^9, {3.8118627514300547`*^9, 
   3.8118627593819437`*^9}, {3.8118632270630903`*^9, 3.811863326828313*^9}, 
   3.8118634029600096`*^9, {3.8118635700628643`*^9, 3.811863574143609*^9}, {
   3.8118654741595607`*^9, 3.8118655915905437`*^9}, {3.8118658693746243`*^9, 
   3.811865896052101*^9}, 3.8118684990918617`*^9, 3.814431542152564*^9, {
   3.8145142359604063`*^9, 3.8145142464401007`*^9}, {3.81452063861008*^9, 
   3.814520663233509*^9}, {3.814536072246044*^9, 3.814536111908013*^9}, {
   3.8145365031739674`*^9, 3.814536513564253*^9}, {3.8145365744735436`*^9, 
   3.814536583785299*^9}, {3.814536639181433*^9, 
   3.8145366767950068`*^9}},ExpressionUUID->"0da0f9f7-1b98-402d-9db1-\
12d181a0c90d"],

Cell["\<\
so the delocalization energy is on the order of 0.47\[Beta]. This value \
represents the approximate magnitude of the additional stabilization afforded \
by the conjugated double bonds.\
\>", "Text",
 CellChangeTimes->{{3.814536679617342*^9, 
  3.814536738947582*^9}},ExpressionUUID->"9f678690-7cbe-46c1-9282-\
a0a6d284ef16"],

Cell["\<\
This approach can also be applied to cyclic polyenes (aromatic molecules) \
such as benzene, which has a delocalization energy of 2\[Beta].\
\>", "Text",
 CellChangeTimes->{{3.814536760991884*^9, 3.8145368278630614`*^9}, 
   3.8145369430727386`*^9},ExpressionUUID->"137f7c36-d9df-4f0f-8279-\
86ce64e58870"]
}, Open  ]]
}, Open  ]]
}, Open  ]]
},
