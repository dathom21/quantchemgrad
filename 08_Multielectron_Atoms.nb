59b50360a533"],

Cell[BoxData[
 RowBox[{
  SubscriptBox[
   StyleBox["E",
    FontSlant->"Italic"], "\[Phi]"], "=", 
  RowBox[{
   RowBox[{
    FractionBox[
     RowBox[{"\[LeftAngleBracket]", 
      RowBox[{"\[Phi]", "|", 
       OverscriptBox[
        StyleBox["H",
         FontSlant->"Italic"], "^"], "|", "\[Phi]"}], 
      "\[RightAngleBracket]"}], 
     RowBox[{
      RowBox[{"\[LeftAngleBracket]", 
       RowBox[{"\[Phi]", "|", "\[Phi]"}], "\[RightAngleBracket]"}], " ", 
      " "}]], "                                           ", 
    StyleBox[
     SubscriptBox[
      StyleBox["E",
       FontSlant->"Italic"], 
      StyleBox["\[Phi]",
       FontSlant->"Plain"]],
     FontSlant->"Italic"]}], "=", 
   FractionBox[
    RowBox[{"\[Integral]", 
     RowBox[{
      SuperscriptBox["\[Phi]", "\[Star]"], " ", 
      OverscriptBox[
       StyleBox["H",
        FontSlant->"Italic"], "^"], "\[Phi]", " ", "d\[Tau]"}]}], 
    RowBox[{"\[Integral]", 
     RowBox[{
      SuperscriptBox["\[Phi]", "\[Star]"], "\[Phi]", " ", 
      "d\[Tau]"}]}]]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.811593312893673*^9, 3.8115933831661987`*^9}, {
