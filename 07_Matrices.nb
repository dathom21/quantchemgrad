Cell[TextData[{
 "Now, the bra-ket notation can be utilized to succinctly represent many \
operations that are ubiquitous in quantum mechanics. To illustrate some of \
these situations, let\[CloseCurlyQuote]s set up an example. Take two \
wavefunctions  ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[CapitalPsi]", "a"], TraditionalForm]],
  FontWeight->"Bold",ExpressionUUID->"88917239-b565-4e7b-b761-808ffe6da2f8"],
 " and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[CapitalPsi]", "b"], TraditionalForm]],
  FontWeight->"Bold",ExpressionUUID->"7babb6a2-83aa-4c93-a336-fb62fe3a45dd"],
 ". Switching the notation of equation (83) to bra-ket notation, we write"
}], "Text",
 CellChangeTimes->{{3.8113289647442923`*^9, 
  3.8113291968832374`*^9}},ExpressionUUID->"1ebdf8b2-ba78-4e8f-af96-\
0b0a293635af"],

Cell[BoxData[
 RowBox[{
  RowBox[{"\[LeftAngleBracket]", 
   RowBox[{
    StyleBox[
     SubscriptBox[
      StyleBox["\[CapitalPsi]",
       FontWeight->"Bold"], "a"],
     FontWeight->"Bold"], "|", 
    StyleBox[
     SubscriptBox[
      StyleBox["\[CapitalPsi]",
       FontWeight->"Bold"], "b"],
     FontWeight->"Bold"]}], "\[RightAngleBracket]"}], "=", 
  RowBox[{
   RowBox[{"\[LeftAngleBracket]", 
    RowBox[{
     StyleBox["a",
      FontWeight->"Bold"], "|", 
     StyleBox["b",
      FontWeight->"Bold"]}], "\[RightAngleBracket]"}], "=", 
   RowBox[{
    RowBox[{
     SuperscriptBox[
      StyleBox["a",
       FontWeight->"Bold",
       FontSlant->"Plain"], 
      StyleBox["H",
       FontWeight->"Bold"]], 
     StyleBox["b",
      FontWeight->"Bold"]}], "=", 
    RowBox[{
     RowBox[{"(", "\[NoBreak]", 
      RowBox[{GridBox[{
         {
          SubsuperscriptBox[
           StyleBox["a",
            FontSlant->"Italic"], "1", "\[Star]"], 
          SubsuperscriptBox[
           StyleBox["a",
            FontSlant->"Italic"], "2", "\[Star]"]}
        }], GridBox[{
         {"...", 
          SubsuperscriptBox[
           StyleBox["a",
            FontSlant->"Italic"], 
           StyleBox["n",
            FontSlant->"Italic"], "\[Star]"]}
        }]}], ")"}], 
     RowBox[{"(", "\[NoBreak]", GridBox[{
        {
         SubscriptBox[
          StyleBox["b",
           FontSlant->"Italic"], "1"]},
        {
         SubscriptBox[
          StyleBox["b",
           FontSlant->"Italic"], "2"]},
        {GridBox[{
           {"..."},
           {
            SubscriptBox[
             StyleBox["b",
              FontSlant->"Italic"], 
             StyleBox["n",
              FontSlant->"Italic"]]}
          }]}
       }], "\[NoBreak]", ")"}]}]}]}]}]], "DisplayFormulaNumbered",
