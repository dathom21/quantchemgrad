      RowBox[{
       SuperscriptBox["\[ExponentialE]", "\[ImaginaryI]\[Phi]"], "\[Psi]", 
       RowBox[{"(", 
        RowBox[{
         SubscriptBox[
          StyleBox["r",
           FontWeight->"Bold",
           FontSlant->"Italic"], "2"], ",", 
         SubscriptBox[
          StyleBox["r",
