   3.8106611896874313`*^9}, {3.810715242072402*^9, 
   3.810715275027593*^9}},ExpressionUUID->"e7500f41-a0c6-4302-933e-\
ada0829ca500"],

Cell["Because", "Text",
 CellChangeTimes->{{3.810715279059108*^9, 3.8107152805773296`*^9}, {
  3.873792251731863*^9, 
  3.8737922525438895`*^9}},ExpressionUUID->"17baab74-81fe-416e-8a0b-\
5e668f74d58d"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   SubsuperscriptBox[
    OverscriptBox[
     StyleBox["L",
      FontSlant->"Italic"], "^"], 
    StyleBox["z",
     FontSlant->"Italic"], "2"], 
   FormBox[
    RowBox[{
     SubsuperscriptBox[
      StyleBox["Y",
       FontSlant->"Italic"], 
      StyleBox["l",
       FontSlant->"Italic"], 
      SubscriptBox[
       StyleBox["m",
        FontSlant->"Italic"], "l"]], "(", 
     RowBox[{"\[Theta]", ",", "\[Phi]"}], ")"}],
    TraditionalForm]}], "=", 
  RowBox[{
   SubsuperscriptBox[
    StyleBox["m",
     FontSlant->"Italic"], 
    StyleBox["l",
     FontSlant->"Italic"], "2"], 
   StyleBox[" ",
    FontSlant->"Italic"], 
   SuperscriptBox["\[HBar]", "2"], " ", 
   SubsuperscriptBox[
    StyleBox["Y",
     FontSlant->"Italic"], 
