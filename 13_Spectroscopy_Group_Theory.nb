Cell[CellGroupData[{

Cell["Interaction with a Sinusoidal Potential", "Subsection",
 CellChangeTimes->{{3.8154822934584017`*^9, 
  3.8154823054814296`*^9}},ExpressionUUID->"ff9e90ec-17a2-41c2-8161-\
90f30254bce5"],

Cell["\<\
Let us now examine what happens to the weighting coefficients upon \
interaction with a sinusoidal potential (for example, light). Let us write \
the potential as\
\>", "Text",
 CellChangeTimes->{{3.815482307448002*^9, 3.8154823188256435`*^9}, {
  3.8154823828918304`*^9, 
  3.815482434282118*^9}},ExpressionUUID->"218b12bd-84f0-4052-a2f5-\
69387bc06d8f"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   StyleBox["V",
    FontSlant->"Italic"], 
   RowBox[{"(", 
    StyleBox[
     RowBox[{
      StyleBox["r",
       FontWeight->"Bold"], ",", "t"}],
     FontSlant->"Italic"], ")"}]}], "=", 
  RowBox[{
   RowBox[{"2", 
    StyleBox["V",
     FontSlant->"Italic"], 
    RowBox[{
     StyleBox["(",
      FontSlant->"Italic"], 
     StyleBox["r",
      FontWeight->"Bold",
      FontSlant->"Italic"], ")"}], "cos", 
    RowBox[{"(", 
     StyleBox[
      RowBox[{"\[Omega]", 
       StyleBox["t",
        FontSlant->"Italic"]}]], ")"}]}], "=", 
   RowBox[{
    StyleBox["V",
     FontSlant->"Italic"], 
    RowBox[{
     StyleBox["(",
