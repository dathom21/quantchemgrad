    RowBox[{"-", "1"}]], 
   StyleBox["H",
    FontWeight->"Bold"], "\[NoBreak] ", 
   StyleBox["a",
    FontWeight->"Bold"]}], " ", "=", 
  RowBox[{
   SubscriptBox[
    StyleBox["E",
     FontSlant->"Italic"], "\[CapitalPhi]"], " ", 
   StyleBox["a",
