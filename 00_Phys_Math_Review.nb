Cell[TextData[{
 StyleBox["Figure 0.1",
  FontWeight->"Bold"],
 ". Simple pendulum model. Adapted from Prof. Vladimir Dobrushkin, Brown \
University, \
https://www.cfm.brown.edu/people/dobrush/am33/Mathematica/ch4/simple.html"
}], "Affiliation",
 CellChangeTimes->{{3.809435027311596*^9, 3.8094350763900714`*^9}, {
  3.80943583474421*^9, 3.8094358359299717`*^9}, {3.8094472165104203`*^9, 
  3.809447281165168*^9}, {3.809510876137825*^9, 3.809510907739876*^9}, {
  3.809968073566992*^9, 3.8099681536568317`*^9}, {3.810557260250428*^9, 
  3.8105572606139913`*^9}, {3.8130835305386977`*^9, 3.8130836194514275`*^9}, {
  3.813224407772764*^9, 3.8132244817756805`*^9}, {3.8394266250053024`*^9, 
  3.839426636135662*^9}, {3.8394271229755535`*^9, 3.8394271464856167`*^9}, {
  3.8394271859998655`*^9, 3.8394272181213303`*^9}, {3.8395089519189353`*^9, 
  3.839508973029978*^9}, {3.8395092661850324`*^9, 3.839509281138036*^9}, {
  3.9144069299792747`*^9, 3.914406931202832*^9}, {3.914411522642681*^9, 
  3.914411560769556*^9}},ExpressionUUID->"dd523067-2231-4c7e-8e49-\
5824cbb17edf"],

Cell[TextData[{
 "In Newtonian mechanics, we wish to describe the system based on the forces \
acting on it, so we need to identify those forces. Neglecting any damping of \
the oscillation from friction, the only forces are gravity ",
 StyleBox["mg",
  FontSlant->"Italic"],
 ", which points down on the mass at all points, and tension ",
 StyleBox["T",
  FontSlant->"Italic"],
 ", which points along the string from the mass to the origin. According to \
Newton\[CloseCurlyQuote]s second law, we can then sum up those forces and set \
them equal to ",
 StyleBox["ma",
  FontSlant->"Italic"],
 ". We will find that the net force along the direction of travel will be the \
component of ",
 StyleBox["mg",
  FontSlant->"Italic"],
 " that is perpendicular to ",
 StyleBox["T ",
  FontSlant->"Italic"],
 ". As the pendulum moves, the magnitude of this component changes, but we \
can define this using a bit of geometry to be"
}], "Text",
 CellChangeTimes->{{3.9144105049549184`*^9, 3.9144105803343153`*^9}, {
  3.9144106728021746`*^9, 3.9144107306772823`*^9}, {3.9144115912475376`*^9, 
  3.9144117415559235`*^9}, {3.9339476875730553`*^9, 
  3.9339477538099785`*^9}},ExpressionUUID->"8858c871-0a9f-4454-8c5b-\
993bfd8be3f6"],

Cell[BoxData[
 RowBox[{
  RowBox[{"-", 
   StyleBox["m",
    FontSlant->"Italic"]}], 
  StyleBox[" ",
   FontSlant->"Italic"], 
  StyleBox["g",
   FontSlant->"Italic"], 
  StyleBox[" ",
   FontSlant->"Italic"], "sin", 
  RowBox[{"(", "\[Theta]", ")"}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.9144118221394973`*^9, 3.914411829555718*^9}, {
  3.9144118910717535`*^9, 
  3.914411892912548*^9}},ExpressionUUID->"5620bf47-8a9e-4d4c-9ac9-\
5de236d14f64"],

Cell[TextData[{
 "where the negative sign indicates that this force points in the opposite \
direction of displacement. Then, because this force is only pointing in the",
 " direction of the arc, we can write the acceleration to only be in the ",
 StyleBox["s",
  FontSlant->"Italic"],
 " direction,"
}], "Text",
 CellChangeTimes->{{3.914411862766618*^9, 3.9144118852540903`*^9}, {
  3.91441197066595*^9, 3.914411996458067*^9}, {3.914412517044325*^9, 
  3.914412533348916*^9}},ExpressionUUID->"95d1e2a7-af9f-4afe-8cb3-\
06a81ec45ee0"],

Cell[BoxData[
 RowBox[{
  StyleBox["F",
   FontSlant->"Italic"], 
  StyleBox["=",
   FontSlant->"Plain"], 
  RowBox[{
   StyleBox["ma",
    FontSlant->"Italic"], 
   StyleBox["=",
    FontSlant->"Plain"], 
   RowBox[{
    StyleBox["m",
     FontSlant->"Italic"], 
    FractionBox[
     RowBox[{
      SuperscriptBox["\[DifferentialD]", "2"], 
      StyleBox["s",
       FontSlant->"Italic"]}], 
     RowBox[{"\[DifferentialD]", 
      SuperscriptBox[
       StyleBox["t",
        FontSlant->"Italic"], "2"]}]]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.9144118221394973`*^9, 3.914411829555718*^9}, {
