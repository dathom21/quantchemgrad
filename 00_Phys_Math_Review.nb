  3.914414994963703*^9}, {3.9144151599124594`*^9, 3.9144152483186803`*^9}, {
  3.914415371158986*^9, 
  3.9144154343682675`*^9}},ExpressionUUID->"ce6cbc40-50cf-4961-8857-\
74810b85c7a6"],

Cell["(see Figure 0.1)", "Text",
