   3.8132340269582367`*^9, 3.813234078465289*^9}, {3.813234167608451*^9, 
   3.8132341770737553`*^9}},ExpressionUUID->
  "c430b854-41fa-49e2-8f83-dd9285f63ab6"],
 ", and the normalization constant becomes"
}], "Text",
