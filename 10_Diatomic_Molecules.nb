        RowBox[{"Ticks", "\[Rule]", 
         RowBox[{"{", 
          RowBox[{"None", ",", "None"}], "}"}]}], ",", 
        RowBox[{"ImageSize", "\[Rule]", "Small"}], ",", " ", 
