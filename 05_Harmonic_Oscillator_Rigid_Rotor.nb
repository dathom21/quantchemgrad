165209e7f501"],

Cell[TextData[{
 StyleBox["Figure 5.5",
  FontWeight->"Bold"],
 ". The cross product gives a  vector that lies perpendicular to the plane \
formed by ",
 StyleBox["a",
  FontWeight->"Bold",
  FontSlant->"Italic"],
 " and ",
 StyleBox["b",
  FontWeight->"Bold",
  FontSlant->"Italic"],
 ", with the direction given by the right-hand rule, Acdx, Wikimedia, 2008, \
CC BY-SA 3.0, \
https://upload.wikimedia.org/wikipedia/commons/1/1a/Right_hand_rule_Cartesian_\
axes-permuted.svg"
}], "Affiliation",
 CellChangeTimes->{{3.809435027311596*^9, 3.8094350763900714`*^9}, {
   3.80943583474421*^9, 3.8094358359299717`*^9}, {3.8094472165104203`*^9, 
   3.809447281165168*^9}, {3.810054221304062*^9, 3.8100542409148703`*^9}, {
   3.81005507040509*^9, 3.8100552110944114`*^9}, {3.872941056978551*^9, 
   3.8729410604422073`*^9}, {3.872941095339377*^9, 3.872941104497695*^9}, {
   3.8729411877856026`*^9, 3.872941192500902*^9}, 3.872941410619486*^9, {
   3.8729414552433224`*^9, 3.8729414593940353`*^9}, {3.9158004827079096`*^9, 
   3.9158004847600565`*^9}},ExpressionUUID->"539c0aa1-b5fe-4abb-b8a4-\
7bf7f8bbdd9e"],

Cell[TextData[{
 "We can also write the cross product in terms of the magnitude of a vector \
along the ",
 StyleBox["x",
  FontSlant->"Italic"],
 ", ",
 StyleBox["y",
  FontSlant->"Italic"],
 ", and ",
 StyleBox["z",
  FontSlant->"Italic"],
 " axes (e.g., ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["a", "x"], TraditionalForm]],ExpressionUUID->
  "b5c37ead-b3e7-4c6e-ba65-44875b91e787"],
 ") and the axis unit vectors (vectors ",
 StyleBox["i",
  FontWeight->"Bold",
  FontSlant->"Italic"],
 ", ",
 StyleBox["j",
  FontWeight->"Bold",
  FontSlant->"Italic"],
 ", and ",
 StyleBox["k",
  FontWeight->"Bold",
  FontSlant->"Italic"],
 " of magnitude 1 that point along the ",
 StyleBox["x",
  FontSlant->"Italic"],
 ", ",
 StyleBox["y",
  FontSlant->"Italic"],
 ", and ",
 StyleBox["z",
  FontSlant->"Italic"],
 " axes, respectively) as"
}], "Text",
 CellChangeTimes->{{3.8100552892779503`*^9, 3.8100552899841204`*^9}, {
  3.8100553310340652`*^9, 3.8100554812104845`*^9}, {3.9158004997477336`*^9, 
  3.9158005004051175`*^9}},ExpressionUUID->"5aa7d957-9a91-4bdf-9bd1-\
7ca4b3ba64bd"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   StyleBox["a",
    FontWeight->"Bold",
    FontSlant->"Italic"], "\[Cross]", 
   StyleBox["b",
    FontWeight->"Bold",
    FontSlant->"Italic"]}], "=", 
  RowBox[{
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{
       SubscriptBox[
        StyleBox["a",
         FontSlant->"Italic"], 
        StyleBox["y",
         FontSlant->"Italic"]], 
       SubscriptBox[
        StyleBox["b",
         FontSlant->"Italic"], 
        StyleBox["z",
         FontSlant->"Italic"]]}], "-", 
      RowBox[{
       SubscriptBox[
        StyleBox["a",
         FontSlant->"Italic"], 
        StyleBox["z",
         FontSlant->"Italic"]], 
       SubscriptBox[
        StyleBox["b",
         FontSlant->"Italic"], 
        StyleBox["y",
         FontSlant->"Italic"]]}]}], ")"}], 
    StyleBox["i",
     FontWeight->"Bold",
     FontSlant->"Italic"]}], "+", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{
       SubscriptBox[
        StyleBox["a",
         FontSlant->"Italic"], 
        StyleBox["z",
         FontSlant->"Italic"]], 
       SubscriptBox[
        StyleBox["b",
         FontSlant->"Italic"], 
        StyleBox["x",
         FontSlant->"Italic"]]}], "-", 
      RowBox[{
       SubscriptBox[
        StyleBox["a",
         FontSlant->"Italic"], 
        StyleBox["x",
         FontSlant->"Italic"]], 
       SubscriptBox[
        StyleBox["b",
         FontSlant->"Italic"], 
        StyleBox["z",
         FontSlant->"Italic"]]}]}], ")"}], 
    StyleBox["j",
     FontWeight->"Bold",
     FontSlant->"Italic"]}], "+", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{
       SubscriptBox[
        StyleBox["a",
         FontSlant->"Italic"], 
        StyleBox["x",
         FontSlant->"Italic"]], 
       SubscriptBox[
        StyleBox["b",
         FontSlant->"Italic"], 
        StyleBox["y",
         FontSlant->"Italic"]]}], "-", 
