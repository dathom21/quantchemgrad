Cell[TextData[{
 "Then, noting that ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["a", "3"], TraditionalForm]],ExpressionUUID->
  "10e85343-05d1-4c6b-b21c-912828104274"],
 " is the volume of the box ",
 StyleBox["V",
  FontSlant->"Italic"],
 ", we obtain our final expression for the translational partition function \
of an individual atom or molecule,"
}], "Text",
