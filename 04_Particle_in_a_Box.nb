Cell["\<\
Although clearly not a linear molecule, let\[CloseCurlyQuote]s make the \
approximation that the \[Pi] electrons in butadiene move along a straight \
line, whose length we can estimate as 578 pm (two C=C bonds plus one C-C bond \
plus two carbon atom radii). This molecule has four \[Pi] electrons, but we \
can actually put two in each energy level according the to Pauli exclusion \
principle. Recalling that the energies are given by\
\>", "Text",
 CellChangeTimes->{{3.809359178369775*^9, 
  3.8093593234083433`*^9}},ExpressionUUID->"e40aa3a6-5690-4449-93ee-\
d0191effd2d9"],

Cell[BoxData[
 RowBox[{
  SubscriptBox[
   StyleBox["E",
    FontSlant->"Italic"], 
   StyleBox["n",
    FontSlant->"Italic"]], "=", 
  FractionBox[
   RowBox[{
    SuperscriptBox[
     StyleBox["n",
      FontSlant->"Italic"], "2"], 
    SuperscriptBox["\[Pi]", "2"], 
    SuperscriptBox["\[HBar]", "2"]}], 
   RowBox[{"2", 
    SuperscriptBox[
     StyleBox["ma",
      FontSlant->"Italic"], "2"]}]]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.808746256152788*^9, 3.8087463361701956`*^9}, {
  3.808746369787464*^9, 
  3.808746370563246*^9}},ExpressionUUID->"7f867fe9-0cbb-4dfe-9cec-\
5162df23971c"],

Cell[TextData[{
 "we want to find the energy difference between the lowest unoccupied state (",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["E",
    FontSlant->"Italic"], "3"]],
  CellChangeTimes->{{3.808746256152788*^9, 3.8087463361701956`*^9}, {
   3.808746369787464*^9, 3.808746370563246*^9}},ExpressionUUID->
  "d09c56f6-2abe-457b-b911-970f05a7b2de"],
 ") and the highest occupied state (",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["E",
    FontSlant->"Italic"], "2"]],
  CellChangeTimes->{{3.808746256152788*^9, 3.8087463361701956`*^9}, {
   3.808746369787464*^9, 3.808746370563246*^9}},ExpressionUUID->
  "f16e05ab-96cc-457e-9c3f-e0aa5a2d0ef8"],
 "). Plugging in the values into our equation, we find"
}], "Text",
 CellChangeTimes->{{3.80935933382067*^9, 
  3.809359399292159*^9}},ExpressionUUID->"b2bed5a7-7ff4-439a-8068-\
35b4a7d1628d"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   SubscriptBox[
    StyleBox["E",
     FontSlant->"Italic"], "3"], "-", 
   SubscriptBox[
    StyleBox["E",
     FontSlant->"Italic"], "2"]}], "=", 
  RowBox[{
   FractionBox[
    RowBox[{
     SuperscriptBox["\[Pi]", "2"], 
     SuperscriptBox["\[HBar]", "2"]}], 
    RowBox[{"2", 
     SuperscriptBox[
      StyleBox["ma",
       FontSlant->"Italic"], "2"]}]], 
   RowBox[{"(", 
    RowBox[{
     SuperscriptBox["3", "2"], "-", 
     SuperscriptBox["2", "2"]}], ")"}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.808746256152788*^9, 3.8087463361701956`*^9}, {
  3.808746369787464*^9, 3.808746370563246*^9}, {3.8093594081314893`*^9, 
