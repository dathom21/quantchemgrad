   SubscriptBox[
    StyleBox["S",
     FontSlant->"Italic"], 
    StyleBox["nm",
     FontSlant->"Italic"]], " ", "=", 
   SubscriptBox["\[Delta]", 
    StyleBox["nm",
     FontSlant->"Italic"]]}]}]], "DisplayFormulaNumbered",
