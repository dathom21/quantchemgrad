Cell[TextData[{
 "Now we arrive at an important point about the meaning of ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["A",
    FontSlant->"Italic"], 
   StyleBox["ij",
    FontSlant->"Italic"]]],
  CellChangeTimes->{{3.8113265575394135`*^9, 3.8113266208341584`*^9}, {
    3.8113268886705112`*^9, 3.8113269031313066`*^9}, 3.8113270406173744`*^9, {
