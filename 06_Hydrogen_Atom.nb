Cell[BoxData[
 TagBox[GridBox[{
    {"\<\"\\!\\(\\*StyleBox[\\\"l\\\",FontSlant->\\\"Italic\\\"]\\)\"\>", "\<\
\"\\!\\(\\*SubscriptBox[StyleBox[\\\"m\\\",FontSlant->\\\"Italic\\\"], \
StyleBox[\\\"l\\\",FontSlant->\\\"Italic\\\"]]\\)\"\>", \
"\<\"\\!\\(\\*SubsuperscriptBox[StyleBox[\\\"Y\\\",FontSlant->\\\"Italic\\\"],\
 StyleBox[\\\"l\\\",FontSlant->\\\"Italic\\\"], SubscriptBox[StyleBox[\\\"m\\\
\",FontSlant->\\\"Italic\\\"], \
StyleBox[\\\"l\\\",FontSlant->\\\"Italic\\\"]]]\\)(\[Theta],\[Phi])\"\>"},
    {"0", "0", 
     FractionBox["1", 
      RowBox[{"2", " ", 
       SqrtBox["\[Pi]"]}]]},
    {"1", 
     RowBox[{"-", "1"}], 
     RowBox[{
      FractionBox["1", "2"], " ", 
      SuperscriptBox["\[ExponentialE]", 
       RowBox[{
        RowBox[{"-", "\[ImaginaryI]"}], " ", "\[Phi]"}]], " ", 
      SqrtBox[
       FractionBox["3", 
        RowBox[{"2", " ", "\[Pi]"}]]], " ", 
      RowBox[{"Sin", "[", "\[Theta]", "]"}]}]},
    {"1", "0", 
     RowBox[{
      FractionBox["1", "2"], " ", 
      SqrtBox[
       FractionBox["3", "\[Pi]"]], " ", 
      RowBox[{"Cos", "[", "\[Theta]", "]"}]}]},
    {"1", "1", 
     RowBox[{
      FractionBox["1", "2"], " ", 
      SuperscriptBox["\[ExponentialE]", 
       RowBox[{"\[ImaginaryI]", " ", "\[Phi]"}]], " ", 
      SqrtBox[
       FractionBox["3", 
        RowBox[{"2", " ", "\[Pi]"}]]], " ", 
      RowBox[{"Sin", "[", "\[Theta]", "]"}]}]},
    {"2", 
     RowBox[{"-", "2"}], 
     RowBox[{
      FractionBox["1", "4"], " ", 
      SuperscriptBox["\[ExponentialE]", 
       RowBox[{
        RowBox[{"-", "2"}], " ", "\[ImaginaryI]", " ", "\[Phi]"}]], " ", 
      SqrtBox[
       FractionBox["15", 
        RowBox[{"2", " ", "\[Pi]"}]]], " ", 
      SuperscriptBox[
       RowBox[{"Sin", "[", "\[Theta]", "]"}], "2"]}]},
    {"2", 
     RowBox[{"-", "1"}], 
     RowBox[{
      FractionBox["1", "2"], " ", 
      SuperscriptBox["\[ExponentialE]", 
       RowBox[{
        RowBox[{"-", "\[ImaginaryI]"}], " ", "\[Phi]"}]], " ", 
      SqrtBox[
       FractionBox["15", 
        RowBox[{"2", " ", "\[Pi]"}]]], " ", 
      RowBox[{"Cos", "[", "\[Theta]", "]"}], " ", 
      RowBox[{"Sin", "[", "\[Theta]", "]"}]}]},
    {"2", "0", 
     RowBox[{
      FractionBox["1", "4"], " ", 
      SqrtBox[
       FractionBox["5", "\[Pi]"]], " ", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"-", "1"}], "+", 
        RowBox[{"3", " ", 
         SuperscriptBox[
          RowBox[{"Cos", "[", "\[Theta]", "]"}], "2"]}]}], ")"}]}]},
    {"2", "1", 
     RowBox[{
      FractionBox["1", "2"], " ", 
      SuperscriptBox["\[ExponentialE]", 
       RowBox[{"\[ImaginaryI]", " ", "\[Phi]"}]], " ", 
      SqrtBox[
       FractionBox["15", 
        RowBox[{"2", " ", "\[Pi]"}]]], " ", 
      RowBox[{"Cos", "[", "\[Theta]", "]"}], " ", 
      RowBox[{"Sin", "[", "\[Theta]", "]"}]}]},
    {"2", "2", 
     RowBox[{
      FractionBox["1", "4"], " ", 
      SuperscriptBox["\[ExponentialE]", 
       RowBox[{"2", " ", "\[ImaginaryI]", " ", "\[Phi]"}]], " ", 
      SqrtBox[
       FractionBox["15", 
        RowBox[{"2", " ", "\[Pi]"}]]], " ", 
      SuperscriptBox[
       RowBox[{"Sin", "[", "\[Theta]", "]"}], "2"]}]}
   },
   AutoDelete->False,
   BaseStyle->{FontFamily -> "Arial", FontSize -> 18},
