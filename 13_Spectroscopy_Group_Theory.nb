Cell[CellGroupData[{

Cell[TextData[{
 "Improper Rotation: ",
 Cell[BoxData[
  FormBox[
   SubscriptBox[
    OverscriptBox["S", "^"], "n"], TraditionalForm]],ExpressionUUID->
  "ef356bfc-295d-4b0c-ad24-ea1cf8890549"]
}], "Subsubsection",
 CellChangeTimes->{{3.816258293276898*^9, 
  3.81625832049346*^9}},ExpressionUUID->"6a7609ac-8ca2-45cf-855b-\
efec934d594a"],

Cell[TextData[{
 "The improper rotation operation involves a combination of rotation and \
reflection and is defined by symmetry element ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["S", "n"], TraditionalForm]],ExpressionUUID->
  "18997ba7-80b8-47e6-841f-36538520f1b0"],
 ", an ",
 StyleBox["n",
  FontSlant->"Italic"],
 "-fold rotation-reflection axis or improper rotation axis. In the operation, \
the molecule is first rotated about the axis by ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["360", "\[Degree]"], "/", "n"}], TraditionalForm]],
  ExpressionUUID->"a44d3134-7b3a-40ff-b075-7d48ee0276d3"],
 " and then reflected through a mirror plane perpendicular to the axis. The ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["S", "6"], TraditionalForm]],ExpressionUUID->
  "fbb46fde-0181-4e3a-9815-376965e4bf61"],
 " rotation-reflection axis of ethane is illustrated in Figure 13.13. The \
plane of symmetry is also shown for clarity. "
}], "Text",
 CellChangeTimes->{{3.8162583251524367`*^9, 3.816258517048414*^9}, {
   3.816259232537986*^9, 3.81625927091072*^9}, 3.9398953464491615`*^9, {
   3.9400904939563427`*^9, 
   3.940090494140087*^9}},ExpressionUUID->"690b1681-5de4-44aa-a5e3-\
ed5cf514715b"],

