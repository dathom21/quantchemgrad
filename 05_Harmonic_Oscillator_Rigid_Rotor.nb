  3.8101096702538624`*^9, 3.8101096759209433`*^9}, {3.841416816063059*^9, 
  3.8414168167187757`*^9}},ExpressionUUID->"62ffa9df-430f-43f1-9eb4-\
350404253ace"],

Cell[BoxData[
 RowBox[{
  StyleBox["p",
   FontWeight->"Bold",
   FontSlant->"Italic"], "=", 
  StyleBox[
   StyleBox[
    RowBox[{"m", 
     StyleBox["v",
      FontWeight->"Bold"]}]],
   FontSlant->"Italic"]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.810055754230993*^9, 
  3.8100557572447653`*^9}},ExpressionUUID->"abeb4efd-f122-4874-a096-\
8149616f5ee9"],

Cell[TextData[{
 "The angular momentum ",
 StyleBox["L",
  FontWeight->"Bold",
  FontSlant->"Italic"],
 " of a particle is given by"
}], "Text",
 CellChangeTimes->{{3.81010968757923*^9, 
  3.8101096921087356`*^9}},ExpressionUUID->"9e25f2f4-197c-42e0-8adc-\
06eb76805c1f"],

Cell[BoxData[
 RowBox[{
  StyleBox["L",
   FontWeight->"Bold",
   FontSlant->"Italic"], "=", 
  RowBox[{
   StyleBox["r",
    FontWeight->"Bold",
    FontSlant->"Italic"], "\[Cross]", 
   StyleBox["p",
    FontWeight->"Bold",
    FontSlant->"Italic"]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8100544880652375`*^9, 3.8100545041200957`*^9}, {
