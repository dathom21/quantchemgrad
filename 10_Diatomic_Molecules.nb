Cell[TextData[{
 "The term ",
 Cell[BoxData[
  RowBox[{"-", 
   RowBox[{"\[LeftAngleBracket]", 
    RowBox[{
     SubscriptBox["\[Phi]", 
      RowBox[{"1", 
       SubscriptBox[
