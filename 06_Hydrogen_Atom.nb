Cell[BoxData[
 RowBox[{
  SuperscriptBox[
   OverscriptBox[
    StyleBox["L",
     FontSlant->"Italic"], "^"], "2"], "=", 
  RowBox[{"-", 
   RowBox[{
    SuperscriptBox["\[HBar]", "2"], "[", 
    RowBox[{
     RowBox[{
      FractionBox["1", 
       RowBox[{"sin", 
        RowBox[{"(", "\[Theta]", ")"}]}]], 
      RowBox[{
       FractionBox["\[PartialD]", 
        RowBox[{"\[PartialD]", "\[Theta]"}]], 
