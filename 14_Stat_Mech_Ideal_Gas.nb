  3.9212533999403925`*^9}},ExpressionUUID->"3c9d190a-e3c8-4532-b25c-\
bc0f1159be7e"],

Cell["each term is then identical, so we obtain", "Text",
 CellChangeTimes->{{3.921253435273589*^9, 
  3.9212534405071883`*^9}},ExpressionUUID->"3f2d2a8a-dd76-4410-a506-\
473578deb5ab"],

Cell[BoxData[
 RowBox[{
  SubscriptBox[
   StyleBox["Z",
    FontSlant->"Italic"], 
   SubscriptBox["\[CurlyEpsilon]", 
    StyleBox["trans",
     FontSlant->"Italic"]]], "=", 
  SuperscriptBox[
   RowBox[{"(", 
    RowBox[{
     UnderoverscriptBox["\[Sum]", 
      RowBox[{"n", "=", "1"}], "\[Infinity]"], 
     SuperscriptBox["\[ExponentialE]", 
      RowBox[{
       FractionBox[
        RowBox[{"-", 
         SuperscriptBox[
          StyleBox[
           RowBox[{"\[Beta]", 
            StyleBox["h",
             FontSlant->"Italic"]}]], "2"]}], 
        RowBox[{"8", 
         SuperscriptBox[
          StyleBox["ma",
           FontSlant->"Italic"], "2"]}]], 
       SuperscriptBox[
        StyleBox["n",
         FontSlant->"Italic"], "2"]}]]}], ")"}], 
   "3"]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.816606313917019*^9, 3.816606348170246*^9}, {
  3.8166065472626705`*^9, 3.8166065528425016`*^9}, {3.816607096263274*^9, 
  3.8166071319089766`*^9}, {3.8166082792077055`*^9, 3.816608293099399*^9}, {
  3.816608332410132*^9, 3.8166083462110634`*^9}, {3.8166084113469725`*^9, 
  3.8166084137878127`*^9}, {3.8166085853535995`*^9, 3.8166086653266125`*^9}, {
  3.816608708567449*^9, 3.8166087156576424`*^9}, {3.8166092184739776`*^9, 
  3.8166092268161383`*^9}, {3.8166150630343227`*^9, 3.816615085830597*^9}, {
  3.8166172290084677`*^9, 3.8166172362795367`*^9}, {3.81661726771554*^9, 
  3.8166172792306194`*^9}, {3.921252657969633*^9, 3.921252700157872*^9}, {
  3.921253074652234*^9, 3.921253080819618*^9}, {3.9212531883067007`*^9, 
  3.921253269930357*^9}, {3.921253353298236*^9, 3.9212533999403925`*^9}, {
  3.921253456696965*^9, 
  3.921253536618924*^9}},ExpressionUUID->"15f74909-6737-411f-bb17-\
865aef447cab"],

Cell[TextData[{
 "In a typical system (",
 StyleBox["m",
  FontSlant->"Italic"],
 " on the order of ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["10", 
     RowBox[{"-", "26", " "}]], "kg"}], TraditionalForm]],ExpressionUUID->
  "9f42b7a5-2b26-4a46-a396-31f343b95fde"],
 ", ",
 StyleBox["a",
  FontSlant->"Italic"],
 " on the order of cm to ",
 StyleBox["m",
  FontSlant->"Italic"],
 ", and ",
 StyleBox["T",
  FontSlant->"Italic"],
 " of about 300 K), the spacing between successive values in the summation \
(that is, adjacent values of ",
 StyleBox["n",
  FontSlant->"Italic"],
 "), will be very small. Therefore, we can convert our sum to an integral,"
}], "Text",
 CellChangeTimes->{{3.9213273255643606`*^9, 3.9213274421139226`*^9}, {
  3.9213275305005007`*^9, 
  3.921327607016283*^9}},ExpressionUUID->"d9d76f63-036b-4e26-9775-\
e831de043230"],

Cell[BoxData[
 RowBox[{
  SubscriptBox[
   StyleBox["Z",
    FontSlant->"Italic"], 
   SubscriptBox["\[CurlyEpsilon]", 
    StyleBox["trans",
     FontSlant->"Italic"]]], "=", 
  SuperscriptBox[
   RowBox[{"(", 
    RowBox[{
     SuperscriptBox[
      SubscriptBox["\[Integral]", "0"], "\[Infinity]"], 
     RowBox[{
      SuperscriptBox["\[ExponentialE]", 
       RowBox[{
        FractionBox[
         RowBox[{"-", 
          SuperscriptBox[
           StyleBox[
            RowBox[{"\[Beta]", 
             StyleBox["h",
              FontSlant->"Italic"]}]], "2"]}], 
         RowBox[{"8", 
          SuperscriptBox[
           StyleBox["ma",
            FontSlant->"Italic"], "2"]}]], 
        SuperscriptBox[
         StyleBox["n",
          FontSlant->"Italic"], "2"]}]], 
      RowBox[{"\[DifferentialD]", 
       StyleBox["n",
        FontSlant->"Italic"]}]}]}], ")"}], "3"]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.816606313917019*^9, 3.816606348170246*^9}, {
  3.8166065472626705`*^9, 3.8166065528425016`*^9}, {3.816607096263274*^9, 
  3.8166071319089766`*^9}, {3.8166082792077055`*^9, 3.816608293099399*^9}, {
  3.816608332410132*^9, 3.8166083462110634`*^9}, {3.8166084113469725`*^9, 
  3.8166084137878127`*^9}, {3.8166085853535995`*^9, 3.8166086653266125`*^9}, {
  3.816608708567449*^9, 3.8166087156576424`*^9}, {3.8166092184739776`*^9, 
  3.8166092268161383`*^9}, {3.8166150630343227`*^9, 3.816615085830597*^9}, {
  3.8166172290084677`*^9, 3.8166172362795367`*^9}, {3.81661726771554*^9, 
  3.8166172792306194`*^9}, {3.921252657969633*^9, 3.921252700157872*^9}, {
  3.921253074652234*^9, 3.921253080819618*^9}, {3.9212531883067007`*^9, 
