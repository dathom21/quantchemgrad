    OverscriptBox[
     StyleBox["T",
      FontSlant->"Italic"], "^"], 
    StyleBox["N",
     FontSlant->"Italic"]], 
   RowBox[{"(", 
    StyleBox["R",
     FontSlant->"Italic"], 
    StyleBox[")",
     FontSlant->"Italic"]}], 
   SubscriptBox["\[Phi]", 
    StyleBox["N",
     FontSlant->"Italic"]], 
   RowBox[{"(", 
    StyleBox["R",
     FontWeight->"Bold",
     FontSlant->"Italic"], 
    StyleBox[")",
     FontSlant->"Italic"]}], 
   SubscriptBox["\[Phi]", 
    StyleBox["e",
     FontSlant->"Italic"]], 
