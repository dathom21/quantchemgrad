\\!\\(\\*StyleBox[\\\"\[Minus]\\\",FontWeight->\\\"Plain\\\"]\\)\\!\\(\\*\
StyleBox[\\\"z\\\",FontWeight->\\\"Plain\\\",FontSlant->\\\"Italic\\\"]\\)\\!\
\\(\\*StyleBox[FractionBox[\\\"\[PartialD]\\\", RowBox[{\\\"\[PartialD]\\\", \
StyleBox[\\\"y\\\",FontSlant->\\\"Italic\\\"]}]],FontWeight->\\\"Plain\\\"]\\)\
\\!\\(\\*StyleBox[\\\")\\\",FontWeight->\\\"Plain\\\"]\\)\"\>"},
    {"\<\"\\!\\(\\*StyleBox[\\\"Angular\\\",FontWeight->\\\"Plain\\\"]\\)\\!\\\
