   3.8113273925612955`*^9}, {3.8113274382012477`*^9, 3.811327492034623*^9}, {
   3.8113275253821125`*^9, 3.8113275462381163`*^9}, {3.811329211490376*^9, 
   3.8113292145036054`*^9}, {3.811329455455474*^9, 3.81132950541926*^9}, {
   3.811329708119735*^9, 3.8113297115727005`*^9}, {3.811329763448269*^9, 
   3.811329778280109*^9}},ExpressionUUID->"68ec02c8-c6b9-47ee-9cb2-\
3291eaac00ec"],

Cell["For a normalized wavefunction,", "Text",
 CellChangeTimes->{{3.811329715750289*^9, 
  3.8113297217407*^9}},ExpressionUUID->"2fe1944b-f310-44c5-a857-46f4135910b1"],

Cell[BoxData[
 RowBox[{
  RowBox[{"\[LeftAngleBracket]", 
   RowBox[{
    StyleBox[
     SubscriptBox[
      StyleBox["\[CapitalPsi]",
       FontWeight->"Bold"], "a"],
     FontWeight->"Bold"], "|", 
    StyleBox[
     SubscriptBox[
      StyleBox["\[CapitalPsi]",
       FontWeight->"Bold"], "a"],
     FontWeight->"Bold"]}], "\[RightAngleBracket]"}], "=", 
  "1"}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8112559638442764`*^9, 3.8112559741396627`*^9}, {
   3.8113221103126726`*^9, 3.811322130222258*^9}, 3.8113221675383205`*^9, {
   3.811322570897264*^9, 3.811322611416624*^9}, {3.8113228670247326`*^9, 
   3.811322868962326*^9}, 3.8113230721769085`*^9, {3.8113233012632074`*^9, 
   3.811323380796157*^9}, {3.8113234162551765`*^9, 3.8113234396763544`*^9}, {
   3.811324020646849*^9, 3.811324058909622*^9}, {3.8113241032752814`*^9, 
   3.811324173977947*^9}, {3.8113242527124395`*^9, 3.8113243673570013`*^9}, {
   3.8113246331815095`*^9, 3.811324637106286*^9}, {3.8113251052825127`*^9, 
   3.8113251075253*^9}, {3.811325157092647*^9, 3.811325157547997*^9}, {
   3.8113251947951336`*^9, 3.8113252086545453`*^9}, {3.8113271771897645`*^9, 
   3.811327184536927*^9}, {3.811327229827714*^9, 3.811327252666423*^9}, {
   3.8113273026463294`*^9, 3.811327327733873*^9}, {3.8113273817178807`*^9, 
   3.8113273925612955`*^9}, {3.8113274382012477`*^9, 3.811327492034623*^9}, {
   3.8113275253821125`*^9, 3.8113275462381163`*^9}, {3.811329211490376*^9, 
   3.8113292145036054`*^9}, {3.811329455455474*^9, 3.81132950541926*^9}, {
   3.811329708119735*^9, 
   3.8113297273178205`*^9}},ExpressionUUID->"fbe0c8fa-366f-4681-8694-\
51551430ebbd"],

Cell["\<\
Note that because of the simplification we derived for an orthonormal basis, \
this equation is also written as\
\>", "Text",
 CellChangeTimes->{{3.8113297830276346`*^9, 
  3.811329818861514*^9}},ExpressionUUID->"016f12be-82c5-46ae-affe-\
d3ddcc56e774"],

Cell[BoxData[
 RowBox[{
  RowBox[{"\[LeftAngleBracket]", 
   RowBox[{
    StyleBox["a",
     FontSlant->"Italic"], "|", 
    StyleBox["b",
     FontSlant->"Italic"]}], "\[RightAngleBracket]"}], "=", 
  RowBox[{"\[Integral]", 
   RowBox[{
    SubsuperscriptBox["\[Psi]", 
     StyleBox["a",
      FontSlant->"Italic"], "\[Star]"], 
    RowBox[{"(", 
     StyleBox["x",
      FontSlant->"Italic"], ")"}], 
    SubscriptBox["\[Psi]", 
     StyleBox["b",
      FontSlant->"Italic"]], 
    RowBox[{"(", 
     StyleBox["x",
      FontSlant->"Italic"], ")"}], 
    StyleBox["dx",
     FontSlant->"Italic"]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8112559638442764`*^9, 3.8112559741396627`*^9}, {
   3.8113221103126726`*^9, 3.811322130222258*^9}, 3.8113221675383205`*^9, {
   3.811322570897264*^9, 3.811322611416624*^9}, {3.8113228670247326`*^9, 
   3.811322868962326*^9}, 3.8113230721769085`*^9, {3.8113233012632074`*^9, 
   3.811323380796157*^9}, {3.8113234162551765`*^9, 3.8113234396763544`*^9}, {
   3.811324020646849*^9, 3.811324058909622*^9}, {3.8113241032752814`*^9, 
   3.811324173977947*^9}, {3.8113242527124395`*^9, 3.8113243673570013`*^9}, {
   3.8113246331815095`*^9, 3.811324637106286*^9}, {3.8113251052825127`*^9, 
   3.8113251075253*^9}, {3.811325157092647*^9, 3.811325157547997*^9}, {
   3.8113251947951336`*^9, 3.8113252086545453`*^9}, {3.8113271771897645`*^9, 
   3.811327184536927*^9}, {3.811327229827714*^9, 3.811327252666423*^9}, {
   3.8113273026463294`*^9, 3.811327327733873*^9}, {3.8113273817178807`*^9, 
   3.8113273925612955`*^9}, {3.8113274382012477`*^9, 3.811327492034623*^9}, {
   3.8113275253821125`*^9, 3.8113275462381163`*^9}, {3.811329211490376*^9, 
   3.8113292145036054`*^9}, {3.811329455455474*^9, 3.81132950541926*^9}, {
   3.8113298279830933`*^9, 
   3.8113298332218847`*^9}},ExpressionUUID->"d37a92d8-f561-4a46-87bc-\
cf4e1a761131"],

Cell[TextData[{
 "(although the basis ",
 StyleBox["x",
  FontSlant->"Italic"],
 " is clearly not orthonormal). This becomes a general trend that only the \
subscripts are used to specify the wavefunction in Dirac notation."
}], "Text",
 CellChangeTimes->{{3.8113298468431177`*^9, 3.8113298627078867`*^9}, {
  3.8113299380963435`*^9, 
  3.81132996728286*^9}},ExpressionUUID->"31778d87-7d98-4bbb-ba68-\
489859770ce9"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Operators in Matrix and Bra-Ket Representations", "Subsection",
 CellChangeTimes->{{3.8113300597270255`*^9, 
  3.8113300907071953`*^9}},ExpressionUUID->"2a31ef01-16f8-445f-9950-\
d45fa1821059"],

Cell[TextData[{
 "Now let\[CloseCurlyQuote]s think about what happens to operators if we \
represent our wavefunction as a linear combination over some vector space. As \
we briefly mentioned earlier, because all quantum-mechanical operators \
associated with observables are linear operators, we can represent our \
operator as a linear combination of operations on each basis vector. For some \
generic linear operator ",
 Cell[BoxData[
  FormBox[
   OverscriptBox["A", "^"], TraditionalForm]],ExpressionUUID->
  "730cbebb-0c6b-42c3-8bb1-5d2448f1490b"],
 ", we write"
}], "Text",
 CellChangeTimes->{{3.8113303279274445`*^9, 3.811330411584235*^9}, {
  3.8113304815739403`*^9, 
  3.81133059327011*^9}},ExpressionUUID->"8fb55969-742e-4319-a137-\
da1489527413"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   OverscriptBox[
    StyleBox["A",
     FontSlant->"Italic"], "^"], 
   SubscriptBox[
    StyleBox["\[CapitalPsi]",
     FontWeight->"Bold"], 
    StyleBox["a",
     FontWeight->"Bold",
     FontSlant->"Italic"]]}], "=", 
  RowBox[{
   UnderscriptBox[
    OverscriptBox["\[Sum]", 
     StyleBox["n",
      FontSlant->"Italic"]], 
    RowBox[{
     StyleBox["j",
      FontSlant->"Italic"], "=", "1"}]], 
   RowBox[{
    SubscriptBox[
     StyleBox["a",
      FontSlant->"Italic"], 
     StyleBox["j",
      FontSlant->"Italic"]], 
    OverscriptBox[
     StyleBox["A",
      FontSlant->"Italic"], "^"], 
    SubscriptBox[
     StyleBox["\[Psi]",
      FontWeight->"Bold"], 
     StyleBox["j",
      FontWeight->"Bold",
      FontSlant->"Italic"]]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8113265575394135`*^9, 3.8113266208341584`*^9}, {
   3.8113268886705112`*^9, 3.8113269031313066`*^9}, 3.8113270406173744`*^9, {
   3.811330598918048*^9, 3.8113306162990384`*^9}, {3.811330646381595*^9, 
   3.8113306467325897`*^9}, {3.8113307587355585`*^9, 
   3.811330766603507*^9}},ExpressionUUID->"7205095f-4b75-452b-8729-\
5bdbd7db81fd"],

Cell[TextData[{
 "(we\[CloseCurlyQuote]re using ",
 StyleBox["j",
  FontSlant->"Italic"],
 " here as the summation iterator to keep the notation consistent in the next \
step, but it\[CloseCurlyQuote]s the same as if it were ",
 StyleBox["i",
  FontSlant->"Italic"],
 "). Now, here comes the part that can get a bit confusing. Since our basis \
vectors form a complete set, we can represent transformed basis vector ",
 Cell[BoxData[
  RowBox[{
   OverscriptBox[
    StyleBox["A",
     FontSlant->"Italic"], "^"], 
   SubscriptBox[
    StyleBox["\[Psi]",
     FontWeight->"Bold"], 
    StyleBox["j",
     FontWeight->"Bold",
     FontSlant->"Italic"]]}]],
  CellChangeTimes->{{3.8113265575394135`*^9, 3.8113266208341584`*^9}, {
    3.8113268886705112`*^9, 3.8113269031313066`*^9}, 3.8113270406173744`*^9, {
    3.811330598918048*^9, 3.8113306162990384`*^9}, {3.811330646381595*^9, 
    3.8113306467325897`*^9}},ExpressionUUID->
  "7df9a502-cd48-4d47-9e26-bf414f765140"],
 " as a linear combination of the original basis vectors. In equation form, \
we write,"
}], "Text",
 CellChangeTimes->{{3.811330673859607*^9, 3.8113307337703924`*^9}, {
   3.811330772195627*^9, 3.8113308240387497`*^9}, 
   3.969021568467142*^9},ExpressionUUID->"51569579-6e54-4b65-9649-\
620a7f7f0ba5"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   OverscriptBox[
    StyleBox["A",
     FontSlant->"Italic"], "^"], 
   SubscriptBox[
    StyleBox["\[Psi]",
     FontWeight->"Bold"], 
    StyleBox["j",
     FontWeight->"Bold",
     FontSlant->"Italic"]]}], "=", 
  RowBox[{
   UnderscriptBox[
    OverscriptBox["\[Sum]", 
     StyleBox["n",
      FontSlant->"Italic"]], 
    RowBox[{
     StyleBox["i",
      FontSlant->"Italic"], "=", "1"}]], 
   RowBox[{
    SubscriptBox[
     StyleBox["A",
      FontSlant->"Italic"], 
     StyleBox["ij",
      FontSlant->"Italic"]], 
    SubscriptBox[
     StyleBox["\[Psi]",
      FontWeight->"Bold"], 
     StyleBox["i",
      FontWeight->"Bold",
      FontSlant->"Italic"]]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8113265575394135`*^9, 3.8113266208341584`*^9}, {
   3.8113268886705112`*^9, 3.8113269031313066`*^9}, 3.8113270406173744`*^9, {
   3.811330598918048*^9, 3.8113306162990384`*^9}, {3.811330646381595*^9, 
   3.8113306467325897`*^9}, {3.811330739744603*^9, 3.8113307427314014`*^9}, {
   3.811330835135107*^9, 3.811330835875268*^9}, 3.811501833540098*^9, {
   3.811501867015377*^9, 
   3.8115019239986753`*^9}},ExpressionUUID->"1d7c4ff0-fa9a-4416-ba5e-\
a0f58a2c5ab3"],

Cell[TextData[{
 "where ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["A",
    FontSlant->"Italic"], 
   StyleBox["ij",
    FontSlant->"Italic"]]],
  CellChangeTimes->{{3.8113265575394135`*^9, 3.8113266208341584`*^9}, {
    3.8113268886705112`*^9, 3.8113269031313066`*^9}, 3.8113270406173744`*^9, {
    3.811330598918048*^9, 3.8113306162990384`*^9}, {3.811330646381595*^9, 
    3.8113306467325897`*^9}, {3.811330739744603*^9, 3.8113307427314014`*^9}, {
    3.811330835135107*^9, 3.811330835875268*^9}, 3.811501833540098*^9, {
    3.811501867015377*^9, 3.8115019239986753`*^9}},ExpressionUUID->
  "a04ccbfb-72aa-4603-96eb-d3e22b4af685"],
 " represents the magnitude of ",
 Cell[BoxData[
  RowBox[{
   OverscriptBox[
    StyleBox["A",
     FontSlant->"Italic"], "^"], 
   SubscriptBox[
    StyleBox["\[Psi]",
     FontWeight->"Bold"], 
    StyleBox["j",
     FontWeight->"Bold",
     FontSlant->"Italic"]]}]],
  CellChangeTimes->{{3.8113265575394135`*^9, 3.8113266208341584`*^9}, {
    3.8113268886705112`*^9, 3.8113269031313066`*^9}, 3.8113270406173744`*^9, {
    3.811330598918048*^9, 3.8113306162990384`*^9}, {3.811330646381595*^9, 
    3.8113306467325897`*^9}, {3.811330739744603*^9, 3.8113307427314014`*^9}, {
    3.811330835135107*^9, 3.811330835875268*^9}, 3.811501833540098*^9, {
    3.811501867015377*^9, 3.8115019239986753`*^9}},ExpressionUUID->
  "dea85b85-fb08-4869-9d31-706697688854"],
 " along the vector ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["\[Psi]",
    FontWeight->"Bold"], 
   StyleBox["i",
    FontWeight->"Bold",
    FontSlant->"Italic"]]],
  CellChangeTimes->{{3.8113265575394135`*^9, 3.8113266208341584`*^9}, {
    3.8113268886705112`*^9, 3.8113269031313066`*^9}, 3.8113270406173744`*^9, {
    3.811330598918048*^9, 3.8113306162990384`*^9}, {3.811330646381595*^9, 
    3.8113306467325897`*^9}, {3.811330739744603*^9, 3.8113307427314014`*^9}, {
    3.811330835135107*^9, 3.811330835875268*^9}, 3.811501833540098*^9, {
    3.811501867015377*^9, 3.8115019239986753`*^9}},ExpressionUUID->
  "ee8ff2b5-7834-44e4-aa77-731dacf02642"],
 ". So we are now writing our operator acting on our basis vector, ",
 Cell[BoxData[
  RowBox[{
   OverscriptBox[
    StyleBox["A",
     FontSlant->"Italic"], "^"], 
   SubscriptBox[
    StyleBox["\[Psi]",
     FontWeight->"Bold"], 
    StyleBox["j",
     FontWeight->"Bold",
     FontSlant->"Italic"]]}]],
  CellChangeTimes->{{3.8113265575394135`*^9, 3.8113266208341584`*^9}, {
    3.8113268886705112`*^9, 3.8113269031313066`*^9}, 3.8113270406173744`*^9, {
    3.811330598918048*^9, 3.8113306162990384`*^9}, {3.811330646381595*^9, 
    3.8113306467325897`*^9}, {3.811330739744603*^9, 3.8113307427314014`*^9}, {
    3.811330835135107*^9, 3.811330835875268*^9}, 3.811501833540098*^9, {
    3.811501867015377*^9, 3.8115019239986753`*^9}},ExpressionUUID->
  "8bdd5018-6544-48e9-9b21-026ae0e1aa8c"],
 ", as a sum over all of the basis vectors ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["\[Psi]",
    FontWeight->"Bold"], 
   StyleBox["i",
    FontWeight->"Bold",
    FontSlant->"Italic"]]],
  CellChangeTimes->{{3.8113265575394135`*^9, 3.8113266208341584`*^9}, {
    3.8113268886705112`*^9, 3.8113269031313066`*^9}, 3.8113270406173744`*^9, {
    3.811330598918048*^9, 3.8113306162990384`*^9}, {3.811330646381595*^9, 
    3.8113306467325897`*^9}, {3.811330739744603*^9, 3.8113307427314014`*^9}, {
    3.811330835135107*^9, 3.811330835875268*^9}, 3.811501833540098*^9, {
    3.811501867015377*^9, 3.8115019239986753`*^9}},ExpressionUUID->
  "57a82f79-a3ef-4e47-b93f-5b5d3932ba30"],
 ", where the weighting factor is given by the component ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["A",
    FontSlant->"Italic"], 
   StyleBox["ij",
    FontSlant->"Italic"]]],
  CellChangeTimes->{{3.8113265575394135`*^9, 3.8113266208341584`*^9}, {
    3.8113268886705112`*^9, 3.8113269031313066`*^9}, 3.8113270406173744`*^9, {
    3.811330598918048*^9, 3.8113306162990384`*^9}, {3.811330646381595*^9, 
    3.8113306467325897`*^9}, {3.811330739744603*^9, 3.8113307427314014`*^9}, {
    3.811330835135107*^9, 3.811330835875268*^9}, 3.811501833540098*^9, {
    3.811501867015377*^9, 3.8115019239986753`*^9}},ExpressionUUID->
  "7e2b0bed-5ef2-4447-88e3-990f0b9e5ac8"],
 "."
}], "Text",
 CellChangeTimes->{{3.8115019704837303`*^9, 3.8115020466405134`*^9}, {
  3.8115021121932983`*^9, 
  3.811502169986166*^9}},ExpressionUUID->"686bc2cb-b0e6-4841-8db1-\
3833a165a4f4"],

Cell[TextData[{
 "Now, we originally were trying to write an expression for the operator ",
 Cell[BoxData[
  OverscriptBox[
   StyleBox["A",
    FontSlant->"Italic"], "^"]],
  CellChangeTimes->{{3.8113265575394135`*^9, 3.8113266208341584`*^9}, {
    3.8113268886705112`*^9, 3.8113269031313066`*^9}, 3.8113270406173744`*^9, {
    3.811330598918048*^9, 3.8113306162990384`*^9}, {3.811330646381595*^9, 
    3.8113306467325897`*^9}, {3.8113307587355585`*^9, 3.811330766603507*^9}},
  ExpressionUUID->"568e00c2-5224-459d-b371-51a0c9d7c706"],
 " acting on our vector ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["\[CapitalPsi]",
    FontWeight->"Bold"], 
   StyleBox["a",
    FontWeight->"Bold",
    FontSlant->"Italic"]]],
  CellChangeTimes->{{3.8113265575394135`*^9, 3.8113266208341584`*^9}, {
    3.8113268886705112`*^9, 3.8113269031313066`*^9}, 3.8113270406173744`*^9, {
    3.811330598918048*^9, 3.8113306162990384`*^9}, {3.811330646381595*^9, 
    3.8113306467325897`*^9}, {3.8113307587355585`*^9, 3.811330766603507*^9}},
  ExpressionUUID->"0af903ce-4883-4a58-9af3-67c585da9b7c"],
 " (which for example, might be a wavefunction) . Plugging equation (97) into \
equation (96), we obtain"
}], "Text",
 CellChangeTimes->{{3.8115021764106646`*^9, 3.8115022344720325`*^9}, {
  3.811502413401611*^9, 
  3.8115024160454683`*^9}},ExpressionUUID->"d73b8a4b-64a5-477d-9688-\
a32d7db2295e"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   OverscriptBox[
    StyleBox["A",
     FontSlant->"Italic"], "^"], 
   SubscriptBox[
    StyleBox["\[CapitalPsi]",
     FontWeight->"Bold"], 
    StyleBox["a",
     FontWeight->"Bold",
     FontSlant->"Italic"]]}], "=", 
  RowBox[{
   UnderscriptBox[
    OverscriptBox["\[Sum]", 
     StyleBox["n",
      FontSlant->"Italic"]], 
    RowBox[{
     StyleBox["j",
      FontSlant->"Italic"], "=", "1"}]], 
   RowBox[{
    UnderscriptBox[
     OverscriptBox["\[Sum]", 
      StyleBox["n",
       FontSlant->"Italic"]], 
     RowBox[{
      StyleBox["i",
       FontSlant->"Italic"], "=", "1"}]], 
    RowBox[{
     SubscriptBox[
      StyleBox["a",
       FontSlant->"Italic"], 
      StyleBox["j",
       FontSlant->"Italic"]], 
     SubscriptBox[
      StyleBox["A",
       FontSlant->"Italic"], 
      StyleBox["ij",
       FontSlant->"Italic"]], 
     SubscriptBox[
      StyleBox["\[Psi]",
       FontWeight->"Bold"], 
      StyleBox["i",
       FontWeight->"Bold",
       FontSlant->"Italic"]]}]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8113265575394135`*^9, 3.8113266208341584`*^9}, {
   3.8113268886705112`*^9, 3.8113269031313066`*^9}, 3.8113270406173744`*^9, {
   3.811330598918048*^9, 3.8113306162990384`*^9}, {3.811330646381595*^9, 
   3.8113306467325897`*^9}, {3.8113307587355585`*^9, 3.811330766603507*^9}, {
   3.8115022498525515`*^9, 3.8115022712851877`*^9}, 
   3.811502314017759*^9},ExpressionUUID->"808ab52e-f4da-47f7-a605-\
36f6778efa3f"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   OverscriptBox[
    StyleBox["A",
     FontSlant->"Italic"], "^"], 
   SubscriptBox[
    StyleBox["\[CapitalPsi]",
     FontWeight->"Bold"], 
    StyleBox["a",
     FontWeight->"Bold",
     FontSlant->"Italic"]]}], "=", 
  RowBox[{
   UnderscriptBox[
    OverscriptBox["\[Sum]", 
     StyleBox["n",
      FontSlant->"Italic"]], 
    RowBox[{
     StyleBox["i",
      FontSlant->"Italic"], "=", "1"}]], 
   RowBox[{
    SubscriptBox[
     StyleBox["\[Psi]",
      FontWeight->"Bold"], 
     StyleBox["i",
      FontWeight->"Bold",
      FontSlant->"Italic"]], 
    RowBox[{
     UnderscriptBox[
      OverscriptBox["\[Sum]", 
       StyleBox["n",
        FontSlant->"Italic"]], 
      RowBox[{
       StyleBox["j",
        FontSlant->"Italic"], "=", "1"}]], 
     RowBox[{
      SubscriptBox[
       StyleBox["a",
        FontSlant->"Italic"], 
       StyleBox["j",
        FontSlant->"Italic"]], 
      SubscriptBox[
       StyleBox["A",
        FontSlant->"Italic"], 
       StyleBox["ij",
        FontSlant->"Italic"]]}]}]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8113265575394135`*^9, 3.8113266208341584`*^9}, {
   3.8113268886705112`*^9, 3.8113269031313066`*^9}, 3.8113270406173744`*^9, {
   3.811330598918048*^9, 3.8113306162990384`*^9}, {3.811330646381595*^9, 
   3.8113306467325897`*^9}, {3.8113307587355585`*^9, 3.811330766603507*^9}, {
   3.8115022498525515`*^9, 
   3.8115023759138527`*^9}},ExpressionUUID->"377fe1b6-4ba7-460d-8ae6-\
ffa44e727c83"],

Cell[TextData[{
 "Let\[CloseCurlyQuote]s use the label ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["\[CapitalPsi]",
    FontWeight->"Bold"], 
   StyleBox["b",
    FontWeight->"Bold",
    FontSlant->"Italic"]]],
  CellChangeTimes->{{3.8113265575394135`*^9, 3.8113266208341584`*^9}, {
    3.8113268886705112`*^9, 3.8113269031313066`*^9}, 3.8113270406173744`*^9, {
    3.811330598918048*^9, 3.8113306162990384`*^9}, {3.811330646381595*^9, 
    3.8113306467325897`*^9}, {3.8113307587355585`*^9, 3.811330766603507*^9}},
  ExpressionUUID->"69df8b2c-598c-40d5-a13a-5cb0aa7eaf35"],
 " for our transformed vector that we obtain from ",
 Cell[BoxData[
  OverscriptBox[
   StyleBox["A",
    FontSlant->"Italic"], "^"]],
  CellChangeTimes->{{3.8113265575394135`*^9, 3.8113266208341584`*^9}, {
    3.8113268886705112`*^9, 3.8113269031313066`*^9}, 3.8113270406173744`*^9, {
    3.811330598918048*^9, 3.8113306162990384`*^9}, {3.811330646381595*^9, 
    3.8113306467325897`*^9}, {3.8113307587355585`*^9, 3.811330766603507*^9}},
  ExpressionUUID->"9c7df954-04da-4d95-9f21-f8afa87617da"],
 " acting on our vector ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["\[CapitalPsi]",
    FontWeight->"Bold"], 
   StyleBox["a",
    FontWeight->"Bold",
    FontSlant->"Italic"]]],
  CellChangeTimes->{{3.8113265575394135`*^9, 3.8113266208341584`*^9}, {
    3.8113268886705112`*^9, 3.8113269031313066`*^9}, 3.8113270406173744`*^9, {
    3.811330598918048*^9, 3.8113306162990384`*^9}, {3.811330646381595*^9, 
    3.8113306467325897`*^9}, {3.8113307587355585`*^9, 3.811330766603507*^9}},
  ExpressionUUID->"a53bb36d-6a17-45e9-9dc1-95e4d72238d0"],
 ", "
}], "Text",
 CellChangeTimes->{{3.8115024912068357`*^9, 
  3.811502540143784*^9}},ExpressionUUID->"4f7e9c6f-5f54-41f9-90dc-\
84bf52c870f5"],

Cell[BoxData[
 RowBox[{
  SubscriptBox[
   StyleBox["\[CapitalPsi]",
    FontWeight->"Bold"], 
   StyleBox["b",
    FontWeight->"Bold",
    FontSlant->"Italic"]], "=", 
  RowBox[{
   RowBox[{
    OverscriptBox[
     StyleBox["A",
      FontSlant->"Italic"], "^"], 
    SubscriptBox[
     StyleBox["\[CapitalPsi]",
      FontWeight->"Bold"], 
     StyleBox["a",
      FontWeight->"Bold",
      FontSlant->"Italic"]]}], "=", 
   RowBox[{
    UnderscriptBox[
     OverscriptBox["\[Sum]", 
      StyleBox["n",
       FontSlant->"Italic"]], 
     RowBox[{
      StyleBox["i",
       FontSlant->"Italic"], "=", "1"}]], 
    RowBox[{
     SubscriptBox[
      StyleBox["\[Psi]",
       FontWeight->"Bold"], 
      StyleBox["i",
       FontWeight->"Bold",
       FontSlant->"Italic"]], 
     RowBox[{
      UnderscriptBox[
       OverscriptBox["\[Sum]", 
        StyleBox["n",
         FontSlant->"Italic"]], 
       RowBox[{
        StyleBox["j",
         FontSlant->"Italic"], "=", "1"}]], 
      RowBox[{
       SubscriptBox[
        StyleBox["a",
         FontSlant->"Italic"], 
        StyleBox["j",
         FontSlant->"Italic"]], 
       SubscriptBox[
        StyleBox["A",
         FontSlant->"Italic"], 
        StyleBox["ij",
         FontSlant->"Italic"]]}]}]}]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8113265575394135`*^9, 3.8113266208341584`*^9}, {
   3.8113268886705112`*^9, 3.8113269031313066`*^9}, 3.8113270406173744`*^9, {
   3.811330598918048*^9, 3.8113306162990384`*^9}, {3.811330646381595*^9, 
   3.8113306467325897`*^9}, {3.8113307587355585`*^9, 3.811330766603507*^9}, {
   3.8115022498525515`*^9, 3.8115023759138527`*^9}, {3.811502546944206*^9, 
   3.8115025494918385`*^9}},ExpressionUUID->"d2c5ccb7-d40b-4d59-aff0-\
8a0ea96d9011"],

Cell["\<\
Remembering that we can write any generic vector as a linear combination of \
our basis vectors,\
\>", "Text",
 CellChangeTimes->{{3.8115025553748264`*^9, 
  3.8115025836996326`*^9}},ExpressionUUID->"982a26f7-223b-4ab7-8b16-\
a32ba4f01443"],

Cell[BoxData[
 RowBox[{
  StyleBox[
   SubscriptBox[
    StyleBox["\[CapitalPsi]",
     FontWeight->"Bold"], "b"],
   FontWeight->"Bold"], "=", 
  RowBox[{
   UnderscriptBox[
    OverscriptBox["\[Sum]", 
     StyleBox["n",
      FontSlant->"Italic"]], 
    RowBox[{
     StyleBox["i",
      FontSlant->"Italic"], "=", "1"}]], 
   RowBox[{
    SubscriptBox[
     StyleBox["b",
      FontSlant->"Italic"], 
     StyleBox["i",
      FontSlant->"Italic"]], 
    SubscriptBox[
     StyleBox["\[Psi]",
      FontWeight->"Bold"], 
     StyleBox["i",
      FontWeight->"Bold",
      FontSlant->"Italic"]]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8113265575394135`*^9, 3.8113266208341584`*^9}, {
  3.8113268886705112`*^9, 3.8113269031313066`*^9}, {3.8113270136420536`*^9, 
  3.811327061904248*^9}, {3.811329307606151*^9, 3.8113293101704955`*^9}, {
  3.8115026021772604`*^9, 
  3.8115026097515287`*^9}},ExpressionUUID->"f277d4bc-1426-419b-8dbe-\
aa8e89621e74"],

Cell["We see that", "Text",
 CellChangeTimes->{{3.8115026145396843`*^9, 
  3.8115026164373493`*^9}},ExpressionUUID->"298ad04d-1a57-4e1d-aff1-\
815ba6f226a2"],

Cell[BoxData[
 RowBox[{
  SubscriptBox[
   StyleBox["b",
    FontSlant->"Italic"], 
   StyleBox["i",
    FontSlant->"Italic"]], "=", 
  RowBox[{
   UnderscriptBox[
    OverscriptBox["\[Sum]", 
     StyleBox["n",
      FontSlant->"Italic"]], 
    RowBox[{
     StyleBox["j",
      FontSlant->"Italic"], "=", "1"}]], 
   RowBox[{
    SubscriptBox[
     StyleBox["a",
      FontSlant->"Italic"], 
     StyleBox["j",
      FontSlant->"Italic"]], 
    SubscriptBox[
     StyleBox["A",
      FontSlant->"Italic"], 
     StyleBox["ij",
      FontSlant->"Italic"]]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8113265575394135`*^9, 3.8113266208341584`*^9}, {
   3.8113268886705112`*^9, 3.8113269031313066`*^9}, 3.8113270406173744`*^9, {
   3.811330598918048*^9, 3.8113306162990384`*^9}, {3.811330646381595*^9, 
   3.8113306467325897`*^9}, {3.8113307587355585`*^9, 3.811330766603507*^9}, {
   3.8115022498525515`*^9, 3.8115023759138527`*^9}, {3.811502546944206*^9, 
   3.8115025494918385`*^9}, {3.8115026379709654`*^9, 
   3.8115026440756397`*^9}},ExpressionUUID->"da0f4062-c322-4dd1-8ca8-\
8fc6c879bc87"],

Cell[TextData[{
 "That is, the weighting factors for our new vector are given by the original \
weighting factors multiplied by the ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["A",
    FontSlant->"Italic"], 
   StyleBox["ij",
    FontSlant->"Italic"]]],
  CellChangeTimes->{{3.8113265575394135`*^9, 3.8113266208341584`*^9}, {
    3.8113268886705112`*^9, 3.8113269031313066`*^9}, 3.8113270406173744`*^9, {
    3.811330598918048*^9, 3.8113306162990384`*^9}, {3.811330646381595*^9, 
    3.8113306467325897`*^9}, {3.811330739744603*^9, 3.8113307427314014`*^9}, {
    3.811330835135107*^9, 3.811330835875268*^9}, 3.811501833540098*^9, {
    3.811501867015377*^9, 3.8115019239986753`*^9}},ExpressionUUID->
  "0ca0dd04-e65d-4a24-9a85-4055d8a505a6"],
 " values that give the component of ",
 Cell[BoxData[
  RowBox[{
   OverscriptBox[
    StyleBox["A",
     FontSlant->"Italic"], "^"], 
   SubscriptBox[
    StyleBox["\[CapitalPsi]",
     FontWeight->"Bold"], 
    StyleBox["a",
     FontWeight->"Bold",
     FontSlant->"Italic"]]}]],
  CellChangeTimes->{{3.8113265575394135`*^9, 3.8113266208341584`*^9}, {
    3.8113268886705112`*^9, 3.8113269031313066`*^9}, 3.8113270406173744`*^9, {
    3.811330598918048*^9, 3.8113306162990384`*^9}, {3.811330646381595*^9, 
    3.8113306467325897`*^9}, {3.8113307587355585`*^9, 3.811330766603507*^9}, {
    3.8115022498525515`*^9, 3.8115023759138527`*^9}},ExpressionUUID->
  "ba07742e-517e-4100-83a7-c52b292f99af"],
 " at each value of ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["\[Psi]",
    FontWeight->"Bold"], 
   StyleBox["i",
    FontWeight->"Bold",
    FontSlant->"Italic"]]],
  CellChangeTimes->{{3.8113265575394135`*^9, 3.8113266208341584`*^9}, {
    3.8113268886705112`*^9, 3.8113269031313066`*^9}, 3.8113270406173744`*^9, {
    3.811330598918048*^9, 3.8113306162990384`*^9}, {3.811330646381595*^9, 
    3.8113306467325897`*^9}, {3.811330739744603*^9, 3.8113307427314014`*^9}, {
    3.811330835135107*^9, 3.811330835875268*^9}, 3.811501833540098*^9, {
    3.811501867015377*^9, 3.8115019239986753`*^9}},ExpressionUUID->
  "4e920127-c425-4953-b1c1-45e538c29f65"],
 ". We can visualize this result in matrix form as well, "
}], "Text",
 CellChangeTimes->{{3.811502650944788*^9, 3.8115027338389187`*^9}, {
  3.8115027764988213`*^9, 3.811502785864465*^9}, {3.811513723598948*^9, 
  3.8115137406171827`*^9}},ExpressionUUID->"42002fd0-d386-4e4d-959b-\
b2e09593f8a2"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(", "\[NoBreak]", GridBox[{
     {
      SubscriptBox[
       StyleBox["b",
        FontSlant->"Italic"], "1"]},
     {
      SubscriptBox[
       StyleBox["b",
        FontSlant->"Italic"], "2"]},
     {GridBox[{
        {"..."},
        {
         SubscriptBox[
          StyleBox["b",
           FontSlant->"Italic"], 
          StyleBox["n",
           FontSlant->"Italic"]]}
       }]}
    }], "\[NoBreak]", ")"}], "=", 
  RowBox[{
   RowBox[{"(", "\[NoBreak]", GridBox[{
      {
       SubscriptBox[
        StyleBox["A",
         FontSlant->"Italic"], "11"], 
       SubscriptBox[
        StyleBox["A",
         FontSlant->"Italic"], "12"], "...", 
       SubscriptBox[
        StyleBox["A",
         FontSlant->"Italic"], 
        RowBox[{"1", 
         StyleBox["n",
          FontSlant->"Italic"]}]]},
      {
       SubscriptBox[
        StyleBox["A",
         FontSlant->"Italic"], "21"], 
       SubscriptBox[
        StyleBox["A",
         FontSlant->"Italic"], "22"], "...", 
       SubscriptBox[
        StyleBox["A",
         FontSlant->"Italic"], 
        RowBox[{"2", 
         StyleBox["n",
          FontSlant->"Italic"]}]]},
      {"...", "...", "...", "..."},
      {
       SubscriptBox[
        StyleBox["A",
         FontSlant->"Italic"], 
        StyleBox[
         RowBox[{
          StyleBox["n",
           FontSlant->"Italic"], "1"}]]], 
       SubscriptBox[
        StyleBox["A",
         FontSlant->"Italic"], 
        StyleBox[
         RowBox[{
          StyleBox["n",
           FontSlant->"Italic"], "2"}]]], "...", 
       SubscriptBox[
        StyleBox["A",
         FontSlant->"Italic"], 
        StyleBox["nn",
         FontSlant->"Italic"]]}
     }], "\[NoBreak]", ")"}], 
   RowBox[{"(", "\[NoBreak]", GridBox[{
      {
       SubscriptBox[
        StyleBox["a",
         FontSlant->"Italic"], "1"]},
      {
       SubscriptBox[
        StyleBox["a",
         FontSlant->"Italic"], "2"]},
      {GridBox[{
         {"..."},
         {
          SubscriptBox[
           StyleBox["a",
            FontSlant->"Italic"], 
           StyleBox["n",
            FontSlant->"Italic"]]}
        }]}
     }], "\[NoBreak]", ")"}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.811253718311788*^9, 3.8112538382526913`*^9}, {
  3.8113202158202267`*^9, 3.8113202295187783`*^9}, {3.811502813748584*^9, 
  3.81150298489917*^9}, {3.8115030155746*^9, 3.811503044981599*^9}, {
  3.8115033620226526`*^9, 3.8115033621488113`*^9}, {3.811513754216603*^9, 
  3.8115137911005745`*^9}},ExpressionUUID->"3b13cc77-eac9-4730-9e51-\
7d25d327debd"],

Cell[TextData[{
 "Now we must address the question of how we find the values of ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["A",
    FontSlant->"Italic"], 
   StyleBox["ij",
    FontSlant->"Italic"]]],
  CellChangeTimes->{{3.8113265575394135`*^9, 3.8113266208341584`*^9}, {
    3.8113268886705112`*^9, 3.8113269031313066`*^9}, 3.8113270406173744`*^9, {
    3.811330598918048*^9, 3.8113306162990384`*^9}, {3.811330646381595*^9, 
    3.8113306467325897`*^9}, {3.8113307587355585`*^9, 3.811330766603507*^9}, {
    3.8115022498525515`*^9, 3.8115023759138527`*^9}, {3.811502546944206*^9, 
    3.8115025494918385`*^9}, {3.8115026379709654`*^9, 
    3.8115026440756397`*^9}},ExpressionUUID->
  "5bace835-d5cf-4a91-b35c-0744915aa67d"],
 ". Remember that we defined ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["A",
    FontSlant->"Italic"], 
   StyleBox["ij",
    FontSlant->"Italic"]]],
  CellChangeTimes->{{3.8113265575394135`*^9, 3.8113266208341584`*^9}, {
    3.8113268886705112`*^9, 3.8113269031313066`*^9}, 3.8113270406173744`*^9, {
    3.811330598918048*^9, 3.8113306162990384`*^9}, {3.811330646381595*^9, 
    3.8113306467325897`*^9}, {3.8113307587355585`*^9, 3.811330766603507*^9}, {
    3.8115022498525515`*^9, 3.8115023759138527`*^9}, {3.811502546944206*^9, 
    3.8115025494918385`*^9}, {3.8115026379709654`*^9, 
    3.8115026440756397`*^9}},ExpressionUUID->
  "871d89a4-dfc7-441d-b32f-721434dcd1a2"],
 " in the equation"
}], "Text",
 CellChangeTimes->{{3.811513848683657*^9, 3.8115138616231375`*^9}, {
  3.8115139008056555`*^9, 
  3.811513935314516*^9}},ExpressionUUID->"0442e9ec-3e29-4c1e-8ac4-\
77ee934ceaf1"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   OverscriptBox[
    StyleBox["A",
     FontSlant->"Italic"], "^"], 
   SubscriptBox[
    StyleBox["\[Psi]",
     FontWeight->"Bold"], 
    StyleBox["j",
     FontWeight->"Bold",
     FontSlant->"Italic"]]}], "=", 
  RowBox[{
   UnderscriptBox[
    OverscriptBox["\[Sum]", 
     StyleBox["n",
      FontSlant->"Italic"]], 
    RowBox[{
     StyleBox["i",
      FontSlant->"Italic"], "=", "1"}]], 
   RowBox[{
    SubscriptBox[
     StyleBox["A",
      FontSlant->"Italic"], 
     StyleBox["ij",
      FontSlant->"Italic"]], 
    SubscriptBox[
     StyleBox["\[Psi]",
      FontWeight->"Bold"], 
     StyleBox["i",
      FontWeight->"Bold",
      FontSlant->"Italic"]]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8113265575394135`*^9, 3.8113266208341584`*^9}, {
   3.8113268886705112`*^9, 3.8113269031313066`*^9}, 3.8113270406173744`*^9, {
   3.811330598918048*^9, 3.8113306162990384`*^9}, {3.811330646381595*^9, 
   3.8113306467325897`*^9}, {3.811330739744603*^9, 3.8113307427314014`*^9}, {
   3.811330835135107*^9, 3.811330835875268*^9}, 3.811501833540098*^9, {
   3.811501867015377*^9, 
   3.8115019239986753`*^9}},ExpressionUUID->"89588396-988e-4832-8df0-\
a04605d471d2"],

Cell[TextData[{
 "It turns out if we take the inner product of equation (104) with ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["\[Psi]",
    FontWeight->"Bold"], 
   StyleBox["i",
    FontWeight->"Bold",
    FontSlant->"Italic"]]],
  CellChangeTimes->{{3.8113265575394135`*^9, 3.8113266208341584`*^9}, {
    3.8113268886705112`*^9, 3.8113269031313066`*^9}, 3.8113270406173744`*^9, {
    3.811330598918048*^9, 3.8113306162990384`*^9}, {3.811330646381595*^9, 
    3.8113306467325897`*^9}, {3.8113307587355585`*^9, 3.811330766603507*^9}, {
    3.8115022498525515`*^9, 3.8115023759138527`*^9}, {3.811502546944206*^9, 
    3.8115025494918385`*^9}},ExpressionUUID->
  "70d7e6e9-df88-4362-b7b8-dc08778cd4fb"],
 ", we find"
}], "Text",
 CellChangeTimes->{{3.8115139125266695`*^9, 
  3.8115139868324833`*^9}},ExpressionUUID->"ccd0de25-d8af-4413-ac91-\
a1a855d6b574"],

Cell[BoxData[
 RowBox[{
  RowBox[{"\[LeftAngleBracket]", 
   RowBox[{
    StyleBox[
     SubscriptBox[
      StyleBox["\[Psi]",
       FontWeight->"Bold"], 
      StyleBox["i",
       FontWeight->"Bold",
       FontSlant->"Italic"]],
     FontWeight->"Bold"], "|", 
    RowBox[{
     OverscriptBox[
      StyleBox["A",
       FontSlant->"Italic"], "^"], 
     SubscriptBox[
      StyleBox["\[Psi]",
       FontWeight->"Bold"], 
      StyleBox["j",
       FontWeight->"Bold",
       FontSlant->"Italic"]]}]}], "\[RightAngleBracket]"}], "=", 
  RowBox[{"\[LeftAngleBracket]", 
   RowBox[{
    StyleBox[
     SubscriptBox[
      StyleBox["\[Psi]",
       FontWeight->"Bold"], 
      StyleBox["i",
       FontWeight->"Bold",
       FontSlant->"Italic"]],
     FontWeight->"Bold"], "|", 
    RowBox[{
     UnderscriptBox[
      OverscriptBox["\[Sum]", 
       StyleBox["n",
        FontSlant->"Italic"]], 
      RowBox[{
       StyleBox["k",
        FontSlant->"Italic"], "=", "1"}]], 
     RowBox[{
      SubscriptBox[
       StyleBox["A",
        FontSlant->"Italic"], 
       StyleBox["kj",
        FontSlant->"Italic"]], 
      SubscriptBox[
       StyleBox["\[Psi]",
        FontWeight->"Bold"], 
