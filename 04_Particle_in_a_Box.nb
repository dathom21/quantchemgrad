Cell[TextData[{
 "The actual experimental value is roughly ",
 Cell[BoxData[
  RowBox[{"4.61", "\[Times]", " ", 
   SuperscriptBox["10", "4"], " ", 
   SuperscriptBox["cm", 
    RowBox[{"-", "1"}]]}]],
  CellChangeTimes->{{3.808746256152788*^9, 3.8087463361701956`*^9}, {
   3.808746369787464*^9, 3.808746370563246*^9}, {3.8093594081314893`*^9, 
   3.8093594420949144`*^9}, {3.8093596524208345`*^9, 
   3.8093596588003235`*^9}, {3.8093597716176004`*^9, 
   3.8093598903575935`*^9}, {3.8093599460170126`*^9, 3.809359970319847*^9}},
  ExpressionUUID->"4a327345-eeb8-49f5-9dcc-00e89d143c2f"],
 ", so the approximation is not too far off (although not good enough for \
spectroscopic prediction). Below is an experimental measurement of direct \
absorption of ",
 StyleBox["trans",
  FontSlant->"Italic"],
 "-1,3-butadiene in the expected transition range:"
}], "Text",
