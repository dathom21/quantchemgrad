Cell[TextData[{
 "Remember that the probability of finding the system in state |",
 StyleBox["m",
  FontSlant->"Italic"],
 "\[RightAngleBracket] at time ",
 StyleBox["t",
  FontSlant->"Italic"],
 " is given by the absolute square of the weighting coefficient,"
}], "Text",
 CellChangeTimes->{{3.8154857068688464`*^9, 
  3.8154857607790437`*^9}},ExpressionUUID->"7ab5c390-b312-463a-9088-\
c42d44e30a1b"],

