     RowBox[{"(", "0", ")"}]], "+", 
    SuperscriptBox["\[Psi]", 
     RowBox[{"(", "1", ")"}]], "+", 
    SuperscriptBox["\[Psi]", 
     RowBox[{"(", "2", ")"}]], "+"}], "..."}]}]], "DisplayFormulaNumbered",
