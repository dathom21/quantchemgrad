         StyleBox["H",
          FontSlant->"Italic"], 
         RowBox[{"2", 
          StyleBox["N",
           FontSlant->"Italic"]}]], "-", 
        RowBox[{
         SubscriptBox[
          StyleBox["E",
           FontSlant->"Italic"], "\[CapitalPhi]"], 
         SubscriptBox[
          StyleBox["S",
           FontSlant->"Italic"], 
          RowBox[{"2", 
           StyleBox["N",
            FontSlant->"Italic"]}]]}]}], "...", 
       RowBox[{
        SubscriptBox[
         StyleBox["H",
          FontSlant->"Italic"], 
         StyleBox["NN",
          FontSlant->"Italic"]], "-", 
