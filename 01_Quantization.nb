Cell[CellGroupData[{

Cell["The Rayleigh-Jeans Law (Spectral Radiance)", "Subsection",
 CellChangeTimes->{{3.80564877740528*^9, 3.805648783292946*^9}, {
  3.8063382360446353`*^9, 
  3.8063382409887867`*^9}},ExpressionUUID->"e90b2c58-c002-4e59-a063-\
525b271bb3a2"],

Cell["\<\
The Rayleigh-Jeans law gives the dependence of light emission B on wavelength \
\[Lambda] and temperature T,\
\>", "Text",
 CellChangeTimes->{{3.8056491635971794`*^9, 3.8056492185507445`*^9}, {
  3.805649280130458*^9, 3.8056493961515656`*^9}, {3.8056494363375573`*^9, 
  3.805649518161705*^9}, {3.806338243687194*^9, 3.806338259473058*^9}, {
  3.806339494444642*^9, 3.806339573235202*^9}, {3.806339649678943*^9, 
  3.806339696007042*^9}, {3.8063400858966846`*^9, 3.8063401271396117`*^9}, {
  3.8064049365952606`*^9, 3.806404942580722*^9}, {3.8394261182684946`*^9, 
  3.8394261219245443`*^9}, {3.914237386521344*^9, 3.914237397725523*^9}, {
  3.9338594653279305`*^9, 
  3.933859470324671*^9}},ExpressionUUID->"526b7a11-1c5d-274a-9f94-\
c3819e4d09c8"],

Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{"B", "(", 
    RowBox[{"\[Lambda]", ",", 
     StyleBox["T",
      FontSlant->"Italic"]}], ")"}], " ", "=", " ", 
   FractionBox[
    RowBox[{"2", "c", " ", 
     SubscriptBox["k", "B"], "T"}], 
    SuperscriptBox["\[Lambda]", "4"]]}], 
  TraditionalForm]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8394261265865235`*^9, 
  3.8394261716976395`*^9}},ExpressionUUID->"06e290d6-bcd9-44a4-8d6c-\
2c7029ea3413"],

Cell[TextData[{
 "Notice that as \[Lambda] \[RightArrow] 0, ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["B", "\[Lambda]"], TraditionalForm]],ExpressionUUID->
  "58531950-bdb8-4848-840d-984c3958b913"],
 "(T) \[RightArrow] \[Infinity], which gives unphysical infinite emission of \
short-wavelength (high-energy) light. The Rayleigh-Jeans law is depicted as \
the red curve in Figure 1.3."
}], "Text",
 CellChangeTimes->{{3.8056491635971794`*^9, 3.8056492185507445`*^9}, {
   3.805649280130458*^9, 3.8056493961515656`*^9}, {3.8056494363375573`*^9, 
   3.805649518161705*^9}, {3.806338243687194*^9, 3.806338259473058*^9}, {
   3.806339494444642*^9, 3.806339573235202*^9}, {3.806339649678943*^9, 
   3.806339696007042*^9}, {3.8063400858966846`*^9, 3.8063401271396117`*^9}, {
   3.8064049365952606`*^9, 3.806404942580722*^9}, {3.8394261182684946`*^9, 
   3.8394261219245443`*^9}, {3.914237386521344*^9, 3.914237397725523*^9}, 
   3.9338594757339535`*^9},ExpressionUUID->"ea39bd11-eb8c-4d1f-8220-\
b0a461b9ee8e"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Planck\[CloseCurlyQuote]s Law ", "Subsection",
 CellChangeTimes->{{3.80564877740528*^9, 3.805648783292946*^9}, {
  3.8063382360446353`*^9, 3.8063382409887867`*^9}, {3.806340782322491*^9, 
  3.8063407890823245`*^9}},ExpressionUUID->"b0cc7573-e358-431c-bfdb-\
2327551a8bc8"],

Cell["\<\
To address the \[OpenCurlyDoubleQuote]ultraviolet catastrophe\
\[CloseCurlyDoubleQuote], Planck proposed that the energies of the \
oscillating electrons that yielded radiation (light) could only take on \
specific values (rather than continuous values):\
\>", "Text",
 CellChangeTimes->{{3.8063408651333733`*^9, 3.8063408781424675`*^9}, {
   3.806340938780123*^9, 3.806340959581731*^9}, {3.8064042436591787`*^9, 
   3.8064042470117593`*^9}, {3.8064042771623735`*^9, 
   3.8064044620453463`*^9}, {3.8064045487786055`*^9, 3.8064045552391458`*^9}, 
   3.8064045862349367`*^9, {3.8064047544184823`*^9, 3.80640478604101*^9}, {
   3.806404830865034*^9, 3.806404902267784*^9}, {3.8064049606010866`*^9, 
   3.8064050083494554`*^9}, {3.8064065993228536`*^9, 
   3.8064066000833454`*^9}, {3.8064073872539625`*^9, 
   3.8064074100849886`*^9}, {3.839426511959313*^9, 3.839426513646513*^9}, {
   3.8394265438259974`*^9, 
   3.8394265461843133`*^9}},ExpressionUUID->"0c5d52b9-adb4-4bf6-bb88-\
ae8c03f9ee00"],

