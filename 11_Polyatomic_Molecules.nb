Cell[CellGroupData[{

Cell["\<\
Linear Combination of Atomic Orbitals in Polyatomic Molecules\
\>", "Subsection",
 CellChangeTimes->{{3.8142712023190517`*^9, 
  3.8142712174377203`*^9}},ExpressionUUID->"02aa7b64-827e-45c7-8e79-\
350616797bbb"],

Cell["\<\
Now that we have examined diatomic molecules in some detail using molecular \
orbital theory, we must now consider how we can represent the molecular \
orbitals of polyatomic molecules. Let\[CloseCurlyQuote]s review our linear \
combination of atomic orbitals approach. We want to write our molecular \
orbitals as a linear combination of all of our atomic orbitals,\
\>", "Text",
 CellChangeTimes->{{3.8142063905679216`*^9, 
  3.8142065303123183`*^9}},ExpressionUUID->"81816f7e-9e52-430d-80d4-\
97f8e4074fe1"],

Cell[BoxData[
 RowBox[{
  SubscriptBox["\[Psi]", 
   StyleBox["e",
    FontSlant->"Italic"]], "=", 
  RowBox[{
   RowBox[{
    RowBox[{
     SubscriptBox[
      StyleBox["c",
       FontSlant->"Italic"], "1"], 
     SubscriptBox["\[Phi]", 
      RowBox[{"1", 
       SubscriptBox[
        StyleBox["s",
         FontSlant->"Italic"], 
        StyleBox["A",
         FontSlant->"Italic"]]}]]}], "+", 
    RowBox[{
     SubscriptBox[
      StyleBox["c",
       FontSlant->"Italic"], "2"], 
     SubscriptBox["\[Phi]", 
      RowBox[{"1", 
       SubscriptBox[
        StyleBox["s",
         FontSlant->"Italic"], 
        StyleBox["B",
         FontSlant->"Italic"]]}]]}], "+", 
    RowBox[{
     SubscriptBox[
      StyleBox["c",
       FontSlant->"Italic"], "3"], 
     SubscriptBox["\[Phi]", 
      RowBox[{"1", 
       SubscriptBox[
        StyleBox["s",
         FontSlant->"Italic"], 
        StyleBox["C",
         FontSlant->"Italic"]]}]]}], "+", 
    RowBox[{
     SubscriptBox[
      StyleBox["c",
       FontSlant->"Italic"], "4"], 
     SubscriptBox["\[Phi]", 
      RowBox[{"2", 
       SubscriptBox[
        StyleBox["s",
         FontSlant->"Italic"], 
        StyleBox["A",
         FontSlant->"Italic"]]}]]}], "+", 
    RowBox[{
     SubscriptBox[
      StyleBox["c",
       FontSlant->"Italic"], "5"], 
     SubscriptBox["\[Phi]", 
      RowBox[{"2", 
       SubscriptBox[
        StyleBox["s",
         FontSlant->"Italic"], 
        StyleBox["B",
         FontSlant->"Italic"]]}]]}], "+", 
    RowBox[{
     SubscriptBox[
      StyleBox["c",
       FontSlant->"Italic"], "6"], 
     SubscriptBox["\[Phi]", 
      RowBox[{"2", 
       SubscriptBox[
        StyleBox["s",
         FontSlant->"Italic"], 
        StyleBox["C",
         FontSlant->"Italic"]]}]]}], "+", 
    RowBox[{
     SubscriptBox[
      StyleBox["c",
       FontSlant->"Italic"], "7"], 
     SubscriptBox["\[Phi]", 
      RowBox[{"2", 
       SubscriptBox[
        StyleBox["p",
         FontSlant->"Italic"], 
        StyleBox["zA",
         FontSlant->"Italic"]]}]]}], "+", 
    RowBox[{
     SubscriptBox[
      StyleBox["c",
       FontSlant->"Italic"], "8"], 
     SubscriptBox["\[Phi]", 
      RowBox[{"2", 
       SubscriptBox[
