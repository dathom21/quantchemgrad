Cell[TextData[{
 "Now, if we replace ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Psi]", "0"], TraditionalForm]],ExpressionUUID->
  "de9b6750-69d8-854d-9a20-e10764ed5dfd"],
 " in equation (11) with our trial wavefunction \[Phi], we obtain"
}], "Text",
 CellChangeTimes->{{3.811594572037122*^9, 3.8115946386289625`*^9}, {
  3.936279766490673*^9, 
