  3.917086509966265*^9}},ExpressionUUID->"abe6d713-d7c4-4f8b-a636-\
2159a292d6d4"],

Cell[TextData[{
 "Notably, the spherical harmonics ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubsuperscriptBox[
     StyleBox["Y",
      FontSlant->"Italic"], 
     StyleBox["l",
      FontSlant->"Italic"], 
     SubscriptBox[
      StyleBox["m",
       FontSlant->"Italic"], "l"]], "(", 
    RowBox[{"\[Theta]", ",", "\[Phi]"}], ")"}], TraditionalForm]],
  CellChangeTimes->{{3.8100544880652375`*^9, 3.8100545041200957`*^9}, {
    3.810054632482561*^9, 3.8100546606919527`*^9}, {3.810054738405748*^9, 
    3.810054754160844*^9}, {3.810055496888957*^9, 3.810055644063492*^9}, {
    3.8101099522060614`*^9, 3.8101100508523717`*^9}, {3.8101101194750385`*^9, 
    3.8101101642963843`*^9}, {3.8107127659519644`*^9, 3.810712781977992*^9}, {
    3.8107128863205147`*^9, 3.8107129246267147`*^9}, 3.810712975971156*^9, 
    3.8107130396874857`*^9, {3.810713072953952*^9, 3.810713077029566*^9}, {
    3.8107138654100857`*^9, 3.810713907959445*^9}, 3.810714092835499*^9, {
    3.8107142057542086`*^9, 3.8107142281878614`*^9}},ExpressionUUID->
  "e43efc11-d943-434b-a396-ee90b0a53847"],
 " are ",
 StyleBox["not",
  FontWeight->"Bold"],
 " eigenfunctions of the other angular momentum component operators, ",
 Cell[BoxData[
  SubscriptBox[
   OverscriptBox[
    StyleBox["L",
     FontSlant->"Italic"], "^"], 
   StyleBox["x",
    FontSlant->"Italic"]]],
  CellChangeTimes->{{3.8100544880652375`*^9, 3.8100545041200957`*^9}, {
   3.810054632482561*^9, 3.8100546606919527`*^9}, {3.810054738405748*^9, 
   3.810054754160844*^9}, {3.810055496888957*^9, 3.810055644063492*^9}, {
   3.8101099522060614`*^9, 3.8101100508523717`*^9}, {3.8101101194750385`*^9, 
   3.810110136121354*^9}, {3.8107126867697287`*^9, 3.810712741604373*^9}, {
   3.810712809473565*^9, 3.810712872371795*^9}, {3.8107129714133415`*^9, 
   3.8107130201357374`*^9}},ExpressionUUID->
  "6903e5ff-3083-4f76-8f62-cfa606c368f2"],
 " and ",
 Cell[BoxData[
  SubscriptBox[
   OverscriptBox[
    StyleBox["L",
     FontSlant->"Italic"], "^"], 
   StyleBox["y",
    FontSlant->"Italic"]]],
  CellChangeTimes->{{3.8100544880652375`*^9, 3.8100545041200957`*^9}, {
   3.810054632482561*^9, 3.8100546606919527`*^9}, {3.810054738405748*^9, 
   3.810054754160844*^9}, {3.810055496888957*^9, 3.810055644063492*^9}, {
   3.8101099522060614`*^9, 3.8101100508523717`*^9}, {3.8101101194750385`*^9, 
   3.810110136121354*^9}, {3.8107126867697287`*^9, 3.810712741604373*^9}, {
   3.810712809473565*^9, 3.810712872371795*^9}, {3.8107129714133415`*^9, 
   3.8107130201357374`*^9}},ExpressionUUID->
  "76c56b47-d5e9-445f-be09-5f6add62e6f3"],
 ". Keep in mind that if there is no external potential (e.g., an electric or \
magnetic field), the choice of the direction of the ",
 StyleBox["z-",
  FontSlant->"Italic"],
 "axis is arbitrary."
}], "Text",
 CellChangeTimes->{{3.810714553599968*^9, 3.8107146492302055`*^9}, {
  3.8421004661315513`*^9, 3.842100478156266*^9}, {3.91708651427302*^9, 
  3.917086514582859*^9}},ExpressionUUID->"8b978e7b-e0f8-4b62-b383-\
29fd619080b6"],

Cell[TextData[{
 "We have now shown that the spherical harmonics ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubsuperscriptBox[
     StyleBox["Y",
      FontSlant->"Italic"], 
     StyleBox["l",
      FontSlant->"Italic"], 
     SubscriptBox[
      StyleBox["m",
       FontSlant->"Italic"], "l"]], "(", 
    RowBox[{"\[Theta]", ",", "\[Phi]"}], ")"}], TraditionalForm]],
  CellChangeTimes->{{3.8100544880652375`*^9, 3.8100545041200957`*^9}, {
    3.810054632482561*^9, 3.8100546606919527`*^9}, {3.810054738405748*^9, 
    3.810054754160844*^9}, {3.810055496888957*^9, 3.810055644063492*^9}, {
    3.8101099522060614`*^9, 3.8101100508523717`*^9}, {3.8101101194750385`*^9, 
    3.8101101642963843`*^9}, {3.8107127659519644`*^9, 3.810712781977992*^9}, {
    3.8107128863205147`*^9, 3.8107129246267147`*^9}, 3.810712975971156*^9, 
    3.8107130396874857`*^9, {3.810713072953952*^9, 3.810713077029566*^9}, {
    3.8107138654100857`*^9, 3.810713907959445*^9}, 3.810714092835499*^9, {
    3.8107142057542086`*^9, 3.8107142281878614`*^9}},ExpressionUUID->
  "121b25c4-1753-476f-ae83-384ccb11ea12"],
 " are eigenfunctions of both the operator for the square of the angular \
momentum ",
 Cell[BoxData[
  SuperscriptBox[
   OverscriptBox[
    StyleBox["L",
     FontSlant->"Italic"], "^"], "2"]],
  CellChangeTimes->{{3.810112811439228*^9, 3.8101128248442793`*^9}, {
    3.810479494926491*^9, 3.8104795038498344`*^9}, {3.810479572543576*^9, 
    3.8104796147383184`*^9}, {3.8104802055659895`*^9, 
    3.8104802433915305`*^9}, {3.8104802785189395`*^9, 
    3.8104802814214115`*^9}, {3.810480477782269*^9, 3.8104805471507206`*^9}, {
    3.8104805927965565`*^9, 3.810480633017248*^9}, {3.8104807595294323`*^9, 
    3.8104809538100047`*^9}, {3.8104811300285854`*^9, 
    3.8104811403007636`*^9}, {3.8104812580010843`*^9, 
    3.8104813317580833`*^9}, {3.81048146789211*^9, 3.8104815557630205`*^9}, {
    3.8104817202872114`*^9, 3.8104817438715935`*^9}, 3.810481790764664*^9, 
    3.810481836241686*^9, {3.810481926951917*^9, 3.810481935802024*^9}, {
    3.8106609069078913`*^9, 3.81066090872985*^9}, {3.8106610360496655`*^9, 
    3.8106610794321012`*^9}, {3.8106611250786457`*^9, 
    3.8106611896874313`*^9}},ExpressionUUID->
  "7c8d8791-fe9e-4f87-8706-c242f8da149d"],
 " and the operator for the ",
 StyleBox["z",
  FontSlant->"Italic"],
 "-component of the angular momentum  ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox[
    OverscriptBox[
     StyleBox["L",
      FontSlant->"Italic"], "^"],
    FontSlant->"Italic"], 
   StyleBox["z",
    FontSlant->"Italic"]]],
  CellChangeTimes->{{3.8100544880652375`*^9, 3.8100545041200957`*^9}, {
    3.810054632482561*^9, 3.8100546606919527`*^9}, {3.810054738405748*^9, 
    3.810054754160844*^9}, {3.810055496888957*^9, 3.810055644063492*^9}, {
    3.8101099522060614`*^9, 3.8101100508523717`*^9}, {3.8101101194750385`*^9, 
    3.8101101642963843`*^9}, {3.8107127659519644`*^9, 3.810712781977992*^9}, {
    3.8107128863205147`*^9, 3.8107129246267147`*^9}, 3.810712975971156*^9, 
    3.8107130396874857`*^9, {3.810713072953952*^9, 3.810713077029566*^9}, {
    3.8107138654100857`*^9, 3.810713907959445*^9}, 3.810714092835499*^9, {
    3.8107142057542086`*^9, 3.8107142281878614`*^9}},ExpressionUUID->
  "90ec4207-579f-4cf5-8a2f-0c2164ad5998"],
 ". Thus, we can measure both values with infinite precision for a given \
solution of the angular equation ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubsuperscriptBox[
     StyleBox["Y",
      FontSlant->"Italic"], 
     StyleBox["l",
      FontSlant->"Italic"], 
     SubscriptBox[
      StyleBox["m",
       FontSlant->"Italic"], "l"]], "(", 
    RowBox[{"\[Theta]", ",", "\[Phi]"}], ")"}], TraditionalForm]],
  CellChangeTimes->{{3.8100544880652375`*^9, 3.8100545041200957`*^9}, {
    3.810054632482561*^9, 3.8100546606919527`*^9}, {3.810054738405748*^9, 
    3.810054754160844*^9}, {3.810055496888957*^9, 3.810055644063492*^9}, {
    3.8101099522060614`*^9, 3.8101100508523717`*^9}, {3.8101101194750385`*^9, 
    3.8101101642963843`*^9}, {3.8107127659519644`*^9, 3.810712781977992*^9}, {
    3.8107128863205147`*^9, 3.8107129246267147`*^9}, 3.810712975971156*^9, 
    3.8107130396874857`*^9, {3.810713072953952*^9, 3.810713077029566*^9}, {
    3.8107138654100857`*^9, 3.810713907959445*^9}, 3.810714092835499*^9, {
    3.8107142057542086`*^9, 3.8107142281878614`*^9}},ExpressionUUID->
  "75f431ec-9728-4083-96ea-79a402edda15"],
 " , which indicates that these operators commute. We can in fact show that \
the commutator of these operators is zero,"
}], "Text",
 CellChangeTimes->{{3.8107147772554345`*^9, 3.810714813185395*^9}, {
  3.8107148457228603`*^9, 3.810714971581853*^9}, {3.9170865257206526`*^9, 
  3.9170865694897795`*^9}},ExpressionUUID->"bbf73ba0-764e-424c-bf07-\
eb1e3e30d8d9"],

Cell[BoxData[
 RowBox[{
  RowBox[{"[", 
   RowBox[{
    SuperscriptBox[
     OverscriptBox[
      StyleBox["L",
       FontSlant->"Italic"], "^"], "2"], ",", 
    SubscriptBox[
     StyleBox[
      OverscriptBox[
       StyleBox["L",
        FontSlant->"Italic"], "^"],
      FontSlant->"Italic"], 
     StyleBox["z",
      FontSlant->"Italic"]]}], "]"}], "=", "0"}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.810112811439228*^9, 3.8101128248442793`*^9}, {
   3.810479494926491*^9, 3.8104795038498344`*^9}, {3.810479572543576*^9, 
   3.8104796147383184`*^9}, {3.8104802055659895`*^9, 
   3.8104802433915305`*^9}, {3.8104802785189395`*^9, 
   3.8104802814214115`*^9}, {3.810480477782269*^9, 3.8104805471507206`*^9}, {
   3.8104805927965565`*^9, 3.810480633017248*^9}, {3.8104807595294323`*^9, 
   3.8104809538100047`*^9}, {3.8104811300285854`*^9, 
   3.8104811403007636`*^9}, {3.8104812580010843`*^9, 
   3.8104813317580833`*^9}, {3.81048146789211*^9, 3.8104815557630205`*^9}, {
   3.8104817202872114`*^9, 3.8104817438715935`*^9}, 3.810481790764664*^9, 
   3.810481836241686*^9, {3.810481926951917*^9, 3.810481935802024*^9}, {
   3.8106608387005043`*^9, 3.8106608893247347`*^9}, {3.810715008376715*^9, 
   3.810715021169223*^9}},ExpressionUUID->"bda92fde-3e9e-402d-80a7-\
6f0dd035213a"],

Cell[TextData[{
 "The square of the angular momentum also commutes with ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox[
    OverscriptBox[
     StyleBox["L",
      FontSlant->"Italic"], "^"],
    FontSlant->"Italic"], 
   StyleBox["x",
    FontSlant->"Italic"]]],
  CellChangeTimes->{{3.810112811439228*^9, 3.8101128248442793`*^9}, {
    3.810479494926491*^9, 3.8104795038498344`*^9}, {3.810479572543576*^9, 
    3.8104796147383184`*^9}, {3.8104802055659895`*^9, 
    3.8104802433915305`*^9}, {3.8104802785189395`*^9, 
    3.8104802814214115`*^9}, {3.810480477782269*^9, 3.8104805471507206`*^9}, {
    3.8104805927965565`*^9, 3.810480633017248*^9}, {3.8104807595294323`*^9, 
    3.8104809538100047`*^9}, {3.8104811300285854`*^9, 
    3.8104811403007636`*^9}, {3.8104812580010843`*^9, 
    3.8104813317580833`*^9}, {3.81048146789211*^9, 3.8104815557630205`*^9}, {
    3.8104817202872114`*^9, 3.8104817438715935`*^9}, 3.810481790764664*^9, 
    3.810481836241686*^9, {3.810481926951917*^9, 3.810481935802024*^9}, {
    3.8106608387005043`*^9, 3.8106608893247347`*^9}, {3.810715008376715*^9, 
    3.810715021169223*^9}},ExpressionUUID->
  "aa587271-8fa5-4db2-bc86-8a13e4f30359"],
 " or ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox[
    OverscriptBox[
     StyleBox["L",
      FontSlant->"Italic"], "^"],
    FontSlant->"Italic"], 
   StyleBox["y",
    FontSlant->"Italic"]]],
  CellChangeTimes->{{3.810112811439228*^9, 3.8101128248442793`*^9}, {
    3.810479494926491*^9, 3.8104795038498344`*^9}, {3.810479572543576*^9, 
    3.8104796147383184`*^9}, {3.8104802055659895`*^9, 
    3.8104802433915305`*^9}, {3.8104802785189395`*^9, 
    3.8104802814214115`*^9}, {3.810480477782269*^9, 3.8104805471507206`*^9}, {
    3.8104805927965565`*^9, 3.810480633017248*^9}, {3.8104807595294323`*^9, 
    3.8104809538100047`*^9}, {3.8104811300285854`*^9, 
    3.8104811403007636`*^9}, {3.8104812580010843`*^9, 
    3.8104813317580833`*^9}, {3.81048146789211*^9, 3.8104815557630205`*^9}, {
    3.8104817202872114`*^9, 3.8104817438715935`*^9}, 3.810481790764664*^9, 
    3.810481836241686*^9, {3.810481926951917*^9, 3.810481935802024*^9}, {
    3.8106608387005043`*^9, 3.8106608893247347`*^9}, {3.810715008376715*^9, 
    3.810715021169223*^9}},ExpressionUUID->
  "f17a8da9-168b-42a4-b459-be634ccf330d"],
 ", but none of the angular momentum components commute with each other. \
Therefore, we cannot simultaneously measure the angular momentum component \
along any two axes. Also note that "
}], "Text",
 CellChangeTimes->{{3.8107152212624564`*^9, 3.8107152227025843`*^9}, {
  3.8107166926112347`*^9, 3.810716760246685*^9}, {3.9170866334543667`*^9, 
  3.917086634283475*^9}, {3.91708674955562*^9, 3.917086760414794*^9}, {
  3.935590714072836*^9, 
  3.9355907142936153`*^9}},ExpressionUUID->"24bf7e69-8234-45da-bb5c-\
362bf400b0de"],

Cell[BoxData[
 RowBox[{
  SuperscriptBox[
   OverscriptBox[
    StyleBox["L",
     FontSlant->"Italic"], "^"], "2"], "=", 
  RowBox[{
   SubsuperscriptBox[
    OverscriptBox[
     StyleBox["L",
      FontSlant->"Italic"], "^"], 
    StyleBox["x",
     FontSlant->"Italic"], "2"], "+", 
   SubsuperscriptBox[
    OverscriptBox[
     StyleBox["L",
      FontSlant->"Italic"], "^"], 
    StyleBox["y",
     FontSlant->"Italic"], "2"], "+", 
   SubsuperscriptBox[
    OverscriptBox[
     StyleBox["L",
      FontSlant->"Italic"], "^"], 
    StyleBox["z",
     FontSlant->"Italic"], "2"]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.810112811439228*^9, 3.8101128248442793`*^9}, {
   3.810479494926491*^9, 3.8104795038498344`*^9}, {3.810479572543576*^9, 
   3.8104796147383184`*^9}, {3.8104802055659895`*^9, 
   3.8104802433915305`*^9}, {3.8104802785189395`*^9, 
   3.8104802814214115`*^9}, {3.810480477782269*^9, 3.8104805471507206`*^9}, {
   3.8104805927965565`*^9, 3.810480633017248*^9}, {3.8104807595294323`*^9, 
   3.8104809538100047`*^9}, {3.8104811300285854`*^9, 
   3.8104811403007636`*^9}, {3.8104812580010843`*^9, 
   3.8104813317580833`*^9}, {3.81048146789211*^9, 3.8104815557630205`*^9}, {
   3.8104817202872114`*^9, 3.8104817438715935`*^9}, 3.810481790764664*^9, 
   3.810481836241686*^9, {3.810481926951917*^9, 3.810481935802024*^9}, {
   3.8106609069078913`*^9, 3.81066090872985*^9}, {3.8106610360496655`*^9, 
