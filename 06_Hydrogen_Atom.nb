        FontSlant->"Italic"], 
       RowBox[{
        StyleBox["l",
         FontSlant->"Italic"], 
        StyleBox["+",
         FontSlant->"Plain"], 
        StyleBox["1",
         FontSlant->"Plain"]}], 
       StyleBox[")",
        FontSlant->"Plain"]}]}], 
     StyleBox["-",
      FontSlant->"Plain"], 
     SubsuperscriptBox[
      StyleBox["m",
       FontSlant->"Italic"], 
