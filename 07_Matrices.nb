Cell["\<\
Perhaps you can see from this brief example how using these types of \
operations might simplify problems in quantum mechanics. We will continue to \
expand upon these ideas using a slightly different nomenclature, Dirac \
bra-ket notation.\
\>", "Text",
 CellChangeTimes->{{3.8113276766425514`*^9, 
  3.8113277853419456`*^9}},ExpressionUUID->"5360409d-bebc-4ef8-a8ea-\
9cc3977b9d07"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Dirac Bra-Ket Notation", "Subsection",
 CellChangeTimes->{{3.8113254368488307`*^9, 3.81132544387422*^9}, {
  3.8113277122878184`*^9, 
  3.811327718854502*^9}},ExpressionUUID->"714c8ce9-44f6-4c4b-90b4-\
8c6d6e4a7c37"],

Cell["\<\
We will now introduce the bra-ket notation developed by Dirac, which is also \
known as Dirac notation or sometimes braket notation. It begins with the \
simple step of replacing the comma in our inner product with a vertical bar,\
\>", "Text",
 CellChangeTimes->{{3.8113285383351293`*^9, 
  3.8113286037361546`*^9}},ExpressionUUID->"d9da82bf-5a47-4018-bc58-\
b544422cf24e"],

Cell[BoxData[
 RowBox[{
  RowBox[{"\[LeftAngleBracket]", 
   RowBox[{
    StyleBox["a",
     FontWeight->"Bold"], ",", 
    StyleBox["b",
     FontWeight->"Bold"]}], "\[RightAngleBracket]"}], "\[RightArrow]", 
  RowBox[{"\[LeftAngleBracket]", 
   RowBox[{
    StyleBox["a",
     FontWeight->"Bold"], 
    StyleBox["|",
     FontWeight->"Plain"], 
    StyleBox["b",
     FontWeight->"Bold"]}], 
   "\[RightAngleBracket]"}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8112559638442764`*^9, 3.8112559741396627`*^9}, {
   3.8113221103126726`*^9, 3.811322130222258*^9}, 3.8113221675383205`*^9, {
   3.811322570897264*^9, 3.811322611416624*^9}, {3.8113228670247326`*^9, 
   3.811322868962326*^9}, 3.8113230721769085`*^9, {3.8113233012632074`*^9, 
