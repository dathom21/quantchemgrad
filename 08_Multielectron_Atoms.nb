Cell[CellGroupData[{

Cell["Solving Secular Equations", "Subsubsection",
 CellChangeTimes->{{3.8118667440016503`*^9, 3.811866745232089*^9}, {
   3.811866823815317*^9, 3.8118668414930086`*^9}, 
   3.811868757117859*^9},ExpressionUUID->"89dedd94-d239-6044-8bb6-\
787d25d68c41"],

Cell["\<\
Let\[CloseCurlyQuote]s take the simplest case of a linear combination of \
basis functions, where we have only two basis functions,\
\>", "Text",
 CellChangeTimes->{{3.81186684369624*^9, 
  3.8118668693233023`*^9}},ExpressionUUID->"a2024e13-ed6a-0446-b3ab-\
339b82bf30ce"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{"|", "\[CapitalPhi]"}], "\[RightAngleBracket]"}], "=", 
          RowBox[{
           RowBox[{
            OverscriptBox[
             UnderscriptBox["\[Sum]", 
              StyleBox["n",
               FontSlant->"Italic"]], "2"], 
            SubscriptBox[
             StyleBox["a",
              FontSlant->"Italic"], 
             StyleBox["n",
              FontSlant->"Italic"]]}], "|", 
           SubscriptBox["\[Phi]", 
            StyleBox["n",
             FontSlant->"Italic"]]}]}], "\[RightAngleBracket]"}], "=", 
        RowBox[{
         SubscriptBox[
          StyleBox["a",
           FontSlant->"Italic"], "1"], "|", 
         SubscriptBox["\[Phi]", "1"]}]}], "\[RightAngleBracket]"}], "+", 
      SubscriptBox[
       StyleBox["a",
        FontSlant->"Italic"], "2"]}], "|", 
     SubscriptBox["\[Phi]", "2"]}], "\[RightAngleBracket]"}], "                         ",
    "\[CapitalPhi]"}], "=", 
  RowBox[{
   RowBox[{
    OverscriptBox[
     UnderscriptBox["\[Sum]", 
      StyleBox["n",
       FontSlant->"Italic"]], "2"], 
    RowBox[{
     SubscriptBox[
      StyleBox["a",
       FontSlant->"Italic"], 
      StyleBox["n",
       FontSlant->"Italic"]], 
     SubscriptBox["\[Phi]", 
      StyleBox["n",
       FontSlant->"Italic"]]}]}], "=", 
   RowBox[{
    RowBox[{
     SubscriptBox[
      StyleBox["a",
       FontSlant->"Italic"], "1"], 
     SubscriptBox["\[Phi]", "1"]}], "+", 
    RowBox[{
     SubscriptBox[
      StyleBox["a",
       FontSlant->"Italic"], "2"], 
     SubscriptBox["\[Phi]", "2"], "  "}]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.811593312893673*^9, 3.8115933831661987`*^9}, {
   3.811593458953679*^9, 3.8115934974178753`*^9}, {3.811594043422389*^9, 
   3.8115940850450926`*^9}, {3.8115941212928057`*^9, 3.81159413134099*^9}, {
