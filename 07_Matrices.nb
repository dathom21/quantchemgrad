   3.8113275725367107`*^9}},ExpressionUUID->"77d4c6d2-29da-4c54-be52-\
84aeb58446c6"],

Cell[TextData[{
 "where ",
 Cell[BoxData[
  SuperscriptBox[
   StyleBox["a",
    FontWeight->"Bold",
    FontSlant->"Plain"], 
   StyleBox["H",
    FontWeight->"Bold"]]],
  CellChangeTimes->{{3.8112559638442764`*^9, 3.8112559741396627`*^9}, {
    3.8113221103126726`*^9, 3.811322130222258*^9}, 3.8113221675383205`*^9, {
    3.811322570897264*^9, 3.811322611416624*^9}, {3.8113228670247326`*^9, 
    3.811322868962326*^9}, 3.8113230721769085`*^9},ExpressionUUID->
  "d3a2bd20-8083-4bd1-bf96-28a86df9e5fe"],
 " is known as the conjugate transpose of a vector (or matrix). With this \
information, we define a new type of multiplication. For any column vectors ",
 StyleBox["a",
  FontWeight->"Bold"],
 " and ",
 StyleBox["b",
  FontWeight->"Bold"],
 ", we define the inner product of ",
 StyleBox["a",
  FontWeight->"Bold"],
 " and ",
 StyleBox["b ",
  FontWeight->"Bold"],
 "as "
}], "Text",
 CellChangeTimes->{{3.8113230973998423`*^9, 3.8113231193261356`*^9}, {
  3.8113231561638823`*^9, 3.8113232180833645`*^9}, {3.8113249645308337`*^9, 
  3.8113249904165535`*^9}, {3.81132602968641*^9, 
  3.811326048421235*^9}},ExpressionUUID->"64c1d453-39e1-4e7c-8dc8-\
71033c401521"],

Cell[BoxData[
 RowBox[{
  RowBox[{"\[LeftAngleBracket]", 
   RowBox[{
    StyleBox["a",
     FontWeight->"Bold"], ",", 
    StyleBox["b",
     FontWeight->"Bold"]}], "\[RightAngleBracket]"}], 
  StyleBox["=",
   FontWeight->"Plain",
   FontSlant->"Plain"], 
  RowBox[{
   RowBox[{
    SuperscriptBox[
     StyleBox["a",
      FontWeight->"Bold",
      FontSlant->"Plain"], 
     StyleBox["H",
      FontWeight->"Bold"]], 
    StyleBox["b",
     FontWeight->"Bold"]}], "=", 
   RowBox[{
    RowBox[{"(", "\[NoBreak]", 
     RowBox[{GridBox[{
        {
         SubsuperscriptBox[
          StyleBox["a",
           FontSlant->"Italic"], "1", "\[Star]"], 
         SubsuperscriptBox[
          StyleBox["a",
           FontSlant->"Italic"], "2", "\[Star]"]}
       }], GridBox[{
        {"...", 
         SubsuperscriptBox[
          StyleBox["a",
           FontSlant->"Italic"], 
          StyleBox["n",
           FontSlant->"Italic"], "\[Star]"]}
       }]}], ")"}], 
    RowBox[{"(", "\[NoBreak]", GridBox[{
       {
        SubscriptBox[
         StyleBox["b",
          FontSlant->"Italic"], "1"]},
       {
        SubscriptBox[
         StyleBox["b",
          FontSlant->"Italic"], "2"]},
       {GridBox[{
          {"..."},
          {
           SubscriptBox[
            StyleBox["b",
             FontSlant->"Italic"], 
            StyleBox["n",
             FontSlant->"Italic"]]}
         }]}
      }], "\[NoBreak]", ")"}]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8112559638442764`*^9, 3.8112559741396627`*^9}, {
   3.8113221103126726`*^9, 3.811322130222258*^9}, 3.8113221675383205`*^9, {
