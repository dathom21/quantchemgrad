Cell[TextData[{
 "Notice the similarity between equations (78) and (79). If we use ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Beta]", "=", 
    RowBox[{"l", "(", 
     RowBox[{"l", "+", "1"}], ")"}]}], TraditionalForm]],ExpressionUUID->
  "d00c793d-142d-4737-9f62-4a59cfb176ba"],
 " and multiply both sides of equation (78) by ",
 Cell[BoxData[
  RowBox[{
   SuperscriptBox["\[HBar]", "2"], 
   SubsuperscriptBox[
    StyleBox["Y",
     FontSlant->"Italic"], 
    StyleBox["l",
     FontSlant->"Italic"], 
    SubscriptBox[
     StyleBox["m",
      FontSlant->"Italic"], 
     StyleBox["l",
      FontSlant->"Italic"]]], 
   RowBox[{"(", 
    RowBox[{"\[Theta]", ",", "\[Phi]"}], ")"}]}]],
  CellChangeTimes->{{3.810112811439228*^9, 3.8101128248442793`*^9}, {
