Cell[BoxData[
 RowBox[{
  SubscriptBox[
   StyleBox["E",
    FontSlant->"Italic"], "\[CapitalPhi]"], "=", 
  FractionBox[
   RowBox[{
    UnderscriptBox["\[Sum]", 
     StyleBox["n",
      FontSlant->"Italic"]], 
    RowBox[{
     UnderscriptBox["\[Sum]", 
      StyleBox["m",
       FontSlant->"Italic"]], 
