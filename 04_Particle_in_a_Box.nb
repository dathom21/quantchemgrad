   3.808745607563491*^9}},ExpressionUUID->"12d227c8-e5ce-43b7-af02-\
7d889f60167c"],

Cell[TextData[{
 "Now, plugging in our second boundary condition, \[Psi](",
 StyleBox["a ",
  FontSlant->"Italic"],
 ") = 0, we find"
}], "Text",
