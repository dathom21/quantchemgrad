    UntrackedVariables:>{Typeset`size$$}], "Manipulate",
   Deployed->True,
   StripOnInput->False],
  Manipulate`InterpretManipulate[1]]], "Output",
 CellChangeTimes->{3.7597963397296*^9, 3.8136643924309196`*^9, 
  3.8136644993664904`*^9, 3.8136655425696926`*^9},
