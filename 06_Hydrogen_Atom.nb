Cell["\<\
We should point out that the probability densities are the same for these two \
wavefunctions,\
\>", "Text",
 CellChangeTimes->{{3.8109824584436707`*^9, 3.810982471010968*^9}, {
  3.8109846698163824`*^9, 
  3.8109846825991244`*^9}},ExpressionUUID->"cbbf693f-46b5-415e-96e0-\
68c214a4757c"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   StyleBox["|",
    FontSlant->"Italic"], 
   RowBox[{
    SubsuperscriptBox[
     StyleBox["Y",
      FontSlant->"Italic"], "1", "1"], 
    RowBox[{"(", 
     RowBox[{"\[Theta]", ",", "\[Phi]"}], ")"}]}], 
   SuperscriptBox["|", "2"]}], "=", 
  RowBox[{
   RowBox[{"|", 
    RowBox[{
     SubsuperscriptBox[
      StyleBox["Y",
       FontSlant->"Italic"], "1", 
      RowBox[{"-", "1"}]], 
     RowBox[{"(", 
      RowBox[{"\[Theta]", ",", "\[Phi]"}], ")"}]}], 
    SuperscriptBox["|", "2"]}], "=", 
   RowBox[{
    FractionBox["3", 
     RowBox[{"8", " ", "\[Pi]"}]], " ", 
    SuperscriptBox["sin", "2"], 
    RowBox[{"(", "\[Theta]", ")"}]}]}]}]], "DisplayFormulaNumbered",
