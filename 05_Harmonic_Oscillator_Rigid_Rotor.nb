  RowBox[{
   StyleBox["V",
    FontSlant->"Italic"], 
   RowBox[{
    StyleBox["(",
     FontSlant->"Plain"], 
    StyleBox["x",
     FontSlant->"Italic"], ")"}]}], "=", 
  RowBox[{"-", 
   RowBox[{"\[Integral]", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{"-", 
       StyleBox["kx",
        FontSlant->"Italic"]}], 
      StyleBox[")",
       FontSlant->"Italic"]}], 
     StyleBox[" ",
      FontSlant->"Italic"], 
     RowBox[{
      StyleBox["\[DifferentialD]",
       FontSlant->"Plain"], 
      StyleBox["x",
       FontSlant->"Italic"]}]}]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8094362093669643`*^9, 3.809436315131312*^9}, {
  3.8094364621225743`*^9, 3.809436481460247*^9}, {3.9351437835365086`*^9, 
  3.9351437837729416`*^9}},ExpressionUUID->"63db4bf4-db88-4c53-8470-\
7dc6ada54d14"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   StyleBox["V",
    FontSlant->"Italic"], 
   RowBox[{
    StyleBox["(",
     FontSlant->"Plain"], 
    StyleBox["x",
     FontSlant->"Italic"], ")"}]}], "=", 
  RowBox[{
   RowBox[{
    FractionBox["1", "2"], 
    SuperscriptBox[
     StyleBox["kx",
      FontSlant->"Italic"], "2"]}], "+", 
   StyleBox["C",
    FontSlant->"Italic"]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8094362093669643`*^9, 3.809436315131312*^9}, {
  3.8094364621225743`*^9, 
  3.8094364990803995`*^9}},ExpressionUUID->"9d4ecf9b-e49f-436b-b01e-\
38a52a69556a"],

Cell[TextData[{
 "The constant ",
 StyleBox["C",
  FontSlant->"Italic"],
 " is just an offset in the zero of energy, and we can set it equal to zero. \
That gives us"
}], "Text",
 CellChangeTimes->{{3.8094363400511847`*^9, 3.8094363598173246`*^9}, {
  3.8094365042969065`*^9, 3.8094365046220264`*^9}, {3.8094365365339456`*^9, 
  3.809436539104734*^9}},ExpressionUUID->"9eceaeae-407a-4a9e-a5fa-\
f6062f40a7e1"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   StyleBox["V",
    FontSlant->"Italic"], 
   RowBox[{
    StyleBox["(",
     FontSlant->"Plain"], 
    StyleBox["x",
     FontSlant->"Italic"], ")"}]}], "=", 
  RowBox[{
   FractionBox["1", "2"], 
   SuperscriptBox[
    StyleBox["kx",
     FontSlant->"Italic"], "2"]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8094362093669643`*^9, 3.809436315131312*^9}, {
  3.8094364621225743`*^9, 3.8094364990803995`*^9}, {3.8094365447169914`*^9, 
  3.8094365448488054`*^9}},ExpressionUUID->"b1c558a6-286e-47c8-8b8d-\
b3868a8041c7"],

Cell[TextData[{
 "Equation (6) is the main part of the classical harmonic oscillator that \
will carry to our quantum-mechanical system: the potential has a harmonic ",
 Cell[BoxData[
  FormBox[
   RowBox[{"(", 
    RowBox[{"a", " ", 
     SuperscriptBox["x", "2"]}], ")"}], TraditionalForm]],ExpressionUUID->
  "1f8b2426-5b6a-44f2-b682-c066568cb2a8"],
 " dependence."
}], "Text",
 CellChangeTimes->{{3.9157965681157346`*^9, 
  3.915796620378026*^9}},ExpressionUUID->"9af6a1fd-4a21-4a83-8c72-\
0c7831581b77"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Two Masses Connected by a Spring", "Subsection",
 CellChangeTimes->{{3.8094467343123016`*^9, 
  3.809446743179655*^9}},ExpressionUUID->"5c6af37c-842d-499d-8918-\
b47ebcbfa584"],

Cell["\<\
Another important system to consider is that of two mass connected by a \
spring (Figure 5.1). In this case, we must consider the motion of two masses, \
so we can\[CloseCurlyQuote]t use the position of a single mass as the \
reference point.\
\>", "Text",
 CellChangeTimes->{{3.9157968672533646`*^9, 3.9157968773763075`*^9}, {
  3.9157970037346497`*^9, 3.915797032344945*^9}, {3.915797096921976*^9, 
  3.9157971080815897`*^9}, {3.9157971424015636`*^9, 3.915797153159684*^9}, {
  3.9157973330655107`*^9, 
  3.915797333425733*^9}},ExpressionUUID->"4f201c29-183d-45d7-b3f2-\
9e8df032e37e"],

