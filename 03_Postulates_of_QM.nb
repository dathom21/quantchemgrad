  "],ExpressionUUID->"794765df-5e02-46d3-bff3-a7f1c3010ac4"],

Cell[TextData[{
 "recall that ",
 Cell[BoxData[
  SuperscriptBox[
   RowBox[{"\[LeftBracketingBar]", 
    SubscriptBox[
     StyleBox["c",
      FontSlant->"Italic"], "1"], "\[RightBracketingBar]"}], "2"]],
  CellChangeTimes->{{3.8079664251944246`*^9, 3.8079664343142004`*^9}, {
   3.8079689400739555`*^9, 3.8079689680029573`*^9}, {3.807970315263204*^9, 
   3.8079703215316095`*^9}, {3.807970415909548*^9, 3.807970437015459*^9}, {
   3.8079705221296997`*^9, 3.8079705895237727`*^9}, {3.8079740353167067`*^9, 
   3.807974091342613*^9}, {3.8079792460635405`*^9, 3.807979253256398*^9}, {
   3.808056638763859*^9, 3.808056681287653*^9}, {3.8080569738200073`*^9, 
   3.8080570333706875`*^9}, {3.8080573070857663`*^9, 3.808057330443427*^9}, {
   3.8080623653640356`*^9, 3.808062383919905*^9}, {3.808062621222328*^9, 
   3.8080626474284306`*^9}, {3.808062711499276*^9, 3.8080627131447396`*^9}, {
   3.808063090172789*^9, 3.8080631519100065`*^9}, {3.8080631961157813`*^9, 
   3.8080634272234225`*^9}, {3.8080634929297457`*^9, 3.808063494097248*^9}, {
   3.8080635515365252`*^9, 3.8080638476650076`*^9}, {3.8080639093394995`*^9, 
   3.808063924793887*^9}},ExpressionUUID->
  "3179fd5d-8411-49e4-b15d-63aac5c5188e"],
 " = ",
 Cell[BoxData[
  SubsuperscriptBox[
   StyleBox["c",
    FontSlant->"Italic"], "1", "\[Star]"]],
  CellChangeTimes->{{3.8079664251944246`*^9, 3.8079664343142004`*^9}, {
   3.8079689400739555`*^9, 3.8079689680029573`*^9}, {3.807970315263204*^9, 
   3.8079703215316095`*^9}, {3.807970415909548*^9, 3.807970437015459*^9}, {
   3.8079705221296997`*^9, 3.8079705895237727`*^9}, {3.8079740353167067`*^9, 
   3.807974091342613*^9}, {3.8079792460635405`*^9, 3.807979253256398*^9}, {
   3.808056638763859*^9, 3.808056681287653*^9}, {3.8080569738200073`*^9, 
   3.8080570333706875`*^9}, {3.8080573070857663`*^9, 3.808057330443427*^9}, {
   3.8080623653640356`*^9, 3.808062383919905*^9}, {3.808062621222328*^9, 
   3.8080626474284306`*^9}, {3.808062711499276*^9, 3.8080627131447396`*^9}, {
   3.808063090172789*^9, 3.8080631519100065`*^9}, {3.8080631961157813`*^9, 
   3.8080634272234225`*^9}, {3.8080634929297457`*^9, 3.808063494097248*^9}, {
   3.8080635515365252`*^9, 3.8080638476650076`*^9}, {3.8080639093394995`*^9, 
   3.808063924793887*^9}},ExpressionUUID->
  "e6de4b6d-d07e-4735-b107-acbd073f3413"],
 Cell[BoxData[
  SubscriptBox[
   StyleBox["c",
    FontSlant->"Italic"], "1"]],
  CellChangeTimes->{{3.8079664251944246`*^9, 3.8079664343142004`*^9}, {
   3.8079689400739555`*^9, 3.8079689680029573`*^9}, {3.807970315263204*^9, 
   3.8079703215316095`*^9}, {3.807970415909548*^9, 3.807970437015459*^9}, {
   3.8079705221296997`*^9, 3.8079705895237727`*^9}, {3.8079740353167067`*^9, 
   3.807974091342613*^9}, {3.8079792460635405`*^9, 3.807979253256398*^9}, {
   3.808056638763859*^9, 3.808056681287653*^9}, {3.8080569738200073`*^9, 
   3.8080570333706875`*^9}, {3.8080573070857663`*^9, 3.808057330443427*^9}, {
   3.8080623653640356`*^9, 3.808062383919905*^9}, {3.808062621222328*^9, 
   3.8080626474284306`*^9}, {3.808062711499276*^9, 3.8080627131447396`*^9}, {
   3.808063090172789*^9, 3.8080631519100065`*^9}, {3.8080631961157813`*^9, 
   3.8080634272234225`*^9}, {3.8080634929297457`*^9, 3.808063494097248*^9}, {
   3.8080635515365252`*^9, 3.8080638476650076`*^9}, {3.8080639093394995`*^9, 
   3.808063924793887*^9}},ExpressionUUID->
  "345d13b1-f1cf-43f8-a2bb-24a904b0f02d"],
 " is called the absolute square of ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["c",
    FontSlant->"Italic"], "1"]],
  CellChangeTimes->{{3.8079664251944246`*^9, 3.8079664343142004`*^9}, {
   3.8079689400739555`*^9, 3.8079689680029573`*^9}, {3.807970315263204*^9, 
   3.8079703215316095`*^9}, {3.807970415909548*^9, 3.807970437015459*^9}, {
   3.8079705221296997`*^9, 3.8079705895237727`*^9}, {3.8079740353167067`*^9, 
   3.807974091342613*^9}, {3.8079792460635405`*^9, 3.807979253256398*^9}, {
   3.808056638763859*^9, 3.808056681287653*^9}, {3.8080569738200073`*^9, 
   3.8080570333706875`*^9}, {3.8080573070857663`*^9, 3.808057330443427*^9}, {
   3.8080623653640356`*^9, 3.808062383919905*^9}, {3.808062621222328*^9, 
   3.8080626474284306`*^9}, {3.808062711499276*^9, 3.8080627131447396`*^9}, {
   3.808063090172789*^9, 3.8080631519100065`*^9}, {3.8080631961157813`*^9, 
   3.8080634272234225`*^9}, {3.8080634929297457`*^9, 3.808063494097248*^9}, {
   3.8080635515365252`*^9, 3.8080638476650076`*^9}, {3.8080639093394995`*^9, 
   3.808063924793887*^9}},ExpressionUUID->
  "a65ed7bf-e248-462e-8cd9-ea1dbdb756ba"],
 ". Because the eigenfunctions are orthornormal (orthogonal and normalized),"
}], "Text",
 CellChangeTimes->{{3.808063953454318*^9, 3.8080639652249937`*^9}, {
  3.8080640507376885`*^9, 3.8080640777768927`*^9}, {3.84072517575935*^9, 
  3.8407251764617467`*^9}, {3.9148618908536654`*^9, 
  3.9148618946696925`*^9}},ExpressionUUID->"426787fc-abbc-4d02-9772-\
c098720a7e3d"],

Cell[BoxData[
 RowBox[{
  RowBox[{"\[Integral]", 
   RowBox[{
    SubsuperscriptBox["\[Psi]", "1", "\[Star]"], 
    SubscriptBox["\[Psi]", "2"]}]}], "=", "0"}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8080639820587687`*^9, 
  3.808063984342499*^9}},ExpressionUUID->"fad6a477-a10f-4790-9cb8-\
6dda0d691a56"],

Cell["and because the eigenfunctions are normalized,", "Text",
 CellChangeTimes->{{3.808063985766559*^9, 3.808064015117941*^9}, {
  3.914861909615986*^9, 
  3.9148619442478943`*^9}},ExpressionUUID->"0cd1efe3-5f13-4a7d-8fe6-\
9fc38b809c6a"],

Cell[BoxData[
 RowBox[{
  RowBox[{"\[Integral]", 
   RowBox[{
    SubsuperscriptBox["\[Psi]", "1", "\[Star]"], 
    SubscriptBox["\[Psi]", "1"]}]}], "=", "1"}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.808064025004633*^9, 
  3.8080640290156555`*^9}},ExpressionUUID->"9d87ab66-e127-4964-8f55-\
91a576e742e2"],

Cell["so we are left with", "Text",
 CellChangeTimes->{{3.8080640326621*^9, 3.808064034700019*^9}, {
  3.914861927590191*^9, 
  3.914861949415354*^9}},ExpressionUUID->"3ac9f0f0-f959-4b06-99cc-\
e58758ea6f60"],

Cell[BoxData[
 RowBox[{
  RowBox[{"<", 
   StyleBox["A",
    FontSlant->"Italic"], ">"}], " ", "=", 
  RowBox[{
   RowBox[{
    SubscriptBox[
     StyleBox["a",
      FontSlant->"Italic"], "1"], 
    SuperscriptBox[
     RowBox[{"\[LeftBracketingBar]", 
      SubscriptBox[
       StyleBox["c",
        FontSlant->"Italic"], "1"], "\[RightBracketingBar]"}], "2"]}], "+", 
   RowBox[{
    SubscriptBox[
     StyleBox["a",
      FontSlant->"Italic"], "2"], 
    SuperscriptBox[
     RowBox[{"\[LeftBracketingBar]", 
      SubscriptBox[
       StyleBox["c",
        FontSlant->"Italic"], "2"], "\[RightBracketingBar]"}], 
     "2"]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8080640414603057`*^9, 3.808064046777788*^9}, 
   3.8080640906265373`*^9},ExpressionUUID->"59964b82-daaa-47c5-b428-\
bedcb0ec8fa1"],

Cell[TextData[{
 "Thus, the squares of the coefficients in the initial wavefunction give us \
the ",
 StyleBox["probability",
  FontSlant->"Italic"],
 " that we will measure a given eigenvalue."
}], "Text",
 CellChangeTimes->{{3.80806413019495*^9, 
  3.8080641542569036`*^9}},ExpressionUUID->"a0935dad-5097-4b6b-bbba-\
47f94a30e29e"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Postulate 5: The Time-Dependent Schr\[ODoubleDot]dinger Equation", \
"Section",
 CellChangeTimes->{{3.8080646844747767`*^9, 
  3.808064701510038*^9}},ExpressionUUID->"fa611fb3-30de-4657-841f-\
69d3dd89b533"],

Cell[CellGroupData[{

Cell["Statement of the Postulate", "Subsection",
 CellChangeTimes->{{3.8080647068097053`*^9, 
  3.8080647115545263`*^9}},ExpressionUUID->"a06c9cb2-240f-4502-b89c-\
a57a4e5b9d65"],

Cell["\<\
The wavefunction describing a system evolves in time according to the \
time-dependent Schr\[ODoubleDot]dinger equation\
\>", "Text",
 CellChangeTimes->{{3.808064990478114*^9, 
  3.8080650125049496`*^9}},ExpressionUUID->"0b894447-6675-4a7f-9d56-\
0d12d471dff2"],

Cell[BoxData[
 RowBox[{
  RowBox[{"\[ImaginaryI]\[HBar]", " ", 
   StyleBox[
    FractionBox[
     RowBox[{
      StyleBox[
       RowBox[{"\[PartialD]", "\[Psi]"}],
       FontSlant->"Plain"], 
      RowBox[{
       StyleBox["(",
        FontSlant->"Plain"], 
       RowBox[{
        StyleBox["r",
         FontWeight->"Bold"], 
        StyleBox[",",
         FontSlant->"Plain"], 
        StyleBox["t",
         FontSlant->"Italic"]}], 
       StyleBox[")",
        FontSlant->"Italic"]}]}], 
     RowBox[{
      StyleBox["\[PartialD]",
       FontSlant->"Plain"], "t"}]],
    FontSlant->"Italic"]}], 
  StyleBox["=",
   FontSlant->"Plain"], 
  RowBox[{
   RowBox[{
    RowBox[{"-", 
     FractionBox[
      SuperscriptBox["\[HBar]", "2"], 
      RowBox[{"2", 
       StyleBox["m",
        FontSlant->"Italic"]}]]}], 
    RowBox[{
     SuperscriptBox["\[Del]", "2"], 
     StyleBox["\[Psi]",
      FontSlant->"Plain"]}], 
    RowBox[{
     StyleBox["(",
      FontSlant->"Plain"], 
     RowBox[{
      StyleBox["r",
       FontWeight->"Bold",
       FontSlant->"Italic"], 
      StyleBox[",",
       FontSlant->"Plain"], 
      StyleBox["t",
       FontSlant->"Italic"]}], 
     StyleBox[")",
      FontSlant->"Italic"]}]}], "+", 
   RowBox[{
    StyleBox["V",
     FontSlant->"Italic"], 
    StyleBox[
     RowBox[{"(", 
      StyleBox["r",
       FontWeight->"Bold"], ")"}],
     FontSlant->"Italic"], 
    StyleBox["\[Psi]",
     FontSlant->"Plain"], 
    RowBox[{
     StyleBox["(",
      FontSlant->"Plain"], 
     RowBox[{
      StyleBox["r",
       FontWeight->"Bold",
       FontSlant->"Italic"], 
      StyleBox[",",
       FontSlant->"Plain"], 
      StyleBox["t",
       FontSlant->"Italic"]}], 
     StyleBox[")",
      FontSlant->"Italic"]}]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8079712935412436`*^9, 3.8079714900326514`*^9}, {
  3.8080650361338077`*^9, 3.808065078586836*^9}, {3.9148620040786715`*^9, 
  3.9148620063514004`*^9}},ExpressionUUID->"ef5e17f4-f674-4ffe-9c20-\
ff93c65cb990"],

Cell["or, more succinctly, in operator form", "Text",
 CellChangeTimes->{{3.808065101682048*^9, 
  3.808065108924751*^9}},ExpressionUUID->"2f7fd918-8a26-4107-be77-\
36bd362c21c8"],

Cell[BoxData[
 RowBox[{
  RowBox[{"\[ImaginaryI]\[HBar]", " ", 
   RowBox[{
    StyleBox[
     FractionBox[
      StyleBox["\[PartialD]",
       FontSlant->"Plain"], 
      RowBox[{
       StyleBox["\[PartialD]",
        FontSlant->"Plain"], "t"}]],
     FontSlant->"Italic"], 
    StyleBox["\[Psi]",
     FontSlant->"Plain"]}], 
   RowBox[{
    StyleBox["(",
     FontSlant->"Plain"], 
    RowBox[{
     StyleBox["r",
      FontWeight->"Bold"], 
     StyleBox[",",
      FontSlant->"Plain"], 
     StyleBox["t",
      FontSlant->"Italic"]}], 
    StyleBox[")",
     FontSlant->"Italic"]}]}], 
  StyleBox["=",
   FontSlant->"Plain"], 
  RowBox[{
   OverscriptBox[
    StyleBox["H",
     FontSlant->"Italic"], "^"], 
   StyleBox[" ",
    FontSlant->"Italic"], 
   StyleBox["\[Psi]",
    FontSlant->"Plain"], 
   RowBox[{
    StyleBox["(",
     FontSlant->"Plain"], 
    RowBox[{
     StyleBox["r",
      FontWeight->"Bold",
      FontSlant->"Italic"], 
     StyleBox[",",
      FontSlant->"Plain"], 
     StyleBox["t",
      FontSlant->"Italic"]}], 
    StyleBox[")",
     FontSlant->"Italic"]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8079712935412436`*^9, 3.8079714900326514`*^9}, {
  3.8080650361338077`*^9, 3.808065078586836*^9}, {3.8080651294863386`*^9, 
  3.8080651662446632`*^9}, {3.914862009818528*^9, 
  3.914862010486101*^9}},ExpressionUUID->"796f17ce-5aa1-45e9-a3d0-\
0c87fc7c49ec"],

Cell["\<\
as we discussed in a previous lesson, one can\[CloseCurlyQuote]t really \
derive this equation from a classical wave equation. However, there are some \
ongoing discussions in the literature about the best way to reach this \
equation, at least in a logical if not rigidly proven manner.\
\>", "Text",
 CellChangeTimes->{{3.8080651863537664`*^9, 
  3.80806526582911*^9}},ExpressionUUID->"8db81d9c-a70f-48e4-aa35-\
a98c9de78d12"]
}, Open  ]],

Cell[CellGroupData[{

Cell["From TDSE to TISE: Separation of Variables", "Subsection",
 CellChangeTimes->{{3.8080653409052134`*^9, 
  3.808065348181574*^9}},ExpressionUUID->"0d6c8bef-e0bd-4389-885f-\
6a6e4cc0d2c0"],

Cell["\<\
We can gain some important insight into the time evolution of a wavefunction \
by once again applying the trick of separation of variables to go from the \
time-dependent Schr\[ODoubleDot]dinger equation to the time-independent \
version. If we say\
\>", "Text",
 CellChangeTimes->{{3.8080653513581924`*^9, 
  3.808065435171404*^9}},ExpressionUUID->"b3d6be73-a7ae-413a-adca-\
9c77d1a429f0"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   StyleBox["\[Psi]",
    FontSlant->"Plain"], 
   RowBox[{
    StyleBox["(",
     FontSlant->"Plain"], 
    RowBox[{
     StyleBox["r",
      FontWeight->"Bold"], 
     StyleBox[",",
      FontSlant->"Plain"], 
     StyleBox["t",
      FontSlant->"Italic"]}], 
    StyleBox[")",
     FontSlant->"Italic"]}]}], 
  StyleBox["=",
   FontSlant->"Plain"], 
  RowBox[{
   StyleBox["\[Psi]",
    FontSlant->"Plain"], 
   RowBox[{
    StyleBox["(",
     FontSlant->"Plain"], 
    StyleBox["r",
     FontWeight->"Bold",
     FontSlant->"Italic"], 
    StyleBox[")",
     FontSlant->"Italic"]}], 
   StyleBox["f",
    FontSlant->"Italic"], 
   StyleBox[
    RowBox[{"(", "t", ")"}],
    FontSlant->"Italic"]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8079712935412436`*^9, 3.8079714900326514`*^9}, {
  3.8080650361338077`*^9, 3.808065078586836*^9}, {3.8080651294863386`*^9, 
  3.8080651662446632`*^9}, {3.8080654448179817`*^9, 
  3.8080654672619233`*^9}},ExpressionUUID->"58014f94-f7ac-4de9-b92f-\
2ae293ac3016"],

Cell["and plug this into equation (19), we obtain", "Text",
 CellChangeTimes->{{3.8080654715269732`*^9, 
  3.8080655013624563`*^9}},ExpressionUUID->"2051b341-1a58-48df-83e3-\
96cbceb6e7c3"],

Cell[BoxData[
 RowBox[{
  RowBox[{"\[ImaginaryI]\[HBar]", " ", "\[Psi]", 
   RowBox[{"(", "r", ")"}], 
   StyleBox[
    FractionBox[
     RowBox[{
      RowBox[{
       StyleBox["\[PartialD]",
        FontSlant->"Plain"], "f"}], 
      RowBox[{"(", "t", ")"}]}], 
     RowBox[{
      StyleBox["\[PartialD]",
       FontSlant->"Plain"], "t"}]],
    FontSlant->"Italic"]}], 
  StyleBox["=",
   FontSlant->"Plain"], 
  RowBox[{
   StyleBox["f",
    FontSlant->"Italic"], 
   StyleBox[
    RowBox[{"(", "t", ")"}],
    FontSlant->"Italic"], 
   OverscriptBox[
    StyleBox["H",
     FontSlant->"Italic"], "^"], 
   StyleBox[" ",
    FontSlant->"Italic"], 
   StyleBox["\[Psi]",
    FontSlant->"Plain"], 
   RowBox[{
    StyleBox["(",
     FontSlant->"Plain"], 
    StyleBox["r",
     FontWeight->"Bold",
     FontSlant->"Italic"], 
    StyleBox[")",
     FontSlant->"Italic"]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8079712935412436`*^9, 3.8079714900326514`*^9}, {
  3.8080650361338077`*^9, 3.808065078586836*^9}, {3.8080651294863386`*^9, 
  3.8080651662446632`*^9}, {3.8080655103101*^9, 3.808065549470801*^9}, {
  3.914862014452381*^9, 
  3.9148620151312833`*^9}},ExpressionUUID->"ba9a1b12-0273-42d5-a5e9-\
a12ab021790f"],

Cell["collecting variables gives us", "Text",
 CellChangeTimes->{{3.8080655566481786`*^9, 
  3.8080655808644056`*^9}},ExpressionUUID->"f9489674-7adb-4fe2-b106-\
471a80178ef6"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   FractionBox["\[ImaginaryI]\[HBar]", 
    StyleBox[
     RowBox[{"f", 
      RowBox[{"(", "t", ")"}]}],
     FontSlant->"Italic"]], " ", 
   StyleBox[
    FractionBox[
     RowBox[{
      RowBox[{
       StyleBox["\[PartialD]",
        FontSlant->"Plain"], "f"}], 
      RowBox[{"(", "t", ")"}]}], 
     RowBox[{
      StyleBox["\[PartialD]",
       FontSlant->"Plain"], "t"}]],
    FontSlant->"Italic"]}], 
  StyleBox["=",
   FontSlant->"Plain"], 
  RowBox[{
   FractionBox[
    StyleBox["1",
     FontSlant->"Plain"], 
    RowBox[{
     StyleBox["\[Psi]",
      FontSlant->"Plain"], 
     RowBox[{
      StyleBox["(",
       FontSlant->"Plain"], 
      StyleBox["r",
       FontWeight->"Bold"], 
      StyleBox[")",
       FontSlant->"Italic"]}]}]], 
   OverscriptBox[
    StyleBox["H",
     FontSlant->"Italic"], "^"], 
   StyleBox[" ",
    FontSlant->"Italic"], 
   StyleBox["\[Psi]",
    FontSlant->"Plain"], 
   RowBox[{
    StyleBox["(",
     FontSlant->"Plain"], 
    StyleBox["r",
     FontWeight->"Bold",
     FontSlant->"Italic"], 
    StyleBox[")",
     FontSlant->"Italic"]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8079712935412436`*^9, 3.8079714900326514`*^9}, {
  3.8080650361338077`*^9, 3.808065078586836*^9}, {3.8080651294863386`*^9, 
  3.8080651662446632`*^9}, {3.8080655103101*^9, 3.808065549470801*^9}, {
  3.8080655874181037`*^9, 3.8080655997397223`*^9}, {3.9148620179399147`*^9, 
  3.9148620185900497`*^9}},ExpressionUUID->"cf9d2e94-a212-47b6-bbca-\
88b5357f0453"],

Cell[TextData[{
 "Once again, each side of the equation is a function of a single variable, \
which means that we can set them equal to a constant, in this case ",
 StyleBox["E",
  FontSlant->"Italic"],
 ", and we obtain"
}], "Text",
 CellChangeTimes->{{3.8080656184327135`*^9, 
  3.808065666994115*^9}},ExpressionUUID->"6870d7a9-4769-4220-97dc-\
c70c7d51c224"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   OverscriptBox[
    StyleBox["H",
     FontSlant->"Italic"], "^"], 
   StyleBox[" ",
    FontSlant->"Italic"], 
   StyleBox["\[Psi]",
    FontSlant->"Plain"], 
   RowBox[{
    StyleBox["(",
     FontSlant->"Plain"], 
    StyleBox["r",
     FontWeight->"Bold",
     FontSlant->"Italic"], 
    StyleBox[")",
     FontSlant->"Italic"]}]}], "=", 
  RowBox[{
   StyleBox[
    RowBox[{
     StyleBox["E",
      FontSlant->"Italic"], 
     StyleBox["\[Psi]",
      FontSlant->"Plain"]}]], 
   RowBox[{
    StyleBox["(",
     FontSlant->"Plain"], 
    StyleBox["r",
     FontWeight->"Bold",
     FontSlant->"Italic"], 
    StyleBox[")",
     FontSlant->"Italic"]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8079712935412436`*^9, 3.8079714900326514`*^9}, {
  3.8080650361338077`*^9, 3.808065078586836*^9}, {3.8080651294863386`*^9, 
  3.8080651662446632`*^9}, {3.8080655103101*^9, 3.808065549470801*^9}, {
  3.8080655874181037`*^9, 3.8080655997397223`*^9}, {3.808065695240284*^9, 
  3.808065706824973*^9}},ExpressionUUID->"978f8d22-cff7-4fda-8f53-\
7dc146009c8b"],

Cell["which is the time-independent Schr\[ODoubleDot]dinger equation, and ", \
"Text",
 CellChangeTimes->{{3.8080657090723877`*^9, 
  3.808065724616761*^9}},ExpressionUUID->"c9f2a363-31f9-4cb8-8639-\
a36a8f365706"],

Cell[BoxData[
 RowBox[{" ", 
  RowBox[{
   StyleBox[
    FractionBox[
     RowBox[{
      RowBox[{
       StyleBox["\[DifferentialD]",
        FontSlant->"Plain"], "f"}], 
      RowBox[{"(", "t", ")"}]}], 
     RowBox[{
      StyleBox["\[DifferentialD]",
       FontSlant->"Plain"], "t"}]],
    FontSlant->"Italic"], 
   StyleBox["=",
    FontSlant->"Plain"], 
   RowBox[{
    FractionBox[
     RowBox[{
      StyleBox["-",
       FontSlant->"Italic"], 
      StyleBox[
       RowBox[{
        StyleBox["\[ImaginaryI]",
         FontSlant->"Plain"], 
        StyleBox["E",
         FontSlant->"Italic"]}]]}], "\[HBar]"], 
    StyleBox["f",
     FontSlant->"Italic"], 
    StyleBox[
     RowBox[{"(", "t", ")"}],
     FontSlant->"Italic"]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8079712935412436`*^9, 3.8079714900326514`*^9}, {
  3.8080650361338077`*^9, 3.808065078586836*^9}, {3.8080651294863386`*^9, 
  3.8080651662446632`*^9}, {3.8080655103101*^9, 3.808065549470801*^9}, {
  3.8080655874181037`*^9, 3.8080655997397223`*^9}, {3.80806586302172*^9, 
  3.808065882866931*^9}, {3.8080659492793603`*^9, 3.808065953047598*^9}, {
  3.9148620219435835`*^9, 3.9148620226366014`*^9}, {3.9148621124379215`*^9, 
  3.914862119024748*^9}},ExpressionUUID->"afc18c6d-d844-4eb4-8e8a-\
5430af489497"],

Cell[TextData[{
 "where we have used the relation 1/",
 "\[ImaginaryI] ",
 "= -\[ImaginaryI]. Now, this equation tells us that the solution of ",
 StyleBox["f ",
  FontSlant->"Italic"],
 "(",
 StyleBox["t",
  FontSlant->"Italic"],
 " ) must satisfy the condition that its derivative returns the function \
times the constant -",
 StyleBox["iE",
  FontSlant->"Italic"],
 "/\[HBar]. A particular solution of this form is"
}], "Text",
 CellChangeTimes->{{3.808065893657441*^9, 3.80806599948672*^9}, {
  3.8080670930717297`*^9, 3.808067094469941*^9}, {3.914862034850782*^9, 
  3.91486204548636*^9}},ExpressionUUID->"51f29da2-6649-4a65-b289-\
f1a445ad8e7e"],

Cell[BoxData[
 RowBox[{
  StyleBox[
   RowBox[{"f", 
    RowBox[{"(", "t", ")"}]}],
   FontSlant->"Italic"], 
  StyleBox["=",
   FontSlant->"Plain"], 
  SuperscriptBox["\[ExponentialE]", 
   RowBox[{
    RowBox[{"-", 
     StyleBox[
      RowBox[{"\[ImaginaryI]", 
       StyleBox["Et",
        FontSlant->"Italic"]}]]}], "/", 
    "\[HBar]"}]]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8079712935412436`*^9, 3.8079714900326514`*^9}, {
  3.8080650361338077`*^9, 3.808065078586836*^9}, {3.8080651294863386`*^9, 
  3.8080651662446632`*^9}, {3.8080655103101*^9, 3.808065549470801*^9}, {
  3.8080655874181037`*^9, 3.8080655997397223`*^9}, {3.80806586302172*^9, 
  3.808065882866931*^9}, {3.8080659492793603`*^9, 3.808065953047598*^9}, {
  3.808066005614772*^9, 3.8080660274348636`*^9}, {3.8080662251299095`*^9, 
  3.8080662851171017`*^9}, {3.9148620590038056`*^9, 3.914862059824171*^9}, {
  3.9148622079223604`*^9, 
  3.9148622092579393`*^9}},ExpressionUUID->"6dc60c63-4088-4980-8ad8-\
d713146f43a3"],

Cell[TextData[{
 "which means that the time component ",
 StyleBox["f ",
  FontSlant->"Italic"],
 "(",
 StyleBox["t ",
  FontSlant->"Italic"],
 ") represents oscillations of the spatial component  \[Psi](",
 StyleBox["r ",
  FontWeight->"Bold",
  FontSlant->"Italic"],
 ") (remember Euler\[CloseCurlyQuote]s formula). This results leads to two \
important conclusions:"
}], "Text",
 CellChangeTimes->{{3.808066326942196*^9, 3.808066442558588*^9}, {
  3.9148621399132433`*^9, 
  3.914862140886283*^9}},ExpressionUUID->"27159600-b066-47ad-a379-\
05beec519873"],

Cell[TextData[{
 "The absolute square of the wavefunction, ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    RowBox[{"\[LeftBracketingBar]", 
     RowBox[{"\[Psi]", "(", 
      RowBox[{
       StyleBox["r",
        FontWeight->"Bold"], ",", "t"}], ")"}], "\[RightBracketingBar]"}], 
    "2"], TraditionalForm]],ExpressionUUID->
  "86b76bee-5f0d-4394-b9a1-678d470e50bd"],
 ", is time-independent."
}], "Item",
 CellChangeTimes->{{3.8080664496981163`*^9, 
  3.8080665222528276`*^9}},ExpressionUUID->"717b7c5b-290e-46ee-9da2-\
96cb4a9ab838"],

Cell[BoxData[
 RowBox[{
  SuperscriptBox[
   RowBox[{"\[LeftBracketingBar]", 
    RowBox[{"\[Psi]", 
     RowBox[{"(", 
      RowBox[{
       StyleBox["r",
        FontWeight->"Bold",
        FontSlant->"Italic"], ",", " ", 
       StyleBox["t",
        FontSlant->"Italic"]}], 
      StyleBox[")",
       FontSlant->"Italic"]}]}], "\[RightBracketingBar]"}], "2"], "=", 
  RowBox[{
   SuperscriptBox["\[Psi]", "\[Star]"], 
   RowBox[{"(", 
    RowBox[{
     StyleBox["r",
      FontWeight->"Bold",
      FontSlant->"Italic"], ",", " ", 
     StyleBox["t",
      FontSlant->"Italic"]}], 
    StyleBox[")",
     FontSlant->"Italic"]}], "\[Psi]", 
   RowBox[{"(", 
    RowBox[{
     StyleBox["r",
      FontWeight->"Bold",
      FontSlant->"Italic"], ",", " ", 
     StyleBox["t",
      FontSlant->"Italic"]}], 
    StyleBox[")",
     FontSlant->"Italic"]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8080665643258467`*^9, 
  3.8080666805817137`*^9}},ExpressionUUID->"4ba28941-36e3-4940-b563-\
817d3dc2296d"],

Cell[BoxData[
 RowBox[{"\t\t      ", 
  RowBox[{"=", 
   RowBox[{
    SuperscriptBox["\[ExponentialE]", 
     RowBox[{
      StyleBox[
       RowBox[{
        StyleBox["\[ImaginaryI]",
         FontSlant->"Plain"], 
