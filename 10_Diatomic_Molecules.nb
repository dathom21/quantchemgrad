Cell[TextData[{
 StyleBox["Figure 10.10",
  FontWeight->"Bold"],
 ". Visualization of molecular orbitals of some simple molecules.  Guenther \
Gsaller (October 2013), Wolfram Demonstrations, CC BY-NC-SA 3.0, \
https://demonstrations.wolfram.com/SomeExamplesOfMoleculeOrbitals/."
}], "Affiliation",
 CellChangeTimes->{{3.809435027311596*^9, 3.8094350763900714`*^9}, {
   3.80943583474421*^9, 3.8094358359299717`*^9}, {3.8094472165104203`*^9, 
   3.809447281165168*^9}, {3.809510876137825*^9, 3.809510907739876*^9}, {
   3.809968073566992*^9, 3.8099681536568317`*^9}, {3.810557260250428*^9, 
   3.8105572606139913`*^9}, {3.8130835305386977`*^9, 
   3.8130836194514275`*^9}, {3.813224407772764*^9, 3.8132244817756805`*^9}, {
   3.8132354037950773`*^9, 3.813235501614183*^9}, 3.813236418234542*^9, {
   3.81351439000795*^9, 3.8135143988971663`*^9}, {3.813665905470446*^9, 
   3.8136660007466154`*^9}, {3.8136660571324577`*^9, 3.81366605723772*^9}, {
   3.8136663097257414`*^9, 3.8136664742951727`*^9}, {3.8136771452348175`*^9, 
   3.8136771995450125`*^9}, {3.8136840032722273`*^9, 
   3.8136840441234016`*^9}, {3.9196735748631077`*^9, 3.919673575367688*^9}, {
