Cell[TextData[{
 "If we think about the case where ",
 StyleBox["r  ",
  FontSlant->"Italic"],
 "= 1, then by just changing \[Theta], we go around in a circle on the \
complex plane of radius 1, as illustrated in Figure 0.5."
}], "Text",
