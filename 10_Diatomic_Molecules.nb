  "00a08bdf-bf2c-4ddd-be7b-0a5bf622d220"],
 " resembles the attractive potential term ",
 StyleBox["N",
  FontSlant->"Italic"],
 ", but now the electron is in different orbitals on each side of the \
operator ",
 Cell[BoxData[
  FractionBox["1", 
   SubscriptBox[
    StyleBox["r",
     FontSlant->"Italic"], 
    StyleBox["A",
     FontSlant->"Italic"]]]],
  CellChangeTimes->{{3.8135052923220196`*^9, 3.813505326944688*^9}, {
   3.813505358543342*^9, 3.813505384859789*^9}, {3.813505426726184*^9, 
   3.8135054412132916`*^9}, {3.8135055231751776`*^9, 3.813505529922575*^9}, {
   3.8135055732207823`*^9, 3.8135055842599134`*^9}},ExpressionUUID->
  "077ccb4a-de93-4841-b7b7-e593f4d15728"],
 ". We will call this the exchanged attractive potential ",
 StyleBox["M",
  FontSlant->"Italic"],
 ", "
}], "Text",
