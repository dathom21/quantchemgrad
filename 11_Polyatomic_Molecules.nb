 RowBox[{"Import", "[", 
  "\"\<https://upload.wikimedia.org/wikipedia/commons/thumb/d/d4/H2O-MO-\
Diagram.svg/1024px-H2O-MO-Diagram.svg.png\>\"", "]"}]], "Input",
