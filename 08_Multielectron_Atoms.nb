       RowBox[{"(", "1", ")"}]]}], "\[RightAngleBracket]"}]}], "+", 
   RowBox[{"\[LeftAngleBracket]", 
    RowBox[{
     SuperscriptBox["\[Psi]", 
      RowBox[{"(", "0", ")"}]], "|", 
     StyleBox[
      SuperscriptBox[
