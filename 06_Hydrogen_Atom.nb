    3.8107156349892807`*^9}},ExpressionUUID->
  "2bf0d544-88c5-4d93-99cb-ec78b2d113cc"],
 ". If we measure ",
 Cell[BoxData[
  StyleBox[
   SubscriptBox["L", 
    StyleBox["z",
     FontSlant->"Italic"]],
   FontSlant->"Italic"]],
  CellChangeTimes->{{3.8100544880652375`*^9, 3.8100545041200957`*^9}, {
