        RowBox[{".15", 
         SuperscriptBox["\[Omega]", "2"], 
         SuperscriptBox["d", 
          RowBox[{"-", "1"}]], 
         SuperscriptBox[
          RowBox[{"(", 
           RowBox[{"v", "+", ".5"}], ")"}], "2"]}]}]}], ";", 
      RowBox[{
       RowBox[{"x", "[", 
