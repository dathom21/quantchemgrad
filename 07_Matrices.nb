    3.811327184536927*^9}, {3.811327229827714*^9, 3.811327252666423*^9}, {
    3.8113273026463294`*^9, 3.811327327733873*^9}, {3.8113273817178807`*^9, 
    3.8113273925612955`*^9}, {3.8113274382012477`*^9, 3.811327492034623*^9}, {
    3.8113275253821125`*^9, 3.8113275462381163`*^9}, {3.811329211490376*^9, 
