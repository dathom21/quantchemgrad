Cell["\<\
These delta functions provide a simple expression for the orthonormal \
conditions. The first few spherical harmonic functions are shown in the table \
below.\
\>", "Text",
 CellChangeTimes->{{3.810652431226815*^9, 3.8106524605126886`*^9}, {
  3.8106528399987116`*^9, 
  3.8106528491051216`*^9}},ExpressionUUID->"cea701fc-bd85-4a58-91c6-\
9a1bcdaf9f8f"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"Grid", "[", 
   RowBox[{
    RowBox[{"Prepend", "[", 
     RowBox[{
      RowBox[{"Flatten", "[", 
       RowBox[{
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"n", ",", "m", ",", 
            RowBox[{
             RowBox[{"Piecewise", "[", 
              RowBox[{
               RowBox[{"{", 
                RowBox[{"{", 
                 RowBox[{
                  SuperscriptBox[
                   RowBox[{"(", 
                    RowBox[{"-", "1"}], ")"}], "m"], ",", 
                  RowBox[{"m", ">", "0"}]}], "}"}], "}"}], ",", "1"}], "]"}], 
             "*", 
             RowBox[{"SphericalHarmonicY", "[", 
              RowBox[{"n", ",", "m", ",", "\[Theta]", ",", "\[Phi]"}], 
              "]"}]}]}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"n", ",", "0", ",", "2"}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"m", ",", 
            RowBox[{"-", "n"}], ",", "n"}], "}"}]}], "]"}], ",", "1"}], "]"}],
       ",", 
      RowBox[{"{", 
       RowBox[{
       "\"\<\!\(\*StyleBox[\"l\",FontSlant->\"Italic\"]\)\>\"", ",", 
        "\"\<\!\(\*SubscriptBox[StyleBox[\"m\",FontSlant->\"Italic\"], \
StyleBox[\"l\",FontSlant->\"Italic\"]]\)\>\"", ",", 
        "\"\<\!\(\*SubsuperscriptBox[StyleBox[\"Y\",FontSlant->\"Italic\"], \
StyleBox[\"l\",FontSlant->\"Italic\"], \
SubscriptBox[StyleBox[\"m\",FontSlant->\"Italic\"], \
StyleBox[\"l\",FontSlant->\"Italic\"]]]\)(\[Theta],\[Phi])\>\""}], "}"}]}], 
     "]"}], ",", 
    RowBox[{"BaseStyle", "\[Rule]", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"FontFamily", "\[Rule]", "\"\<Arial\>\""}], ",", 
       RowBox[{"FontSize", "\[Rule]", "18"}]}], "}"}]}], ",", 
    RowBox[{"Frame", "\[Rule]", "All"}]}], "]"}], 
  "\[IndentingNewLine]"}]], "Input",
