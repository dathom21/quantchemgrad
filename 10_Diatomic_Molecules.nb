       Typeset`show$$, Typeset`bookmarkList$$, Typeset`bookmarkMode$$, 
        Typeset`animator$$, Typeset`animvar$$, Typeset`name$$, 
        Typeset`specs$$, Typeset`size$$, Typeset`update$$, Typeset`initDone$$,
         Typeset`skipInitDone$$}, "Body" :> GraphicsColumn[{
         DensityPlot[
         Abs[($CellContext`f[$CellContext`x - $CellContext`a$$/
               2, $CellContext`y] + $CellContext`f[$CellContext`x + \
$CellContext`a$$/2, $CellContext`y])/
            2]^2, {$CellContext`x, -$CellContext`d, $CellContext`d}, \
{$CellContext`y, -$CellContext`d, $CellContext`d}, PlotPoints -> 40, 
          PlotRange -> All], 
         Plot[
         Abs[($CellContext`f[$CellContext`x - $CellContext`a$$/2, 
               0] + $CellContext`f[$CellContext`x + $CellContext`a$$/2, 0])/
            2]^2, {$CellContext`x, -$CellContext`d, $CellContext`d}, 
          PlotPoints -> 40, PlotRange -> {0, All}]}], 
      "Specifications" :> {{{$CellContext`a$$, 2, "R"}, 2, 10, Appearance -> 
