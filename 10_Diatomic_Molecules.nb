       StyleBox["R",
        FontSlant->"Italic"], 
       StyleBox[")",
        FontSlant->"Italic"]}]}], "+", 
     SubscriptBox[
      StyleBox["E",
       FontSlant->"Italic"], 
      StyleBox["e",
       FontSlant->"Italic"]]}], 
    StyleBox["]",
     FontSlant->"Italic"]}], 
