Cell["\<\
So we see again how Dirac notation can express an important quantity in a \
very simple form.\
\>", "Text",
 CellChangeTimes->{3.811577491838703*^9, 
  3.811577533228956*^9},ExpressionUUID->"99c8bdb3-0192-4ed4-9c10-\
e90469f2720c"],

Cell["\<\
Note that when using the inner product conjugate definition (equation 67), we \
move the operator when switching the vectors,\
\>", "Text",
 CellChangeTimes->{{3.8115775980615797`*^9, 3.8115776107051735`*^9}, {
  3.8115776439374685`*^9, 3.811577691441141*^9}, {3.81157784835958*^9, 
  3.8115778694590864`*^9}, {3.811577899860072*^9, 
  3.811577924074888*^9}},ExpressionUUID->"2f1be37c-9f58-4b52-8613-\
6738efaf093d"],

Cell[BoxData[
 RowBox[{
  RowBox[{"\[LeftAngleBracket]", 
   RowBox[{
    StyleBox[
     SubscriptBox[
      StyleBox["\[CapitalPsi]",
       FontWeight->"Bold"], 
      StyleBox["a",
       FontWeight->"Bold",
       FontSlant->"Italic"]],
     FontWeight->"Bold"], "|", 
    OverscriptBox[
     StyleBox["A",
      FontSlant->"Italic"], "^"], "|", 
    SubscriptBox[
     StyleBox["\[CapitalPsi]",
      FontWeight->"Bold"], 
     StyleBox["b",
      FontWeight->"Bold",
      FontSlant->"Italic"]]}], "\[RightAngleBracket]"}], "=", 
  RowBox[{
   RowBox[{"\[LeftAngleBracket]", 
    RowBox[{
     StyleBox[
      SubscriptBox[
       StyleBox["\[CapitalPsi]",
        FontWeight->"Bold"], 
       StyleBox["a",
        FontWeight->"Bold",
        FontSlant->"Italic"]],
      FontWeight->"Bold"], "|", 
     RowBox[{
      OverscriptBox[
       StyleBox["A",
        FontSlant->"Italic"], "^"], 
      SubscriptBox[
       StyleBox["\[CapitalPsi]",
        FontWeight->"Bold"], 
       StyleBox["b",
        FontWeight->"Bold",
        FontSlant->"Italic"]]}]}], "\[RightAngleBracket]"}], "=", 
   SuperscriptBox[
    RowBox[{"\[LeftAngleBracket]", 
     RowBox[{
      RowBox[{
       OverscriptBox[
        StyleBox["A",
         FontSlant->"Italic"], "^"], 
       SubscriptBox[
        StyleBox["\[CapitalPsi]",
         FontWeight->"Bold"], 
        StyleBox["b",
         FontWeight->"Bold",
         FontSlant->"Italic"]]}], "|", 
      StyleBox[
       SubscriptBox[
        StyleBox["\[CapitalPsi]",
         FontWeight->"Bold"], 
        StyleBox["a",
         FontWeight->"Bold",
         FontSlant->"Italic"]],
       FontWeight->"Bold"]}], "\[RightAngleBracket]"}], 
    "\[Star]"]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8113265575394135`*^9, 3.8113266208341584`*^9}, {
   3.8113268886705112`*^9, 3.8113269031313066`*^9}, 3.8113270406173744`*^9, {
