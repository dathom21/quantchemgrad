   3.8113286375554333`*^9}},ExpressionUUID->"2859be70-d621-4215-8e34-\
a0ba86cc4cf4"],

Cell["\<\
In this way, we have separated our inner product into two components: the bra,\
\>", "Text",
 CellChangeTimes->{{3.8113286614081497`*^9, 3.811328666232428*^9}, 
   3.8113287302550263`*^9, {3.8113287610828857`*^9, 3.811328772144811*^9}, 
