Cell[CellGroupData[{

Cell["Selection Rules of a Harmonic Oscillator", "Subsection",
 CellChangeTimes->{{3.8158276864162436`*^9, 
  3.815827696815858*^9}},ExpressionUUID->"6105b645-fa5f-4889-a6ec-\
be0a23483c33"],

Cell[TextData[{
 "Now let\[CloseCurlyQuote]s consider not only the rotational states of a \
rigid-rotor/harmonic oscillator molecule but also the vibrational states. In \
addition to fulfilling the rotational selection rules outlined above, now we \
must consider the dependence of the transition dipole moment on the change in \
the internuclear distance(s). Using the harmonic approximation, the nuclear \
eigenfunctions for a given vibrational coordinate ",
 StyleBox["q",
  FontSlant->"Italic"],
 " are given by"
}], "Text",
 CellChangeTimes->{{3.8158277018588324`*^9, 3.815827778696435*^9}, {
  3.815828022935422*^9, 3.815828024059657*^9}, {3.8158280752109823`*^9, 
  3.8158281736394825`*^9}, {3.8158282199215994`*^9, 
  3.815828228491526*^9}},ExpressionUUID->"9343a299-0024-4c88-a3e3-\
cf24d41ec794"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   SubscriptBox["\[Psi]", 
    StyleBox["n",
     FontSlant->"Italic"]], 
   RowBox[{"(", 
    StyleBox["q",
     FontSlant->"Italic"], ")"}]}], "=", 
  RowBox[{
   SubscriptBox[
    StyleBox["N",
     FontSlant->"Italic"], 
    StyleBox["n",
     FontSlant->"Italic"]], 
   SubscriptBox[
    StyleBox["H",
     FontSlant->"Italic"], 
    StyleBox["n",
     FontSlant->"Italic"]], 
   RowBox[{"(", 
    RowBox[{
     SuperscriptBox["\[Alpha]", 
      RowBox[{"1", "/", "2"}]], 
     StyleBox["q",
      FontSlant->"Italic"]}], ")"}], 
   SuperscriptBox["\[ExponentialE]", 
    RowBox[{
     RowBox[{"-", 
      SuperscriptBox[
       StyleBox[
        RowBox[{"\[Alpha]", 
         StyleBox["q",
          FontSlant->"Italic"]}]], "2"]}], "/", 
     "2"}]]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.815828180214196*^9, 3.8158282059131823`*^9}, {
  3.8158282388847585`*^9, 3.815828278296766*^9}, {3.8158291799181256`*^9, 
  3.8158291805733967`*^9}, {3.8158315887216773`*^9, 3.815831591314068*^9}, {
  3.940080723981142*^9, 
  3.9400807269837265`*^9}},ExpressionUUID->"5dfb50ae-8e96-49e3-a06e-\
87fa2ef43e8a"],

Cell[TextData[{
 "where ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["N", "n"], TraditionalForm]],ExpressionUUID->
  "4415b1db-9ea5-4af6-b1b5-5228f8b46427"],
 " is a normalization constant, ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["H", "n"], TraditionalForm]],ExpressionUUID->
  "268143af-fba6-49a0-9df6-68de5d5584c7"],
 " is a Hermite polynomial, ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Alpha]", "=", 
    SuperscriptBox[
     RowBox[{"(", 
      RowBox[{"k", " ", 
       RowBox[{
        SubscriptBox["m", "red"], "/", 
        SuperscriptBox["\[HBar]", "2"]}]}], ")"}], 
     RowBox[{"1", "/", "2"}]]}], TraditionalForm]],ExpressionUUID->
  "c36f67c0-16ee-4904-8a48-a98eb7583089"],
 ", and ",
 StyleBox["n",
  FontSlant->"Italic"],
 " is the quantum number specifying the ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["n", "th"], TraditionalForm]],ExpressionUUID->
  "54f23edb-f2d4-451a-950d-cb243d3b9435"],
 " eigenfunction of the vibrational potential. The displacement coordinate ",
 StyleBox["q",
  FontSlant->"Italic"],
 " gives the net displacement of the atoms along the vibration\
\[CloseCurlyQuote]s displacement vector (we\[CloseCurlyQuote]ll discuss \
vibrational modes and normal coordinates more later). For a given vibration, \
neglecting the rotational selection rules, the transition dipole moment is \
then"
}], "Text",
 CellChangeTimes->{{3.8158282810027313`*^9, 3.8158285013531227`*^9}, {
