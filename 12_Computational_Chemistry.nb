   3.814607342514814*^9}},ExpressionUUID->"c6a348d1-8fa8-47ee-bddb-\
944fec530227"],

Cell[TextData[{
 "In this format, the angular distribution (related to the angular momentum) \
is given by the constants ",
 StyleBox["a",
  FontSlant->"Italic"],
 ", ",
 StyleBox["b",
  FontSlant->"Italic"],
 ", and ",
 StyleBox["c",
  FontSlant->"Italic"],
 ". Note that these functions are not true spherical harmonics, and, as we \
discussed previously, the orbitals do not have nodes like true hydrogen-like \
atomic orbitals."
}], "Text",
 CellChangeTimes->{{3.814607348988947*^9, 3.8146073806382933`*^9}, {
  3.8146083384663053`*^9, 
  3.8146084197308884`*^9}},ExpressionUUID->"a8f25704-7c88-4efd-ad67-\
be2d69225ab3"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Gaussian-Type Orbitals (GTOs)", "Subsection",
 CellChangeTimes->{{3.814601601973534*^9, 3.814601623170665*^9}, {
  3.8146073729911957`*^9, 3.814607375746098*^9}, {3.8146097957406907`*^9, 
  3.814609796618414*^9}, {3.814610132684737*^9, 
  3.814610133026823*^9}},ExpressionUUID->"f7ec646f-0158-4ed6-a0f4-\
2dfcbcaf9b5c"],

Cell["\<\
Although older computational chemistry programs employed Slater-type \
orbitals, essentially all modern computational chemistry is performed with \
Gaussian-type orbitals (GTOs),\
\>", "Text",
 CellChangeTimes->{{3.8146098016448317`*^9, 3.814609803765221*^9}, {
  3.8146100451099415`*^9, 3.8146101054158173`*^9}, {3.8146101365941553`*^9, 
  3.814610138614143*^9}},ExpressionUUID->"b58bf589-b19c-418b-bd19-\
63690a30ff01"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   SubsuperscriptBox["\[Phi]", 
    StyleBox["abc",
     FontSlant->"Italic"], "GTO"], 
   RowBox[{"(", 
    RowBox[{
     StyleBox["x",
      FontSlant->"Italic"], ",", 
     StyleBox["y",
      FontSlant->"Italic"], ",", 
     StyleBox["z",
      FontSlant->"Italic"]}], ")"}]}], "=", 
  RowBox[{
   StyleBox["N",
    FontSlant->"Italic"], 
   StyleBox[" ",
    FontSlant->"Italic"], 
   SuperscriptBox[
    StyleBox["x",
     FontSlant->"Italic"], 
    StyleBox["a",
     FontSlant->"Italic"]], 
   SuperscriptBox[
    StyleBox["y",
     FontSlant->"Italic"], 
    StyleBox["b",
     FontSlant->"Italic"]], 
   SuperscriptBox[
    StyleBox["z",
     FontSlant->"Italic"], 
    StyleBox["c",
     FontSlant->"Italic"]], 
   SuperscriptBox["\[ExponentialE]", 
    RowBox[{"-", 
     SuperscriptBox[
      StyleBox[
       RowBox[{
        StyleBox["\[Zeta]",
         FontSlant->"Plain"], 
        StyleBox["r",
         FontSlant->"Italic"]}]], "2"]}]]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.811593312893673*^9, 3.8115933831661987`*^9}, {
   3.811593458953679*^9, 3.8115934974178753`*^9}, {3.811594043422389*^9, 
   3.8115940850450926`*^9}, {3.8115941212928057`*^9, 3.81159413134099*^9}, {
   3.8115942129312763`*^9, 3.811594213576462*^9}, {3.811594345555955*^9, 
   3.8115943458791523`*^9}, 3.8115943810138807`*^9, {3.8118583015457077`*^9, 
   3.8118583904266043`*^9}, {3.8118668881127214`*^9, 3.811866985652667*^9}, {
   3.81187008170006*^9, 3.8118700849636593`*^9}, {3.8118701593125334`*^9, 
   3.811870201331394*^9}, {3.811935703417695*^9, 3.8119357133826056`*^9}, {
   3.8119449835579224`*^9, 3.8119450568130407`*^9}, 3.8119451443759785`*^9, {
   3.814606778471686*^9, 3.8146067795513096`*^9}, {3.8146068273815556`*^9, 
   3.814606904418*^9}, {3.814607322020729*^9, 3.814607342514814*^9}, {
   3.8146101267236547`*^9, 
   3.814610130170759*^9}},ExpressionUUID->"b6f6f3f9-2b27-489e-a9dc-\
476873e59b55"],

Cell["\<\
The reason for using Gaussian-type orbitals is something called the Gaussian \
product theorem, which, in short, states that the product of any two Gaussian \
functions centered on different atoms also yields a Gaussian function. This \
property greatly simplifies the calculation of integrals and speeds up \
computation.\
\>", "Text",
 CellChangeTimes->{{3.81461015659103*^9, 3.814610160173987*^9}, {
  3.814610246328951*^9, 3.8146102535134716`*^9}, {3.814610286992918*^9, 
  3.814610293500293*^9}, {3.8146103865250635`*^9, 3.814610408055788*^9}, {
  3.8146104840625515`*^9, 3.814610511125496*^9}, {3.8146105849402637`*^9, 
  3.814610588668352*^9}, {3.8146107003787518`*^9, 
  3.814610727580058*^9}},ExpressionUUID->"1ada59d5-2629-4374-b21a-\
c734fbfa7e9d"],

Cell["\<\
We already discussed the difference in the radial dependence of Slater-type \
and Gaussian-type functions, as shown in Figure 12.1. The Gaussian-type \
orbital does not correctly match the behavior of a Slater-type orbital \
(which, remember, mimic the shape of a Hydrogen atomic orbitals). At long and \
short distance from the atomic nucleus, the Gaussian function fails to \
correctly predict the shape of the wavefunction. \
\>", "Text",
 CellChangeTimes->{{3.8146118445702195`*^9, 3.814611880764306*^9}, {
   3.8146119158116107`*^9, 3.8146119477007895`*^9}, {3.8146122005397444`*^9, 
   3.814612206444378*^9}, {3.8146122419809937`*^9, 3.814612295955682*^9}, {
   3.814612339030515*^9, 3.8146124355502496`*^9}, {3.814614313048847*^9, 
   3.8146143154029555`*^9}, {3.8148824249169035`*^9, 3.814882425180247*^9}, 
   3.9392061487878666`*^9},ExpressionUUID->"a6c01065-2f79-4116-9105-\
ed363d7b0919"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"phi1s", "=", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{"Integrate", "[", 
      RowBox[{
       RowBox[{"Integrate", "[", 
        RowBox[{
         RowBox[{
          SuperscriptBox[
           RowBox[{"(", 
            RowBox[{
             SuperscriptBox[
              RowBox[{"(", 
               RowBox[{"1", "/", 
                RowBox[{"(", 
                 RowBox[{"\[Pi]", "*", 
                  SuperscriptBox["a", "3"]}], ")"}]}], ")"}], 
              RowBox[{"1", "/", "2"}]], "*", 
             SuperscriptBox["\[ExponentialE]", 
              RowBox[{
               RowBox[{"-", "r"}], "/", "a"}]]}], ")"}], "2"], 
          RowBox[{"Sin", "[", "\[Theta]", "]"}]}], ",", 
         RowBox[{"{", 
          RowBox[{"\[Phi]", ",", "0", ",", 
           RowBox[{"2", "\[Pi]"}]}], "}"}]}], "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"\[Theta]", ",", "0", ",", "\[Pi]"}], "}"}]}], "]"}], ")"}], 
    "^", 
    RowBox[{"(", 
     RowBox[{"1", "/", "2"}], ")"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"phigauss", "=", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{"Integrate", "[", 
       RowBox[{
        RowBox[{"Integrate", "[", 
         RowBox[{
          RowBox[{
           SuperscriptBox[
            RowBox[{"(", 
             RowBox[{
              SuperscriptBox[
               RowBox[{"(", 
                RowBox[{
                 RowBox[{"(", 
                  RowBox[{"2", "*", 
                   RowBox[{"(", 
                    RowBox[{"8", "/", 
                    RowBox[{"(", 
                    RowBox[{"9", "\[Pi]", "*", 
                    RowBox[{"a", "^", "2"}]}], ")"}]}], ")"}]}], ")"}], "/", 
                 "\[Pi]"}], ")"}], 
               RowBox[{"3", "/", "4"}]], "*", 
              SuperscriptBox["\[ExponentialE]", 
               RowBox[{
                RowBox[{"-", 
                 RowBox[{"(", 
                  RowBox[{"8", "/", 
                   RowBox[{"(", 
                    RowBox[{"9", "\[Pi]", "*", 
                    RowBox[{"a", "^", "2"}]}], ")"}]}], ")"}]}], 
                SuperscriptBox["r", "2"]}]]}], ")"}], "2"], 
           RowBox[{"Sin", "[", "\[Theta]", "]"}]}], ",", 
          RowBox[{"{", 
           RowBox[{"\[Phi]", ",", "0", ",", 
            RowBox[{"2", "\[Pi]"}]}], "}"}]}], "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"\[Theta]", ",", "0", ",", "\[Pi]"}], "}"}]}], "]"}], ")"}], 
     "^", 
     RowBox[{"(", 
      RowBox[{"1", "/", "2"}], ")"}]}]}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{"Plot", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"phi1s", "/.", 
      RowBox[{"a", "\[Rule]", "1"}]}], ",", 
     RowBox[{"phigauss", "/.", 
      RowBox[{"a", "\[Rule]", "1"}]}]}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"r", ",", "0", ",", "5"}], "}"}], ",", 
   RowBox[{"BaseStyle", "\[Rule]", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"FontFamily", "\[Rule]", "\"\<Arial\>\""}], ",", 
      RowBox[{"FontSize", "\[Rule]", "14"}]}], "}"}]}], ",", 
   RowBox[{"PlotStyle", "\[Rule]", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"Directive", "[", 
       RowBox[{"Black", ",", 
        RowBox[{"PointSize", "[", "Large", "]"}]}], "]"}], ",", 
      RowBox[{"Directive", "[", 
       RowBox[{"Black", ",", "Dashed", ",", 
        RowBox[{"PointSize", "[", "Large", "]"}]}], "]"}]}], "}"}]}], ",", 
   RowBox[{"AxesStyle", "\[Rule]", 
    RowBox[{"Directive", "[", 
     RowBox[{"Thick", ",", "Black"}], "]"}]}], ",", 
   RowBox[{"TicksStyle", "\[Rule]", 
    RowBox[{"Directive", "[", 
     RowBox[{"Black", ",", " ", "Thick"}], "]"}]}], ",", 
   RowBox[{"Ticks", "\[Rule]", "Automatic"}], ",", 
   RowBox[{"ImageSize", "\[Rule]", "Medium"}], ",", " ", 
   RowBox[{"Exclusions", "\[Rule]", "None"}], ",", 
   RowBox[{"AxesOrigin", "\[Rule]", 
    RowBox[{"{", 
     RowBox[{"0", ",", "0"}], "}"}]}], ",", 
   RowBox[{"AxesLabel", "\[Rule]", 
    RowBox[{"{", 
     RowBox[{
     "\"\<\!\(\*StyleBox[\"r\",FontWeight->\"Plain\",FontSlant->\"Italic\"]\)\
\!\(\*StyleBox[\"/\",FontWeight->\"Plain\"]\)\!\(\*StyleBox[SubscriptBox[\
StyleBox[\"a\",FontSlant->\"Italic\"], \"0\"],FontWeight->\"Plain\"]\)\>\"", 
      ",", "\"\<\!\(\*StyleBox[SubsuperscriptBox[StyleBox[\"a\",FontSlant->\"\
Italic\"], \"0\", RowBox[{RowBox[{\"-\", \"3\"}], \"/\", \
\"2\"}]],FontWeight->\"Plain\"]\)\!\(\*StyleBox[\"\[Phi]\",FontWeight->\"\
Plain\"]\)\!\(\*StyleBox[\"(\",FontWeight->\"Plain\"]\)\!\(\*StyleBox[\"r\",\
FontWeight->\"Plain\",FontSlant->\"Italic\"]\)\!\(\*StyleBox[\")\",FontWeight-\
>\"Plain\"]\)\>\""}], "}"}]}], ",", 
   RowBox[{"PlotLegends", "\[Rule]", 
    RowBox[{"{", 
     RowBox[{
     "\"\<\!\(\*FractionBox[\"2\", \
SubsuperscriptBox[StyleBox[\"a\",FontSlant->\"Italic\"], \"0\", \
RowBox[{\"3\", \"/\", \"2\"}]]]\)\!\(\*SuperscriptBox[\"\[ExponentialE]\", \
RowBox[{RowBox[{\"-\", StyleBox[\"r\",FontSlant->\"Italic\"]}], \"/\", \
SubscriptBox[StyleBox[\"a\",FontSlant->\"Italic\"], \"0\"]}]]\)\>\"", ",", 
      "\"\<2(\!\(\*FractionBox[\(8 \*SuperscriptBox[\(\[Alpha]\), \(3\)]\), \
\(\[Pi]\)]\)\!\(\*SuperscriptBox[\()\), \(1/4\)]\)\!\(\*SuperscriptBox[\"\
\[ExponentialE]\", RowBox[{\"-\", \
SuperscriptBox[StyleBox[RowBox[{\"\[Alpha]\", \
StyleBox[\"r\",FontSlant->\"Italic\"]}]], \"2\"]}]]\)\>\""}], "}"}]}]}], 
  "]"}]}], "Input",
