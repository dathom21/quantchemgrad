    3.9214244282577167`*^9, 3.9214244340743675`*^9}, {3.921424481932246*^9, 
    3.9214245032022505`*^9}},ExpressionUUID->
  "45df5a74-deaa-4407-a411-8905098812cc"],
 " as an example, we obtain"
}], "Text",
