  3.807636423479644*^9}},ExpressionUUID->"26415b42-eb59-4591-a874-\
aea8249e512a"],

Cell[CellGroupData[{

Cell["Boundary Conditions", "Subsection",
 CellChangeTimes->{{3.807636309174425*^9, 3.807636328720072*^9}, {
  3.8076364291196823`*^9, 
  3.8076364323341885`*^9}},ExpressionUUID->"b709cc75-1b87-4515-92d0-\
c57900fa5db6"],

Cell[TextData[{
 "Think about a string of length ",
 StyleBox["L ",
  FontSlant->"Italic"],
 " that is held fixed at its ends. What sort of vibrational waves might we \
see? Because the string is fixed, we have the boundary conditions"
}], "Text",
 CellChangeTimes->{{3.8076364361223106`*^9, 3.8076364419035606`*^9}, {
  3.80763651967525*^9, 3.807636580730465*^9}, {3.8076366354446044`*^9, 
  3.807636657383687*^9}, {3.8078690063570185`*^9, 
  3.807869018435763*^9}},ExpressionUUID->"a8fb1625-b384-4ca8-ab99-\
c8d6c79f51aa"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   StyleBox["u",
    FontSlant->"Italic"], 
   RowBox[{
    StyleBox["(",
     FontSlant->"Italic"], 
    RowBox[{
     StyleBox["0",
      FontSlant->"Plain"], 
     StyleBox[",",
      FontSlant->"Plain"], 
     StyleBox["t",
      FontSlant->"Italic"]}], 
    StyleBox[")",
     FontSlant->"Italic"]}]}], "=", "0"}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8076366636837025`*^9, 
  3.8076366749676976`*^9}},ExpressionUUID->"3512d110-095a-4bf1-9796-\
c654c0fafa37"],

Cell["and", "Text",
 CellChangeTimes->{{3.807636678307699*^9, 
  3.807636678499654*^9}},ExpressionUUID->"ab107774-0461-44ca-94a6-\
eceac2117ddb"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   StyleBox["u",
    FontSlant->"Italic"], 
   RowBox[{
    StyleBox["(",
     FontSlant->"Italic"], 
    RowBox[{
     StyleBox["L",
      FontSlant->"Italic"], 
     StyleBox[",",
      FontSlant->"Plain"], 
     StyleBox["t",
      FontSlant->"Italic"]}], 
    StyleBox[")",
     FontSlant->"Italic"]}]}], "=", "0"}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.807636719162508*^9, 
  3.8076367215482955`*^9}},ExpressionUUID->"63e53c38-8451-47f8-bebc-\
64802e1fd4a6"],

Cell["\<\
meaning that the string can\[CloseCurlyQuote]t be displaced at the ends \
(which makes sense because they\[CloseCurlyQuote]re fixed).\
\>", "Text",
 CellChangeTimes->{{3.8076367286060867`*^9, 
  3.8076367580845647`*^9}},ExpressionUUID->"042d4d81-a913-4650-9cf6-\
f73c79a3c52d"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Finding a Solution", "Subsection",
 CellChangeTimes->{{3.8076367776539707`*^9, 3.8076367807519026`*^9}, {
  3.807890423581408*^9, 
  3.807890424714757*^9}},ExpressionUUID->"c81f2874-d89f-40b0-b4f3-\
0b7f99a3120f"],

Cell[TextData[{
 "We can start with the solution to the position dependence given by ",
 StyleBox["X",
  FontSlant->"Italic"],
 "(",
 StyleBox["x",
  FontSlant->"Italic"],
 "). Rewriting equation (6) slightly, we have"
}], "Text",
 CellChangeTimes->{{3.8076367849657245`*^9, 3.8076367979671392`*^9}, {
  3.8076369003004785`*^9, 3.8076369182141175`*^9}, {3.807891519428454*^9, 
  3.807891560109711*^9}, {3.9146660329776554`*^9, 
  3.914666033353322*^9}},ExpressionUUID->"45ab73db-a230-4035-8d8b-\
0f8a0dbc01b4"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   FractionBox[
    RowBox[{
     RowBox[{
      SuperscriptBox["\[DifferentialD]", "2"], 
      StyleBox["X",
       FontSlant->"Italic"]}], 
     StyleBox[
      RowBox[{"(", "x", ")"}],
      FontSlant->"Italic"]}], 
    RowBox[{"\[DifferentialD]", 
     SuperscriptBox[
      StyleBox["x",
       FontSlant->"Italic"], "2"]}]], "-", 
   StyleBox[
    RowBox[{"K", " ", "X", 
     RowBox[{"(", "x", ")"}]}],
    FontSlant->"Italic"]}], 
  StyleBox["=",
   FontSlant->"Plain"], 
  StyleBox["0",
   FontSlant->"Plain"]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8078917168441167`*^9, 3.8078917387598248`*^9}, {
  3.8079662384224157`*^9, 3.807966241287773*^9}, {3.9148604424572067`*^9, 
  3.91486044982189*^9}},ExpressionUUID->"316be63b-9947-4fb5-b070-\
39165684b4a4"],

Cell[TextData[{
 "We already discussed that when ",
 StyleBox["K",
  FontSlant->"Italic"],
 " = 0, there is no wave. If ",
 StyleBox["K",
  FontSlant->"Italic"],
 " >0, then"
}], "Text",
 CellChangeTimes->{
  3.8078915623749475`*^9},ExpressionUUID->"5b8e000b-27e7-4357-992b-\
92fec3f0d803"],

Cell[BoxData[
 RowBox[{
  StyleBox[
   RowBox[{"X", 
    RowBox[{"(", "x", ")"}]}],
   FontSlant->"Italic"], "=", 
  RowBox[{
   RowBox[{
    SubscriptBox[
     StyleBox["c",
      FontSlant->"Italic"], "1"], 
    SuperscriptBox["\[ExponentialE]", 
     StyleBox["kx",
      FontSlant->"Italic"]]}], "+", 
   RowBox[{
    SubscriptBox[
     StyleBox["c",
      FontSlant->"Italic"], "2"], 
    SuperscriptBox["\[ExponentialE]", 
     StyleBox[
      RowBox[{"-", "kx"}],
      FontSlant->"Italic"]]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.807636938176734*^9, 3.807636948402064*^9}, {
   3.8076370584824505`*^9, 3.8076370589929886`*^9}, 
   3.9146660976514034`*^9},ExpressionUUID->"31581499-5de4-4fd0-b643-\
a983a2231aef"],

Cell[TextData[{
 "We know from the boundary conditions that ",
 StyleBox["X",
  FontSlant->"Italic"],
 "(0) = 0 and ",
 StyleBox["X",
  FontSlant->"Italic"],
 "(",
 StyleBox["L",
  FontSlant->"Italic"],
 ") = 0, so"
}], "Text",
 CellChangeTimes->{{3.8076369580656385`*^9, 3.807637012820156*^9}, 
   3.8076370653755107`*^9, {3.8087600639186416`*^9, 
   3.808760064815029*^9}},ExpressionUUID->"933ab750-89a6-40df-9628-\
a6a5004ca73e"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   StyleBox["X",
    FontSlant->"Italic"], 
   RowBox[{
    StyleBox["(",
     FontSlant->"Italic"], 
    StyleBox["0",
     FontSlant->"Plain"], 
    StyleBox[")",
     FontSlant->"Italic"]}]}], "=", 
  RowBox[{"0", "=", 
   RowBox[{
    SubscriptBox[
     StyleBox["c",
      FontSlant->"Italic"], "1"], "+", 
    SubscriptBox[
     StyleBox["c",
      FontSlant->"Italic"], "2"]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.807637031557167*^9, 
  3.8076370766330185`*^9}},ExpressionUUID->"cb67abb3-4ab7-4578-89bc-\
ab6ae7c9d7b5"],

Cell["and", "Text",
 CellChangeTimes->{{3.8076370866837626`*^9, 
  3.8076370868775234`*^9}},ExpressionUUID->"cdc2b7fa-4029-4570-9922-\
693938879867"],

Cell[BoxData[
 RowBox[{
  StyleBox[
   RowBox[{"X", 
    RowBox[{"(", "L", ")"}]}],
   FontSlant->"Italic"], "=", 
  RowBox[{"0", "=", 
   RowBox[{
    RowBox[{
     SubscriptBox[
      StyleBox["c",
       FontSlant->"Italic"], "1"], 
     SuperscriptBox["\[ExponentialE]", 
      StyleBox["kL",
       FontSlant->"Italic"]]}], "+", 
    RowBox[{
     SubscriptBox[
      StyleBox["c",
       FontSlant->"Italic"], "2"], 
     SuperscriptBox["\[ExponentialE]", 
      StyleBox[
       RowBox[{"-", "kL"}],
       FontSlant->"Italic"]]}]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8076371123853855`*^9, 3.8076371524192667`*^9}, {
  3.914666062913182*^9, 
  3.9146660707780633`*^9}},ExpressionUUID->"15fd5e73-09cb-418c-911a-\
b64388e47d22"],

Cell[TextData[{
 StyleBox["the only possible way for these conditions to be met is if ",
  FontSlant->"Plain"],
 Cell[BoxData[
  SubscriptBox[
   StyleBox["c",
    FontSlant->"Italic"], "1"]],
  CellChangeTimes->{{3.8076371123853855`*^9, 3.8076371524192667`*^9}},
  ExpressionUUID->"3cead058-d9fe-4910-a930-45e2a7de2514"],
 " ",
 StyleBox["= ",
  FontSlant->"Plain"],
 Cell[BoxData[
  SubscriptBox[
   StyleBox["c",
    FontSlant->"Italic"], "2"]],
  CellChangeTimes->{{3.8076371123853855`*^9, 3.8076371524192667`*^9}},
  ExpressionUUID->"9a1b8824-0c06-4e48-8bd1-5f08eeca086b"],
 " ",
 StyleBox["= 0, which also means there\[CloseCurlyQuote]s no wave.",
  FontSlant->"Plain"]
}], "Text",
 CellChangeTimes->{{3.8076371709298253`*^9, 3.807637208002103*^9}},
 FontSlant->"Italic",ExpressionUUID->"b766a145-a908-41d7-9eb1-8c762ba2dae9"],

Cell["\<\
The last best hope for a non - trivial solution is then K < 0. Recall that if \
K < 0, the solution takes the form \
\>", "Text",
 CellChangeTimes->{{3.8076372135977783`*^9, 3.8076372463430405`*^9}, {
   3.8078690614131966`*^9, 3.807869073499844*^9}, {3.80787104156981*^9, 
   3.807871041582737*^9}, 3.8078711760515137`*^9, {3.934369315274763*^9, 
   3.9343693154442635`*^9}},ExpressionUUID->"c6cbddc0-72ab-46d8-ab82-\
e4c4b8a8bf05"],

Cell[BoxData[
 RowBox[{
  StyleBox[
   RowBox[{"X", 
    RowBox[{"(", "x", ")"}]}],
   FontSlant->"Italic"], "=", 
  RowBox[{
   RowBox[{
    SubscriptBox[
     StyleBox["c",
      FontSlant->"Italic"], "1"], 
    SuperscriptBox["\[ExponentialE]", 
     StyleBox[
      RowBox[{
       StyleBox["\[ImaginaryI]",
        FontSlant->"Plain"], 
       StyleBox["kx",
        FontSlant->"Italic"]}]]]}], "+", 
   RowBox[{
    SubscriptBox[
     StyleBox["c",
      FontSlant->"Italic"], "2"], 
    SuperscriptBox["\[ExponentialE]", 
     RowBox[{
      StyleBox["-",
       FontSlant->"Italic"], 
      StyleBox[
       RowBox[{
        StyleBox["\[ImaginaryI]",
         FontSlant->"Plain"], 
        StyleBox["kx",
         FontSlant->"Italic"]}]]}]]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8078690896740685`*^9, 3.8078690975644183`*^9}, 
   3.9146661524953585`*^9},ExpressionUUID->"ed3c8dfe-af5c-4182-9d10-\
c81e4ad44f11"],

Cell["Let\[CloseCurlyQuote]s use Euler\[CloseCurlyQuote]s formula,", "Text",
 CellChangeTimes->{{3.807870392253518*^9, 
  3.807870421652693*^9}},ExpressionUUID->"4895aaf0-ff34-41d6-8436-\
abd4d5824dd7"],

Cell[BoxData[
 RowBox[{
  SuperscriptBox["\[ExponentialE]", 
   RowBox[{"\[PlusMinus]", 
    StyleBox[
     RowBox[{"\[ImaginaryI]", 
      StyleBox["kx",
       FontSlant->"Italic"]}]]}]], "=", 
  RowBox[{
   RowBox[{"cos", 
    RowBox[{"(", 
     StyleBox["kx",
      FontSlant->"Italic"], ")"}]}], "\[PlusMinus]", 
   RowBox[{"\[ImaginaryI]", " ", "sin", 
    RowBox[{"(", 
     StyleBox["kx",
      FontSlant->"Italic"], ")"}]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.807870426292494*^9, 3.807870508138503*^9}, {
  3.914666161303809*^9, 
  3.9146662003767586`*^9}},ExpressionUUID->"d5a18fcb-cd2c-4fe3-85fe-\
ad6bf5c4e9a2"],

Cell["to convert our representation of equation (16).", "Text",
 CellChangeTimes->{{3.8078705842933044`*^9, 3.8078705970601697`*^9}, {
  3.8078917537460804`*^9, 3.8078917545419035`*^9}, {3.914666230377915*^9, 
  3.9146662312571554`*^9}},ExpressionUUID->"6b017355-6e32-4a2f-94a0-\
58646ca59776"],

Cell[BoxData[
 RowBox[{
  StyleBox[
   RowBox[{"X", 
    RowBox[{"(", "x", ")"}]}],
   FontSlant->"Italic"], 
  StyleBox["=",
   FontSlant->"Plain"], 
  RowBox[{
   RowBox[{
    SubscriptBox[
     StyleBox["c",
      FontSlant->"Italic"], "1"], "[", 
    RowBox[{
     RowBox[{"cos", 
      RowBox[{"(", 
       StyleBox["kx",
        FontSlant->"Italic"], ")"}]}], "+", 
     RowBox[{"\[ImaginaryI]", " ", "sin", 
      RowBox[{"(", 
       StyleBox["kx",
        FontSlant->"Italic"], ")"}]}]}], "]"}], "+", 
   RowBox[{
    SubscriptBox["c", "2"], "[", 
    RowBox[{
     RowBox[{"cos", 
      RowBox[{"(", 
       StyleBox["kx",
        FontSlant->"Italic"], ")"}]}], "\[Minus]", 
     RowBox[{"\[ImaginaryI]", " ", "sin", 
      RowBox[{"(", 
       StyleBox["kx",
        FontSlant->"Italic"], ")"}]}]}], "]"}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.807870607396226*^9, 3.8078706084301205`*^9}, {
  3.8078706596429195`*^9, 3.807870695608344*^9}, {3.9146662131792974`*^9, 
  3.9146662206174946`*^9}},ExpressionUUID->"17d29004-ea65-4534-9800-\
4c878defd43a"],

Cell["Collecting cos() and sin() terms gives us", "Text",
 CellChangeTimes->{{3.8078707025154753`*^9, 3.8078707107274113`*^9}, {
  3.934369373756941*^9, 
  3.934369374201168*^9}},ExpressionUUID->"70eafd14-f6f4-4eef-8a2b-\
27709de12c5e"],

Cell[BoxData[
 RowBox[{
  StyleBox[
   RowBox[{"X", 
    RowBox[{"(", "x", ")"}]}],
   FontSlant->"Italic"], 
  StyleBox["=",
   FontSlant->"Plain"], 
  RowBox[{
   RowBox[{
    RowBox[{
     StyleBox["(",
      FontSlant->"Plain"], 
     RowBox[{
      SubscriptBox[
       StyleBox["c",
        FontSlant->"Italic"], "1"], "+", 
      SubscriptBox[
       StyleBox["c",
        FontSlant->"Italic"], "2"]}], ")"}], "cos", 
    RowBox[{"(", 
     StyleBox["kx",
      FontSlant->"Italic"], ")"}]}], "+", 
   RowBox[{"\[ImaginaryI]", 
    RowBox[{"(", 
     RowBox[{
      SubscriptBox[
       StyleBox["c",
        FontSlant->"Italic"], "1"], "-", 
      SubscriptBox[
       StyleBox["c",
        FontSlant->"Italic"], "2"]}], ")"}], "sin", 
    RowBox[{"(", 
     StyleBox["kx",
      FontSlant->"Italic"], ")"}]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8078707213166084`*^9, 3.8078707674762955`*^9}, {
  3.9146662380456953`*^9, 
  3.914666238257505*^9}},ExpressionUUID->"559b7a7a-863e-4103-b427-\
96139727fd18"],

Cell[TextData[{
 "Now we define new constants, ",
 Cell[BoxData[
  SubsuperscriptBox[
   StyleBox["c",
    FontSlant->"Italic"], "1", "'"]],
  CellChangeTimes->{{3.8078707213166084`*^9, 3.8078707674762955`*^9}},
  ExpressionUUID->"42ef7812-c0d6-4095-99e6-52add3d28d6b"],
 " = ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["c",
     FontSlant->"Italic"], "1"], "+", 
   SubscriptBox[
    StyleBox["c",
     FontSlant->"Italic"], "2"]}]],
  CellChangeTimes->{{3.8078707213166084`*^9, 3.8078707674762955`*^9}},
  ExpressionUUID->"66ab3a1d-7277-4403-9144-88a796c39c24"],
 " and ",
 Cell[BoxData[
  SubsuperscriptBox[
   StyleBox["c",
    FontSlant->"Italic"], "2", "'"]],
  CellChangeTimes->{{3.8078707213166084`*^9, 3.8078707674762955`*^9}},
  ExpressionUUID->"b49685aa-e194-48f9-9e6a-c6c8f1eda116"],
 " = \[ImaginaryI](",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["c",
     FontSlant->"Italic"], "1"], "-", 
   SubscriptBox[
    StyleBox["c",
     FontSlant->"Italic"], "2"]}]],
  CellChangeTimes->{{3.8078707213166084`*^9, 3.8078707674762955`*^9}},
  ExpressionUUID->"472a008c-8df7-4ee5-af60-d9c2e8e49cc0"],
 "), so that  "
}], "Text",
 CellChangeTimes->{{3.8078708231734047`*^9, 3.8078709299024134`*^9}, {
  3.914666244516697*^9, 3.9146662466092663`*^9}, {3.9343693790590305`*^9, 
  3.9343693814514084`*^9}},ExpressionUUID->"1576a195-8bc2-4e57-8787-\
d931d4ccfe60"],

Cell[BoxData[
 RowBox[{
  StyleBox[
   RowBox[{"X", 
    RowBox[{"(", "x", ")"}]}],
   FontSlant->"Italic"], 
  StyleBox["=",
   FontSlant->"Plain"], 
  RowBox[{
   RowBox[{
    SubsuperscriptBox[
     StyleBox["c",
      FontSlant->"Italic"], "1", "'"], "cos", 
    RowBox[{"(", 
     StyleBox["kx",
      FontSlant->"Italic"], ")"}]}], "+", 
   RowBox[{
    SubsuperscriptBox[
     StyleBox["c",
      FontSlant->"Italic"], "2", "'"], "sin", 
    RowBox[{"(", 
     StyleBox["kx",
      FontSlant->"Italic"], ")"}]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8078709470180807`*^9, 
  3.8078709681161065`*^9}},ExpressionUUID->"5d20ac4e-c114-4872-9eab-\
af24bb9d4bd9"],

Cell["Now we can use those boundary conditions to find a solution.", "Text",
 CellChangeTimes->{{3.8078709814652815`*^9, 3.8078710081766806`*^9}, {
  3.8087600828592825`*^9, 
  3.808760084078792*^9}},ExpressionUUID->"1e08ae36-50c5-4ea1-8e22-\
e860128a6f67"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   StyleBox["X",
    FontSlant->"Italic"], 
   RowBox[{
    StyleBox["(",
     FontSlant->"Italic"], 
    StyleBox["0",
     FontSlant->"Plain"], 
    StyleBox[")",
     FontSlant->"Italic"]}]}], 
  StyleBox["=",
   FontSlant->"Plain"], 
  RowBox[{
   StyleBox["0",
    FontSlant->"Plain"], 
   StyleBox["=",
    FontSlant->"Plain"], 
   RowBox[{
    RowBox[{
     SubsuperscriptBox[
      StyleBox["c",
       FontSlant->"Italic"], "1", "'"], "cos", 
     RowBox[{"(", "0", ")"}]}], "+", 
    RowBox[{
     SubsuperscriptBox[
      StyleBox["c",
       FontSlant->"Italic"], "2", "'"], "sin", 
     RowBox[{"(", "0", ")"}]}]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8078710533079896`*^9, 3.8078710768513994`*^9}, {
  3.8078712094225693`*^9, 
  3.8078712100284305`*^9}},ExpressionUUID->"cec65660-524d-4bcb-a2c7-\
a066eb359982"],

Cell["Remember that sin(0) = 0 and cos(0) = 1, so ", "Text",
 CellChangeTimes->{{3.8078710821945925`*^9, 
  3.807871103866106*^9}},ExpressionUUID->"224df7bc-e8c2-4ab9-b2a5-\
d9d605e752ed"],

Cell[BoxData[
 RowBox[{
  SubsuperscriptBox[
   StyleBox["c",
    FontSlant->"Italic"], "1", "'"], "=", "0"}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8078711160824804`*^9, 
  3.8078711199703217`*^9}},ExpressionUUID->"38fb939a-6e42-42e0-b12e-\
f9c22b1b4cff"],

Cell[TextData[{
 "Then we can use our other boundary condition, ",
 StyleBox["X ",
  FontSlant->"Italic"],
 "(",
 StyleBox["L",
  FontSlant->"Italic"],
 ") = 0, to find"
}], "Text",
 CellChangeTimes->{{3.8078711287566476`*^9, 
  3.807871165092407*^9}},ExpressionUUID->"a24cb4e1-babd-4d55-8fc2-\
302c54401d45"],

Cell[BoxData[
 RowBox[{
  StyleBox[
   RowBox[{"X", 
    RowBox[{"(", "L", ")"}]}],
   FontSlant->"Italic"], 
  StyleBox["=",
   FontSlant->"Plain"], 
  RowBox[{
   StyleBox["0",
    FontSlant->"Plain"], 
   StyleBox["=",
    FontSlant->"Plain"], 
   RowBox[{
    SubsuperscriptBox[
     StyleBox["c",
      FontSlant->"Italic"], "2", "'"], "sin", 
    RowBox[{"(", 
     StyleBox["kL",
      FontSlant->"Italic"], ")"}]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.807871215282195*^9, 
  3.807871233421128*^9}},ExpressionUUID->"ec25bfae-e4d1-4c74-b1b3-\
8398969874ab"],

Cell[TextData[{
 "This solution has two possible solutions: either ",
 Cell[BoxData[
  SubsuperscriptBox[
   StyleBox["c",
    FontSlant->"Italic"], "2", "'"]],
  CellChangeTimes->{{3.8078707213166084`*^9, 3.8078707674762955`*^9}},
  ExpressionUUID->"2b2023cd-e06e-4a09-9bf3-74a51ccb9102"],
 "= 0 or sin(",
 StyleBox["kL",
  FontSlant->"Italic"],
 ") = 0. If ",
 Cell[BoxData[
  SubsuperscriptBox[
   StyleBox["c",
    FontSlant->"Italic"], "2", "'"]],
  CellChangeTimes->{{3.8078707213166084`*^9, 3.8078707674762955`*^9}},
  ExpressionUUID->"49aca39a-355a-415c-a8c9-0ad5c79b8c9e"],
 "= 0, then there is no wave, and we\[CloseCurlyQuote]re back to a \
meaningless solution. Recall that sin() is a periodic function, and sin(",
 StyleBox["x",
  FontSlant->"Italic"],
 ") = 0 whenever ",
 StyleBox["x  ",
  FontSlant->"Italic"],
 "= ",
 StyleBox["n",
  FontSlant->"Italic"],
 "\[Pi], where ",
 StyleBox["n",
  FontSlant->"Italic"],
 " is an integer. So we end up with the result"
}], "Text",
 CellChangeTimes->{{3.807871255278566*^9, 3.807871439499816*^9}, {
  3.807871520588026*^9, 
  3.8078715273417*^9}},ExpressionUUID->"2d76eeb6-00d3-4296-946a-cd8e76410a23"],

Cell[BoxData[
 RowBox[{
  StyleBox["k",
   FontSlant->"Italic"], 
  StyleBox["=",
   FontSlant->"Plain"], 
  FractionBox[
   StyleBox[
    RowBox[{
     StyleBox["n",
      FontSlant->"Italic"], "\[Pi]"}]], 
   StyleBox["L",
    FontSlant->"Italic"]]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8078715379595222`*^9, 
  3.8078715606925907`*^9}},ExpressionUUID->"743c42a6-1518-4704-b370-\
6f9c62be464c"],

Cell["and our solution (for spatial dependence) is", "Text",
 CellChangeTimes->{{3.80787156774032*^9, 3.807871576644302*^9}, {
  3.807892862419624*^9, 
  3.807892864591626*^9}},ExpressionUUID->"57fe8cf6-c7f8-4261-9b91-\
a3ec1f549c64"],

Cell[BoxData[
 RowBox[{
  StyleBox[
   RowBox[{"X", 
    RowBox[{"(", "x", ")"}]}],
   FontSlant->"Italic"], 
  StyleBox["=",
   FontSlant->"Plain"], 
  RowBox[{
   SubsuperscriptBox[
    StyleBox["c",
     FontSlant->"Italic"], "2", "'"], "sin", 
   RowBox[{"(", 
    StyleBox[
     FractionBox[
      StyleBox[
       RowBox[{
        StyleBox["n",
         FontSlant->"Italic"], "\[Pi]", 
        StyleBox["x",
         FontSlant->"Italic"]}]], 
      StyleBox["L",
       FontSlant->"Italic"]],
     FontSlant->"Italic"], ")"}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8078716160155306`*^9, 3.8078716498588743`*^9}, 
   3.8078718474214697`*^9},ExpressionUUID->"64836538-f233-45d8-b66d-\
139aee274682"],

Cell[TextData[{
 "The value of ",
 StyleBox["n",
  FontSlant->"Italic"],
 " here can vary from 1 to infinity, so there are many possible solutions. \
Let\[CloseCurlyQuote]s take a look at a few of the solutions (Figure 2.1), \
which are a set of ",
 StyleBox["periodic",
  FontSlant->"Italic"],
 " functions",
 "."
}], "Text",
 CellChangeTimes->{{3.807871690911067*^9, 3.8078717227050967`*^9}, {
   3.8078718539791155`*^9, 3.8078718806551085`*^9}, 3.807872175630198*^9, {
   3.8078904979777875`*^9, 3.807890526880234*^9}, {3.914666312916109*^9, 
   3.914666336354119*^9}},ExpressionUUID->"ee65e888-04d8-4aeb-b065-\
8006fae4e5c7"],

