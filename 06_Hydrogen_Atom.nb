Cell[CellGroupData[{

Cell["Interpreting the Hydrogen Atomic Wavefunctions and Energies", "Section",
 CellChangeTimes->{{3.8106604979360104`*^9, 
  3.8106605113418818`*^9}},ExpressionUUID->"92301a4b-3a16-489a-8fc9-\
dba5d6c63932"],

Cell["\<\
Solving for the energies and wavefunctions of the hydrogen atom is an \
important first step, but the equations above can be difficult to interpret. \
Now, let\[CloseCurlyQuote]s dive into what these equations actually tell us \
about the hydrogen atom.\
\>", "Text",
 CellChangeTimes->{{3.8106605703742676`*^9, 
  3.8106606184675846`*^9}},ExpressionUUID->"303e7da7-6f95-4375-8de3-\
78f7d2e99576"],

Cell[CellGroupData[{

Cell[TextData[{
 "The Quantum Numbers ",
 StyleBox["m",
  FontSlant->"Italic"],
 " and ",
 StyleBox["l",
  FontSlant->"Italic"],
 " Constrain the Angular Momentum"
}], "Subsection",
 CellChangeTimes->{{3.8106606487387724`*^9, 3.8106606648162804`*^9}, {
  3.9355891815818386`*^9, 
  3.935589191132183*^9}},ExpressionUUID->"10cf61f5-b4c8-4c8d-9b53-\
81de261c4ba3"],

Cell["\<\
Let\[CloseCurlyQuote]s look back briefly at our differential equation for the \
angular component of the hydrogen atom,\
\>", "Text",
 CellChangeTimes->{{3.8106607140456495`*^9, 
  3.8106607506653175`*^9}},ExpressionUUID->"e8a92768-c5f3-452b-b9cb-\
573a21a2775a"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   FractionBox[
    RowBox[{"-", "1"}], 
    RowBox[{
     SubsuperscriptBox[
      StyleBox["Y",
       FontSlant->"Italic"], 
      StyleBox["l",
       FontSlant->"Italic"], 
      SubscriptBox["m", 
       StyleBox["l",
        FontSlant->"Italic"]]], 
     RowBox[{"(", 
      RowBox[{"\[Theta]", ",", "\[Phi]"}], ")"}]}]], "[", 
   RowBox[{
    RowBox[{
     FractionBox["1", 
      RowBox[{"sin", 
       RowBox[{"(", "\[Theta]", ")"}]}]], 
     RowBox[{
      FractionBox["\[PartialD]", 
       RowBox[{"\[PartialD]", "\[Theta]"}]], 
      RowBox[{"(", 
       RowBox[{"sin", 
        RowBox[{"(", "\[Theta]", ")"}], 
        FractionBox[
         RowBox[{
          RowBox[{"\[PartialD]", 
