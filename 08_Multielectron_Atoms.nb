Cell[TextData[{
 "We see that this operator simply represents the effective potential \
experienced by an electron in spin orbital ",
 StyleBox["i ",
  FontSlant->"Italic"],
 " in the presence of an electron in spin orbital ",
 StyleBox["j",
  FontSlant->"Italic"],
 ", so this component we already observed in the case of the Hartree \
approximation."
}], "Text",
