         RowBox[{
          RowBox[{"10", "d", " ", 
           SuperscriptBox["\[Omega]", 
            RowBox[{"-", "1"}]]}], "-", "v", "-", ".5"}]], 
        RowBox[{"LaguerreL", "[", 
         RowBox[{"v", ",", 
