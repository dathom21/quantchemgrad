        StyleBox["zA",
         FontSlant->"Italic"]]}]]}], "+", 
    RowBox[{
     SubscriptBox[
      StyleBox["c",
       FontSlant->"Italic"], "6"], 
     SubscriptBox["\[Phi]", 
