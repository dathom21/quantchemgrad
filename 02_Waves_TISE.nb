   RowBox[{"A", "[", "n", "]"}], "=", 
   RowBox[{
    RowBox[{
     FractionBox["2", "L"], 
     RowBox[{"NIntegrate", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"f", "[", "x", "]"}], 
        RowBox[{"Sin", "[", 
         RowBox[{
          FractionBox[
           RowBox[{"n", " ", "\[Pi]"}], "L"], " ", "x"}], "]"}]}], ",", 
       RowBox[{"{", 
        RowBox[{"x", ",", "0", ",", 
         RowBox[{"L", "/", "2"}]}], "}"}]}], "]"}]}], "+", 
    RowBox[{
     FractionBox["2", "L"], 
     RowBox[{"NIntegrate", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"f", "[", "x", "]"}], 
        RowBox[{"Sin", "[", 
         RowBox[{
          FractionBox[
           RowBox[{"n", " ", "\[Pi]"}], "L"], " ", "x"}], "]"}]}], ",", 
       RowBox[{"{", 
        RowBox[{"x", ",", 
         RowBox[{"L", "/", "2"}], ",", "L"}], "}"}]}], "]"}]}]}]}]}], "\n", 
 RowBox[{
