Cell[BoxData[
 RowBox[{"Det", "[", GridBox[{
    {
     RowBox[{"-", "3"}], "2", 
     RowBox[{"-", "3"}]},
    {"1", "8", "1"},
    {"5", "2", "5"}
   }], "]"}]], "Input",
 CellChangeTimes->{{3.811318368945367*^9, 3.8113183817902255`*^9}},
 CellLabel->"In[4]:=",ExpressionUUID->"8f2ba677-f16d-4f07-98aa-7d28b8adce7c"],

