Cell[TextData[{
 StyleBox["Figure 1.6",
  FontWeight->"Bold"],
 ". Bragg Diffraction, Hydrargyrum, Wikimedia Commons, CC BY-SA 3.0, \
https://commons.wikimedia.org/wiki/File:Bragg_diffraction_2.svg"
}], "Affiliation",
 CellChangeTimes->{{3.809435027311596*^9, 3.8094350763900714`*^9}, {
  3.80943583474421*^9, 3.8094358359299717`*^9}, {3.8094472165104203`*^9, 
  3.809447281165168*^9}, {3.809510876137825*^9, 3.809510907739876*^9}, {
  3.809968073566992*^9, 3.8099681536568317`*^9}, {3.810557260250428*^9, 
  3.8105572606139913`*^9}, {3.8130835305386977`*^9, 3.8130836194514275`*^9}, {
  3.813224407772764*^9, 3.8132244817756805`*^9}, {3.8394266250053024`*^9, 
  3.839426636135662*^9}, {3.8394271229755535`*^9, 3.8394271464856167`*^9}, {
  3.8394271859998655`*^9, 3.8394272181213303`*^9}, {3.8394281636526613`*^9, 
  3.839428168851229*^9}, {3.91423799573891*^9, 3.9142379968867025`*^9}, {
  3.9145996359413767`*^9, 
  3.914599640554757*^9}},ExpressionUUID->"fbea06ca-31a7-449c-a73f-\
4024a8ef182c"],

Cell["\<\
Constructive interference between waves occurs at the so-called Bragg \
condition,\
\>", "Text",
 CellChangeTimes->{{3.8081424563064966`*^9, 
  3.8081424762208195`*^9}},ExpressionUUID->"0bc40f9c-eefe-4e6c-9496-\
95b5af1e3da5"],

Cell[BoxData[
 RowBox[{
  StyleBox[
   RowBox[{
    StyleBox["n",
     FontSlant->"Italic"], "\[Lambda]"}]], "=", 
  RowBox[{"2", 
   StyleBox["d",
    FontSlant->"Italic"], 
   StyleBox[" ",
    FontSlant->"Italic"], "sin", 
   RowBox[{"(", "\[Theta]", ")"}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8081425493072186`*^9, 
  3.808142593360757*^9}},ExpressionUUID->"fc839db0-f3b1-403f-82b3-\
e7419595a8f2"],

Cell[TextData[{
 "where ",
 StyleBox["n",
  FontSlant->"Italic"],
 " is an integer from 1 upwards, ",
 StyleBox["d",
  FontSlant->"Italic"],
 " is the lattice spacing (the space between atoms, see image above), and \
\[Theta] is the angle of incidence or angle of scattering (see image above). \
So if you have a wave incident on the lattice, you can see peaks in the \
scattering pattern if you scan a detector across the angle of incidence. \
Because, as de Broglie hypothesized, matter also has a wavelength, \
diffraction patterns can also be observed for matter."
}], "Text",
 CellChangeTimes->{{3.8081426237263837`*^9, 3.8081426872444663`*^9}, {
  3.8081428055657096`*^9, 3.8081428511559486`*^9}, {3.914599592918154*^9, 
  3.9145996062952623`*^9}},ExpressionUUID->"209cbe4c-0493-408b-ba64-\
a405a842e623"]
}, Open  ]],

Cell[CellGroupData[{

Cell["The Wave Nature of Matter", "Subsection",
 CellChangeTimes->{{3.8073700346205263`*^9, 
  3.807370041451276*^9}},ExpressionUUID->"891aba1a-c2de-44da-b67e-\
9ed78948bd91"],

Cell[TextData[{
 "The proposal by de Broglie and subsequent experimental verification by \
Davisson and Germer demonstrated the wave nature of matter (as well as \
light). Below in Figure 1.7 is a demonstration of the wave nature of the \
electron. The light areas show the ",
 StyleBox["probability",
  FontSlant->"Italic"],
 " of measuring the electron at a specific location at different time points \
as the electron passes through two slits. This phenomenon leads to a \
diffraction pattern, typically observed by collection beyond the slit. This \
is the matter analogue of the famous Young\[CloseCurlyQuote]s double slit \
experiment for light."
}], "Text",
 CellChangeTimes->{{3.807370055347022*^9, 3.80737008120419*^9}, {
   3.8073702009107666`*^9, 3.8073703701664686`*^9}, 3.9142379731264195`*^9, {
   3.9142380383570523`*^9, 3.914238048099766*^9}, {3.914238112616505*^9, 
   3.9142381497561293`*^9}, {3.9145996494818063`*^9, 
   3.9145996496296406`*^9}},ExpressionUUID->"be2f0854-08da-4c66-8e35-\
f8980da148a8"],

Cell["\<\
 But to really be able to interpret this result, we need to know more about \
the wave nature of matter. What are its implications? How can we describe it? \
More on that in the coming lessons.\
\>", "Text",
 CellChangeTimes->{{3.914238031987249*^9, 
  3.914238036581008*^9}},ExpressionUUID->"b2217dff-0271-447b-98e3-\
58017a96834a"],

Cell["", "Text",
 CellChangeTimes->{
  3.807370621347946*^9, {3.807370659813136*^9, 3.8073706726314783`*^9}, {
   3.807370790634924*^9, 3.8073707961347747`*^9}, {3.839428218834738*^9, 
   3.8394282216925993`*^9}},ExpressionUUID->"00fec288-0c9c-4050-a3aa-\
755f44229481"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"n", "=", "55"}], ";", 
  RowBox[{"dx", "=", 
   FractionBox["1.0", 
    RowBox[{"n", "-", "1"}]]}], ";", 
  RowBox[{"hbar", "=", 
   RowBox[{"m", "=", "1"}]}], ";", 
  RowBox[{"dt", "=", 
   FractionBox[
    RowBox[{"m", " ", 
     SuperscriptBox["dx", "2"]}], "hbar"]}], ";", 
  RowBox[{"a", "=", 
   FractionBox[
    RowBox[{"\[ImaginaryI]", " ", "hbar"}], "dt"]}], ";", 
  RowBox[{"b", "=", 
   FractionBox[
    SuperscriptBox["hbar", "2"], 
    RowBox[{"4", " ", "m", " ", 
     SuperscriptBox["dx", "2"]}]]}], ";", 
  RowBox[{"blist", "=", 
   RowBox[{"Table", "[", 
    RowBox[{"b", ",", 
     RowBox[{"{", 
      RowBox[{"n", "-", "1"}], "}"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"V", "=", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"0.48", "<", "x", "<", "0.52"}], "&&", 
        RowBox[{"!", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"0.4", "<", "y", "<", "0.475"}], "||", 
           RowBox[{"0.525", "<", "y", "<", "0.6"}]}], ")"}]}]}], ",", "10000",
        ",", "0"}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"y", ",", "0", ",", "1", ",", "dx"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", "0", ",", "1", ",", "dx"}], "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{"Manipulate", "[", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", "\[IndentingNewLine]", 
      RowBox[{"psi", "=", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"Module", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"p", "=", 
             RowBox[{"{", 
              RowBox[{
               RowBox[{"x", "-", "0.25"}], ",", 
