Cell[TextData[{
 StyleBox["Figure 13.11",
  FontWeight->"Bold"],
 ". Water has two distinct ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Sigma]", "v"], TraditionalForm]],ExpressionUUID->
  "9e29a6ac-1fd7-40cd-9098-02fb821f5910"],
 " planes of symmetry, and benzene has one ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Sigma]", "h"], TraditionalForm]],ExpressionUUID->
  "d72dec8a-fe90-4dc3-a023-035f384f6d5f"],
 " (in plane of molecule), three ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Sigma]", "d"], TraditionalForm]],ExpressionUUID->
  "612fac1c-1777-4910-8ace-1ac468015995"],
 " (bisecting bonds), and three ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Sigma]", "v"], TraditionalForm]],ExpressionUUID->
  "8b23d80b-2b5b-4413-80f2-6c719f6d173f"],
 " (through atoms) planes of symmetry."
}], "Affiliation",
