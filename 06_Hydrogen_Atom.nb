Cell[BoxData[
 RowBox[{
  SubscriptBox[
   StyleBox["N",
    FontSlant->"Italic"], 
   SubscriptBox[
    StyleBox["lm",
     FontSlant->"Italic"], 
    StyleBox["l",
     FontSlant->"Italic"]]], "=", 
  SuperscriptBox[
   RowBox[{"(", 
    RowBox[{
     FractionBox[
      RowBox[{"(", 
       RowBox[{
        RowBox[{"2", 
         StyleBox["l",
          FontSlant->"Italic"]}], "+", "1"}], ")"}], "2"], 
     FractionBox[
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         StyleBox["l",
          FontSlant->"Italic"], 
         StyleBox["-",
          FontSlant->"Italic"], 
         RowBox[{"\[LeftBracketingBar]", 
          StyleBox[
           SubscriptBox[
            StyleBox["m",
             FontSlant->"Italic"], 
            StyleBox["l",
             FontSlant->"Italic"]],
           FontSlant->"Italic"], "\[RightBracketingBar]"}]}], ")"}], "!"}], 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         StyleBox["l",
          FontSlant->"Italic"], "+", 
         RowBox[{"\[LeftBracketingBar]", 
          StyleBox[
           SubscriptBox[
            StyleBox["m",
             FontSlant->"Italic"], 
            StyleBox["l",
             FontSlant->"Italic"]],
           FontSlant->"Italic"], "\[RightBracketingBar]"}]}], ")"}], "!"}]]}],
     ")"}], 
   RowBox[{"1", "/", "2"}]]}]], "DisplayFormulaNumbered",
