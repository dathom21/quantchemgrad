Cell[TextData[{
 "The second integral in equation (56) is more complicated to evaluate, and \
we won\[CloseCurlyQuote]t go through the details. In short, this integral \
yields a value of zero unless ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"J", "'"}], "=", 
    RowBox[{"J", "+", "1"}]}], TraditionalForm]],ExpressionUUID->
  "25a1c366-3f60-442c-895a-276b5cf63dac"],
 " or ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"J", "'"}], "=", 
    RowBox[{"J", "-", "1"}]}], TraditionalForm]],ExpressionUUID->
  "ec73c6d3-2ef6-46d4-ae3f-876134dbba01"],
 ", giving the second selection rule"
}], "Text",
 CellChangeTimes->{{3.8157604115652304`*^9, 3.815760489290923*^9}, {
