 RowBox[{
  RowBox[{
   RowBox[{"(", " ", 
    RowBox[{
     SuperscriptBox[
      OverscriptBox[
       StyleBox["H",
        FontSlant->"Italic"], "^"], 
      RowBox[{"(", "0", ")"}]], "+", 
     RowBox[{"\[Lambda]", 
      StyleBox[
       SuperscriptBox[
        OverscriptBox[
         StyleBox["H",
          FontSlant->"Italic"], "^"], 
