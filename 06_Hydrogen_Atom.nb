Cell[TextData[{
 "As was mentioned briefly earlier, there is not a direct correspondence \
between these wavefunctions and the ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "x"], TraditionalForm]],ExpressionUUID->
  "fd05ac01-4359-446f-9225-f46b08d08c9a"],
 " and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "y"], TraditionalForm]],ExpressionUUID->
  "a7401258-0d65-4667-8571-547cf4cb2f9b"],
 " atomic orbitals. Because the wavefunctions ",
 Cell[BoxData[
  RowBox[{
   SubsuperscriptBox[
    StyleBox["Y",
     FontSlant->"Italic"], "1", "1"], 
   RowBox[{"(", 
