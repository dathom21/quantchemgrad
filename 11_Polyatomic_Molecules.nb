  "0"}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.811865621268368*^9, 3.81186572995993*^9}, {
  3.811868471275405*^9, 3.811868487155151*^9}, {3.814431632450887*^9, 
  3.8144316740832705`*^9}, {3.814461521602205*^9, 
  3.814461584039669*^9}},ExpressionUUID->"0922e7a9-b0b9-4ae1-90f3-\
b403fae49593"],

Cell[TextData[{
 "Recall that the number of values of ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["E",
    FontSlant->"Italic"], 
   SubscriptBox["\[Psi]", "\[Pi]"]]],
  CellChangeTimes->{{3.811865621268368*^9, 3.81186572995993*^9}, {
   3.811868471275405*^9, 3.811868487155151*^9}, {3.814431632450887*^9, 
   3.8144316740832705`*^9}},ExpressionUUID->
  "93c09a79-6767-4c4c-92e2-f2be950c86c2"],
 " we obtain is equal to the number of basis functions, so in this case there \
will be two values of ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["E",
    FontSlant->"Italic"], 
   SubscriptBox["\[Psi]", "\[Pi]"]]],
  CellChangeTimes->{{3.811865621268368*^9, 3.81186572995993*^9}, {
   3.811868471275405*^9, 3.811868487155151*^9}, {3.814431632450887*^9, 
   3.8144316740832705`*^9}},ExpressionUUID->
  "2d619655-4407-4cd4-a144-4752ffb7e988"],
 " (eigenvalues), each with its own corresponding set of weighting \
coefficients ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["a",
    FontSlant->"Italic"], "1"]],
  CellChangeTimes->{{3.811865621268368*^9, 3.81186572995993*^9}, {
   3.811868471275405*^9, 3.811868487155151*^9}, {3.814431632450887*^9, 
   3.8144316740832705`*^9}},ExpressionUUID->
  "c93c20f8-b033-486b-aab8-f94e7c85b744"],
 " and ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["a",
    FontSlant->"Italic"], "2"]],
  CellChangeTimes->{{3.811865621268368*^9, 3.81186572995993*^9}, {
   3.811868471275405*^9, 3.811868487155151*^9}, {3.814431632450887*^9, 
   3.8144316740832705`*^9}},ExpressionUUID->
  "ad0aa827-18a0-477b-9267-160454b85f26"],
 " (eigenvectors)."
}], "Text",
 CellChangeTimes->{{3.8144316843638053`*^9, 3.8144317289503207`*^9}, {
  3.814431801677905*^9, 
  3.814431820071128*^9}},ExpressionUUID->"5b4823a4-786d-4ec6-af48-\
87b284bfb135"],

Cell["\<\
H\[UDoubleDot]ckel theory involves several approximations that simplify \
solving such an eigenvalue problem. \
\>", "Text",
 CellChangeTimes->{{3.8144606710892963`*^9, 3.8144606797336464`*^9}, {
  3.8144607097367444`*^9, 
  3.814460735042081*^9}},ExpressionUUID->"a8d9b8e6-cb1c-4239-b7c0-\
f6c10f0d5ff0"],

Cell["All of the on-diagonal terms are set equal to each other,", \
"ItemNumbered",
 CellChangeTimes->{{3.8144607486251564`*^9, 
  3.8144608890145545`*^9}},ExpressionUUID->"2b3fbf5c-f8cd-40d8-ac24-\
07dca0989da3"],

Cell[BoxData[
 RowBox[{"\t", 
  RowBox[{
   SubscriptBox[
    StyleBox["H",
     FontSlant->"Italic"], 
    StyleBox["ii",
     FontSlant->"Italic"]], "=", 
   RowBox[{
    SubscriptBox[
     StyleBox["H",
      FontSlant->"Italic"], 
     StyleBox["jj",
      FontSlant->"Italic"]], "=", "\[Alpha]"}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8144609047501793`*^9, 
  3.814460952222639*^9}},ExpressionUUID->"568a05c6-6702-4af2-af31-\
eefdd255963b"],

Cell[TextData[{
 "This statement implies that all of the ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "z"], TraditionalForm]],ExpressionUUID->
  "322dc046-d63e-44af-88d4-7eabe8506a7f"],
 " orbitals on the carbon atoms are equivalent."
}], "Text",
 CellChangeTimes->{{3.8144610471227956`*^9, 
  3.8144610947697*^9}},ExpressionUUID->"5e128ab1-a274-40e0-bd38-a2a0ba0deebe"],

Cell[TextData[{
 "The integrals ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["H",
    FontSlant->"Italic"], 
   StyleBox["ij",
    FontSlant->"Italic"]]],
  CellChangeTimes->{{3.8144609047501793`*^9, 3.814460952222639*^9}},
  ExpressionUUID->"b96c2be5-c92a-439a-ad25-6604078daffa"],
 " between non-neighboring atoms are set equal to zero,"
}], "ItemNumbered",
 CellChangeTimes->{{3.8144607486251564`*^9, 3.8144608616029024`*^9}, 
   3.8144609201867933`*^9, {3.814460956361014*^9, 3.8144609595799427`*^9}, 
   3.814461013592622*^9, {3.8144610821053925`*^9, 3.81446108263449*^9}, {
   3.814461121714589*^9, 
   3.8144611553061447`*^9}},ExpressionUUID->"b46322f5-ce7a-4bea-9ce7-\
91c502b1ba61"],

Cell[BoxData[
 RowBox[{"\t", 
  RowBox[{
   RowBox[{
    SubscriptBox[
     StyleBox["H",
      FontSlant->"Italic"], 
     StyleBox["ij",
      FontSlant->"Italic"]], "=", 
    RowBox[{
     RowBox[{"0", "                 ", 
      StyleBox["i",
       FontSlant->"Italic"]}], "\[NotEqual]", 
     StyleBox["j",
      FontSlant->"Italic"]}]}], 
   StyleBox[",",
    FontSlant->"Italic"], 
   StyleBox[
    RowBox[{
     StyleBox[" ",
      FontSlant->"Italic"], " "}]], 
   RowBox[{
    StyleBox["i",
     FontSlant->"Italic"], "\[NotEqual]", 
    RowBox[{
     StyleBox["j",
      FontSlant->"Italic"], " ", "+", "1"}]}], ",", " ", 
   RowBox[{
    StyleBox["i",
     FontSlant->"Italic"], "\[NotEqual]", 
    RowBox[{
     StyleBox["j",
      FontSlant->"Italic"], "-", "1"}]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8144609047501793`*^9, 3.814460952222639*^9}, {
  3.814461162743871*^9, 
  3.814461243521641*^9}},ExpressionUUID->"050ed34c-1384-4863-a977-\
cdf09610edf4"],

Cell[TextData[{
 "This approximation states that interactions between non-neighboring ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "z"], TraditionalForm]],ExpressionUUID->
  "d967f233-42e4-487e-bd70-e6dea5ad10a3"],
 " orbitals can be neglected."
}], "Text",
 CellChangeTimes->{{3.814461255253457*^9, 
  3.814461277032466*^9}},ExpressionUUID->"30ecdb59-6ee6-4f6d-bcc4-\
75e095b5124a"],

Cell[TextData[{
 "The integrals ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["H",
    FontSlant->"Italic"], 
   StyleBox["ij",
    FontSlant->"Italic"]]],
  CellChangeTimes->{{3.8144609047501793`*^9, 3.814460952222639*^9}},
  ExpressionUUID->"c222e967-eb7a-424c-b196-528548a203ec"],
 " between neighboring atoms are set equal to each other,"
}], "ItemNumbered",
 CellChangeTimes->{{3.8144607486251564`*^9, 3.8144608616029024`*^9}, 
   3.8144609201867933`*^9, {3.814460956361014*^9, 3.8144609595799427`*^9}, 
   3.814461013592622*^9, {3.8144610821053925`*^9, 3.81446108263449*^9}, {
   3.814461121714589*^9, 3.8144611553061447`*^9}, {3.814461298746722*^9, 
   3.814461302489818*^9}},ExpressionUUID->"c06e0765-1adf-4bae-976d-\
911ba783a52f"],

Cell[BoxData[
 RowBox[{"\t", 
  RowBox[{
   RowBox[{
    SubscriptBox[
     StyleBox["H",
      FontSlant->"Italic"], 
     StyleBox["ij",
      FontSlant->"Italic"]], "=", 
    RowBox[{
     RowBox[{"\[Beta]", "       ", 
      StyleBox["i",
       FontSlant->"Italic"]}], "\[NotEqual]", 
     StyleBox["j",
      FontSlant->"Italic"]}]}], 
   StyleBox[",",
    FontSlant->"Italic"], 
   StyleBox[
    RowBox[{
     StyleBox[" ",
      FontSlant->"Italic"], " "}]], 
   RowBox[{
    StyleBox["i",
     FontSlant->"Italic"], "=", 
    RowBox[{
     StyleBox["j",
      FontSlant->"Italic"], " ", "+", "1"}]}], ",", " ", 
   RowBox[{
    StyleBox["i",
     FontSlant->"Italic"], "=", 
    RowBox[{
     StyleBox["j",
      FontSlant->"Italic"], "-", "1"}]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8144609047501793`*^9, 3.814460952222639*^9}, {
  3.814461162743871*^9, 3.814461243521641*^9}, {3.8144613055378656`*^9, 
  3.8144613461422997`*^9}},ExpressionUUID->"413d9c25-a3f3-4ae8-93d2-\
0e8cc753edb1"],

Cell[TextData[{
 "This approximation states that interactions between neighboring ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "z"], TraditionalForm]],ExpressionUUID->
  "1d2ce5fc-aff7-415e-b5f1-9c576a8fc7ba"],
 " orbitals are all equivalent."
}], "Text",
 CellChangeTimes->{{3.814461255253457*^9, 3.814461277032466*^9}, {
  3.8144613581446*^9, 
  3.8144613648923817`*^9}},ExpressionUUID->"75092bfe-92fc-4dc4-b9b9-\
e12c3f28705c"],

Cell["The overlap integrals are set equal to zero, ", "ItemNumbered",
 CellChangeTimes->{{3.8144607486251564`*^9, 3.8144608616029024`*^9}, 
   3.8144609201867933`*^9, {3.814460956361014*^9, 3.8144609595799427`*^9}, 
   3.814461013592622*^9, {3.8144610821053925`*^9, 
   3.81446108263449*^9}},ExpressionUUID->"da99b1ad-66f4-4103-addc-\
c19dde3fa095"],

Cell[BoxData[
 RowBox[{"\t", 
  RowBox[{
   RowBox[{
    FormBox[
     RowBox[{
      StyleBox[
       SubscriptBox["S", "ij"],
       FontSlant->"Italic"], "=", " ", "0", "              "}],
     TraditionalForm], " ", 
    StyleBox["i",
     FontSlant->"Italic"]}], "\[NotEqual]", 
   StyleBox["j",
    FontSlant->"Italic"]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.814460972768362*^9, 3.8144610100485826`*^9}, {
  3.8144613278795004`*^9, 
  3.814461334689993*^9}},ExpressionUUID->"8795db04-a7a5-4df4-aa35-\
aa8e9f67c290"],

Cell[TextData[{
 "This approximation is based upon the idea that the ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "z"], TraditionalForm]],ExpressionUUID->
  "116a0d56-c08f-46fa-8fb4-cbdbd91644b6"],
 " orbitals are perpendicular to the bonding direction in \[Pi] molecular \
orbitals and is known as the neglect of differential overlap (NDO)."
}], "Text",
 CellChangeTimes->{{3.814461017343033*^9, 3.8144610333921475`*^9}, {
  3.814461368376732*^9, 
  3.814461368792162*^9}},ExpressionUUID->"72ea050a-c594-43b1-bfb2-\
ead81c134464"],

Cell["\<\
Plugging these statements into our equations for ethene, we obtain\
\>", "Text",
 CellChangeTimes->{{3.814461433366235*^9, 3.8144614371855507`*^9}, {
  3.814461605263017*^9, 
  3.8144616153820896`*^9}},ExpressionUUID->"1ffc3496-5380-4350-9177-\
fcb95a3f484b"],

Cell[BoxData[{
 RowBox[{
  StyleBox["H",
   FontWeight->"Bold"], "=", 
  RowBox[{"(", "\[NoBreak]", GridBox[{
     {"\[Alpha]", "\[Beta]"},
     {"\[Beta]", "\[Alpha]"}
    }], "\[NoBreak]", ")"}]}], "\[IndentingNewLine]", 
 RowBox[{
  StyleBox["S",
   FontWeight->"Bold"], "=", 
  RowBox[{"(", "\[NoBreak]", GridBox[{
     {"1", "0"},
     {"0", "1"}
    }], "\[NoBreak]", ")"}]}]}], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.811593312893673*^9, 3.8115933831661987`*^9}, {
   3.811593458953679*^9, 3.8115934974178753`*^9}, {3.8115936143121653`*^9, 
   3.811593715195953*^9}, {3.811594208013258*^9, 3.811594210677987*^9}, {
   3.811594342816991*^9, 3.8115943434093456`*^9}, {3.811594623901507*^9, 
   3.811594670874273*^9}, {3.8115948564704037`*^9, 3.8115948589878416`*^9}, {
   3.8115949257053156`*^9, 3.811594926820971*^9}, {3.8118594909971013`*^9, 
   3.8118595100044374`*^9}, {3.811861225074663*^9, 3.8118612380287175`*^9}, {
   3.811861337070103*^9, 3.811861354268696*^9}, {3.8118616010571704`*^9, 
   3.8118616623290653`*^9}, {3.811861807987365*^9, 3.811861813069888*^9}, {
   3.811862169852538*^9, 3.8118621746446657`*^9}, {3.811862556259386*^9, 
   3.811862623167489*^9}, 3.8118626599418736`*^9, {3.8118627514300547`*^9, 
   3.8118627593819437`*^9}, {3.8118632270630903`*^9, 3.811863326828313*^9}, {
   3.8118634029600096`*^9, 3.811863463418617*^9}, {3.811863584402319*^9, 
   3.811863591954771*^9}, {3.8118640398232126`*^9, 3.8118641703774643`*^9}, {
   3.8118642286844606`*^9, 3.811864249317439*^9}, {3.8118670740896573`*^9, 
   3.8118670847666006`*^9}, {3.8119300607751865`*^9, 
   3.8119301009584703`*^9}, {3.814188630314172*^9, 3.814188633751275*^9}, {
   3.81446163360746*^9, 
   3.81446167577594*^9}},ExpressionUUID->"5637f2e0-ab3c-420e-a729-\
6464d73a56d7"],

Cell["\<\
Solving the matrix eigenvalue problem, we find that the energies are\
\>", "Text",
 CellChangeTimes->{{3.8144617177814465`*^9, 3.8144617255090733`*^9}, {
  3.814514178969316*^9, 
  3.814514193820279*^9}},ExpressionUUID->"3a2cd388-e75d-4c46-86b1-\
2e9f69c8bac4"],

Cell[BoxData[
 RowBox[{
  SubscriptBox[
   StyleBox["E",
    FontSlant->"Italic"], 
   SubscriptBox["\[Psi]", "\[Pi]"]], " ", "=", 
  RowBox[{"\[Alpha]", "\[PlusMinus]", "\[Beta]"}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.811593312893673*^9, 3.8115933831661987`*^9}, {
   3.811593458953679*^9, 3.8115934974178753`*^9}, {3.8115936143121653`*^9, 
   3.811593715195953*^9}, {3.811594208013258*^9, 3.811594210677987*^9}, {
   3.811594342816991*^9, 3.8115943434093456`*^9}, {3.811594623901507*^9, 
   3.811594670874273*^9}, {3.8115948564704037`*^9, 3.8115948589878416`*^9}, {
   3.8115949257053156`*^9, 3.811594926820971*^9}, {3.8118594909971013`*^9, 
   3.8118595100044374`*^9}, {3.811861225074663*^9, 3.8118612380287175`*^9}, {
   3.811861337070103*^9, 3.811861354268696*^9}, {3.8118616010571704`*^9, 
   3.8118616623290653`*^9}, {3.811861807987365*^9, 3.811861813069888*^9}, {
   3.811862169852538*^9, 3.8118621746446657`*^9}, {3.811862556259386*^9, 
   3.811862623167489*^9}, 3.8118626599418736`*^9, {3.8118627514300547`*^9, 
   3.8118627593819437`*^9}, {3.8118632270630903`*^9, 3.811863326828313*^9}, 
   3.8118634029600096`*^9, {3.8118635700628643`*^9, 3.811863574143609*^9}, {
   3.8118654741595607`*^9, 3.8118655915905437`*^9}, {3.8118658693746243`*^9, 
   3.811865896052101*^9}, 3.8118684990918617`*^9, 3.814431542152564*^9, {
   3.8145142359604063`*^9, 
   3.8145142464401007`*^9}},ExpressionUUID->"875b9f43-9464-4f12-8749-\
d5846286a49d"],

Cell["with corresponding eigenfunctions", "Text",
 CellChangeTimes->{{3.8145142550331955`*^9, 
  3.8145142740998616`*^9}},ExpressionUUID->"19cd8afb-a93f-4f16-a0a6-\
2addab395fb6"],

Cell[BoxData[
 RowBox[{
  SubscriptBox["\[Psi]", "\[Pi]"], "=", 
  RowBox[{
   FractionBox["1", 
    SqrtBox["2"]], 
   RowBox[{"(", 
    RowBox[{
     SubscriptBox["\[Phi]", 
      RowBox[{"2", 
       SubscriptBox[
        StyleBox["p",
         FontSlant->"Italic"], 
        StyleBox["zA",
         FontSlant->"Italic"]]}]], "\[PlusMinus]", 
     SubscriptBox["\[Phi]", 
      RowBox[{"2", 
       SubscriptBox[
        StyleBox["p",
         FontSlant->"Italic"], 
        StyleBox["zB",
         FontSlant->"Italic"]]}]]}], ")"}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8142715408501225`*^9, 3.8142716264528427`*^9}, {
  3.8142716634962983`*^9, 3.81427166385531*^9}, {3.8142717090653296`*^9, 
  3.814271758882024*^9}, {3.8144305791172466`*^9, 3.8144305954419746`*^9}, {
  3.8144307461264753`*^9, 3.814430819988105*^9}, {3.8144315687851577`*^9, 
  3.814431572922325*^9}, {3.814514291539785*^9, 3.8145143370538917`*^9}, {
  3.8145144764075503`*^9, 3.814514479317971*^9}, {3.8145147262851176`*^9, 
  3.8145147287172513`*^9}},ExpressionUUID->"6a107657-5d64-4a28-9152-\
391456505dda"],

Cell[TextData[{
 "These two molecular orbitals are shown schematically in Figure 11.6. The \
lower-energy bonding orbital exhibits an in-phase combination of the ",
 Cell[BoxData[
  RowBox[{"2", 
   SubscriptBox[
    StyleBox["p",
     FontSlant->"Italic"], 
    StyleBox["z",
     FontSlant->"Italic"]]}]],
  CellChangeTimes->{{3.8142715408501225`*^9, 3.8142716264528427`*^9}, {
   3.8142716634962983`*^9, 3.81427166385531*^9}, {3.8142717090653296`*^9, 
   3.814271758882024*^9}, {3.8144305791172466`*^9, 3.8144305954419746`*^9}, {
   3.8144307461264753`*^9, 3.814430819988105*^9}, {3.8144315687851577`*^9, 
   3.814431572922325*^9}, {3.814514291539785*^9, 3.8145143370538917`*^9}, {
   3.8145144764075503`*^9, 3.814514479317971*^9}, {3.8145147262851176`*^9, 
   3.8145147287172513`*^9}},ExpressionUUID->
  "7c59f910-4b45-48e6-8c4a-ff3bd9dea28b"],
 " orbitals (",
 Cell[BoxData[
  RowBox[{
   SubscriptBox["\[Phi]", 
    RowBox[{"2", 
     SubscriptBox[
      StyleBox["p",
       FontSlant->"Italic"], 
      StyleBox["zA",
       FontSlant->"Italic"]]}]], "+", 
   SubscriptBox["\[Phi]", 
    RowBox[{"2", 
     SubscriptBox[
      StyleBox["p",
       FontSlant->"Italic"], 
      StyleBox["zB",
       FontSlant->"Italic"]]}]]}]],
  CellChangeTimes->{{3.8142715408501225`*^9, 3.8142716264528427`*^9}, {
   3.8142716634962983`*^9, 3.81427166385531*^9}, {3.8142717090653296`*^9, 
   3.814271758882024*^9}, {3.8144305791172466`*^9, 3.8144305954419746`*^9}, {
   3.8144307461264753`*^9, 3.814430819988105*^9}, {3.8144315687851577`*^9, 
   3.814431572922325*^9}, {3.814514291539785*^9, 3.8145143370538917`*^9}, {
   3.8145144764075503`*^9, 3.814514479317971*^9}, {3.8145147262851176`*^9, 
   3.8145147287172513`*^9}},ExpressionUUID->
  "ff2cb277-611c-4657-9b68-bc172bea8cfa"],
 "), yielding a stabilizing constructive interference of orbitals to give a \
lower energy of \[Alpha] + \[Beta] (\[Alpha] and \[Beta] are both negative).  \
Remember that these molecular orbitals account for the remaining valence \
electrons when all other electrons are in lower-energy \[Sigma] orbitals, so \
the bonding and antibonding orbitals obtained are labeled as the highest \
occupied molecular orbital (HOMO) and the lowest unoccupied molecular orbital \
(LUMO), respectively."
}], "Text",
 CellChangeTimes->{{3.81451450217283*^9, 3.8145146101492786`*^9}, {
  3.8145147347142935`*^9, 3.81451497856502*^9}, {3.8145152975958805`*^9, 
  3.8145152996891055`*^9}, {3.9388709112641506`*^9, 
  3.938870911358629*^9}},ExpressionUUID->"03603a83-6979-4459-abb1-\
428cb1a3b290"],

