 CellChangeTimes->{{3.810112811439228*^9, 3.8101128248442793`*^9}, {
   3.810479494926491*^9, 3.8104795038498344`*^9}, {3.810479572543576*^9, 
   3.8104796147383184`*^9}, {3.8104802055659895`*^9, 
   3.8104802433915305`*^9}, {3.8104802785189395`*^9, 
   3.8104802814214115`*^9}, {3.8109915300785556`*^9, 
   3.8109916793993816`*^9}, {3.810991710031681*^9, 3.8109918292023373`*^9}, {
   3.810994488524798*^9, 3.810994499853472*^9}, {3.8109948928195066`*^9, 
   3.8109948950763626`*^9}, {3.8109949491606197`*^9, 3.810995087249513*^9}, {
   3.8109951188614283`*^9, 3.8109951226144466`*^9}, {3.8115998145208507`*^9, 
   3.8115999093225703`*^9}, 3.8119468581508093`*^9, {3.8126173912859564`*^9, 
   3.8126174353481674`*^9}, {3.812617986792708*^9, 3.812617987701547*^9}, {
   3.8126194925193796`*^9, 3.812619503416272*^9}, {3.812619551056244*^9, 
   3.812619564308283*^9}, {3.812619992990877*^9, 3.8126200208718753`*^9}, 
   3.8126201248430705`*^9, {3.812620163920018*^9, 3.8126201669704065`*^9}, {
   3.8126204678526173`*^9, 3.8126204826728334`*^9}, {3.8126205155312433`*^9, 
   3.81262057853043*^9}, {3.812620660711446*^9, 3.812620661159943*^9}, {
   3.8126208302516937`*^9, 3.8126208466299543`*^9}, {3.812620980916898*^9, 
   3.8126209810859137`*^9}, 3.8126287856964226`*^9, {3.812629271581931*^9, 
   3.8126292755855017`*^9}, {3.8126293423208475`*^9, 3.812629351460653*^9}, {
   3.8126294501142464`*^9, 3.8126295143102984`*^9}, {3.812629684693431*^9, 
   3.812629684832785*^9}, {3.8128207562103453`*^9, 3.8128207944722958`*^9}, {
   3.8128208284185944`*^9, 
   3.812820828600006*^9}},ExpressionUUID->"e58a6c09-aac9-45cd-83e1-\
d90e6efbc192"],

Cell[TextData[{
 "Although in both cases we have an ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["M",
    FontWeight->"Plain",
    FontSlant->"Italic"], 
   StyleBox["S",
    FontSlant->"Italic"]]],
  CellChangeTimes->{{3.8128117549390078`*^9, 3.812811805160163*^9}, {
    3.8128122054106054`*^9, 3.812812225217738*^9}, {3.8128123371306987`*^9, 
    3.8128123854295173`*^9}, {3.812812734843032*^9, 3.812812738001706*^9}, {
    3.812812777924115*^9, 3.812812784141674*^9}, {3.8128129529930706`*^9, 
    3.8128130907006335`*^9}, 3.812813186181301*^9, {3.812814998961049*^9, 
    3.8128149993964257`*^9}},ExpressionUUID->
  "4bb49b82-bf85-4477-a70d-8577334c6ae4"],
 " value of 0, ",
 Cell[BoxData[
  SubscriptBox["\[Sigma]", "+"]],
  CellChangeTimes->{{3.810112811439228*^9, 3.8101128248442793`*^9}, {
    3.810479494926491*^9, 3.8104795038498344`*^9}, {3.810479572543576*^9, 
    3.8104796147383184`*^9}, {3.8104802055659895`*^9, 
    3.8104802433915305`*^9}, {3.8104802785189395`*^9, 
    3.8104802814214115`*^9}, {3.8109915300785556`*^9, 
    3.8109916793993816`*^9}, {3.810991710031681*^9, 3.8109918292023373`*^9}, {
    3.810994488524798*^9, 3.810994499853472*^9}, {3.8109948928195066`*^9, 
    3.8109948950763626`*^9}, {3.8109949491606197`*^9, 3.810995087249513*^9}, {
    3.8109951188614283`*^9, 3.8109951226144466`*^9}, {3.8115998145208507`*^9, 
    3.8115999093225703`*^9}, 3.8119468581508093`*^9, {3.8126173912859564`*^9, 
    3.8126174353481674`*^9}, {3.812617986792708*^9, 3.812617987701547*^9}, {
    3.8126194925193796`*^9, 3.812619503416272*^9}, {3.812619551056244*^9, 
    3.812619564308283*^9}, {3.812619992990877*^9, 3.8126200208718753`*^9}, 
    3.8126201248430705`*^9, {3.812620163920018*^9, 3.8126201669704065`*^9}, {
    3.8126204678526173`*^9, 3.8126204826728334`*^9}, {3.8126205155312433`*^9, 
    3.81262057853043*^9}, {3.812620660711446*^9, 3.812620661159943*^9}, {
    3.8126208302516937`*^9, 3.8126208466299543`*^9}, {3.812620980916898*^9, 
    3.8126209810859137`*^9}, 3.8126287856964226`*^9, {3.812629271581931*^9, 
    3.8126292755855017`*^9}, {3.8126293423208475`*^9, 3.812629351460653*^9}, {
    3.8126294501142464`*^9, 3.8126295143102984`*^9}, {3.812629684693431*^9, 
    3.812629684832785*^9}, {3.8128207562103453`*^9, 3.812820780041172*^9}},
  ExpressionUUID->"aa1720b8-69eb-4f98-a109-f4d4bdba7478"],
 ", also known as the symmetric state, gives a value of ",
 StyleBox["S",
  FontSlant->"Italic"],
 "  = 1, and ",
 Cell[BoxData[
  SubscriptBox["\[Sigma]", "-"]],
  CellChangeTimes->{{3.810112811439228*^9, 3.8101128248442793`*^9}, {
    3.810479494926491*^9, 3.8104795038498344`*^9}, {3.810479572543576*^9, 
    3.8104796147383184`*^9}, {3.8104802055659895`*^9, 
    3.8104802433915305`*^9}, {3.8104802785189395`*^9, 
    3.8104802814214115`*^9}, {3.8109915300785556`*^9, 
    3.8109916793993816`*^9}, {3.810991710031681*^9, 3.8109918292023373`*^9}, {
    3.810994488524798*^9, 3.810994499853472*^9}, {3.8109948928195066`*^9, 
    3.8109948950763626`*^9}, {3.8109949491606197`*^9, 3.810995087249513*^9}, {
    3.8109951188614283`*^9, 3.8109951226144466`*^9}, {3.8115998145208507`*^9, 
    3.8115999093225703`*^9}, 3.8119468581508093`*^9, {3.8126173912859564`*^9, 
    3.8126174353481674`*^9}, {3.812617986792708*^9, 3.812617987701547*^9}, {
    3.8126194925193796`*^9, 3.812619503416272*^9}, {3.812619551056244*^9, 
    3.812619564308283*^9}, {3.812619992990877*^9, 3.8126200208718753`*^9}, 
    3.8126201248430705`*^9, {3.812620163920018*^9, 3.8126201669704065`*^9}, {
    3.8126204678526173`*^9, 3.8126204826728334`*^9}, {3.8126205155312433`*^9, 
    3.81262057853043*^9}, {3.812620660711446*^9, 3.812620661159943*^9}, {
    3.8126208302516937`*^9, 3.8126208466299543`*^9}, {3.812620980916898*^9, 
    3.8126209810859137`*^9}, 3.8126287856964226`*^9, {3.812629271581931*^9, 
    3.8126292755855017`*^9}, {3.8126293423208475`*^9, 3.812629351460653*^9}, {
    3.8126294501142464`*^9, 3.8126295143102984`*^9}, {3.812629684693431*^9, 
    3.812629684832785*^9}, {3.8128207562103453`*^9, 3.8128207944722958`*^9}, {
    3.8128208284185944`*^9, 3.812820828600006*^9}},ExpressionUUID->
  "dfa3f35e-ac44-4918-9d58-47e18f132aad"],
 ", the antisymmetric state, gives a value of ",
 StyleBox["S",
  FontSlant->"Italic"],
 " = 0. Note that only the antisymmetric state is allowed if the electrons \
are in the same orbital."
}], "Text",
 CellChangeTimes->{
  3.8128205426223345`*^9, {3.8128208483234034`*^9, 
   3.812820951309224*^9}},ExpressionUUID->"409a1f66-d4a4-4f62-9d20-\
ceee9bd6bde6"],

Cell[TextData[{
 "The triplet state derives its name from the fact that there are three spin \
configurations that give a value of ",
 StyleBox["S",
  FontSlant->"Italic"],
 "  = 1, whereas the singlet state derives its name from the fact there is is \
only one state the gives a value of ",
 StyleBox["S",
  FontSlant->"Italic"],
 "  = 0. "
}], "Text",
 CellChangeTimes->{{3.8128209545171695`*^9, 
  3.8128209941714745`*^9}},ExpressionUUID->"d8a40b19-3d18-4d3d-b5cc-\
e550b60c0df4"]
}, Open  ]],

Cell[CellGroupData[{

Cell["\<\
Hund\[CloseCurlyQuote]s Rule Gives us a Method to Determine the Ground \
Electronic State\
\>", "Subsection",
 CellChangeTimes->{{3.812821019704714*^9, 
  3.8128210436068287`*^9}},ExpressionUUID->"47f4e760-fd26-4009-ac5f-\
e71865d546ca"],

Cell["\<\
We saw for the example of carbon that for a given electron configuration, \
there are many possible term symbols. How do we determine the configuration \
that will give us the lowest energy? In principle, since these different \
configurations have different wavefunctions given by the Slater determinant, \
we could calculate the energy for each configuration and compare. However, it\
\[CloseCurlyQuote]s much easier to use a set of empirical rules developed by \
the physicist Friedrich Hund. Hund\[CloseCurlyQuote]s rules, as they are \
called, are\
\>", "Text",
 CellChangeTimes->{{3.8128211539758635`*^9, 
  3.8128213151810746`*^9}},ExpressionUUID->"26d1b708-c656-493e-b03c-\
57d24314a76c"],

Cell[TextData[{
 "The state with the largest value of  ",
 StyleBox["S",
  FontSlant->"Italic"],
 "  is most stable, and the stability decreases with decreasing  ",
 StyleBox["S",
  FontSlant->"Italic"],
 "."
}], "ItemNumbered",
 CellChangeTimes->{{3.8128213257245955`*^9, 3.8128213262997584`*^9}, {
  3.81282138136779*^9, 
  3.8128213969565396`*^9}},ExpressionUUID->"a13150e6-2ec0-46e7-ad1a-\
996603afa931"],

Cell[TextData[{
 "For states with the same values of  ",
 StyleBox["S",
  FontSlant->"Italic"],
 ", the state with the largest value of ",
 StyleBox["L",
  FontSlant->"Italic"],
 " is the most stable."
}], "ItemNumbered",
 CellChangeTimes->{{3.8128213257245955`*^9, 3.8128213262997584`*^9}, {
  3.81282138136779*^9, 
  3.8128214406242266`*^9}},ExpressionUUID->"953afc3d-83ca-4663-aefa-\
06beedad8429"],

Cell[TextData[{
 "If states have the same values of ",
 StyleBox["L",
  FontSlant->"Italic"],
 " and ",
 StyleBox["S",
  FontSlant->"Italic"],
 ", for atoms with less than half-filled subshells, the level with the lowest \
value of ",
 StyleBox["J",
  FontSlant->"Italic"],
 " lies lowest in energy. For atoms with more than half-filled subshells, the \
level with the highest value of ",
 StyleBox["J",
  FontSlant->"Italic"],
 " lies lowest in energy."
}], "ItemNumbered",
 CellChangeTimes->{{3.8128213257245955`*^9, 3.8128213262997584`*^9}, {
  3.81282138136779*^9, 3.812821427129777*^9}, {3.8128215084149904`*^9, 
  3.812821571198794*^9}},ExpressionUUID->"94ba3b00-3c45-4aba-85ba-\
c27004d8ddd9"],

Cell[TextData[{
 "Looking back at our example of Carbon, we see that the state with the \
largest value of ",
 StyleBox["S",
  FontSlant->"Italic"],
 " is ",
 Cell[BoxData[
  RowBox[{
   SuperscriptBox["", "3"], 
   StyleBox["P",
    FontSlant->"Italic"]}]],
  CellChangeTimes->{{3.8128152039945197`*^9, 3.812815256576949*^9}, {
   3.8128178519973774`*^9, 3.8128178576384025`*^9}, {3.8128181778326225`*^9, 
   3.81281818689855*^9}},ExpressionUUID->
  "78d8680f-85ca-4cdb-9436-ed2b4b2fe587"],
 ". Since all of the ",
 Cell[BoxData[
  RowBox[{
   SuperscriptBox["", "3"], 
   StyleBox["P",
    FontSlant->"Italic"]}]],
  CellChangeTimes->{{3.8128152039945197`*^9, 3.812815256576949*^9}, {
   3.8128178519973774`*^9, 3.8128178576384025`*^9}, {3.8128181778326225`*^9, 
   3.81281818689855*^9}},ExpressionUUID->
  "27421227-755a-4724-90c4-9dcdaccca555"],
 " states have ",
 StyleBox["L",
  FontSlant->"Italic"],
 " = 1, we then must look at the ",
 StyleBox["J",
  FontSlant->"Italic"],
 " values. Since the subshell is less than half-filled ",
 Cell[BoxData[
  FormBox[
   RowBox[{"(", 
    RowBox[{"2", 
     SuperscriptBox["p", "2"]}]}], TraditionalForm]],ExpressionUUID->
  "e25ebe99-f5de-40f1-8291-9a975653f491"],
 "), we want the lowest value of ",
 Cell[BoxData[
  FormBox["J", TraditionalForm]],ExpressionUUID->
  "d3f0b2fe-88fe-4cfd-b04a-29c062e9562e"],
 ", which is 0, giving the most stable configuration as"
}], "Text",
 CellChangeTimes->{{3.812821616190045*^9, 3.8128217349405565`*^9}, {
  3.812821769599968*^9, 3.812821786258253*^9}, {3.937055262851364*^9, 
  3.9370552637679615`*^9}},ExpressionUUID->"b75dd9a0-95d8-48e8-a753-\
55e52ec3e816"],

Cell[BoxData[
 RowBox[{
  SuperscriptBox["", "3"], 
  SubscriptBox[
   StyleBox["P",
    FontSlant->"Italic"], "0"]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{
  3.812821800270341*^9},ExpressionUUID->"075ac356-8407-48a0-b4dc-\
04d6c322cb00"]
}, Open  ]],

Cell[CellGroupData[{

Cell["\<\
Physical Interpretation of the Term Symbol and Implications for Spectroscopy\
\>", "Subsection",
 CellChangeTimes->{{3.8128804457850294`*^9, 
  3.8128804620516405`*^9}},ExpressionUUID->"4a528480-d48c-4c34-a45c-\
61a680220ef2"],

Cell["\<\
The term symbol is needed to completely specify the state of a system because \
of what is known as spin-orbit coupling, or Russel-Saunders coupling. But why \
do we need this term to specify a change in energy (which will lead to the \
observed change in photon wavelength in atomic spectroscopy)? To answer this \
question, we must consider how Hamiltonian of our atom is impacted by the \
relationship between the spin and orbital angular momentum. Let\
\[CloseCurlyQuote]s examine Figure 8.5 again.\
\>", "Text",
 CellChangeTimes->{{3.8128805030196743`*^9, 3.812880555998559*^9}, {
  3.812880587350238*^9, 3.8128806096623373`*^9}, {3.8128812787268996`*^9, 
  3.812881324679597*^9}, {3.9184049324235387`*^9, 3.9184050224763207`*^9}, {
  3.918405433148774*^9, 
  3.918405433319254*^9}},ExpressionUUID->"c85d174b-5727-4a89-9052-\
4379d499fd36"],

