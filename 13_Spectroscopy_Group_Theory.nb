          RowBox[{"-", "1"}]], 
         RowBox[{"Log", "[", 
          RowBox[{"1", "-", 
           RowBox[{"0.003651", 
            SuperscriptBox["d", 
             RowBox[{"-", "1"}]], 
            SqrtBox[
             RowBox[{
              RowBox[{"(", 
               RowBox[{"0.5", " ", "+", "v"}], ")"}], " ", "\[Omega]", " ", 
              RowBox[{"(", 
               RowBox[{
