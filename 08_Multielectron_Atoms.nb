Cell[BoxData[
 RowBox[{
  RowBox[{"\[LeftAngleBracket]", 
   RowBox[{"\[Phi]", "|", 
    OverscriptBox[
     StyleBox["H",
      FontSlant->"Italic"], "^"], "|", "\[Phi]"}], "\[RightAngleBracket]"}], 
  "=", 
  RowBox[{
   RowBox[{
    RowBox[{"\[LeftAngleBracket]", 
     RowBox[{
      RowBox[{
       UnderscriptBox["\[Sum]", 
        StyleBox["n",
         FontSlant->"Italic"]], 
       RowBox[{
        SubscriptBox[
         StyleBox["c",
          FontSlant->"Italic"], 
         StyleBox["n",
          FontSlant->"Italic"]], 
        SubscriptBox["\[Psi]", 
         StyleBox["n",
          FontSlant->"Italic"]]}]}], " ", "|", 
      OverscriptBox[
       StyleBox["H",
        FontSlant->"Italic"], "^"], "|", 
      RowBox[{
       UnderscriptBox["\[Sum]", 
        StyleBox["m",
         FontSlant->"Italic"]], 
       RowBox[{
        SubscriptBox[
         StyleBox["c",
          FontSlant->"Italic"], 
         StyleBox["m",
          FontSlant->"Italic"]], 
        SubscriptBox["\[Psi]", 
         StyleBox["m",
          FontSlant->"Italic"]]}]}]}], " ", "\[RightAngleBracket]"}], "                           ", 
    RowBox[{"\[Integral]", 
     RowBox[{
      SuperscriptBox["\[Phi]", "\[Star]"], " ", 
      OverscriptBox[
       StyleBox["H",
        FontSlant->"Italic"], "^"], "\[Phi]", " ", "d\[Tau]"}]}]}], "=", 
   RowBox[{"\[Integral]", 
    RowBox[{
     UnderscriptBox["\[Sum]", 
      StyleBox["n",
       FontSlant->"Italic"]], 
     RowBox[{
      SubsuperscriptBox[
       StyleBox["c",
        FontSlant->"Italic"], 
       StyleBox["n",
        FontSlant->"Italic"], "\[Star]"], 
      SubsuperscriptBox["\[Psi]", 
       StyleBox["n",
        FontSlant->"Italic"], "\[Star]"], " ", 
      OverscriptBox[
       StyleBox["H",
        FontSlant->"Italic"], "^"], 
      RowBox[{
       UnderscriptBox["\[Sum]", 
        StyleBox["m",
         FontSlant->"Italic"]], 
       RowBox[{
        SubscriptBox[
         StyleBox["c",
          FontSlant->"Italic"], 
