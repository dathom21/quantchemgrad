Cell["\<\
describe the qualitative application of MOs, including prediction of \
approximate energies, electron filling, and electron pairing.\
\>", "Item",
 CellChangeTimes->{{3.8064070512118487`*^9, 3.8064071296108913`*^9}, {
   3.8064085319006467`*^9, 3.806408589657423*^9}, {3.8064086221967144`*^9, 
   3.8064086237170687`*^9}, {3.806408667141599*^9, 3.806408681285579*^9}, {
   3.807352722088828*^9, 3.807352759957488*^9}, {3.8073727596099796`*^9, 
   3.8073728009156528`*^9}, {3.8074587030505486`*^9, 3.807458720791384*^9}, {
   3.8076176652242327`*^9, 3.807617704647169*^9}, {3.8076307042988253`*^9, 
   3.8076307277658367`*^9}, 3.8078687276987715`*^9, {3.807964920361148*^9, 
   3.8079649324941607`*^9}, {3.807978453367484*^9, 3.8079784602745285`*^9}, 
   3.807978572108963*^9, {3.8079786237090693`*^9, 3.8079786237100697`*^9}, {
   3.8080648117417436`*^9, 3.808064863889304*^9}, {3.80806492558871*^9, 
   3.808064926419731*^9}, {3.8087412800210857`*^9, 3.8087412977883787`*^9}, {
   3.8095121859086065`*^9, 3.80951227034749*^9}, {3.8101220447745075`*^9, 
   3.810122054131899*^9}, {3.810122100354334*^9, 3.8101221031749597`*^9}, {
   3.810122145482953*^9, 3.810122146171503*^9}, {3.8104854159984446`*^9, 
   3.8104854323943815`*^9}, {3.811331305885708*^9, 3.811331332333135*^9}, {
   3.8116065686800957`*^9, 3.8116066250878115`*^9}, {3.811950582952672*^9, 
   3.8119506294416685`*^9}, {3.811950699976611*^9, 3.8119507211593285`*^9}, {
   3.8119507796105995`*^9, 3.811950811621095*^9}, {3.811950866946955*^9, 
   3.811950866947954*^9}, {3.8132301135486517`*^9, 
   3.8132301549659824`*^9}},ExpressionUUID->"d219d7ca-51e6-40a8-91aa-\
42cdadf435f5"]
}, Open  ]],

Cell[CellGroupData[{

Cell["The Born-Oppenheimer Approximation", "Section",
 CellChangeTimes->{{3.8130748299200068`*^9, 
  3.8130748346665363`*^9}},ExpressionUUID->"1835c635-bfc2-4b2b-8fec-\
7f8c62462b09"],

Cell[CellGroupData[{

Cell["The Molecular Schr\[ODoubleDot]dinger Equation", "Subsection",
 CellChangeTimes->{{3.813074839363206*^9, 
  3.8130748561981344`*^9}},ExpressionUUID->"c63084d3-b070-450a-a440-\
c96842ab4009"],

Cell["\<\
We are now (finally) at the point where we can discuss molecules, which are \
at the heart of much of chemistry. We\[CloseCurlyQuote]re now talking about \
multiple nuclei as well as multiple electrons, so our Hamiltonian will have \
new terms to account for these new interactions. The molecular Hamiltonian \
takes the form\
\>", "Text",
 CellChangeTimes->{{3.813074865067734*^9, 3.813074968573245*^9}, {
  3.813075002292188*^9, 3.813075030987863*^9}, {3.8130759109793386`*^9, 
  3.8130759183947997`*^9}, {3.813075971721114*^9, 3.8130759740936832`*^9}, {
  3.813232108108199*^9, 3.8132321106996193`*^9}, {3.9185811037154264`*^9, 
  3.9185811458897*^9}, {3.918581183718336*^9, 3.9185811913224177`*^9}, {
  3.919503214237435*^9, 
  3.9195032151342225`*^9}},ExpressionUUID->"107e705c-cf77-4159-b00e-\
f1061a772150"],

Cell[BoxData[
 RowBox[{
  OverscriptBox[
   StyleBox["H",
    FontSlant->"Italic"], "^"], "=", 
  RowBox[{
   RowBox[{"-", 
    RowBox[{
     UnderscriptBox["\[Sum]", 
      StyleBox["A",
       FontSlant->"Italic"]], 
     RowBox[{
      FractionBox["1", 
       RowBox[{"2", 
        SubscriptBox[
         StyleBox["M",
          FontSlant->"Italic"], 
         StyleBox["A",
          FontSlant->"Italic"]]}]], 
      RowBox[{
       SubsuperscriptBox["\[Del]", 
        StyleBox["A",
         FontSlant->"Italic"], "2"], 
       RowBox[{"-", 
        RowBox[{
         UnderscriptBox["\[Sum]", 
          StyleBox["i",
           FontSlant->"Italic"]], 
         RowBox[{
          FractionBox["1", "2"], 
          RowBox[{
           SubsuperscriptBox["\[Del]", 
            StyleBox["i",
             FontSlant->"Italic"], "2"], 
           RowBox[{"-", 
            RowBox[{
             UnderscriptBox["\[Sum]", 
              StyleBox[
               RowBox[{"A", ",", "i"}],
               FontSlant->"Italic"]], 
             FractionBox[
              SubscriptBox[
               StyleBox["Z",
                FontSlant->"Italic"], 
               StyleBox["A",
                FontSlant->"Italic"]], 
              SubscriptBox[
               StyleBox["r",
                FontSlant->"Italic"], 
               StyleBox["Ai",
                FontSlant->"Italic"]]]}]}]}]}]}]}]}]}]}]}], "+", 
   RowBox[{
    UnderscriptBox["\[Sum]", 
     StyleBox[
      RowBox[{"A", ">", "B"}],
      FontSlant->"Italic"]], 
    FractionBox[
     RowBox[{
      SubscriptBox[
       StyleBox["Z",
        FontSlant->"Italic"], 
       StyleBox["A",
        FontSlant->"Italic"]], 
      SubscriptBox[
       StyleBox["Z",
        FontSlant->"Italic"], 
       StyleBox["B",
        FontSlant->"Italic"]]}], 
     StyleBox[
      SubscriptBox["R", "AB"],
      FontSlant->"Italic"]]}], "+", 
   RowBox[{
    UnderscriptBox["\[Sum]", 
     StyleBox[
      RowBox[{"i", ">", "j"}],
      FontSlant->"Italic"]], 
    FractionBox["1", 
     SubscriptBox[
      StyleBox["r",
       FontSlant->"Italic"], 
      StyleBox["ij",
       FontSlant->"Italic"]]]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8130759614135423`*^9, 3.813076278147323*^9}, {
   3.813076380382406*^9, 3.8130764153085423`*^9}, 
   3.813076816633875*^9},ExpressionUUID->"9594be8d-69e8-ae4e-91ad-\
5905d74d2395"],

Cell[TextData[{
 "where ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["M",
    FontSlant->"Italic"], 
   StyleBox["A",
    FontSlant->"Italic"]]],
  CellChangeTimes->{{3.8130759614135423`*^9, 3.813076278147323*^9}, {
   3.813076380382406*^9, 3.8130764153085423`*^9}},ExpressionUUID->
  "1153e067-65b5-4f35-a219-5e24c439dabb"],
 " gives the mass of nucleus ",
 StyleBox["A",
  FontSlant->"Italic"],
 ",",
 " ",
 Cell[BoxData[
  SubsuperscriptBox["\[Del]", 
   StyleBox["A",
    FontSlant->"Italic"], "2"]],
  CellChangeTimes->{{3.8130759614135423`*^9, 3.813076278147323*^9}, {
   3.813076380382406*^9, 3.8130764153085423`*^9}},ExpressionUUID->
  "8f6878bb-9768-449c-9866-af55988a3ff7"],
 " is the Laplacian with respect to the position of nucleus ",
 StyleBox["A",
  FontSlant->"Italic"],
 ", ",
 Cell[BoxData[
  SubsuperscriptBox["\[Del]", 
   StyleBox["i",
    FontSlant->"Italic"], "2"]],
  CellChangeTimes->{{3.8130759614135423`*^9, 3.813076278147323*^9}, {
   3.813076380382406*^9, 3.8130764153085423`*^9}},ExpressionUUID->
  "2595b38a-c8f4-4277-bdb1-ae5968ff0b20"],
 " is the Laplacian with respect to the position of electron ",
 StyleBox["i",
  FontSlant->"Italic"],
 ", ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["Z",
    FontSlant->"Italic"], 
   StyleBox["A",
    FontSlant->"Italic"]]],
  CellChangeTimes->{{3.8130759614135423`*^9, 3.813076278147323*^9}, {
   3.813076380382406*^9, 3.8130764153085423`*^9}},ExpressionUUID->
  "125e7e39-4538-41ae-9b0b-f3fefa7f8420"],
 " (or ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["Z",
    FontSlant->"Italic"], 
   StyleBox["B",
    FontSlant->"Italic"]]],
  CellChangeTimes->{{3.8130759614135423`*^9, 3.813076278147323*^9}, {
   3.813076380382406*^9, 3.8130764153085423`*^9}},ExpressionUUID->
  "462f218f-fbf4-47f2-8300-defadedd9577"],
 ") is the charge of the corresponding nuclei, ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["r",
    FontSlant->"Italic"], 
   StyleBox["Ai",
    FontSlant->"Italic"]]],
  CellChangeTimes->{{3.8130759614135423`*^9, 3.813076278147323*^9}, {
   3.813076380382406*^9, 3.8130764153085423`*^9}},ExpressionUUID->
  "407f8044-e220-43d8-b1cb-cae65b8c829d"],
 " is the distance between nucleus ",
 StyleBox["A",
  FontSlant->"Italic"],
 " and electron ",
 StyleBox["i",
  FontSlant->"Italic"],
 ", ",
 Cell[BoxData[
  StyleBox[
   SubscriptBox["R", "AB"],
   FontSlant->"Italic"]],
  CellChangeTimes->{{3.8130759614135423`*^9, 3.813076278147323*^9}, {
   3.813076380382406*^9, 3.8130764153085423`*^9}},ExpressionUUID->
  "5cf5c424-6761-40f4-98a3-59a0546fbf78"],
 " is the distance between the nuclei ",
 StyleBox["A ",
  FontSlant->"Italic"],
 "and ",
 StyleBox["B",
  FontSlant->"Italic"],
 ", and ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["r",
    FontSlant->"Italic"], 
   StyleBox["ij",
    FontSlant->"Italic"]]],
  CellChangeTimes->{{3.8130759614135423`*^9, 3.813076278147323*^9}, {
   3.813076380382406*^9, 3.8130764153085423`*^9}},ExpressionUUID->
  "395d83cb-5d79-41fc-8010-c2c93199147a"],
 " is the distance between electrons ",
 StyleBox["i",
  FontSlant->"Italic"],
 " and ",
 StyleBox["j",
  FontSlant->"Italic"],
 ". The sum ",
 StyleBox["A ",
  FontSlant->"Italic"],
 "is over all nuclei, the sum ",
 StyleBox["i",
  FontSlant->"Italic"],
 " is over all electrons."
}], "Text",
 CellChangeTimes->{{3.8130764211121078`*^9, 3.813076578760293*^9}, {
  3.918581532721986*^9, 
  3.918581682178409*^9}},ExpressionUUID->"03538830-5d28-47ef-a943-\
a62b2e3b1302"],

Cell["The first term is the kinetic energy operator of the nuclei,", "Text",
 CellChangeTimes->{
  3.813076580793152*^9},ExpressionUUID->"58ae5885-1478-42e1-95e1-\
08ff20507444"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   SubscriptBox[
    OverscriptBox[
     StyleBox["T",
      FontSlant->"Italic"], "^"], 
    StyleBox["N",
     FontSlant->"Italic"]], 
   RowBox[{"(", 
    StyleBox["R",
     FontSlant->"Italic"], 
    StyleBox[")",
     FontSlant->"Italic"]}]}], "=", 
  RowBox[{"-", 
   RowBox[{
    UnderscriptBox["\[Sum]", 
     StyleBox["A",
      FontSlant->"Italic"]], 
    RowBox[{
     FractionBox["1", 
      RowBox[{"2", 
       SubscriptBox[
        StyleBox["M",
         FontSlant->"Italic"], 
        StyleBox["A",
         FontSlant->"Italic"]]}]], 
     SubsuperscriptBox["\[Del]", 
      StyleBox["A",
       FontSlant->"Italic"], "2"]}]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8130765928719873`*^9, 
  3.8130766419857407`*^9}},ExpressionUUID->"be0212d3-d6d8-7d43-8a0f-\
bd0fcd4583e0"],

Cell["\<\
Note that we technically also had such a term in the multielectron atoms, but \
we ignored it based on a reduced-mass-like approximation (we treated the \
nucleus as stationary so the kinetic energy didn\[CloseCurlyQuote]t need to \
be accounted for). The next term is the kinetic energy operator of the \
electrons,\
\>", "Text",
 CellChangeTimes->{{3.8130766619219236`*^9, 3.8130766873024054`*^9}, {
  3.813076725763554*^9, 3.8130767780686855`*^9}, {3.918581715445417*^9, 
  3.9185817511679277`*^9}},ExpressionUUID->"cac9bcb5-178f-44d1-b721-\
8e0bd820230f"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   SubscriptBox[
    OverscriptBox[
     StyleBox["T",
      FontSlant->"Italic"], "^"], 
    StyleBox["e",
     FontSlant->"Italic"]], 
   RowBox[{"(", 
    StyleBox["r",
     FontSlant->"Italic"], 
    StyleBox[")",
     FontSlant->"Italic"]}]}], "=", 
  RowBox[{"-", 
   RowBox[{
    UnderscriptBox["\[Sum]", 
     StyleBox["i",
      FontSlant->"Italic"]], 
    RowBox[{
     FractionBox["1", "2"], 
     SubsuperscriptBox["\[Del]", 
      StyleBox["i",
       FontSlant->"Italic"], "2"]}]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8130765928719873`*^9, 3.8130766419857407`*^9}, {
   3.813076783365462*^9, 3.813076786478775*^9}, 3.81307681962652*^9, {
   3.813076858567613*^9, 
   3.8130768586821976`*^9}},ExpressionUUID->"b27b7da7-c466-9d48-865d-\
5d2574669f2b"],

Cell["\<\
which we have already seen many times in our multielectron atoms. Next, we \
have the potential energy term representing the attraction between each \
electron and each nucleus,\
\>", "Text",
 CellChangeTimes->{{3.8130768237711782`*^9, 
  3.813076852848076*^9}},ExpressionUUID->"d9f31ec4-7959-44a0-8a71-\
635d5b95326d"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   SubscriptBox[
    OverscriptBox[
     StyleBox["V",
      FontSlant->"Italic"], "^"], 
    StyleBox["eN",
     FontSlant->"Italic"]], 
   RowBox[{"(", 
    RowBox[{
     StyleBox["r",
      FontSlant->"Italic"], 
     StyleBox[",",
      FontSlant->"Plain"], 
     StyleBox["R",
      FontSlant->"Italic"]}], 
    StyleBox[")",
     FontSlant->"Italic"]}]}], "=", 
  RowBox[{"-", 
   RowBox[{
    UnderscriptBox["\[Sum]", 
     StyleBox[
      RowBox[{"A", ",", "i"}],
      FontSlant->"Italic"]], 
    FractionBox[
     SubscriptBox[
      StyleBox["Z",
       FontSlant->"Italic"], 
      StyleBox["A",
       FontSlant->"Italic"]], 
     SubscriptBox[
      StyleBox["r",
       FontSlant->"Italic"], 
      StyleBox["Ai",
       FontSlant->"Italic"]]]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8130765928719873`*^9, 3.8130766419857407`*^9}, {
   3.813076783365462*^9, 3.813076786478775*^9}, 3.81307681962652*^9, {
   3.813076858567613*^9, 
   3.8130769013064566`*^9}},ExpressionUUID->"ac0e0b86-8021-4947-8c7f-\
7ba94d6ab32d"],

Cell["\<\
We\[CloseCurlyQuote]ve also seen this term before, except up to this point \
there\[CloseCurlyQuote]s only been one nucleus to think about. Next comes the \
nuclear-nuclear repulsion term,\
\>", "Text",
 CellChangeTimes->{{3.813076906147212*^9, 3.813076926113165*^9}, {
  3.8130769699406204`*^9, 
  3.813076987096348*^9}},ExpressionUUID->"d72860c5-cb40-49e5-8103-\
d0a0f4ee449f"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   SubscriptBox[
    OverscriptBox[
     StyleBox["V",
      FontSlant->"Italic"], "^"], 
    StyleBox["NN",
     FontSlant->"Italic"]], 
   RowBox[{"(", 
    StyleBox["R",
     FontSlant->"Italic"], 
    StyleBox[")",
     FontSlant->"Italic"]}]}], "=", 
  RowBox[{
   UnderscriptBox["\[Sum]", 
    StyleBox[
     RowBox[{"A", ">", "B"}],
     FontSlant->"Italic"]], 
   FractionBox[
    RowBox[{
     SubscriptBox[
      StyleBox["Z",
       FontSlant->"Italic"], 
      StyleBox["A",
       FontSlant->"Italic"]], 
     SubscriptBox[
      StyleBox["Z",
       FontSlant->"Italic"], 
      StyleBox["B",
       FontSlant->"Italic"]]}], 
    StyleBox[
     SubscriptBox["R", "AB"],
     FontSlant->"Italic"]]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8130765928719873`*^9, 3.8130766419857407`*^9}, {
   3.813076783365462*^9, 3.813076786478775*^9}, 3.81307681962652*^9, {
   3.813076858567613*^9, 3.8130769013064566`*^9}, {3.813076997386063*^9, 
   3.813077009755924*^9}},ExpressionUUID->"24b67856-a832-8442-82ce-\
5e3761e61db4"],

Cell["\<\
which accounts for the Coulomb repulsion between all nuclei. Since we\
\[CloseCurlyQuote]ve never had more than one atomic nucleus, we haven\
\[CloseCurlyQuote]t seen this term before. Note that because the potential is \
repulsive, the sign on this term is positive (increases the energy of the \
system). Finally, we have our familiar interelectronic repulsion term,\
\>", "Text",
 CellChangeTimes->{{3.8130770136426373`*^9, 3.8130770790551405`*^9}, {
  3.919503294939934*^9, 3.919503299550186*^9}, {3.9195033378168173`*^9, 
  3.919503339459071*^9}},ExpressionUUID->"1e8d51f3-6787-474c-9813-\
73c34cf8d5c3"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   SubscriptBox[
    OverscriptBox[
     StyleBox["V",
      FontSlant->"Italic"], "^"], 
    StyleBox["ee",
     FontSlant->"Italic"]], 
   RowBox[{"(", 
    StyleBox["r",
     FontSlant->"Italic"], 
    StyleBox[")",
     FontSlant->"Italic"]}]}], "=", 
  RowBox[{
   UnderscriptBox["\[Sum]", 
    StyleBox[
     RowBox[{"i", ">", "j"}],
     FontSlant->"Italic"]], 
   FractionBox["1", 
    SubscriptBox[
     StyleBox["r",
      FontSlant->"Italic"], 
     StyleBox["ij",
      FontSlant->"Italic"]]]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8130765928719873`*^9, 3.8130766419857407`*^9}, {
   3.813076783365462*^9, 3.813076786478775*^9}, 3.81307681962652*^9, {
   3.813076858567613*^9, 3.8130769013064566`*^9}, {3.813076997386063*^9, 
   3.813077009755924*^9}, {3.8130770864080315`*^9, 
   3.81307710002981*^9}},ExpressionUUID->"c148289f-a154-1d4a-bef5-\
7ec9b8e327f3"],

Cell["\<\
We\[CloseCurlyQuote]ve already seen the importance of this term in solving \
the Hartree-Fock equations. Putting all of these labels together, we can \
equivalently write the molecular Hamiltonian as\
\>", "Text",
 CellChangeTimes->{{3.813077102112772*^9, 
  3.813077144121684*^9}},ExpressionUUID->"0312237d-4513-4750-894b-\
ff8183bb9432"],

Cell[BoxData[
 RowBox[{
  OverscriptBox[
   StyleBox["H",
    FontSlant->"Italic"], "^"], "=", 
  RowBox[{
   RowBox[{
    SubscriptBox[
     OverscriptBox[
      StyleBox["T",
       FontSlant->"Italic"], "^"], 
     StyleBox["N",
      FontSlant->"Italic"]], 
    RowBox[{"(", 
     StyleBox["R",
      FontSlant->"Italic"], 
     StyleBox[")",
      FontSlant->"Italic"]}]}], "+", 
   RowBox[{
    SubscriptBox[
     OverscriptBox[
      StyleBox["T",
       FontSlant->"Italic"], "^"], 
     StyleBox["e",
      FontSlant->"Italic"]], 
    RowBox[{"(", 
     StyleBox["r",
      FontSlant->"Italic"], 
     StyleBox[")",
      FontSlant->"Italic"]}]}], "+", 
   RowBox[{
    SubscriptBox[
     OverscriptBox[
      StyleBox["V",
       FontSlant->"Italic"], "^"], 
     StyleBox["eN",
      FontSlant->"Italic"]], 
    RowBox[{"(", 
     RowBox[{
      StyleBox["r",
       FontSlant->"Italic"], 
      StyleBox[",",
       FontSlant->"Plain"], 
      StyleBox["R",
       FontSlant->"Italic"]}], 
     StyleBox[")",
      FontSlant->"Italic"]}]}], "+", 
   RowBox[{
    SubscriptBox[
     OverscriptBox[
      StyleBox["V",
       FontSlant->"Italic"], "^"], 
     StyleBox["NN",
      FontSlant->"Italic"]], 
    RowBox[{"(", 
     StyleBox["R",
      FontSlant->"Italic"], 
     StyleBox[")",
      FontSlant->"Italic"]}]}], "+", 
   RowBox[{
    SubscriptBox[
     OverscriptBox[
      StyleBox["V",
       FontSlant->"Italic"], "^"], 
     StyleBox["ee",
      FontSlant->"Italic"]], 
    RowBox[{"(", 
     StyleBox["r",
      FontSlant->"Italic"], 
     StyleBox[")",
      FontSlant->"Italic"]}]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8130759614135423`*^9, 3.813076278147323*^9}, {
   3.813076380382406*^9, 3.8130764153085423`*^9}, 3.813076816633875*^9, {
   3.8130771563624783`*^9, 
   3.8130771828803873`*^9}},ExpressionUUID->"d1785f36-baf3-6b43-a794-\
6aa5711e4e5f"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Solving the Molecular Time-Independent Schr\[ODoubleDot]dinger \
Equation", "Subsection",
 CellChangeTimes->{{3.813077857301325*^9, 3.81307788370608*^9}, {
  3.8130781456350937`*^9, 
  3.813078146261036*^9}},ExpressionUUID->"4e3befa1-72a4-47b1-8d74-\
f56a38fc7a94"],

Cell["\<\
As we have already seen in the case of multielectron atoms, it\
\[CloseCurlyQuote]s much easier to solve the TISE if our Hamiltonian is \
separable. In other words, we want to be able to write our wavefunction as a \
product of separable components and then separate the Hamiltonian into terms \
that act on each part of the wavefunction. In the case of the Hartree (Fock) \
approximation, we wrote our wavefunction as a product of one-electron \
wavefunctions,\
\>", "Text",
 CellChangeTimes->{{3.813077887426569*^9, 3.8130779961655307`*^9}, {
  3.8130780824566507`*^9, 3.813078088786743*^9}, {3.8130781738525543`*^9, 
  3.8130781750452185`*^9}, {3.81307848533836*^9, 3.8130785026307526`*^9}, {
  3.918582102227088*^9, 
  3.9185821034901056`*^9}},ExpressionUUID->"b5aaa482-42d3-45de-b861-\
b374c96ba841"],

Cell[BoxData[
 RowBox[{
  RowBox[{"\[Psi]", 
   RowBox[{"(", 
    RowBox[{
     SubscriptBox[
      StyleBox["r",
       FontWeight->"Bold",
       FontSlant->"Italic"], "1"], ",", " ", 
     SubscriptBox[
      StyleBox["r",
       FontWeight->"Bold",
       FontSlant->"Italic"], "2"]}], ")"}]}], "\[TildeTilde]", 
  RowBox[{"\[Phi]", 
   RowBox[{"(", 
    SubscriptBox[
     StyleBox["r",
      FontWeight->"Bold",
      FontSlant->"Italic"], "1"], ")"}], "\[Phi]", 
   RowBox[{"(", 
    SubscriptBox[
     StyleBox["r",
      FontWeight->"Bold",
      FontSlant->"Italic"], "2"], ")"}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.81307809350165*^9, 3.8130781609264364`*^9}, 
   3.8130782039890594`*^9},ExpressionUUID->"eeae0614-0908-4ea7-841b-\
f318620aca19"],

Cell["\<\
Now, we want to be able to write our wavefunction as a product of an electron \
wavefunction and a nuclear wavefunction,\
\>", "Text",
 CellChangeTimes->{{3.813078218937453*^9, 
  3.8130782581687155`*^9}},ExpressionUUID->"3974bd56-2f16-4089-a6b5-\
8973f3540209"],

Cell[BoxData[
 RowBox[{
  RowBox[{"\[Psi]", 
   RowBox[{"(", 
    RowBox[{
     StyleBox["R",
      FontWeight->"Bold",
      FontSlant->"Italic"], ",", " ", 
     StyleBox["r",
      FontWeight->"Bold",
      FontSlant->"Italic"]}], ")"}]}], "=", 
  RowBox[{
   SubscriptBox["\[Psi]", 
    StyleBox["N",
     FontSlant->"Italic"]], 
   RowBox[{"(", 
    StyleBox["R",
     FontWeight->"Bold",
     FontSlant->"Italic"], 
    StyleBox[")",
     FontSlant->"Italic"]}], 
   SubscriptBox["\[Psi]", 
    StyleBox["e",
     FontSlant->"Italic"]], 
   RowBox[{"(", 
    StyleBox["r",
     FontWeight->"Bold",
     FontSlant->"Italic"], 
    StyleBox[")",
     FontSlant->"Italic"]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.81307809350165*^9, 3.8130781609264364`*^9}, 
   3.8130782039890594`*^9, {3.813078272672757*^9, 
   3.8130783323990836`*^9}},ExpressionUUID->"91f983a3-3d78-44ea-9c6f-\
a1a488983638"],

Cell[TextData[{
 "where we are using ",
 StyleBox["R",
  FontWeight->"Bold",
  FontSlant->"Italic"],
 " and ",
 StyleBox["r",
  FontWeight->"Bold",
  FontSlant->"Italic"],
 " as shorthand to represent the coordinates of all nuclei and electrons, \
respectively. If we then had a Hamiltonian,"
}], "Text",
 CellChangeTimes->{{3.813078337477155*^9, 3.813078370019065*^9}, {
   3.8130785140436783`*^9, 3.8130785203233843`*^9}, 
   3.9185821968002605`*^9},ExpressionUUID->"bf89b15e-f22d-4f39-9948-\
c933611281d6"],

Cell[BoxData[
 RowBox[{
  OverscriptBox[
   StyleBox["H",
    FontSlant->"Italic"], "^"], "=", 
  RowBox[{
   RowBox[{
    SubscriptBox[
     OverscriptBox[
      StyleBox["H",
       FontSlant->"Italic"], "^"], 
     StyleBox["N",
      FontSlant->"Italic"]], 
    RowBox[{"(", 
     StyleBox["R",
      FontSlant->"Italic"], 
     StyleBox[")",
      FontSlant->"Italic"]}]}], "+", 
   RowBox[{
    SubscriptBox[
     OverscriptBox[
      StyleBox["H",
       FontSlant->"Italic"], "^"], 
     StyleBox["e",
      FontSlant->"Italic"]], 
    RowBox[{"(", 
     StyleBox["r",
      FontSlant->"Italic"], 
     StyleBox[")",
      FontSlant->"Italic"]}]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8130759614135423`*^9, 3.813076278147323*^9}, {
   3.813076380382406*^9, 3.8130764153085423`*^9}, 3.813076816633875*^9, {
   3.8130771563624783`*^9, 3.8130771828803873`*^9}, {3.8130785310803776`*^9, 
   3.8130785402645917`*^9}},ExpressionUUID->"ce2a2d32-9eec-4726-9392-\
2005a2f10d40"],

Cell["\<\
we would obtain an easily solvable time-independent Schr\[ODoubleDot]dinger \
equation,\
\>", "Text",
 CellChangeTimes->{{3.8130785458251295`*^9, 3.813078565151059*^9}, {
  3.8130786762671585`*^9, 
  3.8130786787883167`*^9}},ExpressionUUID->"9c5a74b6-e277-4988-9f17-\
4f571532de14"],

