 RowBox[{
  RowBox[{"\[LeftAngleBracket]", 
   StyleBox["r",
    FontSlant->"Italic"], "\[RightAngleBracket]"}], "=", 
  RowBox[{
   SubsuperscriptBox["\[Integral]", "0", "\[Infinity]"], 
   RowBox[{
