        FontSlant->"Italic"]], 
      RowBox[{
       SubsuperscriptBox[
        StyleBox["c",
         FontSlant->"Italic"], 
        StyleBox["n",
         FontSlant->"Italic"], "\[Star]"], 
       SubscriptBox[
        StyleBox["c",
         FontSlant->"Italic"], 
        StyleBox["n",
         FontSlant->"Italic"]]}]}]}]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.811593312893673*^9, 3.8115933831661987`*^9}, {
  3.811593458953679*^9, 3.8115934974178753`*^9}, {3.8115936143121653`*^9, 
  3.811593715195953*^9}, {3.811594208013258*^9, 3.811594210677987*^9}, {
  3.811594342816991*^9, 3.8115943434093456`*^9}, {3.811594623901507*^9, 
  3.811594670874273*^9}, {3.8115947420473485`*^9, 3.8115947734245424`*^9}, {
  3.811594861515888*^9, 3.8115948828180823`*^9}, {3.8115949210585313`*^9, 
  3.811595050352028*^9}, {3.8115952609845133`*^9, 
  3.8115953215973034`*^9}},ExpressionUUID->"d9189fb1-57e9-514e-97ef-\
3fea0e8da419"],

Cell["So equation (16) becomes", "Text",
 CellChangeTimes->{{3.811595333706521*^9, 3.811595336836768*^9}, {
  3.9362797910677414`*^9, 
  3.936279791764204*^9}},ExpressionUUID->"1da5f196-d90f-5442-8ffe-\
568a77470900"],

Cell[BoxData[
 RowBox[{
  SubscriptBox[
   StyleBox["E",
    FontSlant->"Italic"], "\[Phi]"], "=", 
  FractionBox[
   RowBox[{
    UnderscriptBox["\[Sum]", 
     StyleBox["n",
      FontSlant->"Italic"]], 
    RowBox[{
     SubsuperscriptBox[
      StyleBox["c",
       FontSlant->"Italic"], 
      StyleBox["n",
       FontSlant->"Italic"], "\[Star]"], 
     SubscriptBox[
      StyleBox["c",
       FontSlant->"Italic"], 
      StyleBox["n",
       FontSlant->"Italic"]], 
     SubscriptBox[
      StyleBox["E",
       FontSlant->"Italic"], 
      StyleBox["n",
       FontSlant->"Italic"]], "   "}]}], 
   RowBox[{
    UnderscriptBox["\[Sum]", 
     StyleBox["n",
      FontSlant->"Italic"]], 
    RowBox[{
     SubsuperscriptBox[
      StyleBox["c",
       FontSlant->"Italic"], 
      StyleBox["n",
       FontSlant->"Italic"], "\[Star]"], 
     SubscriptBox[
      StyleBox["c",
       FontSlant->"Italic"], 
      StyleBox["n",
       FontSlant->"Italic"]], " ", " "}]}]], 
  "                                         "}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.811593312893673*^9, 3.8115933831661987`*^9}, {
  3.811593458953679*^9, 3.8115934974178753`*^9}, {3.8115936143121653`*^9, 
  3.811593715195953*^9}, {3.811594208013258*^9, 3.811594210677987*^9}, {
  3.811594342816991*^9, 3.8115943434093456`*^9}, {3.811594623901507*^9, 
  3.811594670874273*^9}, {3.8115948564704037`*^9, 3.8115948589878416`*^9}, {
  3.8115949257053156`*^9, 3.811594926820971*^9}, {3.811595479273041*^9, 
  3.8115954891149044`*^9}},ExpressionUUID->"21698d30-7fdf-244e-892d-\
eab30aa78ec1"],

Cell[TextData[{
 "If we subtract from both sides the true ground-state energy ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["E", "0"], TraditionalForm]],ExpressionUUID->
  "81931c30-53d2-f840-a02d-15b31823c968"],
 ", we obtain"
}], "Text",
 CellChangeTimes->{{3.811595509922247*^9, 
  3.8115955274248333`*^9}},ExpressionUUID->"4cba8a86-e911-b847-b14c-\
acb022e9d55b"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   SubscriptBox[
    StyleBox["E",
     FontSlant->"Italic"], "\[Phi]"], "-", 
   SubscriptBox[
    StyleBox["E",
     FontSlant->"Italic"], "0"]}], "=", 
  FractionBox[
   RowBox[{
    UnderscriptBox["\[Sum]", 
     StyleBox["n",
      FontSlant->"Italic"]], 
    RowBox[{
     SubsuperscriptBox[
      StyleBox["c",
       FontSlant->"Italic"], 
      StyleBox["n",
       FontSlant->"Italic"], "\[Star]"], 
     SubscriptBox[
      StyleBox["c",
       FontSlant->"Italic"], 
      StyleBox["n",
       FontSlant->"Italic"]], 
     RowBox[{"(", 
      RowBox[{
       SubscriptBox[
        StyleBox["E",
         FontSlant->"Italic"], 
        StyleBox["n",
         FontSlant->"Italic"]], " ", "-", 
       SubscriptBox[
        StyleBox["E",
         FontSlant->"Italic"], "0"]}], ")"}], "  "}]}], 
   RowBox[{
    UnderscriptBox["\[Sum]", 
     StyleBox["n",
      FontSlant->"Italic"]], 
    RowBox[{
     SubsuperscriptBox[
      StyleBox["c",
       FontSlant->"Italic"], 
      StyleBox["n",
       FontSlant->"Italic"], "\[Star]"], 
     SubscriptBox[
      StyleBox["c",
       FontSlant->"Italic"], 
      StyleBox["n",
       FontSlant->"Italic"]], " ", " "}]}]], 
  "                                         "}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.811593312893673*^9, 3.8115933831661987`*^9}, {
  3.811593458953679*^9, 3.8115934974178753`*^9}, {3.8115936143121653`*^9, 
  3.811593715195953*^9}, {3.811594208013258*^9, 3.811594210677987*^9}, {
  3.811594342816991*^9, 3.8115943434093456`*^9}, {3.811594623901507*^9, 
  3.811594670874273*^9}, {3.8115948564704037`*^9, 3.8115948589878416`*^9}, {
  3.8115949257053156`*^9, 3.811594926820971*^9}, {3.811595479273041*^9, 
  3.8115954891149044`*^9}, {3.811595544770972*^9, 
  3.8115955636290846`*^9}},ExpressionUUID->"d89fbf4d-4a7d-ad4f-a387-\
2812de8ba01d"],

Cell[TextData[{
 "Because all of the quantities on the right-hand side are positive (remember \
that the ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["E", "n"], TraditionalForm]],ExpressionUUID->
  "5059ec6d-9ad5-ca49-9cfb-21b28f6f0518"],
 " values are simply the energy eigenvalues of higher-energy eigenstates), we \
come to the conclusion that"
}], "Text",
 CellChangeTimes->{{3.811595572873334*^9, 3.811595645774925*^9}, {
  3.93627980861792*^9, 
  3.936279811211706*^9}},ExpressionUUID->"255d7472-b0c5-e248-92e9-\
42ac281d4aaa"],

Cell[BoxData[
 RowBox[{
  SubscriptBox[
   StyleBox["E",
    FontSlant->"Italic"], "\[Phi]"], "\[GreaterEqual]", 
  SubscriptBox[
   StyleBox["E",
    FontSlant->"Italic"], "0"], 
  "                             "}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.811593312893673*^9, 3.8115933831661987`*^9}, {
  3.811593458953679*^9, 3.8115934974178753`*^9}, {3.8115936143121653`*^9, 
  3.811593715195953*^9}, {3.811594208013258*^9, 3.811594210677987*^9}, {
  3.811594342816991*^9, 3.8115943434093456`*^9}, {3.811594623901507*^9, 
  3.811594670874273*^9}, {3.8115948564704037`*^9, 3.8115948589878416`*^9}, {
  3.8115949257053156`*^9, 3.811594926820971*^9}, {3.811595479273041*^9, 
  3.8115954891149044`*^9}, {3.811595544770972*^9, 3.8115955636290846`*^9}, {
  3.81159565421358*^9, 
  3.811595661321888*^9}},ExpressionUUID->"9d857c0e-1497-354a-8b3b-\
339449535720"],

Cell["\<\
which is known as the variational principle. In other words, the energy we \
obtain from solving the Hamiltonian of our trial wavefunction will always be \
greater than or equal to the energy of the true wavefunction. That means, for \
a given trial wavefunction that is a function of some parameters, \
\>", "Text",
 CellChangeTimes->{{3.811595665074706*^9, 
  3.8115957711046777`*^9}},ExpressionUUID->"e67bdae7-3fab-8e47-95df-\
5086c817b02f"],

Cell[BoxData[
 RowBox[{"\[Phi]", 
  RowBox[{"(", 
   RowBox[{"\[Alpha]", ",", "\[Beta]", ",", "\[Gamma]", ",", "..."}], 
   ")"}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8115957861172256`*^9, 
  3.8115957979180317`*^9}},ExpressionUUID->"9b742255-05cf-0648-a3cd-\
048eae5a8a9a"],

Cell[TextData[{
 "the value of the parameters that gives the lowest value of ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["E", "\[Phi]"], TraditionalForm]],ExpressionUUID->
  "3c28b01b-9431-5c4d-8fba-523cfa83a363"],
 " will give the best approximation of the true energy eigenvalues and \
wavefunction eigenstates."
}], "Text",
 CellChangeTimes->{{3.8115958134856806`*^9, 
  3.8115958736340804`*^9}},ExpressionUUID->"c37278f3-f770-424b-865c-\
6c748b4e9abc"],

Cell["\<\
Thus, the variational method involves selecting a trial wavefunction and \
adjusting parameters to achieve the lowest-possible energy in the TISE. The \
ultimate accuracy of the method will depend on how well the trial \
wavefunction approximates the true wavefunction.\
\>", "Text",
 CellChangeTimes->{{3.811595879331231*^9, 
  3.811595954155257*^9}},ExpressionUUID->"8a5e08f3-3012-4847-853e-\
8f1624713946"]
}, Open  ]],

Cell[CellGroupData[{

Cell["The Hartree Approximation", "Subsection",
 CellChangeTimes->{{3.8119460978813057`*^9, 
  3.8119461141688137`*^9}},ExpressionUUID->"1830509e-0020-4526-b58f-\
5b6da9c5a74d"],

Cell["\<\
The variational method allows us to provide a guess wavefunction and then \
optimize parameters to find the best possible solution. However, we still \
need to address what that guess wavefunction might actually look like. \
Specifically, we have to develop a method to address the challenges of the \
interelectronic repulsion term, which prevents an exact solution to the TISE. \
But what if we assume that we can approximate the true wavefunction of the \
ground states as the product of two hydrogen-like wavefunctions,\
\>", "Text",
 CellChangeTimes->{{3.811946776390978*^9, 3.811946834883534*^9}, {
  3.917701198814831*^9, 3.9177012521468506`*^9}, {3.9177013030881157`*^9, 
  3.9177013641541615`*^9}},ExpressionUUID->"010bea3a-6d45-4627-b89b-\
8aaf23e84bbc"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"\[Psi]", 
    RowBox[{"(", 
     RowBox[{
      SubscriptBox[
       StyleBox["r",
        FontWeight->"Bold",
        FontSlant->"Italic"], "1"], ",", " ", 
      SubscriptBox[
       StyleBox["r",
        FontWeight->"Bold",
        FontSlant->"Italic"], "2"]}], ")"}]}], "\[TildeTilde]", 
   RowBox[{"\[CapitalPhi]", 
    RowBox[{"(", 
     RowBox[{
      SubscriptBox[
       StyleBox["r",
        FontWeight->"Bold",
        FontSlant->"Italic"], "1"], ",", " ", 
      SubscriptBox[
       StyleBox["r",
        FontWeight->"Bold",
        FontSlant->"Italic"], "2"]}], ")"}]}]}], "=", 
  RowBox[{"\[Phi]", 
   RowBox[{"(", 
    SubscriptBox[
     StyleBox["r",
      FontWeight->"Bold",
      FontSlant->"Italic"], "1"], ")"}], "\[Phi]", 
   RowBox[{"(", 
    SubscriptBox[
     StyleBox["r",
      FontWeight->"Bold",
      FontSlant->"Italic"], "2"], ")"}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.810112811439228*^9, 3.8101128248442793`*^9}, {
  3.810479494926491*^9, 3.8104795038498344`*^9}, {3.810479572543576*^9, 
  3.8104796147383184`*^9}, {3.8104802055659895`*^9, 3.8104802433915305`*^9}, {
  3.8104802785189395`*^9, 3.8104802814214115`*^9}, {3.8109915300785556`*^9, 
  3.8109916793993816`*^9}, {3.810991710031681*^9, 3.8109918292023373`*^9}, {
  3.810994488524798*^9, 3.810994499853472*^9}, {3.8109948928195066`*^9, 
  3.8109948950763626`*^9}, {3.8109949491606197`*^9, 3.810995087249513*^9}, {
  3.8109951188614283`*^9, 3.8109951226144466`*^9}, {3.8115998145208507`*^9, 
  3.8115999093225703`*^9}},ExpressionUUID->"15e9d1b3-65fc-4b8b-b447-\
0868382096c7"],

Cell[TextData[{
 "This approach represents the starting point of the ",
 StyleBox["Hartree approximation, which assumes that the exact wavefunction \
of a multielectron system can be approximated as the product of \
single-electron wavefunctions",
  FontWeight->"Bold"],
 "."
}], "Text",
 CellChangeTimes->{{3.811946912077041*^9, 
  3.811946966438778*^9}},ExpressionUUID->"4847c062-76b7-4dbb-929c-\
8781ef4f7001"],

Cell["\<\
The next step in the Hartree method involves the formulation of an effective \
potential experienced by an electron due to the other electrons. Let\
\[CloseCurlyQuote]s continue with the example of the helium atom, which only \
has two electrons. We have thus far been interpreting the quantity\
\>", "Text",
 CellChangeTimes->{{3.811947025233654*^9, 3.811947137342453*^9}, {
  3.8119472068066072`*^9, 3.8119472362252483`*^9}, {3.8119475900311756`*^9, 
  3.8119475944328403`*^9}},ExpressionUUID->"49f750bf-f6dd-49b9-afb6-\
545c129971eb"],

Cell[BoxData[
 RowBox[{
  SuperscriptBox["\[Phi]", "\[Star]"], 
  RowBox[{"(", 
   SubscriptBox[
    StyleBox["r",
     FontWeight->"Bold",
     FontSlant->"Italic"], "2"], ")"}], "\[Phi]", 
  RowBox[{"(", 
   SubscriptBox[
    StyleBox["r",
     FontWeight->"Bold",
     FontSlant->"Italic"], "2"], ")"}], 
  RowBox[{"\[DifferentialD]", 
   SubscriptBox[
    StyleBox["r",
     FontWeight->"Bold",
     FontSlant->"Italic"], "2"]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.810112811439228*^9, 3.8101128248442793`*^9}, {
   3.810479494926491*^9, 3.8104795038498344`*^9}, {3.810479572543576*^9, 
   3.8104796147383184`*^9}, {3.8104802055659895`*^9, 
   3.8104802433915305`*^9}, {3.8104802785189395`*^9, 
   3.8104802814214115`*^9}, {3.8109915300785556`*^9, 
   3.8109916793993816`*^9}, {3.810991710031681*^9, 3.8109918292023373`*^9}, {
   3.810994488524798*^9, 3.810994499853472*^9}, {3.8109948928195066`*^9, 
   3.8109948950763626`*^9}, {3.8109949491606197`*^9, 3.810995087249513*^9}, {
   3.8109951188614283`*^9, 3.8109951226144466`*^9}, {3.8115998145208507`*^9, 
   3.8115999093225703`*^9}, 3.8119468581508093`*^9, {3.811947243706769*^9, 
   3.811947267020794*^9}},ExpressionUUID->"1c1ea6f0-b891-4b30-864a-\
8e1cf286eda8"],

Cell[TextData[{
 "as the probability of finding electron 2 in the infinitesimally small \
volume element ",
 Cell[BoxData[
  RowBox[{"\[DifferentialD]", 
   SubscriptBox[
    StyleBox["r",
     FontWeight->"Bold",
     FontSlant->"Italic"], "2"]}]],
  CellChangeTimes->{{3.810112811439228*^9, 3.8101128248442793`*^9}, {
    3.810479494926491*^9, 3.8104795038498344`*^9}, {3.810479572543576*^9, 
    3.8104796147383184`*^9}, {3.8104802055659895`*^9, 
    3.8104802433915305`*^9}, {3.8104802785189395`*^9, 
    3.8104802814214115`*^9}, {3.8109915300785556`*^9, 
    3.8109916793993816`*^9}, {3.810991710031681*^9, 3.8109918292023373`*^9}, {
    3.810994488524798*^9, 3.810994499853472*^9}, {3.8109948928195066`*^9, 
    3.8109948950763626`*^9}, {3.8109949491606197`*^9, 3.810995087249513*^9}, {
    3.8109951188614283`*^9, 3.8109951226144466`*^9}, {3.8115998145208507`*^9, 
    3.8115999093225703`*^9}, 3.8119468581508093`*^9, {3.811947243706769*^9, 
    3.811947267020794*^9}},ExpressionUUID->
  "b0b707c9-371d-4a30-8c53-82c1590ecf1a"],
 " located at position ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["r",
    FontWeight->"Bold",
    FontSlant->"Italic"], "2"]],
  CellChangeTimes->{{3.810112811439228*^9, 3.8101128248442793`*^9}, {
    3.810479494926491*^9, 3.8104795038498344`*^9}, {3.810479572543576*^9, 
    3.8104796147383184`*^9}, {3.8104802055659895`*^9, 
    3.8104802433915305`*^9}, {3.8104802785189395`*^9, 
    3.8104802814214115`*^9}, {3.8109915300785556`*^9, 
    3.8109916793993816`*^9}, {3.810991710031681*^9, 3.8109918292023373`*^9}, {
    3.810994488524798*^9, 3.810994499853472*^9}, {3.8109948928195066`*^9, 
    3.8109948950763626`*^9}, {3.8109949491606197`*^9, 3.810995087249513*^9}, {
    3.8109951188614283`*^9, 3.8109951226144466`*^9}, {3.8115998145208507`*^9, 
    3.8115999093225703`*^9}, 3.8119468581508093`*^9, {3.811947243706769*^9, 
    3.811947267020794*^9}},ExpressionUUID->
  "5b97edcf-bb2e-4cbc-ad68-0439fb7968ab"],
 ". However, we could also think about this quantity as representing the \
charge density at position ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["r",
    FontWeight->"Bold",
    FontSlant->"Italic"], "2"]],
  CellChangeTimes->{{3.810112811439228*^9, 3.8101128248442793`*^9}, {
    3.810479494926491*^9, 3.8104795038498344`*^9}, {3.810479572543576*^9, 
    3.8104796147383184`*^9}, {3.8104802055659895`*^9, 
    3.8104802433915305`*^9}, {3.8104802785189395`*^9, 
    3.8104802814214115`*^9}, {3.8109915300785556`*^9, 
    3.8109916793993816`*^9}, {3.810991710031681*^9, 3.8109918292023373`*^9}, {
    3.810994488524798*^9, 3.810994499853472*^9}, {3.8109948928195066`*^9, 
    3.8109948950763626`*^9}, {3.8109949491606197`*^9, 3.810995087249513*^9}, {
    3.8109951188614283`*^9, 3.8109951226144466`*^9}, {3.8115998145208507`*^9, 
    3.8115999093225703`*^9}, 3.8119468581508093`*^9, {3.811947243706769*^9, 
    3.811947267020794*^9}},ExpressionUUID->
  "593fb6fb-291b-4302-b805-ba70efff17a9"],
 ". In this case, we can define an effective potential experienced by \
electron 1 due to the charge density of electron 2 as"
}], "Text",
 CellChangeTimes->{{3.8119472711695952`*^9, 3.811947427261121*^9}, {
  3.917701492711166*^9, 
  3.9177014934296675`*^9}},ExpressionUUID->"79a1bc8c-e8a6-46dd-967c-\
a35bf18a8833"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   SubsuperscriptBox[
    StyleBox["V",
     FontSlant->"Italic"], "1", "eff"], 
   RowBox[{"(", 
    SubscriptBox[
     StyleBox["r",
      FontSlant->"Italic"], "1"], ")"}]}], "=", 
  RowBox[{"\[Integral]", 
   RowBox[{
    SuperscriptBox["\[Phi]", "\[Star]"], 
    RowBox[{"(", 
     SubscriptBox[
      StyleBox["r",
       FontWeight->"Bold",
       FontSlant->"Italic"], "2"], ")"}], 
    FractionBox[
     SuperscriptBox[
      StyleBox["e",
       FontSlant->"Italic"], "2"], 
     RowBox[{"4", 
      SubscriptBox["\[Pi]\[Epsilon]", "0"]}]], 
    FractionBox["1", 
     SubscriptBox[
      StyleBox["r",
       FontSlant->"Italic"], "12"]], "\[Phi]", 
    RowBox[{"(", 
     SubscriptBox[
      StyleBox["r",
       FontWeight->"Bold",
       FontSlant->"Italic"], "2"], ")"}], 
    RowBox[{"\[DifferentialD]", 
     SubscriptBox[
      StyleBox["r",
       FontWeight->"Bold",
       FontSlant->"Italic"], "2"]}]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.810112811439228*^9, 3.8101128248442793`*^9}, {
   3.810479494926491*^9, 3.8104795038498344`*^9}, {3.810479572543576*^9, 
   3.8104796147383184`*^9}, {3.8104802055659895`*^9, 
   3.8104802433915305`*^9}, {3.8104802785189395`*^9, 
   3.8104802814214115`*^9}, {3.8109915300785556`*^9, 
   3.8109916793993816`*^9}, {3.810991710031681*^9, 3.8109918292023373`*^9}, {
   3.810994488524798*^9, 3.810994499853472*^9}, {3.8109948928195066`*^9, 
   3.8109948950763626`*^9}, {3.8109949491606197`*^9, 3.810995087249513*^9}, {
   3.8109951188614283`*^9, 3.8109951226144466`*^9}, {3.8115998145208507`*^9, 
   3.8115999093225703`*^9}, 3.8119468581508093`*^9, {3.811947243706769*^9, 
   3.811947267020794*^9}, {3.8119474358938656`*^9, 3.8119474621815863`*^9}, {
