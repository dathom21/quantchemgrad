}], "Text",
 CellChangeTimes->{{3.810110382328756*^9, 
  3.8101104074128857`*^9}},ExpressionUUID->"7de62352-dcb8-4eb1-a217-\
f00b650e94d9"],

Cell[BoxData[
 RowBox[{
  StyleBox["L",
   FontSlant->"Italic"], "=", 
  RowBox[{
   RowBox[{"\[LeftBracketingBar]", 
    StyleBox["L",
     FontWeight->"Bold",
     FontSlant->"Italic"], "\[RightBracketingBar]"}], "=", 
   RowBox[{
    RowBox[{
     RowBox[{"\[LeftBracketingBar]", 
      StyleBox["r",
       FontWeight->"Bold",
       FontSlant->"Italic"], "\[RightBracketingBar]"}], 
     RowBox[{"\[LeftBracketingBar]", 
      StyleBox["p",
       FontWeight->"Bold",
       FontSlant->"Italic"], "\[RightBracketingBar]"}]}], 
    StyleBox[" ",
     FontWeight->"Bold",
     FontSlant->"Italic"], "=", 
    StyleBox["mvr",
     FontSlant->"Italic"]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8100544880652375`*^9, 3.8100545041200957`*^9}, {
  3.810054632482561*^9, 3.8100546606919527`*^9}, {3.810054738405748*^9, 
  3.810054754160844*^9}, {3.8101095281443005`*^9, 3.810109574197364*^9}, {
  3.810110302377673*^9, 3.81011033119788*^9}, {3.81011042226412*^9, 
  3.8101104310884852`*^9}, {3.8101105613940926`*^9, 
  3.810110566931136*^9}},ExpressionUUID->"6bfc15ad-79ef-4ac4-bf09-\
e28bd564924f"],

Cell[TextData[{
 "The speed ",
 StyleBox["v",
  FontSlant->"Italic"],
 " of the particle in this equation is given by"
}], "Text",
 CellChangeTimes->{{3.810110708626486*^9, 
  3.810110736569311*^9}},ExpressionUUID->"b449e47c-14b6-4516-84a2-\
099bf91e4ce8"],

Cell[BoxData[
 RowBox[{
  StyleBox["v",
   FontSlant->"Italic"], "=", 
  RowBox[{
   RowBox[{"2", 
    StyleBox[
     RowBox[{"\[Pi]", 
      StyleBox["r",
       FontSlant->"Italic"], "\[Nu]"}]]}], "=", 
   StyleBox[
    RowBox[{
     StyleBox["r",
      FontSlant->"Italic"], "\[Omega]"}]]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8100569287953453`*^9, 3.810056984903867*^9}, {
   3.8101088518226004`*^9, 3.8101088557601814`*^9}, 
   3.810110967901849*^9},ExpressionUUID->"d314b530-d3f8-4b48-b0c4-\
c6c1b9e5bf75"],

Cell[TextData[{
 "where ",
 Cell[BoxData[
  FormBox["\[Nu]", TraditionalForm]],ExpressionUUID->
  "75b057d1-6f4b-4ef0-bdbf-870f16049770"],
 " is the rotational frequency (cycles per second) and ",
 Cell[BoxData[
  FormBox["\[Omega]", TraditionalForm]],ExpressionUUID->
  "e4dab6cc-5a18-4b03-a2eb-177f31030383"],
 " is the angular speed. Using these definitions, we can rewrite our equation \
for ",
 StyleBox["L",
  FontSlant->"Italic"],
 " as"
}], "Text",
 CellChangeTimes->{{3.8101107730514326`*^9, 3.8101108020744133`*^9}, {
  3.8101108936419735`*^9, 
  3.8101109350249653`*^9}},ExpressionUUID->"aa91f6d8-90ea-4d2f-8683-\
d646d2ecbfa9"],

Cell[BoxData[
 RowBox[{
  StyleBox["L",
   FontSlant->"Italic"], "=", 
  RowBox[{
   RowBox[{
    StyleBox["m",
     FontSlant->"Italic"], 
    RowBox[{
     StyleBox["(",
      FontSlant->"Italic"], 
     StyleBox[
      RowBox[{
       StyleBox["r",
        FontSlant->"Italic"], 
       StyleBox["\[Omega]",
        FontSlant->"Plain"]}]], 
     StyleBox[")",
      FontSlant->"Italic"]}], 
    StyleBox["r",
     FontSlant->"Italic"]}], 
   StyleBox["=",
    FontSlant->"Plain"], 
   RowBox[{
    RowBox[{
     SuperscriptBox[
      StyleBox["mr",
       FontSlant->"Italic"], "2"], "\[Omega]"}], "=", 
    StyleBox[
     RowBox[{
      StyleBox["I",
       FontSlant->"Italic"], "\[Omega]"}]]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8100544880652375`*^9, 3.8100545041200957`*^9}, {
  3.810054632482561*^9, 3.8100546606919527`*^9}, {3.810054738405748*^9, 
  3.810054754160844*^9}, {3.8101095281443005`*^9, 3.810109574197364*^9}, {
  3.810110302377673*^9, 3.81011033119788*^9}, {3.81011042226412*^9, 
  3.8101104310884852`*^9}, {3.8101105613940926`*^9, 3.810110566931136*^9}, {
  3.810110941872168*^9, 
  3.810111041727865*^9}},ExpressionUUID->"3dfd334f-b41a-45be-8d63-\
b0c863e2b0a9"],

Cell[TextData[{
 "where we have now defined the moment of inertia ",
 StyleBox["I",
  FontSlant->"Italic"],
 " as"
}], "Text",
 CellChangeTimes->{{3.810111044298995*^9, 
  3.8101110580386815`*^9}},ExpressionUUID->"da70ae94-3cd3-4444-8e86-\
9ff2aae9253f"],

Cell[BoxData[
 RowBox[{
  StyleBox["I",
   FontSlant->"Italic"], 
  StyleBox["=",
   FontSlant->"Plain"], 
  SuperscriptBox[
   StyleBox["mr",
    FontSlant->"Italic"], "2"]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8100544880652375`*^9, 3.8100545041200957`*^9}, {
  3.810054632482561*^9, 3.8100546606919527`*^9}, {3.810054738405748*^9, 
  3.810054754160844*^9}, {3.8101095281443005`*^9, 3.810109574197364*^9}, {
  3.810110302377673*^9, 3.81011033119788*^9}, {3.81011042226412*^9, 
  3.8101104310884852`*^9}, {3.8101105613940926`*^9, 3.810110566931136*^9}, {
  3.810110941872168*^9, 
  3.8101110800488815`*^9}},ExpressionUUID->"ca4c5f2d-fea6-420a-b737-\
03c3dcb6b0bd"],

Cell["\<\
Although we have derived this result for circular motion, it turns out that \
the angular momentum can generally be written as\
\>", "Text",
 CellChangeTimes->{{3.810111191409666*^9, 
  3.8101112387265787`*^9}},ExpressionUUID->"66465950-5709-4bd8-8fda-\
b0bbfdc44390"],

Cell[BoxData[
 RowBox[{
  StyleBox["L",
   FontWeight->"Bold",
   FontSlant->"Italic"], "=", 
  StyleBox[
   RowBox[{
    StyleBox["I",
     FontSlant->"Italic"], 
    StyleBox["\[Omega]",
     FontWeight->"Bold"]}]]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8100544880652375`*^9, 3.8100545041200957`*^9}, {
   3.810054632482561*^9, 3.8100546606919527`*^9}, {3.810054738405748*^9, 
   3.810054754160844*^9}, {3.8101095281443005`*^9, 3.810109574197364*^9}, {
   3.810110302377673*^9, 3.81011033119788*^9}, {3.81011042226412*^9, 
   3.8101104310884852`*^9}, {3.8101105613940926`*^9, 3.810110566931136*^9}, {
   3.810110941872168*^9, 3.810111041727865*^9}, 
   3.8101112473493013`*^9},ExpressionUUID->"ac0471b3-1e6c-437d-9ddd-\
fd5aeb9a8c7e"],

Cell[TextData[{
 "We can see an analogy between the equations for linear momentum ",
 StyleBox["p",
  FontWeight->"Bold",
  FontSlant->"Italic"],
 " and angular momentum ",
 StyleBox["L",
  FontWeight->"Bold",
  FontSlant->"Italic"],
 ", where the mass has been replaced by the moment of inertia ",
 StyleBox["I",
  FontSlant->"Italic"],
 ", and the velocity ",
 StyleBox["v",
  FontWeight->"Bold",
  FontSlant->"Italic"],
 " has been replaced by the angular velocity ",
 StyleBox["\[Omega]",
  FontWeight->"Bold"],
 ". This replacement is in fact a general method to find the corresponding \
rotational system equations beginning with those for linear systems."
}], "Text",
 CellChangeTimes->{{3.8101112611329994`*^9, 3.8101113515748224`*^9}, {
  3.810111420092642*^9, 3.8101114641659517`*^9}, {3.810112167775034*^9, 
  3.8101122194086213`*^9}},ExpressionUUID->"95a94e35-79a8-4a44-9edc-\
4746ad7f1b13"],

Cell[TextData[{
 "Using the circular example again, we can also see the correspondence \
between linear and rotational kinetic energy. The kinetic energy ",
 StyleBox["T",
  FontSlant->"Italic"],
 " ",
 "of a particle with circular motion is given by"
}], "Text",
 CellChangeTimes->{{3.810111466273756*^9, 3.810111473552887*^9}, {
  3.915800901998008*^9, 
  3.9158009044083867`*^9}},ExpressionUUID->"b72f4481-6151-464c-b38d-\
1ec16554a90c"],

Cell[BoxData[
 RowBox[{
  StyleBox["T",
   FontSlant->"Italic"], 
  StyleBox["=",
   FontSlant->"Plain"], 
  RowBox[{
   FractionBox[
    SuperscriptBox[
     StyleBox["p",
      FontSlant->"Italic"], "2"], 
    RowBox[{"2", 
     StyleBox["m",
      FontSlant->"Italic"]}]], "=", 
   RowBox[{
    FractionBox[
     SuperscriptBox[
      StyleBox["mv",
       FontSlant->"Italic"], "2"], "2"], "=", 
    RowBox[{
     FractionBox[
      RowBox[{
       SuperscriptBox[
        StyleBox["mr",
         FontSlant->"Italic"], "2"], 
       SuperscriptBox["\[Omega]", "2"]}], "2"], "=", 
     RowBox[{
      FractionBox[
       SuperscriptBox[
        StyleBox[
         RowBox[{
          StyleBox["I",
           FontSlant->"Italic"], "\[Omega]"}]], "2"], "2"], "=", 
      FractionBox[
       SuperscriptBox[
        StyleBox["L",
         FontSlant->"Italic"], "2"], 
       RowBox[{"2", 
        StyleBox["I",
         FontSlant->"Italic"]}]]}]}]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.810108783183482*^9, 3.810108815266238*^9}, {
  3.8101088632448235`*^9, 3.8101088893706894`*^9}, {3.8101114824558687`*^9, 
  3.810111559886958*^9}, {3.9158008927190104`*^9, 
  3.9158008935126176`*^9}},ExpressionUUID->"3bf7500b-320f-4c10-8eef-\
33597c2b73b8"],

Cell[TextData[{
 "Thus, ",
 Cell[BoxData[
  FractionBox[
   SuperscriptBox[
    StyleBox["L",
     FontSlant->"Italic"], "2"], 
   RowBox[{"2", 
    StyleBox["I",
     FontSlant->"Italic"]}]]],
  CellChangeTimes->{
   3.810111603806044*^9, {3.8101116453503847`*^9, 3.8101116463740788`*^9}},
  FontSize->24,ExpressionUUID->"2a5c01b8-8e38-4f7d-aac2-0549987d8fc8"],
 "is the rotational equivalent of ",
 Cell[BoxData[
  FractionBox[
   SuperscriptBox[
    StyleBox["p",
     FontSlant->"Italic"], "2"], 
   RowBox[{"2", 
    StyleBox["m",
     FontSlant->"Italic"]}]]],
  CellChangeTimes->{3.8101116299988704`*^9},
  FontSize->24,ExpressionUUID->"3ae82eb2-0c91-4e61-8576-6ca50ea5d6ef"],
 ", and ",
 Cell[BoxData[
  FractionBox[
   SuperscriptBox[
    StyleBox[
     RowBox[{
      StyleBox["I",
       FontSlant->"Italic"], "\[Omega]"}]], "2"], "2"]],
  CellChangeTimes->{3.810111654772566*^9},
  FontSize->24,ExpressionUUID->"fdd38512-8da1-4113-86be-4d75f811fa7b"],
 "is the rotational equivalent of ",
 Cell[BoxData[
  FractionBox[
   SuperscriptBox[
    StyleBox["mv",
     FontSlant->"Italic"], "2"], "2"]],
  CellChangeTimes->{3.8101116747592664`*^9},
  FontSize->24,ExpressionUUID->"399b27e5-7b9b-4fc8-a35f-4c82d24ccfbd"],
 ". "
}], "Text",
 CellChangeTimes->{{3.8101115863889894`*^9, 3.8101115869184923`*^9}, {
  3.810111701386856*^9, 3.8101117242895904`*^9}, {3.810112070566839*^9, 
  3.810112163223507*^9}},ExpressionUUID->"8754c96f-f44c-4fb4-9c72-\
866e1c2709a7"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Spherical Coordinates", "Subsection",
 CellChangeTimes->{{3.810114970651063*^9, 
  3.8101149729654713`*^9}},ExpressionUUID->"626a379c-0bea-4a03-bc73-\
4ae26579f3c1"],

Cell["\<\
When working with concepts of rotation, it is often convenient to work in \
spherical rather than Cartesian coordinates. Let\[CloseCurlyQuote]s review \
the basics of spherical coordinates. Recall that the correspondence between \
Cartesian and spherical coordinates is given by\
\>", "Text",
 CellChangeTimes->{{3.8101149752034006`*^9, 
  3.810115022757722*^9}},ExpressionUUID->"8ee7751c-7e93-4861-a3f9-\
7816006d0849"],

Cell[BoxData[
 RowBox[{
  StyleBox["x",
   FontSlant->"Italic"], "=", 
  RowBox[{
   StyleBox["r",
    FontSlant->"Italic"], " ", "sin", 
   RowBox[{"(", "\[Theta]", ")"}], "cos", 
   RowBox[{"(", "\[Phi]", ")"}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8101150577108593`*^9, 
  3.8101150758002863`*^9}},ExpressionUUID->"f59dbfb8-de75-41a0-bd6a-\
3767bc433c02"],

Cell[BoxData[
 RowBox[{
  StyleBox["y",
   FontSlant->"Italic"], "=", 
  RowBox[{
   StyleBox["r",
    FontSlant->"Italic"], " ", "sin", 
   RowBox[{"(", "\[Theta]", ")"}], "sin", 
   RowBox[{"(", "\[Phi]", ")"}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8101150577108593`*^9, 
  3.8101150892132025`*^9}},ExpressionUUID->"93e5830a-1401-42dd-8934-\
500dbbfd0b72"],

Cell[BoxData[
 RowBox[{
  StyleBox["z",
   FontSlant->"Italic"], "=", 
  RowBox[{
   StyleBox["r",
    FontSlant->"Italic"], " ", "cos", 
   RowBox[{"(", "\[Theta]", ")"}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8101150577108593`*^9, 
  3.810115104810896*^9}},ExpressionUUID->"0da84eea-ff4d-4723-b7c6-\
03a15601c17c"],

Cell["These relationships are illustrated in Figure 5.7", "Text",
 CellChangeTimes->{{3.8101151113191757`*^9, 3.810115129202072*^9}, {
  3.91580103140858*^9, 
  3.91580103309419*^9}},ExpressionUUID->"2b8de9b0-6eb5-4edd-a04f-\
795e2cdef924"],

