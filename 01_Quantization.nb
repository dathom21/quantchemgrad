Cell[TextData[{
 StyleBox["Figure 1.9",
  FontWeight->"Bold"],
 ". Plot of the function cos(",
 StyleBox["x",
  FontSlant->"Italic"],
 "), emphasizing that this function has a wavelength (or period) of 2\[Pi]."
}], "Affiliation",
