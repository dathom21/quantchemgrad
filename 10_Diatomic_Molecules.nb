Cell[TextData[{
 "Because the 1",
 StyleBox["s",
  FontSlant->"Italic"],
 " orbital of both nuclei is real, we have that ",
 Cell[BoxData[
  RowBox[{
   StyleBox["S",
    FontSlant->"Italic"], "=", 
   SuperscriptBox[
    StyleBox["S",
     FontSlant->"Italic"], "\[Star]"]}]],
  CellChangeTimes->{{3.813228038288596*^9, 3.813228093385758*^9}, {
   3.8132336120692124`*^9, 3.8132336334997315`*^9}, {3.8132336788534994`*^9, 
