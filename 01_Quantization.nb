Cell[TextData[{
 "Now we can write the complex Fourier series (for \[Minus]",
 StyleBox["L/2 ",
  FontSlant->"Italic"],
 " to ",
 StyleBox["L/2",
  FontSlant->"Italic"],
 ") as"
}], "Text",
 CellChangeTimes->{
  3.933951846535784*^9},ExpressionUUID->"f686628d-3006-1c4c-8e26-\
6421d76fcedf"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   StyleBox["f",
    FontSlant->"Italic"], 
   RowBox[{"(", 
    StyleBox["x",
     FontSlant->"Italic"], ")"}]}], "=", " ", 
  RowBox[{
   UnderoverscriptBox["\[Sum]", 
    RowBox[{
     StyleBox["n",
      FontSlant->"Italic"], "=", 
     RowBox[{"\[Minus]", "\[Infinity]"}]}], "\[Infinity]"], 
   RowBox[{
    SubscriptBox[
     StyleBox["A",
      FontSlant->"Italic"], 
     StyleBox["n",
      FontSlant->"Italic"]], " ", 
    SuperscriptBox[
     StyleBox["\[ExponentialE]",
      FontSlant->"Italic"], 
     RowBox[{"\[ImaginaryI]", 
      FractionBox[
       RowBox[{"2", 
        StyleBox[
         RowBox[{"\[Pi]", 
          StyleBox["nx",
           FontSlant->"Italic"]}]]}], 
       StyleBox["L",
        FontSlant->"Italic"]]}]]}]}]}]], "DisplayFormulaNumbered",
