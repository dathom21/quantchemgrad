Cell[TextData[{
 StyleBox["Figure 4.4",
  FontWeight->"Bold"],
 ". Plot of the square of the eigenfunctions ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[RightBracketingBar]", 
    RowBox[{
     SubscriptBox[
      StyleBox["\[Psi]",
       FontSlant->"Plain"], 
      StyleBox["n",
       FontSlant->"Italic"]], "(", 
     StyleBox["x",
      FontSlant->"Italic"], ")"}], 
    SuperscriptBox["\[LeftBracketingBar]", "2"]}], TraditionalForm]],
  ExpressionUUID->"f7b97f33-f0ca-48b2-9617-483678f3cbcf"],
 " of the particle in a box for values of ",
 StyleBox["n",
  FontSlant->"Italic"],
 " from 1 (bottom) to 4 (top), offset by the associated energies ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["E", "n"], TraditionalForm]],ExpressionUUID->
  "433b11b3-6995-4ed9-ad35-3c750e47db5c"],
 "."
}], "Affiliation",
 CellChangeTimes->CompressedData["
1:eJxTTMoPSmViYGAQA2IQPeNH5qbXiW8cy6t7doDoiRfCxd8A6ZBDtWA6NlRg
2Ucgzeepug5EC2S27BZIAtJry/eD6DMqRj/fA+kjLKbMH4B0E3PHSv6UN44X
l04G08y2gYYPM944ShTl2YDoml0/fqlmvnFMuGTBogakC7QVOBRmv3GMCG/h
BNF7zOPdQLROl78niH72z94PRH946BwEol+n/7XyANJTvi6wBdFxBrfuZgNp
vpqpT0B0kIDKTxCt5OjyG8y3P9WQA6S/fNjfCqJPpXhV5gLpC5umVIPojjCh
RhD9yjG7DUTXWPhr7JnzxvEbv4kOiFZ6t38qiP7TtWYxiH5wKmD2/rlvHBkE
YheAaJ9PRUtA9ErmKytAtLfwFut6nbeOQg94bEA0ANJitEI=
  "],ExpressionUUID->"d51441b8-427c-4f9c-92df-673e1ca2aa7d"],

Cell[TextData[{
 "we can see that the most probable position for the lowest-energy state is \
in the middle of the box, but the higher-energy levels have multiple peaks in \
the probability distribution, most of which are not at ",
 StyleBox["x",
  FontSlant->"Italic"],
 " = (1/2)",
 StyleBox["a",
  FontSlant->"Italic"],
 "."
}], "Text",
 CellChangeTimes->{{3.80935347744683*^9, 
  3.809353531672183*^9}},ExpressionUUID->"98e2fa3a-a7ce-4b0f-b2c4-\
13ef3e304d41"]
}, Open  ]],

Cell[CellGroupData[{

Cell["\<\
We Obtain the Average Value of an Observable through an Expectation Value\
\>", "Subsection",
 CellChangeTimes->{{3.8087516614037423`*^9, 3.808751721735821*^9}, {
  3.8093517122604313`*^9, 
  3.809351715967519*^9}},ExpressionUUID->"44255ce9-b522-4475-b20f-\
837d6ba9a6da"],

Cell[TextData[{
 "Recall that the fourth postulate tells us that the average value of the \
observable corresponding to a given quantum mechanical operator ",
 Cell[BoxData[
  FormBox[
   OverscriptBox["A", "^"], TraditionalForm]],ExpressionUUID->
  "ad1551b7-10d1-4eea-bcfe-485355bfb0ce"],
 " is given by"
}], "Text",
 CellChangeTimes->{{3.809353547809531*^9, 
  3.8093535985568104`*^9}},ExpressionUUID->"de8435c7-3a32-4963-97ec-\
62ed7e6669fa"],

Cell[BoxData[
 RowBox[{
  RowBox[{"<", 
   StyleBox["A",
    FontSlant->"Italic"], ">"}], " ", "=", 
  RowBox[{
   SubsuperscriptBox["\[Integral]", 
    RowBox[{"-", "\[Infinity]"}], "\[Infinity]"], 
   RowBox[{
    SuperscriptBox["\[Psi]", "\[Star]"], 
    RowBox[{"(", 
     StyleBox["x",
      FontSlant->"Italic"], ")"}], 
    OverscriptBox[
     StyleBox["A",
      FontSlant->"Italic"], "^"], "\[Psi]", 
    RowBox[{"(", 
     StyleBox["x",
      FontSlant->"Italic"], 
     StyleBox[")",
      FontSlant->"Italic"]}], 
    StyleBox["dx",
     FontSlant->"Italic"]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8079664251944246`*^9, 3.8079664343142004`*^9}, {
   3.8079689400739555`*^9, 3.8079689680029573`*^9}, {3.807970315263204*^9, 
   3.8079703215316095`*^9}, {3.807970415909548*^9, 3.807970437015459*^9}, {
   3.8079705221296997`*^9, 3.8079705895237727`*^9}, {3.8079740353167067`*^9, 
   3.807974091342613*^9}, {3.8079792460635405`*^9, 3.807979253256398*^9}, {
   3.808056638763859*^9, 3.808056681287653*^9}, {3.8080569738200073`*^9, 
   3.8080570333706875`*^9}, {3.8080573070857663`*^9, 3.808057330443427*^9}, {
   3.8080623653640356`*^9, 3.808062383919905*^9}, {3.8080627064338617`*^9, 
   3.8080627936668353`*^9}, {3.8093536882702403`*^9, 3.8093537215753336`*^9}, 
   3.8408029092163324`*^9},ExpressionUUID->"36bb32bb-ce14-4ec6-9290-\
adac6dfe4189"],

Cell[TextData[{
 "let\[CloseCurlyQuote]s try calculating the average value of ",
 StyleBox["x",
  FontSlant->"Italic"],
 ", <",
 StyleBox["x",
  FontSlant->"Italic"],
 ">"
}], "Text",
 CellChangeTimes->{{3.809353633477353*^9, 
  3.8093536519662485`*^9}},ExpressionUUID->"922e6fdf-4400-4af9-abb7-\
4c8176bfd937"],

