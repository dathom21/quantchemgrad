      FontSlant->"Italic"], 
     StyleBox[")",
      FontSlant->"Italic"]}]}]}]}], "\[IndentingNewLine]", 
 RowBox[{"\t\t\t\t\t\t     ", 
  RowBox[{"=", 
   RowBox[{
    RowBox[{
     SubscriptBox[
      StyleBox["E",
       FontSlant->"Italic"], 
      StyleBox["N",
       FontSlant->"Italic"]], 
     SubscriptBox["\[Psi]", 
      StyleBox["N",
       FontSlant->"Italic"]], 
     RowBox[{"(", 
      StyleBox["R",
       FontWeight->"Bold",
       FontSlant->"Italic"], 
      StyleBox[")",
       FontSlant->"Italic"]}], 
     SubscriptBox["\[Psi]", 
      StyleBox["e",
       FontSlant->"Italic"]], 
     RowBox[{"(", 
      StyleBox["r",
       FontWeight->"Bold",
       FontSlant->"Italic"], 
      StyleBox[")",
       FontSlant->"Italic"]}]}], "+", 
    RowBox[{
     SubscriptBox[
      StyleBox["E",
       FontSlant->"Italic"], 
      StyleBox["e",
       FontSlant->"Italic"]], 
     SubscriptBox["\[Psi]", 
      StyleBox["N",
       FontSlant->"Italic"]], 
     RowBox[{"(", 
      StyleBox["R",
       FontWeight->"Bold",
       FontSlant->"Italic"], 
      StyleBox[")",
       FontSlant->"Italic"]}], 
