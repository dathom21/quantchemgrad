Cell[CellGroupData[{

Cell["Solving the Schr\[ODoubleDot]dinger Equation of the Hydrogen Atom", \
"Section",
 CellChangeTimes->{{3.810480382610484*^9, 
  3.810480408363947*^9}},ExpressionUUID->"dc46bf21-76e8-4067-92f5-\
93d9979e4a24"],

Cell[CellGroupData[{

Cell["Setting up the TISE", "Subsection",
 CellChangeTimes->{{3.8104809761252313`*^9, 
  3.8104809817782774`*^9}},ExpressionUUID->"e573fe79-95e9-4fb1-8f96-\
744dd7819c9f"],

Cell["\<\
Using equations (6) and (7) above, we can write the time-independent Schr\
\[ODoubleDot]dinger equation for the hydrogen atom as\
\>", "Text",
 CellChangeTimes->{{3.810480444613635*^9, 
  3.8104804678708563`*^9}},ExpressionUUID->"e7b3c55b-e55f-4070-b942-\
76a712ff4371"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"[", 
    RowBox[{
     RowBox[{"-", 
      RowBox[{
       FractionBox[
        SuperscriptBox["\[HBar]", "2"], 
        RowBox[{"2", 
         StyleBox[
          SubscriptBox["m", "e"],
          FontSlant->"Italic"]}]], "[", 
       RowBox[{
        RowBox[{
         FractionBox["1", 
          SuperscriptBox[
           StyleBox["r",
            FontSlant->"Italic"], "2"]], 
         RowBox[{
          FractionBox["\[PartialD]", 
           RowBox[{"\[PartialD]", 
            StyleBox["r",
             FontSlant->"Italic"]}]], 
          RowBox[{"(", 
           RowBox[{
            SuperscriptBox[
             StyleBox["r",
              FontSlant->"Italic"], "2"], 
            FractionBox["\[PartialD]", 
             RowBox[{"\[PartialD]", 
              StyleBox["r",
               FontSlant->"Italic"]}]]}], ")"}]}]}], "+", 
        RowBox[{
         FractionBox["1", 
          RowBox[{
           SuperscriptBox[
            StyleBox["r",
             FontSlant->"Italic"], "2"], "sin", 
           RowBox[{"(", "\[Theta]", ")"}]}]], 
         RowBox[{
          FractionBox["\[PartialD]", 
           RowBox[{"\[PartialD]", "\[Theta]"}]], 
          RowBox[{"(", 
           RowBox[{"sin", 
            RowBox[{"(", "\[Theta]", ")"}], 
            FractionBox["\[PartialD]", 
             RowBox[{"\[PartialD]", "\[Theta]"}]]}], ")"}]}]}], "+", 
        RowBox[{
         FractionBox["1", 
          RowBox[{
           SuperscriptBox[
            StyleBox["r",
             FontSlant->"Italic"], "2"], 
           SuperscriptBox["sin", "2"], 
           RowBox[{"(", "\[Theta]", ")"}]}]], 
         RowBox[{"(", 
          FractionBox[
           SuperscriptBox["\[PartialD]", "2"], 
           RowBox[{"\[PartialD]", 
            SuperscriptBox["\[Phi]", "2"]}]], ")"}]}]}], "]"}]}], "-", 
     FractionBox[
      SuperscriptBox[
       StyleBox["e",
        FontSlant->"Italic"], "2"], 
      RowBox[{"4", 
       SubscriptBox["\[Pi]\[Epsilon]", "0"], 
       StyleBox["r",
        FontSlant->"Italic"]}]]}], "]"}], "\[Psi]", 
   RowBox[{"(", 
    RowBox[{
     StyleBox["r",
      FontSlant->"Italic"], ",", "\[Theta]", ",", "\[Phi]"}], ")"}]}], "=", 
  RowBox[{
   StyleBox[
    RowBox[{
     StyleBox["E",
      FontSlant->"Italic"], "\[Psi]"}]], 
   RowBox[{"(", 
    RowBox[{
     StyleBox["r",
      FontSlant->"Italic"], ",", "\[Theta]", ",", "\[Phi]"}], 
    ")"}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.810112811439228*^9, 3.8101128248442793`*^9}, {
  3.810479494926491*^9, 3.8104795038498344`*^9}, {3.810479572543576*^9, 
  3.8104796147383184`*^9}, {3.8104802055659895`*^9, 3.8104802433915305`*^9}, {
  3.8104802785189395`*^9, 3.8104802814214115`*^9}, {3.810480477782269*^9, 
  3.8104805471507206`*^9}},ExpressionUUID->"6b5ff169-0ba1-4826-9735-\
09d2f51f0690"],

Cell["\<\
Using the shorthand \[Psi] for \[Psi](r,\[Theta],\[Phi]) and distributing, we \
write\
\>", "Text",
 CellChangeTimes->{{3.8104805624816446`*^9, 
  3.810480583129487*^9}},ExpressionUUID->"5555595e-62a5-4f81-bbd5-\
fe6dadb52d30"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"-", 
    RowBox[{
     FractionBox[
      SuperscriptBox["\[HBar]", "2"], 
      RowBox[{"2", 
       StyleBox[
        SubscriptBox["m", "e"],
        FontSlant->"Italic"]}]], "[", 
     RowBox[{
      RowBox[{
       FractionBox["1", 
        SuperscriptBox[
         StyleBox["r",
          FontSlant->"Italic"], "2"]], 
       RowBox[{
        FractionBox["\[PartialD]", 
         RowBox[{"\[PartialD]", 
          StyleBox["r",
           FontSlant->"Italic"]}]], 
        RowBox[{"(", 
         RowBox[{
          SuperscriptBox[
           StyleBox["r",
            FontSlant->"Italic"], "2"], 
          FractionBox[
           RowBox[{"\[PartialD]", "\[Psi]"}], 
           RowBox[{"\[PartialD]", 
            StyleBox["r",
             FontSlant->"Italic"]}]]}], ")"}]}]}], "+", 
      RowBox[{
       FractionBox["1", 
        RowBox[{
         SuperscriptBox[
          StyleBox["r",
           FontSlant->"Italic"], "2"], "sin", 
         RowBox[{"(", "\[Theta]", ")"}]}]], 
       RowBox[{
        FractionBox["\[PartialD]", 
         RowBox[{"\[PartialD]", "\[Theta]"}]], 
        RowBox[{"(", 
         RowBox[{"sin", 
          RowBox[{"(", "\[Theta]", ")"}], 
          FractionBox[
           RowBox[{"\[PartialD]", "\[Psi]"}], 
           RowBox[{"\[PartialD]", "\[Theta]"}]]}], ")"}]}]}], "+", 
      RowBox[{
       FractionBox["1", 
        RowBox[{
         SuperscriptBox[
          StyleBox["r",
           FontSlant->"Italic"], "2"], 
         SuperscriptBox["sin", "2"], 
         RowBox[{"(", "\[Theta]", ")"}]}]], 
       RowBox[{"(", 
        FractionBox[
         RowBox[{
          SuperscriptBox["\[PartialD]", "2"], "\[Psi]"}], 
         RowBox[{"\[PartialD]", 
          SuperscriptBox["\[Phi]", "2"]}]], ")"}]}]}], "]"}]}], "-", 
   RowBox[{
    FractionBox[
     SuperscriptBox[
      StyleBox["e",
       FontSlant->"Italic"], "2"], 
     RowBox[{"4", 
      SubscriptBox["\[Pi]\[Epsilon]", "0"], 
      StyleBox["r",
       FontSlant->"Italic"]}]], "\[Psi]"}]}], "=", 
  StyleBox[
   RowBox[{
    StyleBox["E",
     FontSlant->"Italic"], "\[Psi]"}]]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.810112811439228*^9, 3.8101128248442793`*^9}, {
   3.810479494926491*^9, 3.8104795038498344`*^9}, {3.810479572543576*^9, 
   3.8104796147383184`*^9}, {3.8104802055659895`*^9, 
   3.8104802433915305`*^9}, {3.8104802785189395`*^9, 
   3.8104802814214115`*^9}, {3.810480477782269*^9, 3.8104805471507206`*^9}, {
   3.8104805927965565`*^9, 3.810480633017248*^9}, 
   3.8107292052898026`*^9},ExpressionUUID->"7d412d56-d76a-4f4c-8562-\
3998b64c7b55"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Meaning of Parameters in Spherical Coordinates Space", "Subsection",
 CellChangeTimes->{{3.8104842749726477`*^9, 
  3.810484298346778*^9}},ExpressionUUID->"582fbe46-f762-4c40-88e8-\
7b5c6069fa8c"],

Cell[TextData[{
 "Equation (9) appears incredibly complex and difficult to solve, but as with \
other systems we have studied thus far, the problem can be greatly simplified \
through a separation of variables approach. Before we move ahead with the \
separation of variables, it\[CloseCurlyQuote]s useful to have a brief \
reminder of what each parameter tells us in spherical coordinates. Remember \
that the relationship between spherical coordinate parameters and ",
 StyleBox["xyz",
  FontSlant->"Italic"],
 "  coordinates is given by"
}], "Text",
 CellChangeTimes->{{3.810484301187164*^9, 3.8104843881939945`*^9}, 
   3.9170217537503557`*^9},ExpressionUUID->"85638169-9157-438f-a477-\
85598a20efb6"],

Cell[BoxData[
 RowBox[{
  StyleBox["r",
   FontSlant->"Italic"], "=", 
  SuperscriptBox[
   RowBox[{"(", 
    RowBox[{
     SuperscriptBox[
      StyleBox["x",
       FontSlant->"Italic"], "2"], "+", 
     SuperscriptBox[
      StyleBox["y",
       FontSlant->"Italic"], "2"], "+", 
     SuperscriptBox[
      StyleBox["z",
       FontSlant->"Italic"], "2"]}], ")"}], 
   RowBox[{"1", "/", "2"}]]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8101150577108593`*^9, 3.8101150758002863`*^9}, {
  3.810115342492568*^9, 
  3.8101153595690007`*^9}},ExpressionUUID->"07588312-8479-4d64-a77a-\
2e9ff4833ae2"],

Cell[BoxData[
 RowBox[{
  StyleBox[
   RowBox[{"cos", 
    RowBox[{"(", "\[Theta]", ")"}]}],
   FontSlant->"Plain"], "=", 
  FractionBox[
   StyleBox["z",
    FontSlant->"Italic"], 
   SuperscriptBox[
    RowBox[{"(", 
     RowBox[{
      SuperscriptBox[
       StyleBox["x",
        FontSlant->"Italic"], "2"], "+", 
      SuperscriptBox[
       StyleBox["y",
        FontSlant->"Italic"], "2"], "+", 
      SuperscriptBox[
       StyleBox["z",
        FontSlant->"Italic"], "2"]}], ")"}], 
    RowBox[{"1", "/", "2"}]]]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8101150577108593`*^9, 3.8101150892132025`*^9}, {
  3.810115369368109*^9, 
  3.8101154018170767`*^9}},ExpressionUUID->"a9de6c35-6cea-49c4-b35c-\
4b91f8464e64"],

Cell[BoxData[
 RowBox[{
  StyleBox[" ",
   FontSlant->"Italic"], 
  RowBox[{
   RowBox[{"tan", 
    RowBox[{"(", "\[Phi]", ")"}]}], "=", 
   FractionBox[
    StyleBox["y",
     FontSlant->"Italic"], 
    StyleBox["x",
     FontSlant->"Italic"]]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8101150577108593`*^9, 3.810115104810896*^9}, {
  3.81011541510189*^9, 
  3.81011544073394*^9}},ExpressionUUID->"bf1269ad-adb6-4fcd-9549-\
c146323d91e0"],

