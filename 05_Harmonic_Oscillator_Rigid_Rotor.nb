       SuperscriptBox["x", "3"], " ", 
       SuperscriptBox["\[Alpha]", 
        RowBox[{"3", "/", "2"}]]}]}]},
    {"4", 
     RowBox[{"12", "-", 
      RowBox[{"48", " ", 
