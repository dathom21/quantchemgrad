Cell[BoxData[
 TagBox[GridBox[{
    {"\<\"\\!\\(\\*StyleBox[\\\"n\\\",FontSlant->\\\"Italic\\\"]\\)\"\>", "\<\
\"\\!\\(\\*StyleBox[SubscriptBox[\\\"H\\\", \
\\\"n\\\"],FontSlant->\\\"Italic\\\"]\\)\\!\\(\\*StyleBox[\\\" \
\\\",FontSlant->\\\"Italic\\\"]\\)\\!\\(\\*StyleBox[\\\"(\\\",FontSlant->\\\"\
Italic\\\"]\\)\\!\\(\\*SuperscriptBox[\\(\[Alpha]\\), \
\\(1/2\\)]\\)\\!\\(\\*StyleBox[\\\"x\\\",FontSlant->\\\"Italic\\\"]\\))\"\>"},
    {"0", "1"},
    {"1", 
     RowBox[{"2", " ", "x", " ", 
      SqrtBox["\[Alpha]"]}]},
    {"2", 
     RowBox[{
      RowBox[{"-", "2"}], "+", 
      RowBox[{"4", " ", 
       SuperscriptBox["x", "2"], " ", "\[Alpha]"}]}]},
    {"3", 
     RowBox[{
      RowBox[{
       RowBox[{"-", "12"}], " ", "x", " ", 
       SqrtBox["\[Alpha]"]}], "+", 
