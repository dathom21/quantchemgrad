       Hold[$CellContext`tmax$$], 0, "time in second"}, 0, 1.184, 0.001}, {{
       Hold[$CellContext`F$$], False, "show forces"}, {False, True}}, {{
       Hold[$CellContext`R$$], False, 
       "resultant \!\(\*OverscriptBox[\(R\), \(\[RightArrow]\)]\)"}, {
      False, True}}, {{
       Hold[$CellContext`comp$$], False, "normal and tangential"}, {
      False, True}}, {{
       Hold[$CellContext`m$$], 0.05, "mass m kg"}, 0.02, 0.05, 0.001}}, 
    Typeset`size$$ = {550., {216.84743637626528`, 223.15256362373478`}}, 
    Typeset`update$$ = 0, Typeset`initDone$$, Typeset`skipInitDone$$ = 
