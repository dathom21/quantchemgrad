Cell[CellGroupData[{

Cell["The de Broglie wavelength and the Fourier transform", "Section",
 CellChangeTimes->{{3.8074599898355827`*^9, 3.8074600027792964`*^9}, {
  3.8076188426710405`*^9, 
  3.8076188507276354`*^9}},ExpressionUUID->"421ea62d-2903-4607-99af-\
28dcfadf419f"],

Cell[CellGroupData[{

Cell["The Fourier series - a brief introduction", "Subsection",
 CellChangeTimes->{{3.9339350548257103`*^9, 
  3.933935064049259*^9}},ExpressionUUID->"232f1d9d-9be3-fc4c-9b3c-\
7b14745b4b09"],

Cell[TextData[{
 "Let\[CloseCurlyQuote]s say we have a function that exists in the interval \
from \[Minus]",
 StyleBox["L",
  FontSlant->"Italic"],
 " to ",
 StyleBox["L",
  FontSlant->"Italic"],
 " (these can be any number). Perhaps we don\[CloseCurlyQuote]t know the form \
of this function, and we want to approximate using some functions that we do \
know. How could we do that? "
}], "Text",
 CellChangeTimes->{
  3.9339515511836224`*^9},ExpressionUUID->"2e19c8bf-20cc-2546-af2b-\
731cdabc93ab"],

Cell[TextData[{
 "We could think of a set of functions, which we will call our ",
 StyleBox["basis set",
  FontSlant->"Italic"],
 ", that we could add up to get what we want."
}], "Item",
 CellChangeTimes->{
  3.9339515819043655`*^9},ExpressionUUID->"79907794-20bd-404a-a5b0-\
3bfff8b43ef8"],

Cell["\<\
They would need to be \[OpenCurlyDoubleQuote]nice\[CloseCurlyDoubleQuote] \
functions, meaning that they don\[CloseCurlyQuote]t have any \
\[OpenCurlyDoubleQuote]jumps\[CloseCurlyDoubleQuote] or go to infinity\
\>", "Item",
 CellChangeTimes->{
  3.933951592309561*^9},ExpressionUUID->"5f5a56ca-a0ad-ad44-b0be-\
34d8d60c581d"],

Cell["\<\
Fortunately for us, someone already figured out a set of functions that \
satisfy these requirements. They are the sin() and cos() functions (along \
with a constant, flat line).
Specifically, we are going to use functions of the form\
\>", "Text",
 CellChangeTimes->{{3.933951597591831*^9, 
  3.9339516041100864`*^9}},ExpressionUUID->"0b956d43-553b-9749-9a2a-\
5fc746c7f10c"],

Cell[BoxData[
 RowBox[{"sin", 
  RowBox[{"(", 
   FractionBox[
    RowBox[{"2", 
     StyleBox[
      RowBox[{"\[Pi]", 
       StyleBox["nx",
        FontSlant->"Italic"]}]]}], 
    StyleBox["L",
     FontSlant->"Italic"]], ")"}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.807460153662324*^9, 3.807460198691662*^9}, {
  3.8075422968631506`*^9, 3.807542298906891*^9}},
 FontFamily->"Consolas",
 FontWeight->"Normal",ExpressionUUID->"7e9847b6-1ddc-d84e-96be-4c22047c5249"],

Cell["and", "Text",
 CellChangeTimes->{
  3.933951638848604*^9},ExpressionUUID->"d6bf5f1c-fa2e-4643-a3eb-\
117beb26ea3f"],

Cell[BoxData[
 RowBox[{"cos", 
  RowBox[{"(", 
   FractionBox[
    RowBox[{"2", 
     StyleBox[
      RowBox[{"\[Pi]", 
       StyleBox["nx",
        FontSlant->"Italic"]}]]}], 
    StyleBox["L",
     FontSlant->"Italic"]], ")"}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8074602856081*^9, 3.8074602885025015`*^9}, 
   3.8075423008508444`*^9},
 FontFamily->"Consolas",
 FontWeight->"Normal",ExpressionUUID->"64a9ad18-f01c-6e40-b35d-0511f847ba8c"],

Cell["\<\
These functions have maxima and minima that are offset from one another, \
giving us the chance to add them up to form a desired function. We can write \
this out as\
\>", "Text",
 CellChangeTimes->{{3.9339516914784565`*^9, 
  3.9339516984009094`*^9}},ExpressionUUID->"4eb92a92-986b-814d-87ee-\
de1172504bce"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   StyleBox["f",
    FontSlant->"Italic"], 
   RowBox[{"(", 
    StyleBox["x",
     FontSlant->"Italic"], ")"}]}], "=", " ", 
  RowBox[{
   RowBox[{
    FractionBox["1", "2"], 
    SubscriptBox[
     StyleBox["a",
      FontSlant->"Italic"], "0"]}], "+", 
   RowBox[{
    UnderoverscriptBox["\[Sum]", 
     RowBox[{
      StyleBox["n",
       FontSlant->"Italic"], "=", "1"}], "\[Infinity]"], 
    RowBox[{
     SubscriptBox[
      StyleBox["a",
       FontSlant->"Italic"], 
      StyleBox["n",
       FontSlant->"Italic"]], "cos", 
     RowBox[{"(", 
      FractionBox[
       RowBox[{"2", 
        StyleBox[
         RowBox[{"\[Pi]", 
          StyleBox["nx",
           FontSlant->"Italic"]}]]}], 
       StyleBox["L",
        FontSlant->"Italic"]], ")"}]}]}], "+", 
   RowBox[{
    UnderoverscriptBox["\[Sum]", 
     RowBox[{
      StyleBox["n",
       FontSlant->"Italic"], "=", "1"}], "\[Infinity]"], 
    RowBox[{
     SubscriptBox[
      StyleBox["b",
       FontSlant->"Italic"], 
      StyleBox["n",
       FontSlant->"Italic"]], "sin", 
     RowBox[{"(", 
      FractionBox[
       RowBox[{"2", 
        StyleBox[
         RowBox[{"\[Pi]", 
          StyleBox["nx",
           FontSlant->"Italic"]}]]}], 
       StyleBox["L",
        FontSlant->"Italic"]], ")"}]}]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.807462125857564*^9, 3.807462181913151*^9}, {
  3.807462363860742*^9, 3.8074623671318383`*^9}, {3.8074624219026136`*^9, 
  3.8074626130753183`*^9}, {3.8075422843284473`*^9, 3.8075422874406004`*^9}},
 FontFamily->"Consolas",
 FontWeight->"Normal",ExpressionUUID->"563b97bb-0af1-4348-93a3-1f0996118a3f"],

Cell[TextData[{
 "where ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["a", "0"], TraditionalForm]],ExpressionUUID->
  "5527a424-f887-c344-8048-625d8a723ae9"],
 ", ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["a", "n"], TraditionalForm]],ExpressionUUID->
  "18690d13-47cd-7e46-a3d3-cba065449cba"],
 ", and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["b", "n"], TraditionalForm]],ExpressionUUID->
  "e942d27c-0a7f-834b-b605-c35f9e2cf5dd"],
 " are constants. This is in fact the Fourier series. We \
won\[CloseCurlyQuote]t go into all of the math, but we even know the values \
of these constants! In the demonstration shown in Figure 1.8.2, you can see \
how the goodness of the approximation depends on the number of basis \
functions ",
 StyleBox["n",
  FontSlant->"Italic"],
 " for some typical functions."
}], "Text",
 CellChangeTimes->{
  3.93395174946751*^9},ExpressionUUID->"2b54724b-1699-9b41-8bfb-12e1ea43aeb6"],

Cell["", "Text",
 CellChangeTimes->{{3.8074626831650753`*^9, 3.8074628906010666`*^9}, {
   3.8076093893024817`*^9, 3.807609401427311*^9}, {3.8395821836176147`*^9, 
   3.8395821853990145`*^9}, {3.933935239737118*^9, 3.9339352576535416`*^9}, 
   3.933951746362831*^9},
 FontFamily->
  "Source Serif Pro",ExpressionUUID->"8c82e536-ff19-1e44-8c66-c1744b118dd3"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Manipulate", "[", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"Plot", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"PeriodicExtension", "[", 
        RowBox[{
         RowBox[{"k", "[", 
          RowBox[{"[", "1", "]"}], "]"}], ",", "x"}], "]"}], ",", 
       RowBox[{"Evaluate", "[", 
        RowBox[{
         RowBox[{"k", "[", 
          RowBox[{"[", "2", "]"}], "]"}], "+", 
         RowBox[{"Sum", "[", 
          RowBox[{
           RowBox[{
            RowBox[{
             RowBox[{"k", "[", 
              RowBox[{"[", "3", "]"}], "]"}], " ", 
             RowBox[{"Sin", "[", 
              RowBox[{"u", " ", "x"}], "]"}]}], "+", 
            RowBox[{
             RowBox[{"k", "[", 
              RowBox[{"[", "4", "]"}], "]"}], " ", 
             RowBox[{"Cos", "[", 
              RowBox[{"u", " ", "x"}], "]"}]}]}], ",", 
           RowBox[{"{", 
            RowBox[{"u", ",", "1", ",", "m"}], "}"}]}], "]"}]}], "]"}]}], 
      "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", 
       RowBox[{"-", "r"}], ",", "r"}], "}"}], ",", 
     RowBox[{"Axes", "\[Rule]", 
      RowBox[{"{", 
       RowBox[{"True", ",", "True"}], "}"}]}], ",", " ", 
     RowBox[{"PlotStyle", "\[Rule]", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"Thickness", "[", "0.003", "]"}], ",", "Black"}], "}"}], 
        ",", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"Thickness", "[", "0.003", "]"}], ",", "Blue"}], "}"}]}], 
       "}"}]}], " ", ",", "\[IndentingNewLine]", "              ", 
     RowBox[{"Filling", "\[Rule]", 
      RowBox[{"{", 
       RowBox[{"1", "\[Rule]", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"{", "2", "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"Yellow", ",", "Orange"}], "}"}]}], "}"}]}], "}"}]}], ",", 
     RowBox[{"ImageSize", "\[Rule]", 
      RowBox[{"{", 
       RowBox[{"500", ",", "400"}], "}"}]}], ",", 
     RowBox[{"ImagePadding", "\[Rule]", "30"}]}], "]"}], ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"k", ",", 
       RowBox[{"{", 
        RowBox[{"Sign", ",", "0", ",", 
         RowBox[{
          RowBox[{"1", "/", 
           RowBox[{"(", 
            RowBox[{"Pi", "*", "u"}], ")"}]}], "*", 
          RowBox[{"(", 
           RowBox[{"1", "-", 
            RowBox[{"2", 
             RowBox[{"Cos", "[", 
              RowBox[{"u", "*", "Pi"}], "]"}]}], "+", "1"}], ")"}]}], ",", 
         "0"}], "}"}], ",", "\"\<function\>\""}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{"{", 
         RowBox[{"Sign", ",", "0", ",", 
          RowBox[{
           RowBox[{"1", "/", 
            RowBox[{"(", 
             RowBox[{"Pi", "*", "u"}], ")"}]}], "*", 
           RowBox[{"(", 
            RowBox[{"2", "-", 
             RowBox[{"2", 
              RowBox[{"Cos", "[", 
               RowBox[{"u", "*", "Pi"}], "]"}]}]}], ")"}]}], ",", "0"}], 
         "}"}], "\[Rule]", "\"\<step\>\""}], ",", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"#", "&"}], ",", "0", ",", 
          RowBox[{"2", 
           RowBox[{
            RowBox[{
             RowBox[{"(", 
              RowBox[{"-", "1"}], ")"}], "^", 
             RowBox[{"(", 
              RowBox[{"u", "+", "1"}], ")"}]}], "/", "u"}]}], ",", "0"}], 
         "}"}], "\[Rule]", "\"\<sawtooth\>\""}], ",", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{
           RowBox[{"#", "^", "2"}], "&"}], ",", 
          FractionBox[
           SuperscriptBox["\[Pi]", "2"], "3"], ",", "0", ",", 
          FractionBox[
           RowBox[{"4", " ", 
            SuperscriptBox[
             RowBox[{"(", 
              RowBox[{"-", "1"}], ")"}], "u"]}], 
           SuperscriptBox["u", "2"]]}], "}"}], "\[Rule]", 
        "\"\<parabola\>\""}], ",", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{"(", 
             RowBox[{"#", "-", "Pi"}], " ", ")"}], 
            RowBox[{"(", 
             RowBox[{"#", "+", "Pi"}], ")"}], 
            RowBox[{"(", 
             RowBox[{"#", "-", "1"}], ")"}]}], "&"}], ",", 
          FractionBox[
           RowBox[{"2", " ", 
            SuperscriptBox["\[Pi]", "2"]}], "3"], ",", 
          FractionBox[
           RowBox[{"12", " ", 
            SuperscriptBox[
             RowBox[{"(", 
              RowBox[{"-", "1"}], ")"}], "u"]}], 
           SuperscriptBox["u", "3"]], ",", 
          RowBox[{"-", 
           FractionBox[
            RowBox[{" ", 
             RowBox[{"4", 
              SuperscriptBox[
               RowBox[{"(", 
                RowBox[{"-", "1"}], ")"}], "u"]}]}], 
            SuperscriptBox["u", "2"]]}]}], "}"}], "\[Rule]", 
        "\"\<cubic\>\""}], ",", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{
           RowBox[{"(", 
            RowBox[{
             RowBox[{"Sin", "[", "#", "]"}], 
             RowBox[{"UnitStep", "[", "#", "]"}]}], ")"}], "&"}], ",", 
          RowBox[{"1", "/", "Pi"}], ",", 
          RowBox[{
           RowBox[{"KroneckerDelta", "[", 
            RowBox[{"u", ",", "1"}], "]"}], "/", "2"}], ",", 
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{"u", "\[Equal]", "1"}], ",", "0", ",", 
            RowBox[{"(", 
             RowBox[{"-", 
              FractionBox[
               RowBox[{"1", "+", 
                SuperscriptBox[
                 RowBox[{"(", 
                  RowBox[{"-", "1"}], ")"}], "u"]}], 
               RowBox[{
                RowBox[{"(", 
                 RowBox[{
                  RowBox[{"-", "1"}], "+", 
                  SuperscriptBox["u", "2"]}], ")"}], " ", "\[Pi]"}]]}], 
             ")"}]}], "]"}]}], "}"}], "\[Rule]", 
        "\"\<half-wave rectifier\>\""}]}], "}"}]}], "}"}], ",", 
   "\[IndentingNewLine]", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"m", ",", "3", ",", "\"\<number of terms\>\""}], "}"}], ",", 
     "1", ",", "50", ",", "1", ",", 
     RowBox[{"Appearance", "\[Rule]", "\"\<Labeled\>\""}]}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"r", ",", "Pi", ",", "\"\<x range\>\""}], "}"}], ",", "Pi", ",", 
     RowBox[{"5", "*", "Pi"}], ",", "Pi", ",", 
     RowBox[{"Appearance", "\[Rule]", "\"\<Labeled\>\""}]}], "}"}], ",", 
   RowBox[{"Initialization", "\[RuleDelayed]", 
    RowBox[{"{", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"PeriodicExtension", "[", 
        RowBox[{"g_", ",", "x_"}], "]"}], ":=", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"Abs", "[", "x", "]"}], "<", "Pi"}], ",", 
         RowBox[{"g", "[", "x", "]"}], ",", 
         RowBox[{"PeriodicExtension", "[", 
          RowBox[{"g", ",", 
           RowBox[{"x", "-", 
            RowBox[{"2", 
             RowBox[{"Sign", "[", "x", "]"}], "Pi"}]}]}], "]"}]}], "]"}]}], 
      ")"}], "}"}]}]}], "]"}]], "Input",
 CellLabel->"In[3]:=",ExpressionUUID->"7bf1f026-9e0e-0e47-94c4-4ed86cfda012"],

Cell[BoxData[
 TagBox[
  StyleBox[
   DynamicModuleBox[{$CellContext`k$$ = {
    Sign, 0, Pi^(-1) $CellContext`u^(-1) (2 - 2 Cos[Pi $CellContext`u]), 
     0}, $CellContext`m$$ = 3, $CellContext`r$$ = Pi, Typeset`show$$ = True, 
    Typeset`bookmarkList$$ = {}, Typeset`bookmarkMode$$ = "Menu", 
    Typeset`animator$$, Typeset`animvar$$ = 1, Typeset`name$$ = 
    "\"untitled\"", Typeset`specs$$ = {{{
       Hold[$CellContext`k$$], {
       Sign, 0, Pi^(-1) $CellContext`u^(-1) (2 - 2 Cos[Pi $CellContext`u]), 
        0}, "function"}, {{
        Sign, 0, Pi^(-1) $CellContext`u^(-1) (2 - 2 Cos[Pi $CellContext`u]), 
         0} -> "step", {#& , 0, 2 (-1)^(1 + $CellContext`u)/$CellContext`u, 
         0} -> "sawtooth", {#^2& , Rational[1, 3] Pi^2, 0, 
         4 (-1)^$CellContext`u $CellContext`u^(-2)} -> 
       "parabola", {(# - Pi) (# + Pi) (# - 1)& , Rational[2, 3] Pi^2, 
         12 (-1)^$CellContext`u $CellContext`u^(-3), (-4) (-1)^$CellContext`u \
$CellContext`u^(-2)} -> 
       "cubic", {
        Sin[#] UnitStep[#]& , Pi^(-1), Rational[1, 2] 
         KroneckerDelta[1, $CellContext`u], 
         If[$CellContext`u == 1, 
          0, -((1 + (-1)^$CellContext`u)/((-1 + $CellContext`u^2) Pi))]} -> 
       "half-wave rectifier"}, ControlType -> SetterBar}, {{
       Hold[$CellContext`m$$], 3, "number of terms"}, 1, 50, 1, ControlType -> 
      Manipulator}, {{
       Hold[$CellContext`r$$], Pi, "x range"}, Pi, 5 Pi, Pi, ControlType -> 
      Manipulator}}, Typeset`size$$ = {
    500., {197.1340331430547, 202.8659668569453}}, Typeset`update$$ = 0, 
    Typeset`initDone$$, Typeset`skipInitDone$$ = False, 
    Typeset`keyframeActionsQ$$ = False, Typeset`keyframeList$$ = {}}, 
    DynamicBox[Manipulate`ManipulateBoxes[
     1, StandardForm, 
      "Variables" :> {$CellContext`k$$ = {
         Sign, 0, Pi^(-1) $CellContext`u^(-1) (2 - 2 Cos[Pi $CellContext`u]), 
          0}, $CellContext`m$$ = 3, $CellContext`r$$ = Pi}, 
      "ControllerVariables" :> {}, 
      "OtherVariables" :> {
       Typeset`show$$, Typeset`bookmarkList$$, Typeset`bookmarkMode$$, 
        Typeset`animator$$, Typeset`animvar$$, Typeset`name$$, 
        Typeset`specs$$, Typeset`size$$, Typeset`update$$, Typeset`initDone$$,
         Typeset`skipInitDone$$, Typeset`keyframeActionsQ$$, 
        Typeset`keyframeList$$}, "Body" :> Plot[{
         $CellContext`PeriodicExtension[
          Part[$CellContext`k$$, 1], $CellContext`x], 
         Evaluate[
         Part[$CellContext`k$$, 2] + 
          Sum[Part[$CellContext`k$$, 3] Sin[$CellContext`u $CellContext`x] + 
            Part[$CellContext`k$$, 4] 
             Cos[$CellContext`u $CellContext`x], {$CellContext`u, 
             1, $CellContext`m$$}]]}, {$CellContext`x, -$CellContext`r$$, \
$CellContext`r$$}, Axes -> {True, True}, PlotStyle -> {{
           Thickness[0.003], Black}, {
           Thickness[0.003], Blue}}, 
        Filling -> {1 -> {{2}, {Yellow, Orange}}}, ImageSize -> {500, 400}, 
        ImagePadding -> 30], 
      "Specifications" :> {{{$CellContext`k$$, {
          Sign, 0, Pi^(-1) $CellContext`u^(-1) (2 - 2 Cos[Pi $CellContext`u]),
            0}, "function"}, {{
           Sign, 0, 
            Pi^(-1) $CellContext`u^(-1) (2 - 2 Cos[Pi $CellContext`u]), 0} -> 
          "step", {#& , 0, 2 (-1)^(1 + $CellContext`u)/$CellContext`u, 0} -> 
          "sawtooth", {#^2& , Rational[1, 3] Pi^2, 0, 
            4 (-1)^$CellContext`u $CellContext`u^(-2)} -> 
          "parabola", {(# - Pi) (# + Pi) (# - 1)& , Rational[2, 3] Pi^2, 
            12 (-1)^$CellContext`u $CellContext`u^(-3), (-4) \
(-1)^$CellContext`u $CellContext`u^(-2)} -> 
          "cubic", {
           Sin[#] UnitStep[#]& , Pi^(-1), Rational[1, 2] 
            KroneckerDelta[1, $CellContext`u], 
            
            If[$CellContext`u == 1, 
             0, -((1 + (-1)^$CellContext`u)/((-1 + $CellContext`u^2) Pi))]} -> 
          "half-wave rectifier"}}, {{$CellContext`m$$, 3, "number of terms"}, 
         1, 50, 1, Appearance -> 
         "Labeled"}, {{$CellContext`r$$, Pi, "x range"}, Pi, 5 Pi, Pi, 
         Appearance -> "Labeled"}}, "Options" :> {}, "DefaultOptions" :> {}],
     ImageSizeCache->{
      547.0999999999999, {260.3651854868047, 266.0971192006953}},
     SingleEvaluation->True],
    Deinitialization:>None,
    DynamicModuleValues:>{},
    Initialization:>({$CellContext`PeriodicExtension[
         Pattern[$CellContext`g, 
          Blank[]], 
         Pattern[$CellContext`x, 
          Blank[]]] := If[Abs[$CellContext`x] < Pi, 
         $CellContext`g[$CellContext`x], 
         $CellContext`PeriodicExtension[$CellContext`g, $CellContext`x - 2 
          Sign[$CellContext`x] Pi]]}; Typeset`initDone$$ = True),
