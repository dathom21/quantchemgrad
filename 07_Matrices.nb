 RowBox[{
  RowBox[{
   RowBox[{"\[LeftAngleBracket]", 
    StyleBox["a",
     FontWeight->"Bold"]}], "\[RightBracketingBar]"}], "=", 
  RowBox[{"(", "\[NoBreak]", 
   RowBox[{GridBox[{
      {
       SubsuperscriptBox[
        StyleBox["a",
         FontSlant->"Italic"], "1", "\[Star]"], 
       SubsuperscriptBox[
        StyleBox["a",
         FontSlant->"Italic"], "2", "\[Star]"]}
     }], GridBox[{
      {"...", 
       SubsuperscriptBox[
        StyleBox["a",
         FontSlant->"Italic"], 
        StyleBox["n",
         FontSlant->"Italic"], "\[Star]"]}
     }]}], ")"}]}]], "DisplayFormulaNumbered",
