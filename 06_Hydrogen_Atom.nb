Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"Grid", "[", 
   RowBox[{
    RowBox[{"Prepend", "[", 
     RowBox[{
      RowBox[{"Flatten", "[", 
       RowBox[{
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"n", ",", "m", ",", 
            RowBox[{
             RowBox[{"Piecewise", "[", 
              RowBox[{
               RowBox[{"{", 
                RowBox[{"{", 
                 RowBox[{
                  RowBox[{"-", "1"}], ",", 
                  RowBox[{"m", ">", "0"}]}], "}"}], "}"}], ",", "1"}], "]"}], 
             "*", 
             RowBox[{"LegendreP", "[", 
              RowBox[{"n", ",", "m", ",", "\[Chi]"}], "]"}]}], ",", 
            RowBox[{"Simplify", "[", 
             RowBox[{
              SuperscriptBox[
               RowBox[{"(", 
                RowBox[{"-", "1"}], ")"}], "m"], "*", 
              RowBox[{"LegendreP", "[", 
               RowBox[{"n", ",", "m", ",", 
                RowBox[{"Cos", "[", "\[Theta]", "]"}]}], "]"}]}], "]"}]}], 
           "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"n", ",", "0", ",", "3"}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"m", ",", "0", ",", "n"}], "}"}]}], "]"}], ",", "1"}], 
       "]"}], ",", 
      RowBox[{"{", 
       RowBox[{
       "\"\<\!\(\*StyleBox[\"l\",FontSlant->\"Italic\"]\)\>\"", ",", 
        "\"\<\!\(\*SubscriptBox[StyleBox[\"m\",FontSlant->\"Italic\"], \
StyleBox[\"l\",FontSlant->\"Italic\"]]\)\>\"", ",", 
        "\"\<\!\(\*SubsuperscriptBox[StyleBox[\"P\",FontSlant->\"Italic\"], \
StyleBox[\"l\",FontSlant->\"Italic\"], RowBox[{\"\[LeftBracketingBar]\", \
