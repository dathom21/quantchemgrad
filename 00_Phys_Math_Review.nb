  3.8395102439081573`*^9}},ExpressionUUID->"149841e7-855e-4d70-9ccb-\
f602a652280b"],

Cell["\<\
using our sum/difference trigonometric identities, this converts to\
\>", "Text",
 CellChangeTimes->{
  3.8395100430203257`*^9, {3.8395102508330307`*^9, 3.839510251655213*^9}, {
   3.8395103958012714`*^9, 
