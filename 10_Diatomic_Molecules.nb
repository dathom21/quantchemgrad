  FormBox[
   SubscriptBox[
    StyleBox["R",
     FontWeight->"Bold"], "2"], TraditionalForm]],ExpressionUUID->
  "bcf8fcce-d8cc-4a5c-b9e8-b9ff711ca702"],
 "."
