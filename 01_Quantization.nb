    StyleBox["\[Nu]",
     FontFamily->"Source Serif Pro"]}]]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8394265239394445`*^9, 
  3.8394265369692993`*^9}},ExpressionUUID->"489ef878-25ee-45b7-a728-\
a92b6e6db588"],

Cell[TextData[{
 "where ",
 StyleBox["n",
  FontSlant->"Italic"],
 " is an integer value, ",
 StyleBox["h",
  FontSlant->"Italic"],
 " is a constant known as Planck\[CloseCurlyQuote]s constant, and \[Nu] is \
the light frequency. Planck then derived the following equation for the \
spectral radiance (known as Planck\[CloseCurlyQuote]s law) :"
}], "Text",
 CellChangeTimes->{{3.8063408651333733`*^9, 3.8063408781424675`*^9}, {
   3.806340938780123*^9, 3.806340959581731*^9}, {3.8064042436591787`*^9, 
   3.8064042470117593`*^9}, {3.8064042771623735`*^9, 
   3.8064044620453463`*^9}, {3.8064045487786055`*^9, 3.8064045552391458`*^9}, 
   3.8064045862349367`*^9, {3.8064047544184823`*^9, 3.80640478604101*^9}, {
   3.806404830865034*^9, 3.806404902267784*^9}, {3.8064049606010866`*^9, 
   3.8064050083494554`*^9}, {3.8064065993228536`*^9, 
   3.8064066000833454`*^9}, {3.8064073872539625`*^9, 
   3.8064074100849886`*^9}, {3.839426511959313*^9, 3.839426513646513*^9}, {
   3.8394265438259974`*^9, 3.8394265461843133`*^9}, 
   3.9338594113985653`*^9},ExpressionUUID->"834aad57-a94d-344b-9af2-\
0842f4a4561e"],

Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{"B", "(", 
    RowBox[{"\[Lambda]", ",", 
     StyleBox["T",
      FontSlant->"Italic"]}], ")"}], " ", "=", 
   StyleBox[" ",
    FontSize->48], 
   RowBox[{
    FractionBox[
     RowBox[{"2", 
      SuperscriptBox[
       StyleBox["hc",
        FontSlant->"Italic"], "2"], 
      StyleBox[
       RowBox[{
        StyleBox[" ",
         FontSize->34], " "}]]}], 
     SuperscriptBox["\[Lambda]", "5"]], 
    RowBox[{"(", 
     FractionBox["1", 
      RowBox[{
       SuperscriptBox["e", 
        FractionBox[
         RowBox[{"h", " ", "c"}], 
         RowBox[{"\[Lambda]", " ", 
          SubscriptBox["k", "B"], "T"}]]], "-", "1"}]], ")"}]}]}], 
  TraditionalForm]], "DisplayFormulaNumbered",
 CellChangeTimes->{
  3.839426717344816*^9, {3.839426771446299*^9, 
   3.8394267852630806`*^9}},ExpressionUUID->"c9e80e65-4383-40e9-a391-\
c5c2e64cf812"],

Cell[TextData[{
 "this equation accurately reproduced experimental data, with a value for ",
 StyleBox["h",
  FontSlant->"Italic"],
 " "
}], "Text",
 CellChangeTimes->{
  3.933859441471033*^9},ExpressionUUID->"e592477e-8802-9f4a-9782-\
99a8e2076992"],

Cell[BoxData[
 RowBox[{
  StyleBox["h",
   FontFamily->"Source Sans Pro",
   FontSlant->"Italic"], 
  StyleBox[" ",
   FontFamily->"Source Sans Pro"], 
  StyleBox["=",
   FontFamily->"Source Sans Pro"], 
  StyleBox[" ",
   FontFamily->"Source Sans Pro"], 
  RowBox[{
   StyleBox["6.626",
    FontFamily->"Source Sans Pro"], 
   StyleBox[" ",
    FontFamily->"Source Sans Pro"], "\[Times]", " ", 
   SuperscriptBox["10", 
    RowBox[{"\[Minus]", "34"}]], " ", "J", " ", 
   "s"}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.839426869082141*^9, 3.839426871417731*^9}, {
  3.8394269148305783`*^9, 3.8394269494888678`*^9}, {3.839427005837844*^9, 
  3.839427042122512*^9}},ExpressionUUID->"8673ccab-802f-4f45-9750-\
b029d3246de3"],

Cell["\<\
this value is known as Planck\[CloseCurlyQuote]s constant and will pop up \
just about everywhere. This  result was one of the first breakthroughs \
showing quantization in physical systems.\
\>", "Text",
 CellChangeTimes->{{3.8394270542447653`*^9, 
  3.8394270591417723`*^9}},ExpressionUUID->"d2ebc0a1-30a5-4c67-96c2-\
10f430240c2d"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Comparing Rayleigh-Jeans and Planck\[CloseCurlyQuote]s Law", \
"Subsection",
 CellChangeTimes->{{3.8057220598459597`*^9, 3.8057220670847826`*^9}, {
  3.8064056383430386`*^9, 
  3.8064056421450825`*^9}},ExpressionUUID->"9aa69be6-e4e5-4f41-928b-\
06e7e6636996"],

Cell["\<\
Below you can compare the Rayleigh-Jeans law prediction (red) and the Planck\
\[CloseCurlyQuote]s Law prediction (blue). Only the Planck\[CloseCurlyQuote]s \
law equation reproduces experimental data.\
\>", "Text",
 CellChangeTimes->{{3.8064056610769124`*^9, 
  3.80640570109264*^9}},ExpressionUUID->"2d75743b-7045-4b94-aaea-\
9abff6c6352c"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"\[IndentingNewLine]", 
  RowBox[{"Manipulate", "[", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"c", "=", "3*^8"}], " ", 
     RowBox[{"(*", 
      RowBox[{
       RowBox[{"speed", " ", "of", " ", "light"}], ",", " ", 
       RowBox[{"m", "/", "s"}]}], "*)"}], ";", "\[IndentingNewLine]", 
     RowBox[{"kB", "=", "1.3806*^-23"}], " ", 
     RowBox[{"(*", 
      RowBox[{
       RowBox[{"Boltzmann", " ", "constant", " ", "J", " ", "K"}], "-", "1"}],
       "*)"}], ";", "\[IndentingNewLine]", 
     RowBox[{"h", "=", "6.626*^-34"}], " ", 
     RowBox[{"(*", 
      RowBox[{
       RowBox[{
        RowBox[{"Planck", "'"}], "s", " ", "constant"}], ",", " ", 
       RowBox[{
        RowBox[{
         RowBox[{"m", "^", "2"}], " ", "kg", " ", "s"}], "-", "1"}]}], "*)"}],
      ";", "\[IndentingNewLine]", 
     RowBox[{"Plot", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"2", "*", "c", "*", "kB", "*", 
          RowBox[{"T", "/", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{"\[Lambda]", "*", "1*^-9"}], ")"}], "^", "4"}]}], "*", 
          "1*^-9", "*", "1*^-3"}], ",", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"2", "*", "h", "*", 
            RowBox[{
             RowBox[{"c", "^", "2"}], "/", 
             RowBox[{
              RowBox[{"(", 
               RowBox[{"\[Lambda]", "*", "1*^-9"}], ")"}], "^", "5"}]}]}], 
           ")"}], "*", 
          RowBox[{"1", "/", 
           RowBox[{"(", 
            RowBox[{
             RowBox[{"Exp", "[", 
              RowBox[{"h", "*", 
               RowBox[{"c", "/", 
                RowBox[{"(", 
                 RowBox[{"\[Lambda]", "*", "1*^-9", "*", "kB", "*", "T"}], 
                 ")"}]}]}], "]"}], "-", "1"}], ")"}]}], "*", "1*^-9", "*", 
          "1*^-3"}]}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"\[Lambda]", ",", "100", ",", "2500"}], "}"}], ",", 
       RowBox[{"PlotRange", "\[Rule]", 
        RowBox[{"{", 
         RowBox[{
