 RowBox[{
  StyleBox["p",
   FontSlant->"Italic"], "=", 
  RowBox[{
   SuperscriptBox[
    StyleBox["ml",
     FontSlant->"Italic"], "2"], 
   FractionBox[
    RowBox[{"\[DifferentialD]", "\[Theta]"}], 
    RowBox[{"\[DifferentialD]", 
     StyleBox["t",
      FontSlant->"Italic"]}]]}]}]], "DisplayFormulaNumbered",
