4894687bb48c"],

Cell[TextData[{
 "where ",
 StyleBox["\[Mu]",
  FontWeight->"Bold"],
 " is the dipole moment and ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["E",
    FontWeight->"Bold",
    FontSlant->"Italic"], 
   StyleBox["0",
    FontWeight->"Bold"]]],
  CellChangeTimes->{{3.815754827344803*^9, 3.8157548620713606`*^9}},
  ExpressionUUID->"e0d8cb2e-ba11-4acc-a0c7-ae625e14baaa"],
 " is the light electric field amplitude vector. Using this expression, ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["V",
    FontSlant->"Italic"], 
   StyleBox["mk",
    FontSlant->"Italic"]]],
  CellChangeTimes->CompressedData["
