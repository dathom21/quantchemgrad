Cell[TextData[{
 "Note that the probability of finding a molecule in state |",
 StyleBox["m",
  FontSlant->"Italic"],
 "\[RightAngleBracket] is proportional to the absolute square of ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["V",
    FontSlant->"Italic"], 
   StyleBox["mk",
    FontSlant->"Italic"]]],
  CellChangeTimes->{{3.8079712935412436`*^9, 3.8079714900326514`*^9}, {
    3.8080650361338077`*^9, 3.808065078586836*^9}, {3.8080651294863386`*^9, 
    3.8080651662446632`*^9}, {3.8080655103101*^9, 3.808065549470801*^9}, {
    3.8080655874181037`*^9, 3.8080655997397223`*^9}, {3.80806586302172*^9, 
    3.808065882866931*^9}, {3.8080659492793603`*^9, 3.808065953047598*^9}, {
