Cell[TextData[{
 StyleBox["Figure 10.1",
  FontWeight->"Bold"],
 ". The Morse potential (solid line) is an approximation of the true \
potential for a diatomic, found by solving for the electronic energy ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["E",
    FontSlant->"Italic"], 
   StyleBox["e",
    FontSlant->"Italic"]]],
  CellChangeTimes->{{3.81307809350165*^9, 3.8130781609264364`*^9}, 
