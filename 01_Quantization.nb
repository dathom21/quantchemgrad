            RowBox[{"\"\<f(x)\>\"", ",", "24", ",", "Italic"}], "]"}]}], 
          "}"}]}], ",", 
        RowBox[{"PlotStyle", "->", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"Thickness", "[", ".008", "]"}], ",", "Black"}], "}"}]}], 
        ",", 
        RowBox[{"PlotRange", "->", 
         RowBox[{"{", 
          RowBox[{"0", ",", "1.1"}], "}"}]}], ",", 
        RowBox[{"Ticks", "->", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{
             RowBox[{"-", "3"}], ",", "0", ",", "3"}], "}"}], ",", 
