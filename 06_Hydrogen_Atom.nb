Cell[TextData[{
 "Once again, we find that we only obtain well-behaved, finite wavefunctions \
if we introduce a new quantum number ",
 StyleBox["n",
  FontSlant->"Italic"],
 " that can only take on integer values from 1 to \[Infinity]. We also find \
that the values of ",
 StyleBox["l",
  FontSlant->"Italic"],
 " are now constrained to take on values of"
}], "Text",
