Cell[CellGroupData[{

Cell[TextData[{
 "Multiplication of a Row or Column by a Factor ",
 StyleBox["c",
  FontSlant->"Italic"],
 " Multiplies Determinant by ",
 StyleBox["c",
  FontSlant->"Italic"]
}], "Subsubsection",
 CellChangeTimes->{{3.81131822525836*^9, 3.8113182531407485`*^9}, {
   3.811318437032322*^9, 3.811318467257702*^9}, 3.811318566065028*^9, {
   3.811318687240985*^9, 3.8113187221442175`*^9}, {3.811319179045396*^9, 
   3.8113192146017933`*^9}},ExpressionUUID->"a153da60-8a94-4e16-a700-\
f65c67b34e20"],

Cell[TextData[{
 "If we multiply every element in a row or every element in a column by a \
factor ",
 StyleBox["c",
  FontSlant->"Italic"],
 ", then the determinant is multiplied by a factor ",
 StyleBox["c",
  FontSlant->"Italic"],
 ". Again, we can investigate a quick example using Mathematica evaluation,"
}], "Text",
 CellChangeTimes->{{3.8113192194898863`*^9, 
  3.8113192612819085`*^9}},ExpressionUUID->"196557e6-03f5-4c3b-ad6a-\
757f2f03e9b0"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"Expand", "[", 
   RowBox[{
    StyleBox["c",
     FontSlant->"Italic"], "*", 
    RowBox[{"Det", "[", GridBox[{
       {
        SubscriptBox[
         StyleBox["a",
          FontSlant->"Italic"], "11"], 
        SubscriptBox[
         StyleBox["a",
          FontSlant->"Italic"], "12"], 
        SubscriptBox[
         StyleBox["a",
          FontSlant->"Italic"], "13"]},
       {
        SubscriptBox[
         StyleBox["a",
          FontSlant->"Italic"], "21"], 
        SubscriptBox[
         StyleBox["a",
          FontSlant->"Italic"], "22"], 
        SubscriptBox[
         StyleBox["a",
          FontSlant->"Italic"], "23"]},
       {
        SubscriptBox[
         StyleBox["a",
          FontSlant->"Italic"], "31"], 
        SubscriptBox[
         StyleBox["a",
          FontSlant->"Italic"], "32"], 
        SubscriptBox[
         StyleBox["a",
          FontSlant->"Italic"], "33"]}
      }], "]"}]}], "]"}], "==", 
  RowBox[{"Det", "[", GridBox[{
     {
      RowBox[{
       StyleBox["c",
        FontSlant->"Italic"], 
       StyleBox["*",
        FontSlant->"Italic"], 
       SubscriptBox[
        StyleBox["a",
         FontSlant->"Italic"], "11"]}], 
      RowBox[{
       StyleBox["c",
        FontSlant->"Italic"], 
       StyleBox["*",
        FontSlant->"Italic"], 
       SubscriptBox[
        StyleBox["a",
         FontSlant->"Italic"], "12"]}], 
      RowBox[{
       StyleBox["c",
        FontSlant->"Italic"], 
       StyleBox["*",
        FontSlant->"Italic"], 
       SubscriptBox[
        StyleBox["a",
         FontSlant->"Italic"], "13"]}]},
     {
      SubscriptBox[
       StyleBox["a",
        FontSlant->"Italic"], "21"], 
      SubscriptBox[
       StyleBox["a",
        FontSlant->"Italic"], "22"], 
      SubscriptBox[
       StyleBox["a",
        FontSlant->"Italic"], "23"]},
     {
      SubscriptBox[
       StyleBox["a",
        FontSlant->"Italic"], "31"], 
      SubscriptBox[
       StyleBox["a",
        FontSlant->"Italic"], "32"], 
      SubscriptBox[
       StyleBox["a",
        FontSlant->"Italic"], "33"]}
    }], "]"}]}]], "Input",
 CellChangeTimes->{{3.8113181472109995`*^9, 3.811318156487506*^9}, {
  3.8113192684164476`*^9, 3.8113193070719357`*^9}},
 CellLabel->"In[17]:=",ExpressionUUID->"cd430cc7-3cf9-4bcd-a138-7245a85e5432"],

Cell[BoxData["True"], "Output",
 CellChangeTimes->{{3.8113192881629133`*^9, 3.811319307474764*^9}},
 CellLabel->"Out[17]=",ExpressionUUID->"65a17497-b820-4e08-a511-696c28067a14"]
}, Open  ]],

Cell["And for columns,", "Text",
 CellChangeTimes->{{3.811319329762727*^9, 
  3.811319332306206*^9}},ExpressionUUID->"57bceb66-e58f-4c06-a89c-\
5a556478be3a"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"Expand", "[", 
   RowBox[{
    StyleBox["c",
     FontSlant->"Italic"], "*", 
    RowBox[{"Det", "[", GridBox[{
       {
        SubscriptBox[
         StyleBox["a",
          FontSlant->"Italic"], "11"], 
        SubscriptBox[
         StyleBox["a",
          FontSlant->"Italic"], "12"], 
        SubscriptBox[
         StyleBox["a",
          FontSlant->"Italic"], "13"]},
       {
        SubscriptBox[
         StyleBox["a",
          FontSlant->"Italic"], "21"], 
        SubscriptBox[
         StyleBox["a",
          FontSlant->"Italic"], "22"], 
        SubscriptBox[
         StyleBox["a",
          FontSlant->"Italic"], "23"]},
       {
        SubscriptBox[
         StyleBox["a",
          FontSlant->"Italic"], "31"], 
        SubscriptBox[
         StyleBox["a",
          FontSlant->"Italic"], "32"], 
        SubscriptBox[
         StyleBox["a",
          FontSlant->"Italic"], "33"]}
      }], "]"}]}], "]"}], "==", 
  RowBox[{"Det", "[", GridBox[{
     {
      SubscriptBox[
       StyleBox["a",
        FontSlant->"Italic"], "11"], 
      SubscriptBox[
       StyleBox["a",
        FontSlant->"Italic"], "12"], 
      RowBox[{
       StyleBox["c",
