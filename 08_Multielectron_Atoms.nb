 RowBox[{
  StyleBox["a",
   FontSlant->"Italic"], 
  StyleBox["=",
   FontSlant->"Italic"], 
  RowBox[{"(", 
   RowBox[{"1", "-", 
    SubsuperscriptBox[
     StyleBox["S",
      FontSlant->"Italic"], "12", "2"]}], ")"}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.811867187960767*^9, 3.811867203632437*^9}, {
