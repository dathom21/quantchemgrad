Cell["\<\
Now we need to address the denominator of equation (89). Following a similar \
procedure to that we used for the numerator, we obtain\
\>", "Text",
 CellChangeTimes->{{3.811860713060875*^9, 3.811860728214941*^9}, {
  3.8118607750734463`*^9, 3.8118607909754915`*^9}, {3.9362803614207172`*^9, 
  3.9362803615304546`*^9}},ExpressionUUID->"12d892f1-8e45-9b4f-a13c-\
704b06fccf0b"],

Cell[BoxData[
 RowBox[{
  RowBox[{"\[LeftAngleBracket]", 
   RowBox[{"\[CapitalPhi]", "|", "\[CapitalPhi]"}], "\[RightAngleBracket]"}], 
  "  ", "=", 
  RowBox[{
   RowBox[{
    UnderscriptBox["\[Sum]", 
     StyleBox["n",
      FontSlant->"Italic"]], 
    RowBox[{
     UnderscriptBox["\[Sum]", 
      StyleBox["m",
       FontSlant->"Italic"]], 
     RowBox[{
      SubsuperscriptBox[
       StyleBox["a",
        FontSlant->"Italic"], 
       StyleBox["n",
        FontSlant->"Italic"], "\[Star]"], 
      SubscriptBox[
       StyleBox["a",
        FontSlant->"Italic"], 
       StyleBox["m",
        FontSlant->"Italic"]], " ", 
      RowBox[{"\[LeftAngleBracket]", 
       RowBox[{
        SubscriptBox["\[Phi]", 
         StyleBox["n",
          FontSlant->"Italic"]], "|", 
        SubscriptBox["\[Phi]", 
         StyleBox["m",
          FontSlant->"Italic"]]}], "\[RightAngleBracket]"}], "                                       ", 
      RowBox[{"\[Integral]", 
       RowBox[{
        SuperscriptBox["\[CapitalPhi]", "\[Star]"], " ", 
        OverscriptBox[
         StyleBox["H",
          FontSlant->"Italic"], "^"], "\[CapitalPhi]", " ", 
        "d\[Tau]"}]}]}]}]}], "=", 
   RowBox[{
    UnderscriptBox["\[Sum]", 
     StyleBox["n",
      FontSlant->"Italic"]], 
    RowBox[{
     UnderscriptBox["\[Sum]", 
      StyleBox["m",
       FontSlant->"Italic"]], 
     RowBox[{
      SubsuperscriptBox[
       StyleBox["a",
        FontSlant->"Italic"], 
       StyleBox["n",
        FontSlant->"Italic"], "\[Star]"], 
      SubscriptBox[
       StyleBox["a",
        FontSlant->"Italic"], 
       StyleBox["m",
        FontSlant->"Italic"]], 
      RowBox[{"\[Integral]", 
       RowBox[{
        SubsuperscriptBox["\[Phi]", 
         StyleBox["n",
          FontSlant->"Italic"], "\[Star]"], " ", 
        SubscriptBox["\[Phi]", 
         StyleBox["m",
          FontSlant->"Italic"]], " ", 
        "d\[Tau]"}]}]}]}]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8118608050778804`*^9, 
  3.811860862478286*^9}},ExpressionUUID->"5bac8abb-b89a-d943-86a0-\
b8f4f390aee8"],

Cell[TextData[{
 "We typically give the quantity ",
 Cell[BoxData[
  RowBox[{"\[LeftAngleBracket]", 
   RowBox[{
    SubscriptBox["\[Phi]", 
     StyleBox["n",
      FontSlant->"Italic"]], "|", 
    SubscriptBox["\[Phi]", 
     StyleBox["m",
      FontSlant->"Italic"]]}], "\[RightAngleBracket]"}]],
  CellChangeTimes->{{3.8118608050778804`*^9, 3.811860862478286*^9}},
  ExpressionUUID->"69836e16-d55d-434f-9973-78d076b5c9ac"],
 " the title of overlap integral, which we represent with the symbol ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["S", 
    StyleBox["nm",
     FontSlant->"Italic"]], TraditionalForm]],ExpressionUUID->
  "8ec35c98-8c09-2246-8678-ab181e1496e9"],
 ","
}], "Text",
 CellChangeTimes->{{3.8118608675671473`*^9, 
  3.811860911354288*^9}},ExpressionUUID->"e956dd56-aade-114a-8a52-\
76f10049e9fe"],

Cell[BoxData[
 RowBox[{
  StyleBox["        ",
   FontSlant->"Italic"], 
  RowBox[{
   SubscriptBox[
    StyleBox["S",
     FontSlant->"Italic"], 
    StyleBox["nm",
     FontSlant->"Italic"]], " ", "=", 
   RowBox[{
    RowBox[{
     RowBox[{"\[LeftAngleBracket]", 
      RowBox[{
       SubscriptBox["\[Phi]", 
        StyleBox["n",
         FontSlant->"Italic"]], "|", 
       SubscriptBox["\[Phi]", 
        StyleBox["m",
         FontSlant->"Italic"]]}], "\[RightAngleBracket]"}], "                                                                           ", 
     SubscriptBox[
      StyleBox["S",
       FontSlant->"Italic"], 
      StyleBox["nm",
       FontSlant->"Italic"]]}], " ", "=", 
    RowBox[{"\[Integral]", 
     RowBox[{
      SubsuperscriptBox["\[Phi]", 
       StyleBox["n",
        FontSlant->"Italic"], "\[Star]"], " ", 
      SubscriptBox["\[Phi]", 
       StyleBox["m",
        FontSlant->"Italic"]], " ", 
      "d\[Tau]"}]}]}]}]}]], "DisplayFormulaNumbered",
