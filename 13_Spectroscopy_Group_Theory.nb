    3.8154794764432354`*^9}, {3.8154827001319475`*^9, 
    3.8154827649959607`*^9}, {3.815754454341432*^9, 3.815754455861507*^9}, {
    3.815755043689207*^9, 3.81575504640403*^9}, 3.8157559076864185`*^9, 
    3.8157559845101175`*^9, {3.8157561148226886`*^9, 
    3.8157561432247086`*^9}, {3.815756206037531*^9, 3.8157562153683667`*^9}, {
    3.8157562600399704`*^9, 3.815756261111499*^9}, {3.815756300371641*^9, 
    3.815756304417721*^9}, {3.816342500257859*^9, 3.816342502332419*^9}, {
    3.8163425702798834`*^9, 3.8163425884784684`*^9}},ExpressionUUID->
  "18a1f832-b2b1-4b5d-b72e-8cc9fcb1cb66"],
 " is the excited state, and ",
 Cell[BoxData[
  SubscriptBox["\[Psi]", 
   RowBox[{"0", "vib"}]]],
  CellChangeTimes->{{3.8079712935412436`*^9, 3.8079714900326514`*^9}, {
    3.8080650361338077`*^9, 3.808065078586836*^9}, {3.8080651294863386`*^9, 
    3.8080651662446632`*^9}, {3.8080655103101*^9, 3.808065549470801*^9}, {
    3.8080655874181037`*^9, 3.8080655997397223`*^9}, {3.80806586302172*^9, 
    3.808065882866931*^9}, {3.8080659492793603`*^9, 3.808065953047598*^9}, {
    3.808066005614772*^9, 3.8080660274348636`*^9}, {3.8080662251299095`*^9, 
    3.8080662851171017`*^9}, {3.815378518820794*^9, 3.815378562596084*^9}, {
    3.81537861215761*^9, 3.815378656577838*^9}, {3.815379033614147*^9, 
    3.8153790773392897`*^9}, {3.8153792393653684`*^9, 3.81537924024451*^9}, {
    3.8153793909369802`*^9, 3.81537943105853*^9}, {3.815381276661846*^9, 
    3.8153813324920735`*^9}, {3.815468631694975*^9, 3.8154686569549303`*^9}, {
    3.8154691238283195`*^9, 3.815469135872029*^9}, {3.815469234740734*^9, 
    3.815469253967925*^9}, {3.815469801580475*^9, 3.8154698049489393`*^9}, {
    3.8154704295945253`*^9, 3.8154705377746935`*^9}, {3.815470675960216*^9, 
    3.815470685687868*^9}, {3.8154771921536026`*^9, 3.8154772311980553`*^9}, {
    3.815477347847094*^9, 3.815477378878831*^9}, {3.8154781257511315`*^9, 
    3.815478223009077*^9}, {3.8154786358518734`*^9, 3.8154786389651012`*^9}, {
    3.8154786960548897`*^9, 3.8154786979311686`*^9}, {3.815478752042659*^9, 
    3.8154787864116263`*^9}, {3.815478846570588*^9, 3.815478870033407*^9}, {
    3.8154793192990932`*^9, 3.8154793232406645`*^9}, {3.8154794670370035`*^9, 
    3.8154794764432354`*^9}, {3.8154827001319475`*^9, 
    3.8154827649959607`*^9}, {3.815754454341432*^9, 3.815754455861507*^9}, {
    3.815755043689207*^9, 3.81575504640403*^9}, 3.8157559076864185`*^9, 
    3.8157559845101175`*^9, {3.8157561148226886`*^9, 
    3.8157561432247086`*^9}, {3.815756206037531*^9, 3.8157562153683667`*^9}, {
    3.8157562600399704`*^9, 3.815756261111499*^9}, {3.815756300371641*^9, 
    3.815756304417721*^9}, {3.816342500257859*^9, 3.816342502332419*^9}, {
    3.8163425702798834`*^9, 3.8163425884784684`*^9}},ExpressionUUID->
  "641178cc-3396-4789-8ec9-3ba7856c5fe5"],
 " is the ground state. "
}], "Text",
 CellChangeTimes->{{3.8163425938777227`*^9, 3.8163426580288906`*^9}, 
   3.8163428054305086`*^9, {3.8163433814945145`*^9, 
   3.816343400328463*^9}},ExpressionUUID->"d0700e8e-5d80-4514-8a9e-\
0203a30775ed"],

Cell[TextData[{
 "Because the normal modes belong to the irreducible representations of the \
point group, any group symmetry operator ",
 Cell[BoxData[
  FormBox[
   OverscriptBox["A", "^"], TraditionalForm]],ExpressionUUID->
  "be7d51bb-f54a-4fa2-8ee9-13fcf20b304a"],
 " acting on the normal mode will change the dependence on ",
 StyleBox["Q",
  FontSlant->"Italic"],
 " by \[PlusMinus]1,"
}], "Text",
 CellChangeTimes->{{3.8163429004558325`*^9, 3.81634295916263*^9}, {
  3.8163429932207932`*^9, 3.816343013436331*^9}, {3.8163430577677145`*^9, 
  3.816343074179572*^9}, {3.8163431046077166`*^9, 3.8163431096788015`*^9}, {
  3.8163436279388237`*^9, 3.81634364804305*^9}, {3.816343744800967*^9, 
  3.8163437454156065`*^9}},ExpressionUUID->"b2d95547-b2dc-41cf-beab-\
9d106c36ea86"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   OverscriptBox[
    StyleBox["A",
     FontSlant->"Italic"], "^"], 
   SubscriptBox["\[Psi]", 
    RowBox[{"0", 
     SubscriptBox["vib", 
      StyleBox["i",
       FontSlant->"Italic"]]}]], 
   RowBox[{"(", 
    SubscriptBox[
     StyleBox["Q",
      FontSlant->"Italic"], 
     StyleBox["i",
      FontSlant->"Italic"]], ")"}]}], "=", 
  RowBox[{
   SubscriptBox["\[Psi]", 
    RowBox[{"0", 
     SubscriptBox["vib", 
      StyleBox["i",
       FontSlant->"Italic"]]}]], 
   RowBox[{"(", 
    RowBox[{"\[PlusMinus]", 
     SubscriptBox[
      StyleBox["Q",
       FontSlant->"Italic"], 
      StyleBox["i",
       FontSlant->"Italic"]]}], ")"}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8163430817811728`*^9, 3.8163431436486635`*^9}, {
   3.8163432287605705`*^9, 3.8163432328847084`*^9}, {3.816343425297841*^9, 
   3.816343445782265*^9}, 
   3.8163623881408057`*^9},ExpressionUUID->"17f12b45-852f-4b8b-878f-\
0609ecd85b34"],

Cell[TextData[{
 "Remembering that the ground-state harmonic oscillator functions depend on \
the square of ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["Q",
    FontSlant->"Italic"], 
   StyleBox["i",
    FontSlant->"Italic"]]],
  CellChangeTimes->{{3.8163430817811728`*^9, 3.816343114938343*^9}},
  ExpressionUUID->"0b71bb52-1866-4cd9-8c5f-ce6149c9312f"],
 ","
}], "Text",
 CellChangeTimes->{{3.816343117659831*^9, 3.816343150541812*^9}, {
  3.81634321606008*^9, 
  3.8163432174461775`*^9}},ExpressionUUID->"548a2ae2-5ddd-4c5f-865e-\
4ac3c60c0802"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   SubscriptBox["\[Psi]", 
    RowBox[{"0", 
     SubscriptBox["vib", 
      StyleBox["i",
       FontSlant->"Italic"]]}]], 
   RowBox[{"(", 
    StyleBox[
     SubscriptBox[
      StyleBox["Q",
       FontSlant->"Italic"], 
      StyleBox["i",
       FontSlant->"Italic"]],
     FontSlant->"Italic"], ")"}]}], "=", 
  RowBox[{
   RowBox[{
    SubscriptBox[
     StyleBox["N",
      FontSlant->"Italic"], "0"], 
    SubscriptBox[
     StyleBox["H",
      FontSlant->"Italic"], "0"], 
    RowBox[{"(", 
     RowBox[{
      SuperscriptBox["\[Alpha]", 
       RowBox[{"1", "/", "2"}]], 
      StyleBox[
       SubscriptBox[
        StyleBox["Q",
         FontSlant->"Italic"], 
        StyleBox["i",
         FontSlant->"Italic"]],
       FontSlant->"Italic"]}], ")"}], 
    SuperscriptBox["\[ExponentialE]", 
     RowBox[{
      RowBox[{"-", 
       SuperscriptBox[
        SubscriptBox[
         StyleBox[
          RowBox[{
           StyleBox["\[Alpha]",
            FontSlant->"Plain"], 
           StyleBox["Q",
            FontSlant->"Italic"]}]], 
         StyleBox["i",
          FontSlant->"Italic"]], "2"]}], "/", "2"}]]}], "=", 
   RowBox[{
    SubscriptBox[
     StyleBox["c",
      FontSlant->"Italic"], 
     StyleBox["i",
      FontSlant->"Italic"]], 
    SuperscriptBox["\[ExponentialE]", 
     RowBox[{
      RowBox[{"-", 
       SuperscriptBox[
        SubscriptBox[
         StyleBox[
          RowBox[{
           StyleBox["\[Alpha]",
            FontSlant->"Plain"], 
           StyleBox["Q",
            FontSlant->"Italic"]}]], 
         StyleBox["i",
          FontSlant->"Italic"]], "2"]}], "/", 
      "2"}]]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.815828180214196*^9, 3.8158282059131823`*^9}, {
   3.8158282388847585`*^9, 3.815828278296766*^9}, {3.8158291799181256`*^9, 
   3.8158291805733967`*^9}, {3.8158315887216773`*^9, 3.815831591314068*^9}, {
   3.8163431755603704`*^9, 3.8163431817645144`*^9}, {3.8163432416781454`*^9, 
   3.816343264255813*^9}, 3.816343345661664*^9, {3.816343459805952*^9, 
   3.816343461064107*^9}},ExpressionUUID->"430c1cb4-fdbf-485c-bf48-\
9049c08e4a1e"],

Cell["we have that", "Text",
 CellChangeTimes->{{3.8163431977209644`*^9, 3.816343200332714*^9}, {
  3.8163432359997005`*^9, 
  3.816343237421266*^9}},ExpressionUUID->"7b754cb8-ee33-4cd7-b448-\
1edef00a88ba"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   SubscriptBox["\[Psi]", 
    RowBox[{"0", 
     SubscriptBox["vib", 
      StyleBox["i",
       FontSlant->"Italic"]]}]], 
   RowBox[{"(", 
    SubscriptBox[
     StyleBox["Q",
      FontSlant->"Italic"], 
     StyleBox["i",
      FontSlant->"Italic"]], ")"}]}], "=", 
  RowBox[{
   SubscriptBox["\[Psi]", 
    RowBox[{"0", 
     SubscriptBox["vib", 
      StyleBox["i",
       FontSlant->"Italic"]]}]], 
   RowBox[{"(", 
    RowBox[{"\[PlusMinus]", 
     SubscriptBox[
      StyleBox["Q",
       FontSlant->"Italic"], 
      StyleBox["i",
       FontSlant->"Italic"]]}], ")"}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8163430817811728`*^9, 3.8163431436486635`*^9}, {
  3.8163432287605705`*^9, 3.8163432328847084`*^9}, {3.8163432855739408`*^9, 
  3.816343289023427*^9}, {3.8163434701051264`*^9, 
  3.8163434717172813`*^9}},ExpressionUUID->"e258c448-3397-4fc1-8ed9-\
eda6370c48d0"],

Cell[TextData[{
 "We can say that the ground-state harmonic oscillator wavefunction belongs \
to the irreducible representation ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["A", "1"], TraditionalForm]],ExpressionUUID->
  "4e7b1119-72f3-4631-873d-4692ee742b37"],
 " (totally symmetric). In this irreducible representation, any symmetry \
operation will yield a character of +1. "
}], "Text",
 CellChangeTimes->{{3.8163437631472483`*^9, 3.8163438175873785`*^9}, {
  3.816344041695581*^9, 
  3.816344052478707*^9}},ExpressionUUID->"caec3443-98c7-4acf-a1d3-\
dc1bf63a14d2"],

Cell["\<\
Now we turn our attention to the form of the vibrationally excited state \
wavefunction, where, for one vibrational state,\
\>", "Text",
 CellChangeTimes->{{3.8163441155377245`*^9, 
  3.81634414859982*^9}},ExpressionUUID->"b8947e28-92e9-4af0-a5a7-\
3e34c87ad820"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   SubscriptBox["\[Psi]", 
    RowBox[{"1", 
     SubscriptBox["vib", 
      StyleBox["i",
       FontSlant->"Italic"]]}]], 
   RowBox[{"(", 
    StyleBox[
     SubscriptBox[
      StyleBox["Q",
       FontSlant->"Italic"], 
      StyleBox["i",
       FontSlant->"Italic"]],
     FontSlant->"Italic"], ")"}]}], "=", 
  RowBox[{
   RowBox[{
    SubscriptBox[
     StyleBox["N",
      FontSlant->"Italic"], "1"], 
    SubscriptBox[
     StyleBox["H",
      FontSlant->"Italic"], "1"], 
    RowBox[{"(", 
     RowBox[{
      SuperscriptBox["\[Alpha]", 
       RowBox[{"1", "/", "2"}]], 
      StyleBox[
       SubscriptBox[
        StyleBox["Q",
         FontSlant->"Italic"], 
        StyleBox["i",
         FontSlant->"Italic"]],
       FontSlant->"Italic"]}], ")"}], 
    SuperscriptBox["\[ExponentialE]", 
     RowBox[{
      RowBox[{"-", 
       SuperscriptBox[
        SubscriptBox[
         StyleBox[
          RowBox[{
           StyleBox["\[Alpha]",
            FontSlant->"Plain"], 
           StyleBox["Q",
            FontSlant->"Italic"]}]], 
         StyleBox["i",
          FontSlant->"Italic"]], "2"]}], "/", "2"}]]}], "=", 
   RowBox[{
    SubsuperscriptBox[
     StyleBox["c",
      FontSlant->"Italic"], 
     StyleBox["i",
      FontSlant->"Italic"], "\[Prime]"], 
    StyleBox[
     SubscriptBox[
      StyleBox["Q",
       FontSlant->"Italic"], 
      StyleBox["i",
       FontSlant->"Italic"]],
     FontSlant->"Italic"], 
    SubscriptBox[
     StyleBox["c",
      FontSlant->"Italic"], 
     StyleBox["i",
      FontSlant->"Italic"]], 
    SuperscriptBox["\[ExponentialE]", 
     RowBox[{
      RowBox[{"-", 
       SuperscriptBox[
        SubscriptBox[
         StyleBox[
          RowBox[{
           StyleBox["\[Alpha]",
            FontSlant->"Plain"], 
           StyleBox["Q",
            FontSlant->"Italic"]}]], 
         StyleBox["i",
          FontSlant->"Italic"]], "2"]}], "/", 
      "2"}]]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.815828180214196*^9, 3.8158282059131823`*^9}, {
   3.8158282388847585`*^9, 3.815828278296766*^9}, {3.8158291799181256`*^9, 
   3.8158291805733967`*^9}, {3.8158315887216773`*^9, 3.815831591314068*^9}, {
   3.8163431755603704`*^9, 3.8163431817645144`*^9}, {3.8163432416781454`*^9, 
   3.816343264255813*^9}, 3.816343345661664*^9, {3.816343459805952*^9, 
   3.816343461064107*^9}, {3.8163441538685617`*^9, 
   3.8163441861099834`*^9}},ExpressionUUID->"99e809b3-9177-4013-a2d5-\
2ceaa09112af"],

Cell[TextData[{
 "In other words, the first excited state differs from the ground state by \
some factor ",
 Cell[BoxData[
  RowBox[{
   SubsuperscriptBox[
    StyleBox["c",
     FontSlant->"Italic"], 
    StyleBox["i",
     FontSlant->"Italic"], "\[Prime]"], 
   StyleBox[
    SubscriptBox[
     StyleBox["Q",
      FontSlant->"Italic"], 
     StyleBox["i",
      FontSlant->"Italic"]],
    FontSlant->"Italic"]}]],
  CellChangeTimes->{{3.815828180214196*^9, 3.8158282059131823`*^9}, {
    3.8158282388847585`*^9, 3.815828278296766*^9}, {3.8158291799181256`*^9, 
    3.8158291805733967`*^9}, {3.8158315887216773`*^9, 3.815831591314068*^9}, {
    3.8163431755603704`*^9, 3.8163431817645144`*^9}, {3.8163432416781454`*^9, 
    3.816343264255813*^9}, 3.816343345661664*^9, {3.816343459805952*^9, 
    3.816343461064107*^9}, {3.8163441538685617`*^9, 3.8163441861099834`*^9}},
  ExpressionUUID->"6b2dee8b-0d59-412d-a678-cfa49d9f4834"],
 ", where ",
 Cell[BoxData[
  SubsuperscriptBox[
   StyleBox["c",
    FontSlant->"Italic"], 
   StyleBox["i",
    FontSlant->"Italic"], "\[Prime]"]],
  CellChangeTimes->{{3.815828180214196*^9, 3.8158282059131823`*^9}, {
    3.8158282388847585`*^9, 3.815828278296766*^9}, {3.8158291799181256`*^9, 
    3.8158291805733967`*^9}, {3.8158315887216773`*^9, 3.815831591314068*^9}, {
    3.8163431755603704`*^9, 3.8163431817645144`*^9}, {3.8163432416781454`*^9, 
    3.816343264255813*^9}, 3.816343345661664*^9, {3.816343459805952*^9, 
    3.816343461064107*^9}, {3.8163441538685617`*^9, 3.8163441861099834`*^9}},
  ExpressionUUID->"f519bedf-14b5-4b90-a156-198901ff7159"],
 " is a normalization constant. We can then write the entire vibrational \
wavefunction as"
}], "Text",
 CellChangeTimes->{{3.8163441914459004`*^9, 
  3.816344229782222*^9}},ExpressionUUID->"2934fbbc-33e7-418e-9e49-\
147c3384a8df"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   SubscriptBox["\[Psi]", 
    RowBox[{"1", "vib"}]], 
   RowBox[{"(", 
    RowBox[{
     SubscriptBox[
      StyleBox["Q",
       FontSlant->"Italic"], "1"], ",", " ", 
     SubscriptBox[
      StyleBox["Q",
       FontSlant->"Italic"], "2"], ",", "...", ",", 
     SubscriptBox[
      StyleBox["Q",
       FontSlant->"Italic"], 
      StyleBox["N",
       FontSlant->"Italic"]]}], ")"}]}], "=", 
  RowBox[{
   SubsuperscriptBox[
    StyleBox["c",
     FontSlant->"Italic"], 
    StyleBox["i",
     FontSlant->"Italic"], "\[Prime]"], 
   StyleBox[
    SubscriptBox[
     StyleBox["Q",
      FontSlant->"Italic"], 
     StyleBox["i",
      FontSlant->"Italic"]],
    FontSlant->"Italic"], 
   SubscriptBox["\[Psi]", 
    RowBox[{"0", "vib"}]], 
   RowBox[{"(", 
    RowBox[{
     SubscriptBox[
      StyleBox["Q",
       FontSlant->"Italic"], "1"], ",", " ", 
     SubscriptBox[
      StyleBox["Q",
       FontSlant->"Italic"], "2"], ",", "...", ",", 
     SubscriptBox[
      StyleBox["Q",
       FontSlant->"Italic"], 
      StyleBox["N",
       FontSlant->"Italic"]]}], ")"}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8163442469544964`*^9, 
  3.816344264413885*^9}},ExpressionUUID->"adc2c66a-0538-4667-ae4d-\
3ac6ab39271c"],

Cell[TextData[{
 "Where the ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["i", "th"], TraditionalForm]],ExpressionUUID->
  "60a50aa1-3c31-4cc9-89f5-b342ea20d146"],
 " vibration is in the first excited state. Because the new wavefunction \
differs from the ground state by a factor of ",
 Cell[BoxData[
  StyleBox[
   SubscriptBox[
    StyleBox["Q",
     FontSlant->"Italic"], 
    StyleBox["i",
     FontSlant->"Italic"]],
   FontSlant->"Italic"]],
  CellChangeTimes->{{3.8163442469544964`*^9, 3.816344264413885*^9}},
  ExpressionUUID->"89d6136d-8430-4b09-b1e0-4aaaa27583ec"],
 ", we say that the wavefunction ",
 StyleBox["transforms",
  FontSlant->"Italic"],
 " as the normal coordinate ",
 Cell[BoxData[
  StyleBox[
   SubscriptBox[
    StyleBox["Q",
     FontSlant->"Italic"], 
    StyleBox["i",
     FontSlant->"Italic"]],
   FontSlant->"Italic"]],
  CellChangeTimes->{{3.8163442469544964`*^9, 3.816344264413885*^9}},
  ExpressionUUID->"58ff501c-bee1-498a-b276-169cb4f1a609"],
 ". Now, a symmetry operator acting on this wavefunction will return the \
character of the operation, which we will call \[Chi],"
}], "Text",
 CellChangeTimes->{{3.8163442695700383`*^9, 3.8163443252246447`*^9}, {
  3.816352559703089*^9, 3.816352600065055*^9}, {3.8163622217839804`*^9, 
  3.816362235400282*^9}, {3.816362335888702*^9, 
  3.8163623427632275`*^9}},ExpressionUUID->"16c7f57c-6385-4157-ae18-\
5f40023ee15d"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   OverscriptBox[
    StyleBox["A",
     FontSlant->"Italic"], "^"], 
   SubscriptBox["\[Psi]", 
    RowBox[{"1", "vib"}]], 
   RowBox[{"(", 
    RowBox[{
     SubscriptBox[
      StyleBox["Q",
       FontSlant->"Italic"], "1"], ",", " ", 
     SubscriptBox[
      StyleBox["Q",
       FontSlant->"Italic"], "2"], ",", "...", ",", 
     SubscriptBox[
      StyleBox["Q",
       FontSlant->"Italic"], 
      StyleBox["N",
       FontSlant->"Italic"]]}], ")"}]}], "=", 
  RowBox[{
   SubscriptBox["\[Chi]", 
    StyleBox[
     SubscriptBox["Q", "i"],
     FontSlant->"Italic"]], 
   RowBox[{"(", 
    OverscriptBox[
     StyleBox["A",
      FontSlant->"Italic"], "^"], ")"}], 
   SubscriptBox["\[Psi]", 
    RowBox[{"1", "vib"}]], 
   RowBox[{"(", 
    RowBox[{
     SubscriptBox[
      StyleBox["Q",
       FontSlant->"Italic"], "1"], ",", " ", 
     SubscriptBox[
      StyleBox["Q",
       FontSlant->"Italic"], "2"], ",", "...", ",", 
     SubscriptBox[
      StyleBox["Q",
       FontSlant->"Italic"], 
      StyleBox["N",
       FontSlant->"Italic"]]}], ")"}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8163442469544964`*^9, 3.816344264413885*^9}, {
  3.8163623643830175`*^9, 3.8163624061546893`*^9}, {3.8163624614220643`*^9, 
  3.8163624700013294`*^9}},ExpressionUUID->"0f358b03-4b36-4db0-9c5f-\
b0c543cf4eb8"],

Cell[TextData[{
 "We use a similar notation to denote a symmetry operator acting on the ",
 StyleBox["x",
  FontSlant->"Italic"],
 ", ",
 StyleBox["y",
  FontSlant->"Italic"],
 ", or ",
 StyleBox["z",
  FontSlant->"Italic"],
 " component of the dipole moment,"
}], "Text",
 CellChangeTimes->{{3.8163628432527485`*^9, 3.8163628471969824`*^9}, {
  3.816362878773687*^9, 
  3.8163629091089582`*^9}},ExpressionUUID->"7657343c-7412-4983-9a1d-\
2b93c19c8c85"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   OverscriptBox[
    StyleBox["A",
     FontSlant->"Italic"], "^"], 
   SubscriptBox["\[Mu]", 
    StyleBox["x",
     FontSlant->"Italic"]]}], "=", 
  RowBox[{
   SubscriptBox["\[Chi]", 
    SubscriptBox["\[Mu]", 
     StyleBox["x",
      FontSlant->"Italic"]]], 
   RowBox[{"(", 
    OverscriptBox[
     StyleBox["A",
      FontSlant->"Italic"], "^"], ")"}], 
   SubscriptBox["\[Mu]", 
    StyleBox["x",
     FontSlant->"Italic"]]}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   OverscriptBox[
    StyleBox["A",
     FontSlant->"Italic"], "^"], 
   SubscriptBox["\[Mu]", 
    StyleBox["y",
     FontSlant->"Italic"]]}], "=", 
  RowBox[{
   SubscriptBox["\[Chi]", 
    SubscriptBox["\[Mu]", 
     StyleBox["y",
      FontSlant->"Italic"]]], 
   RowBox[{"(", 
    OverscriptBox[
     StyleBox["A",
      FontSlant->"Italic"], "^"], ")"}], 
   SubscriptBox["\[Mu]", 
    StyleBox["y",
     FontSlant->"Italic"]]}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   OverscriptBox[
    StyleBox["A",
     FontSlant->"Italic"], "^"], 
   SubscriptBox["\[Mu]", 
    StyleBox["z",
     FontSlant->"Italic"]]}], "=", 
  RowBox[{
   SubscriptBox["\[Chi]", 
    SubscriptBox["\[Mu]", 
     StyleBox["z",
      FontSlant->"Italic"]]], 
   RowBox[{"(", 
    OverscriptBox[
     StyleBox["A",
      FontSlant->"Italic"], "^"], ")"}], 
   SubscriptBox["\[Mu]", 
    StyleBox["z",
     FontSlant->"Italic"]]}]}]}], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8163442469544964`*^9, 3.816344264413885*^9}, {
  3.8163623643830175`*^9, 3.8163624061546893`*^9}, {3.8163624614220643`*^9, 
  3.8163624700013294`*^9}, {3.816362926913225*^9, 
  3.8163629736866674`*^9}},ExpressionUUID->"33b7ecd4-3db9-40c5-8502-\
0029611e0729"],

Cell["\<\
In summary, we have found the following results of the symmetry operations \
acting on three components,\
\>", "Text",
 CellChangeTimes->{{3.816362659753071*^9, 
  3.816362678054099*^9}},ExpressionUUID->"78709aa6-46d4-4da8-a366-\
7b8f13707b3f"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   OverscriptBox[
    StyleBox["A",
     FontSlant->"Italic"], "^"], 
   SubscriptBox["\[Psi]", 
    RowBox[{"0", "vib"}]]}], "=", 
  RowBox[{
   RowBox[{
    SubscriptBox["\[Chi]", 
     SubscriptBox[
      StyleBox["A",
       FontSlant->"Italic"], "1"]], 
    RowBox[{"(", 
     OverscriptBox[
      StyleBox["A",
       FontSlant->"Italic"], "^"], ")"}], 
    SubscriptBox["\[Psi]", 
     RowBox[{"0", "vib"}]]}], "=", 
   RowBox[{
    RowBox[{"(", "1", ")"}], 
    SubscriptBox["\[Psi]", 
     RowBox[{"0", "vib"}]]}]}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   OverscriptBox[
    StyleBox["A",
     FontSlant->"Italic"], "^"], 
   SubscriptBox["\[Psi]", 
    RowBox[{"1", "vib"}]]}], "=", 
  RowBox[{
   SubscriptBox["\[Chi]", 
    StyleBox[
     SubscriptBox["Q", "i"],
     FontSlant->"Italic"]], 
   RowBox[{"(", 
    OverscriptBox[
     StyleBox["A",
      FontSlant->"Italic"], "^"], ")"}], 
   SubscriptBox["\[Psi]", 
    RowBox[{"1", "vib"}]]}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   OverscriptBox[
    StyleBox["A",
     FontSlant->"Italic"], "^"], 
   SubscriptBox["\[Mu]", 
    StyleBox["x",
     FontSlant->"Italic"]]}], "=", 
  RowBox[{
   SubscriptBox["\[Chi]", 
    SubscriptBox["\[Mu]", 
     StyleBox["x",
      FontSlant->"Italic"]]], 
   RowBox[{"(", 
    OverscriptBox[
     StyleBox["A",
      FontSlant->"Italic"], "^"], ")"}], 
   SubscriptBox["\[Mu]", 
    StyleBox["x",
     FontSlant->"Italic"]]}]}]}], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8163430817811728`*^9, 3.8163431436486635`*^9}, {
   3.8163432287605705`*^9, 3.8163432328847084`*^9}, {3.816343425297841*^9, 
   3.816343445782265*^9}, 3.8163623881408057`*^9, {3.816362714987462*^9, 
   3.8163628062674494`*^9}, {3.8163629903785324`*^9, 
   3.816362997047018*^9}},ExpressionUUID->"5f36a160-862d-4326-85dc-\
1dceeff6139e"],

Cell[TextData[{
 "Now we can apply the symmetry operation ",
 Cell[BoxData[
  OverscriptBox[
   StyleBox["A",
    FontSlant->"Italic"], "^"]],
  CellChangeTimes->{{3.8163442469544964`*^9, 3.816344264413885*^9}, {
   3.8163623643830175`*^9, 3.8163624061546893`*^9}, {3.8163624614220643`*^9, 
   3.8163624700013294`*^9}},ExpressionUUID->
  "9e9336a2-f6ee-4e8d-a2ce-6f2e9d512a14"],
 " to the transition dipole moment,"
}], "Text",
 CellChangeTimes->{{3.8163625102716646`*^9, 
  3.8163625461880665`*^9}},ExpressionUUID->"d093fe42-4c15-4a59-b1c7-\
59adb31c8dad"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   OverscriptBox[
    StyleBox["A",
     FontSlant->"Italic"], "^"], 
   SubscriptBox[
    RowBox[{"\[LeftAngleBracket]", 
     StyleBox["\[Mu]",
      FontWeight->"Bold"], "\[RightAngleBracket]"}], 
    StyleBox["10",
     FontSlant->"Italic"]]}], "=", 
  RowBox[{"\[LeftAngleBracket]", 
   RowBox[{
    RowBox[{
     OverscriptBox[
      StyleBox["A",
       FontSlant->"Italic"], "^"], 
     SubscriptBox["\[Psi]", 
      RowBox[{"1", "vib"}]]}], 
    StyleBox["|",
     FontSlant->"Italic"], 
    RowBox[{
     OverscriptBox[
      StyleBox["A",
       FontSlant->"Italic"], "^"], 
     StyleBox["\[Mu]",
      FontWeight->"Bold"]}], "|", 
    RowBox[{
     OverscriptBox[
      StyleBox["A",
       FontSlant->"Italic"], "^"], 
     SubscriptBox["\[Psi]", 
      RowBox[{"0", "vib"}]]}]}], 
   "\[RightAngleBracket]"}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.816362560914196*^9, 
  3.8163626142846885`*^9}},ExpressionUUID->"f13ea755-2186-4f4e-82d6-\
68e56e5c2f7d"],

Cell[TextData[{
 "where we evaluate the ",
 StyleBox["x",
  FontSlant->"Italic"],
 ", ",
 StyleBox["y",
  FontSlant->"Italic"],
 ", and ",
 StyleBox["z",
  FontSlant->"Italic"],
 " components of \[Mu] individually. Taking ",
 Cell[BoxData[
  SubscriptBox["\[Mu]", 
   StyleBox["x",
    FontSlant->"Italic"]]],
  CellChangeTimes->{{3.8163430817811728`*^9, 3.8163431436486635`*^9}, {
    3.8163432287605705`*^9, 3.8163432328847084`*^9}, {3.816343425297841*^9, 
    3.816343445782265*^9}, 3.8163623881408057`*^9, {3.816362714987462*^9, 
    3.8163628062674494`*^9}, {3.8163629903785324`*^9, 3.816362997047018*^9}},
  ExpressionUUID->"8d68cf31-8742-4732-a6fa-7af24915f956"],
 " as an example,"
}], "Text",
 CellChangeTimes->{{3.8163630480112567`*^9, 
  3.816363099749459*^9}},ExpressionUUID->"aa65fca8-d1d0-4b59-b929-\
bd2e59d61a80"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   OverscriptBox[
    StyleBox["A",
     FontSlant->"Italic"], "^"], 
   SubscriptBox[
    RowBox[{"\[LeftAngleBracket]", 
     SubscriptBox[
      StyleBox["\[Mu]",
       FontWeight->"Bold"], "x"], "\[RightAngleBracket]"}], 
    StyleBox["10",
     FontSlant->"Italic"]]}], "=", 
  RowBox[{"\[LeftAngleBracket]", 
   RowBox[{
    RowBox[{
     OverscriptBox[
      StyleBox["A",
       FontSlant->"Italic"], "^"], 
     SubscriptBox["\[Psi]", 
      RowBox[{"1", "vib"}]]}], 
    StyleBox["|",
     FontSlant->"Italic"], 
    RowBox[{
     OverscriptBox[
      StyleBox["A",
       FontSlant->"Italic"], "^"], 
     StyleBox[
      SubscriptBox[
       StyleBox["\[Mu]",
        FontWeight->"Bold"], "x"],
      FontWeight->"Bold"]}], "|", 
    RowBox[{
     OverscriptBox[
      StyleBox["A",
       FontSlant->"Italic"], "^"], 
     SubscriptBox["\[Psi]", 
      RowBox[{"0", "vib"}]]}]}], 
   "\[RightAngleBracket]"}]}], "\[IndentingNewLine]", 
 RowBox[{"\t      ", 
  RowBox[{"=", 
   RowBox[{
    SubscriptBox["\[Chi]", 
     StyleBox[
      SubscriptBox["Q", "i"],
      FontSlant->"Italic"]], 
    RowBox[{"(", 
     OverscriptBox[
      StyleBox["A",
       FontSlant->"Italic"], "^"], ")"}], 
    SubscriptBox["\[Chi]", 
     SubscriptBox["\[Mu]", 
      StyleBox["x",
       FontSlant->"Italic"]]], 
    RowBox[{"(", 
     OverscriptBox[
      StyleBox["A",
       FontSlant->"Italic"], "^"], ")"}], 
    SubscriptBox["\[Chi]", 
     SubscriptBox[
      StyleBox["A",
       FontSlant->"Italic"], "1"]], 
    RowBox[{"(", 
     OverscriptBox[
      StyleBox["A",
       FontSlant->"Italic"], "^"], ")"}], 
    RowBox[{"\[LeftAngleBracket]", 
     RowBox[{
      SubscriptBox["\[Psi]", 
       RowBox[{"1", "vib"}]], 
      StyleBox["|",
       FontSlant->"Italic"], 
      SubscriptBox[
       StyleBox["\[Mu]",
        FontWeight->"Bold"], "x"], "|", 
      SubscriptBox["\[Psi]", 
       RowBox[{"0", "vib"}]]}], 
     "\[RightAngleBracket]"}]}]}]}], "\[IndentingNewLine]", 
 RowBox[{"\t      ", 
  RowBox[{"=", 
   RowBox[{
    SubscriptBox["\[Chi]", 
     StyleBox[
      SubscriptBox["Q", "i"],
      FontSlant->"Italic"]], 
    RowBox[{"(", 
     OverscriptBox[
      StyleBox["A",
       FontSlant->"Italic"], "^"], ")"}], 
    SubscriptBox["\[Chi]", 
     SubscriptBox["\[Mu]", 
      StyleBox["x",
       FontSlant->"Italic"]]], 
    RowBox[{"(", 
     OverscriptBox[
      StyleBox["A",
       FontSlant->"Italic"], "^"], ")"}], 
    RowBox[{"\[LeftAngleBracket]", 
     RowBox[{
      SubscriptBox["\[Psi]", 
       RowBox[{"1", "vib"}]], 
      StyleBox["|",
       FontSlant->"Italic"], 
      SubscriptBox[
       StyleBox["\[Mu]",
        FontWeight->"Bold"], "x"], "|", 
      SubscriptBox["\[Psi]", 
       RowBox[{"0", "vib"}]]}], 
     "\[RightAngleBracket]"}]}]}]}]}], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.816362560914196*^9, 3.8163626142846885`*^9}, {
  3.816363106319135*^9, 3.8163631847967477`*^9}, {3.816363242121337*^9, 
  3.816363255181043*^9}},ExpressionUUID->"93ee5c6d-eaae-4cf7-9c63-\
093f5d2fa6a9"],

Cell["\<\
Because the transition dipole moment should not change under any operation of \
the group, we must have that\
\>", "Text",
 CellChangeTimes->{{3.816363263978766*^9, 
  3.816363283072604*^9}},ExpressionUUID->"9f5b8929-b567-4798-bf57-\
f146d37f361e"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   SubscriptBox["\[Chi]", 
    StyleBox[
     SubscriptBox["Q", "i"],
     FontSlant->"Italic"]], 
   RowBox[{"(", 
    OverscriptBox[
     StyleBox["A",
      FontSlant->"Italic"], "^"], ")"}], 
   SubscriptBox["\[Chi]", 
    SubscriptBox["\[Mu]", 
     StyleBox["x",
      FontSlant->"Italic"]]], 
   RowBox[{"(", 
    OverscriptBox[
     StyleBox["A",
      FontSlant->"Italic"], "^"], ")"}]}], "=", 
  "1"}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.816362560914196*^9, 3.8163626142846885`*^9}, {
  3.816363106319135*^9, 3.8163631847967477`*^9}, {3.816363242121337*^9, 
  3.816363255181043*^9}, {3.8163632942102957`*^9, 
  3.8163632974978166`*^9}},ExpressionUUID->"35ae1f9c-b886-4551-aeae-\
7806be367a8e"],

Cell[TextData[{
 "This condition is only met if ",
 Cell[BoxData[
  StyleBox[
   SubscriptBox["Q", "i"],
   FontSlant->"Italic"]],
  CellChangeTimes->{{3.816362560914196*^9, 3.8163626142846885`*^9}, {
   3.816363106319135*^9, 3.8163631847967477`*^9}, {3.816363242121337*^9, 
   3.816363255181043*^9}, {3.8163632942102957`*^9, 3.8163632974978166`*^9}},
  ExpressionUUID->"265f50a9-083d-4aa5-b38f-a4774e0181f7"],
 " and ",
 Cell[BoxData[
  SubscriptBox["\[Mu]", 
   StyleBox["x",
    FontSlant->"Italic"]]],
  CellChangeTimes->{{3.816362560914196*^9, 3.8163626142846885`*^9}, {
   3.816363106319135*^9, 3.8163631847967477`*^9}, {3.816363242121337*^9, 
   3.816363255181043*^9}, {3.8163632942102957`*^9, 3.8163632974978166`*^9}},
  ExpressionUUID->"e5015879-5db3-4091-b64b-c35abf3c19be"],
 " belong to the same irreducible representation. In other words, ",
 Cell[BoxData[
  StyleBox[
   SubscriptBox["Q", "i"],
   FontSlant->"Italic"]],
  CellChangeTimes->{{3.816362560914196*^9, 3.8163626142846885`*^9}, {
   3.816363106319135*^9, 3.8163631847967477`*^9}, {3.816363242121337*^9, 
   3.816363255181043*^9}, {3.8163632942102957`*^9, 3.8163632974978166`*^9}},
  ExpressionUUID->"4bf0ea7e-9f04-4cfe-a452-a00da2e9807a"],
 " must belong to the same irreducible representation as ",
 StyleBox["x",
  FontSlant->"Italic"],
 ", ",
 StyleBox["y",
  FontSlant->"Italic"],
 ", or ",
 StyleBox["z",
  FontSlant->"Italic"],
 " to have nonzero infrared intensity. The irreducible representations to \
which ",
 StyleBox["x",
  FontSlant->"Italic"],
 ", ",
 StyleBox["y",
  FontSlant->"Italic"],
 ", and ",
 StyleBox["z",
  FontSlant->"Italic"],
 " belong are given by the penultimate column of the character table. "
}], "Text",
 CellChangeTimes->{{3.8163633421661735`*^9, 
  3.8163635196061487`*^9}},ExpressionUUID->"1c5f0874-0f38-492d-889a-\
f46ef5203cb7"],

Cell[TextData[{
 "A similar result is obtained for Raman activity, which depends on \
polarizability, except that the normal coordinate must belong to the same \
irreducible representation as a product of Cartesian coordinates (e.g. ",
 StyleBox["xy",
  FontSlant->"Italic"],
 ", ",
 StyleBox["yz",
  FontSlant->"Italic"],
 ", ",
 StyleBox["xz",
  FontSlant->"Italic"],
 ", ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["y", "2"], TraditionalForm]],ExpressionUUID->
  "ecca6e02-2880-434a-b603-6487e20ee7df"],
 ", ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["x", "2"], TraditionalForm]],ExpressionUUID->
  "595c5401-35a9-4d61-a7d1-d380a01f0367"],
 ", ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["z", "2"], TraditionalForm]],ExpressionUUID->
  "de4d7944-0eb9-49d8-b903-7a716228709d"],
 "). The irreducible representations of these transformations are given in \
the final column of the character table."
}], "Text",
 CellChangeTimes->{{3.8163635246487656`*^9, 
  3.816363638682506*^9}},ExpressionUUID->"07493fb1-d674-4a4d-b688-\
d96cb0508f6f"]
}, Open  ]]
}, Open  ]]
}, Open  ]]
},
