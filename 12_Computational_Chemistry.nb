Cell[TextData[{
 StyleBox["Figure 12.1.",
  FontWeight->"Bold"],
 " Plot of the radial component of the hydrogen 1s wavefunction (solid line) \
vs the Gaussian trial function optimized to yield the lowest energy (dashed \
line). The parameter \[Alpha] is given by ",
 Cell[BoxData[
  RowBox[{"\[Alpha]", "=", 
   FractionBox["8", 
    RowBox[{"9", "\[Pi]", " ", 
     SubsuperscriptBox[
      StyleBox["a",
       FontSlant->"Italic"], "0", "2"]}]]}]],
  CellChangeTimes->{{3.8119344223174734`*^9, 3.8119344618253365`*^9}},
  ExpressionUUID->"a1e92770-a7b5-4f40-87b4-88d6244526b9"],
 "."
}], "Affiliation",
 CellChangeTimes->{{3.809435027311596*^9, 3.8094350763900714`*^9}, {
   3.80943583474421*^9, 3.8094358359299717`*^9}, {3.8094472165104203`*^9, 
   3.809447281165168*^9}, {3.810054221304062*^9, 3.8100542409148703`*^9}, {
   3.8101125924447937`*^9, 3.8101126426025887`*^9}, {3.8101127071459217`*^9, 
   3.810112714050138*^9}, {3.810115126505663*^9, 3.810115154403865*^9}, {
   3.8101152097595587`*^9, 3.8101152368678613`*^9}, {3.8104844563968916`*^9, 
   3.8104844576598825`*^9}, {3.81193141565689*^9, 3.8119315300297594`*^9}, {
   3.8119337071325006`*^9, 3.811933740644105*^9}, {3.8119343804898696`*^9, 
   3.811934419448634*^9}, {3.811934465780332*^9, 3.8119344672733955`*^9}, {
   3.8119350679013205`*^9, 3.811935086595256*^9}, {3.814614320484557*^9, 
   3.814614322854318*^9}, 3.8146144024746094`*^9, 3.8148824401266165`*^9, 
   3.9392061407701054`*^9},ExpressionUUID->"28b0d63d-2d96-44aa-9862-\
c68ec098cac0"],

Cell["\<\
To account for this difference, the Slater-type functions are typically \
replaced by a linear combination of Gaussian functions,\
\>", "Text",
 CellChangeTimes->{{3.8146124387033644`*^9, 3.8146124546647415`*^9}, {
  3.814614297917238*^9, 3.814614350926196*^9}, {3.814614414900416*^9, 
  3.814614498724351*^9}, {3.814615587874685*^9, 
  3.8146155941664505`*^9}},ExpressionUUID->"b4602300-e9c6-417c-88f3-\
a2a14a4a79fc"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   SubsuperscriptBox["\[Phi]", 
    StyleBox["abc",
     FontSlant->"Italic"], "GTO"], 
   RowBox[{"(", 
    RowBox[{
     StyleBox["x",
      FontSlant->"Italic"], ",", 
     StyleBox["y",
      FontSlant->"Italic"], ",", 
     StyleBox["z",
      FontSlant->"Italic"]}], ")"}]}], "=", 
  RowBox[{
   StyleBox["N",
    FontSlant->"Italic"], 
   StyleBox[" ",
    FontSlant->"Italic"], 
   SuperscriptBox[
    StyleBox["x",
     FontSlant->"Italic"], 
    StyleBox["a",
     FontSlant->"Italic"]], 
   SuperscriptBox[
    StyleBox["y",
     FontSlant->"Italic"], 
    StyleBox["b",
     FontSlant->"Italic"]], 
   SuperscriptBox[
    StyleBox["z",
     FontSlant->"Italic"], 
    StyleBox["c",
     FontSlant->"Italic"]], 
   RowBox[{"(", 
    RowBox[{
     SuperscriptBox["\[ExponentialE]", 
      RowBox[{
       RowBox[{"-", 
        SubscriptBox[
         StyleBox["\[Zeta]",
          FontSlant->"Plain"], "1"]}], 
       SuperscriptBox[
        StyleBox["r",
         FontSlant->"Italic"], "2"]}]], "+", 
     SuperscriptBox["\[ExponentialE]", 
      RowBox[{
       RowBox[{"-", 
        SubscriptBox[
         StyleBox["\[Zeta]",
          FontSlant->"Plain"], "2"]}], 
       SuperscriptBox[
        StyleBox["r",
         FontSlant->"Italic"], "2"]}]], "+", 
     SuperscriptBox["\[ExponentialE]", 
      RowBox[{
       RowBox[{"-", 
        SubscriptBox[
         StyleBox["\[Zeta]",
          FontSlant->"Plain"], "3"]}], 
       SuperscriptBox[
        StyleBox["r",
         FontSlant->"Italic"], "2"]}]]}], ")"}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.811593312893673*^9, 3.8115933831661987`*^9}, {
   3.811593458953679*^9, 3.8115934974178753`*^9}, {3.811594043422389*^9, 
   3.8115940850450926`*^9}, {3.8115941212928057`*^9, 3.81159413134099*^9}, {
   3.8115942129312763`*^9, 3.811594213576462*^9}, {3.811594345555955*^9, 
   3.8115943458791523`*^9}, 3.8115943810138807`*^9, {3.8118583015457077`*^9, 
   3.8118583904266043`*^9}, {3.8118668881127214`*^9, 3.811866985652667*^9}, {
   3.81187008170006*^9, 3.8118700849636593`*^9}, {3.8118701593125334`*^9, 
   3.811870201331394*^9}, {3.811935703417695*^9, 3.8119357133826056`*^9}, {
   3.8119449835579224`*^9, 3.8119450568130407`*^9}, 3.8119451443759785`*^9, {
   3.814606778471686*^9, 3.8146067795513096`*^9}, {3.8146068273815556`*^9, 
   3.814606904418*^9}, {3.814607322020729*^9, 3.814607342514814*^9}, {
   3.8146101267236547`*^9, 3.814610130170759*^9}, {3.8146145101469207`*^9, 
   3.8146145451325207`*^9}},ExpressionUUID->"0f4753be-8d95-4c52-8ab2-\
47c76a69232c"],

Cell[TextData[{
 "An example of a three-term fitting to the radial component of a hydrogen 1",
 StyleBox["s",
  FontSlant->"Italic"],
 " orbital is shown in Figure 12.2. Each Gaussian term in the sum is known as \
a primitive. The combination functions are typically labeled with the form \
STO\[Dash]",
 StyleBox["x",
  FontSlant->"Italic"],
 "G, where ",
 StyleBox["x",
  FontSlant->"Italic"],
 " gives the number of Gaussian terms. For example STO-3G would mean the \
Slater-type orbital is represented by a linear combination of three Gaussian \
functions, as in Figure 12.2."
}], "Text",
 CellChangeTimes->{{3.814614494289974*^9, 3.814614497184456*^9}, {
