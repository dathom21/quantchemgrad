ba8b24e2d757"],

Cell[BoxData[
 RowBox[{
  FractionBox[
   StyleBox[
    RowBox[{
     SubscriptBox["m", "p"], 
     SubscriptBox["m", "e"]}],
    FontSlant->"Italic"], 
   RowBox[{
    StyleBox[
     SubscriptBox["m", "p"],
     FontSlant->"Italic"], "+", 
    StyleBox[
     SubscriptBox["m", "e"],
     FontSlant->"Italic"]}]], "=", 
  RowBox[{
   RowBox[{"5.48281", " ", "\[Times]", 
    SuperscriptBox["10", 
     RowBox[{"-", "4"}]], "  ", "Da"}], " ", "\[TildeTilde]", 
   StyleBox[
    SubscriptBox["m", "e"],
    FontSlant->"Italic"]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.810478938167596*^9, 3.810478955242468*^9}, {
  3.8104790350150933`*^9, 3.8104790752316113`*^9}, {3.8104791945947237`*^9, 
  3.81047920178861*^9}},ExpressionUUID->"b8deadac-be66-4342-9054-\
d8b6e1fc7ee3"],

Cell[TextData[{
 "Similarly, the location of the center of mass is approximately equal to the \
location of the proton. To simplify everything, we then represent the system \
as an electron of mass ",
 Cell[BoxData[
  StyleBox[
   SubscriptBox["m", "e"],
   FontSlant->"Italic"]],
  CellChangeTimes->{{3.810478938167596*^9, 3.810478955242468*^9}, {
   3.8104790350150933`*^9, 3.8104790752316113`*^9}, {3.8104791945947237`*^9, 
   3.81047920178861*^9}},ExpressionUUID->
  "3b8ed36b-9f4c-4f66-a285-53b5e6b09902"],
 " at distance ",
 StyleBox["r",
  FontSlant->"Italic"],
 " from the proton."
}], "Text",
 CellChangeTimes->{{3.8104792335206375`*^9, 
  3.8104793292016497`*^9}},ExpressionUUID->"9ad33f4d-3f61-442b-aa9f-\
2bca1cbaba19"]
}, Open  ]],

Cell[CellGroupData[{

Cell["The Potential Function", "Subsection",
 CellChangeTimes->{{3.810479300424015*^9, 3.81047930364119*^9}, {
  3.8104793640442066`*^9, 
  3.8104793662060823`*^9}},ExpressionUUID->"a10a707f-e3d4-4eb4-ae10-\
062cedf1219c"],

Cell["\<\
Because the proton and electron are both charged particles with equal and \
opposite charges of\
\>", "Text",
 CellChangeTimes->{{3.8104780850264416`*^9, 3.810478158007231*^9}, {
  3.810478188272515*^9, 3.810478213897179*^9}, {3.810478256457456*^9, 
  3.8104783444208865`*^9}, {3.8104783834411936`*^9, 3.810478390185643*^9}, {
  3.8104784829177494`*^9, 3.810478540472525*^9}, {3.8104785733790383`*^9, 
  3.810478609883218*^9}, {3.810478734228631*^9, 3.8104787474310246`*^9}, {
  3.810479416988557*^9, 
  3.8104794507668905`*^9}},ExpressionUUID->"9de76810-e9a8-4dcf-aa22-\
6b46a252e7e6"],

Cell[BoxData[
 RowBox[{
  StyleBox["e",
   FontSlant->"Italic"], "=", 
  RowBox[{"1.602176634", "\[Times]", 
   SuperscriptBox["10", 
    RowBox[{"-", "19"}]], " ", "C"}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.810112811439228*^9, 3.8101128248442793`*^9}, {
  3.810479494926491*^9, 
  3.8104795038498344`*^9}},ExpressionUUID->"76c669b6-64a9-47ae-9dbd-\
e3182e82125b"],

Cell["they interact through a Coulombic potential given by", "Text",
 CellChangeTimes->{{3.8104795189729996`*^9, 
  3.810479561330971*^9}},ExpressionUUID->"cc30a601-5fc9-4d69-9b30-\
cdb196457d89"],

Cell[BoxData[
 RowBox[{
  StyleBox[
   RowBox[{"V", 
    RowBox[{"(", "r", ")"}]}],
   FontSlant->"Italic"], "=", 
  RowBox[{"-", 
   FractionBox[
    SuperscriptBox[
     StyleBox["e",
      FontSlant->"Italic"], "2"], 
    RowBox[{"4", 
     SubscriptBox["\[Pi]\[Epsilon]", "0"], 
     StyleBox["r",
      FontSlant->"Italic"]}]]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.810112811439228*^9, 3.8101128248442793`*^9}, {
  3.810479494926491*^9, 3.8104795038498344`*^9}, {3.810479572543576*^9, 
  3.8104796147383184`*^9}},ExpressionUUID->"961636c7-8626-4190-80b1-\
45dc6237e3d9"],

Cell[TextData[{
 "where ",
 Cell[BoxData[
  SubscriptBox["\[Epsilon]", "0"]],
  CellChangeTimes->{{3.810112811439228*^9, 3.8101128248442793`*^9}, {
   3.810479494926491*^9, 3.8104795038498344`*^9}, {3.810479572543576*^9, 
   3.8104796147383184`*^9}},ExpressionUUID->
  "2388ab0e-7c4d-43f3-ab44-23c5d3fddc65"],
 " is the permittivity of free space defined as "
}], "Text",
 CellChangeTimes->{{3.8104796233997693`*^9, 
  3.8104796595029497`*^9}},ExpressionUUID->"3b09b3d9-7a7d-49c0-8715-\
7b209ebb8b4f"],

Cell[BoxData[
 RowBox[{
  SubscriptBox["\[Epsilon]", "0"], "=", 
  RowBox[{"8.8541878128", "\[Times]", 
   SuperscriptBox["10", 
    RowBox[{"-", "12"}]], " ", "F", " ", 
   SuperscriptBox["m", 
    RowBox[{"-", "1"}]]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.810112811439228*^9, 3.8101128248442793`*^9}, {
  3.810479494926491*^9, 3.8104795038498344`*^9}, {3.810479667124099*^9, 
  3.810479702431532*^9}},ExpressionUUID->"5097afe6-ea36-4480-a2ee-\
e713d536edab"],

Cell[TextData[{
 "The fact that our potential function depends on the distance ",
 StyleBox["r",
  FontSlant->"Italic"],
 " and not on any relative orientation suggests that we should use a \
spherical coordinates system for our Schr\[ODoubleDot]dinger equation."
}], "Text",
 CellChangeTimes->{{3.8104797667440805`*^9, 
  3.8104798097634506`*^9}},ExpressionUUID->"83392752-84e9-4899-a173-\
461130d10b7a"]
}, Open  ]],

Cell[CellGroupData[{

Cell["The Hamiltonian for a Hydrogen Atom", "Subsection",
 CellChangeTimes->{{3.810479300424015*^9, 3.81047930364119*^9}, {
  3.8104793640442066`*^9, 3.8104793662060823`*^9}, {3.810479833352313*^9, 
  3.8104798431397777`*^9}},ExpressionUUID->"6f8e1a35-a86a-49d6-816a-\
ef6811873fd6"],

Cell["\<\
Based on the reduced mass discussion and the form of our potential function \
above we can write the Hamiltonian operator for the hydrogen atom as\
\>", "Text",
 CellChangeTimes->{{3.81047986219586*^9, 3.8104798685574665`*^9}, {
  3.8104801846474605`*^9, 3.8104801981917667`*^9}, {3.8104802495675573`*^9, 
  3.8104802549725895`*^9}},ExpressionUUID->"6eed882b-d035-4e2c-999f-\
588139dd1a1a"],

Cell[BoxData[
 RowBox[{
  OverscriptBox[
   StyleBox["H",
    FontSlant->"Italic"], "^"], "=", 
  RowBox[{
   RowBox[{"-", 
    FractionBox[
     SuperscriptBox["\[HBar]", "2"], 
     RowBox[{"2", 
      StyleBox[
       SubscriptBox["m", "e"],
       FontSlant->"Italic"]}]]}], 
   RowBox[{
    SuperscriptBox["\[Del]", "2"], 
    RowBox[{"-", 
     FractionBox[
      SuperscriptBox[
       StyleBox["e",
        FontSlant->"Italic"], "2"], 
      RowBox[{"4", 
       SubscriptBox["\[Pi]\[Epsilon]", "0"], 
       StyleBox["r",
        FontSlant->"Italic"]}]]}]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.810112811439228*^9, 3.8101128248442793`*^9}, {
  3.810479494926491*^9, 3.8104795038498344`*^9}, {3.810479572543576*^9, 
  3.8104796147383184`*^9}, {3.8104802055659895`*^9, 3.8104802433915305`*^9}, {
  3.8104802785189395`*^9, 
  3.8104802814214115`*^9}},ExpressionUUID->"6e07db9f-90a3-44b4-8da0-\
068493b0c5fb"],

Cell["\<\
Remember from the previous lesson on the rigid rotor that the Laplacian in \
spherical coordinates is written\
\>", "Text",
 CellChangeTimes->{{3.810480294110199*^9, 
  3.810480313917305*^9}},ExpressionUUID->"21093451-0213-463f-a322-\
6c38a2dcc2df"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    SuperscriptBox["\[Del]", "2"], "=", 
    FractionBox["1", 
     SuperscriptBox[
      StyleBox["r",
       FontSlant->"Italic"], "2"]]}], 
   RowBox[{
    FractionBox["\[PartialD]", 
     RowBox[{"\[PartialD]", 
      StyleBox["r",
       FontSlant->"Italic"]}]], 
    RowBox[{"(", 
     RowBox[{
      SuperscriptBox[
       StyleBox["r",
        FontSlant->"Italic"], "2"], 
      FractionBox["\[PartialD]", 
       RowBox[{"\[PartialD]", 
        StyleBox["r",
         FontSlant->"Italic"]}]]}], ")"}]}]}], "+", 
  RowBox[{
   FractionBox["1", 
    RowBox[{
     SuperscriptBox[
      StyleBox["r",
       FontSlant->"Italic"], "2"], "sin", 
     RowBox[{"(", "\[Theta]", ")"}]}]], 
   RowBox[{
    FractionBox["\[PartialD]", 
     RowBox[{"\[PartialD]", "\[Theta]"}]], 
    RowBox[{"(", 
     RowBox[{"sin", 
      RowBox[{"(", "\[Theta]", ")"}], 
      FractionBox["\[PartialD]", 
       RowBox[{"\[PartialD]", "\[Theta]"}]]}], ")"}]}]}], "+", 
  RowBox[{
   FractionBox["1", 
    RowBox[{
     SuperscriptBox[
      StyleBox["r",
       FontSlant->"Italic"], "2"], 
     SuperscriptBox["sin", "2"], 
     RowBox[{"(", "\[Theta]", ")"}]}]], 
   RowBox[{"(", 
    FractionBox[
     SuperscriptBox["\[PartialD]", "2"], 
     RowBox[{"\[PartialD]", 
      SuperscriptBox["\[Phi]", "2"]}]], ")"}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8079734359242287`*^9, 3.8079734595866747`*^9}, {
   3.8079735259616528`*^9, 3.807973556017437*^9}, {3.8101148246033597`*^9, 
   3.8101148337760096`*^9}, {3.8101155026418304`*^9, 3.810115681440522*^9}, 
   3.8101157585076213`*^9, {3.810480335671856*^9, 
   3.8104803459129114`*^9}},ExpressionUUID->"466dbd0a-f766-42c2-9555-\
660a37ccd21a"]
}, Open  ]]
