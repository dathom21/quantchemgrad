   3.914416545406904*^9}, {3.9144166999630556`*^9, 3.9144167008460875`*^9}, {
   3.914416765395209*^9, 3.914416819325585*^9}},ExpressionUUID->
  "b528d6a6-aeed-4714-82cf-bc0f5dbd1b53"],
 "equal, we end up with"
}], "Text",
 CellChangeTimes->{{3.9144168216220264`*^9, 
  3.914416838908523*^9}},ExpressionUUID->"b95f474a-0667-49a6-a455-\
4501dcad2cb6"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   SuperscriptBox[
    StyleBox["ml",
     FontSlant->"Italic"], "2"], 
   FractionBox[
    RowBox[{
     SuperscriptBox["\[DifferentialD]", "2"], "\[Theta]"}], 
    RowBox[{"\[DifferentialD]", 
     SuperscriptBox[
      StyleBox["t",
       FontSlant->"Italic"], "2"]}]]}], "=", 
  RowBox[{
   RowBox[{"-", 
    StyleBox["mgl",
     FontSlant->"Italic"]}], 
   StyleBox[" ",
    FontSlant->"Italic"], "sin", 
   RowBox[{"(", "\[Theta]", ")"}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.9144110221722584`*^9, 3.9144110251791077`*^9}, {
  3.9144111820235987`*^9, 3.9144112064138207`*^9}, {3.9144112438703938`*^9, 
  3.9144112575699005`*^9}, {3.914411336972353*^9, 3.9144113705117893`*^9}, {
  3.9144114056902256`*^9, 3.9144114238165298`*^9}, {3.9144149904644547`*^9, 
  3.914414994963703*^9}, {3.9144162577997284`*^9, 3.914416264452047*^9}, {
  3.91441633851143*^9, 3.9144163712990932`*^9}, {3.9144165386467295`*^9, 
  3.914416545406904*^9}, {3.914416579872903*^9, 3.914416585553296*^9}, {
  3.91441662863968*^9, 3.9144166430991335`*^9}, {3.9144168525139256`*^9, 
  3.9144169160222178`*^9}},ExpressionUUID->"cc8846d7-8626-4d26-920d-\
17f05ade787f"],

Cell["Then, eliminating common factors yields", "Text",
 CellChangeTimes->{{3.9144169191083746`*^9, 
  3.914416933412354*^9}},ExpressionUUID->"1bfdfa27-3e43-4c2d-ab2b-\
e4f01e84dd8d"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   StyleBox["l",
    FontSlant->"Italic"], 
   FractionBox[
    RowBox[{
     SuperscriptBox["\[DifferentialD]", "2"], "\[Theta]"}], 
    RowBox[{"\[DifferentialD]", 
     SuperscriptBox[
      StyleBox["t",
       FontSlant->"Italic"], "2"]}]]}], "=", 
  RowBox[{
   RowBox[{"-", 
    StyleBox["g",
     FontSlant->"Italic"]}], 
   StyleBox[" ",
    FontSlant->"Italic"], "sin", 
   RowBox[{"(", "\[Theta]", ")"}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.9144169372383456`*^9, 
  3.9144169476421003`*^9}},ExpressionUUID->"29bc1006-0cfe-438d-9a12-\
3c94dedc76ac"],

Cell["or ", "Text",
 CellChangeTimes->{{3.9144169497914424`*^9, 
  3.9144169502001514`*^9}},ExpressionUUID->"eb4dfc57-0905-4922-862a-\
0c4b2ec47024"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   FractionBox[
    RowBox[{
     SuperscriptBox["\[DifferentialD]", "2"], "\[Theta]"}], 
    RowBox[{"\[DifferentialD]", 
     SuperscriptBox[
      StyleBox["t",
       FontSlant->"Italic"], "2"]}]], "+", 
   RowBox[{
    RowBox[{"(", 
     FractionBox[
      StyleBox["g",
       FontSlant->"Italic"], 
      StyleBox["l",
       FontSlant->"Italic"]], ")"}], 
    StyleBox[" ",
     FontSlant->"Italic"], "sin", 
    RowBox[{"(", "\[Theta]", ")"}]}]}], "=", "0"}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.9144169372383456`*^9, 
  3.9144169753211613`*^9}},ExpressionUUID->"9c044fa9-b7f1-4137-947a-\
2027577aa8e2"],

Cell["\<\
which is exactly the same as equation (8) that we obtained by Newtonian \
mechanics!\
\>", "Text",
 CellChangeTimes->{{3.9144169951826663`*^9, 3.914417031031337*^9}, {
  3.933948118038103*^9, 
  3.933948118338215*^9}},ExpressionUUID->"ba699177-28fe-4413-8d34-\
a0b5e93ff772"],

Cell[CellGroupData[{

Cell["Takeaways from Hamiltonian mechanics", "Subsubsection",
 CellChangeTimes->{{3.9144170984676867`*^9, 
  3.9144171235483866`*^9}},ExpressionUUID->"8f239508-2111-4e97-82bd-\
7872025994ec"],

Cell["\<\
If you haven\[CloseCurlyQuote]t worked with Hamiltonian mechanics before, the \
previous section may have been a bit confusing. The takeaways that are \
important for this class moving forward are\
\>", "Text",
 CellChangeTimes->{{3.914417126351416*^9, 
  3.9144171588519397`*^9}},ExpressionUUID->"a399cf1f-3f48-4d79-851f-\
ab3883689220"],

Cell["\<\
Equivalent to a Newtonian (force-based) description of a system, we can use a \
Hamiltonian description that involves the sum of kinetic and potential \
energies.\
\>", "Item",
 CellChangeTimes->{{3.914417165831445*^9, 
  3.91441724279072*^9}},ExpressionUUID->"1a0bcd82-ef05-40f2-99c3-\
509765b27b05"],

Cell["\<\
There is a relationship between the kinetic energy term and the momentum of \
the system.\
\>", "Item",
 CellChangeTimes->{{3.914417165831445*^9, 
  3.9144172444729133`*^9}},ExpressionUUID->"7635d9b8-eef6-4637-b982-\
a2b0795d6a64"],

Cell["\<\
Either description provides the same result for the evolution of the system \
in time.\
\>", "Item",
 CellChangeTimes->{{3.914417165831445*^9, 
  3.9144172771354585`*^9}},ExpressionUUID->"da024caf-63e6-4f48-8c0c-\
b9a2957e1711"]
}, Open  ]]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Complex numbers - a review", "Section",
 CellChangeTimes->{{3.914406997159396*^9, 
  3.914407000867257*^9}},ExpressionUUID->"c4390c1c-61aa-4cc2-ae6d-\
47746bc6374c"],

Cell[CellGroupData[{

Cell["The \[OpenCurlyDoubleQuote]Imaginary\[CloseCurlyDoubleQuote] Number", \
"Subsection",
 CellChangeTimes->{{3.807375507489319*^9, 
  3.8073755161671085`*^9}},ExpressionUUID->"3c1779a8-6a94-6140-86f3-\
e7f147da4373"],

Cell[TextData[{
 StyleBox["The imaginary number, which we will call \[ImaginaryI]",
  FontFamily->"Source Serif Pro"],
 StyleBox[" ",
  FontFamily->"Source Serif Pro",
  FontSlant->"Italic"],
 StyleBox["but is also referred to as \[ImaginaryJ], is defined as",
  FontFamily->"Source Serif Pro"]
}], "Text",
 CellChangeTimes->{{3.8073755282155204`*^9, 3.807375849197941*^9}, {
   3.807375884523903*^9, 3.8073759171664467`*^9}, {3.8073760286886454`*^9, 
   3.8073761959212675`*^9}, {3.807377160685053*^9, 3.807377160685053*^9}, 
   3.807445058195981*^9, {3.8395079673293905`*^9, 3.8395079842758665`*^9}, 
   3.839508357333066*^9, 3.8395083975458527`*^9, {3.871547801710446*^9, 
   3.871547815718996*^9}, {3.9339330133892536`*^9, 
   3.9339330145720787`*^9}},ExpressionUUID->"29bffcbb-294f-9345-a8c4-\
f918bffef5bd"],

Cell[BoxData[
 RowBox[{
  SuperscriptBox["\[ImaginaryI]", "2"], "=", 
  RowBox[{"\[Minus]", "1"}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8395080349644094`*^9, 
  3.839508078266085*^9}},ExpressionUUID->"56f39332-2bad-904b-ac58-\
fdf7075c5ed3"],

Cell[TextData[StyleBox["But why would we ever need such a number? Well, if \
you want to solve the roots of the equation",
 FontFamily->"Source Serif Pro"]], "Text",
 CellChangeTimes->{
  3.8395079910720377`*^9, {3.8395080916140842`*^9, 3.83950809396797*^9}, {
   3.933933034814039*^9, 
   3.93393304129867*^9}},ExpressionUUID->"c44c624d-899d-fe49-8f2e-\
aa2f22c2bdac"],

Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{
    SuperscriptBox[
     StyleBox["x",
      FontSlant->"Italic"], "2"], "+", "1"}], "=", "0"}], 
  TraditionalForm]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8395081096564217`*^9, 
  3.8395081327952623`*^9}},ExpressionUUID->"144448e7-d020-5e49-b1c6-\
55f858f9bd9f"],

Cell[TextData[StyleBox["you get",
 FontFamily->"Source Serif Pro"]], "Text",
 CellChangeTimes->{{3.8395081000133452`*^9, 3.839508103848596*^9}, {
  3.8395081455260267`*^9, 
  3.8395081539778166`*^9}},ExpressionUUID->"afccae29-33a0-c24c-89f5-\
536f3cfacb4d"],

Cell[BoxData[
 RowBox[{
  StyleBox["x",
   FontSlant->"Italic"], 
  StyleBox["=",
   FontSlant->"Plain"], 
  RowBox[{"\[PlusMinus]", 
   SqrtBox[
    RowBox[{"\[Minus]", "1"}]]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.839508174678363*^9, 3.839508251786166*^9}, {
  3.8395082980436754`*^9, 
  3.839508309466117*^9}},ExpressionUUID->"fb14d9c0-7c0a-014a-983d-\
5aab7ca83e04"],

Cell["or", "Text",
 CellChangeTimes->{{3.8395082223008947`*^9, 3.8395082292221127`*^9}, {
  3.8395083185012755`*^9, 
  3.83950832063002*^9}},ExpressionUUID->"4d276963-3441-1e46-bc3c-\
feee7ab9e14c"],

Cell[BoxData[
 RowBox[{
  StyleBox["x",
   FontSlant->"Italic"], "=", 
  RowBox[{"\[PlusMinus]", "\[ImaginaryI]"}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.839508339974831*^9, 
  3.839508346068205*^9}},ExpressionUUID->"32ed403e-1acf-c24f-9ba2-\
d92d4e670ba1"]
}, Open  ]],

Cell[CellGroupData[{

Cell["The Complex Plane", "Subsection",
 CellChangeTimes->{{3.8073762355990458`*^9, 
  3.8073762381498117`*^9}},ExpressionUUID->"13717f1c-4834-4ffb-9344-\
40f110fb7964"],

Cell[TextData[{
 "We want to talk about the combination of imaginary numbers and what we call \
real numbers (the numbers you are more accustomed to). When we combine a real \
number ",
 StyleBox["x",
  FontSlant->"Italic"],
 " with an imaginary number \[ImaginaryI]",
 StyleBox["y",
  FontSlant->"Italic"],
 ", we get a complex number ",
 StyleBox["z",
  FontSlant->"Italic"],
 " given by"
}], "Text",
 CellChangeTimes->{
  3.83950901182691*^9, {3.839509070987316*^9, 3.839509109147562*^9}, {
   3.839509142941682*^9, 3.839509143948043*^9}, {3.9338592937184906`*^9, 
   3.9338593016140614`*^9}},ExpressionUUID->"62cbeb80-782d-8542-afc8-\
02332ff917f2"],

Cell[BoxData[
 RowBox[{
  StyleBox["z",
   FontSlant->"Italic"], "=", 
  RowBox[{
   StyleBox["x",
    FontSlant->"Italic"], "+", 
   StyleBox[
    RowBox[{"\[ImaginaryI]", 
     StyleBox["y",
      FontSlant->"Italic"]}]]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8395084318312426`*^9, 
  3.8395084393806396`*^9}},ExpressionUUID->"d30f9475-0263-401d-a85a-\
496f896d4208"],

Cell["\<\
We also need to note some properties of complex numbers that hopefully you \
can visualize if you think about the complex plane. If you add complex \
numbers, then you just add their real and imaginary parts\
\>", "Text",
 CellChangeTimes->{
  3.83950901182691*^9, {3.839509070987316*^9, 3.839509109147562*^9}, {
   3.839509142941682*^9, 3.839509143948043*^9}, {3.9338592937184906`*^9, 
   3.933859319954483*^9}},ExpressionUUID->"19c9008e-e30b-7245-abb7-\
495062dcbd92"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   SubscriptBox[
    StyleBox["z",
     FontSlant->"Italic"], "1"], "+", 
   SubscriptBox[
    StyleBox["z",
     FontSlant->"Italic"], "2"]}], "=", 
  RowBox[{
   RowBox[{"(", 
    RowBox[{
     SubscriptBox[
      StyleBox["x",
       FontSlant->"Italic"], "1"], "+", 
     SubscriptBox[
      StyleBox["x",
       FontSlant->"Italic"], "2"]}], ")"}], "+", 
   RowBox[{"\[ImaginaryI]", 
    RowBox[{"(", 
     RowBox[{
      SubscriptBox[
       StyleBox["y",
        FontSlant->"Italic"], "1"], "+", 
      SubscriptBox[
       StyleBox["y",
        FontSlant->"Italic"], "2"]}], ")"}]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.839509022517037*^9, 
  3.8395090661442866`*^9}},ExpressionUUID->"72c2cbde-9b47-4c3d-8f05-\
11fac91d921f"],

Cell[TextData[{
 "We can visualize the value ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["z",
     FontSlant->"Italic"], "1"], "+", 
   SubscriptBox[
    StyleBox["z",
     FontSlant->"Italic"], "2"]}]],
  CellChangeTimes->{{3.839509022517037*^9, 3.8395090661442866`*^9}},
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "14133ddf-e389-4972-acd5-ff274549fddb"],
 " in a plot as the addition of two vectors"
}], "Text",
 CellChangeTimes->{
  3.83950901182691*^9, {3.839509070987316*^9, 3.839509109147562*^9}, {
   3.839509142941682*^9, 
   3.839509143948043*^9}},ExpressionUUID->"03aa1bca-f1f7-4b4c-b2fd-\
12735cb92048"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"(", 
    RowBox[{"2", "+", 
     RowBox[{"4", "\[ImaginaryI]"}]}], ")"}], "+", 
   RowBox[{"(", 
    RowBox[{"1", "\[Minus]", 
     RowBox[{"3", "\[ImaginaryI]"}]}], ")"}]}], "=", 
  RowBox[{
   RowBox[{
    RowBox[{"(", 
     RowBox[{"2", "+", "1"}], ")"}], "+", 
    RowBox[{"\[ImaginaryI]", 
     RowBox[{"(", 
      RowBox[{"4", "\[Minus]", "3"}], ")"}]}]}], "=", 
   RowBox[{"3", "+", "\[ImaginaryI]"}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8395091650862646`*^9, 
  3.839509197941635*^9}},ExpressionUUID->"4425c1df-1234-4649-822f-\
4f42a9ebeb74"],

