Cell[CellGroupData[{

Cell["Newtonian and Hamiltonian Mechanics", "Section",
 CellChangeTimes->{{3.9144093712186832`*^9, 3.9144093830153346`*^9}, {
  3.9144135240069933`*^9, 
  3.9144135287047863`*^9}},ExpressionUUID->"e030ab13-d8ff-410d-9b54-\
9d28d66cecb1"],

Cell[CellGroupData[{

Cell["Reminder - working with derivatives and partial derivatives", \
"Subsection",
 CellChangeTimes->{{3.9146657655254736`*^9, 
  3.9146657720863724`*^9}},ExpressionUUID->"6bc5a112-28c7-4616-9458-\
025093a9ea98"],

Cell[TextData[{
 "In case you haven\[CloseCurlyQuote]t worked with partial derivatives in a \
while, let\[CloseCurlyQuote]s briefly review some concepts. \n\nA derivative, \
recall, just tells us how a function changes with respect to a variable. So \
for example, if ",
 StyleBox["f(t) ",
  FontSlant->"Italic"],
 " gives the position as a function of time"
}], "Text",
 CellChangeTimes->{{3.807618710973903*^9, 3.8076187576530156`*^9}, {
   3.807631997385412*^9, 3.807632052912342*^9}, {3.8076320840808015`*^9, 
   3.8076321111314836`*^9}, {3.807632239402089*^9, 3.807632263596979*^9}, {
   3.8076324553616724`*^9, 3.8076325666579638`*^9}, {3.8076326844713645`*^9, 
   3.8076327043391066`*^9}, {3.807632917044757*^9, 3.807632917174731*^9}, 
   3.8076334431757746`*^9, {3.8076335045253*^9, 3.8076335270680933`*^9}, {
   3.807868772618793*^9, 3.807868773551629*^9}, {3.8078688108952384`*^9, 
   3.807868811837223*^9}, {3.9146656439071045`*^9, 3.914665644145259*^9}, {
   3.914665806875736*^9, 
   3.914665808857382*^9}},ExpressionUUID->"50c7cb9d-800a-4fe0-b3b0-\
f8ef692b064c"],

Cell[BoxData[
 RowBox[{
  FractionBox[
   RowBox[{
    RowBox[{
     StyleBox["\[DifferentialD]",
      FontSlant->"Plain"], 
     StyleBox["f",
      FontSlant->"Italic"]}], 
    RowBox[{"(", 
     StyleBox["t",
      FontSlant->"Italic"], ")"}]}], 
   RowBox[{
    StyleBox["\[DifferentialD]",
     FontSlant->"Plain"], 
    StyleBox["t",
     FontSlant->"Italic"]}]], "=", 
  StyleBox[
   RowBox[{"v", 
    RowBox[{"(", "t", ")"}]}],
   FontSlant->"Italic"]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8076325744477515`*^9, 3.8076326256098537`*^9}, {
  3.807632707363511*^9, 3.807632710811061*^9}, {3.807632765024428*^9, 
  3.8076327665378156`*^9}, {3.914668366137374*^9, 
  3.9146683728638477`*^9}},ExpressionUUID->"e9546ad5-bb06-4988-a7e8-\
11a5e43df956"],

Cell[TextData[{
 "where ",
 StyleBox["v",
  FontSlant->"Italic"],
 " is the velocity. So the derivative gives us the change in position with \
respect to time, or velocity. If we take the second derivative,"
}], "Text",
 CellChangeTimes->{{3.8076326421502495`*^9, 3.8076326571953325`*^9}, {
  3.8076327163600063`*^9, 
  3.8076328021922884`*^9}},ExpressionUUID->"3108f04d-5b82-4b97-9c64-\
be4f4e95a0fd"],

Cell[BoxData[
 RowBox[{
  FractionBox[
   RowBox[{
    RowBox[{
     SuperscriptBox["\[DifferentialD]", "2"], 
     StyleBox["f",
      FontSlant->"Italic"]}], 
    RowBox[{"(", 
     StyleBox["t",
      FontSlant->"Italic"], ")"}]}], 
   RowBox[{"\[DifferentialD]", 
    SuperscriptBox[
     StyleBox["t",
      FontSlant->"Italic"], "2"]}]], "=", 
  RowBox[{
   FractionBox[
    RowBox[{
     RowBox[{"\[DifferentialD]", 
      StyleBox["v",
       FontSlant->"Italic"]}], 
     RowBox[{"(", 
      StyleBox["t",
       FontSlant->"Italic"], ")"}]}], 
    RowBox[{"\[DifferentialD]", 
     StyleBox["t",
      FontSlant->"Italic"]}]], "=", 
   StyleBox[
    RowBox[{"a", 
     RowBox[{"(", "t", ")"}]}],
    FontSlant->"Italic"]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8076328105429087`*^9, 3.8076328478416767`*^9}, {
  3.914668377343692*^9, 
  3.9146683954817595`*^9}},ExpressionUUID->"20ac1a72-7c6e-4236-ad7c-\
bcd5eca4d04b"],

Cell[TextData[{
 "we get the acceleration ",
 StyleBox["a",
  FontSlant->"Italic"],
 ". So the second derivative tells us the rate of change in the rate of \
change of the position, or the rate of change in the velocity, which is the \
acceleration rate.\n\nSo now, if we have a function of two variables, ",
 StyleBox["u ",
  FontSlant->"Italic"],
 "(",
 StyleBox["x, t ",
  FontSlant->"Italic"],
 "), and we take a partial derivative,"
}], "Text",
 CellChangeTimes->{{3.807632855029997*^9, 3.8076329582802987`*^9}, {
  3.8087596424557753`*^9, 
  3.8087596460537844`*^9}},ExpressionUUID->"665a3738-9cc0-4215-8dca-\
a91a1d962659"],

Cell[BoxData[
 FractionBox[
  RowBox[{
   RowBox[{
    SuperscriptBox["\[PartialD]", "2"], 
    StyleBox["u",
     FontSlant->"Italic"]}], 
   RowBox[{"(", 
    RowBox[{
     StyleBox["x",
      FontSlant->"Italic"], ",", 
     StyleBox["t",
      FontSlant->"Italic"]}], ")"}]}], 
  RowBox[{"\[PartialD]", 
   SuperscriptBox[
    StyleBox["t",
     FontSlant->"Italic"], "2"]}]]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.807632972924408*^9, 
  3.8076329804094396`*^9}},ExpressionUUID->"c68efa6f-95e3-411e-bba8-\
7694e8bc87ec"],

Cell[TextData[{
 "that describes only how the function ",
 StyleBox["u",
  FontSlant->"Italic"],
 " changes with time for a given position (specifically, this second partial \
derivative tells us the rate of change in the rate of change of ",
 StyleBox["u",
  FontSlant->"Italic"],
 "). It doesn\[CloseCurlyQuote]t tell us how the function ",
 StyleBox["u",
  FontSlant->"Italic"],
 " changes with position."
}], "Text",
 CellChangeTimes->{{3.8076329978760138`*^9, 3.8076331317734213`*^9}, 
   3.8078688603975177`*^9},ExpressionUUID->"138c17a0-d569-4240-9984-\
083a06464621"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Simple pendulum - Newtonian mechanics", "Subsection",
 CellChangeTimes->{{3.9144130735022078`*^9, 
  3.914413079454651*^9}},ExpressionUUID->"ec6870b0-06a5-4e8b-88f0-\
b004244db5cd"],

Cell[TextData[{
 "We will use the pendulum as a demonstrative system for explaining the \
process of analysis with Newtonian mechanics. Consider a pendulum comprising \
a string of length ",
 StyleBox["l",
  FontSlant->"Italic"],
 " ",
 "attached to a fixed point at one end and to a mass ",
 StyleBox["m",
  FontSlant->"Italic"],
 " at the other end. We will designate the vertical coordinate as ",
 StyleBox["y",
  FontSlant->"Italic"],
 ", and the horizontal coordinate as ",
 StyleBox["x",
  FontSlant->"Italic"],
 ". Another important descriptor of this system is the angle \[Theta], which \
describes the angle between the string and the ",
 StyleBox["y",
  FontSlant->"Italic"],
 " axis (see Figure 0.1). Additionally, we can describe the arclength ",
 StyleBox["s",
  FontSlant->"Italic"],
 ", which gives the path of displacement of the pendulum mass from its \
resting position, using"
}], "Text",
 CellChangeTimes->{{3.914409387698737*^9, 3.91440941328259*^9}, {
  3.9144099742101164`*^9, 3.9144101111845713`*^9}, {3.914410341111844*^9, 
  3.914410431587661*^9}, {3.9144104929284697`*^9, 3.9144104958808165`*^9}, {
  3.914410753843243*^9, 3.9144108642031646`*^9}, {3.914410957417559*^9, 
  3.9144109613251305`*^9}, {3.9144110604584107`*^9, 3.914411165420993*^9}, {
  3.914412397548773*^9, 
  3.914412442724569*^9}},ExpressionUUID->"a01ae156-0f45-4238-8c41-\
6b7f53e63069"],

Cell[BoxData[
 RowBox[{
  StyleBox["\[Theta]",
   FontSlant->"Plain"], 
  StyleBox["=",
   FontSlant->"Plain"], 
  FractionBox[
   StyleBox["s",
    FontSlant->"Italic"], 
   StyleBox["l",
    FontSlant->"Italic"]], 
  StyleBox[" ",
   FontSlant->"Italic"]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.9144110221722584`*^9, 3.9144110251791077`*^9}, {
  3.9144111820235987`*^9, 3.9144112064138207`*^9}, {3.9144112438703938`*^9, 
  3.9144112575699005`*^9}, {3.9144113621341143`*^9, 3.914411369491595*^9}, {
  3.914411414332187*^9, 3.9144114682957087`*^9}, {3.91441245169024*^9, 
  3.914412456634287*^9}},ExpressionUUID->"214fb126-dbfa-4836-a8d4-\
1b3f2f047f19"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"polygon", "=", 
   RowBox[{"Polygon", "[", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
