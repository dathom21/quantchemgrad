Cell[TextData[{
 "And here is a similar plot, this time showing  ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[RightBracketingBar]", 
    RowBox[{
     SubscriptBox[
      StyleBox["\[Psi]",
       FontSlant->"Plain"], 
      StyleBox["n",
       FontSlant->"Italic"]], "(", 
     StyleBox["x",
      FontSlant->"Italic"], ")"}], 
    SuperscriptBox["\[LeftBracketingBar]", "2"]}], TraditionalForm]],
  ExpressionUUID->"ce636418-7bed-46db-ac36-5ec7011dd276"],
 ", which, remember, tells you the probability of finding the particle at a \
given location."
}], "Text",
 CellChangeTimes->{{3.8087513007018404`*^9, 
  3.8087513925831685`*^9}},ExpressionUUID->"cf964b30-2a55-492a-a72f-\
20e8130eb999"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"a", "=", "1"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"h", "=", "1"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"m", "=", "1"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"energies", "=", "\[IndentingNewLine]", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{"n", "^", "2"}], "*", 
          RowBox[{"h", "^", "2"}]}], ")"}], "/", 
        RowBox[{"(", 
         RowBox[{"8", "*", "m", "*", 
          RowBox[{"a", "^", "2"}]}], ")"}]}], ",", 
       RowBox[{"{", 
        RowBox[{"n", ",", "1", ",", "4"}], "}"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"energiesplot", "=", "\[IndentingNewLine]", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"0", ",", 
           RowBox[{"energies", "[", 
            RowBox[{"[", "n", "]"}], "]"}]}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"a", ",", 
           RowBox[{"energies", "[", 
            RowBox[{"[", "n", "]"}], "]"}]}], "}"}]}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"n", ",", "1", ",", "4"}], "}"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"potential", "=", 
     RowBox[{"Piecewise", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"{", 
         RowBox[{"0", ",", 
          RowBox[{"0", "\[LessEqual]", "x", "\[LessEqual]", "1"}]}], "}"}], 
        "}"}], ",", "1000"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"wfsquared", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"0.1", "*", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{
             RowBox[{"(", 
              RowBox[{"2", "/", "a"}], ")"}], "^", 
             RowBox[{"(", 
              RowBox[{"1", "/", "2"}], ")"}]}], 
            RowBox[{"Sin", "[", 
             RowBox[{"n", "*", "Pi", "*", 
              RowBox[{"x", "/", "a"}]}], "]"}]}], ")"}], "^", "2"}]}], "+", 
        RowBox[{"energies", "[", 
         RowBox[{"[", "n", "]"}], "]"}]}], ",", 
       RowBox[{"{", 
        RowBox[{"n", ",", "1", ",", "4"}], "}"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{"Show", "[", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"Plot", "[", 
      RowBox[{"potential", ",", 
       RowBox[{"{", 
        RowBox[{"x", ",", 
         RowBox[{"-", "1"}], ",", "3"}], "}"}], ",", 
       RowBox[{"PlotRange", "\[Rule]", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{
            RowBox[{"-", "0.2"}], ",", "1.2"}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"-", "0.1"}], ",", "2.5"}], "}"}]}], "}"}]}], ",", 
       RowBox[{"BaseStyle", "\[Rule]", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"FontFamily", "\[Rule]", "\"\<Arial\>\""}], ",", 
          RowBox[{"FontSize", "\[Rule]", "16"}]}], "}"}]}], ",", 
       RowBox[{"PlotStyle", "\[Rule]", 
        RowBox[{"Directive", "[", 
         RowBox[{"Black", ",", 
          RowBox[{"PointSize", "[", "Large", "]"}]}], "]"}]}], ",", 
       RowBox[{"AxesStyle", "\[Rule]", 
        RowBox[{"Directive", "[", 
         RowBox[{"Thick", ",", "Black"}], "]"}]}], ",", 
       RowBox[{"TicksStyle", "\[Rule]", 
        RowBox[{"Directive", "[", 
         RowBox[{"Black", ",", " ", "Thick"}], "]"}]}], ",", 
       RowBox[{"Ticks", "\[Rule]", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{
              RowBox[{"-", "0.5"}], ",", 
              "\"\<-\!\(\*StyleBox[\"L\",FontSlant->\"Italic\"]\)\>\""}], 
             "}"}], ",", 
            RowBox[{"{", 
             RowBox[{"0", ",", "\"\<0\>\""}], "}"}], ",", 
            RowBox[{"{", 
             RowBox[{
             "1", ",", 
              "\"\<\!\(\*StyleBox[\"a\",FontSlant->\"Italic\"]\)\>\""}], 
             "}"}]}], "}"}], ",", 
          RowBox[{"Table", "[", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{
              RowBox[{"energies", "[", 
               RowBox[{"[", "n", "]"}], "]"}], ",", 
              RowBox[{"Subscript", "[", 
               RowBox[{
               "\"\<\!\(\*StyleBox[\"E\",FontWeight->\"Plain\",FontSlant->\"\
Italic\"]\)\>\"", ",", 
                RowBox[{"ToString", "[", "n", "]"}]}], "]"}]}], "}"}], ",", 
            RowBox[{"{", 
             RowBox[{"n", ",", "1", ",", "4"}], "}"}]}], "]"}]}], "}"}]}], 
       ",", 
       RowBox[{"ImageSize", "\[Rule]", "Large"}], ",", " ", 
       RowBox[{"Exclusions", "\[Rule]", "None"}], ",", 
       RowBox[{"AxesOrigin", "\[Rule]", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"-", "0.2"}], ",", "0"}], "}"}]}], ",", 
       RowBox[{"AxesLabel", "\[Rule]", 
        RowBox[{"{", 
         RowBox[{
         "\"\<\!\(\*StyleBox[\"x\",FontSlant->\"Italic\"]\)\>\"", ",", 
          "\"\<\!\(\*StyleBox[\"E\",FontWeight->\"Plain\",FontSlant->\"Italic\
\"]\)\>\""}], "}"}]}], ",", 
       RowBox[{"Filling", "\[Rule]", "0"}], ",", 
       RowBox[{"FillingStyle", "->", 
        RowBox[{"HatchFilling", "[", 
         RowBox[{
          RowBox[{"-", "Pi"}], "/", "4"}], "]"}]}]}], "]"}], 
     "\[IndentingNewLine]", ",", "\[IndentingNewLine]", 
     RowBox[{"ListLinePlot", "[", 
      RowBox[{
       RowBox[{"energiesplot", "[", 
        RowBox[{"[", 
         RowBox[{"1", ";;", "4"}], "]"}], "]"}], ",", 
       RowBox[{"PlotStyle", "->", 
        RowBox[{"Directive", "[", "Black", "]"}]}]}], "]"}], 
     "\[IndentingNewLine]", ",", "\[IndentingNewLine]", 
     RowBox[{"Plot", "[", 
      RowBox[{
       RowBox[{"wfsquared", "[", 
        RowBox[{"[", 
         RowBox[{"1", ";;", "4"}], "]"}], "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"x", ",", "0", ",", "1"}], "}"}], ",", 
       RowBox[{"PlotRange", "\[Rule]", "All"}], ",", 
       RowBox[{"PlotStyle", "\[Rule]", "Thick"}]}], "]"}]}], 
    "\[IndentingNewLine]", "]"}]}]}]], "Input",
 CellChangeTimes->{{3.8087497866367736`*^9, 3.808749900519122*^9}, {
