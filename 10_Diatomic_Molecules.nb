     StyleBox["R",
      FontWeight->"Bold",
      FontSlant->"Italic"], 
     StyleBox[")",
      FontSlant->"Italic"]}], 
    SubscriptBox["\[Psi]", 
     StyleBox["e",
      FontSlant->"Italic"]], 
    RowBox[{"(", 
     StyleBox["r",
      FontWeight->"Bold",
      FontSlant->"Italic"], 
     StyleBox[")",
      FontSlant->"Italic"]}]}]}]}]}], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8130759614135423`*^9, 3.813076278147323*^9}, {
   3.813076380382406*^9, 3.8130764153085423`*^9}, 3.813076816633875*^9, {
   3.8130771563624783`*^9, 3.8130771828803873`*^9}, {3.8130785310803776`*^9, 
   3.8130785402645917`*^9}, {3.813078573864727*^9, 
   3.81307866764525*^9}},ExpressionUUID->"34f21671-dfe8-46ac-bddd-\
de9d653cd544"],

Cell["\<\
However, we can see from the form of our molecular Hamiltonian,\
\>", "Text",
 CellChangeTimes->{{3.813078683210449*^9, 3.813078694091669*^9}, 
   3.8130787250433455`*^9},ExpressionUUID->"4cfd0e67-d6bf-4c5a-a389-\
178c4f26eacf"],

Cell[BoxData[
 RowBox[{
  OverscriptBox[
   StyleBox["H",
    FontSlant->"Italic"], "^"], "=", 
  RowBox[{
   RowBox[{
    SubscriptBox[
     OverscriptBox[
      StyleBox["T",
       FontSlant->"Italic"], "^"], 
     StyleBox["N",
      FontSlant->"Italic"]], 
    RowBox[{"(", 
     StyleBox["R",
      FontSlant->"Italic"], 
     StyleBox[")",
      FontSlant->"Italic"]}]}], "+", 
   RowBox[{
    SubscriptBox[
     OverscriptBox[
      StyleBox["T",
       FontSlant->"Italic"], "^"], 
     StyleBox["e",
      FontSlant->"Italic"]], 
    RowBox[{"(", 
     StyleBox["r",
      FontSlant->"Italic"], 
     StyleBox[")",
      FontSlant->"Italic"]}]}], "+", 
   RowBox[{
    SubscriptBox[
     OverscriptBox[
      StyleBox["V",
       FontSlant->"Italic"], "^"], 
     StyleBox["eN",
      FontSlant->"Italic"]], 
    RowBox[{"(", 
     RowBox[{
      StyleBox["r",
       FontSlant->"Italic"], 
      StyleBox[",",
       FontSlant->"Plain"], 
      StyleBox["R",
       FontSlant->"Italic"]}], 
     StyleBox[")",
      FontSlant->"Italic"]}]}], "+", 
   RowBox[{
    SubscriptBox[
     OverscriptBox[
      StyleBox["V",
       FontSlant->"Italic"], "^"], 
     StyleBox["NN",
      FontSlant->"Italic"]], 
    RowBox[{"(", 
     StyleBox["R",
      FontSlant->"Italic"], 
     StyleBox[")",
      FontSlant->"Italic"]}]}], "+", 
   RowBox[{
    SubscriptBox[
     OverscriptBox[
      StyleBox["V",
       FontSlant->"Italic"], "^"], 
     StyleBox["ee",
      FontSlant->"Italic"]], 
    RowBox[{"(", 
     StyleBox["r",
      FontSlant->"Italic"], 
     StyleBox[")",
      FontSlant->"Italic"]}]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8130759614135423`*^9, 3.813076278147323*^9}, {
   3.813076380382406*^9, 3.8130764153085423`*^9}, 3.813076816633875*^9, {
   3.8130771563624783`*^9, 
   3.8130771828803873`*^9}},ExpressionUUID->"6585e4c0-97fb-4b4f-833e-\
d83263deb234"],

Cell[TextData[{
 "that we cannot cleanly separate the energy into electronic and nuclear \
components because the term ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    OverscriptBox[
     StyleBox["V",
      FontSlant->"Italic"], "^"], 
    StyleBox["eN",
     FontSlant->"Italic"]], 
   RowBox[{"(", 
    RowBox[{
     StyleBox["r",
      FontSlant->"Italic"], 
     StyleBox[",",
      FontSlant->"Plain"], 
     StyleBox["R",
      FontSlant->"Italic"]}], 
    StyleBox[")",
     FontSlant->"Italic"]}]}]],
  CellChangeTimes->{{3.8130759614135423`*^9, 3.813076278147323*^9}, {
    3.813076380382406*^9, 3.8130764153085423`*^9}, 3.813076816633875*^9, {
    3.8130771563624783`*^9, 3.8130771828803873`*^9}},ExpressionUUID->
  "76f79b1a-f732-4468-b59a-091051f243f6"],
 "depends simultaneously on the positions of both the nuclei and the \
electrons. Nevertheless, we will attempt to write our wavefunction \
approximately in the form"
}], "Text",
 CellChangeTimes->{{3.8130787013157015`*^9, 
  3.8130788006694927`*^9}},ExpressionUUID->"cded1703-0393-4f8d-ae61-\
debdc6a9e060"],

Cell[BoxData[
 RowBox[{
  RowBox[{"\[Psi]", 
   RowBox[{"(", 
    RowBox[{
     StyleBox["R",
      FontWeight->"Bold",
      FontSlant->"Italic"], ",", " ", 
     StyleBox["r",
      FontWeight->"Bold",
      FontSlant->"Italic"]}], ")"}]}], "\[TildeTilde]", 
  RowBox[{
   SubscriptBox["\[Phi]", 
    StyleBox["N",
     FontSlant->"Italic"]], 
   RowBox[{"(", 
    StyleBox["R",
     FontWeight->"Bold",
     FontSlant->"Italic"], 
    StyleBox[")",
     FontSlant->"Italic"]}], 
   SubscriptBox["\[Phi]", 
    StyleBox["e",
     FontSlant->"Italic"]], 
   RowBox[{"(", 
    StyleBox["r",
     FontWeight->"Bold",
     FontSlant->"Italic"], 
    StyleBox[")",
     FontSlant->"Italic"]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.81307809350165*^9, 3.8130781609264364`*^9}, 
   3.8130782039890594`*^9, {3.813078272672757*^9, 3.8130783323990836`*^9}, {
   3.8130788081537347`*^9, 3.8130788107416773`*^9}, {3.813084070519988*^9, 
   3.8130841045184684`*^9}, {3.8132221944603963`*^9, 
   3.81322219862286*^9}},ExpressionUUID->"1076bd04-bb1d-4544-a006-\
408c5f181591"],

Cell["\<\
This approximation is the main assumption of the Born-Oppenheimer \
approximation.\
\>", "Text",
 CellChangeTimes->{{3.8130788212086077`*^9, 
  3.8130788572950044`*^9}},ExpressionUUID->"c7d29fbd-3dfa-476f-b5ad-\
8b34e0d89d28"]
}, Open  ]],

Cell[CellGroupData[{

Cell["The Born-Oppenheimer Approximation", "Subsection",
 CellChangeTimes->{{3.813078859800047*^9, 
  3.813078864913535*^9}},ExpressionUUID->"de72d931-4873-4f72-8d04-\
c43d24b2ea28"],

Cell["\<\
Different textbooks (and different scientists) may envision different \
meanings when they invoke the Born-Oppenheimer approximation. However, in \
general, all explanations of the approximation rest on a central principle: \
because the nuclei are much more massive than the electrons, the position of \
the nuclei can be regarded as fixed with respect to electron motion. Taking \
the form of our approximate wavefunction,\
\>", "Text",
 CellChangeTimes->{{3.8130820390234823`*^9, 3.8130820513627577`*^9}, {
  3.813082102914988*^9, 3.8130821406384315`*^9}, {3.8130824062612243`*^9, 
  3.81308261049492*^9}},ExpressionUUID->"e657878b-efb3-47ef-9a67-\
25d0a08d78e9"],

Cell[BoxData[
 RowBox[{
  RowBox[{"\[Psi]", 
   RowBox[{"(", 
    RowBox[{
     StyleBox["R",
      FontWeight->"Bold",
      FontSlant->"Italic"], ",", " ", 
     StyleBox["r",
      FontWeight->"Bold",
      FontSlant->"Italic"]}], ")"}]}], "\[TildeTilde]", 
  RowBox[{
   SubscriptBox["\[Phi]", 
    StyleBox["N",
     FontSlant->"Italic"]], 
   RowBox[{"(", 
    StyleBox["R",
     FontWeight->"Bold",
     FontSlant->"Italic"], 
    StyleBox[")",
     FontSlant->"Italic"]}], 
   SubscriptBox["\[Phi]", 
    StyleBox["e",
     FontSlant->"Italic"]], 
   RowBox[{"(", 
    StyleBox["r",
     FontWeight->"Bold",
     FontSlant->"Italic"], 
    StyleBox[")",
     FontSlant->"Italic"]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.81307809350165*^9, 3.8130781609264364`*^9}, 
   3.8130782039890594`*^9, {3.813078272672757*^9, 3.8130783323990836`*^9}, {
   3.8130788081537347`*^9, 3.8130788107416773`*^9}, {3.813084082642866*^9, 
   3.8130840836064095`*^9}, 3.813222203505035*^9, {3.813222251629841*^9, 
   3.8132222597207966`*^9}},ExpressionUUID->"9b36533b-a651-4536-bf7b-\
41ebd5dc8388"],

Cell[TextData[{
 "We can fix the coordinates of the nuclei ",
 StyleBox["R",
  FontWeight->"Bold",
  FontSlant->"Italic"],
 " and then solve the Schr\[ODoubleDot]dinger equation for ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox["\[Phi]", 
    StyleBox["e",
     FontSlant->"Italic"]], 
   RowBox[{"(", 
    StyleBox["r",
     FontWeight->"Bold",
     FontSlant->"Italic"], 
    StyleBox[")",
     FontSlant->"Italic"]}]}]],
  CellChangeTimes->{{3.81307809350165*^9, 3.8130781609264364`*^9}, 
    3.8130782039890594`*^9, {3.813078272672757*^9, 3.8130783323990836`*^9}, {
    3.8130788081537347`*^9, 3.8130788107416773`*^9}},ExpressionUUID->
  "6b61d0d7-76dc-49ce-a61e-506235826231"],
 ". If we perform this calculation for multiple values of ",
 StyleBox["R",
  FontWeight->"Bold",
  FontSlant->"Italic"],
 ", then we end up with a potential energy surface for movement of the nuclei."
}], "Text",
 CellChangeTimes->{{3.8130826175441065`*^9, 3.8130827512931376`*^9}, {
  3.813232093053539*^9, 
  3.8132320943954*^9}},ExpressionUUID->"79cd999e-2f24-452b-8ffe-31e41bac9c31"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"Clear", "[", 
  RowBox[{"k", ",", "De", ",", "a"}], "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"data", "=", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"x", ",", 
       RowBox[{
        RowBox[{"De", "*", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"1", "-", 
            RowBox[{"Exp", "[", 
             RowBox[{
              RowBox[{"-", "a"}], "*", "x"}], "]"}]}], ")"}], "^", "2"}]}], "/.", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"De", "\[Rule]", "1.5"}], ",", 
          RowBox[{"a", "\[Rule]", "1"}]}], "}"}]}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", 
       RowBox[{"-", "1.5"}], ",", "2", ",", "0.1"}], "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"fit", "=", 
   RowBox[{"NonlinearModelFit", "[", 
    RowBox[{"data", ",", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"1", "/", "2"}], ")"}], "*", "k", "*", 
      RowBox[{"x", "^", "2"}]}], ",", "k", ",", "x"}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{"k", "=", 
  RowBox[{"2", "*", "De", "*", 
