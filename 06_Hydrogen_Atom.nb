Cell[CellGroupData[{

Cell["\<\
Combining the Angular Solutions to Obtain Spherical Harmonics\
\>", "Subsubsection",
 CellChangeTimes->{{3.8106504412816997`*^9, 
  3.8106504557210608`*^9}},ExpressionUUID->"cdd73247-e0fb-4acc-b79a-\
d6508f69112c"],

Cell["\<\
We can now put back together our solutions for the equatorial and polar angle \
dependence to get the angular wavefunction,\
\>", "Text",
 CellChangeTimes->{{3.8106506593045206`*^9, 
  3.8106506839645185`*^9}},ExpressionUUID->"6ccfca0b-d620-4fe2-b898-\
89a763ee0269"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   SubsuperscriptBox[
    StyleBox["Y",
     FontSlant->"Italic"], 
    StyleBox["l",
     FontSlant->"Italic"], 
    SubscriptBox[
     StyleBox["m",
      FontSlant->"Italic"], 
     StyleBox["l",
      FontSlant->"Italic"]]], 
   RowBox[{"(", 
    RowBox[{"\[Theta]", ",", "\[Phi]"}], ")"}]}], "=", 
  RowBox[{
   RowBox[{"\[CapitalTheta]", 
    RowBox[{"(", "\[Theta]", ")"}], "\[CapitalPhi]", 
    RowBox[{"(", "\[Phi]", ")"}]}], "=", 
   RowBox[{
    SuperscriptBox[
     RowBox[{"(", 
      RowBox[{
       FractionBox[
        RowBox[{"(", 
         RowBox[{
          RowBox[{"2", 
           StyleBox["l",
            FontSlant->"Italic"]}], "+", "1"}], ")"}], "2"], 
       FractionBox[
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           StyleBox["l",
            FontSlant->"Italic"], 
           StyleBox["-",
            FontSlant->"Italic"], 
           RowBox[{"\[LeftBracketingBar]", 
            SubscriptBox[
             StyleBox["m",
              FontSlant->"Italic"], 
             StyleBox["l",
              FontSlant->"Italic"]], "\[RightBracketingBar]"}]}], ")"}], 
         "!"}], 
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           StyleBox["l",
            FontSlant->"Italic"], "+", 
           RowBox[{"\[LeftBracketingBar]", 
            SubscriptBox[
             StyleBox["m",
              FontSlant->"Italic"], 
             StyleBox["l",
              FontSlant->"Italic"]], "\[RightBracketingBar]"}]}], ")"}], 
         "!"}]]}], ")"}], 
     RowBox[{"1", "/", "2"}]], 
    SubsuperscriptBox[
     StyleBox["P",
      FontSlant->"Italic"], 
     StyleBox["l",
      FontSlant->"Italic"], 
     RowBox[{"\[LeftBracketingBar]", 
      SubscriptBox[
       StyleBox["m",
        FontSlant->"Italic"], 
       StyleBox["l",
        FontSlant->"Italic"]], "\[RightBracketingBar]"}]], 
    RowBox[{"(", "cos\[Theta]", ")"}], 
    SuperscriptBox[
     RowBox[{"(", 
      FractionBox["1", 
       RowBox[{
        StyleBox["2",
         FontSlant->"Plain"], "\[Pi]"}]], ")"}], 
     RowBox[{"1", "/", "2"}]], 
    SuperscriptBox["\[ExponentialE]", 
     RowBox[{
      SubscriptBox[
       StyleBox[
        RowBox[{"\[ImaginaryI]", 
         StyleBox["m",
          FontSlant->"Italic"]}]], 
       StyleBox["l",
        FontSlant->"Italic"]], 
      StyleBox["\[Phi]",
       FontSlant->"Plain"]}]], "   "}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.810112811439228*^9, 3.8101128248442793`*^9}, {
   3.810479494926491*^9, 3.8104795038498344`*^9}, {3.810479572543576*^9, 
