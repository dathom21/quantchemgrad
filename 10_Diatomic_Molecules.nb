       SubscriptBox[
        StyleBox["s",
         FontSlant->"Italic"], 
        StyleBox["A",
         FontSlant->"Italic"]]}]]}], "+", 
    RowBox[{
     SubscriptBox[
      StyleBox["c",
       FontSlant->"Italic"], "4"], 
     SubscriptBox["\[Phi]", 
