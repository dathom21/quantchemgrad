 RowBox[{
  RowBox[{
   RowBox[{"(", "\[NoBreak]", GridBox[{
      {
       SubscriptBox[
        StyleBox["H",
         FontSlant->"Italic"], "11"], 
       SubscriptBox[
        StyleBox["H",
         FontSlant->"Italic"], "12"]},
      {
       SubscriptBox[
        StyleBox["H",
         FontSlant->"Italic"], "12"], 
       SubscriptBox[
        StyleBox["H",
         FontSlant->"Italic"], "22"]}
     }], "\[NoBreak]", ")"}], 
   RowBox[{"(", "\[NoBreak]", GridBox[{
