Cell[TextData[{
 "For each vibration, the irreducible representation (",
 StyleBox["A",
  FontSlant->"Italic"],
 " or ",
 StyleBox["B",
  FontSlant->"Italic"],
 ") is given below the vibration number. "
}], "Text",
 CellChangeTimes->{{3.8163420201753087`*^9, 
  3.8163420694256983`*^9}},ExpressionUUID->"dcadf04e-db89-456f-9ebe-\
0b276e1ed5ac"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Predicting Infrared and Raman Activity from Group Theory", "Subsection",
 CellChangeTimes->{{3.816342094364521*^9, 3.8163421039032493`*^9}, {
  3.8163422407515554`*^9, 
  3.816342242405945*^9}},ExpressionUUID->"cac94b78-c530-466a-8fb6-\
535eee68074f"],

Cell["\<\
We will see that the irreducible representation to which a vibration belongs \
tells us about its infrared and Raman activity. Recall that in the harmonic \
oscillator approximation, the vibrational wavefunction can be written as\
\>", "Text",
 CellChangeTimes->{{3.8163422459686937`*^9, 3.8163422499671507`*^9}, {
  3.8163423268607445`*^9, 3.816342357855007*^9}, {3.816342412569722*^9, 
  3.816342443037737*^9}},ExpressionUUID->"90805707-7934-4e4b-be19-\
ba0f72300944"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   SubscriptBox["\[Psi]", "vib"], 
   RowBox[{"(", 
    RowBox[{
     SubscriptBox[
      StyleBox["Q",
       FontSlant->"Italic"], "1"], ",", " ", 
     SubscriptBox[
      StyleBox["Q",
       FontSlant->"Italic"], "2"], ",", "...", ",", 
     SubscriptBox[
      StyleBox["Q",
       FontSlant->"Italic"], 
      StyleBox["N",
       FontSlant->"Italic"]]}], ")"}]}], "=", 
  RowBox[{
   RowBox[{
    RowBox[{
     SubscriptBox["\[Psi]", 
      SubscriptBox["vib", "1"]], 
     RowBox[{"(", 
      SubscriptBox[
       StyleBox["Q",
        FontSlant->"Italic"], "1"], ")"}], 
     SubscriptBox["\[Psi]", 
      SubscriptBox["vib", "2"]], 
     RowBox[{"(", 
      SubscriptBox[
       StyleBox["Q",
        FontSlant->"Italic"], "2"], ")"}]}], "..."}], 
   SubscriptBox["\[Psi]", 
    SubscriptBox["vib", 
     StyleBox["N",
      FontSlant->"Italic"]]], 
   RowBox[{"(", 
    SubscriptBox[
     StyleBox["Q",
      FontSlant->"Italic"], 
     StyleBox["N",
      FontSlant->"Italic"]], ")"}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.816268121876033*^9, 3.8162682305566397`*^9}, {
  3.816268292637581*^9, 
  3.816268372000382*^9}},ExpressionUUID->"c5c8e11d-c802-4cc4-987c-\
4040041f8056"],

Cell["\<\
If we now evaluate the transition dipole moment for the excitation from the \
ground state to the excited state, we write\
\>", "Text",
 CellChangeTimes->{{3.8163424488329945`*^9, 3.8163424623185363`*^9}, {
  3.8163425071377306`*^9, 3.8163425223500156`*^9}, {3.8163425600686255`*^9, 
  3.8163425628648667`*^9}},ExpressionUUID->"81c10ed5-fb5d-471c-88f4-\
9498bfebccd8"],

Cell[BoxData[
 RowBox[{
  SubscriptBox[
   RowBox[{"\[LeftAngleBracket]", 
    StyleBox["\[Mu]",
     FontWeight->"Bold"], "\[RightAngleBracket]"}], 
   StyleBox["10",
    FontSlant->"Italic"]], "=", 
  RowBox[{"\[LeftAngleBracket]", 
   RowBox[{
    RowBox[{
     SubscriptBox["\[Psi]", 
      RowBox[{"1", "vib"}]], 
     RowBox[{"(", 
      RowBox[{
       SubscriptBox[
        StyleBox["Q",
         FontSlant->"Italic"], "1"], ",", " ", 
       SubscriptBox[
        StyleBox["Q",
         FontSlant->"Italic"], "2"], ",", "...", ",", 
       SubscriptBox[
        StyleBox["Q",
         FontSlant->"Italic"], 
        StyleBox["N",
         FontSlant->"Italic"]]}], ")"}]}], 
    StyleBox["|",
     FontSlant->"Italic"], 
    StyleBox["\[Mu]",
     FontWeight->"Bold"], "|", 
    RowBox[{
     SubscriptBox["\[Psi]", 
      RowBox[{"0", "vib"}]], 
     RowBox[{"(", 
      RowBox[{
       SubscriptBox[
        StyleBox["Q",
         FontSlant->"Italic"], "1"], ",", " ", 
       SubscriptBox[
        StyleBox["Q",
         FontSlant->"Italic"], "2"], ",", "...", ",", 
       SubscriptBox[
        StyleBox["Q",
         FontSlant->"Italic"], 
        StyleBox["N",
         FontSlant->"Italic"]]}], ")"}]}]}], 
   "\[RightAngleBracket]"}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8079712935412436`*^9, 3.8079714900326514`*^9}, {
   3.8080650361338077`*^9, 3.808065078586836*^9}, {3.8080651294863386`*^9, 
   3.8080651662446632`*^9}, {3.8080655103101*^9, 3.808065549470801*^9}, {
   3.8080655874181037`*^9, 3.8080655997397223`*^9}, {3.80806586302172*^9, 
   3.808065882866931*^9}, {3.8080659492793603`*^9, 3.808065953047598*^9}, {
   3.808066005614772*^9, 3.8080660274348636`*^9}, {3.8080662251299095`*^9, 
   3.8080662851171017`*^9}, {3.815378518820794*^9, 3.815378562596084*^9}, {
   3.81537861215761*^9, 3.815378656577838*^9}, {3.815379033614147*^9, 
   3.8153790773392897`*^9}, {3.8153792393653684`*^9, 3.81537924024451*^9}, {
   3.8153793909369802`*^9, 3.81537943105853*^9}, {3.815381276661846*^9, 
   3.8153813324920735`*^9}, {3.815468631694975*^9, 3.8154686569549303`*^9}, {
