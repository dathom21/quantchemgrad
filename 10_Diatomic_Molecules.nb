       RowBox[{"Black", ",", "Thick", ",", "DotDashed"}], "]"}], ",", 
      RowBox[{"Directive", "[", 
       RowBox[{"Black", ",", "Dashed", ",", "Thin"}], "]"}]}], "}"}]}], ",", 
   RowBox[{"AxesStyle", "\[Rule]", 
    RowBox[{"Directive", "[", 
     RowBox[{"Thick", ",", "Black"}], "]"}]}], ",", 
   RowBox[{"TicksStyle", "\[Rule]", 
    RowBox[{"Directive", "[", 
     RowBox[{"Black", ",", " ", "Thick"}], "]"}]}], ",", 
   RowBox[{"Ticks", "\[Rule]", 
