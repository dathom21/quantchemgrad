Cell[TextData[{
 "The functions ",
 Cell[BoxData[
  RowBox[{
   SubsuperscriptBox[
    StyleBox["Y",
     FontSlant->"Italic"], 
    StyleBox["l",
     FontSlant->"Italic"], 
    SubscriptBox[
     StyleBox["m",
      FontSlant->"Italic"], 
     StyleBox["l",
      FontSlant->"Italic"]]], 
   RowBox[{"(", 
    RowBox[{"\[Theta]", ",", "\[Phi]"}], ")"}]}]],
  CellChangeTimes->{{3.810112811439228*^9, 3.8101128248442793`*^9}, {
    3.810479494926491*^9, 3.8104795038498344`*^9}, {3.810479572543576*^9, 
    3.8104796147383184`*^9}, {3.8104802055659895`*^9, 
    3.8104802433915305`*^9}, {3.8104802785189395`*^9, 
    3.8104802814214115`*^9}, {3.810480477782269*^9, 3.8104805471507206`*^9}, {
    3.8104805927965565`*^9, 3.810480633017248*^9}, {3.8104807595294323`*^9, 
    3.8104809538100047`*^9}, {3.8104811300285854`*^9, 
    3.8104811403007636`*^9}, {3.8104812580010843`*^9, 
    3.8104813317580833`*^9}, {3.81048146789211*^9, 3.8104815557630205`*^9}, {
    3.8104817202872114`*^9, 3.8104817438715935`*^9}, 3.810481790764664*^9, 
    3.810481836241686*^9, {3.810481926951917*^9, 3.810481935802024*^9}, {
    3.8104820720505495`*^9, 3.8104821860076323`*^9}, {3.810482833577834*^9, 
    3.810482856592573*^9}, {3.810650687465464*^9, 3.8106507334315205`*^9}, 
    3.810651925937356*^9},ExpressionUUID->
  "31d5bad1-504d-417c-bd4f-6cb504e98825"],
 "are known as spherical harmonics because they are orthonormal over the \
surface of a sphere. Orthonormal means that they are both orthogonal and \
normalized, meaning"
}], "Text",
 CellChangeTimes->{{3.8106520635170603`*^9, 3.810652121369669*^9}, {
  3.9170225794084363`*^9, 
  3.917022579636133*^9}},ExpressionUUID->"92a0a913-b411-4daa-9e79-\
1ed23f954506"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   SubsuperscriptBox["\[Integral]", "0", "\[Pi]"], 
   RowBox[{
    SubsuperscriptBox["\[Integral]", "0", 
     RowBox[{"2", "\[Pi]"}]], 
    RowBox[{
     SubsuperscriptBox[
      StyleBox["Y",
       FontSlant->"Italic"], 
      StyleBox["l",
       FontSlant->"Italic"], 
      StyleBox["m",
       FontSlant->"Italic"]], 
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{"\[Theta]", ",", "\[Phi]"}], ")"}], "\[Star]"], 
     SubsuperscriptBox[
      StyleBox["Y",
       FontSlant->"Italic"], 
      StyleBox["n",
       FontSlant->"Italic"], 
      StyleBox["k",
       FontSlant->"Italic"]], 
     RowBox[{"(", 
      RowBox[{"\[Theta]", ",", "\[Phi]"}], ")"}], 
     RowBox[{"\[DifferentialD]", "\[Phi]"}], " ", "sin\[Theta]", " ", 
     RowBox[{"\[DifferentialD]", "\[Theta]"}]}]}]}], "=", 
  RowBox[{
   SubscriptBox["\[Delta]", 
    StyleBox["ln",
     FontSlant->"Italic"]], 
   SubscriptBox["\[Delta]", 
    StyleBox["mk",
     FontSlant->"Italic"]]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.810112811439228*^9, 3.8101128248442793`*^9}, {
