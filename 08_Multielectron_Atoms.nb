 RowBox[{
  RowBox[{
   RowBox[{"(", "\[NoBreak]", GridBox[{
      {
       RowBox[{
        SubscriptBox[
         StyleBox["H",
          FontSlant->"Italic"], "11"], "-", 
        RowBox[{
         SubscriptBox[
          StyleBox["E",
           FontSlant->"Italic"], "\[CapitalPhi]"], 
         SubscriptBox[
          StyleBox["S",
           FontSlant->"Italic"], "11"]}]}], 
       RowBox[{
        SubscriptBox[
         StyleBox["H",
          FontSlant->"Italic"], "12"], "-", 
        RowBox[{
         SubscriptBox[
          StyleBox["E",
           FontSlant->"Italic"], "\[CapitalPhi]"], 
         SubscriptBox[
          StyleBox["S",
           FontSlant->"Italic"], "12"]}]}]},
      {
       RowBox[{
        SubscriptBox[
         StyleBox["H",
          FontSlant->"Italic"], "12"], "-", 
        RowBox[{
         SubscriptBox[
          StyleBox["E",
           FontSlant->"Italic"], "\[CapitalPhi]"], 
         SubscriptBox[
          StyleBox["S",
           FontSlant->"Italic"], "12"]}]}], 
       RowBox[{
        SubscriptBox[
         StyleBox["H",
          FontSlant->"Italic"], "22"], "-", 
        RowBox[{
         SubscriptBox[
          StyleBox["E",
           FontSlant->"Italic"], "\[CapitalPhi]"], 
         SubscriptBox[
          StyleBox["S",
           FontSlant->"Italic"], "22"]}]}]}
     }], "\[NoBreak]", ")"}], 
   RowBox[{"(", "\[NoBreak]", GridBox[{
      {
       SubscriptBox[
        StyleBox["a",
         FontSlant->"Italic"], "1"]},
      {
       SubscriptBox[
        StyleBox["a",
         FontSlant->"Italic"], "2"]}
     }], "\[NoBreak]", ")"}]}], "=", " ", 
  RowBox[{"(", "\[NoBreak]", GridBox[{
     {"0"},
     {"0"}
    }], "\[NoBreak]", ")"}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.811593312893673*^9, 3.8115933831661987`*^9}, {
