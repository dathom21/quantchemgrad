9d8bf151b2e0"],

Cell[BoxData[
 RowBox[{
  RowBox[{"\[LeftAngleBracket]", 
   RowBox[{
    StyleBox[
     SubscriptBox[
      StyleBox["\[CapitalPsi]",
       FontWeight->"Bold"], "a"],
     FontWeight->"Bold"], ",", 
    StyleBox[
     SubscriptBox[
      StyleBox["\[CapitalPsi]",
       FontWeight->"Bold"], "b"],
     FontWeight->"Bold"]}], "\[RightAngleBracket]"}], "=", 
  RowBox[{
   RowBox[{"\[LeftAngleBracket]", 
    RowBox[{
     StyleBox["a",
      FontWeight->"Bold"], ",", 
     StyleBox["b",
      FontWeight->"Bold"]}], "\[RightAngleBracket]"}], "=", 
   RowBox[{
    RowBox[{
     SuperscriptBox[
      StyleBox["a",
       FontWeight->"Bold",
       FontSlant->"Plain"], 
      StyleBox["H",
       FontWeight->"Bold"]], 
     StyleBox["b",
      FontWeight->"Bold"]}], "=", 
    RowBox[{
     RowBox[{"(", "\[NoBreak]", 
      RowBox[{GridBox[{
         {
          SubsuperscriptBox[
           StyleBox["a",
            FontSlant->"Italic"], "1", "\[Star]"], 
          SubsuperscriptBox[
           StyleBox["a",
            FontSlant->"Italic"], "2", "\[Star]"]}
        }], GridBox[{
         {"...", 
          SubsuperscriptBox[
           StyleBox["a",
            FontSlant->"Italic"], 
           StyleBox["n",
            FontSlant->"Italic"], "\[Star]"]}
        }]}], ")"}], 
     RowBox[{"(", "\[NoBreak]", GridBox[{
        {
         SubscriptBox[
          StyleBox["b",
           FontSlant->"Italic"], "1"]},
        {
         SubscriptBox[
          StyleBox["b",
           FontSlant->"Italic"], "2"]},
        {GridBox[{
           {"..."},
           {
            SubscriptBox[
             StyleBox["b",
              FontSlant->"Italic"], 
             StyleBox["n",
              FontSlant->"Italic"]]}
          }]}
       }], "\[NoBreak]", ")"}]}]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8112559638442764`*^9, 3.8112559741396627`*^9}, {
