  "6d887bd2-03c4-4051-87ab-e089682a4540"],
 " unless we already know the value of ",
 Cell[BoxData[
  RowBox[{"\[Phi]", 
   RowBox[{"(", 
    SubscriptBox[
     StyleBox["r",
      FontWeight->"Bold",
      FontSlant->"Italic"], "1"], ")"}]}]],
