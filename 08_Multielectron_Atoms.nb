  3.8119303130744066`*^9}},ExpressionUUID->"1881da75-cd1a-af4a-910c-\
24f82fd65cb7"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   OverscriptBox[
    UnderscriptBox["\[Sum]", 
     StyleBox["n",
