Cell[BoxData[
 RowBox[{
  RowBox[{"HybridSP", "[", "view_", "]"}], ":=", 
  RowBox[{"Block", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "hybridFuns", ",", "scalingVecs", ",", "len", ",", "pos", ",", "i", ",", 
      "hybOrbs1r", ",", "hybOrbs1b", ",", "hybOrbs1rScaled", ",", 
      "hybOrbs1bScaled", ",", "hybOrbs1rScaledP", ",", "hybOrbs1bScaledP", 
      ",", "hybOrbs1rOne", ",", "hybOrbs1bOne", ",", "hybOrbs1rTwo", ",", 
      "hybOrbs1bTwo", ",", "hybOrbs1rNew", ",", "hybOrbs1bNew", ",", 
      "sampleSize"}], "}"}], ",", 
    RowBox[{
     RowBox[{"sampleSize", "=", "500"}], ";", "\n", 
     RowBox[{"hybridFuns", "=", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         RowBox[{"1.", "/", 
          RowBox[{"Sqrt", "[", "2", "]"}]}], " ", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"OrbitalModel", "[", "1", "]"}], "+", 
           RowBox[{"OrbitalModel", "[", "2", "]"}]}], ")"}]}], ",", 
        RowBox[{
         RowBox[{"1.", "/", 
          RowBox[{"Sqrt", "[", "2", "]"}]}], " ", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"OrbitalModel", "[", "1", "]"}], "-", 
           RowBox[{"OrbitalModel", "[", "2", "]"}]}], ")"}]}]}], "}"}]}], ";",
