     RowBox[{
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"n", ",", 
          RowBox[{"HermiteH", "[", 
           RowBox[{"n", ",", 
            RowBox[{
             SuperscriptBox["\[Alpha]", 
              RowBox[{"1", "/", "2"}]], "x"}]}], "]"}]}], "}"}], ",", 
