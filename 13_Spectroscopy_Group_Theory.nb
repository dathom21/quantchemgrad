 RowBox[{
  RowBox[{
   SubscriptBox[
    StyleBox["P",
     FontSlant->"Italic"], 
    StyleBox["m",
     FontSlant->"Italic"]], 
   RowBox[{"(", 
    StyleBox["t",
     FontSlant->"Italic"], ")"}]}], "=", 
  RowBox[{
   RowBox[{"|", 
    RowBox[{
     SubsuperscriptBox["c", 
