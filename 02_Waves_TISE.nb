Cell[TextData[{
 StyleBox["Figure 2.1",
  FontWeight->"Bold"],
 ". Plot of the function ",
 Cell[BoxData[
  RowBox[{
   StyleBox[
    SubsuperscriptBox[
     StyleBox["c",
      FontSlant->"Italic"], "2", 
     StyleBox["'",
      FontSize->20]],
    FontFamily->"Source Serif Pro",
    FontWeight->"Plain"], 
   StyleBox[" ",
    FontFamily->"Source Serif Pro",
    FontWeight->"Plain"], 
   StyleBox["sin",
    FontFamily->"Consolas",
    FontWeight->"Normal"], 
   StyleBox[
    RowBox[{"(", 
     StyleBox[
      FractionBox[
       StyleBox[
        RowBox[{
         StyleBox["n",
          FontSlant->"Italic"], "\[Pi]", 
         StyleBox["x",
          FontSlant->"Italic"]}]], 
       StyleBox["L",
        FontSlant->"Italic"]],
      FontSlant->"Italic"], ")"}],
    FontFamily->"Consolas",
    FontWeight->"Normal"]}]],
  CellChangeTimes->{{3.80787182098985*^9, 3.807871850931781*^9}, {
    3.807871889420841*^9, 3.8078719220144444`*^9}, {3.80787198448829*^9, 
    3.8078721855891733`*^9}, 3.8078722793781643`*^9},ExpressionUUID->
  "663975c1-97e3-4efe-aa94-9182465120d0"],
 " for values of ",
 StyleBox["n",
  FontSlant->"Italic"],
 " from 1 (top) to 4 (bottom)."
}], "Affiliation",
