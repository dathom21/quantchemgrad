Cell[TextData[{
 StyleBox["Figure 0.5",
  FontWeight->"Bold"],
 ". Illustration of movement along a circle in the complex plane. Change the \
value of \[Theta] in z=r(cos \[Theta]+\[ImaginaryI] sin \[Theta]) moves along \
a circle of radius ",
 StyleBox["r",
  FontSlant->"Italic"],
 " in the complex plane."
}], "Affiliation",
 CellChangeTimes->{{3.809435027311596*^9, 3.8094350763900714`*^9}, {
  3.80943583474421*^9, 3.8094358359299717`*^9}, {3.8094472165104203`*^9, 
  3.809447281165168*^9}, {3.809510876137825*^9, 3.809510907739876*^9}, {
  3.809968073566992*^9, 3.8099681536568317`*^9}, {3.810557260250428*^9, 
  3.8105572606139913`*^9}, {3.8130835305386977`*^9, 3.8130836194514275`*^9}, {
  3.813224407772764*^9, 3.8132244817756805`*^9}, {3.8394266250053024`*^9, 
  3.839426636135662*^9}, {3.8394271229755535`*^9, 3.8394271464856167`*^9}, {
  3.8394271859998655`*^9, 3.8394272181213303`*^9}, {3.8395089519189353`*^9, 
  3.839508973029978*^9}, {3.8395092661850324`*^9, 3.839509281138036*^9}, {
  3.839509799308126*^9, 3.839509816261318*^9}, {3.83951063026188*^9, 
  3.839510671838603*^9}, {3.8395107294068866`*^9, 3.8395107298487115`*^9}, {
  3.9144174269938903`*^9, 
  3.914417428502987*^9}},ExpressionUUID->"18f1efa5-90a0-45d8-8903-\
e44b5038304e"],

Cell["\<\
It turns out that there is an alternate form of representing a point on a \
circle in the complex plane that we will use frequently in this course. \
Remember that when we multiply two complex numbers, \
\>", "Text",
 CellChangeTimes->{{3.8074563768210216`*^9, 3.807456536457431*^9}, {
   3.807456574220021*^9, 3.807456906293648*^9}, {3.807456962048489*^9, 
   3.807456977824791*^9}, {3.807457028770769*^9, 3.807457086153125*^9}, {
   3.8395108511513176`*^9, 3.8395108527172656`*^9}, 
   3.9144071786675663`*^9},ExpressionUUID->"030584dd-6099-4335-87d8-\
c877ce749c6c"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   SubscriptBox[
    StyleBox["z",
     FontSlant->"Italic"], "1"], 
   SubscriptBox[
    StyleBox["z",
     FontSlant->"Italic"], "2"]}], "=", 
  RowBox[{
   SubscriptBox[
    StyleBox["r",
     FontSlant->"Italic"], "1"], 
   RowBox[{
    SubscriptBox[
     StyleBox["r",
      FontSlant->"Italic"], "2"], "[", 
    RowBox[{
     RowBox[{"cos", " ", 
      RowBox[{"(", 
       RowBox[{
        SubscriptBox["\[Theta]", "1"], "+", 
        SubscriptBox["\[Theta]", "2"]}], ")"}]}], "+", 
     RowBox[{"\[ImaginaryI]", " ", "sin", 
      RowBox[{"(", 
       RowBox[{
        SubscriptBox["\[Theta]", "1"], "+", 
        SubscriptBox["\[Theta]", "2"]}], ")"}]}]}], 
    "]"}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{
  3.8395108902613335`*^9},ExpressionUUID->"266fd4af-96a8-493b-8a41-\
515e6be6e82f"],

Cell["\<\
so when r = 1, we just add the angles to move around the unit circle. \
\>", "Text",
 CellChangeTimes->{{3.8074563768210216`*^9, 3.807456536457431*^9}, {
   3.807456574220021*^9, 3.807456906293648*^9}, {3.807456962048489*^9, 
   3.807456977824791*^9}, {3.807457028770769*^9, 3.807457086153125*^9}, {
   3.8395108511513176`*^9, 3.8395108527172656`*^9}, 3.9144071786675663`*^9, {
   3.9338592708994637`*^9, 3.933859276249693*^9}, {3.9339328973392334`*^9, 
   3.9339328987166367`*^9}},ExpressionUUID->"caa7950c-a087-7144-bc3e-\
8c7d7e42fdd1"],

Cell["\<\
If we consider that exponents also add when multiplied, i.e.,\
\>", "Text",
 CellChangeTimes->{
  3.9144175005306997`*^9, {3.9144175393803883`*^9, 
   3.9144175540845213`*^9}},ExpressionUUID->"12cf3d17-af9d-4e48-9bed-\
0610988dc6d7"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   SuperscriptBox[
    StyleBox["a",
     FontSlant->"Italic"], 
    SubscriptBox["\[Theta]", "1"]], 
   SuperscriptBox[
    StyleBox["a",
     FontSlant->"Italic"], 
    SubscriptBox["\[Theta]", "2"]]}], "=", 
  SuperscriptBox[
   StyleBox["a",
    FontSlant->"Italic"], 
   RowBox[{
    SubscriptBox["\[Theta]", "1"], "+", 
    SubscriptBox["\[Theta]", "2"]}]]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{
  3.9144175465910187`*^9},ExpressionUUID->"0b64eaaf-8b42-47be-9ad0-\
ddc0a92fe9f3"],

Cell["\<\
perhaps we can represent our sin/cos equation using an exponent.  From here, \
the math gets a bit complicated, but we find that the proper equation is\
\>", "Text",
 CellChangeTimes->{{3.914417551509004*^9, 
  3.9144175730613365`*^9}},ExpressionUUID->"1a4b0f81-babf-4f92-a8bf-\
5f7d988fcf40"],

Cell[BoxData[
 RowBox[{
  SuperscriptBox["\[ExponentialE]", 
   RowBox[{
    RowBox[{"\[PlusMinus]", "\[ImaginaryI]"}], "\[Theta]"}]], "=", 
  RowBox[{
   RowBox[{"cos", " ", "\[Theta]"}], "\[PlusMinus]", " ", 
   RowBox[{
   "\[ImaginaryI]", " ", "sin", " ", 
    "\[Theta]"}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8395111265347805`*^9, 
  3.839511177082587*^9}},ExpressionUUID->"49a045a7-af0c-4527-b068-\
910191012d9c"],

Cell[TextData[{
 "This is known as ",
 StyleBox["Euler\[CloseCurlyQuote]s formula",
  FontWeight->"Bold"],
 ", and it is an extremely important tool in quantum mechanics. We\
\[CloseCurlyQuote]ll be using it quite often as the course goes on."
}], "Text",
 CellChangeTimes->{
  3.839511115061317*^9, {3.8395111802609477`*^9, 3.839511181666628*^9}, {
   3.9144175793545403`*^9, 
   3.91441759036675*^9}},ExpressionUUID->"132daea3-b965-4543-bcd1-\
6dd312cf34b7"]
}, Open  ]]
}, Open  ]]
}, Open  ]]
