Cell[TextData[{
 StyleBox["Figure 10.3",
  FontWeight->"Bold"],
 ". Illustration of the atomic overlap integral for two 1",
 StyleBox["s",
  FontSlant->"Italic"],
 " orbitals. If the nuclei are far apart (left), then ",
 StyleBox["S",
  FontSlant->"Italic"],
 " will equal zero because ",
 Cell[BoxData[
  RowBox[{
   SubsuperscriptBox["\[Phi]", 
    RowBox[{"1", 
     SubscriptBox[
      StyleBox["s",
       FontSlant->"Italic"], 
      StyleBox["B",
       FontSlant->"Italic"]]}], "\[Star]"], 
   SubscriptBox["\[Phi]", 
    RowBox[{"1", 
     SubscriptBox[
      StyleBox["s",
       FontSlant->"Italic"], 
      StyleBox["A",
       FontSlant->"Italic"]]}]]}]],
  CellChangeTimes->{{3.813228038288596*^9, 3.813228093385758*^9}, {
   3.8132336120692124`*^9, 3.8132336334997315`*^9}, {3.8132336788534994`*^9, 
   3.813233689019577*^9}, {3.813233767533953*^9, 3.813233938988695*^9}, {
   3.8132340269582367`*^9, 3.813234187742289*^9}},ExpressionUUID->
  "8cb180a9-d334-41bb-b13e-874af10b5306"],
 " will be zero everywhere. If the two nuclei are closer (right), then ",
 Cell[BoxData[
  RowBox[{
   SubsuperscriptBox["\[Phi]", 
    RowBox[{"1", 
     SubscriptBox[
      StyleBox["s",
       FontSlant->"Italic"], 
      StyleBox["B",
       FontSlant->"Italic"]]}], "\[Star]"], 
   SubscriptBox["\[Phi]", 
    RowBox[{"1", 
     SubscriptBox[
      StyleBox["s",
       FontSlant->"Italic"], 
      StyleBox["A",
       FontSlant->"Italic"]]}]]}]],
  CellChangeTimes->{{3.813228038288596*^9, 3.813228093385758*^9}, {
   3.8132336120692124`*^9, 3.8132336334997315`*^9}, {3.8132336788534994`*^9, 
   3.813233689019577*^9}, {3.813233767533953*^9, 3.813233938988695*^9}, {
   3.8132340269582367`*^9, 3.813234187742289*^9}},ExpressionUUID->
  "e57a8a22-94dd-4e4d-9a0a-1c208b7c6c98"],
 " will be nonzero where the two orbital wavefunctions overlap, giving a \
nonzero value for ",
 StyleBox["S",
  FontSlant->"Italic"],
 "."
}], "Affiliation",
 CellChangeTimes->{{3.809435027311596*^9, 3.8094350763900714`*^9}, {
  3.80943583474421*^9, 3.8094358359299717`*^9}, {3.8094472165104203`*^9, 
  3.809447281165168*^9}, {3.809510876137825*^9, 3.809510907739876*^9}, {
  3.809968073566992*^9, 3.8099681536568317`*^9}, {3.810557260250428*^9, 
  3.8105572606139913`*^9}, {3.8130835305386977`*^9, 3.8130836194514275`*^9}, {
  3.813224407772764*^9, 3.8132244817756805`*^9}, {3.8132354037950773`*^9, 
  3.813235501614183*^9}, {3.918584921693467*^9, 3.9185849221077847`*^9}, {
  3.9374866530886154`*^9, 
  3.9374866534097404`*^9}},ExpressionUUID->"370aa4a7-dc1e-4a11-8ce3-\
2be4059f167d"],

Cell[TextData[{
 "These concepts are illustrated in Figure 10.3 for two hypothetical 1",
 StyleBox["s",
  FontSlant->"Italic"],
 " orbitals on two nuclei separated by some distance. If the nuclei are far \
apart (left), the value of ",
 StyleBox["S",
  FontSlant->"Italic"],
 " will be nearly zero, because the product ",
 Cell[BoxData[
  RowBox[{
   SubsuperscriptBox["\[Phi]", 
    RowBox[{"1", 
     SubscriptBox[
      StyleBox["s",
       FontSlant->"Italic"], 
      StyleBox["B",
       FontSlant->"Italic"]]}], "\[Star]"], 
   SubscriptBox["\[Phi]", 
    RowBox[{"1", 
     SubscriptBox[
      StyleBox["s",
       FontSlant->"Italic"], 
      StyleBox["A",
       FontSlant->"Italic"]]}]]}]],
  CellChangeTimes->{{3.813228038288596*^9, 3.813228093385758*^9}, {
   3.8132336120692124`*^9, 3.8132336334997315`*^9}, {3.8132336788534994`*^9, 
   3.813233689019577*^9}, {3.813233767533953*^9, 3.813233938988695*^9}, {
   3.8132340269582367`*^9, 3.813234187742289*^9}},ExpressionUUID->
  "3ee5fa07-1212-4256-97cd-426e426a6484"],
 " will be zero everywhere. If the nuclei are close (right), then ",
 Cell[BoxData[
  SubscriptBox["\[Phi]", 
   RowBox[{"1", 
    SubscriptBox[
     StyleBox["s",
      FontSlant->"Italic"], 
     StyleBox["B",
      FontSlant->"Italic"]]}]]],
  CellChangeTimes->{{3.813228038288596*^9, 3.813228093385758*^9}, {
   3.8132336120692124`*^9, 3.8132336334997315`*^9}, {3.8132336788534994`*^9, 
   3.813233689019577*^9}, {3.813233767533953*^9, 3.813233938988695*^9}, {
   3.8132340269582367`*^9, 3.813234187742289*^9}},ExpressionUUID->
  "f594ed68-bfdd-4801-81ca-15fc67bcbdf8"],
 " and ",
 Cell[BoxData[
  SubscriptBox["\[Phi]", 
   RowBox[{"1", 
    SubscriptBox[
     StyleBox["s",
      FontSlant->"Italic"], 
     StyleBox["A",
      FontSlant->"Italic"]]}]]],ExpressionUUID->
  "f49d6e63-60d1-49fd-a800-9075a0e17273"],
 " overlap, which gives a nonzero value of ",
 StyleBox["S",
  FontSlant->"Italic"],
 ". Note that more generally, the orbital functions can also take on negative \
values, which can give a value of ",
 StyleBox["S ",
  FontSlant->"Italic"],
 "of zero even if the orbital functions overlap."
}], "Text",
 CellChangeTimes->{{3.813235512830369*^9, 3.8132355518504987`*^9}, {
  3.8132358850970583`*^9, 3.813235886964933*^9}, {3.9185849250734143`*^9, 
  3.918584925435169*^9}, {3.9374866568267574`*^9, 
  3.9374866570953503`*^9}},ExpressionUUID->"b5a78e1f-14dc-46ca-9ded-\
aa813498a0e8"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Energies of the Molecular Orbitals", "Subsubsection",
 CellChangeTimes->{{3.8132359392586365`*^9, 
  3.8132359536442432`*^9}},ExpressionUUID->"bec18b3b-b3d5-4550-9a95-\
735d3c55513c"],

Cell["\<\
Now that we have properly normalized the two wavefunctions, we return to the \
task of determining the energy using the variational method,\
\>", "Text",
 CellChangeTimes->{{3.813426424546599*^9, 
  3.813426478835417*^9}},ExpressionUUID->"d6b5ef7b-0349-4cbe-8877-\
2f0410bba3da"],

Cell[BoxData[
 RowBox[{
  SubscriptBox[
   StyleBox["E",
    FontSlant->"Italic"], "\[PlusMinus]"], "=", 
  FractionBox[
   RowBox[{"\[LeftAngleBracket]", 
    RowBox[{
     SubscriptBox["\[Psi]", "\[PlusMinus]"], "|", 
     SubscriptBox[
      OverscriptBox[
       StyleBox["H",
        FontSlant->"Italic"], "^"], 
      StyleBox["e",
       FontSlant->"Italic"]], "|", 
     SubscriptBox["\[Psi]", "\[PlusMinus]"]}], "\[RightAngleBracket]"}], 
   RowBox[{"\[LeftAngleBracket]", 
    RowBox[{
     SubscriptBox["\[Psi]", "\[PlusMinus]"], "|", 
     SubscriptBox["\[Psi]", "\[PlusMinus]"]}], 
    "\[RightAngleBracket]"}]]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.813228038288596*^9, 3.813228093385758*^9}, {
  3.8132336120692124`*^9, 3.8132336334997315`*^9}, {3.8132336788534994`*^9, 
  3.813233689019577*^9}},ExpressionUUID->"f1380eb4-eb70-5146-8155-\
e066976e6086"],

Cell["\<\
For the normalized wavefunctions, the denominator is now equal to 1, but we \
must now evaluate the numerator. Using the normalized wavefunctions, we obtain\
\>", "Text",
 CellChangeTimes->{{3.813426489171689*^9, 3.813426533943511*^9}, {
  3.8134275118711257`*^9, 3.8134275136555686`*^9}, {3.8134275741042757`*^9, 
  3.8134275747305317`*^9}, {3.81342761730235*^9, 
  3.8134276182720957`*^9}},ExpressionUUID->"7e682308-bc53-49aa-b80c-\
bffe1cec3e60"],

Cell[BoxData[{
 RowBox[{
  SubscriptBox[
   StyleBox["E",
    FontSlant->"Italic"], "\[PlusMinus]"], "=", 
  RowBox[{
   RowBox[{"\[LeftAngleBracket]", 
    RowBox[{
     SubscriptBox["\[Psi]", "\[PlusMinus]"], "|", 
     SubscriptBox[
      OverscriptBox[
       StyleBox["H",
        FontSlant->"Italic"], "^"], 
      StyleBox["e",
       FontSlant->"Italic"]], "|", 
     SubscriptBox["\[Psi]", "\[PlusMinus]"]}], "\[RightAngleBracket]"}], "=", 
   RowBox[{"\[LeftAngleBracket]", 
    RowBox[{
     RowBox[{
      FractionBox["1", 
       SqrtBox[
        RowBox[{"2", 
         RowBox[{"(", 
          RowBox[{"1", "\[PlusMinus]", 
           StyleBox["S",
            FontSlant->"Italic"]}], 
          StyleBox[")",
           FontSlant->"Italic"]}]}]]], 
      RowBox[{"(", 
       RowBox[{
        SubscriptBox["\[Phi]", 
         RowBox[{"1", 
          SubscriptBox[
           StyleBox["s",
            FontSlant->"Italic"], 
           StyleBox["A",
            FontSlant->"Italic"]]}]], "\[PlusMinus]", 
        SubscriptBox["\[Phi]", 
         RowBox[{"1", 
          SubscriptBox[
           StyleBox["s",
            FontSlant->"Italic"], 
           StyleBox["B",
            FontSlant->"Italic"]]}]]}], ")"}]}], "|", 
     SubscriptBox[
      OverscriptBox[
       StyleBox["H",
        FontSlant->"Italic"], "^"], 
      StyleBox["e",
       FontSlant->"Italic"]], "|", 
     RowBox[{
      FractionBox["1", 
       SqrtBox[
        RowBox[{"2", 
         RowBox[{"(", 
          RowBox[{"1", "\[PlusMinus]", 
           StyleBox["S",
            FontSlant->"Italic"]}], 
          StyleBox[")",
           FontSlant->"Italic"]}]}]]], 
      RowBox[{"(", 
       RowBox[{
        SubscriptBox["\[Phi]", 
         RowBox[{"1", 
          SubscriptBox[
           StyleBox["s",
            FontSlant->"Italic"], 
           StyleBox["A",
            FontSlant->"Italic"]]}]], "\[PlusMinus]", 
        SubscriptBox["\[Phi]", 
         RowBox[{"1", 
          SubscriptBox[
           StyleBox["s",
            FontSlant->"Italic"], 
           StyleBox["B",
            FontSlant->"Italic"]]}]]}], ")"}]}]}], 
    "\[RightAngleBracket]"}]}]}], "\[IndentingNewLine]", 
 RowBox[{"\t\t\t       ", 
  RowBox[{"=", 
   RowBox[{
    FractionBox["1", 
     RowBox[{"2", 
      RowBox[{"(", 
       RowBox[{"1", "\[PlusMinus]", 
        StyleBox["S",
         FontSlant->"Italic"]}], 
       StyleBox[")",
        FontSlant->"Italic"]}]}]], "[", 
    RowBox[{
     RowBox[{"\[LeftAngleBracket]", 
      RowBox[{
       SubscriptBox["\[Phi]", 
        RowBox[{"1", 
         SubscriptBox[
          StyleBox["s",
           FontSlant->"Italic"], 
          StyleBox["A",
