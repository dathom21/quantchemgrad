    StyleBox["sp",
     FontSlant->"Italic"], 
    StyleBox["j",
     FontSlant->"Italic"]]], "=", 
  RowBox[{
   FractionBox["1", 
    SqrtBox["2"]], 
   RowBox[{"(", 
    RowBox[{
     SubscriptBox["\[Phi]", 
      RowBox[{"2", 
       StyleBox["s",
        FontSlant->"Italic"]}]], "-", 
     SubscriptBox["\[Phi]", 
      RowBox[{"2", 
       SubscriptBox[
        StyleBox["p",
         FontSlant->"Italic"], "z"]}]]}], 
