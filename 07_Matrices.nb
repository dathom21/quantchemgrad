 RowBox[{
  RowBox[{
   RowBox[{"-", 
    SubscriptBox["a", "13"]}], " ", 
   SubscriptBox["a", "22"], " ", 
   SubscriptBox["a", "31"]}], "+", 
  RowBox[{
   SubscriptBox["a", "12"], " ", 
   SubscriptBox["a", "23"], " ", 
   SubscriptBox["a", "31"]}], "+", 
  RowBox[{
   SubscriptBox["a", "13"], " ", 
