Cell[CellGroupData[{

Cell["Identical Rows or Columns Give a Determinant of Zero", "Subsubsection",
 CellChangeTimes->{{3.81131822525836*^9, 3.8113182531407485`*^9}, {
   3.811318437032322*^9, 3.811318467257702*^9}, 
   3.811318566065028*^9},ExpressionUUID->"d5b9fe07-6386-4001-98ee-\
31c916b1581c"],

Cell["\<\
If any two rows or any two columns of a matrix are identical, the determinant \
is equal to zero. This result is easiest to see with an example.\
\>", "Text",
 CellChangeTimes->{{3.811318256065713*^9, 3.811318304893315*^9}, {
  3.8113184708642206`*^9, 3.8113184855136*^9}, {3.8113185694611273`*^9, 
  3.81131857191124*^9}, {3.8422505250292*^9, 
  3.842250526313475*^9}},ExpressionUUID->"113de2cd-0db5-4225-b219-\
6e1ab2d4fcb1"],

Cell[BoxData[
 RowBox[{
  RowBox[{"\[LeftBracketingBar]", "\[NoBreak]", GridBox[{
     {
      RowBox[{"-", "3"}], "2", 
      RowBox[{"-", "3"}]},
     {"1", "8", "1"},
     {"5", "2", "5"}
    }], "\[NoBreak]", "\[RightBracketingBar]"}], "=", 
  "0"}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.811318113364401*^9, 3.8113181244722557`*^9}, {
  3.8113183185577393`*^9, 
  3.811318356204027*^9}},ExpressionUUID->"3b639c11-0bc6-4d2d-8cd4-\
a83d53f4026a"],

Cell["Or, evaluating using Mathematica,", "Text",
 CellChangeTimes->{{3.8113183619711847`*^9, 
  3.8113183791752396`*^9}},ExpressionUUID->"a7461ebc-9a52-4c5d-aa70-\
b6555fb541b7"],

