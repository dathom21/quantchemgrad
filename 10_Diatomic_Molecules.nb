   3.8135091949215007`*^9, 3.813509209133624*^9}},ExpressionUUID->
  "e1782043-bea9-45b7-91bb-0181a05c5b4d"],
 " as a function of the internuclear distance ",
 StyleBox["R",
  FontSlant->"Italic"],
 "."
}], "Affiliation",
 CellChangeTimes->{{3.809435027311596*^9, 3.8094350763900714`*^9}, {
   3.80943583474421*^9, 3.8094358359299717`*^9}, {3.8094472165104203`*^9, 
   3.809447281165168*^9}, {3.809510876137825*^9, 3.809510907739876*^9}, {
   3.809968073566992*^9, 3.8099681536568317`*^9}, {3.810557260250428*^9, 
   3.8105572606139913`*^9}, {3.8130835305386977`*^9, 
   3.8130836194514275`*^9}, {3.813224407772764*^9, 3.8132244817756805`*^9}, {
   3.8132354037950773`*^9, 3.813235501614183*^9}, 3.813236418234542*^9, {
   3.81351439000795*^9, 3.8135143988971663`*^9}, {3.919512516748942*^9, 
   3.919512517493187*^9}, {3.9374874556290836`*^9, 
   3.9374874559147053`*^9}},ExpressionUUID->"acbe54d9-1236-471f-96f2-\
0650acf412cf"],

Cell[TextData[{
 "We see that the only stable complex (minimum in the potential energy) \
arises in the ",
 Cell[BoxData[
  SubscriptBox["\[Psi]", "+"]],
  CellChangeTimes->{{3.813228038288596*^9, 3.813228093385758*^9}, {
   3.8132336120692124`*^9, 3.8132336334997315`*^9}, {3.8132336788534994`*^9, 
   3.813233689019577*^9}},ExpressionUUID->
  "68eeb98b-50a9-4dd8-921a-1ae590f1c367"],
 " state, with ",
 StyleBox["R",
  FontSlant->"Italic"],
 " \[TildeTilde] ",
 Cell[BoxData[
  FormBox[
   RowBox[{"2.5", 
    SubscriptBox["a", "0"]}], TraditionalForm]],ExpressionUUID->
  "c9adebb2-5503-482b-86e7-526dbc8fc70a"],
 ". Note that the stabilization with respect to the separated nuclei is on \
the order of \[Minus]0.065 Hartrees. This value may sound small but becomes \
~170 kJ ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["mol", 
    RowBox[{"\[Minus]", "1"}]], TraditionalForm]],ExpressionUUID->
  "72593229-f6d7-4978-8ebb-358328401da0"],
 " following unit conversion, which is quite substantial. Note that there is \
no value of ",
 StyleBox["R",
  FontSlant->"Italic"],
 " for which the ",
 Cell[BoxData[
  SubscriptBox["\[Psi]", "-"]],
  CellChangeTimes->{{3.813228038288596*^9, 3.813228093385758*^9}, {
   3.8132336120692124`*^9, 3.8132336334997315`*^9}, {3.8132336788534994`*^9, 
   3.813233689019577*^9}},ExpressionUUID->
  "1332313c-d0db-443e-bb43-f9b2104b5f92"],
 " state is more stable than the separated hydrogen atom and proton. The net \
energetic stability of the ",
 Cell[BoxData[
  SubscriptBox["\[Psi]", "+"]],
  CellChangeTimes->{{3.813228038288596*^9, 3.813228093385758*^9}, {
   3.8132336120692124`*^9, 3.8132336334997315`*^9}, {3.8132336788534994`*^9, 
   3.813233689019577*^9}},ExpressionUUID->
  "63c9cab6-7df2-4cf9-96a2-194e3211e85a"],
 " state arises from the contributions of the exchanged attractive term ",
 StyleBox["M",
  FontSlant->"Italic"],
 ", which provides the additional stabilization necessary to overcome the \
nuclear-nuclear repulsion. Because this term is quantum-mechanical in origin, \
we say that the bonding can only be described accurately by quantum mechanics."
}], "Text",
 CellChangeTimes->{{3.813511859552352*^9, 3.813511891392679*^9}, {
   3.8135119512377415`*^9, 3.8135120922115993`*^9}, {3.8135121233201637`*^9, 
   3.813512313001524*^9}, {3.813512452636011*^9, 3.813512555751388*^9}, 
   3.813514470015444*^9, {3.9195125340897803`*^9, 3.9195125414810333`*^9}, {
   3.9374874766011333`*^9, 3.937487477726303*^9}, {3.9375748044556217`*^9, 
   3.9375748048724995`*^9}},ExpressionUUID->"f8401490-536f-41ba-8e1e-\
f73d9bf6db28"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[{
 "The Bonding and Antibonding Orbitals of ",
 Cell[BoxData[
  FormBox[
   SubsuperscriptBox[
    StyleBox["H",
     FontSlant->"Plain"], "2", "+"], TraditionalForm]],ExpressionUUID->
  "a9784e77-e6af-435d-ba3e-4b5db3a3d244"]
}], "Subsection",
 CellChangeTimes->{{3.813597651277997*^9, 
  3.813597667734645*^9}},ExpressionUUID->"5cf0b572-fba0-4b44-8658-\
f76a2b05218c"],

Cell[TextData[{
 "Before discussing the shape of the two molecular orbitals, let\
\[CloseCurlyQuote]s summarize the results we have so far. Beginning with a \
trial wavefunction for ",
 Cell[BoxData[
  FormBox[
   SubsuperscriptBox[
    StyleBox["H",
     FontSlant->"Plain"], "2", "+"], TraditionalForm]],ExpressionUUID->
  "e763e204-6e85-4791-9921-1d3719161123"],
 " comprising a linear combination of hydrogen 1",
 StyleBox["s",
  FontSlant->"Italic"],
 " atomic orbitals, we have found two eigenfunctions of the electronic \
Hamiltonian,"
}], "Text",
 CellChangeTimes->{{3.8135976769373198`*^9, 3.8135978040734873`*^9}, {
  3.813597838376029*^9, 
  3.8135978693723593`*^9}},ExpressionUUID->"2b2a3bdd-3509-40d7-9561-\
9736fc8ee447"],

Cell[BoxData[
 RowBox[{
  SubscriptBox["\[Psi]", "+"], "=", 
  RowBox[{
   FractionBox["1", 
    SqrtBox[
     RowBox[{"2", 
      RowBox[{"(", 
       RowBox[{"1", "+", 
        StyleBox["S",
         FontSlant->"Italic"]}], 
       StyleBox[")",
        FontSlant->"Italic"]}]}]]], 
   RowBox[{"(", 
    RowBox[{
     SubscriptBox["\[Phi]", 
      RowBox[{"1", 
       SubscriptBox[
        StyleBox["s",
         FontSlant->"Italic"], 
        StyleBox["A",
         FontSlant->"Italic"]]}]], "+", 
     SubscriptBox["\[Phi]", 
      RowBox[{"1", 
       SubscriptBox[
        StyleBox["s",
         FontSlant->"Italic"], 
        StyleBox["B",
         FontSlant->"Italic"]]}]]}], ")"}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8132221669142685`*^9, 3.8132221794693403`*^9}, {
   3.8132222690385857`*^9, 3.813222292552426*^9}, {3.8132225103046436`*^9, 
   3.8132225357976294`*^9}, 3.813225530724597*^9, {3.8132268996594105`*^9, 
   3.8132268997936573`*^9}, {3.8132269718506794`*^9, 
   3.8132270598936987`*^9}, {3.813227090063882*^9, 3.8132270928942423`*^9}, {
   3.8132273687054873`*^9, 3.8132273956726027`*^9}, {3.8132274257354927`*^9, 
   3.8132274504676456`*^9}, {3.813227484968296*^9, 3.8132274916733313`*^9}, {
   3.813227717592659*^9, 3.813227799104663*^9}, {3.8132278524338465`*^9, 
   3.813227854764579*^9}, 3.8132279269606223`*^9, {3.8132284806854115`*^9, 
   3.8132285040063257`*^9}, {3.813233670328187*^9, 3.8132336720975046`*^9}, {
   3.8132357631856723`*^9, 
   3.8132357709170113`*^9}},ExpressionUUID->"9cfdfbfc-aea9-4723-8d79-\
00f861837952"],

Cell["and", "Text",
 CellChangeTimes->{{3.8132284776197124`*^9, 
  3.813228477809259*^9}},ExpressionUUID->"ee41b470-eea9-4ab3-902b-\
712d1fbe865b"],

Cell[BoxData[
 RowBox[{
  SubscriptBox["\[Psi]", 
   StyleBox["-",
    FontSlant->"Italic"]], "=", 
  RowBox[{
   FractionBox["1", 
    SqrtBox[
     RowBox[{"2", 
      RowBox[{"(", 
       RowBox[{"1", "-", 
        StyleBox["S",
         FontSlant->"Italic"]}], 
       StyleBox[")",
        FontSlant->"Italic"]}]}]]], 
   RowBox[{"(", 
    RowBox[{
     SubscriptBox["\[Phi]", 
      RowBox[{"1", 
       SubscriptBox[
        StyleBox["s",
         FontSlant->"Italic"], 
        StyleBox["A",
         FontSlant->"Italic"]]}]], "-", 
     SubscriptBox["\[Phi]", 
      RowBox[{"1", 
       SubscriptBox[
        StyleBox["s",
         FontSlant->"Italic"], 
        StyleBox["B",
         FontSlant->"Italic"]]}]]}], 
    StyleBox[")",
     FontSlant->"Italic"]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8132221669142685`*^9, 3.8132221794693403`*^9}, {
   3.8132222690385857`*^9, 3.813222292552426*^9}, {3.8132225103046436`*^9, 
   3.8132225357976294`*^9}, 3.813225530724597*^9, {3.8132268996594105`*^9, 
   3.8132268997936573`*^9}, {3.8132269718506794`*^9, 
   3.8132270598936987`*^9}, {3.813227090063882*^9, 3.8132270928942423`*^9}, {
   3.8132273687054873`*^9, 3.8132273956726027`*^9}, {3.8132274257354927`*^9, 
   3.8132274504676456`*^9}, {3.813227484968296*^9, 3.8132274916733313`*^9}, {
   3.813227717592659*^9, 3.813227799104663*^9}, {3.8132278524338465`*^9, 
   3.813227854764579*^9}, 3.8132279269606223`*^9, {3.8132284860819626`*^9, 
   3.8132285176811366`*^9}, {3.813233674404284*^9, 3.813233675974839*^9}, {
   3.813235766517973*^9, 
   3.8132357685947847`*^9}},ExpressionUUID->"e3e6466b-ffb2-4a49-876e-\
79ad3e2166c2"],

Cell["whose energies are given by", "Text",
 CellChangeTimes->{{3.8135979441608114`*^9, 
  3.813597947900883*^9}},ExpressionUUID->"13006f31-aa7a-4003-9e42-\
c223ff5935b6"],

Cell[BoxData[
 RowBox[{
  SubscriptBox[
   StyleBox["E",
    FontSlant->"Italic"], "\[PlusMinus]"], "=", 
  RowBox[{
   SubscriptBox[
    StyleBox["E",
     FontSlant->"Italic"], 
    RowBox[{"1", 
     StyleBox["s",
      FontSlant->"Italic"]}]], "+", 
   FractionBox["1", 
    StyleBox["R",
     FontSlant->"Italic"]], "+", 
   FractionBox[
    RowBox[{
     StyleBox["N",
      FontSlant->"Italic"], "\[PlusMinus]", 
     StyleBox["M",
      FontSlant->"Italic"]}], 
    RowBox[{"1", "\[PlusMinus]", 
     StyleBox["S",
      FontSlant->"Italic"]}]]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.813507432429942*^9, 3.8135074361176004`*^9}, {
  3.81351045057891*^9, 
  3.8135104513772106`*^9}},ExpressionUUID->"097a9bf1-df5f-6947-bf36-\
e750badf86ec"],

Cell[TextData[{
 "The energies ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["E",
    FontSlant->"Italic"], "\[PlusMinus]"]],
  CellChangeTimes->{{3.813507432429942*^9, 3.8135074361176004`*^9}, {
   3.81351045057891*^9, 3.8135104513772106`*^9}},ExpressionUUID->
  "f0de4677-f3b1-46a5-9b76-c8ee03db6965"],
 " depend on the internuclear distance ",
 StyleBox["R ",
  FontSlant->"Italic"],
 "(remember that these are the approximate eigenfunctions of the electronic \
Hamiltonian with fixed nuclear positions), and we find that the function ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["E",
     FontSlant->"Italic"], "+"], 
   RowBox[{"(", 
    StyleBox["R",
     FontSlant->"Italic"], 
    StyleBox[")",
     FontSlant->"Italic"]}]}]],
  CellChangeTimes->{{3.813507432429942*^9, 3.8135074361176004`*^9}, {
   3.81351045057891*^9, 3.8135104513772106`*^9}},ExpressionUUID->
  "203fd3ab-757f-4647-bd4a-33ae566023ce"],
 " exhibits a minimum at ",
 StyleBox["R",
  FontSlant->"Italic"],
 " \[TildeTilde] ",
 Cell[BoxData[
  FormBox[
   RowBox[{"2.5", 
    SubscriptBox["a", "0"]}], TraditionalForm]],ExpressionUUID->
  "8f69d862-8a6e-4e37-b365-86c60020cb2d"],
 ". In contrast, ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["E",
     FontSlant->"Italic"], "-"], 
   RowBox[{"(", 
    StyleBox["R",
     FontSlant->"Italic"], 
    StyleBox[")",
     FontSlant->"Italic"]}]}]],
  CellChangeTimes->{{3.813507432429942*^9, 3.8135074361176004`*^9}, {
   3.81351045057891*^9, 3.8135104513772106`*^9}},ExpressionUUID->
  "28cb3482-8e85-4f31-ac29-52a3cab4d580"],
 "exhibits no minimum and only increases as nuclear distance decreases. "
}], "Text",
 CellChangeTimes->{{3.8135991888571167`*^9, 3.8135996145927258`*^9}, {
  3.813600018664178*^9, 3.8136000239458275`*^9}, {3.9195125803393807`*^9, 
  3.9195125806821985`*^9}},ExpressionUUID->"803eb44b-e214-4771-b3d3-\
a4301baddd42"],

Cell[TextData[{
 "We label the state ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Psi]", "+"], TraditionalForm]],ExpressionUUID->
  "2a0ec8f6-c557-410c-b23b-1c6dd1561cb0"],
 " the bonding molecular orbital, and the state ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Psi]", "-"], TraditionalForm]],ExpressionUUID->
  "4eb5bf50-9e62-4c98-b0a6-892fbf279502"],
 " the antibonding molecular orbital. In this molecular orbital \
approximation, the ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Psi]", "+"], TraditionalForm]],ExpressionUUID->
  "16e2c31d-277d-4647-9a9a-8227b6e6704b"],
 " state is the ground state, and the molecule in this state will have an \
equilibrium bond distance of \[Tilde]",
 Cell[BoxData[
  FormBox[
   RowBox[{"2.5", 
    SubscriptBox["a", "0"]}], TraditionalForm]],ExpressionUUID->
  "1a77f80a-73b1-4f26-bb54-c1d736b672bd"],
 ". Since the energy function ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["E",
     FontSlant->"Italic"], "-"], 
   RowBox[{"(", 
    StyleBox["R",
     FontSlant->"Italic"], 
    StyleBox[")",
     FontSlant->"Italic"]}]}]],
  CellChangeTimes->{{3.813507432429942*^9, 3.8135074361176004`*^9}, {
   3.81351045057891*^9, 3.8135104513772106`*^9}},ExpressionUUID->
  "774fb815-3888-4dfa-ae79-8ce97166316b"],
 "exhibits no minimum, the antibonding state ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Psi]", "-"], TraditionalForm]],ExpressionUUID->
  "c60e8ee0-7013-4d3c-bdf3-872250af0036"],
 " is dissociative, and promotion of the electron to this state would lead to \
dissociation of the molecule."
}], "Text",
 CellChangeTimes->{{3.813600026394861*^9, 3.8136000336720605`*^9}, {
  3.8136001402196665`*^9, 3.8136002774601326`*^9}, {3.813600358409472*^9, 
  3.8136004328025*^9}},ExpressionUUID->"128fc7b8-8dea-4099-8ada-c0475aaac673"],

Cell[TextData[{
 "We can visualize the shape of the molecular orbitals in one dimension by \
plotting the wavefunction along the internuclear axis. Such plots are shown \
in Figure 10.5 for  ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Psi]", "+"], TraditionalForm]],ExpressionUUID->
  "beb9e009-5674-4528-8794-f8af8e74570e"],
 ", ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Psi]", "-"], TraditionalForm]],ExpressionUUID->
  "9f970a2b-87ee-4b21-ab78-8b04d9be4863"],
 ",",
 Cell[BoxData[
  FormBox[
   RowBox[{"|", 
    SubscriptBox["\[Psi]", "+"], 
    SuperscriptBox["|", "2"]}], TraditionalForm]],ExpressionUUID->
  "81b4a243-29a4-48dd-9681-4b7aa023f98c"],
 ", and  ",
 Cell[BoxData[
  FormBox[
   RowBox[{"|", 
    SubscriptBox["\[Psi]", "-"], 
    SuperscriptBox["|", "2"]}], TraditionalForm]],ExpressionUUID->
  "9dda7b53-bf8c-4f97-86bf-42b16ab3a680"],
 " ."
}], "Text",
 CellChangeTimes->{{3.813600443994972*^9, 3.813600481504359*^9}, {
  3.8136005298661175`*^9, 3.8136005325681896`*^9}, {3.813601201764325*^9, 
  3.8136012325971174`*^9}, {3.8136028535270634`*^9, 3.813602896447034*^9}, {
  3.919512608780118*^9, 3.9195126097735157`*^9}, {3.937487549259987*^9, 
  3.937487549828602*^9}},ExpressionUUID->"23431f00-162a-4889-ba81-\
c2fd1797930f"],

Cell[CellGroupData[{

