        StyleBox["L",
         FontSlant->"Italic"]]}]], 
     StyleBox["dx",
      FontSlant->"Italic"]}]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8075248444745007`*^9, 3.807524991169207*^9}, {
  3.807542272766609*^9, 3.8075422748829927`*^9}, {3.9339353739220963`*^9, 
  3.9339353774149075`*^9}},ExpressionUUID->"69557606-1ace-1746-8af5-\
e9ff0b61bb45"],

Cell["\<\
You don\[CloseCurlyQuote]t need to worry about the details of this equation, \
but note that we have a way to calculate what the weighting factors are for \
each function based on an integral that involves multiplying the function by \
a complex exponential (which has the form of Euler\[CloseCurlyQuote]s \
formula).\
\>", "Text",
 CellChangeTimes->{{3.8075250771009274`*^9, 3.8075252422814064`*^9}, {
  3.8075252734719133`*^9, 3.8075252756957645`*^9}, {3.807533490085984*^9, 
  3.807533506946515*^9}, {3.8075414950433865`*^9, 3.807541496546204*^9}, {
  3.9339353930992184`*^9, 
  3.933935411565651*^9}},ExpressionUUID->"2c2a694e-c56b-404a-8e97-\
ae2384a9d41b"]
}, Open  ]],

Cell[CellGroupData[{

Cell["From Fourier Series to Fourier Transform", "Subsection",
 CellChangeTimes->{{3.9142386810030103`*^9, 3.914238691021989*^9}, 
   3.933935442785677*^9, {3.9339357350190105`*^9, 
   3.9339357405200653`*^9}},ExpressionUUID->"a8b057d3-437f-4082-b079-\
dd77a210b86d"],

Cell[TextData[{
 "The Fourier series only successfully represents a function on a given \
interval, but what happens when that interval becomes infinitely large \
(meaning ",
 StyleBox["L",
  FontSlant->"Italic"],
 "\[RightArrow]\[Infinity])? Now, the ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["A", "n"], TraditionalForm]],ExpressionUUID->
  "f227711e-22d7-f34b-aa7c-1722b01bc31c"],
 " values are no longer discrete values but rather a continuous set of values \
, so"
}], "Text",
 CellChangeTimes->{{3.9339355386227875`*^9, 3.93393562393169*^9}, {
  3.9339357042892017`*^9, 
  3.9339357168448963`*^9}},ExpressionUUID->"beeaf879-78ae-d64b-8913-\
1a4ebb093c9b"],

Cell[BoxData[
 RowBox[{
  SubscriptBox[
   StyleBox["A",
    FontSlant->"Italic"], 
   StyleBox["n",
    FontSlant->"Italic"]], " ", "\[RightArrow]", " ", 
  StyleBox[
   RowBox[{"F", 
    RowBox[{"(", "k", ")"}], "dk"}],
   FontSlant->"Italic"]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.807542787162401*^9, 3.8075427996169453`*^9}, {
  3.807543002885091*^9, 
  3.8075430151543164`*^9}},ExpressionUUID->"9d165c9c-7c39-7840-8451-\
119378e23284"],

Cell["\<\
Additionally, we are now integrating over the entire range of the function \
(from \[Minus]\[Infinity] to \[Infinity]). Putting all of this together we \
transform eq. 20 into\
\>", "Text",
 CellChangeTimes->{{3.8075430392704115`*^9, 3.807543093210332*^9}, {
  3.8075466830742455`*^9, 3.807546684149975*^9}, {3.8395850593350735`*^9, 
  3.839585059785194*^9}, {3.9339357293601055`*^9, 3.9339357311244583`*^9}, {
  3.933935774359497*^9, 
  3.9339357794690437`*^9}},ExpressionUUID->"b9df3a55-df3b-c54c-bf05-\
86a66566f574"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   StyleBox["f",
    FontSlant->"Italic"], 
   RowBox[{"(", 
    StyleBox["x",
     FontSlant->"Italic"], ")"}]}], "=", " ", 
  RowBox[{
   UnderoverscriptBox["\[Integral]", 
    RowBox[{"\[Minus]", "\[Infinity]"}], "\[Infinity]"], 
   RowBox[{
    StyleBox["F",
     FontSlant->"Italic"], 
    StyleBox[
     RowBox[{"(", "k", ")"}],
     FontSlant->"Italic"], 
    SuperscriptBox[
     StyleBox["e",
      FontSlant->"Italic"], 
     RowBox[{"2", 
      StyleBox[
       RowBox[{"\[Pi]", 
        StyleBox["ikx",
         FontSlant->"Italic"]}]]}]], 
    StyleBox["dk",
     FontSlant->"Italic"]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.807543109001136*^9, 3.807543137398696*^9}, {
  3.80754318548991*^9, 3.8075431932824893`*^9}, {3.8075435507174015`*^9, 
  3.8075435530894623`*^9}},ExpressionUUID->"5e82481f-ede0-3148-b9f1-\
87580f45103e"],

Cell["\<\
The form of our function that describes the weights for our basis now looks \
like (in analogy to eq. 21)\
\>", "Text",
 CellChangeTimes->{{3.807543337180436*^9, 3.807543357673326*^9}, {
   3.807543474516635*^9, 3.807543491984684*^9}, {3.807546690213784*^9, 
   3.807546709535629*^9}, {3.933935783741335*^9, 3.933935784042324*^9}, 
   3.933935889552765*^9},ExpressionUUID->"7d80ab66-d612-1e44-af0a-\
2633decce3a4"],

Cell[BoxData[
 RowBox[{
  StyleBox[
   RowBox[{"F", 
    RowBox[{"(", "k", ")"}]}],
   FontSlant->"Italic"], 
  StyleBox["=",
   FontSlant->"Italic"], 
  RowBox[{
   SubsuperscriptBox["\[Integral]", 
    RowBox[{"\[Minus]", "\[Infinity]"}], "\[Infinity]"], 
   RowBox[{
    StyleBox["f",
     FontSlant->"Italic"], 
    StyleBox[
     RowBox[{"(", "x", ")"}],
     FontSlant->"Italic"], 
    SuperscriptBox[
     StyleBox["e",
      FontSlant->"Italic"], 
     RowBox[{
      RowBox[{"\[Minus]", "2"}], 
      StyleBox[
       RowBox[{"\[Pi]", 
        StyleBox["ikx",
         FontSlant->"Italic"]}]]}]], 
    StyleBox["dx",
     FontSlant->"Italic"]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8075435044459763`*^9, 
  3.8075435601762033`*^9}},ExpressionUUID->"29183283-8869-b04f-a572-\
c093fbf7bea5"],

Cell[TextData[{
 "We call equations (24) and (23), the Fourier transform and inverse Fourier \
transform, respectively. We will be using a slightly different definition \
that incorporates a factor of ",
 Cell[BoxData[
  FractionBox["1", 
   SqrtBox[
    RowBox[{"2", "\[Pi]"}]]]],
  CellChangeTimes->{{3.807609924071587*^9, 3.807609933916641*^9}, {
   3.807610097235129*^9, 3.807610106816085*^9}, {3.8076101429189034`*^9, 
   3.807610149406391*^9}, {3.914406439155041*^9, 3.9144064442392645`*^9}},
  ExpressionUUID->"e7b792d0-83c6-1444-b25e-ea73441db1ae"],
 ", but the basic form and function of the transform remain the same."
}], "Text",
 CellChangeTimes->{{3.933935786966961*^9, 3.9339358415115395`*^9}, {
  3.933935902125492*^9, 
  3.9339359361909046`*^9}},ExpressionUUID->"e3dba831-1f0d-bd42-9cc3-\
d325c4461056"]
}, Open  ]],

Cell[CellGroupData[{

Cell["The meaning of the Fourier transform", "Subsection",
 CellChangeTimes->{{3.9339357468984985`*^9, 3.9339357500648327`*^9}, {
  3.933935857436775*^9, 
  3.9339358625931263`*^9}},ExpressionUUID->"52687a79-23a8-3547-ba07-\
8167db8dca72"],

Cell[TextData[{
 "The Fourier transform is a mathematical representation encountered in many \
different applications. It is most often used to change a ",
 StyleBox["variable",
  FontSlant->"Italic"],
 " to its ",
 StyleBox["reciprocal",
  FontSlant->"Italic"],
 " ",
 StyleBox[" ",
  FontSlant->"Italic"],
 "to make data more easily interpretable. For example, one can change an \
intensity vs time graph to an intensity vs. frequency graph, a hugely \
powerful methodology to deconstruct any process that is periodic in time."
}], "Text",
 CellChangeTimes->{{3.80754967086403*^9, 3.807549861935769*^9}, {
  3.8076097907634525`*^9, 3.8076098019491463`*^9}, {3.807610256399227*^9, 
  3.807610570580367*^9}, {3.807610733795739*^9, 3.807610755584035*^9}, {
  3.839585208249816*^9, 3.839585210189824*^9}, {3.9142387682002745`*^9, 
  3.914238824434161*^9}},ExpressionUUID->"f0311209-5efe-4ad1-a14c-\
0efb98f47c03"],

Cell[TextData[{
 "A Fourier transform switches between variables that are inversely related, \
for example time (units s) and frequency (units ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    StyleBox["s",
     FontSlant->"Plain"], 
    RowBox[{"\[Minus]", "1"}]], TraditionalForm]],ExpressionUUID->
  "b66e9fd0-f7b0-4910-bcf0-3fc7191740ce"],
 "). Because of this inverse relationship, you can qualitatively guess that ",
 StyleBox["when you narrow the distribution in one space (e.g. time), you \
broaden it in the other",
  FontWeight->"Bold"],
 ". The Fourier transform lets us evaluate this relationship more \
quantitatively and also lets us visualize it."
}], "Text",
 CellChangeTimes->{{3.914238827736609*^9, 3.9142388306712456`*^9}, {
  3.914239314002864*^9, 
  3.914239315472396*^9}},ExpressionUUID->"f99a8440-04aa-4655-a424-\
0da2a1ae709c"],

Cell["\<\
For the relationship between frequency and time, the Fourier transform can be \
written as \
\>", "Text",
 CellChangeTimes->{{3.80754672369016*^9, 3.8075467594847956`*^9}, {
  3.807548960100156*^9, 3.807548979038104*^9}, {3.8075491827640867`*^9, 
  3.8075491908420105`*^9}, {3.807549270926073*^9, 3.807549280554349*^9}, {
  3.9142388486876945`*^9, 3.9142388494110126`*^9}, {3.9142389112130485`*^9, 
  3.9142389257507925`*^9}},ExpressionUUID->"a9e270a5-3ae8-45d7-b4d1-\
36cde0a48449"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   StyleBox["f",
    FontSlant->"Italic"], 
   RowBox[{"(", "\[Omega]", ")"}]}], "=", 
  RowBox[{
   FractionBox["1", 
    SqrtBox[
     RowBox[{"2", "\[Pi]"}]]], 
   RowBox[{
    SubsuperscriptBox["\[Integral]", 
     RowBox[{"\[Minus]", "\[Infinity]"}], "\[Infinity]"], 
    RowBox[{
     StyleBox["f",
      FontSlant->"Italic"], 
     StyleBox[
      RowBox[{"(", "t", ")"}],
      FontSlant->"Italic"], 
     SuperscriptBox[
      StyleBox["e",
       FontSlant->"Italic"], 
      RowBox[{"\[Minus]", 
       StyleBox[
        RowBox[{
         StyleBox["\[ImaginaryI]",
          FontSlant->"Plain"], "\[Omega]t"}]]}]], 
     StyleBox["dt",
      FontSlant->"Italic"]}]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.807609924071587*^9, 3.807609933916641*^9}, {
  3.807610097235129*^9, 3.807610106816085*^9}, {3.8076101429189034`*^9, 
  3.807610149406391*^9}, {3.914406439155041*^9, 
  3.9144064442392645`*^9}},ExpressionUUID->"4bf6ed8d-079d-4307-b008-\
6c3d15f783f8"],

Cell[TextData[{
 "where \[Omega] is the angular frequency. For a time/frequency Fourier \
transform, ",
 StyleBox["the Fourier transform tells us which wave frequencies to add up to \
get the observed function in time",
  FontWeight->"Bold"],
 "."
}], "Text",
 CellChangeTimes->{{3.8075493841906495`*^9, 3.807549416243069*^9}, {
   3.807609901580328*^9, 3.807609908394887*^9}, {3.9142388623269386`*^9, 
   3.914238882319084*^9}, 3.9142389319508133`*^9, {3.914238981940488*^9, 
   3.9142390303962975`*^9}, {3.9142390942322197`*^9, 
   3.9142390948586245`*^9}, {3.914239317797111*^9, 
   3.9142393787289343`*^9}},ExpressionUUID->"5423f72a-59f8-448f-93f4-\
03044d1ea80b"]
}, Open  ]],

Cell[CellGroupData[{

Cell["\<\
Using the de Broglie wavelength - transform between position and momentum\
\>", "Subsection",
 CellChangeTimes->{{3.914238694994854*^9, 
  3.9142387264402823`*^9}},ExpressionUUID->"e6f3c9ce-355a-406d-b620-\
feacaaa7d142"],

Cell[TextData[StyleBox["Let\[CloseCurlyQuote]s think about the equation for \
the Fourier transform of position of a wave,",
 FontFamily->"Source Sans Pro"]], "Text",
 CellChangeTimes->{{3.8074600069661684`*^9, 3.807460041355148*^9}, {
   3.807460078763592*^9, 3.8074600922331667`*^9}, {3.8074601275160832`*^9, 
   3.807460138675999*^9}, {3.807618860067399*^9, 3.807618887954698*^9}, {
   3.807619763472302*^9, 3.807619793449031*^9}, {3.807619865021115*^9, 
   3.8076199010752068`*^9}, 3.914238968765875*^9, {3.914239105059097*^9, 
   3.9142391583788013`*^9}},
 FontFamily->
  "Source Serif Pro",ExpressionUUID->"a2f1dfd7-b9ec-4f9e-ac4b-39a2cb2680d1"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   StyleBox["f",
    FontSlant->"Italic"], 
   RowBox[{"(", "\[Omega]", ")"}]}], "=", 
  RowBox[{
   FractionBox["1", 
    SqrtBox[
     RowBox[{"2", "\[Pi]"}]]], 
   RowBox[{
    SubsuperscriptBox["\[Integral]", 
     RowBox[{"\[Minus]", "\[Infinity]"}], "\[Infinity]"], 
    RowBox[{
     StyleBox["f",
      FontSlant->"Italic"], 
     StyleBox[
      RowBox[{"(", "x", ")"}],
      FontSlant->"Italic"], 
     SuperscriptBox[
      StyleBox["e",
       FontSlant->"Italic"], 
      RowBox[{"\[Minus]", 
       StyleBox[
        RowBox[{
         StyleBox["i",
          FontSlant->"Italic"], "\[Omega]", 
         StyleBox["x",
          FontSlant->"Italic"]}]]}]], 
     StyleBox["dx",
      FontSlant->"Italic"]}]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{
  3.8076199183013086`*^9, {3.8076214411490173`*^9, 3.807621443192359*^9}, {
   3.80942488105558*^9, 
   3.8094248815591154`*^9}},ExpressionUUID->"70e11ceb-82ed-4b66-a5ce-\
a33144693465"],

Cell["\<\
It\[CloseCurlyQuote]s important to note here that \[Omega] for a wave \
represented above is related to the wavelength by the equation\
\>", "Text",
 CellChangeTimes->{{3.8076210172679157`*^9, 
  3.8076210681982718`*^9}},ExpressionUUID->"3830746d-8676-4db3-b1ba-\
a8dc250346cd"],

Cell[BoxData[
 RowBox[{"\[Omega]", "=", 
  FractionBox[
   RowBox[{"2", "\[Pi]"}], "\[Lambda]"]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8076210791239653`*^9, 
  3.8076210935868263`*^9}},ExpressionUUID->"950f8120-2237-4d8c-a673-\
b03c7057ffc2"],

Cell[TextData[{
 "Also, recall that the wavelength is simply the time spacing of one full \
cycle of a wave, as shown below for the function Cos(",
 StyleBox["x",
  FontSlant->"Italic"],
 "), which has a wavelength (or period) of 2\[Pi]."
}], "Text",
 CellChangeTimes->{{3.8076211165200768`*^9, 3.8076211564087534`*^9}, 
   3.9142394037697177`*^9},ExpressionUUID->"e9a8663c-b7e7-4133-8a41-\
4dedac7fff4d"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Show", "[", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"Plot", "[", 
    RowBox[{
     RowBox[{"Cos", "[", "x", "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", 
       RowBox[{
        RowBox[{"-", "2"}], "\[Pi]"}], ",", 
       RowBox[{"2", "\[Pi]"}]}], "}"}], ",", 
     RowBox[{"BaseStyle", "\[Rule]", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"FontFamily", "\[Rule]", "\"\<Arial\>\""}], ",", 
        RowBox[{"FontSize", "\[Rule]", "16"}]}], "}"}]}], ",", 
     RowBox[{"PlotStyle", "\[Rule]", 
      RowBox[{"Directive", "[", 
       RowBox[{"Black", ",", 
        RowBox[{"PointSize", "[", "Large", "]"}]}], "]"}]}], ",", 
     RowBox[{"AxesLabel", "\[Rule]", 
      RowBox[{"{", 
       RowBox[{
       "\"\<\!\(\*StyleBox[\"x\",FontSlant->\"Italic\"]\)\>\"", ",", 
        "\"\<\!\(\*StyleBox[\"f\",FontSlant->\"Italic\"]\)\!\(\*StyleBox[\"(\"\
,FontSlant->\"Italic\"]\)\!\(\*StyleBox[\"x\",FontSlant->\"Italic\"]\)\!\(\*\
StyleBox[\")\",FontSlant->\"Italic\"]\)\>\""}], "}"}]}], ",", 
     RowBox[{"AxesStyle", "\[Rule]", 
      RowBox[{"Directive", "[", 
       RowBox[{"Thick", ",", "Black"}], "]"}]}], ",", 
     RowBox[{"TicksStyle", "\[Rule]", 
      RowBox[{"Directive", "[", 
       RowBox[{"Black", ",", " ", "Thick"}], "]"}]}], ",", 
     RowBox[{"Ticks", "\[Rule]", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{
           RowBox[{"-", "4"}], "Pi"}], ",", 
          RowBox[{
           RowBox[{"-", "2"}], "Pi"}], ",", "0", ",", 
          RowBox[{"2", "Pi"}], ",", 
          RowBox[{"4", "Pi"}]}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"-", "1"}], ",", "1"}], "}"}]}], "}"}]}], ",", 
     RowBox[{"PlotRange", "\[Rule]", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{
           RowBox[{"-", "2"}], "Pi"}], ",", 
          RowBox[{"2", "Pi"}]}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"-", "1.6"}], ",", "1.1"}], "}"}]}], "}"}]}], ",", 
     RowBox[{"ImageSize", "\[Rule]", "Medium"}], ",", 
     RowBox[{"PlotLabels", "->", 
      RowBox[{"Placed", "[", 
       RowBox[{
        RowBox[{"{", "\"\<\[Lambda] = 2\[Pi]\>\"", "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"{", 
          RowBox[{"1.6", ",", 
           RowBox[{"-", "1.3"}]}], "}"}], "}"}]}], "]"}]}]}], "]"}], 
   "\[IndentingNewLine]", ",", "\[IndentingNewLine]", 
   RowBox[{"Graphics", "[", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"Arrowheads", "[", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"-", ".05"}], ",", ".05"}], "}"}], "]"}], ",", 
      RowBox[{"Arrow", "[", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{"-", "Pi"}], ",", 
           RowBox[{"-", "1.2"}]}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"Pi", ",", 
           RowBox[{"-", "1.2"}]}], "}"}]}], "}"}], "]"}]}], "}"}], "]"}]}], 
  "\[IndentingNewLine]", "]"}]], "Input",
 CellChangeTimes->{{3.8076201392396975`*^9, 3.8076201648699117`*^9}, {
  3.807620201139134*^9, 3.807620439556412*^9}, {3.8076206079155855`*^9, 
