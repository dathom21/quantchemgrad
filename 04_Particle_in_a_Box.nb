Cell["\<\
We want to solve the time-independent Schr\[ODoubleDot]dinger equation (TISE) \
for this system. Remember that the TISE is written\
\>", "Text",
 CellChangeTimes->{{3.8087439371860847`*^9, 3.8087440284184484`*^9}, 
   3.808744059295378*^9},ExpressionUUID->"c3e0f9f7-7626-4ccf-b426-\
17ab5a67fd6d"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"-", 
     FractionBox[
      SuperscriptBox["\[HBar]", "2"], 
      RowBox[{"2", 
       StyleBox["m",
        FontSlant->"Italic"]}]]}], 
    FractionBox[
     RowBox[{
      RowBox[{
       SuperscriptBox["\[DifferentialD]", "2"], "\[Psi]"}], 
      RowBox[{"(", 
       StyleBox["x",
        FontSlant->"Italic"], 
       StyleBox[")",
        FontSlant->"Italic"]}]}], 
     RowBox[{"\[DifferentialD]", 
      SuperscriptBox[
       StyleBox["x",
        FontSlant->"Italic"], "2"]}]]}], "+", 
   RowBox[{
    StyleBox["V",
     FontSlant->"Italic"], 
    StyleBox[
     RowBox[{"(", "x", ")"}],
     FontSlant->"Italic"], "\[Psi]", 
    RowBox[{"(", 
     StyleBox["x",
      FontSlant->"Italic"], 
     StyleBox[")",
      FontSlant->"Italic"]}]}]}], "=", 
  RowBox[{
   StyleBox["E",
    FontSlant->"Italic"], 
   StyleBox[" ",
    FontSlant->"Italic"], "\[Psi]", 
   RowBox[{"(", 
    StyleBox["x",
     FontSlant->"Italic"], 
    StyleBox[")",
     FontSlant->"Italic"]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{
  3.8087440520963507`*^9, {3.915641959172245*^9, 
   3.9156419664415197`*^9}},ExpressionUUID->"0f46715f-d26c-416f-9db4-\
93213e6419f1"],

Cell[TextData[{
 "Using the potential ",
 StyleBox["V",
  FontSlant->"Italic"],
 " (",
 StyleBox["x",
  FontSlant->"Italic"],
 " ) defined above, we can write the TISE within the box as"
}], "Text",
 CellChangeTimes->{
  3.808744065576359*^9},ExpressionUUID->"75748213-ba77-4625-b189-\
2c307bab0d55"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"-", 
    FractionBox[
     SuperscriptBox["\[HBar]", "2"], 
     RowBox[{"2", 
      StyleBox["m",
       FontSlant->"Italic"]}]]}], 
   FractionBox[
    RowBox[{
     RowBox[{
      SuperscriptBox["\[DifferentialD]", "2"], "\[Psi]"}], 
     RowBox[{"(", 
      StyleBox["x",
       FontSlant->"Italic"], 
      StyleBox[")",
       FontSlant->"Italic"]}]}], 
    RowBox[{"\[DifferentialD]", 
     SuperscriptBox[
      StyleBox["x",
       FontSlant->"Italic"], "2"]}]]}], "=", 
  RowBox[{
   RowBox[{
    StyleBox["E",
     FontSlant->"Italic"], 
    StyleBox[" ",
     FontSlant->"Italic"], "\[Psi]", 
    RowBox[{"(", 
     StyleBox["x",
      FontSlant->"Italic"], 
     StyleBox[")",
      FontSlant->"Italic"]}], 
    StyleBox[
     RowBox[{
      StyleBox["         ",
       FontSlant->"Italic"], " "}]], "0"}], "\[LessEqual]", 
   StyleBox["x",
    FontSlant->"Italic"], "\[LessEqual]", 
   StyleBox["a",
    FontSlant->"Italic"]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8087440520963507`*^9, 3.8087441370264454`*^9}, {
  3.9156419729980884`*^9, 
  3.915641977876748*^9}},ExpressionUUID->"76a7694a-fa1f-4d3d-83fc-\
e0985c100b43"],

Cell[TextData[{
 "Because we have defined the potential to be infinite on either side of the \
box, we can use similar constraints to those we used on a fixed, vibrating \
string. That is, we can say that \[Psi](",
 StyleBox["x ",
  FontSlant->"Italic"],
 ") must be zero at the two ends of the box: "
}], "Text",
 CellChangeTimes->{{3.8087441598149304`*^9, 3.8087442280938215`*^9}, 
   3.91564186783379*^9},ExpressionUUID->"a728be20-ec37-4a90-a27f-\
85ba743721da"],

Cell[BoxData[
 RowBox[{
  RowBox[{"\[Psi]", 
   RowBox[{"(", "0", ")"}]}], "=", 
  RowBox[{
   RowBox[{"\[Psi]", 
    RowBox[{"(", 
     StyleBox["a",
      FontSlant->"Italic"], ")"}]}], "=", "0"}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8087442365662193`*^9, 
  3.808744249880474*^9}},ExpressionUUID->"b8db6bc1-33b1-432f-b5a8-\
c42468a3dea7"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Solving the Schr\[ODoubleDot]dinger Equation", "Subsection",
 CellChangeTimes->{{3.8087447683963394`*^9, 
  3.8087447800656366`*^9}},ExpressionUUID->"0fe52c25-a867-4681-9d1d-\
bd84dee50dab"],

Cell[TextData[{
 "Now we have the TISE that describes the particle, and we have some boundary \
conditions. We can combine these two pieces of information to try to find the \
solution to the Schr\[ODoubleDot]dinger equation, meaning we solve for \
\[Psi](",
 StyleBox["x ",
  FontSlant->"Italic"],
 "). If we rearrange equation (3) slightly, we get the equation"
}], "Text",
 CellChangeTimes->{{3.8087447861541376`*^9, 
  3.8087449190577135`*^9}},ExpressionUUID->"63b08d3f-f52b-4ed2-8ee5-\
61e0275c6ead"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   FractionBox[
    RowBox[{
     RowBox[{
      SuperscriptBox["\[DifferentialD]", "2"], "\[Psi]"}], 
     RowBox[{"(", 
      StyleBox["x",
       FontSlant->"Italic"], 
      StyleBox[")",
       FontSlant->"Italic"]}]}], 
    RowBox[{"\[DifferentialD]", 
     SuperscriptBox[
      StyleBox["x",
       FontSlant->"Italic"], "2"]}]], "+", 
   RowBox[{
    StyleBox[
     FractionBox[
      StyleBox[
       RowBox[{"2", "mE"}],
       FontSlant->"Italic"], 
      SuperscriptBox[
       StyleBox["\[HBar]",
        FontSlant->"Plain"], "2"]],
     FontSlant->"Italic"], 
    StyleBox[" ",
     FontSlant->"Italic"], "\[Psi]", 
    RowBox[{"(", 
     StyleBox["x",
      FontSlant->"Italic"], 
     StyleBox[")",
      FontSlant->"Italic"]}]}]}], "=", 
  RowBox[{
   RowBox[{"0", 
    StyleBox[
     RowBox[{
      StyleBox["         ",
       FontSlant->"Italic"], " "}]], "0"}], "\[LessEqual]", 
   StyleBox["x",
    FontSlant->"Italic"], "\[LessEqual]", 
   StyleBox["a",
    FontSlant->"Italic"]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8087440520963507`*^9, 3.8087441370264454`*^9}, {
   3.8087449318253775`*^9, 3.8087449639439216`*^9}, 
   3.9156420346259747`*^9},ExpressionUUID->"c5a9af58-e174-48d9-83d8-\
f37371fbcdeb"],

Cell["\<\
equation (5) is of the same form as the position-dependent portion of the \
classical wave equation we solved in lesson 02,\
\>", "Text",
