Cell[TextData[{
 "where ",
 StyleBox["k",
  FontSlant->"Italic"],
 " represents an iterator going from 1 to ",
 StyleBox["N",
  FontSlant->"Italic"],
 ", where ",
 StyleBox["N",
  FontSlant->"Italic"],
 " gives the number of basis functions. So we have a system of ",
 StyleBox["N",
  FontSlant->"Italic"],
 " equations, which are called the secular equations, which have ",
 StyleBox["n",
  FontSlant->"Italic"],
 " unknowns (the coefficients ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["a", "n"], TraditionalForm]],ExpressionUUID->
  "11a1fdcb-f074-9a4d-8831-5ed488c2bdcd"],
 "). We can write this series of equations in matrix form as"
}], "Text",
 CellChangeTimes->{{3.811863619565592*^9, 3.8118638008074265`*^9}, {
  3.811863886175368*^9, 
  3.811863903830885*^9}},ExpressionUUID->"4901c52a-45d7-7149-92cc-\
a96c13b75038"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"(", "\[NoBreak]", GridBox[{
      {
       RowBox[{
        SubscriptBox[
         StyleBox["H",
          FontSlant->"Italic"], "11"], "-", 
        RowBox[{
         SubscriptBox[
          StyleBox["E",
           FontSlant->"Italic"], "\[CapitalPhi]"], 
         SubscriptBox[
          StyleBox["S",
           FontSlant->"Italic"], "11"]}]}], 
       RowBox[{
        SubscriptBox[
         StyleBox["H",
          FontSlant->"Italic"], "12"], "-", 
        RowBox[{
         SubscriptBox[
          StyleBox["E",
           FontSlant->"Italic"], "\[CapitalPhi]"], 
         SubscriptBox[
          StyleBox["S",
           FontSlant->"Italic"], "12"]}]}], "...", 
       RowBox[{
        SubscriptBox[
         StyleBox["H",
          FontSlant->"Italic"], 
         RowBox[{"1", 
          StyleBox["N",
           FontSlant->"Italic"]}]], "-", 
        RowBox[{
         SubscriptBox[
          StyleBox["E",
           FontSlant->"Italic"], "\[CapitalPhi]"], 
         SubscriptBox[
          StyleBox["S",
           FontSlant->"Italic"], 
          RowBox[{"1", 
           StyleBox["N",
            FontSlant->"Italic"]}]]}]}]},
      {
       RowBox[{
        SubscriptBox[
         StyleBox["H",
          FontSlant->"Italic"], "12"], "-", 
        RowBox[{
         SubscriptBox[
          StyleBox["E",
           FontSlant->"Italic"], "\[CapitalPhi]"], 
         SubscriptBox[
          StyleBox["S",
           FontSlant->"Italic"], "12"]}]}], 
       RowBox[{
        SubscriptBox[
         StyleBox["H",
          FontSlant->"Italic"], "22"], "-", 
        RowBox[{
         SubscriptBox[
          StyleBox["E",
           FontSlant->"Italic"], "\[CapitalPhi]"], 
         SubscriptBox[
          StyleBox["S",
           FontSlant->"Italic"], "22"]}]}], "...", 
       RowBox[{
        SubscriptBox[
         StyleBox["H",
          FontSlant->"Italic"], 
         RowBox[{"2", 
          StyleBox["N",
           FontSlant->"Italic"]}]], "-", 
        RowBox[{
         SubscriptBox[
          StyleBox["E",
           FontSlant->"Italic"], "\[CapitalPhi]"], 
         SubscriptBox[
          StyleBox["S",
           FontSlant->"Italic"], 
          RowBox[{"2", 
           StyleBox["N",
            FontSlant->"Italic"]}]]}]}]},
      {"...", "...", "...", "..."},
      {
       RowBox[{
        SubscriptBox[
         StyleBox["H",
          FontSlant->"Italic"], 
         RowBox[{"1", 
          StyleBox["N",
           FontSlant->"Italic"]}]], "-", 
        RowBox[{
         SubscriptBox[
          StyleBox["E",
           FontSlant->"Italic"], "\[CapitalPhi]"], 
         SubscriptBox[
          StyleBox["S",
           FontSlant->"Italic"], 
          RowBox[{"1", 
           StyleBox["N",
            FontSlant->"Italic"]}]]}]}], 
