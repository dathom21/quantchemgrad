Cell[TextData[{
 "where ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["N",
    FontSlant->"Italic"], 
   StyleBox["lm",
    FontSlant->"Italic"]]],
  CellChangeTimes->{{3.810112811439228*^9, 3.8101128248442793`*^9}, {
