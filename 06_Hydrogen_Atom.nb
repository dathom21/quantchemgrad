Cell[TextData[{
 "Remember that \[Theta] in spherical coordinates tells us about the angle \
with respect to the ",
 StyleBox["z",
  FontSlant->"Italic"],
 "-axis (see Figure 6.1). Since we don\[CloseCurlyQuote]t have a dependence \
on \[Phi], this equation tells us that the corresponding wavefunction,"
}], "Text",
 CellChangeTimes->{{3.8107259775985184`*^9, 3.8107260121405096`*^9}, {
  3.8107260597993264`*^9, 3.8107261211843443`*^9}, {3.917100680543933*^9, 
  3.91710068103496*^9}},ExpressionUUID->"f02ef2fd-eb24-4d3f-a8b4-\
11643d586039"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   SubscriptBox["\[Psi]", 
    StyleBox[
     RowBox[{
      StyleBox["n",
       FontSlant->"Italic"], "10"}]]], 
   RowBox[{"(", 
    RowBox[{
     StyleBox["r",
      FontSlant->"Italic"], ",", "\[Theta]", ",", "\[Phi]"}], ")"}]}], "=", 
  RowBox[{
   RowBox[{
    SubscriptBox[
     StyleBox["R",
      FontSlant->"Italic"], 
     StyleBox[
      RowBox[{
       StyleBox["n",
        FontSlant->"Italic"], "1"}]]], 
    RowBox[{"(", 
     StyleBox["r",
      FontSlant->"Italic"], ")"}], 
    SubsuperscriptBox[
     StyleBox["Y",
      FontSlant->"Italic"], "1", "0"], 
    RowBox[{"(", 
     RowBox[{"\[Theta]", ",", "\[Phi]"}], ")"}]}], "=", 
   RowBox[{
    SubscriptBox[
     StyleBox["R",
      FontSlant->"Italic"], 
     StyleBox[
      RowBox[{
       StyleBox["n",
        FontSlant->"Italic"], "1"}]]], 
    RowBox[{"(", 
     StyleBox["r",
      FontSlant->"Italic"], ")"}], 
    FractionBox["1", "2"], " ", 
    SqrtBox[
     FractionBox["3", "\[Pi]"]], " ", "cos", 
    RowBox[{"(", "\[Theta]", ")"}]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.810112811439228*^9, 3.8101128248442793`*^9}, {
   3.810479494926491*^9, 3.8104795038498344`*^9}, {3.810479572543576*^9, 
   3.8104796147383184`*^9}, {3.8104802055659895`*^9, 
