          SubscriptBox[
           StyleBox["r",
            FontSlant->"Italic"], 
           StyleBox["B",
            FontSlant->"Italic"]]]}]}]}], "]"}], "|", 
     SubscriptBox["\[Phi]", 
      RowBox[{"1", 
       SubscriptBox[
        StyleBox["s",
         FontSlant->"Italic"], 
        StyleBox["B",
         FontSlant->"Italic"]]}]]}], "\[RightAngleBracket]"}], "=", 
   RowBox[{
