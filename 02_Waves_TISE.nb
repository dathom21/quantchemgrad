   3.915549310393878*^9}},ExpressionUUID->"2448ee56-f086-4af9-921b-\
6e12308b6732"],

Cell["It is conventional now to write ", "Text",
 CellChangeTimes->{{3.807890992354103*^9, 
  3.8078909999150457`*^9}},ExpressionUUID->"466492a2-4d50-43c1-9f6d-\
0b7d2ca15dc0"],

Cell[BoxData[
 RowBox[{
  SubscriptBox["\[Omega]", 
   StyleBox["n",
    FontSlant->"Italic"]], "=", 
  FractionBox[
   StyleBox[
    RowBox[{
     StyleBox["nv",
      FontSlant->"Italic"], "\[Pi]"}]], 
   StyleBox["L",
    FontSlant->"Italic"]]}]], "DisplayFormulaNumbered",
