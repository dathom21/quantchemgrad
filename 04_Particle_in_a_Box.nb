      FontSlant->"Italic"]], 
    StyleBox[
     RowBox[{"(", "x", ")"}],
     FontSlant->"Italic"]}], "=", 
   RowBox[{
    SuperscriptBox[
     RowBox[{"(", 
      FractionBox["2", 
       StyleBox["a",
        FontSlant->"Italic"]], ")"}], 
     RowBox[{"1", "/", "2"}]], "sin", 
    RowBox[{"(", 
     StyleBox[
      FractionBox[
       StyleBox[
        RowBox[{
         StyleBox["n",
          FontSlant->"Italic"], 
         StyleBox["\[Pi]",
          FontSlant->"Plain"], 
         StyleBox["x",
          FontSlant->"Italic"]}]], "a"],
      FontSlant->"Italic"], ")"}]}]}]],
  CellChangeTimes->{{3.80787182098985*^9, 3.807871850931781*^9}, {
    3.807871889420841*^9, 3.8078719220144444`*^9}, {3.80787198448829*^9, 
    3.8078721855891733`*^9}, 3.8078722793781643`*^9},ExpressionUUID->
  "ecd59712-6441-4e78-a641-80e1793ee136"],
 " for values of ",
 StyleBox["n",
  FontSlant->"Italic"],
 " from 1 (bottom) to 4 (top), offset by the associated energies ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["E", "n"], TraditionalForm]],ExpressionUUID->
  "4f61224d-d41d-4996-812f-8f18c8f52eb8"],
 "."
}], "Affiliation",
 CellChangeTimes->CompressedData["
1:eJxTTMoPSmViYGAQBWIQPeNH5qbXiW8cy6t7doDoiRfCxd8A6ZBDtWA6NlRg
