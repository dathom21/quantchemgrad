   FontWeight->"Bold",
   FontSlant->"Italic"], "=", 
  RowBox[{
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      SubscriptBox[
       StyleBox["yp",
        FontSlant->"Italic"], 
       StyleBox["z",
        FontSlant->"Italic"]], "-", 
      SubscriptBox[
       StyleBox["zp",
        FontSlant->"Italic"], 
       StyleBox["y",
        FontSlant->"Italic"]]}], ")"}], 
    StyleBox["i",
     FontWeight->"Bold",
     FontSlant->"Italic"]}], "+", 
