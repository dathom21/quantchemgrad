Cell[TextData[{
 "where the fact that ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["m",
    FontSlant->"Italic"], 
   StyleBox["l",
    FontSlant->"Italic"]]],
  CellChangeTimes->{{3.810483192695999*^9, 3.810483197963916*^9}, {
