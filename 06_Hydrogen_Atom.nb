Cell["\<\
It turns out that the normalization constant for our associated Legendre \
functions is\
\>", "Text",
 CellChangeTimes->{{3.810650228169078*^9, 3.8106502602997103`*^9}, {
  3.8420234735941257`*^9, 3.842023473967021*^9}, {3.935588480334194*^9, 
