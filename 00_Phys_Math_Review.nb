   SubscriptBox["\[Theta]", "0"], "cos", 
   RowBox[{"(", 
    StyleBox[
     RowBox[{"\[Omega]", 
      StyleBox["t",
       FontSlant->"Italic"]}]], ")"}]}]}]], "DisplayFormulaNumbered",
