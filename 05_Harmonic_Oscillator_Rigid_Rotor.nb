Cell["The Potential Energy of a Harmonic Oscillator", "Subsection",
 CellChangeTimes->{{3.8094361045584292`*^9, 
  3.8094361324687643`*^9}},ExpressionUUID->"910978d7-7d6e-4853-b087-\
7ef5bdcf6f7e"],

Cell[TextData[{
 "The classical harmonic oscillator is a common problem in classical \
mechanics. We\[CloseCurlyQuote]ve already seen that the pendulum problem \
(lesson 0) can be modeled as a harmonic oscillator. Another common model is a \
weight on a string. If we think about a weight on a spring moving in the ",
 StyleBox["x",
  FontSlant->"Italic"],
 " direction, we can describe the force on the weight as"
}], "Text",
 CellChangeTimes->{{3.915796375364058*^9, 3.9157964183212996`*^9}, {
  3.915796466876523*^9, 3.9157965256852584`*^9}, {3.9351436621954193`*^9, 
  3.935143662481537*^9}},ExpressionUUID->"37aec3a5-3cac-4b35-a53a-\
6893f6b0d294"],

Cell[BoxData[
 RowBox[{
  StyleBox["F",
   FontSlant->"Italic"], "=", 
  RowBox[{
   RowBox[{"-", 
    StyleBox["kx",
     FontSlant->"Italic"]}], 
   StyleBox["=",
    FontSlant->"Plain"], 
   RowBox[{
    StyleBox["ma",
     FontSlant->"Italic"], 
    StyleBox["=",
     FontSlant->"Italic"], 
    RowBox[{"m", " ", 
     FractionBox[
      RowBox[{
       SuperscriptBox["\[DifferentialD]", "2"], 
       StyleBox["x",
        FontSlant->"Italic"]}], 
      RowBox[{"\[DifferentialD]", 
       SuperscriptBox[
        StyleBox["t",
         FontSlant->"Italic"], "2"]}]]}]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.809435322857957*^9, 3.8094353275032787`*^9}, {
  3.9157967657322865`*^9, 3.915796773526286*^9}, {3.9157973826544104`*^9, 
  3.9157974052170916`*^9}},ExpressionUUID->"46dcd5d0-52f7-4b61-ad1c-\
d5968a6e2f16"],

Cell[TextData[{
 "We are also interested in the form of the potential energy function ",
 StyleBox["V",
  FontSlant->"Italic"],
 " ( ",
 StyleBox["x",
  FontSlant->"Italic"],
 " ). Recall that"
}], "Text",
 CellChangeTimes->{{3.8094360913692894`*^9, 3.809436092674875*^9}, {
  3.8094361509705725`*^9, 3.8094361938263364`*^9}, {3.9157965328597975`*^9, 
  3.9157965339413223`*^9}},ExpressionUUID->"7e1acde4-e2c4-4a55-9d31-\
7b7783f8d6c6"],

Cell[BoxData[
 StyleBox[
  RowBox[{
   RowBox[{"F", 
    RowBox[{"(", "x", ")"}]}], "=", 
   RowBox[{"-", 
    FractionBox[
     RowBox[{
      RowBox[{
       StyleBox["\[DifferentialD]",
        FontSlant->"Plain"], "V"}], 
      RowBox[{"(", "x", ")"}]}], 
     RowBox[{
      StyleBox["\[DifferentialD]",
       FontSlant->"Plain"], "x"}]]}]}],
  FontSlant->"Italic"]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8094362093669643`*^9, 3.8094362273365407`*^9}, {
