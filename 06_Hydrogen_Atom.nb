 CellChangeTimes->{{3.8104831455988817`*^9, 3.8104831545610485`*^9}, {
  3.9170220632141967`*^9, 3.9170220638058395`*^9}, {3.917085174845704*^9, 
  3.9170851790258*^9}},ExpressionUUID->"43b5a01a-3410-43bc-a00a-95cd0542bde0"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    FractionBox["1", 
     RowBox[{"\[CapitalTheta]", 
      RowBox[{"(", "\[Theta]", ")"}]}]], "sin", 
    RowBox[{"(", "\[Theta]", ")"}], 
    RowBox[{
     FractionBox["\[DifferentialD]", 
      RowBox[{"\[DifferentialD]", "\[Theta]"}]], 
     RowBox[{"(", 
      RowBox[{"sin", 
       RowBox[{"(", "\[Theta]", ")"}], 
       FractionBox[
        RowBox[{
         RowBox[{"\[DifferentialD]", "\[CapitalTheta]"}], 
         RowBox[{"(", "\[Theta]", ")"}]}], 
        RowBox[{"\[DifferentialD]", "\[Theta]"}]]}], ")"}]}]}], "+", 
   RowBox[{
    SuperscriptBox["\[Beta]sin", "2"], 
    RowBox[{"(", "\[Theta]", ")"}]}]}], "=", 
  SubsuperscriptBox[
   StyleBox["m",
    FontSlant->"Italic"], 
   StyleBox["l",
    FontSlant->"Italic"], "2"]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.810112811439228*^9, 3.8101128248442793`*^9}, {
   3.810479494926491*^9, 3.8104795038498344`*^9}, {3.810479572543576*^9, 
   3.8104796147383184`*^9}, {3.8104802055659895`*^9, 
   3.8104802433915305`*^9}, {3.8104802785189395`*^9, 
   3.8104802814214115`*^9}, {3.810480477782269*^9, 3.8104805471507206`*^9}, {
   3.8104805927965565`*^9, 3.810480633017248*^9}, {3.8104807595294323`*^9, 
   3.8104809538100047`*^9}, {3.8104811300285854`*^9, 
   3.8104811403007636`*^9}, {3.8104812580010843`*^9, 
   3.8104813317580833`*^9}, {3.81048146789211*^9, 3.8104815557630205`*^9}, {
   3.8104817202872114`*^9, 3.8104817438715935`*^9}, 3.810481790764664*^9, 
   3.810481836241686*^9, {3.810481926951917*^9, 3.810481935802024*^9}, {
   3.8104820720505495`*^9, 3.8104821860076323`*^9}, {3.810482900850647*^9, 
   3.8104829123165646`*^9}, {3.8104829752587*^9, 3.8104829860744143`*^9}, {
   3.810483024639452*^9, 3.810483038492651*^9}, {3.8104830702023983`*^9, 
   3.8104830866522465`*^9}, {3.8104831187257876`*^9, 3.810483135292489*^9}, {
   3.8104831732744513`*^9, 3.8104831809128747`*^9}, {3.9170220668974032`*^9, 
   3.9170220706296844`*^9}, {3.9170853212949686`*^9, 
   3.917085330287652*^9}},ExpressionUUID->"c96289bc-2187-4dd5-a3bb-\
d2af5db10e3e"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"-", 
    FractionBox["1", 
     RowBox[{"\[CapitalPhi]", 
      RowBox[{"(", "\[Phi]", ")"}]}]]}], 
   FractionBox[
    RowBox[{
     RowBox[{
      SuperscriptBox["\[DifferentialD]", "2"], "\[CapitalPhi]"}], 
     RowBox[{"(", "\[Phi]", ")"}]}], 
    RowBox[{"\[DifferentialD]", 
     SuperscriptBox["\[Phi]", "2"]}]]}], "=", 
  SubsuperscriptBox[
   StyleBox["m",
    FontSlant->"Italic"], 
   StyleBox["l",
    FontSlant->"Italic"], "2"]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.810483192695999*^9, 3.810483197963916*^9}, {
  3.917022082397726*^9, 3.9170220829735365`*^9}, {3.9170852016445866`*^9, 
  3.917085205467969*^9}},ExpressionUUID->"48cb9832-e408-4475-84a6-\
49ab06e53abf"]
}, Open  ]],

Cell[CellGroupData[{

Cell["The Equatorial Angle Function", "Subsubsection",
 CellChangeTimes->{{3.810646006960596*^9, 
  3.8106460293665495`*^9}},ExpressionUUID->"82951a88-85ea-41ad-9801-\
2a0384b5b45b"],

Cell["We can rewrite equation (32) as", "Text",
 CellChangeTimes->{{3.8106448998175063`*^9, 
  3.810644904563326*^9}},ExpressionUUID->"7ee20551-0091-460d-8d0e-\
67e322b5495a"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   FractionBox[
    RowBox[{
     RowBox[{
      SuperscriptBox["\[DifferentialD]", "2"], "\[CapitalPhi]"}], 
     RowBox[{"(", "\[Phi]", ")"}]}], 
    RowBox[{"\[DifferentialD]", 
     SuperscriptBox["\[Phi]", "2"]}]], "+", 
   RowBox[{
    SubsuperscriptBox[
     StyleBox["m",
      FontSlant->"Italic"], 
     StyleBox["l",
      FontSlant->"Italic"], "2"], "\[CapitalPhi]", 
    RowBox[{"(", "\[Phi]", ")"}]}]}], "=", "0"}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.810483192695999*^9, 3.810483197963916*^9}, {
  3.8106449127367277`*^9, 3.810644926430175*^9}, {3.9170220888863707`*^9, 
  3.917022089450661*^9}, {3.917085193524679*^9, 
  3.9170851982519417`*^9}},ExpressionUUID->"72fa8f22-3eec-4f6d-a3cb-\
ba0b03da96b3"],

Cell["\<\
We can see that equation (33) takes the same form as many other differential \
equations that we have solved in this course. The general solutions take the \
form\
\>", "Text",
 CellChangeTimes->{{3.81064487124898*^9, 3.810644893702318*^9}, {
  3.8106449309181957`*^9, 
  3.810644931016141*^9}},ExpressionUUID->"cb7111ce-41e0-41e7-923b-\
75715a122716"],

Cell[BoxData[
 RowBox[{
  RowBox[{"\[CapitalPhi]", 
   RowBox[{"(", "\[Phi]", ")"}]}], "=", 
  RowBox[{
   RowBox[{
    StyleBox[
     SubscriptBox["A", 
      SubscriptBox["m", "l"]],
     FontSlant->"Italic"], 
    SuperscriptBox["\[ExponentialE]", 
     RowBox[{
      SubscriptBox[
       StyleBox[
        RowBox[{"\[ImaginaryI]", 
         StyleBox["m",
          FontSlant->"Italic"]}]], 
       StyleBox["l",
        FontSlant->"Italic"]], 
      StyleBox["\[Phi]",
       FontSlant->"Plain"]}]]}], "+", 
   RowBox[{
    StyleBox[
     SubscriptBox["A", 
      RowBox[{"-", 
       SubscriptBox["m", "l"]}]],
     FontSlant->"Italic"], 
    SuperscriptBox["\[ExponentialE]", 
     RowBox[{
      RowBox[{"-", 
       SubscriptBox[
        StyleBox[
         RowBox[{"\[ImaginaryI]", 
          StyleBox["m",
           FontSlant->"Italic"]}]], 
        StyleBox["l",
         FontSlant->"Italic"]]}], 
      StyleBox["\[Phi]",
       FontSlant->"Plain"]}]]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.810483192695999*^9, 3.810483197963916*^9}, {
  3.8106449127367277`*^9, 3.8106449898962593`*^9}, {3.9170221033974586`*^9, 
  3.917022117516205*^9}},ExpressionUUID->"14c4a498-3718-4f41-9140-\
49d64faadfdf"],

Cell["\<\
As we saw with the particle in free space, since the solution can be a linear \
combination of any solutions, we can choose to write these as two separate \
general solutions,\
\>", "Text",
 CellChangeTimes->{{3.8106449972765827`*^9, 
  3.81064504213667*^9}},ExpressionUUID->"fd3289ff-b210-4727-92a3-\
c5a51f1db373"],

Cell[BoxData[
 RowBox[{
  RowBox[{"\[CapitalPhi]", 
   RowBox[{"(", "\[Phi]", ")"}]}], "=", 
  RowBox[{
   StyleBox[
    SubscriptBox["A", 
     SubscriptBox["m", "l"]],
    FontSlant->"Italic"], 
   SuperscriptBox["\[ExponentialE]", 
    RowBox[{
     SubscriptBox[
      StyleBox[
       RowBox[{"\[ImaginaryI]", 
        StyleBox["m",
         FontSlant->"Italic"]}]], 
      StyleBox["l",
       FontSlant->"Italic"]], 
     StyleBox["\[Phi]",
      FontSlant->"Plain"]}]]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.810483192695999*^9, 3.810483197963916*^9}, {
   3.8106449127367277`*^9, 3.810645017074294*^9}, 
   3.9170221255899935`*^9},ExpressionUUID->"c055695e-fe7e-4e09-a625-\
8e94eb17952c"],

Cell[BoxData[
 RowBox[{
  RowBox[{"\[CapitalPhi]", 
   RowBox[{"(", "\[Phi]", ")"}]}], "=", 
  RowBox[{
   StyleBox[
    SubscriptBox["A", 
     RowBox[{"-", 
      SubscriptBox["m", "l"]}]],
    FontSlant->"Italic"], 
   SuperscriptBox["\[ExponentialE]", 
    RowBox[{
     RowBox[{"-", 
      SubscriptBox[
       StyleBox[
        RowBox[{"\[ImaginaryI]", 
         StyleBox["m",
          FontSlant->"Italic"]}]], 
       StyleBox["l",
        FontSlant->"Italic"]]}], 
     StyleBox["\[Phi]",
      FontSlant->"Plain"]}]]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.810483192695999*^9, 3.810483197963916*^9}, {
   3.8106449127367277`*^9, 3.8106449898962593`*^9}, 3.810645056351136*^9, 
   3.9170221280544395`*^9},ExpressionUUID->"edf03ab2-9f02-4cc6-a7e2-\
e80664ee961f"],

Cell["\<\
Because the equatorial angle \[Phi] can take on values from 0 to 2\[Pi], we \
have the condition that \
\>", "Text",
 CellChangeTimes->{{3.810645069963282*^9, 3.8106451051302953`*^9}, {
  3.9170220085798254`*^9, 
  3.917022009437752*^9}},ExpressionUUID->"aed296a7-11c0-4a8b-8f6e-\
f6517f6ba46e"],

Cell[BoxData[
 RowBox[{
  RowBox[{"\[CapitalPhi]", 
   RowBox[{"(", "\[Phi]", ")"}]}], "=", 
  RowBox[{"\[CapitalPhi]", 
   RowBox[{"(", 
    RowBox[{"\[Phi]", "+", 
     RowBox[{"2", "\[Pi]"}]}], ")"}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.810483192695999*^9, 3.810483197963916*^9}, {
  3.8106449127367277`*^9, 3.810645017074294*^9}, {3.8106451140349803`*^9, 
  3.8106451211380186`*^9}},ExpressionUUID->"91d2b820-bcd7-42c8-966c-\
c76a681e52fd"],

Cell["\<\
because these two quantities represent the same location in \[Phi] space. \
Substituting this condition into equation (35), we find that \
\>", "Text",
 CellChangeTimes->{{3.810645127353158*^9, 3.810645148045469*^9}, {
  3.8106451809457054`*^9, 3.8106452233047533`*^9}, {3.842016358746072*^9, 
  3.842016358929352*^9}, {3.842016449640025*^9, 
  3.842016449757916*^9}},ExpressionUUID->"d5c22012-e9bb-4976-84ce-\
f913bd027096"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   StyleBox[
    SubscriptBox["A", 
     SubscriptBox["m", "l"]],
    FontSlant->"Italic"], 
   SuperscriptBox["\[ExponentialE]", 
    RowBox[{
     SubscriptBox[
      StyleBox[
       RowBox[{"\[ImaginaryI]", 
        StyleBox["m",
         FontSlant->"Italic"]}]], 
      StyleBox["l",
       FontSlant->"Italic"]], 
     StyleBox["\[Phi]",
      FontSlant->"Plain"]}]]}], "=", 
  RowBox[{
   StyleBox[
    SubscriptBox["A", 
     SubscriptBox["m", "l"]],
    FontSlant->"Italic"], 
   SuperscriptBox["\[ExponentialE]", 
    RowBox[{
     SubscriptBox[
      StyleBox[
       RowBox[{"\[ImaginaryI]", 
        StyleBox["m",
         FontSlant->"Italic"]}]], 
      StyleBox["l",
       FontSlant->"Italic"]], 
     StyleBox[
      RowBox[{"(", 
       RowBox[{"\[Phi]", "+", 
        RowBox[{"2", "\[Pi]"}]}], ")"}],
      FontSlant->"Plain"]}]]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.810483192695999*^9, 3.810483197963916*^9}, {
  3.8106449127367277`*^9, 3.810645017074294*^9}, {3.81064520037755*^9, 
  3.810645213086841*^9}, {3.917022134468707*^9, 
  3.9170221458599424`*^9}},ExpressionUUID->"54789931-db92-4a2d-8f17-\
a839f7ceac28"],

Cell[TextData[{
 "dividing both sides by ",
 Cell[BoxData[
  RowBox[{
   StyleBox[
    SubscriptBox["A", 
     SubscriptBox["m", "l"]],
    FontSlant->"Italic"], 
   SuperscriptBox["\[ExponentialE]", 
    RowBox[{
     SubscriptBox[
      StyleBox[
       RowBox[{"\[ImaginaryI]", 
        StyleBox["m",
         FontSlant->"Italic"]}]], 
      StyleBox["l",
       FontSlant->"Italic"]], 
     StyleBox["\[Phi]",
      FontSlant->"Plain"]}]]}]],
  CellChangeTimes->{{3.810483192695999*^9, 3.810483197963916*^9}, {
   3.8106449127367277`*^9, 3.810645017074294*^9}, {3.81064520037755*^9, 
   3.810645213086841*^9}},ExpressionUUID->
  "c651fb0d-cc64-439b-ae7a-fb0862823adf"],
 ", we find that"
}], "Text",
 CellChangeTimes->{{3.8106452329167824`*^9, 3.8106452463645625`*^9}, {
  3.917022149586277*^9, 
  3.9170221495872765`*^9}},ExpressionUUID->"fb21e94f-55dc-403b-a599-\
28d5d52295d3"],

Cell[BoxData[
 RowBox[{"1", "=", 
  SuperscriptBox["\[ExponentialE]", 
   RowBox[{
    SubscriptBox[
     StyleBox[
      RowBox[{"\[ImaginaryI]", 
       StyleBox["m",
        FontSlant->"Italic"]}]], 
     StyleBox["l",
      FontSlant->"Italic"]], 
    StyleBox[
     RowBox[{"(", 
      RowBox[{"2", "\[Pi]"}], ")"}],
     FontSlant->"Plain"]}]]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.810483192695999*^9, 3.810483197963916*^9}, {
   3.8106449127367277`*^9, 3.810645017074294*^9}, {3.81064520037755*^9, 
   3.810645213086841*^9}, {3.810645255698732*^9, 3.810645265491974*^9}, 
   3.8106453362929487`*^9, 
   3.9170221590211606`*^9},ExpressionUUID->"a825d0eb-24d8-4aad-8464-\
84678378e28c"],

Cell["Similarly, for equation (36), we find", "Text",
 CellChangeTimes->{{3.810645271009425*^9, 
  3.8106452792979546`*^9}},ExpressionUUID->"13eb8c74-ac81-4865-b5e7-\
16a2d808b174"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   StyleBox[
    SubscriptBox["A", 
     RowBox[{"-", 
      SubscriptBox["m", "l"]}]],
    FontSlant->"Italic"], 
   SuperscriptBox["\[ExponentialE]", 
    RowBox[{
     RowBox[{"-", 
      SubscriptBox[
       StyleBox[
        RowBox[{"\[ImaginaryI]", 
         StyleBox["m",
          FontSlant->"Italic"]}]], 
       StyleBox["l",
        FontSlant->"Italic"]]}], 
     StyleBox["\[Phi]",
      FontSlant->"Plain"]}]]}], "=", 
  RowBox[{
   StyleBox[
    SubscriptBox["A", 
     RowBox[{"-", 
      SubscriptBox["m", "l"]}]],
    FontSlant->"Italic"], 
   SuperscriptBox["\[ExponentialE]", 
    RowBox[{
     RowBox[{"-", 
      SubscriptBox[
       StyleBox[
        RowBox[{"\[ImaginaryI]", 
         StyleBox["m",
          FontSlant->"Italic"]}]], 
       StyleBox["l",
        FontSlant->"Italic"]]}], 
     StyleBox[
      RowBox[{"(", 
       RowBox[{"\[Phi]", "+", 
        RowBox[{"2", "\[Pi]"}]}], ")"}],
      FontSlant->"Plain"]}]]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.810483192695999*^9, 3.810483197963916*^9}, {
   3.8106449127367277`*^9, 3.8106449898962593`*^9}, 3.810645056351136*^9, {
   3.810645293905263*^9, 3.810645302446638*^9}, {3.917022172236127*^9, 
   3.9170221833868866`*^9}},ExpressionUUID->"42538c22-7eaf-47d9-ad2a-\
ce3bcc42d19d"],

Cell["and", "Text",
 CellChangeTimes->{{3.8106453112090445`*^9, 
  3.81064531368318*^9}},ExpressionUUID->"6302d846-bfcd-4cca-af5a-\
4985d96bc1c9"],

Cell[BoxData[
 RowBox[{"1", "=", 
  SuperscriptBox["\[ExponentialE]", 
   RowBox[{
    RowBox[{"-", 
     SubscriptBox[
      StyleBox[
       RowBox[{"\[ImaginaryI]", 
        StyleBox["m",
         FontSlant->"Italic"]}]], 
      StyleBox["l",
       FontSlant->"Italic"]]}], 
    StyleBox[
     RowBox[{"(", 
      RowBox[{"2", "\[Pi]"}], ")"}],
     FontSlant->"Plain"]}]]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.810483192695999*^9, 3.810483197963916*^9}, {
  3.8106449127367277`*^9, 3.810645017074294*^9}, {3.81064520037755*^9, 
  3.810645213086841*^9}, {3.810645255698732*^9, 3.810645265491974*^9}, {
  3.810645347447385*^9, 3.810645350419532*^9}, {3.9170221864037447`*^9, 
  3.9170221866305437`*^9}},ExpressionUUID->"6814f994-9467-4220-b3e8-\
8fce22496b1d"],

Cell["Summarizing these results, we obtain", "Text",
 CellChangeTimes->{{3.810645354478279*^9, 
  3.810645379398503*^9}},ExpressionUUID->"7cf51871-f7ec-4739-8b7b-\
b15295e79081"],

Cell[BoxData[
 RowBox[{
  SuperscriptBox["\[ExponentialE]", 
   RowBox[{
    RowBox[{"\[PlusMinus]", 
     SubscriptBox[
      StyleBox[
       RowBox[{"\[ImaginaryI]", 
        StyleBox["m",
         FontSlant->"Italic"]}]], 
      StyleBox["l",
       FontSlant->"Italic"]]}], 
    StyleBox[
     RowBox[{"(", 
      RowBox[{"2", "\[Pi]"}], ")"}],
     FontSlant->"Plain"]}]], "=", "1"}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.810483192695999*^9, 3.810483197963916*^9}, {
  3.8106449127367277`*^9, 3.810645017074294*^9}, {3.81064520037755*^9, 
  3.810645213086841*^9}, {3.810645255698732*^9, 3.810645265491974*^9}, {
  3.810645347447385*^9, 3.810645389704649*^9}, {3.9170221936509047`*^9, 
  3.917022193893444*^9}},ExpressionUUID->"e89f24c6-36a6-428d-b29f-\
85df8d960bee"],

Cell["or, using Euler\[CloseCurlyQuote]s formula,", "Text",
 CellChangeTimes->{{3.8106453968505735`*^9, 
  3.810645403639835*^9}},ExpressionUUID->"c9fa908c-243e-44bc-8937-\
afb3c80f9584"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"cos", 
    RowBox[{"(", 
     RowBox[{"2", 
      SubscriptBox[
       StyleBox[
        RowBox[{"\[Pi]", 
         StyleBox["m",
          FontSlant->"Italic"]}]], 
       StyleBox["l",
        FontSlant->"Italic"]]}], ")"}]}], "\[PlusMinus]", 
   RowBox[{"\[ImaginaryI]sin", 
    RowBox[{"(", 
     RowBox[{"2", 
      SubscriptBox[
       StyleBox[
        RowBox[{"\[Pi]", 
         StyleBox["m",
          FontSlant->"Italic"]}]], 
       StyleBox["l",
        FontSlant->"Italic"]]}], ")"}]}]}], "=", 
  "1"}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.810483192695999*^9, 3.810483197963916*^9}, {
  3.8106449127367277`*^9, 3.810645017074294*^9}, {3.81064520037755*^9, 
  3.810645213086841*^9}, {3.810645255698732*^9, 3.810645265491974*^9}, {
  3.810645347447385*^9, 3.8106454365102987`*^9}, {3.9170222060053053`*^9, 
  3.9170222142845616`*^9}},ExpressionUUID->"6d4258a7-30c3-4e4c-8d5f-\
8440739e8e23"],

Cell[TextData[{
 "This condition is only met if ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["m",
    FontSlant->"Italic"], 
   StyleBox["l",
    FontSlant->"Italic"]]],
  CellChangeTimes->{{3.810483192695999*^9, 3.810483197963916*^9}, {
   3.8106449127367277`*^9, 3.810645017074294*^9}, {3.81064520037755*^9, 
   3.810645213086841*^9}, {3.810645255698732*^9, 3.810645265491974*^9}, {
   3.810645347447385*^9, 3.8106454365102987`*^9}, {3.9170222060053053`*^9, 
   3.9170222062299576`*^9}},ExpressionUUID->
  "84c3838c-f3ef-46c0-ab62-45a9bf033800"],
 " is an integer ranging from \[Minus]\[Infinity] to \[Infinity], so we \
obtain the general solution as"
}], "Text",
 CellChangeTimes->{{3.8106454411138325`*^9, 3.81064548336966*^9}, {
  3.8106455307141266`*^9, 3.8106455465643015`*^9}, {3.8106456107952147`*^9, 
  3.8106456137855024`*^9}, {3.9170222185720725`*^9, 
  3.917022221423246*^9}},ExpressionUUID->"8dda09c9-0b93-4c6f-86b3-\
f071094fe5f7"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"\[CapitalPhi]", 
    RowBox[{"(", "\[Phi]", ")"}]}], "=", 
   RowBox[{
    RowBox[{
     StyleBox[
      SubscriptBox["A", 
       SubscriptBox["m", "l"]],
      FontSlant->"Italic"], 
     SuperscriptBox["\[ExponentialE]", 
      RowBox[{
       SubscriptBox[
        StyleBox[
         RowBox[{"\[ImaginaryI]", 
          StyleBox["m",
           FontSlant->"Italic"]}]], 
        StyleBox["l",
         FontSlant->"Italic"]], 
       StyleBox["\[Phi]",
        FontSlant->"Plain"]}]], "                   ", 
