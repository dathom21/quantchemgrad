      FontSlant->"Italic"]]], 
   RowBox[{"(", 
    RowBox[{"\[Theta]", ",", "\[Phi]"}], ")"}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8100544880652375`*^9, 3.8100545041200957`*^9}, {
   3.810054632482561*^9, 3.8100546606919527`*^9}, {3.810054738405748*^9, 
   3.810054754160844*^9}, {3.810055496888957*^9, 3.810055644063492*^9}, {
   3.8101099522060614`*^9, 3.8101100508523717`*^9}, {3.8101101194750385`*^9, 
   3.8101101642963843`*^9}, {3.8107127659519644`*^9, 3.810712781977992*^9}, {
   3.8107128863205147`*^9, 3.8107129246267147`*^9}, 3.810712975971156*^9, 
   3.8107130396874857`*^9, {3.810713072953952*^9, 3.810713077029566*^9}, {
   3.8107138654100857`*^9, 3.810713907959445*^9}, 3.810714092835499*^9, {
   3.8107142057542086`*^9, 3.8107142281878614`*^9}, {3.810715311267351*^9, 
   3.810715321066903*^9}, {3.9170867267725587`*^9, 
   3.9170867419404716`*^9}},ExpressionUUID->"6e10d3e3-2e18-47d1-b209-\
898af90a669d"],

Cell["we find that ", "Text",
 CellChangeTimes->{{3.810715323950266*^9, 3.8107153250929885`*^9}, {
  3.8737922581759214`*^9, 
  3.873792259421378*^9}},ExpressionUUID->"d8e7ed75-6d69-4d9c-90ed-\
be9b8afba6c9"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   SubsuperscriptBox[
    StyleBox["L",
     FontSlant->"Italic"], 
    StyleBox["x",
     FontSlant->"Italic"], "2"], "+", 
   SubsuperscriptBox[
    StyleBox["L",
     FontSlant->"Italic"], 
    StyleBox["y",
     FontSlant->"Italic"], "2"]}], "=", 
  RowBox[{
   RowBox[{
    SuperscriptBox[
     StyleBox["L",
      FontSlant->"Italic"], "2"], "-", 
    SubsuperscriptBox[
     StyleBox["L",
      FontSlant->"Italic"], 
     StyleBox["z",
      FontSlant->"Italic"], "2"]}], "=", 
   RowBox[{
    SuperscriptBox["\[HBar]", "2"], "[", 
    RowBox[{
     RowBox[{
      StyleBox["l",
       FontSlant->"Italic"], 
      RowBox[{
       StyleBox["(",
        FontSlant->"Italic"], 
       RowBox[{
        StyleBox["l",
         FontSlant->"Italic"], 
        StyleBox["+",
         FontSlant->"Plain"], 
        StyleBox["1",
         FontSlant->"Plain"]}], 
       StyleBox[")",
        FontSlant->"Plain"]}]}], 
     StyleBox["-",
      FontSlant->"Plain"], 
     StyleBox[" ",
      FontSlant->"Plain"], 
     SubsuperscriptBox[
      StyleBox["m",
       FontSlant->"Italic"], 
      StyleBox["l",
       FontSlant->"Italic"], "2"]}], "]"}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.810112811439228*^9, 3.8101128248442793`*^9}, {
   3.810479494926491*^9, 3.8104795038498344`*^9}, {3.810479572543576*^9, 
   3.8104796147383184`*^9}, {3.8104802055659895`*^9, 
   3.8104802433915305`*^9}, {3.8104802785189395`*^9, 
   3.8104802814214115`*^9}, {3.810480477782269*^9, 3.8104805471507206`*^9}, {
   3.8104805927965565`*^9, 3.810480633017248*^9}, {3.8104807595294323`*^9, 
   3.8104809538100047`*^9}, {3.8104811300285854`*^9, 
   3.8104811403007636`*^9}, {3.8104812580010843`*^9, 
   3.8104813317580833`*^9}, {3.81048146789211*^9, 3.8104815557630205`*^9}, {
   3.8104817202872114`*^9, 3.8104817438715935`*^9}, 3.810481790764664*^9, 
   3.810481836241686*^9, {3.810481926951917*^9, 3.810481935802024*^9}, {
   3.8106609069078913`*^9, 3.81066090872985*^9}, {3.8106610360496655`*^9, 
   3.8106610794321012`*^9}, {3.8106611250786457`*^9, 
   3.8106611896874313`*^9}, {3.810715242072402*^9, 3.810715275027593*^9}, {
   3.810715339538826*^9, 3.810715464312791*^9}, {3.810715495125059*^9, 
   3.8107155074950466`*^9}, {3.9170869294112234`*^9, 3.9170869301935806`*^9}, 
   3.9170999847743435`*^9},ExpressionUUID->"d2e25601-7834-4df4-89d8-\
76f00502a9f6"],

Cell[TextData[{
 "Meaning that the total value of ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["L", "x"], TraditionalForm]],ExpressionUUID->
  "a2165040-e959-41d3-8b56-9dfa163a09b1"],
 " and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["L", "y"], TraditionalForm]],ExpressionUUID->
  "067518d7-ac40-4ece-a1e6-b2745c4b5256"],
 " is constrained. This value must be positive because of the squares (we can\
\[CloseCurlyQuote]t have an imaginary angular momentum), so this equation \
also explains the constraint on the values of ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["m", "l"], TraditionalForm]],ExpressionUUID->
  "67a45a32-88cb-4b35-b879-c27d05877c97"],
 ", "
}], "Text",
 CellChangeTimes->{{3.810715471458458*^9, 3.810715475054411*^9}, {
