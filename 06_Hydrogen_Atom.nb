Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"-", 
    RowBox[{
     SuperscriptBox["\[HBar]", "2"], "[", 
     RowBox[{
      FractionBox["1", 
       RowBox[{
        StyleBox["R",
         FontSlant->"Italic"], 
        RowBox[{"(", 
         StyleBox["r",
          FontSlant->"Italic"], ")"}]}]], 
      RowBox[{
       FractionBox["\[PartialD]", 
        RowBox[{"\[PartialD]", 
         StyleBox["r",
          FontSlant->"Italic"]}]], 
       RowBox[{"(", 
        RowBox[{
         SuperscriptBox[
          StyleBox["r",
           FontSlant->"Italic"], "2"], 
         FractionBox[
          RowBox[{
           RowBox[{"\[PartialD]", 
            StyleBox["R",
             FontSlant->"Italic"]}], 
           RowBox[{"(", 
            StyleBox["r",
             FontSlant->"Italic"], ")"}]}], 
          RowBox[{"\[PartialD]", 
           StyleBox["r",
            FontSlant->"Italic"]}]]}], ")"}]}]}], "]"}]}], "-", 
   RowBox[{
    SuperscriptBox["\[HBar]", "2"], "[", 
    RowBox[{
     RowBox[{
      FractionBox["1", 
       RowBox[{
        StyleBox["Y",
         FontSlant->"Italic"], 
        RowBox[{"(", 
         RowBox[{"\[Theta]", ",", "\[Phi]"}], ")"}]}]], 
      FractionBox["1", 
       RowBox[{"sin", 
        RowBox[{"(", "\[Theta]", ")"}]}]], 
      RowBox[{
       FractionBox["\[PartialD]", 
        RowBox[{"\[PartialD]", "\[Theta]"}]], 
       RowBox[{"(", 
        RowBox[{"sin", 
         RowBox[{"(", "\[Theta]", ")"}], 
         FractionBox[
          RowBox[{
           RowBox[{"\[PartialD]", 
            StyleBox["Y",
             FontSlant->"Italic"]}], 
           RowBox[{"(", 
            RowBox[{"\[Theta]", ",", "\[Phi]"}], ")"}]}], 
          RowBox[{"\[PartialD]", "\[Theta]"}]]}], ")"}]}]}], "+", 
     RowBox[{
      FractionBox["1", 
       RowBox[{
        StyleBox["Y",
         FontSlant->"Italic"], 
        RowBox[{"(", 
         RowBox[{"\[Theta]", ",", "\[Phi]"}], ")"}]}]], 
      FractionBox["1", 
       RowBox[{
