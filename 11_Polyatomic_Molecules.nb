236349d8d7b1"],

Cell[BoxData[
 RowBox[{
  SubscriptBox[
   StyleBox["a",
    FontSlant->"Italic"], "1"], "=", 
  RowBox[{
   SubscriptBox[
    StyleBox["a",
     FontSlant->"Italic"], "2"], "=", 
   RowBox[{
    SubscriptBox[
     StyleBox["b",
      FontSlant->"Italic"], "1"], "=", 
    RowBox[{
     RowBox[{"-", 
      SubscriptBox[
       StyleBox["b",
        FontSlant->"Italic"], "2"]}], "=", 
