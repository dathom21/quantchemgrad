f3eb264ffb7d"],

Cell["\<\
A table of the hydrogen atomic wavefunctions is provided below. Remember \
that, according to the way in which set up the TISE at the beginning of this \
lesson, these wavefunctions are for the electron of the hydrogen atom with \
respect to the position of the proton.\
\>", "Text",
 CellChangeTimes->{{3.810659903040094*^9, 3.8106599163292766`*^9}, {
  3.8107217384135523`*^9, 
  3.8107217931657705`*^9}},ExpressionUUID->"9fc959d7-7f7c-4363-a344-\
db6dbe411f5e"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"Grid", "[", 
    RowBox[{
     RowBox[{"Prepend", "[", 
      RowBox[{
       RowBox[{"Flatten", "[", 
        RowBox[{
         RowBox[{"Table", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"n", ",", "l", ",", "m", ",", 
             RowBox[{
              RowBox[{"-", 
               RowBox[{"SphericalHarmonicY", "[", 
                RowBox[{"l", ",", "m", ",", "\[Theta]", ",", "\[Phi]"}], 
                "]"}]}], "*", 
              SqrtBox[
               FractionBox[
                RowBox[{" ", 
                 RowBox[{
                  RowBox[{"(", 
                   RowBox[{"n", "-", "l", "-", "1"}], ")"}], "!"}]}], 
                RowBox[{"2", "*", "n", "*", 
                 SuperscriptBox[
                  RowBox[{"(", 
                   RowBox[{
                    RowBox[{"(", 
                    RowBox[{"n", "+", "l"}], ")"}], "!"}], ")"}], "3"]}]]], 
              "*", 
              SuperscriptBox[
               RowBox[{"(", 
                FractionBox["2", 
                 RowBox[{"n", "*", 
                  SubscriptBox["a", "0"]}]], ")"}], 
               RowBox[{"l", "+", 
                RowBox[{"3", "/", "2"}]}]], "*", 
              SuperscriptBox["r", "l"], " ", "*", 
              RowBox[{"-", 
               RowBox[{
                RowBox[{"(", 
                 RowBox[{"n", "+", "l"}], ")"}], "!"}]}], "*", 
              RowBox[{"LaguerreL", "[", 
               RowBox[{
                RowBox[{"n", "-", "l", "-", "1"}], ",", 
                RowBox[{
                 RowBox[{"2", "l"}], "+", "1"}], ",", 
                FractionBox[
                 RowBox[{"2", "r"}], 
                 RowBox[{"n", "*", 
                  SubscriptBox["a", "0"]}]]}], "]"}], "*", 
              SuperscriptBox["\[ExponentialE]", 
               RowBox[{"-", 
                FractionBox["r", 
                 RowBox[{"n", "*", 
                  SubscriptBox["a", "0"]}]]}]]}]}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{"n", ",", "1", ",", "3"}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{"l", ",", "0", ",", 
             RowBox[{"n", "-", "1"}]}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{"m", ",", 
             RowBox[{"-", "l"}], ",", "l"}], "}"}]}], "]"}], ",", "2"}], 
        "]"}], ",", 
       RowBox[{"{", 
        RowBox[{
        "\"\<\!\(\*StyleBox[\"n\",FontSlant->\"Italic\"]\)\>\"", ",", 
         "\"\<\!\(\*StyleBox[\"l\",FontSlant->\"Italic\"]\)\>\"", ",", 
         "\"\<\!\(\*SubscriptBox[StyleBox[\"m\",FontSlant->\"Italic\"], \
StyleBox[\"l\",FontSlant->\"Italic\"]]\)\>\"", ",", 
         "\"\<\!\(\*SubscriptBox[\"\[Psi]\", \
SubscriptBox[StyleBox[\"nlm\",FontSlant->\"Italic\"], \
StyleBox[\"l\",FontSlant->\"Italic\"]]]\)(\!\(\*StyleBox[\"r\",FontSlant->\"\
Italic\"]\),\[Theta],\[Phi])\>\""}], "}"}]}], "]"}], ",", 
     RowBox[{"BaseStyle", "\[Rule]", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"FontFamily", "\[Rule]", "\"\<Arial\>\""}], ",", 
        RowBox[{"FontSize", "\[Rule]", "18"}]}], "}"}]}], ",", 
     RowBox[{"Frame", "\[Rule]", "All"}]}], "]"}], 
   "\[IndentingNewLine]"}]}]], "Input",
