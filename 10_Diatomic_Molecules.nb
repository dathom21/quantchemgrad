       RowBox[{"1", ",", "2", ",", "3", ",", "4", ",", "5", ",", "6"}], "}"}],
       ",", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"-", "0.1"}], ",", "0", ",", "0.1", ",", "0.2"}], "}"}]}], 
     "}"}]}], ",", 
   RowBox[{"ImageSize", "\[Rule]", "Medium"}], ",", " ", 
