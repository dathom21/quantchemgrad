Cell[CellGroupData[{

Cell["Common Forms of Basis Functions", "Subsubsection",
 CellChangeTimes->{{3.811869919071433*^9, 3.8118699234949207`*^9}, {
  3.8119347493494425`*^9, 
  3.8119347537985916`*^9}},ExpressionUUID->"1772eaa9-e03a-ed43-9854-\
cb82816dfcae"],

Cell["\<\
We will come back to the complexities of determining energies and \
eigenfunctions in molecules using the linear variational method in a future \
lesson, but we introduce here the typical form of basis functions used in \
such calculations. In the linear combination of atomic orbitals (LCAO), our \
basis functions for our trial wavefunction,\
\>", "Text",
 CellChangeTimes->{{3.8118699428111334`*^9, 3.811869985227314*^9}, {
  3.8118700301953287`*^9, 
  3.8118700679707074`*^9}},ExpressionUUID->"a08953ce-5e5a-e342-9b7a-\
8938b95ef062"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"|", "\[CapitalPhi]"}], "\[RightAngleBracket]"}], "=", 
     RowBox[{
      RowBox[{
       UnderscriptBox["\[Sum]", 
        StyleBox["n",
         FontSlant->"Italic"]], 
       SubscriptBox[
        StyleBox["a",
         FontSlant->"Italic"], 
        StyleBox["n",
         FontSlant->"Italic"]]}], "|", 
      SubscriptBox["\[Phi]", 
       StyleBox["n",
        FontSlant->"Italic"]]}]}], "\[RightAngleBracket]"}], "                                         ",
    "\[Phi]"}], "=", 
  RowBox[{
   UnderscriptBox["\[Sum]", 
    StyleBox["n",
     FontSlant->"Italic"]], 
   RowBox[{
    SubscriptBox[
     StyleBox["a",
      FontSlant->"Italic"], 
     StyleBox["n",
      FontSlant->"Italic"]], 
    SubscriptBox["\[Phi]", 
     StyleBox["n",
      FontSlant->"Italic"]]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.811593312893673*^9, 3.8115933831661987`*^9}, {
   3.811593458953679*^9, 3.8115934974178753`*^9}, {3.811594043422389*^9, 
   3.8115940850450926`*^9}, {3.8115941212928057`*^9, 3.81159413134099*^9}, {
   3.8115942129312763`*^9, 3.811594213576462*^9}, {3.811594345555955*^9, 
   3.8115943458791523`*^9}, 3.8115943810138807`*^9, {3.8118583015457077`*^9, 
   3.8118583904266043`*^9}, {3.8118668881127214`*^9, 3.811866985652667*^9}, {
   3.81187008170006*^9, 3.8118700849636593`*^9}, {3.811935658277105*^9, 
   3.8119356804714355`*^9}},ExpressionUUID->"a89a76f2-f54d-9c43-8a8b-\
6244a65b7592"],

Cell["\<\
are based upon the structure of atomic orbitals of the hydrogen atom. The \
form that more closely resembles the atomic orbitals of the hydrogen atom are \
called Slater-type orbitals. In a position-basis in spherical coordinates, we \
would write\
\>", "Text",
 CellChangeTimes->{{3.8118701006512666`*^9, 
  3.8118701565023937`*^9}},ExpressionUUID->"f7fa22ee-1ad9-6c42-8ca8-\
5c008fc295ed"],

