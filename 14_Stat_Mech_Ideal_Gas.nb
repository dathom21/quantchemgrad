Cell[BoxData[
 RowBox[{
  RowBox[{"\[LeftAngleBracket]", 
   SubscriptBox["\[CurlyEpsilon]", 
    StyleBox["trans",
     FontSlant->"Italic"]], "\[RightAngleBracket]"}], 
  StyleBox["=",
   FontSlant->"Plain"], 
  RowBox[{
   RowBox[{
    StyleBox["-",
     FontSlant->"Italic"], 
    SubscriptBox[
     RowBox[{
      StyleBox["(",
       FontSlant->"Italic"], 
      FractionBox[
       RowBox[{
        RowBox[{"\[PartialD]", "ln"}], 
        RowBox[{"(", 
         SubscriptBox[
          StyleBox["Z",
           FontSlant->"Italic"], 
          SubscriptBox[
           StyleBox["\[CurlyEpsilon]",
            FontSlant->"Italic"], 
           StyleBox["trans",
            FontSlant->"Italic"]]], ")"}]}], 
       RowBox[{"\[PartialD]", "\[Beta]"}]], ")"}], 
     StyleBox["V",
      FontSlant->"Italic"]]}], "=", 
   RowBox[{"-", 
    RowBox[{
     FractionBox["\[PartialD]", 
      RowBox[{"\[PartialD]", "\[Beta]"}]], 
     RowBox[{"ln", "[", 
      RowBox[{
       SuperscriptBox[
        RowBox[{"(", 
         FractionBox[
          RowBox[{"2", "\[Pi]", " ", 
           StyleBox["m",
            FontSlant->"Italic"], 
           StyleBox["  ",
            FontSlant->"Italic"]}], 
          RowBox[{"\[Beta]", " ", 
           SuperscriptBox[
            StyleBox["h",
             FontSlant->"Italic"], "2"]}]], ")"}], 
        RowBox[{"3", "/", "2"}]], 
       StyleBox["V",
        FontSlant->"Italic"]}], 
      StyleBox["]",
       FontSlant->"Italic"]}]}]}]}]}]], "DisplayFormulaNumbered",
 InitializationCell->True,
 CellChangeTimes->{{3.9212505192469416`*^9, 3.921250534863843*^9}, {
