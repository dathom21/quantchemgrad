      SubscriptBox[
       StyleBox["a",
        FontSlant->"Italic"], 
       StyleBox["m",
        FontSlant->"Italic"]], " ", 
      SubscriptBox[
       StyleBox["H",
        FontSlant->"Italic"], 
       StyleBox["nm",
        FontSlant->"Italic"]]}]}]}], 
   RowBox[{
    UnderscriptBox["\[Sum]", 
     StyleBox["n",
      FontSlant->"Italic"]], 
    RowBox[{
     UnderscriptBox["\[Sum]", 
      StyleBox["m",
       FontSlant->"Italic"]], 
