  3.811867203632437*^9}},ExpressionUUID->"9bd3b484-58e3-a742-9135-\
e2436a1af647"],

Cell["If we take our basis functions to be normalized, we have", "Text",
 CellChangeTimes->{{3.8118673241634374`*^9, 
  3.81186733069289*^9}},ExpressionUUID->"8949fc1c-8109-f04d-a969-\
e634706416b9"],

Cell[BoxData[
 RowBox[{
  SubscriptBox[
   StyleBox["S",
    FontSlant->"Italic"], "11"], "=", 
  RowBox[{
   SubscriptBox[
    StyleBox["S",
     FontSlant->"Italic"], "22"], "=", "1"}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.811867187960767*^9, 3.811867203632437*^9}, {
  3.811867339621044*^9, 
  3.811867347277959*^9}},ExpressionUUID->"18f383a1-99d3-e946-82c2-\
84471d7bca36"],

Cell["and our equations becomes", "Text",
 CellChangeTimes->{{3.811867351978188*^9, 3.811867354370734*^9}, {
  3.8118677194085927`*^9, 
  3.811867719838865*^9}},ExpressionUUID->"2446f3e2-416a-d249-8b98-\
46879a101e56"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      SubscriptBox[
       StyleBox["H",
        FontSlant->"Italic"], "11"], "-", 
      SubscriptBox[
       StyleBox["E",
        FontSlant->"Italic"], "\[CapitalPhi]"]}], ")"}], 
    RowBox[{"(", 
     RowBox[{
      SubscriptBox[
       StyleBox["H",
        FontSlant->"Italic"], "22"], "-", 
      SubscriptBox[
       StyleBox["E",
        FontSlant->"Italic"], "\[CapitalPhi]"]}], ")"}]}], "-", 
   SuperscriptBox[
    RowBox[{"(", 
     RowBox[{
      SubscriptBox[
       StyleBox["H",
        FontSlant->"Italic"], "12"], "-", 
      RowBox[{
       SubscriptBox[
        StyleBox["E",
         FontSlant->"Italic"], "\[CapitalPhi]"], 
       SubscriptBox[
        StyleBox["S",
         FontSlant->"Italic"], "12"]}]}], ")"}], "2"]}], "=", 
