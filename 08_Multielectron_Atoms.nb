Cell[TextData[{
 "So we now have an expression for our first-order correction to the energy, ",
 Cell[BoxData[
  SuperscriptBox[
   StyleBox["E",
    FontSlant->"Italic"], 
   RowBox[{"(", "1", ")"}]]],
  CellChangeTimes->{{3.811939159903883*^9, 3.8119392103826303`*^9}, {
