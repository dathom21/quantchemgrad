    3.811330835135107*^9, 3.811330835875268*^9}, 3.811501833540098*^9, {
    3.811501867015377*^9, 3.8115019239986753`*^9}, {3.8115139754043055`*^9, 
    3.8115140290156994`*^9}, {3.811514094940814*^9, 3.8115141114447994`*^9}, {
    3.811514448949569*^9, 3.811514469461255*^9}, 3.811514585135304*^9, {
    3.811515190235585*^9, 3.8115152613279533`*^9}, {3.811515295648719*^9, 
    3.8115153064174204`*^9}},ExpressionUUID->
  "78e07418-d981-4138-a8bd-6e90a8a0206a"],
 ". Let\[CloseCurlyQuote]s again take our basis vectors to be the position ",
 StyleBox["x",
  FontSlant->"Italic"],
 ", in which case we can write that"
}], "Text",
 CellChangeTimes->{{3.811515348307856*^9, 
  3.8115154358601727`*^9}},ExpressionUUID->"4a09f302-b940-48bd-8494-\
438bc4f00b63"],

Cell[BoxData[
 RowBox[{
  RowBox[{"\[LeftAngleBracket]", 
   RowBox[{
    StyleBox[
     SubscriptBox[
      StyleBox["\[CapitalPsi]",
       FontWeight->"Bold"], 
      StyleBox["a",
       FontWeight->"Bold",
       FontSlant->"Italic"]],
     FontWeight->"Bold"], "|", 
    OverscriptBox[
     StyleBox["A",
      FontSlant->"Italic"], "^"], "|", 
