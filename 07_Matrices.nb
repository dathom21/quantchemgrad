   3.811517335539088*^9}},ExpressionUUID->"9c763047-d510-4c39-97c5-\
7842569f9fe4"],

Cell["Or, in matrix form", "Text",
 CellChangeTimes->{{3.811517299488714*^9, 
  3.8115173016177235`*^9}},ExpressionUUID->"a18126e2-83a7-46e4-8c62-\
1ad33d63ce80"],

Cell[BoxData[
 RowBox[{
  RowBox[{"\[LeftAngleBracket]", 
   RowBox[{
    StyleBox[
     SubscriptBox[
      StyleBox["\[CapitalPsi]",
       FontWeight->"Bold"], 
      StyleBox["a",
       FontWeight->"Bold",
       FontSlant->"Italic"]],
     FontWeight->"Bold"], "|", 
    OverscriptBox[
     StyleBox["A",
      FontSlant->"Italic"], "^"], "|", 
    SubscriptBox[
     StyleBox["\[CapitalPsi]",
      FontWeight->"Bold"], 
     StyleBox["b",
      FontWeight->"Bold",
      FontSlant->"Italic"]]}], "\[RightAngleBracket]"}], "=", 
  RowBox[{
   RowBox[{"(", "\[NoBreak]", 
    RowBox[{GridBox[{
       {
        SubsuperscriptBox[
         StyleBox["a",
          FontSlant->"Italic"], "1", "\[Star]"], 
        SubsuperscriptBox[
         StyleBox["a",
          FontSlant->"Italic"], "2", "\[Star]"]}
      }], GridBox[{
       {"...", 
        SubsuperscriptBox[
         StyleBox["a",
          FontSlant->"Italic"], 
         StyleBox["n",
          FontSlant->"Italic"], "\[Star]"]}
      }]}], ")"}], 
   RowBox[{"(", "\[NoBreak]", GridBox[{
      {
       SubscriptBox[
        StyleBox["A",
         FontSlant->"Italic"], "11"], 
       SubscriptBox[
        StyleBox["A",
         FontSlant->"Italic"], "12"], "...", 
       SubscriptBox[
        StyleBox["A",
         FontSlant->"Italic"], 
        RowBox[{"1", 
         StyleBox["n",
          FontSlant->"Italic"]}]]},
      {
       SubscriptBox[
        StyleBox["A",
         FontSlant->"Italic"], "21"], 
       SubscriptBox[
        StyleBox["A",
         FontSlant->"Italic"], "22"], "...", 
       SubscriptBox[
        StyleBox["A",
         FontSlant->"Italic"], 
        RowBox[{"2", 
         StyleBox["n",
          FontSlant->"Italic"]}]]},
      {"...", "...", "...", "..."},
      {
       SubscriptBox[
        StyleBox["A",
         FontSlant->"Italic"], 
        StyleBox[
         RowBox[{
          StyleBox["n",
           FontSlant->"Italic"], "1"}]]], 
       SubscriptBox[
        StyleBox["A",
         FontSlant->"Italic"], 
        StyleBox[
         RowBox[{
          StyleBox["n",
           FontSlant->"Italic"], "2"}]]], "...", 
       SubscriptBox[
        StyleBox["A",
         FontSlant->"Italic"], 
        StyleBox["nn",
         FontSlant->"Italic"]]}
     }], "\[NoBreak]", ")"}], 
   RowBox[{"(", "\[NoBreak]", GridBox[{
      {
       SubscriptBox[
        StyleBox["b",
         FontSlant->"Italic"], "1"]},
      {
       SubscriptBox[
        StyleBox["b",
         FontSlant->"Italic"], "2"]},
      {GridBox[{
         {"..."},
         {
          SubscriptBox[
           StyleBox["b",
            FontSlant->"Italic"], 
           StyleBox["n",
            FontSlant->"Italic"]]}
        }]}
     }], "\[NoBreak]", ")"}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8113265575394135`*^9, 3.8113266208341584`*^9}, {
   3.8113268886705112`*^9, 3.8113269031313066`*^9}, 3.8113270406173744`*^9, {
