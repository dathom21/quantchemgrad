Cell[TextData[{
 "where we have used the fact that ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    StyleBox["\[Mu]",
     FontWeight->"Bold"], "\[CenterDot]", 
    SubscriptBox[
     StyleBox["E",
      FontWeight->"Bold",
      FontSlant->"Italic"], 
     StyleBox["0",
      FontWeight->"Bold"]]}], "=", 
   RowBox[{
    RowBox[{
     SubscriptBox["\[Mu]", "z"], 
     SubscriptBox[
      StyleBox["E",
       FontSlant->"Italic"], 
      StyleBox["z",
       FontSlant->"Italic"]]}], "=", 
    RowBox[{"\[Mu]", " ", "cos", 
     RowBox[{"(", "\[Theta]", ")"}], 
     SubscriptBox[
      StyleBox["E",
       FontSlant->"Italic"], 
      StyleBox["z",
       FontSlant->"Italic"]]}]}]}]],
  CellChangeTimes->{{3.8079712935412436`*^9, 3.8079714900326514`*^9}, {
    3.8080650361338077`*^9, 3.808065078586836*^9}, {3.8080651294863386`*^9, 
    3.8080651662446632`*^9}, {3.8080655103101*^9, 3.808065549470801*^9}, {
    3.8080655874181037`*^9, 3.8080655997397223`*^9}, {3.80806586302172*^9, 
    3.808065882866931*^9}, {3.8080659492793603`*^9, 3.808065953047598*^9}, {
    3.808066005614772*^9, 3.8080660274348636`*^9}, {3.8080662251299095`*^9, 
    3.8080662851171017`*^9}, {3.815378518820794*^9, 3.815378562596084*^9}, {
    3.81537861215761*^9, 3.815378656577838*^9}, {3.815379033614147*^9, 
    3.8153790773392897`*^9}, {3.8153792393653684`*^9, 3.81537924024451*^9}, {
    3.8153793909369802`*^9, 3.81537943105853*^9}, {3.815381276661846*^9, 
    3.8153813324920735`*^9}, {3.815468631694975*^9, 3.8154686569549303`*^9}, {
    3.8154691238283195`*^9, 3.815469135872029*^9}, {3.815469234740734*^9, 
    3.815469253967925*^9}, {3.815469801580475*^9, 3.8154698049489393`*^9}, {
    3.8154704295945253`*^9, 3.8154705377746935`*^9}, {3.815470675960216*^9, 
    3.815470685687868*^9}, {3.8154771921536026`*^9, 3.8154772311980553`*^9}, {
    3.815477347847094*^9, 3.815477378878831*^9}, {3.8154781257511315`*^9, 
    3.815478223009077*^9}, {3.8154786358518734`*^9, 3.8154786389651012`*^9}, {
    3.8154786960548897`*^9, 3.8154786979311686`*^9}, {3.815478752042659*^9, 
    3.8154787864116263`*^9}, {3.815478846570588*^9, 3.815478870033407*^9}, {
    3.8154793192990932`*^9, 3.8154793232406645`*^9}, {3.8154794670370035`*^9, 
    3.8154794764432354`*^9}, {3.8154827001319475`*^9, 
    3.8154827649959607`*^9}, {3.815754454341432*^9, 3.815754455861507*^9}, {
    3.815755043689207*^9, 3.81575504640403*^9}, 3.8157559076864185`*^9, 
    3.8157559845101175`*^9, {3.8473704607743645`*^9, 3.8473704610648255`*^9}},
  ExpressionUUID->"d21378ad-456f-427e-a868-f91249ff67a4"],
 ". The variable \[Mu] is now a scalar quantity giving the magnitude of the \
vector, and \[Theta] is the angle between the molecular dipole moment and the \
",
 StyleBox["z",
  FontSlant->"Italic"],
 " axis. Remember that the eigenfunctions for the rigid rotor in spherical \
coordinates are the spherical harmonics (there is no dependence on the \
internuclear distance ",
 StyleBox["r",
  FontWeight->"Bold",
  FontSlant->"Italic"],
 StyleBox[" ",
  FontWeight->"Bold"],
 "because it is fixed). Therefore, the transition dipole moment becomes"
}], "Text",
 CellChangeTimes->{
  3.815758139219446*^9, {3.8157585857195544`*^9, 3.8157585871008606`*^9}, {
   3.815758869474475*^9, 3.8157588734205794`*^9}, {3.815758948679206*^9, 
