Cell[TextData[{
 "Let\[CloseCurlyQuote]s take the example of ethene, the simplest aromatic \
hydrocarbon. The \[Sigma] molecular orbitals in this molecule arise from \
carbon ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    StyleBox["sp",
     FontSlant->"Italic"], "2"], TraditionalForm]],ExpressionUUID->
  "7516a055-c861-4fe4-86f8-20aa2e9490c9"],
 " hybrid orbitals,"
}], "Text",
