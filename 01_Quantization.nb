           RowBox[{"-", 
            RowBox[{"T", "^", "2.8"}]}], "/", "10000000000"}], ",", 
          RowBox[{
           RowBox[{"T", "^", "2.8"}], "/", "600000000"}]}], "}"}]}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{"BaseStyle", "\[Rule]", 
        RowBox[{"{", 
