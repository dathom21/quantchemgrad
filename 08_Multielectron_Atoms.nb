   3.8109916793993816`*^9}, {3.810991710031681*^9, 3.8109918292023373`*^9}, {
   3.810994488524798*^9, 3.810994499853472*^9}, {3.8109948928195066`*^9, 
   3.8109948950763626`*^9}, {3.8109949491606197`*^9, 3.810995087249513*^9}, {
   3.8109951188614283`*^9, 3.8109951226144466`*^9}, {3.8115998145208507`*^9, 
   3.8115999093225703`*^9}, 3.8119468581508093`*^9, {3.811947243706769*^9, 
   3.811947267020794*^9}, {3.8119474358938656`*^9, 3.8119474621815863`*^9}, {
   3.8119475278172007`*^9, 3.811947554332982*^9}, {3.811947616170298*^9, 
   3.8119476213260345`*^9}, {3.8119476732648582`*^9, 3.811947727174863*^9}, {
   3.811947824453816*^9, 3.8119478644680986`*^9}, {3.8119495657547507`*^9, 
   3.8119495858873444`*^9}},ExpressionUUID->"80e11d78-1d75-438c-9676-\
c03d5a841911"],

Cell[BoxData[
 RowBox[{
  StyleBox["CE",
   FontSlant->"Italic"], "=", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"-", "2.9037"}], " ", "Hartrees"}], " ", "+", 
    RowBox[{"2.8617", " ", "Hartrees"}]}], " ", "=", " ", 
   RowBox[{
    RowBox[{
     RowBox[{"-", "0.0420"}], " ", "Hartrees"}], " ", "=", " ", 
    RowBox[{
     RowBox[{"-", "110"}], " ", "kJ", " ", 
     SuperscriptBox["mol", 
      RowBox[{"-", "1"}]]}]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.810112811439228*^9, 3.8101128248442793`*^9}, {
   3.810479494926491*^9, 3.8104795038498344`*^9}, {3.810479572543576*^9, 
   3.8104796147383184`*^9}, {3.8104802055659895`*^9, 
   3.8104802433915305`*^9}, {3.8104802785189395`*^9, 
   3.8104802814214115`*^9}, {3.8109915300785556`*^9, 
   3.8109916793993816`*^9}, {3.810991710031681*^9, 3.8109918292023373`*^9}, {
   3.810994488524798*^9, 3.810994499853472*^9}, {3.8109948928195066`*^9, 
   3.8109948950763626`*^9}, {3.8109949491606197`*^9, 3.810995087249513*^9}, {
   3.8109951188614283`*^9, 3.8109951226144466`*^9}, {3.8115998145208507`*^9, 
   3.8115999093225703`*^9}, 3.8119468581508093`*^9, {3.811947243706769*^9, 
   3.811947267020794*^9}, {3.8119474358938656`*^9, 3.8119474621815863`*^9}, {
   3.8119475278172007`*^9, 3.811947554332982*^9}, {3.811947616170298*^9, 
   3.8119476213260345`*^9}, {3.8119476732648582`*^9, 3.811947727174863*^9}, {
   3.811947824453816*^9, 3.8119478644680986`*^9}, {3.8119495657547507`*^9, 
   3.8119496427888937`*^9}},ExpressionUUID->"4b8fa306-2be4-4889-8693-\
9a8338302ec0"],

Cell[TextData[{
 "So the Hartree method overestimates the energy of the system by ",
 Cell[BoxData[
  RowBox[{"110", " ", "kJ", " ", 
   SuperscriptBox["mol", 
    RowBox[{"-", "1"}]]}]],
  CellChangeTimes->{{3.810112811439228*^9, 3.8101128248442793`*^9}, {
    3.810479494926491*^9, 3.8104795038498344`*^9}, {3.810479572543576*^9, 
    3.8104796147383184`*^9}, {3.8104802055659895`*^9, 
    3.8104802433915305`*^9}, {3.8104802785189395`*^9, 
    3.8104802814214115`*^9}, {3.8109915300785556`*^9, 
    3.8109916793993816`*^9}, {3.810991710031681*^9, 3.8109918292023373`*^9}, {
    3.810994488524798*^9, 3.810994499853472*^9}, {3.8109948928195066`*^9, 
    3.8109948950763626`*^9}, {3.8109949491606197`*^9, 3.810995087249513*^9}, {
    3.8109951188614283`*^9, 3.8109951226144466`*^9}, {3.8115998145208507`*^9, 
    3.8115999093225703`*^9}, 3.8119468581508093`*^9, {3.811947243706769*^9, 
    3.811947267020794*^9}, {3.8119474358938656`*^9, 3.8119474621815863`*^9}, {
    3.8119475278172007`*^9, 3.811947554332982*^9}, {3.811947616170298*^9, 
    3.8119476213260345`*^9}, {3.8119476732648582`*^9, 3.811947727174863*^9}, {
    3.811947824453816*^9, 3.8119478644680986`*^9}, {3.8119495657547507`*^9, 
    3.8119496427888937`*^9}},ExpressionUUID->
  "e62148df-afc6-463b-9557-fc4e5f5dc713"],
 ", which is on the order of the strength of a covalent bond. We will see, \
however, that although the absolute accuracy of the method is not very high, \
the Hartree-Fock method in particular can give decent approximations if we \
are only concerned with relative energies that don\[CloseCurlyQuote]t involve \
bond breaking (because the correlation energy won\[CloseCurlyQuote]t change \
very much in that case)."
}], "Text",
 CellChangeTimes->{{3.8119496458027663`*^9, 3.8119497883258033`*^9}, {
  3.936203964147724*^9, 
  3.9362039655942097`*^9}},ExpressionUUID->"b373a88d-ef71-45e0-8792-\
c7b5ae1c4f1c"],

Cell["\<\
To discuss systems with more than two atoms, we must also account for \
electron spin explicitly, which will lead us to the Hartree-Fock method.\
\>", "Text",
 CellChangeTimes->{{3.8119497281894927`*^9, 3.811949729946022*^9}, {
  3.811949792809024*^9, 3.8119498294084916`*^9}, {3.9177018200690823`*^9, 
  3.917701822453184*^9}},ExpressionUUID->"f8920a1b-db46-4726-bea9-\
25185fd3bd0f"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Electron Spin Angular Momentum", "Section",
 CellChangeTimes->{{3.8124617435802903`*^9, 
  3.8124617486626606`*^9}},ExpressionUUID->"36fd8803-511f-45e9-abaa-\
bde2acc5ced5"],

Cell[CellGroupData[{

Cell["Electron Spin and the Schr\[ODoubleDot]dinger Equation", "Subsection",
 CellChangeTimes->{{3.8124617560891695`*^9, 
  3.8124617821847315`*^9}},ExpressionUUID->"8bde5f0f-40b1-4e53-9da0-\
e278c28dea3b"],

Cell["\<\
We are familiar with the concept of electron spin from introductory chemistry \
courses, but thus far in the course we have only referred to electron spin in \
passing. That\[CloseCurlyQuote]s because the Schr\[ODoubleDot]dinger equation \
doesn\[CloseCurlyQuote]t account for spin. This problem was discovered \
relatively early in the history of quantum mechanics. \
\>", "Text",
 CellChangeTimes->{{3.812461799475724*^9, 3.8124618551713*^9}, {
  3.8124619626822104`*^9, 3.8124620479564457`*^9}, {3.812462311947071*^9, 
  3.812462428559454*^9}},ExpressionUUID->"8669ae91-a580-4bb1-b2ed-\
4f4ad51a7eb2"],

Cell[TextData[{
 "Stern and Gerlach observed electron spin experimentally in 1922, although \
they misinterpreted the result at the time. Uhlenbeck and Goudsmit originally \
proposed in 1925 that the ",
 StyleBox["z",
  FontSlant->"Italic"],
 "-component of the spin angular momentum of the electron is quantized in \
values of \[PlusMinus]\[HBar]/2. We now recognize this quantization of the ",
 StyleBox["z",
  FontSlant->"Italic"],
 "-component of spin angular momentum to be specified by a fourth quantum \
number, typically denoted as ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["m", "s"], TraditionalForm]],ExpressionUUID->
  "6698fc9f-2067-447f-bf6b-efdffd4bb9c5"],
 ", which can take on values of \[PlusMinus]1/2."
}], "Text",
 CellChangeTimes->{{3.812462455600271*^9, 3.812462589885931*^9}, {
   3.812464147748994*^9, 3.812464170692873*^9}, 
   3.9177018989055004`*^9},ExpressionUUID->"929c1d3d-d8f0-4959-953e-\
bcda53db4e66"],

Cell[TextData[{
 "Because the time-independent Schr\[ODoubleDot]dinger equation doesn\
\[CloseCurlyQuote]t account for spin directly, spin is usually accounted for \
in an ",
 StyleBox["ad hoc",
  FontSlant->"Italic"],
 " manner. In other words, we construct our solutions to the \
Schr\[ODoubleDot]dinger equation in a way that accounts for spin. Spin isn\
\[CloseCurlyQuote]t derived \[OpenCurlyDoubleQuote]naturally\
\[CloseCurlyDoubleQuote] in this approach, but it allows us to continue using \
the same framework and principles we have developed up to this point."
}], "Text",
 CellChangeTimes->{{3.812462991407113*^9, 3.812463105599515*^9}, {
  3.9177019609182525`*^9, 
  3.9177019865622873`*^9}},ExpressionUUID->"4cb2c770-9cb5-4d00-8288-\
9174f3d13156"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Spin Operators, Eigenvalues, and Eigenfunctions", "Subsection",
 CellChangeTimes->{{3.8124634142258816`*^9, 
  3.812463421834947*^9}},ExpressionUUID->"6ffe754c-8da7-4914-9719-\
8ca8b603e76b"],

Cell[TextData[{
 "If in fact we have some allowed values for the ",
 StyleBox["z",
  FontSlant->"Italic"],
 "-component of the electron spin given by \[PlusMinus]\[HBar]/2, there \
should be some corresponding spin operator ",
 Cell[BoxData[
  FormBox[
   SubscriptBox[
    OverscriptBox["S", "^"], "z"], TraditionalForm]],ExpressionUUID->
  "4989c2c5-422c-4a1d-b481-1c2f9b23b9e0"],
 " that has eigenvalues \[PlusMinus]\[HBar]/2,"
}], "Text",
 CellChangeTimes->{{3.8124634238345137`*^9, 
  3.8124635643384724`*^9}},ExpressionUUID->"654746b4-71da-44af-87b0-\
c9d047cc462a"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   SubscriptBox[
    OverscriptBox[
     StyleBox["S",
      FontSlant->"Italic"], "^"], 
    StyleBox["z",
     FontSlant->"Italic"]], 
   StyleBox["f",
    FontSlant->"Italic"]}], "=", 
  RowBox[{
   SubscriptBox[
    StyleBox["m",
     FontSlant->"Italic"], 
    StyleBox["s",
     FontSlant->"Italic"]], 
   StyleBox[
    RowBox[{
     StyleBox["\[HBar]",
      FontSlant->"Plain"], 
     StyleBox["f",
      FontSlant->"Italic"]}]]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8124635845256133`*^9, 3.812463659917937*^9}, {
  3.8124641224907837`*^9, 
  3.8124641252579465`*^9}},ExpressionUUID->"29a1b877-eac0-48b8-9c97-\
62cbc16a2b56"],

Cell["where", "Text",
 CellChangeTimes->{{3.8124636661012144`*^9, 
  3.8124636664536233`*^9}},ExpressionUUID->"73adfdb9-87f6-4f93-99db-\
663ab796df58"],

Cell[BoxData[
 RowBox[{
  SubscriptBox[
   StyleBox["m",
    FontSlant->"Italic"], 
   StyleBox["s",
    FontSlant->"Italic"]], "=", 
  RowBox[{"\[PlusMinus]", 
   FractionBox["1", "2"]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8124635845256133`*^9, 3.8124636899506598`*^9}, 
   3.8124641197590714`*^9, 
   3.8124641786115336`*^9},ExpressionUUID->"80fb434c-33df-43df-8253-\
d9f47facd5c0"],

Cell[TextData[{
 "Because there are two eigenvalues for the operator ",
 Cell[BoxData[
  FormBox[
   SubscriptBox[
    OverscriptBox["S", "^"], "z"], TraditionalForm]],ExpressionUUID->
  "ab4d9bd1-15fb-4d0e-88b8-62eed7a73c80"],
 ", there are two corresponding eigenfunctions ",
 StyleBox["f",
  FontSlant->"Italic"],
 ". Traditionally, these two eigenfunctions are labeled \[Alpha] and \[Beta],"
}], "Text",
 CellChangeTimes->{{3.8124636952894096`*^9, 3.812463748885102*^9}, {
  3.9177021647991514`*^9, 
  3.9177021654644527`*^9}},ExpressionUUID->"38673776-c89e-455d-8e9b-\
55490fa6a15d"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   SubscriptBox[
    OverscriptBox[
     StyleBox["S",
      FontSlant->"Italic"], "^"], 
    StyleBox["z",
     FontSlant->"Italic"]], "\[Alpha]"}], "=", 
  RowBox[{
   FractionBox["\[HBar]", "2"], "\[Alpha]"}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8124635845256133`*^9, 3.812463659917937*^9}, {
  3.8124637556855745`*^9, 
  3.8124637660754547`*^9}},ExpressionUUID->"ef082eb2-6f82-4187-ac18-\
3bc579b55022"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   SubscriptBox[
    OverscriptBox[
     StyleBox["S",
      FontSlant->"Italic"], "^"], 
    StyleBox["z",
     FontSlant->"Italic"]], "\[Beta]"}], "=", 
  RowBox[{
   RowBox[{"-", 
    FractionBox["\[HBar]", "2"]}], "\[Beta]"}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8124635845256133`*^9, 3.812463659917937*^9}, {
  3.8124637556855745`*^9, 3.8124637759727974`*^9}, {3.812463807023354*^9, 
  3.812463812629797*^9}},ExpressionUUID->"9551d5ca-855e-4a0b-90bd-\
be4a07cd1d88"],

Cell[TextData[{
 "In analogy with the square total angular momentum operator ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    OverscriptBox["L", "^"], "2"], TraditionalForm]],ExpressionUUID->
  "ccd80a12-28cf-409e-b5f5-1909da8d1028"],
 ", we also define a square total spin angular momentum operator ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    OverscriptBox["S", "^"], "2"], TraditionalForm]],ExpressionUUID->
  "b931b756-ba10-4174-a0ca-0dbb3def6d25"],
 ","
}], "Text",
 CellChangeTimes->{{3.8124638953221073`*^9, 
  3.8124639668604493`*^9}},ExpressionUUID->"91e242b7-387d-4e10-8676-\
759e36c49b15"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   OverscriptBox[
    SuperscriptBox[
     StyleBox["S",
      FontSlant->"Italic"], "2"], "^"], "\[Alpha]"}], "=", 
  RowBox[{
   StyleBox["s",
    FontSlant->"Italic"], 
   RowBox[{"(", 
    RowBox[{
     StyleBox["s",
      FontSlant->"Italic"], "+", "1"}], ")"}], 
   SuperscriptBox["\[HBar]", "2"], "\[Alpha]"}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8124635845256133`*^9, 3.812463659917937*^9}, {
  3.8124637556855745`*^9, 3.8124637660754547`*^9}, {3.8124642556527925`*^9, 
  3.8124643147338076`*^9}},ExpressionUUID->"afa31fe0-5b52-413a-bda6-\
13eabc0ca2e0"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   OverscriptBox[
    SuperscriptBox[
     StyleBox["S",
      FontSlant->"Italic"], "2"], "^"], "\[Beta]"}], "=", 
  RowBox[{
   StyleBox["s",
    FontSlant->"Italic"], 
   RowBox[{"(", 
    RowBox[{
     StyleBox["s",
      FontSlant->"Italic"], "+", "1"}], ")"}], 
   SuperscriptBox["\[HBar]", "2"], "\[Beta]"}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8124635845256133`*^9, 3.812463659917937*^9}, {
  3.8124637556855745`*^9, 3.8124637660754547`*^9}, {3.8124642556527925`*^9, 
  3.8124643325348434`*^9}},ExpressionUUID->"f1ba43f9-5227-45b4-b07e-\
1cfc39a568d0"],

Cell[TextData[{
 "In analogy with ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    OverscriptBox["L", "^"], "2"], TraditionalForm]],ExpressionUUID->
  "b5d410df-5864-427b-bc78-c78533c76b3c"],
 " and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox[
    OverscriptBox["L", "^"], "z"], TraditionalForm]],ExpressionUUID->
  "c70574b2-5716-45b6-a6b8-fcb59ecc9022"],
 ", ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["m", "s"], TraditionalForm]],ExpressionUUID->
  "62d34323-d2c5-4e58-9139-677fe2eccfbc"],
 " can take on integer values from \[Minus]",
 StyleBox["s",
  FontSlant->"Italic"],
 " to ",
 StyleBox["s",
  FontSlant->"Italic"],
 ". Because we only have two possible values of ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["m", "s"], TraditionalForm]],ExpressionUUID->
  "306eedf5-469e-4c16-8800-a53dcf25cd6b"],
 ", we must have only one possible value of ",
 StyleBox["s",
  FontSlant->"Italic"],
 ","
}], "Text",
 CellChangeTimes->{{3.8124643360715637`*^9, 3.8124644516372566`*^9}, {
  3.812464500792684*^9, 3.8124645413043385`*^9}, {3.9177022421575947`*^9, 
  3.9177022439687476`*^9}},ExpressionUUID->"0eadc78e-bad3-4062-bfcd-\
05d56e6a0b03"],

Cell[BoxData[
 RowBox[{
  StyleBox["s",
   FontSlant->"Italic"], "=", 
  FractionBox["1", "2"]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8124635845256133`*^9, 3.812463659917937*^9}, {
  3.8124637556855745`*^9, 3.8124637660754547`*^9}, {3.8124642556527925`*^9, 
  3.8124643147338076`*^9}, {3.8124645497272577`*^9, 
  3.8124645549780016`*^9}},ExpressionUUID->"a3ac0182-ea2d-4bcc-9ea5-\
30bebcded882"],

Cell[TextData[{
 "Equations (37) and (38) tell us that if we somehow make a measurement of \
the ",
 StyleBox["z",
  FontSlant->"Italic"],
 "-component of the angular momentum of a free electron, we will only obtain \
values of either \[HBar]/2 or \[Minus]\[HBar]/2 as a result. As a note, we \
often refer to this spin angular momentum as an ",
 StyleBox["intrinsic",
  FontSlant->"Italic"],
 " angular momentum, because it is not associated with a true spinning state \
of the electron. Note that the eigenvalues ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["S",
    FontSlant->"Italic"], 
   StyleBox["z",
    FontSlant->"Italic"]]],
  CellChangeTimes->{{3.8124635845256133`*^9, 3.812463659917937*^9}, {
   3.8124637556855745`*^9, 3.8124637660754547`*^9}, {3.812465075219303*^9, 
   3.8124651077684402`*^9}},ExpressionUUID->
  "da926b02-8dab-4b8c-be1d-e1be19e931c9"],
 " and ",
 Cell[BoxData[
  SuperscriptBox[
   StyleBox["S",
    FontSlant->"Italic"], "2"]],
  CellChangeTimes->{{3.8124635845256133`*^9, 3.812463659917937*^9}, {
   3.8124637556855745`*^9, 3.8124637660754547`*^9}, {3.812465075219303*^9, 
   3.8124650843093405`*^9}, {3.812465116115116*^9, 3.8124651327747536`*^9}, {
   3.8124761533249984`*^9, 3.8124761561504664`*^9}},ExpressionUUID->
  "b20e6f61-5ae4-49c8-aed9-660b26d51c36"],
 " associated with these operators are given by"
}], "Text",
 CellChangeTimes->{{3.812464620729414*^9, 3.8124649217764006`*^9}, 
   3.81246495563468*^9, {3.917702261244465*^9, 3.9177022882089252`*^9}, {
   3.9177023365724015`*^9, 3.917702385156313*^9}, {3.9362799739122486`*^9, 
   3.9362800015897827`*^9}},ExpressionUUID->"8d2c6eff-8f36-4092-a604-\
604b2468c24e"],

Cell[BoxData[
 RowBox[{
  SubscriptBox[
   StyleBox["S",
    FontSlant->"Italic"], 
   StyleBox["z",
    FontSlant->"Italic"]], "=", 
  RowBox[{
   RowBox[{
    SubscriptBox[
     StyleBox["m",
      FontSlant->"Italic"], "s"], "\[HBar]"}], "=", 
   RowBox[{"\[PlusMinus]", 
    FractionBox["\[HBar]", "2"]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8124635845256133`*^9, 3.812463659917937*^9}, {
  3.8124637556855745`*^9, 3.8124637660754547`*^9}, {3.812465075219303*^9, 
  3.8124651077684402`*^9}},ExpressionUUID->"f9f64377-f8b1-42ea-81e4-\
d2ce24822a83"],

Cell["and", "Text",
 CellChangeTimes->{{3.812465086317936*^9, 
  3.8124650865232716`*^9}},ExpressionUUID->"8fe95785-2aab-44c5-9944-\
c309e0eee625"],

Cell[BoxData[
 RowBox[{
  SuperscriptBox[
   StyleBox["S",
    FontSlant->"Italic"], "2"], "=", 
  RowBox[{
   RowBox[{
    StyleBox["s",
     FontSlant->"Italic"], 
    RowBox[{"(", 
     RowBox[{
      StyleBox["s",
       FontSlant->"Italic"], "+", "1"}], ")"}], 
    SuperscriptBox["\[HBar]", "2"]}], "=", 
   RowBox[{
    FractionBox["1", "2"], 
    RowBox[{"(", 
     RowBox[{
      FractionBox["1", "2"], "+", "1"}], ")"}], 
    SuperscriptBox["\[HBar]", "2"]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8124635845256133`*^9, 3.812463659917937*^9}, {
  3.8124637556855745`*^9, 3.8124637660754547`*^9}, {3.812465075219303*^9, 
  3.8124650843093405`*^9}, {3.812465116115116*^9, 3.8124651327747536`*^9}, {
  3.8124761533249984`*^9, 
  3.8124761561504664`*^9}},ExpressionUUID->"31eb9017-d6e7-46dd-9e1a-\
1bfffbaf32dc"],

Cell["\<\
Because \[Alpha] and \[Beta] are eigenfunctions of a Hermitian operator, they \
must be orthogonal. In integral form, we usually write these as a function of \
some variable \[Sigma]. Additionally, we take \[Alpha] and \[Beta] to be \
normalized, so we have\
\>", "Text",
 CellChangeTimes->{{3.8124651641533623`*^9, 3.8124651787728434`*^9}, {
  3.812469871134143*^9, 3.81246990923569*^9}, {3.8124700478830566`*^9, 
  3.812470049021758*^9}, {3.91770239436895*^9, 
  3.91770243069954*^9}},ExpressionUUID->"71e88ed9-27df-420c-b2eb-\
53f8e7ef69c4"],

Cell[BoxData[
 RowBox[{
  RowBox[{"\[Integral]", 
   RowBox[{
    SuperscriptBox["\[Alpha]", "\[Star]"], 
    RowBox[{"(", "\[Sigma]", ")"}], "\[Alpha]", 
    RowBox[{"(", "\[Sigma]", ")"}], 
    RowBox[{"\[DifferentialD]", "\[Sigma]"}]}]}], "=", 
  RowBox[{
   RowBox[{"\[Integral]", 
    RowBox[{
     SuperscriptBox["\[Beta]", "\[Star]"], 
     RowBox[{"(", "\[Sigma]", ")"}], "\[Beta]", 
     RowBox[{"(", "\[Sigma]", ")"}], 
     RowBox[{"\[DifferentialD]", "\[Sigma]"}]}]}], "=", 
   "1"}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8124699435472097`*^9, 3.81246994645569*^9}, {
   3.812469990003168*^9, 3.812470001326069*^9}, 3.8124701212743053`*^9, {
   3.9177024069201555`*^9, 
   3.917702440390351*^9}},ExpressionUUID->"4aa98c56-6f6b-4565-b1be-\
5fb4082c4780"],

Cell[BoxData[
 RowBox[{
  RowBox[{"\[Integral]", 
   RowBox[{
    SuperscriptBox["\[Alpha]", "\[Star]"], 
    RowBox[{"(", "\[Sigma]", ")"}], "\[Beta]", 
    RowBox[{"(", "\[Sigma]", ")"}], 
    RowBox[{"\[DifferentialD]", "\[Sigma]"}]}]}], "=", 
  RowBox[{
   RowBox[{"\[Integral]", 
    RowBox[{
     SuperscriptBox["\[Beta]", "\[Star]"], 
     RowBox[{"(", "\[Sigma]", ")"}], "\[Alpha]", 
     RowBox[{"(", "\[Sigma]", ")"}], 
     RowBox[{"\[DifferentialD]", "\[Sigma]"}]}]}], "=", 
   "0"}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8124699435472097`*^9, 3.81246994645569*^9}, {
  3.812469990003168*^9, 3.812470036570691*^9}, {3.917702445529004*^9, 
