Cell[TextData[{
 StyleBox["Figure 1.5",
  FontWeight->"Bold"],
 ". Davisson-Germer experimental setup, CC BY-SA 3.0, \
https://upload.wikimedia.org/wikipedia/commons/4/4e/Davisson-Germer_\
experiment.svg"
}], "Affiliation",
 CellChangeTimes->{{3.809435027311596*^9, 3.8094350763900714`*^9}, {
  3.80943583474421*^9, 3.8094358359299717`*^9}, {3.8094472165104203`*^9, 
  3.809447281165168*^9}, {3.809510876137825*^9, 3.809510907739876*^9}, {
  3.809968073566992*^9, 3.8099681536568317`*^9}, {3.810557260250428*^9, 
  3.8105572606139913`*^9}, {3.8130835305386977`*^9, 3.8130836194514275`*^9}, {
  3.813224407772764*^9, 3.8132244817756805`*^9}, {3.8394266250053024`*^9, 
  3.839426636135662*^9}, {3.8394271229755535`*^9, 3.8394271464856167`*^9}, {
  3.8394271859998655`*^9, 3.8394272181213303`*^9}, {3.8394281636526613`*^9, 
  3.839428168851229*^9}, {3.91423799573891*^9, 
  3.9142379968867025`*^9}},ExpressionUUID->"d3b9f5cd-f8ae-444b-8e24-\
8c2b3de8dcaa"],

Cell[TextData[{
 "The experiments of Davisson and Germer used a fixed scattering angle \
\[Theta] and measured the change in signal on a detector as a function of the \
accelerating voltage applied to the electrons. Recall that when electrons are \
passed through a potential of ",
 StyleBox["V  ",
  FontSlant->"Italic"],
 "volts, they are accelerated to a kinetic energy"
}], "Text",
 CellChangeTimes->{{3.8081431521664057`*^9, 3.8081431973268175`*^9}, {
  3.8081433307417297`*^9, 3.808143378802741*^9}, {3.808143464901264*^9, 
  3.80814347960721*^9}, {3.808143516162315*^9, 3.808143564793917*^9}, {
  3.8081435948430586`*^9, 
  3.808143601247196*^9}},ExpressionUUID->"5d561174-e360-43ce-9d41-\
34a9074ce72f"],

Cell[BoxData[
 RowBox[{
  StyleBox["E",
   FontSlant->"Italic"], 
  StyleBox["=",
   FontSlant->"Plain"], 
  StyleBox["eV",
   FontSlant->"Italic"]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8081435728592777`*^9, 
  3.8081435902898264`*^9}},ExpressionUUID->"4272b24c-6744-4a22-97e7-\
aa10c2b1f4b9"],

Cell[TextData[{
 "where ",
 StyleBox["e",
  FontSlant->"Italic"],
 " is the charge of an electron = 1.602 \[Times] ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["10", 
    RowBox[{"-", "19"}]], TraditionalForm]],ExpressionUUID->
  "00de3e52-3c55-49e2-8614-e3fcbf0eb9cc"],
 " C. Recall also that"
}], "Text",
 CellChangeTimes->{{3.808143665672464*^9, 3.8081436798006153`*^9}, {
  3.80814372040816*^9, 
  3.808143752328949*^9}},ExpressionUUID->"6329628c-60a1-4641-8025-\
00e1ccd73455"],

Cell[BoxData[
 RowBox[{
  StyleBox["E",
   FontSlant->"Italic"], 
  StyleBox["=",
   FontSlant->"Plain"], 
  FractionBox[
   SuperscriptBox[
    StyleBox["p",
     FontSlant->"Italic"], "2"], 
   RowBox[{"2", 
    StyleBox["m",
     FontSlant->"Italic"]}]]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8081435728592777`*^9, 3.8081435902898264`*^9}, {
  3.8081438077998157`*^9, 
  3.8081438142011747`*^9}},ExpressionUUID->"23c77d0a-a6c3-47bc-85a3-\
cf28cdaeea99"],

Cell[TextData[{
 "and that the mass of the electron is 9.109 \[Times] ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["10", 
    RowBox[{"-", "31"}]], TraditionalForm]],ExpressionUUID->
  "c7b4b03d-83d6-4d05-8096-c8838292ac99"],
 " kg."
}], "Text",
 CellChangeTimes->{{3.808143841978744*^9, 
  3.808143875866624*^9}},ExpressionUUID->"20b64452-41df-4e17-8ccb-\
e4c5c9235a2f"],

