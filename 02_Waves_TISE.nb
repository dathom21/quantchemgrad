      StyleBox["t",
       FontSlant->"Italic"], "2"]}]]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.807618646865757*^9, 3.807618686066933*^9}, {
  3.80763181860414*^9, 
  3.807631948535787*^9}},ExpressionUUID->"ed71104f-02fb-4a77-ab61-\
46c46cdffb0d"],

Cell["\<\
Once again, we will solve this equation by separation of variables,\
\>", "Text",
 CellChangeTimes->{{3.807618710973903*^9, 3.8076187576530156`*^9}, {
   3.807631997385412*^9, 3.807632052912342*^9}, {3.8076320840808015`*^9, 
   3.8076321111314836`*^9}, {3.807632239402089*^9, 3.807632263596979*^9}, {
   3.8076324553616724`*^9, 3.8076325666579638`*^9}, {3.8076326844713645`*^9, 
   3.8076327043391066`*^9}, {3.807632917044757*^9, 3.807632917174731*^9}, 
   3.8076334431757746`*^9, {3.8076335045253*^9, 3.8076335270680933`*^9}, {
   3.807868772618793*^9, 3.807868773551629*^9}, {3.8078688108952384`*^9, 
   3.807868811837223*^9}, 3.807965108575303*^9, {3.8079651461418834`*^9, 
   3.8079651908772573`*^9}, {3.807965222145812*^9, 3.8079652295126295`*^9}, {
   3.807965407081875*^9, 3.8079654251715217`*^9}, {3.808738541941357*^9, 
   3.808738542490629*^9}, {3.9146668491104703`*^9, 3.9146668584463263`*^9}, {
   3.9146669057911005`*^9, 
   3.9146669723365726`*^9}},ExpressionUUID->"57d90033-e90b-4fb4-995b-\
3f0aba9a84fb"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   SubscriptBox[
    StyleBox["u",
     FontSlant->"Italic"], 
    StyleBox["n",
     FontSlant->"Italic"]], 
   RowBox[{"(", 
    RowBox[{
     StyleBox["x",
      FontSlant->"Italic"], ",", 
     StyleBox["t",
      FontSlant->"Italic"]}], ")"}]}], "=", 
  RowBox[{"\[Psi]", 
   RowBox[{"(", 
    StyleBox["x",
     FontSlant->"Italic"], 
    StyleBox[")",
     FontSlant->"Italic"]}], 
   StyleBox["f",
    FontSlant->"Italic"], 
   StyleBox[
    RowBox[{"(", "t", ")"}],
    FontSlant->"Italic"]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.807965443585963*^9, 3.807965488768612*^9}, {
  3.8079655243782053`*^9, 
  3.8079655458139277`*^9}},ExpressionUUID->"efb8a3d1-c892-427f-a8d9-\
6b10164ecd22"],

Cell["\<\
only we are using slight different names for the time- and position-dependent \
components.\
\>", "Text",
 CellChangeTimes->{{3.8079654953478327`*^9, 3.8079655127978373`*^9}, {
  3.80796556909659*^9, 3.8079655952166634`*^9}, {3.9146669409910116`*^9, 
  3.9146669883222017`*^9}},ExpressionUUID->"80b5ae88-dd4a-4ff9-99a9-\
8c27e93c6809"],

Cell["\<\
In the case of our vibrating string, we saw that our solution took the form\
\>", "Text",
 CellChangeTimes->{{3.8079656002317615`*^9, 3.8079656148433905`*^9}, {
  3.8087385302487764`*^9, 
  3.808738531796245*^9}},ExpressionUUID->"75f61438-85b8-4f42-bf07-\
1b101fdd7873"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{
     SubscriptBox[
      StyleBox["u",
       FontSlant->"Italic"], 
      StyleBox["n",
       FontSlant->"Italic"]], 
     RowBox[{"(", 
      RowBox[{
       StyleBox["x",
        FontSlant->"Italic"], ",", 
       StyleBox["t",
        FontSlant->"Italic"]}], ")"}]}], "=", 
    RowBox[{
     SubscriptBox[
      StyleBox["A",
       FontSlant->"Italic"], 
      StyleBox["n",
       FontSlant->"Italic"]], 
     FormBox[
      RowBox[{"cos", "(", 
       RowBox[{
        RowBox[{
         SubscriptBox["\[Omega]", 
          StyleBox["n",
           FontSlant->"Italic"]], 
         StyleBox["t",
          FontSlant->"Italic"]}], "+", 
        SubscriptBox["\[Phi]", "n"]}]}],
      TraditionalForm]}]}], ")"}], "sin", 
  RowBox[{"(", 
   StyleBox[
    FractionBox[
     StyleBox[
      RowBox[{
       StyleBox["n",
        FontSlant->"Italic"], "\[Pi]", 
       StyleBox["x",
        FontSlant->"Italic"]}]], 
     StyleBox["L",
      FontSlant->"Italic"]],
    FontSlant->"Italic"], ")"}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8076325744477515`*^9, 3.8076326256098537`*^9}, {
   3.807632707363511*^9, 3.807632710811061*^9}, {3.807632765024428*^9, 
   3.8076327665378156`*^9}, 
   3.8079652325008793`*^9},ExpressionUUID->"7e9a45e9-eee0-4217-8896-\
55f59eedaecf"],

Cell[TextData[{
 "Let\[CloseCurlyQuote]s for a moment neglect the phase factor ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Phi]", "n"], TraditionalForm]],
  CellChangeTimes->{{3.8076325744477515`*^9, 3.8076326256098537`*^9}, {
    3.807632707363511*^9, 3.807632710811061*^9}, {3.807632765024428*^9, 
    3.8076327665378156`*^9}, 3.8079652325008793`*^9},ExpressionUUID->
  "ebfd830e-8921-417c-b86d-20f4b81f6ad2"],
 " and amplitude ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["A",
    FontSlant->"Italic"], 
   StyleBox["n",
    FontSlant->"Italic"]]],
  CellChangeTimes->{{3.8076325744477515`*^9, 3.8076326256098537`*^9}, {
    3.807632707363511*^9, 3.807632710811061*^9}, {3.807632765024428*^9, 
    3.8076327665378156`*^9}, 3.8079652325008793`*^9},ExpressionUUID->
  "ba1b66c7-c649-45d3-aeab-1ea632d5482a"],
 ". These just shift the wave around in time and change the \
\[OpenCurlyDoubleQuote]height\[CloseCurlyDoubleQuote] of the wave, so we won\
\[CloseCurlyQuote]t be concerned with them at the moment. Let\
\[CloseCurlyQuote]s also call the position-dependent portion \[Psi](",
 StyleBox["x ",
  FontSlant->"Italic"],
 "). Then our solution looks like"
}], "Text",
 CellChangeTimes->{{3.807965257716442*^9, 3.8079653915428114`*^9}, {
  3.8079656285155535`*^9, 3.807965640306798*^9}, {3.9146670247818894`*^9, 
  3.914667052628105*^9}},ExpressionUUID->"7063c74e-35ea-4cad-9c2b-\
ade400353c8d"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    StyleBox["u",
     FontSlant->"Italic"], 
    RowBox[{"(", 
     RowBox[{
      StyleBox["x",
       FontSlant->"Italic"], ",", 
      StyleBox["t",
       FontSlant->"Italic"]}], ")"}]}], "=", 
   FormBox[
    RowBox[{
     RowBox[{"\[Psi]", "(", 
      StyleBox["x",
       FontSlant->"Italic"], 
      StyleBox[")",
       FontSlant->"Italic"]}], 
     RowBox[{"cos", "(", 
      StyleBox[
       RowBox[{"\[Omega]", 
        StyleBox["t",
         FontSlant->"Italic"]}]]}]}],
    TraditionalForm]}], ")"}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8079656510386505`*^9, 
  3.807965695215381*^9}},ExpressionUUID->"64d1a0bf-f175-4009-9ba9-\
a525089dfdea"],

Cell["\<\
This is a more general solution (not just for the vibrating string), which \
shows a position function coupled with some oscillatory motion in time with \
an angular frequency of \[Omega]. This is a slightly more specific version of \
the general solutions we found earlier in the lesson, which took the form\
\>", "Text",
 CellChangeTimes->{{3.807965716182333*^9, 3.8079658257280064`*^9}, {
  3.808738576844811*^9, 3.808738583931141*^9}, {3.9146670866658444`*^9, 
  3.914667087557344*^9}},ExpressionUUID->"d7e7158a-bb82-4828-a35e-\
4b45e9558cdf"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   StyleBox["f",
    FontSlant->"Italic"], 
   RowBox[{"(", 
    StyleBox["t",
     FontSlant->"Italic"], 
    StyleBox[")",
     FontSlant->"Italic"]}]}], "=", 
  RowBox[{
   RowBox[{
    SubscriptBox[
     StyleBox["c",
      FontSlant->"Italic"], "1"], 
    SuperscriptBox["\[ExponentialE]", 
     StyleBox[
      RowBox[{
       StyleBox["\[ImaginaryI]",
        FontSlant->"Plain"], 
       StyleBox["kt",
        FontSlant->"Italic"]}]]]}], "+", 
   RowBox[{
    SubscriptBox[
     StyleBox["c",
      FontSlant->"Italic"], "2"], 
    SuperscriptBox["\[ExponentialE]", 
     RowBox[{
      StyleBox["-",
       FontSlant->"Italic"], 
      StyleBox[
       RowBox[{
        StyleBox["\[ImaginaryI]",
         FontSlant->"Plain"], 
        StyleBox["kt",
         FontSlant->"Italic"]}]]}]]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{
  3.8079658724819946`*^9, {3.808738740637146*^9, 3.8087387475945406`*^9}, {
   3.914667104218416*^9, 
   3.9146671248634553`*^9}},ExpressionUUID->"6af9b62f-045d-4f7d-8f6d-\
87d617907144"],

Cell["\<\
you can see the relationship between equation (42) and equation (43) if you \
remember that\
\>", "Text",
 CellChangeTimes->{{3.8087386500682764`*^9, 3.808738666690608*^9}, {
  3.914667140544881*^9, 
  3.9146671435014815`*^9}},ExpressionUUID->"da4b1a18-d10c-4eb9-9200-\
af12d84fa98e"],

Cell[BoxData[
 RowBox[{
  RowBox[{"cos", 
   RowBox[{"(", 
    StyleBox["kt",
     FontSlant->"Italic"], ")"}]}], "=", 
  FractionBox[
   RowBox[{
    SuperscriptBox["\[ExponentialE]", 
     StyleBox[
      RowBox[{
       StyleBox["\[ImaginaryI]",
        FontSlant->"Plain"], 
       StyleBox["kt",
        FontSlant->"Italic"]}]]], "+", 
    SuperscriptBox["\[ExponentialE]", 
     RowBox[{
      StyleBox["-",
       FontSlant->"Italic"], 
      StyleBox[
       RowBox[{
        StyleBox["\[ImaginaryI]",
         FontSlant->"Plain"], 
        StyleBox["kt",
         FontSlant->"Italic"]}]]}]]}], "2"]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8081500254077106`*^9, 3.8081500761579385`*^9}, {
  3.8087386997138677`*^9, 3.808738722067994*^9}, {3.808738755207317*^9, 
  3.808738760534052*^9}, {3.9146672173832645`*^9, 
  3.914667220877658*^9}},ExpressionUUID->"dcf88520-e4cd-4011-a31e-\
0bf231a9d256"],

Cell["If we plug equation (42) into equation (39), we get", "Text",
 CellChangeTimes->{{3.8079659236496797`*^9, 3.807965933366115*^9}, {
  3.9146672902658243`*^9, 
  3.9146673074555297`*^9}},ExpressionUUID->"fd831b51-12e2-4913-92c3-\
7573ed21bf30"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    FormBox[
     RowBox[{"cos", "(", 
      StyleBox[
       RowBox[{"\[Omega]", 
        StyleBox["t",
         FontSlant->"Italic"]}]]}],
     TraditionalForm], ")"}], 
   FractionBox[
    RowBox[{
     RowBox[{
      SuperscriptBox["\[DifferentialD]", "2"], "\[Psi]"}], 
     RowBox[{"(", 
      StyleBox["x",
       FontSlant->"Italic"], 
      StyleBox[")",
       FontSlant->"Italic"]}]}], 
    RowBox[{"\[DifferentialD]", 
     SuperscriptBox[
      StyleBox["x",
       FontSlant->"Italic"], "2"]}]]}], "=", 
  RowBox[{"\[Psi]", 
   RowBox[{"(", 
    StyleBox["x",
     FontSlant->"Italic"], 
    StyleBox[")",
     FontSlant->"Italic"]}], 
   FractionBox["1", 
    SuperscriptBox[
     StyleBox["v",
      FontSlant->"Italic"], "2"]], 
   FractionBox[
    RowBox[{
     SuperscriptBox["\[DifferentialD]", "2"], 
     FormBox[
      RowBox[{"cos", "(", 
       StyleBox[
        RowBox[{"\[Omega]", 
         StyleBox["t",
          FontSlant->"Italic"]}]], ")"}],
      TraditionalForm]}], 
    RowBox[{"\[DifferentialD]", 
     SuperscriptBox[
      StyleBox["t",
       FontSlant->"Italic"], "2"]}]]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{
  3.807965945197339*^9, {3.8079659862349358`*^9, 3.8079660937383137`*^9}, {
   3.8079661517230787`*^9, 3.807966184809126*^9}, {3.87232628814742*^9, 
   3.8723263107303505`*^9}, {3.914667338837025*^9, 
   3.914667389953338*^9}},ExpressionUUID->"5f0964b7-abce-4439-a4a7-\
fb69a1c1fb24"],

Cell[TextData[{
 "if we evaluate the second derivative of cos( \[Omega]",
 StyleBox["t ",
  FontSlant->"Italic"],
 "), we end up with"
}], "Text",
 CellChangeTimes->{{3.80796611741973*^9, 3.8079661420176387`*^9}, {
   3.807966292015715*^9, 3.8079663056179237`*^9}, 3.807966404356369*^9, 
   3.807966566049746*^9},ExpressionUUID->"c8159e9b-aee0-4287-8fd8-\
f14b1a7a8ba8"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    FormBox[
     RowBox[{"cos", "(", 
      StyleBox[
       RowBox[{"\[Omega]", 
        StyleBox["t",
         FontSlant->"Italic"]}]]}],
     TraditionalForm], ")"}], 
   FractionBox[
    RowBox[{
     RowBox[{
      SuperscriptBox["\[DifferentialD]", "2"], "\[Psi]"}], 
     RowBox[{"(", 
      StyleBox["x",
       FontSlant->"Italic"], 
      StyleBox[")",
       FontSlant->"Italic"]}]}], 
    RowBox[{"\[DifferentialD]", 
     SuperscriptBox[
      StyleBox["x",
       FontSlant->"Italic"], "2"]}]]}], "=", 
  RowBox[{"\[Psi]", 
   RowBox[{"(", 
    StyleBox["x",
     FontSlant->"Italic"], 
    StyleBox[")",
     FontSlant->"Italic"]}], 
   FractionBox[
    RowBox[{"-", 
     SuperscriptBox["\[Omega]", "2"]}], 
    SuperscriptBox[
     StyleBox["v",
      FontSlant->"Italic"], "2"]], 
   FormBox[
    RowBox[{"cos", "(", 
     StyleBox[
      RowBox[{"\[Omega]", 
       StyleBox["t",
        FontSlant->"Italic"]}]], ")"}],
    TraditionalForm]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8079663122051888`*^9, 3.807966345386142*^9}, {
  3.872326321442992*^9, 
  3.872326323450517*^9}},ExpressionUUID->"ff0fccf6-ee64-4e4f-88a9-\
c127015667bd"],

Cell[TextData[{
 "dividing both sides by cos( \[Omega]",
 StyleBox["t ",
  FontSlant->"Italic"],
 ") gives"
}], "Text",
 CellChangeTimes->{{3.8079663798673882`*^9, 3.8079664115632343`*^9}, 
   3.8079665640638757`*^9},ExpressionUUID->"2586c7d4-654b-4364-a0b8-\
f87fb14828c9"],

Cell[BoxData[
 RowBox[{
  FractionBox[
   RowBox[{
    RowBox[{
     SuperscriptBox["\[DifferentialD]", "2"], "\[Psi]"}], 
    RowBox[{"(", 
     StyleBox["x",
      FontSlant->"Italic"], 
     StyleBox[")",
      FontSlant->"Italic"]}]}], 
   RowBox[{"\[DifferentialD]", 
    SuperscriptBox[
     StyleBox["x",
      FontSlant->"Italic"], "2"]}]], "=", 
  RowBox[{
   FractionBox[
    RowBox[{"-", 
     SuperscriptBox["\[Omega]", "2"]}], 
    SuperscriptBox[
     StyleBox["v",
      FontSlant->"Italic"], "2"]], "\[Psi]", 
   RowBox[{"(", 
    StyleBox["x",
     FontSlant->"Italic"], 
    StyleBox[")",
     FontSlant->"Italic"]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8079664251944246`*^9, 3.8079664343142004`*^9}, {
  3.8723263299620943`*^9, 
  3.8723263319628325`*^9}},ExpressionUUID->"85bb3ed8-5163-4fb5-8663-\
72fb857e1a52"],

Cell[TextData[{
 "Ok, so now we have something that looks a lot like our position-dependent \
wave equation (12). We\[CloseCurlyQuote]ve kept the velocity ",
 StyleBox["v",
  FontSlant->"Italic"],
 " now in the position dependence instead of the time dependence because, as \
you will see, we\[CloseCurlyQuote]re going to relate it back to the wave \
nature of matter."
}], "Text",
 CellChangeTimes->{{3.807966495122385*^9, 3.8079666589105453`*^9}, {
   3.8079667359714127`*^9, 3.8079667468491697`*^9}, {3.8079671472877836`*^9, 
   3.807967240353474*^9}, 3.807968019911407*^9, {3.9146674392041006`*^9, 
   3.9146674992200212`*^9}},ExpressionUUID->"6ed41888-68ce-43c7-bdc7-\
13fb5ab56f84"],

Cell[TextData[{
 "We want \[Psi]( ",
 StyleBox["x ",
  FontSlant->"Italic"],
 ") to represent a ",
 StyleBox["matter",
  FontSlant->"Italic"],
 " wave, so we can use some equations we already know to describe matter. \
First, let\[CloseCurlyQuote]s recall that de Broglie\[CloseCurlyQuote]s \
equation tells us that the wavelength of matter \[Lambda] is given by "
}], "Text",
 CellChangeTimes->{{3.807967278970354*^9, 3.807967333300232*^9}, {
  3.8079676241786056`*^9, 3.807967627649619*^9}, {3.8079676620369196`*^9, 
  3.807967668803046*^9}, {3.807968044116542*^9, 3.8079680524098277`*^9}, {
  3.807968572184062*^9, 3.807968574157925*^9}, {3.807968641245495*^9, 
  3.8079686530387383`*^9}, {3.8079687130173807`*^9, 3.8079687405666065`*^9}, {
  3.9146674946763926`*^9, 
  3.9146675010047474`*^9}},ExpressionUUID->"1463a00d-eb97-489f-92de-\
d84607da216e"],

Cell[BoxData[
 RowBox[{"\[Lambda]", "=", 
  FractionBox[
   StyleBox["h",
    FontSlant->"Italic"], 
   StyleBox["p",
    FontSlant->"Italic"]]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{
  3.807968666807887*^9},ExpressionUUID->"f8b262d7-cd55-488c-84e0-\
b5eba6db266d"],

Cell[TextData[{
 "where ",
 StyleBox["h",
  FontSlant->"Italic"],
 " is Planck\[CloseCurlyQuote]s constant and ",
 StyleBox["p",
  FontSlant->"Italic"],
 " is the momentum. Now, if we have a wavelength, then we also have a wave \
frequency \[Nu], and the product of the two gives us something called the \
phase velocity ",
 StyleBox["v",
  FontSlant->"Italic"],
 ". "
}], "Text",
 CellChangeTimes->{{3.8079686710784054`*^9, 3.8079687089907227`*^9}, {
  3.807968745936524*^9, 
  3.8079688351164427`*^9}},ExpressionUUID->"c4a0b09a-e145-4a08-998a-\
8827a6d620fc"],

Cell[BoxData[
 RowBox[{"\[Nu]\[Lambda]", "=", 
  StyleBox["v",
   FontSlant->"Italic"]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.807967353846463*^9, 
  3.8079673698742805`*^9}},ExpressionUUID->"8a8c1084-2408-482a-9776-\
9564341e1483"],

Cell["\<\
This is different from a typical velocity in classical mechanics, but for now \
we won\[CloseCurlyQuote]t discuss it. We\[CloseCurlyQuote]ll be using this \
velocity in our quantum mechanical wave equation.\
\>", "Text",
 CellChangeTimes->{{3.807968838275627*^9, 3.8079688644906187`*^9}, {
  3.9146675351239014`*^9, 
  3.9146675359971533`*^9}},ExpressionUUID->"771c5391-4bcf-4461-9a5b-\
07e178f9b6be"],

Cell[TextData[{
 "Next, we must recall that the relationship between frequency \[Nu]",
 StyleBox[" ",
  FontSlant->"Italic"],
 "and angular frequency \[Omega] is given by"
}], "Text",
 CellChangeTimes->{{3.8079673797806435`*^9, 3.8079673947400446`*^9}, {
  3.8079676359808455`*^9, 3.8079677353359404`*^9}, {3.8079688711308064`*^9, 
  3.8079688868538065`*^9}},ExpressionUUID->"73c47115-077a-44ca-bbb0-\
25253e4c89d6"],

Cell[BoxData[
 RowBox[{"\[Omega]", "=", 
  RowBox[{"2", "\[Pi]\[Nu]"}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8079677410246754`*^9, 
  3.807967752196278*^9}},ExpressionUUID->"43e39fd4-0395-47e8-9425-\
03b196e604bc"],

Cell[TextData[{
 "A quick note about angular frequency - the typical units of angular \
frequency are radians per second (rad ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    StyleBox["s",
     FontSlant->"Plain"], 
    RowBox[{"\[Minus]", "1"}]], TraditionalForm]],ExpressionUUID->
  "e08f1330-1c6c-4c9b-a605-1660c26a4b03"],
 "), but in the SI unit system we don\[CloseCurlyQuote]t write the radians \
part. This omission leads to a lot of confusion about angular frequency (rad ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    StyleBox["s",
     FontSlant->"Plain"], 
    RowBox[{"\[Minus]", "1"}]], TraditionalForm]],ExpressionUUID->
  "766ed7f5-27eb-404d-b354-5f7d130f18db"],
 ") vs. frequency (Hz or ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    StyleBox["s",
     FontSlant->"Plain"], 
    RowBox[{"\[Minus]", "1"}]], TraditionalForm]],ExpressionUUID->
  "82dae7bd-8a4d-4699-a0f0-d58506536f21"],
 "). There\[CloseCurlyQuote]s not much you can do about this convention; just \
remember to think about what units someone is working with when you see the \
unit  ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    StyleBox["s",
     FontSlant->"Plain"], 
    RowBox[{"\[Minus]", "1"}]], TraditionalForm]],ExpressionUUID->
  "d935e920-c87e-4d87-84d3-faa02434a100"],
 "."
}], "Text",
 CellChangeTimes->{{3.808739064198162*^9, 
  3.8087392295155563`*^9}},ExpressionUUID->"1f42d81e-8251-4e05-b875-\
65d58b9b9ae9"],

Cell["Returning to equation (47), we can use the substitutions", "Text",
 CellChangeTimes->{{3.807967800200265*^9, 3.807967835435089*^9}, {
  3.80883271059673*^9, 3.808832710834688*^9}, {3.9146675658979025`*^9, 
  3.9146675728037877`*^9}},ExpressionUUID->"4ef147c5-4852-459c-a663-\
55b2f8942d89"],

Cell[BoxData[
 RowBox[{
  SuperscriptBox["\[Omega]", "2"], "=", 
  RowBox[{"4", 
   SuperscriptBox["\[Pi]", "2"], 
   SuperscriptBox["\[Nu]", "2"]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.807967843711341*^9, 
  3.807967856481063*^9}},ExpressionUUID->"5c29a681-6b4b-41b9-80e8-\
bac29894b865"],

Cell["and", "Text",
 CellChangeTimes->{{3.807967858938618*^9, 
  3.8079678616150866`*^9}},ExpressionUUID->"a6f8ad92-50cb-4913-af78-\
3a41e4717855"],

Cell[BoxData[
 RowBox[{
  SuperscriptBox[
   StyleBox["v",
    FontSlant->"Italic"], "2"], "=", 
  RowBox[{
   SuperscriptBox["\[Nu]", "2"], 
   SuperscriptBox["\[Lambda]", "2"]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8079678744297447`*^9, 
  3.807967893471835*^9}},ExpressionUUID->"f1339f64-7fc7-4645-9f6a-\
3ffab22da30d"],

Cell["to obtain", "Text",
 CellChangeTimes->{{3.8079679081594305`*^9, 
  3.8079679117883425`*^9}},ExpressionUUID->"7c9e2b22-0618-4af5-b300-\
814ea2977a46"],

Cell[BoxData[
 RowBox[{
  FractionBox[
   RowBox[{
    RowBox[{
     SuperscriptBox["\[DifferentialD]", "2"], "\[Psi]"}], 
    RowBox[{"(", 
     StyleBox["x",
      FontSlant->"Italic"], 
     StyleBox[")",
      FontSlant->"Italic"]}]}], 
   RowBox[{"\[DifferentialD]", 
    SuperscriptBox[
     StyleBox["x",
      FontSlant->"Italic"], "2"]}]], "=", 
  RowBox[{
   FractionBox[
    RowBox[{
     RowBox[{"-", "4"}], 
     SuperscriptBox["\[Pi]", "2"]}], 
    SuperscriptBox["\[Lambda]", "2"]], "\[Psi]", 
   RowBox[{"(", 
    StyleBox["x",
     FontSlant->"Italic"], 
    StyleBox[")",
     FontSlant->"Italic"]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8079664251944246`*^9, 3.8079664343142004`*^9}, {
  3.8079689400739555`*^9, 3.8079689680029573`*^9}, {3.872326471753763*^9, 
  3.872326481273816*^9}},ExpressionUUID->"7500e21d-554d-4528-9a3b-\
e1eab7d499df"],

Cell[TextData[{
 "That might not seem to have gotten us very far, but now we are ready to \
make some other substitutions using the properties of matter waves. First \
off, we know that the total energy ",
 StyleBox["E ",
  FontSlant->"Italic"],
 "is a sum of the kinetic and potential energies,"
}], "Text",
 CellChangeTimes->{
  3.8079680232135143`*^9, {3.807969089467378*^9, 3.807969123834692*^9}, {
   3.8079692737638073`*^9, 3.8079692767480965`*^9}, {3.807969737013442*^9, 
   3.8079697429960146`*^9}},ExpressionUUID->"c6ae3546-ba4c-44d9-8396-\
c3a6654bcfbd"],

Cell[BoxData[
 RowBox[{
  StyleBox["E",
   FontSlant->"Italic"], 
  StyleBox["=",
   FontSlant->"Plain"], " ", 
  RowBox[{
   FractionBox[
    SuperscriptBox[
     StyleBox["p",
      FontSlant->"Italic"], "2"], 
    RowBox[{"2", 
     StyleBox["m",
      FontSlant->"Italic"]}]], "+", 
   RowBox[{
    StyleBox["V",
     FontSlant->"Italic"], 
    RowBox[{"(", 
     StyleBox["x",
      FontSlant->"Italic"], ")"}]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8079666692896004`*^9, 
  3.80796671056999*^9}},ExpressionUUID->"55aaa230-75fd-43e2-adb0-\
1bd96b6f24b1"],

Cell[TextData[{
 "where ",
 StyleBox["p",
  FontSlant->"Italic"],
 " is the momentum, ",
 StyleBox["m",
  FontSlant->"Italic"],
 " is the mass, and ",
 StyleBox["V ",
  FontSlant->"Italic"],
 "( ",
 StyleBox["x",
  FontSlant->"Italic"],
 " ) is the position-dependent potential function. Solving for ",
 StyleBox["p",
  FontSlant->"Italic"],
 ", we obtain"
}], "Text",
 CellChangeTimes->{{3.807966749118871*^9, 
  3.807966804383221*^9}},ExpressionUUID->"9a7f549f-a425-48c8-98f0-\
87c079518e20"],

Cell[BoxData[
 RowBox[{
  StyleBox["p",
   FontSlant->"Italic"], 
  StyleBox["=",
   FontSlant->"Plain"], 
  SuperscriptBox[
   RowBox[{
    StyleBox["{",
     FontSlant->"Plain"], 
    RowBox[{
     StyleBox["2",
      FontSlant->"Plain"], 
     RowBox[{
      StyleBox["m",
       FontSlant->"Italic"], 
      StyleBox["[",
       FontSlant->"Italic"], 
      RowBox[{
       StyleBox["E",
        FontSlant->"Italic"], 
       StyleBox["-",
        FontSlant->"Plain"], 
       StyleBox[
        RowBox[{"V", 
         RowBox[{"(", "x", ")"}]}],
        FontSlant->"Italic"]}], 
      StyleBox["]",
       FontSlant->"Italic"]}]}], 
    StyleBox["}",
     FontSlant->"Plain"]}], 
   RowBox[{"1", "/", "2"}]]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.80796681875698*^9, 
  3.8079669182829685`*^9}},ExpressionUUID->"4738f79c-6040-4686-9333-\
c1532ab031cb"],

Cell[TextData[{
 "next, we come back to the de Broglie equation and substitute for ",
 StyleBox["p",
  FontSlant->"Italic"]
}], "Text",
 CellChangeTimes->{{3.8079669248861856`*^9, 3.8079669954287806`*^9}, {
  3.8079670686328497`*^9, 3.807967085986938*^9}, {3.807970083735828*^9, 
  3.807970099922555*^9}},ExpressionUUID->"d97023b3-7012-426c-9297-\
9cd060d4ac3d"],

Cell[BoxData[
 RowBox[{"\[Lambda]", "=", 
  RowBox[{
   FractionBox[
    StyleBox["h",
     FontSlant->"Italic"], 
    StyleBox["p",
     FontSlant->"Italic"]], "=", 
   FractionBox[
    StyleBox["h",
     FontSlant->"Italic"], 
    SuperscriptBox[
     RowBox[{
      StyleBox["{",
       FontSlant->"Plain"], 
      RowBox[{
       StyleBox["2",
        FontSlant->"Plain"], 
       RowBox[{
        StyleBox["m",
         FontSlant->"Italic"], 
        StyleBox["[",
         FontSlant->"Italic"], 
        RowBox[{
         StyleBox["E",
          FontSlant->"Italic"], 
         StyleBox["-",
          FontSlant->"Plain"], 
         StyleBox[
          RowBox[{"V", 
           RowBox[{"(", "x", ")"}]}],
          FontSlant->"Italic"]}], 
        StyleBox["]",
         FontSlant->"Italic"]}]}], 
      StyleBox["}",
       FontSlant->"Plain"]}], 
     RowBox[{"1", "/", "2"}]]]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8079670027835636`*^9, 3.8079670544309893`*^9}, {
  3.8079670905572824`*^9, 
  3.8079670958822327`*^9}},ExpressionUUID->"19131383-a106-493c-a8a4-\
ac38464a9f6d"],

Cell["\<\
finally, we can now substitute for \[Lambda] in equation (53) and obtain\
\>", "Text",
 CellChangeTimes->{{3.8079701101586914`*^9, 3.8079701252130685`*^9}, {
  3.8088328433602085`*^9, 3.8088328434944296`*^9}, {3.914667629166958*^9, 
  3.914667629676222*^9}},ExpressionUUID->"a663e4de-d1b1-48e7-8a7f-\
ebbffdf9e820"],

Cell[BoxData[
 RowBox[{
  FractionBox[
   RowBox[{
    RowBox[{
     SuperscriptBox["\[DifferentialD]", "2"], "\[Psi]"}], 
    RowBox[{"(", 
     StyleBox["x",
      FontSlant->"Italic"], 
     StyleBox[")",
      FontSlant->"Italic"]}]}], 
   RowBox[{"\[DifferentialD]", 
    SuperscriptBox[
     StyleBox["x",
      FontSlant->"Italic"], "2"]}]], "=", 
  RowBox[{
   FractionBox[
    RowBox[{
     RowBox[{"-", "4"}], 
     SuperscriptBox["\[Pi]", "2"], 
     StyleBox["2",
      FontSlant->"Plain"], 
     RowBox[{
      StyleBox["m",
       FontSlant->"Italic"], 
      StyleBox["[",
       FontSlant->"Italic"], 
      RowBox[{
       StyleBox["E",
        FontSlant->"Italic"], 
       StyleBox["-",
        FontSlant->"Plain"], 
       StyleBox[
        RowBox[{"V", 
         RowBox[{"(", "x", ")"}]}],
        FontSlant->"Italic"]}], 
      StyleBox["]",
       FontSlant->"Italic"]}]}], 
    SuperscriptBox[
     StyleBox["h",
      FontSlant->"Italic"], "2"]], "\[Psi]", 
   RowBox[{"(", 
    StyleBox["x",
     FontSlant->"Italic"], 
    StyleBox[")",
     FontSlant->"Italic"]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8079664251944246`*^9, 3.8079664343142004`*^9}, {
   3.8079689400739555`*^9, 3.8079689680029573`*^9}, {3.807970315263204*^9, 
   3.8079703215316095`*^9}, 
   3.9146682352991986`*^9},ExpressionUUID->"2bf9dba5-ccd3-4d73-82e3-\
3b1a2c3c6790"],

Cell[TextData[{
 "using \[HBar] = ",
 StyleBox["h/2\[Pi]  ",
  FontSlant->"Italic"],
 "and moving all terms to the right side of the equation, we get"
}], "Text",
 CellChangeTimes->{{3.8079703313909826`*^9, 3.807970404818901*^9}, {
   3.8093460805261793`*^9, 3.809346082470167*^9}, 
   3.914668156985833*^9},ExpressionUUID->"76f67aea-ad63-4061-b1e6-\
831530d90319"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   FractionBox[
    RowBox[{
     RowBox[{
      SuperscriptBox["\[DifferentialD]", "2"], "\[Psi]"}], 
     RowBox[{"(", 
      StyleBox["x",
       FontSlant->"Italic"], 
      StyleBox[")",
       FontSlant->"Italic"]}]}], 
    RowBox[{"\[DifferentialD]", 
     SuperscriptBox[
      StyleBox["x",
       FontSlant->"Italic"], "2"]}]], "+", 
   RowBox[{
    FractionBox[
     RowBox[{
      StyleBox["2",
       FontSlant->"Plain"], 
      RowBox[{
       StyleBox["m",
        FontSlant->"Italic"], 
       StyleBox["[",
        FontSlant->"Italic"], 
       RowBox[{
        StyleBox["E",
         FontSlant->"Italic"], 
        StyleBox["-",
         FontSlant->"Plain"], 
        StyleBox[
         RowBox[{"V", 
          RowBox[{"(", "x", ")"}]}],
         FontSlant->"Italic"]}], 
       StyleBox["]",
        FontSlant->"Italic"]}]}], 
     SuperscriptBox["\[HBar]", "2"]], "\[Psi]", 
    RowBox[{"(", 
     StyleBox["x",
      FontSlant->"Italic"], 
     StyleBox[")",
      FontSlant->"Italic"]}]}]}], "=", "0"}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8079664251944246`*^9, 3.8079664343142004`*^9}, {
   3.8079689400739555`*^9, 3.8079689680029573`*^9}, {3.807970315263204*^9, 
   3.8079703215316095`*^9}, {3.807970415909548*^9, 3.807970437015459*^9}, 
   3.91466823867271*^9},ExpressionUUID->"e64969d7-01c9-4bfe-a146-\
4515039181be"],

Cell["Typically, this equation is written in the form", "Text",
 CellChangeTimes->{{3.8079704633433747`*^9, 
  3.807970500071336*^9}},ExpressionUUID->"c72b969c-73c0-43cb-b51d-\
5418dbc1237b"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"-", 
     FractionBox[
      SuperscriptBox["\[HBar]", "2"], 
      RowBox[{"2", 
       StyleBox["m",
        FontSlant->"Italic"]}]]}], 
    FractionBox[
     RowBox[{
      RowBox[{
       SuperscriptBox["\[DifferentialD]", "2"], "\[Psi]"}], 
      RowBox[{"(", 
       StyleBox["x",
        FontSlant->"Italic"], 
       StyleBox[")",
        FontSlant->"Italic"]}]}], 
     RowBox[{"\[DifferentialD]", 
      SuperscriptBox[
       StyleBox["x",
        FontSlant->"Italic"], "2"]}]]}], "+", 
   RowBox[{
    StyleBox["V",
     FontSlant->"Italic"], 
    StyleBox[
     RowBox[{"(", "x", ")"}],
     FontSlant->"Italic"], "\[Psi]", 
    RowBox[{"(", 
     StyleBox["x",
      FontSlant->"Italic"], 
     StyleBox[")",
      FontSlant->"Italic"]}]}]}], "=", 
  RowBox[{
   StyleBox["E",
    FontSlant->"Italic"], 
   StyleBox[" ",
    FontSlant->"Italic"], "\[Psi]", 
   RowBox[{"(", 
    StyleBox["x",
     FontSlant->"Italic"], 
    StyleBox[")",
     FontSlant->"Italic"]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8079664251944246`*^9, 3.8079664343142004`*^9}, {
   3.8079689400739555`*^9, 3.8079689680029573`*^9}, {3.807970315263204*^9, 
   3.8079703215316095`*^9}, {3.807970415909548*^9, 3.807970437015459*^9}, {
   3.8079705221296997`*^9, 3.8079705895237727`*^9}, 
   3.9146682418159056`*^9},ExpressionUUID->"2b45f34b-bf30-4e89-982d-\
0c09348ef4fd"],

Cell[TextData[{
 "This is the ",
 StyleBox["time-independent Schr\[ODoubleDot]dinger equation (TISE)",
  FontWeight->"Bold"],
 " in one dimension. We have now taken a classical wave equation and \
transformed it into an equation describing quantum mechanical objects \
utilizing the de Broglie equation to describe the wavelike nature of matter. \
We have a second derivative of a function (with some constants) plus a \
potential energy times a function gives us back an energy times a function. \
The function \[Psi]( ",
 StyleBox["x ",
  FontSlant->"Italic"],
 ") (or in the case of time-dependence, \[Psi]( ",
 StyleBox["x ",
  FontSlant->"Italic"],
 ", ",
 StyleBox["t ",
  FontSlant->"Italic"],
 ")) is known as the wavefunction. The wavefunction provides us with \
information about the state of a system in a very particular way, which we \
will discuss in detail in this course."
}], "Text",
 CellChangeTimes->{{3.807970621143662*^9, 3.8079706693690357`*^9}, {
  3.8079707223896666`*^9, 3.807970779109171*^9}, {3.807971171837203*^9, 
  3.807971175463128*^9}, {3.8079715308352823`*^9, 3.807971579149626*^9}, {
  3.807971708326606*^9, 3.8079717638487997`*^9}, {3.807972126376515*^9, 
  3.8079721642920213`*^9}, {3.8079777771437654`*^9, 3.8079778541276894`*^9}, {
  3.807977929974223*^9, 3.8079779995053883`*^9}, {3.9146682682133455`*^9, 
  3.914668273575676*^9}},ExpressionUUID->"fbf143a8-e073-48f3-8bec-\
655bf6e15e03"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Time Dependence", "Subsection",
 CellChangeTimes->{{3.807970822178503*^9, 
  3.8079708246560793`*^9}},ExpressionUUID->"29718ee2-3f73-4625-8683-\
eb0c0ff04e81"],

Cell["\<\
Unfortunately, the analogy of going from classical to quantum mechanical \
waves breaks down when we try to incorporate time dependence. The reasons for \
this result are complicated. In essence, the problem comes down to coupling \
between a quantum system (as described for example by the TISE) and the \
behavior of its environment that involves a classical progression in time. We \
won\[CloseCurlyQuote]t worry more about the reason in this course. The \
time-dependent Schr\[ODoubleDot]dinger equation (TDSE) in one dimension is \
written\
\>", "Text",
 CellChangeTimes->{{3.807970827865245*^9, 3.807970867877323*^9}, {
  3.80797105130025*^9, 3.807971282780407*^9}, {3.807971617340724*^9, 
  3.807971648832685*^9}},ExpressionUUID->"ce16fbc5-66bc-460e-b8d6-\
c8ba61161c94"],

Cell[BoxData[
 RowBox[{
  RowBox[{"\[ImaginaryI]\[HBar]", " ", 
   StyleBox[
    FractionBox[
     RowBox[{
      StyleBox[
       RowBox[{"\[PartialD]", "\[Psi]"}],
       FontSlant->"Plain"], 
      RowBox[{
       StyleBox["(",
        FontSlant->"Plain"], 
       RowBox[{"x", 
        StyleBox[",",
         FontSlant->"Plain"], 
        StyleBox["t",
         FontSlant->"Italic"]}], 
       StyleBox[")",
        FontSlant->"Italic"]}]}], 
     RowBox[{
      StyleBox["\[PartialD]",
       FontSlant->"Plain"], "t"}]],
    FontSlant->"Italic"]}], 
  StyleBox["=",
   FontSlant->"Plain"], 
  RowBox[{
   RowBox[{
    RowBox[{"-", 
     FractionBox[
      SuperscriptBox["\[HBar]", "2"], 
      RowBox[{"2", 
       StyleBox["m",
        FontSlant->"Italic"]}]]}], 
    FractionBox[
     RowBox[{
      RowBox[{
       SuperscriptBox["\[PartialD]", "2"], "\[Psi]"}], 
      RowBox[{"(", 
       RowBox[{
        StyleBox["x",
         FontSlant->"Italic"], 
        StyleBox[",",
         FontSlant->"Plain"], 
        StyleBox["t",
         FontSlant->"Italic"]}], 
       StyleBox[")",
        FontSlant->"Italic"]}]}], 
     RowBox[{"\[PartialD]", 
      SuperscriptBox[
       StyleBox["x",
        FontSlant->"Italic"], "2"]}]]}], "+", 
   RowBox[{
    StyleBox["V",
     FontSlant->"Italic"], 
    StyleBox[
     RowBox[{"(", "x", ")"}],
     FontSlant->"Italic"], "\[Psi]", 
    RowBox[{"(", 
     RowBox[{
      StyleBox["x",
       FontSlant->"Italic"], 
      StyleBox[",",
       FontSlant->"Plain"], 
      StyleBox["t",
       FontSlant->"Italic"]}], 
     StyleBox[")",
      FontSlant->"Italic"]}]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8079712935412436`*^9, 3.8079714900326514`*^9}, {
  3.914668279937009*^9, 
  3.914668281241682*^9}},ExpressionUUID->"ff2dc424-cc6a-4ec3-b1a4-\
62ab0aa09461"],

Cell["We\[CloseCurlyQuote]ll come back to the TDSE in the coming lessons.", \
"Text",
 CellChangeTimes->{{3.807971594868597*^9, 3.807971602276354*^9}, {
  3.8087394456685195`*^9, 
  3.8087394500776567`*^9}},ExpressionUUID->"d3ce90b4-37d2-4c9b-abe8-\
49c4e4b0afc2"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["The Schr\[ODoubleDot]dinger Equation in Three Dimensions", "Section",
 CellChangeTimes->{{3.8079721761502323`*^9, 3.8079721881813354`*^9}, {
  3.807972262887545*^9, 
  3.8079722823304043`*^9}},ExpressionUUID->"5282e055-3ba2-4345-a28d-\
206512b19c9a"],

Cell[CellGroupData[{

Cell["The Del Operator, the Gradient, and the Laplacian", "Subsection",
 CellChangeTimes->{{3.8079723935160284`*^9, 
  3.807972410077771*^9}},ExpressionUUID->"aac9912c-b4af-409f-833b-\
7610cabe1b0a"],

Cell["\<\
Before we can talk about the Schr\[ODoubleDot]dinger equation in three \
dimensions, we need to briefly review a few items of multidimensional \
calculus. \
\>", "Text",
 CellChangeTimes->{{3.807972415423707*^9, 3.8079724202379503`*^9}, {
  3.8079724965632334`*^9, 
  3.8079725362874727`*^9}},ExpressionUUID->"89956cee-8db0-41f6-9cde-\
825231c1d847"],

Cell["\<\
First up, we have the del operator, represented by the symbol \[Del]. This \
operator is used quite often in vector calculus, for example to obtain the \
curl and divergence. However, the most relevant formulation for us is the \
gradient of a function, which is given by\
\>", "Text",
 CellChangeTimes->{{3.8079725390738983`*^9, 3.8079725560401573`*^9}, {
  3.8079727475215693`*^9, 
  3.807972806160979*^9}},ExpressionUUID->"378db6cc-b4ae-42b0-8d42-\
f26e03107e13"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"\[Del]", 
    StyleBox["f",
     FontSlant->"Italic"]}], 
   RowBox[{"(", 
    RowBox[{
     StyleBox["x",
      FontSlant->"Italic"], ",", 
     StyleBox["y",
      FontSlant->"Italic"], ",", 
     StyleBox["z",
      FontSlant->"Italic"]}], ")"}]}], "=", 
  RowBox[{
   RowBox[{
    FractionBox[
     RowBox[{"\[PartialD]", 
      StyleBox["f",
       FontSlant->"Italic"]}], 
     RowBox[{"\[PartialD]", 
      StyleBox["x",
       FontSlant->"Italic"]}]], 
    OverscriptBox[
     StyleBox["x",
      FontSlant->"Italic"], "\[RightArrow]"]}], "+", 
   RowBox[{
    FractionBox[
     RowBox[{"\[PartialD]", 
      StyleBox["f",
       FontSlant->"Italic"]}], 
     RowBox[{"\[PartialD]", 
      StyleBox["y",
       FontSlant->"Italic"]}]], 
    OverscriptBox[
     StyleBox["y",
      FontSlant->"Italic"], "\[RightArrow]"]}], "+", 
   RowBox[{
    FractionBox[
     RowBox[{"\[PartialD]", 
      StyleBox["f",
       FontSlant->"Italic"]}], 
     RowBox[{"\[PartialD]", 
      StyleBox["z",
       FontSlant->"Italic"]}]], 
    OverscriptBox[
     StyleBox["z",
      FontSlant->"Italic"], "\[RightArrow]"]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8079729759567337`*^9, 3.807973017878702*^9}, {
  3.807973082521673*^9, 
  3.807973119912252*^9}},ExpressionUUID->"7e69cec2-bf9a-4fe5-a575-\
9362548cba3d"],

Cell[TextData[{
 "where ",
 Cell[BoxData[
  OverscriptBox[
   StyleBox["x",
    FontSlant->"Italic"], "\[RightArrow]"]],
  CellChangeTimes->{{3.8079729759567337`*^9, 3.807973017878702*^9}, {
   3.807973082521673*^9, 3.807973119912252*^9}},ExpressionUUID->
  "6f48027b-fa71-4739-9197-9efc13c5fb83"],
 ", ",
 Cell[BoxData[
  OverscriptBox[
   StyleBox["y",
    FontSlant->"Italic"], "\[RightArrow]"]],
  CellChangeTimes->{{3.8079729759567337`*^9, 3.807973017878702*^9}, {
   3.807973082521673*^9, 3.807973119912252*^9}},ExpressionUUID->
  "eb0359c8-4469-4f45-afe0-f2c90fc9cb6e"],
 ", and ",
 Cell[BoxData[
  OverscriptBox[
   StyleBox["z",
    FontSlant->"Italic"], "\[RightArrow]"]],
  CellChangeTimes->{{3.8079729759567337`*^9, 3.807973017878702*^9}, {
   3.807973082521673*^9, 3.807973119912252*^9}},ExpressionUUID->
  "d3062c41-8db4-4ae8-83cc-803af95a2d9e"],
 " are unit vectors. Recall that unit vectors have length 1 and point along \
the specified axis. The gradient tells you the path of steepest descent at a \
given point in a function. The vector points in the direction of steepest \
descent, and the magnitude tells you the rate of descent."
}], "Text",
 CellChangeTimes->{{3.807973126680395*^9, 3.8079731413509707`*^9}, {
   3.807973197317911*^9, 3.8079732869205837`*^9}, 
   3.84029259596854*^9},ExpressionUUID->"1df286c3-9796-4dd9-9899-\
1c8de0562bb8"],

Cell[TextData[{
 "Once we know about the del operator, we can talk about the Laplacian \
operator ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[Del]", "2"], TraditionalForm]],ExpressionUUID->
  "d028e325-2d38-41b5-bde9-d912d3b1b5e0"],
 ", which is defined for a function ",
 StyleBox["f",
  FontSlant->"Italic"],
 "  as"
}], "Text",
 CellChangeTimes->{{3.80797336084824*^9, 
  3.8079734215254803`*^9}},ExpressionUUID->"9d29c426-872e-4b14-b587-\
21551b1d5e2a"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   SuperscriptBox["\[Del]", "2"], 
   StyleBox["f",
    FontSlant->"Italic"]}], "=", 
  RowBox[{
   RowBox[{"\[Del]", "\[CenterDot]", 
    RowBox[{"\[Del]", 
     StyleBox["f",
      FontSlant->"Italic"]}]}], "=", 
   RowBox[{
    FractionBox[
     RowBox[{
      SuperscriptBox["\[PartialD]", "2"], 
      StyleBox["f",
       FontSlant->"Italic"]}], 
     RowBox[{"\[PartialD]", 
      SuperscriptBox[
       StyleBox["x",
        FontSlant->"Italic"], "2"]}]], "+", 
    FractionBox[
     RowBox[{
      SuperscriptBox["\[PartialD]", "2"], 
      StyleBox["f",
       FontSlant->"Italic"]}], 
     RowBox[{"\[PartialD]", 
      SuperscriptBox["y", "2"]}]], "+", 
    FractionBox[
     RowBox[{
      SuperscriptBox["\[PartialD]", "2"], 
      StyleBox["f",
       FontSlant->"Italic"]}], 
     RowBox[{"\[PartialD]", 
      SuperscriptBox["z", "2"]}]]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8079734359242287`*^9, 3.8079734595866747`*^9}, {
  3.8079735259616528`*^9, 
  3.807973556017437*^9}},ExpressionUUID->"2649ddd7-4c5d-4912-8a90-\
6afd82f7a2fa"],

Cell["\<\
Notice that the Laplacian does not give a vector but rather a scalar (just a \
number without direction). It tells you about the curvature of a function in \
three dimensions.\
\>", "Text",
 CellChangeTimes->{{3.8079736401480274`*^9, 
  3.8079736778924065`*^9}},ExpressionUUID->"30441368-84a2-4e6d-898f-\
6ed0e9d608a7"]
}, Open  ]],

Cell[CellGroupData[{

Cell["The Three-Dimensional Schr\[ODoubleDot]dinger Equation", "Subsection",
 CellChangeTimes->{{3.807973895570529*^9, 
  3.8079739147905235`*^9}},ExpressionUUID->"3675c5dc-e022-4fce-82a5-\
b9dc179551be"],

Cell["\<\
Once we know the meaning of the Laplacian operator, we can write the \
three-dimensional version of the Schr\[ODoubleDot]dinger equation. By analogy \
with the one-dimensional case, the three-dimensional TISE is written\
\>", "Text",
 CellChangeTimes->{{3.8079739174859753`*^9, 
  3.8079740135991464`*^9}},ExpressionUUID->"6c004f1a-5ad7-4f0e-8c98-\
8e3ea9ef50b4"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"-", 
     FractionBox[
      SuperscriptBox["\[HBar]", "2"], 
      RowBox[{"2", 
       StyleBox["m",
        FontSlant->"Italic"]}]]}], 
    RowBox[{
     SuperscriptBox["\[Del]", "2"], "\[Psi]"}], 
    RowBox[{"(", 
     StyleBox["r",
      FontWeight->"Bold",
      FontSlant->"Italic"], 
     StyleBox[")",
      FontSlant->"Italic"]}]}], "+", 
   RowBox[{
    StyleBox["V",
     FontSlant->"Italic"], 
    StyleBox[
     RowBox[{"(", 
      StyleBox["r",
       FontWeight->"Bold"], ")"}],
     FontSlant->"Italic"], "\[Psi]", 
    RowBox[{"(", 
     StyleBox["r",
      FontWeight->"Bold",
      FontSlant->"Italic"], 
     StyleBox[")",
      FontSlant->"Italic"]}]}]}], "=", 
  RowBox[{
   StyleBox["E",
    FontSlant->"Italic"], 
   StyleBox[" ",
    FontSlant->"Italic"], "\[Psi]", 
   RowBox[{"(", 
    StyleBox["r",
     FontWeight->"Bold",
     FontSlant->"Italic"], 
    StyleBox[")",
     FontSlant->"Italic"]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8079664251944246`*^9, 3.8079664343142004`*^9}, {
  3.8079689400739555`*^9, 3.8079689680029573`*^9}, {3.807970315263204*^9, 
  3.8079703215316095`*^9}, {3.807970415909548*^9, 3.807970437015459*^9}, {
  3.8079705221296997`*^9, 3.8079705895237727`*^9}, {3.8079740353167067`*^9, 
  3.807974091342613*^9}},ExpressionUUID->"af90668a-fa88-4b4d-872e-\
1e11ef5dad4c"],

Cell[TextData[{
 "where \[Psi]( ",
 StyleBox["r",
  FontWeight->"Bold",
  FontSlant->"Italic"],
 StyleBox[" ",
  FontSlant->"Italic"],
 ") is shorthand for \[Psi]( ",
 StyleBox["x",
  FontSlant->"Italic"],
 ", ",
 StyleBox["y",
  FontSlant->"Italic"],
 ", ",
 StyleBox["z ",
  FontSlant->"Italic"],
 "). Similarly, the TDSE is written"
}], "Text",
 CellChangeTimes->{{3.8079740973331814`*^9, 
  3.807974154151634*^9}},ExpressionUUID->"56fe87dc-a9e0-48ce-aee3-\
c3b7b5a339cc"],

Cell[BoxData[
 RowBox[{
  RowBox[{"\[ImaginaryI]\[HBar]", " ", 
   StyleBox[
    FractionBox[
     RowBox[{
      StyleBox[
       RowBox[{"\[PartialD]", "\[Psi]"}],
       FontSlant->"Plain"], 
      RowBox[{
       StyleBox["(",
        FontSlant->"Plain"], 
       RowBox[{
        StyleBox["r",
         FontWeight->"Bold"], 
        StyleBox[",",
         FontSlant->"Plain"], 
        StyleBox["t",
         FontSlant->"Italic"]}], 
       StyleBox[")",
        FontSlant->"Italic"]}]}], 
     RowBox[{
      StyleBox["\[PartialD]",
       FontSlant->"Plain"], "t"}]],
    FontSlant->"Italic"]}], 
  StyleBox["=",
   FontSlant->"Plain"], 
  RowBox[{
   RowBox[{
    RowBox[{"-", 
     FractionBox[
      SuperscriptBox["\[HBar]", "2"], 
      RowBox[{"2", 
       StyleBox["m",
        FontSlant->"Italic"]}]]}], 
    RowBox[{
     SuperscriptBox["\[Del]", "2"], "\[Psi]"}], 
    RowBox[{"(", 
     RowBox[{
      StyleBox["r",
       FontWeight->"Bold",
       FontSlant->"Italic"], ",", " ", 
      StyleBox["t",
       FontSlant->"Italic"]}], 
     StyleBox[")",
      FontSlant->"Italic"]}]}], "+", 
   RowBox[{
    StyleBox["V",
     FontSlant->"Italic"], 
    StyleBox[
     RowBox[{"(", 
      StyleBox["r",
       FontWeight->"Bold"], ")"}],
     FontSlant->"Italic"], "\[Psi]", 
    RowBox[{"(", 
     RowBox[{
      StyleBox["r",
       FontWeight->"Bold",
       FontSlant->"Italic"], ",", " ", 
      StyleBox["t",
       FontSlant->"Italic"]}], 
     StyleBox[")",
      FontSlant->"Italic"]}]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8079664251944246`*^9, 3.8079664343142004`*^9}, {
  3.8079689400739555`*^9, 3.8079689680029573`*^9}, {3.807970315263204*^9, 
  3.8079703215316095`*^9}, {3.807970415909548*^9, 3.807970437015459*^9}, {
  3.8079705221296997`*^9, 3.8079705895237727`*^9}, {3.8079740353167067`*^9, 
  3.807974091342613*^9}, {3.807974175882186*^9, 3.807974210796206*^9}, {
  3.91467212756149*^9, 
  3.9146721286583815`*^9}},ExpressionUUID->"0e05e90a-f501-4e2d-8b70-\
d07dd3fd3c1c"],

Cell["\<\
these equations will be the basis for nearly everything in the class moving \
forward. To better apply and interpret our use of such equations, however, we\
\[CloseCurlyQuote]ll first have to learn a bit about operators, eigenvectors, \
and eigenvalues.\
\>", "Text",
 CellChangeTimes->{{3.8079744084533772`*^9, 
  3.807974490607319*^9}},ExpressionUUID->"dcbf4272-8efc-490b-a2cd-\
1e7fd71c1d37"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Operators in Quantum Mechanics", "Section",
 CellChangeTimes->{{3.8074594324828715`*^9, 3.8074594487922525`*^9}, {
  3.8076177444720974`*^9, 3.8076177502095847`*^9}, {3.8076315419037385`*^9, 
  3.8076315442771745`*^9}, {3.8076317240690165`*^9, 3.8076317343277235`*^9}, {
  3.8079650185938416`*^9, 3.8079650467347217`*^9}, {3.807978762083801*^9, 
  3.8079787666501837`*^9}},ExpressionUUID->"db4e9892-13bd-3b4c-9cb7-\
d54096147c7b"],

Cell[CellGroupData[{

Cell["What is an Operator?", "Subsection",
 CellChangeTimes->{{3.807978811447527*^9, 
  3.807978816019908*^9}},ExpressionUUID->"790189a6-22b1-b048-8e8d-\
3f4139a77f79"],

Cell["\<\
An operator is typically defined as something that acts on a function to \
transform it into another function. A broader definition from the textbook of \
McQuarrie & Simon is given as \[OpenCurlyDoubleQuote]a symbol that tells you \
to do something with whatever follows that symbol.\[CloseCurlyDoubleQuote] If \
we write the time-independent Schr\[ODoubleDot]dinger equation in the form\
\>", "Text",
 CellChangeTimes->{{3.8079789310968227`*^9, 3.8079789840444717`*^9}, {
  3.807979183580311*^9, 3.807979219699624*^9}, {3.91477789204303*^9, 
  3.914777904202691*^9}, {3.9148605583642273`*^9, 
  3.9148605642523465`*^9}},ExpressionUUID->"dbc2c130-4f49-c647-a781-\
fb6b7a1c25f2"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"[", 
    RowBox[{
     RowBox[{"-", 
      FractionBox[
       SuperscriptBox["\[HBar]", "2"], 
       RowBox[{"2", 
        StyleBox["m",
         FontSlant->"Italic"]}]]}], 
     RowBox[{
      SuperscriptBox["\[Del]", "2"], 
      RowBox[{"+", 
       StyleBox["V",
        FontSlant->"Italic"]}]}], 
     StyleBox[
      RowBox[{"(", 
       StyleBox["r",
        FontWeight->"Bold"], ")"}],
      FontSlant->"Italic"]}], 
    StyleBox["]",
     FontSlant->"Italic"]}], "\[Psi]", 
   RowBox[{"(", 
    StyleBox["r",
     FontWeight->"Bold",
     FontSlant->"Italic"], 
    StyleBox[")",
     FontSlant->"Italic"]}]}], "=", 
  RowBox[{
   StyleBox["E",
    FontSlant->"Italic"], 
   StyleBox[" ",
    FontSlant->"Italic"], "\[Psi]", 
   RowBox[{"(", 
    StyleBox["r",
     FontWeight->"Bold",
     FontSlant->"Italic"], 
    StyleBox[")",
     FontSlant->"Italic"]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8079664251944246`*^9, 3.8079664343142004`*^9}, {
  3.8079689400739555`*^9, 3.8079689680029573`*^9}, {3.807970315263204*^9, 
  3.8079703215316095`*^9}, {3.807970415909548*^9, 3.807970437015459*^9}, {
  3.8079705221296997`*^9, 3.8079705895237727`*^9}, {3.8079740353167067`*^9, 
  3.807974091342613*^9}, {3.8079792460635405`*^9, 
  3.807979253256398*^9}},ExpressionUUID->"e316a615-359a-0441-bc51-\
df132f935e6d"],

Cell[TextData[{
 "then we can define the portion in brackets as an operator acting on \[Psi](",
 StyleBox["r ",
  FontWeight->"Bold",
  FontSlant->"Italic"],
 "). This operator is usually called the Hamiltonian, ",
 Cell[BoxData[
  FormBox[
   OverscriptBox["H", "^"], TraditionalForm]],ExpressionUUID->
  "884eaf89-cd63-c741-89f0-10760cf965ae"],
 ", and is written"
}], "Text",
 CellChangeTimes->{{3.807979264014236*^9, 
  3.807979321371379*^9}},ExpressionUUID->"75ef8241-f830-bb42-8cce-\
90d9c67fab04"],

Cell[BoxData[
 RowBox[{
  OverscriptBox[
   StyleBox["H",
    FontSlant->"Italic"], "^"], "=", 
  RowBox[{
   RowBox[{"-", 
    FractionBox[
     SuperscriptBox["\[HBar]", "2"], 
     RowBox[{"2", 
      StyleBox["m",
       FontSlant->"Italic"]}]]}], 
   RowBox[{
    SuperscriptBox["\[Del]", "2"], 
    RowBox[{"+", 
     StyleBox["V",
      FontSlant->"Italic"]}]}], 
   StyleBox[
    RowBox[{"(", 
     StyleBox["r",
      FontWeight->"Bold"], ")"}],
    FontSlant->"Italic"]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8079664251944246`*^9, 3.8079664343142004`*^9}, {
  3.8079689400739555`*^9, 3.8079689680029573`*^9}, {3.807970315263204*^9, 
  3.8079703215316095`*^9}, {3.807970415909548*^9, 3.807970437015459*^9}, {
  3.8079705221296997`*^9, 3.8079705895237727`*^9}, {3.8079740353167067`*^9, 
  3.807974091342613*^9}, {3.8079792460635405`*^9, 3.807979253256398*^9}, {
  3.8079793289800205`*^9, 
  3.8079793382667046`*^9}},ExpressionUUID->"0e891908-7b49-2549-b740-\
fa755035ce94"],

Cell[TextData[{
 "Operators are often represented by letters with a \
\[OpenCurlyDoubleQuote]hat\[CloseCurlyDoubleQuote], as in ",
 Cell[BoxData[
  FormBox[
   OverscriptBox["H", "^"], TraditionalForm]],ExpressionUUID->
  "de899885-cfbc-7548-ad42-7c7800b6bbc9"],
 ". Why is this operator called the Hamiltonian? In analogy to our previous \
discussion of classical Hamiltonian mechanics, we can see that there is a \
kinetic energy portion of this operator,"
}], "Text",
 CellChangeTimes->{{3.9148607858423023`*^9, 3.914860825555463*^9}, 
   3.9148609162614536`*^9},ExpressionUUID->"47e154fe-28c0-2c44-9fd9-\
48c0e3132076"],

Cell[BoxData[
 RowBox[{
  OverscriptBox[
   StyleBox["T",
    FontSlant->"Italic"], "^"], "=", 
  RowBox[{
   RowBox[{"-", 
    FractionBox[
     SuperscriptBox["\[HBar]", "2"], 
     RowBox[{"2", 
      StyleBox["m",
       FontSlant->"Italic"]}]]}], 
   SuperscriptBox["\[Del]", "2"]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8079664251944246`*^9, 3.8079664343142004`*^9}, {
  3.8079689400739555`*^9, 3.8079689680029573`*^9}, {3.807970315263204*^9, 
  3.8079703215316095`*^9}, {3.807970415909548*^9, 3.807970437015459*^9}, {
  3.8079705221296997`*^9, 3.8079705895237727`*^9}, {3.8079740353167067`*^9, 
  3.807974091342613*^9}, {3.8079792460635405`*^9, 3.807979253256398*^9}, {
  3.8079793289800205`*^9, 3.8079793382667046`*^9}, {3.9148608335644646`*^9, 
  3.914860837129879*^9}},ExpressionUUID->"43bbdafd-e1d4-9d4c-acf2-\
cad42ff1500c"],

Cell["and a potential energy portion of this operator,", "Text",
 CellChangeTimes->{{3.9148608400660143`*^9, 
  3.914860852205114*^9}},ExpressionUUID->"6d73c186-62fb-734b-bde6-\
3d254dc69a85"],

Cell[BoxData[
 RowBox[{
  OverscriptBox[
   StyleBox["V",
    FontSlant->"Italic"], "^"], "=", 
  StyleBox[
   RowBox[{"V", 
    RowBox[{"(", 
     StyleBox["r",
      FontWeight->"Bold"], ")"}]}],
   FontSlant->"Italic"]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8079664251944246`*^9, 3.8079664343142004`*^9}, {
  3.8079689400739555`*^9, 3.8079689680029573`*^9}, {3.807970315263204*^9, 
  3.8079703215316095`*^9}, {3.807970415909548*^9, 3.807970437015459*^9}, {
  3.8079705221296997`*^9, 3.8079705895237727`*^9}, {3.8079740353167067`*^9, 
  3.807974091342613*^9}, {3.8079792460635405`*^9, 3.807979253256398*^9}, {
  3.8079793289800205`*^9, 3.8079793382667046`*^9}, {3.9148608335644646`*^9, 
  3.914860863867011*^9}},ExpressionUUID->"9c535415-5db3-d842-94ab-\
3c2d32f8964c"],

Cell["\<\
Together, these form a Hamiltonian operator, in analogy with the classical \
Hamiltonian\
\>", "Text",
 CellChangeTimes->{{3.914860876803041*^9, 
  3.9148608902456107`*^9}},ExpressionUUID->"083746fa-5719-0549-b44d-\
1dbb9ff7c39f"],

Cell[BoxData[
 RowBox[{
  OverscriptBox[
   StyleBox["H",
    FontSlant->"Italic"], "^"], "=", 
  RowBox[{
   OverscriptBox[
    StyleBox["T",
     FontSlant->"Italic"], "^"], "+", 
   OverscriptBox[
    StyleBox["V",
     FontSlant->"Italic"], "^"]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8079664251944246`*^9, 3.8079664343142004`*^9}, {
  3.8079689400739555`*^9, 3.8079689680029573`*^9}, {3.807970315263204*^9, 
  3.8079703215316095`*^9}, {3.807970415909548*^9, 3.807970437015459*^9}, {
  3.8079705221296997`*^9, 3.8079705895237727`*^9}, {3.8079740353167067`*^9, 
  3.807974091342613*^9}, {3.8079792460635405`*^9, 3.807979253256398*^9}, {
  3.8079793289800205`*^9, 3.8079793382667046`*^9}, {3.9148608972566657`*^9, 
  3.91486090223683*^9}},ExpressionUUID->"e96c5e81-7e4a-b642-93bc-\
42055a8ceb94"],

Cell[TextData[{
 "In quantum mechanics, ",
 StyleBox["physical observables are represented by operators.",
  FontWeight->"Bold"]
}], "Text",
 CellChangeTimes->{{3.80797938072338*^9, 3.807979401782342*^9}, {
   3.8079798249977875`*^9, 3.8079798586295238`*^9}, 
   3.914860912942692*^9},ExpressionUUID->"2b4a5ba8-111a-f044-8baa-\
5ee745d3aecf"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Properties of Operators", "Subsection",
 CellChangeTimes->{{3.8079798746773305`*^9, 
  3.807979878445174*^9}},ExpressionUUID->"abde46d8-0a67-bd47-b49c-\
730ca5ed0fe9"],

Cell[TextData[{
 "Operators generally can be treated like other components of an equation. \
However, ",
 StyleBox["operators do not always commute! ",
  FontWeight->"Bold"],
 "That means they don\[CloseCurlyQuote]t obey the commutative law, or"
}], "Text",
 CellChangeTimes->{{3.8079802583280163`*^9, 3.807980272071144*^9}, {
  3.807980718165512*^9, 3.8079807268065577`*^9}, {3.9147779366426134`*^9, 
  3.9147779498849463`*^9}},ExpressionUUID->"7dcf80bd-86ca-a247-aa4e-\
012537217418"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   OverscriptBox[
    StyleBox["A",
     FontSlant->"Italic"], "^"], 
   OverscriptBox[
    StyleBox["B",
     FontSlant->"Italic"], "^"]}], "\[NotEqual]", 
  RowBox[{
   OverscriptBox[
    StyleBox["B",
     FontSlant->"Italic"], "^"], 
   OverscriptBox[
    StyleBox["A",
     FontSlant->"Italic"], "^"]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8079802884177794`*^9, 
  3.8079803057088737`*^9}},ExpressionUUID->"8859104c-178d-6844-902a-\
2997b49a2bbf"],

Cell["\<\
This property will be very important, especially in relation to the \
uncertainty principle. We will often use the commutator of two operators , \
which is given by\
\>", "Text",
 CellChangeTimes->{{3.8079803101193485`*^9, 3.8079803274314322`*^9}, {
  3.8079806096998634`*^9, 
  3.807980635240232*^9}},ExpressionUUID->"53dcac84-5f5c-f847-95c5-\
f1bebeeefe0b"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   OverscriptBox[
    RowBox[{
     StyleBox["[",
      FontSlant->"Italic"], 
     RowBox[{
      StyleBox["A",
       FontSlant->"Italic"], 
      StyleBox[",",
       FontSlant->"Plain"]}]}], "^"], 
   OverscriptBox[
    StyleBox[
     RowBox[{"B", "]"}],
     FontSlant->"Italic"], "^"]}], "=", 
  RowBox[{
   RowBox[{
    OverscriptBox[
     StyleBox["A",
      FontSlant->"Italic"], "^"], 
    OverscriptBox[
     StyleBox["B",
      FontSlant->"Italic"], "^"]}], "-", 
   RowBox[{
    OverscriptBox[
     StyleBox["B",
      FontSlant->"Italic"], "^"], 
    OverscriptBox[
     StyleBox["A",
      FontSlant->"Italic"], "^"]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8079802884177794`*^9, 3.8079803057088737`*^9}, {
  3.8079806428299017`*^9, 
  3.8079806577653275`*^9}},ExpressionUUID->"53e0326c-7d8b-5349-a810-\
bcbf1310352c"],

Cell["\<\
If two operators commute, then the commutator will give a value of zero. If \
they don\[CloseCurlyQuote]t commute, then it won\[CloseCurlyQuote]t return \
zero.\
\>", "Text",
 CellChangeTimes->{{3.808844646297394*^9, 
  3.808844669672834*^9}},ExpressionUUID->"6b92e1c6-c5c6-8d44-8381-\
bceb5893dcf3"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Linear Operators", "Subsection",
 CellChangeTimes->{{3.8079810697726*^9, 
  3.807981071961344*^9}},ExpressionUUID->"6e03d394-5f23-b342-90d4-\
fe4677cc8b79"],

Cell[TextData[{
 "Nearly all of the operators that we use in quantum mechanics are linear \
operators. An operator must meet two conditions to be considered linear. \
First, for any functions ",
 StyleBox["f",
  FontSlant->"Italic"],
 " and ",
 StyleBox["g",
  FontSlant->"Italic"]
}], "Text",
 CellChangeTimes->{{3.807981075109537*^9, 3.8079811192162704`*^9}, {
  3.8079812477867656`*^9, 3.807981258476662*^9}, {3.9339371452385483`*^9, 
  3.933937146494301*^9}},ExpressionUUID->"00ab3bd4-7739-5849-ae6e-\
05685bcfadd8"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   OverscriptBox[
    StyleBox["A",
     FontSlant->"Italic"], "^"], 
   RowBox[{"(", 
    RowBox[{
     StyleBox["f",
      FontSlant->"Italic"], "+", 
     StyleBox["g",
      FontSlant->"Italic"]}], 
    StyleBox[")",
     FontSlant->"Italic"]}]}], "=", 
  RowBox[{
   RowBox[{
    OverscriptBox[
     StyleBox["A",
      FontSlant->"Italic"], "^"], 
    StyleBox["f",
     FontSlant->"Italic"]}], "+", 
   RowBox[{
    OverscriptBox[
     StyleBox["A",
      FontSlant->"Italic"], "^"], 
    StyleBox["g",
     FontSlant->"Italic"]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.80798114429391*^9, 
  3.8079811876095624`*^9}},ExpressionUUID->"1f8a82ef-6c4c-d94c-be6e-\
5374d5859725"],

Cell["and second,", "Text",
 CellChangeTimes->{{3.807981190007189*^9, 
  3.80798119863692*^9}},ExpressionUUID->"99a84b27-1de3-9748-89f5-\
abcdbb086df1"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   OverscriptBox[
    StyleBox["A",
     FontSlant->"Italic"], "^"], 
   RowBox[{"(", 
    StyleBox["cf",
     FontSlant->"Italic"], ")"}]}], "=", 
  RowBox[{
   StyleBox["c",
    FontSlant->"Italic"], 
   OverscriptBox[
    StyleBox["A",
     FontSlant->"Italic"], "^"], 
   StyleBox["f",
    FontSlant->"Italic"]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.807981210372202*^9, 
  3.807981268076141*^9}},ExpressionUUID->"3900a968-4226-444e-98e6-\
57ae6d38684e"],

Cell[TextData[{
 "where ",
 StyleBox["c",
  FontSlant->"Italic"],
 " is a constant."
}], "Text",
 CellChangeTimes->{{3.8079812715361595`*^9, 
  3.8079812827647276`*^9}},ExpressionUUID->"dbc72b78-c699-ff4e-994a-\
ec17ae859132"],

Cell["\<\
The fact that quantum mechanical operators are mostly linear will be \
extremely helpful in constructing wavefunctions in a basis (more about this \
later).\
\>", "Text",
 CellChangeTimes->{{3.8079813243219223`*^9, 
  3.8079813515693135`*^9}},ExpressionUUID->"3766c4d4-53da-de4b-ac11-\
3d50283f9c48"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Eigenfunctions and Eigenvalues", "Subsection",
 CellChangeTimes->{{3.808040777510792*^9, 
  3.808040780612585*^9}},ExpressionUUID->"8dccdae8-3fd8-9a44-896f-\
15d6f71d39ef"],

Cell["\<\
Eigenvalue problems occur when an operator acting on a function returns that \
function multiplied by a constant, for example\
\>", "Text",
 CellChangeTimes->{{3.8080408551339493`*^9, 3.808040903917271*^9}, {
  3.8080409629466248`*^9, 
  3.808040969383209*^9}},ExpressionUUID->"781a9360-7b4b-d94d-b544-\
c4abcbe56590"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   OverscriptBox[
    StyleBox["A",
     FontSlant->"Italic"], "^"], 
   StyleBox["f",
    FontSlant->"Italic"]}], 
  StyleBox["=",
   FontSlant->"Italic"], 
  StyleBox["cf",
   FontSlant->"Italic"]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.808040919398035*^9, 
  3.8080409219410057`*^9}},ExpressionUUID->"0f0a4e81-4575-854f-b2fe-\
6f3247b2fc04"],

Cell[TextData[{
 " The function ",
 StyleBox["f",
  FontSlant->"Italic"],
 "  is known as an eigenfunction of the operator ",
 Cell[BoxData[
  OverscriptBox[
   StyleBox["A",
    FontSlant->"Italic"], "^"]],
  CellChangeTimes->{{3.808040919398035*^9, 3.8080409219410057`*^9}},
  ExpressionUUID->"bb62401c-ced2-ba4b-b2b0-d6f532f1f6a9"],
 ", and the constant ",
 StyleBox["c",
  FontSlant->"Italic"],
 " is known as the eigenvalue of ",
 StyleBox["f",
  FontSlant->"Italic"],
 ". "
}], "Text",
 CellChangeTimes->{{3.808040925570606*^9, 3.8080410528599553`*^9}, {
  3.808041251477553*^9, 
  3.808041256751296*^9}},ExpressionUUID->"2eb3f099-acdf-5b49-9edc-\
30d3c67d2878"],

Cell["\<\
Recall that physical observables in quantum mechanics are represented by \
operators. As you will see, finding the expected experimental result for a \
given observable involves solving such an eigenvalue problem. You have \
already seen a prominent example of an eigenvalue problem in the \
time-independent Schr\[ODoubleDot]dinger equation. This observation is more \
clear if we write the TISE in the form\
\>", "Text",
 CellChangeTimes->{{3.8080412591108227`*^9, 3.8080414023188076`*^9}, {
  3.8080414440979567`*^9, 3.808041518050269*^9}, {3.9147779882622833`*^9, 
  3.9147779887903833`*^9}},ExpressionUUID->"b2996552-1eb3-e043-82a9-\
c619005970e0"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   OverscriptBox[
    StyleBox["H",
     FontSlant->"Italic"], "^"], "\[Psi]", 
   RowBox[{"(", 
    StyleBox["r",
     FontWeight->"Bold",
     FontSlant->"Italic"], 
    StyleBox[")",
     FontSlant->"Italic"]}]}], "=", 
  RowBox[{
   StyleBox["E",
    FontSlant->"Italic"], 
   StyleBox[" ",
    FontSlant->"Italic"], "\[Psi]", 
   RowBox[{"(", 
    StyleBox["r",
     FontWeight->"Bold",
     FontSlant->"Italic"], 
    StyleBox[")",
     FontSlant->"Italic"]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8080415340456657`*^9, 
  3.808041542194871*^9}},ExpressionUUID->"dac151ff-0cd0-814a-a9d2-\
46097c22b7aa"],

Cell[TextData[{
 "In this form, we see that the Hamiltonian operator ",
 Cell[BoxData[
  OverscriptBox[
   StyleBox["H",
    FontSlant->"Italic"], "^"]],
  CellChangeTimes->{{3.8079664251944246`*^9, 3.8079664343142004`*^9}, {
   3.8079689400739555`*^9, 3.8079689680029573`*^9}, {3.807970315263204*^9, 
   3.8079703215316095`*^9}, {3.807970415909548*^9, 3.807970437015459*^9}, {
   3.8079705221296997`*^9, 3.8079705895237727`*^9}, {3.8079740353167067`*^9, 
   3.807974091342613*^9}, {3.8079792460635405`*^9, 3.807979253256398*^9}, {
   3.8079793289800205`*^9, 3.8079793382667046`*^9}},ExpressionUUID->
  "a134961f-85ea-174d-b3b3-5b692f121527"],
 " returns the energy eigenvalues for the eigenfunction \[Psi]. We will \
return to the importance of eigenvalue problems once we have discussed the \
interpretation of the wavefunction."
}], "Text",
 CellChangeTimes->{{3.808041556246585*^9, 
  3.8080416114737372`*^9}},ExpressionUUID->"510945e9-b99f-5a49-bf0f-\
6de053995ca4"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Hermitian Operators", "Subsection",
 CellChangeTimes->{{3.807983000321397*^9, 
  3.807983002465931*^9}},ExpressionUUID->"95e46348-dcc7-8942-804b-\
4f1a05f5aa4d"],

Cell[TextData[{
 "We are now going to introduce a special class of operators known as \
Hermitian operators. An operator ",
 Cell[BoxData[
  OverscriptBox[
   StyleBox["A",
    FontSlant->"Italic"], "^"]],
  CellChangeTimes->{{3.808040919398035*^9, 3.8080409219410057`*^9}},
  ExpressionUUID->"23bdb151-c874-9548-af1e-f9909e1829bd"],
 " is Hermitian if"
}], "Text",
 CellChangeTimes->{{3.8080399394699373`*^9, 3.8080399573664947`*^9}, {
  3.8080466191095123`*^9, 3.808046654553553*^9}, {3.808046722107066*^9, 
  3.8080467247624474`*^9}, {3.80804678500051*^9, 
  3.8080467854205875`*^9}},ExpressionUUID->"1004d211-2f57-c840-8736-\
5001d5af1cae"],

Cell[BoxData[
 RowBox[{
  RowBox[{"\[Integral]", 
   RowBox[{
    SubsuperscriptBox["\[Psi]", "1", "\[Star]"], 
    RowBox[{"(", 
     StyleBox["r",
      FontWeight->"Bold",
      FontSlant->"Italic"], ")"}], 
    OverscriptBox[
     StyleBox["A",
      FontSlant->"Italic"], "^"], 
    SubscriptBox["\[Psi]", "2"], 
    RowBox[{"(", 
     StyleBox["r",
      FontWeight->"Bold",
      FontSlant->"Italic"], ")"}], 
    StyleBox[
     StyleBox[
      RowBox[{"d", 
       StyleBox["r",
        FontWeight->"Bold"]}]],
     FontSlant->"Italic"]}]}], 
  StyleBox["=",
   FontSlant->"Plain"], 
  RowBox[{"\[Integral]", 
   RowBox[{
    SuperscriptBox[
     RowBox[{"(", 
      RowBox[{
       OverscriptBox[
        StyleBox["A",
         FontSlant->"Italic"], "^"], 
       SubscriptBox["\[Psi]", "1"], 
       RowBox[{"(", 
        StyleBox["r",
         FontWeight->"Bold",
         FontSlant->"Italic"], ")"}]}], ")"}], "\[Star]"], 
    SubscriptBox["\[Psi]", "2"], 
    RowBox[{"(", 
     StyleBox["r",
      FontWeight->"Bold",
      FontSlant->"Italic"], ")"}], 
    StyleBox[
     StyleBox[
      RowBox[{"d", 
       StyleBox["r",
        FontWeight->"Bold"]}]],
     FontSlant->"Italic"]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8080467345271435`*^9, 
  3.808046885533104*^9}},ExpressionUUID->"37369ec4-7613-b248-8b8f-\
f255e956f457"],

Cell[TextData[{
 "for any functions ",
 Cell[BoxData[
  SubscriptBox["\[Psi]", "1"]],
  CellChangeTimes->{{3.8080467345271435`*^9, 3.808046885533104*^9}},
  ExpressionUUID->"67aacbc7-4ac4-0046-8cf4-6fa9ce2ed3de"],
 " and ",
 Cell[BoxData[
  SubscriptBox["\[Psi]", "2"]],
  CellChangeTimes->{{3.8080467345271435`*^9, 3.808046885533104*^9}},
  ExpressionUUID->"b764317b-bebe-4148-8889-8ac3e64e29a5"],
 ". Remember here that the \[Star] signifies the complex conjugate. That may \
seem like a very strange definition at the moment, but it will make more \
sense as we learn about how to interpret a wavefunction."
}], "Text",
 CellChangeTimes->{{3.808047019385373*^9, 
  3.8080471169684086`*^9}},ExpressionUUID->"ed9019e7-b726-4242-942a-\
fbc01b476bb7"],

Cell["\<\
All quantum mechanical observables are represented by Hermitian operators, \
which have some very important properties:\
\>", "Text",
 CellChangeTimes->{{3.808047128451223*^9, 3.8080471368221684`*^9}, {
  3.8080472781028943`*^9, 
  3.808047294919421*^9}},ExpressionUUID->"6fdb3e92-9741-3447-bbc3-\
fbac6540377b"],

Cell["\<\
The eigenvalues of Hermitian operators are real. That means in the eigenvalue \
equation for a Hermitian operator, \
\>", "Item",
 CellChangeTimes->{{3.808047239813257*^9, 3.8080472456764946`*^9}, {
  3.808047345696186*^9, 
  3.8080474217552047`*^9}},ExpressionUUID->"6a3b8f42-bcba-6b41-8dfc-\
0b2d85087b0a"],

Cell[BoxData[
 RowBox[{"   ", 
  RowBox[{
   RowBox[{
    OverscriptBox[
     StyleBox["A",
      FontSlant->"Italic"], "^"], 
    StyleBox["f",
     FontSlant->"Italic"]}], "=", 
   StyleBox["cf",
    FontSlant->"Italic"]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8080474328514304`*^9, 3.808047447130695*^9}, {
  3.8080475272375383`*^9, 
  3.8080475324642143`*^9}},ExpressionUUID->"3f7c59c6-a4ca-bb47-b8de-\
4ed0717d7b4c"],

Cell[TextData[{
 "    the eigenvalue ",
 StyleBox["c",
  FontSlant->"Italic"],
 " must be a real number."
}], "Text",
 CellChangeTimes->{{3.8080474670669165`*^9, 3.8080474751603637`*^9}, {
  3.8080475340609045`*^9, 
  3.808047536167584*^9}},ExpressionUUID->"03ff1582-8fb5-2e42-be1a-\
c24bb948e758"],

Cell[TextData[{
 "The eigenfunctions of a Hermitian operator are orthogonal.  Two functions ",
 StyleBox["f",
  FontSlant->"Italic"],
 " and ",
 StyleBox["g",
  FontSlant->"Italic"],
 " are orthogonal if"
}], "Item",
 CellChangeTimes->{{3.8080475216678505`*^9, 3.8080476473864756`*^9}, {
  3.808047753094455*^9, 3.8080477752316303`*^9}, {3.808048188360359*^9, 
  3.808048221517561*^9}, {3.914861083372903*^9, 3.9148610858955784`*^9}, {
  3.933937257015484*^9, 
  3.9339372655470276`*^9}},ExpressionUUID->"526df212-3d92-7547-90b0-\
e33e42b90fad"],

Cell[BoxData[
 RowBox[{
  RowBox[{"\[Integral]", 
   RowBox[{
    SuperscriptBox[
     StyleBox["f",
      FontSlant->"Italic"], "\[Star]"], 
    RowBox[{"(", 
     StyleBox["r",
      FontWeight->"Bold",
      FontSlant->"Italic"], ")"}], 
    StyleBox["g",
     FontSlant->"Italic"], 
    RowBox[{"(", 
     StyleBox["r",
      FontWeight->"Bold",
      FontSlant->"Italic"], ")"}], 
    StyleBox[
     StyleBox[
      RowBox[{"d", 
       StyleBox["r",
        FontWeight->"Bold"]}]],
     FontSlant->"Italic"]}]}], 
  StyleBox["=",
   FontSlant->"Plain"], 
  StyleBox["0",
   FontSlant->"Plain"]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{
  3.808048231289387*^9},ExpressionUUID->"dd4468f4-8490-3c46-94cd-\
77250c942c9d"],

Cell["\<\
Once again, this property may not seem so important at the moment, but we\
\[CloseCurlyQuote]ll come back to it once we have gone through the postulates \
of quantum mechanics. \
\>", "Text",
 CellChangeTimes->{{3.8080483085983543`*^9, 3.8080483398673196`*^9}, {
  3.9339372686456585`*^9, 
  3.9339372791701393`*^9}},ExpressionUUID->"61adeb86-9e2e-ac47-a56e-\
22e7c4e51f96"],

Cell[TextData[{
 "This property is true whenever the eigenvalues of two eigenfunctions are \
not equal; if the eigenvalues are equal (which we call ",
 StyleBox["degenerate",
  FontSlant->"Italic"],
 " states), the eigenfunctions can be set up in such a way to make them \
orthogonal. This idea may return at a later date in the course."
}], "Text",
 CellChangeTimes->{{3.933937281933153*^9, 
  3.9339373489811363`*^9}},ExpressionUUID->"4db3b30f-034d-c24c-af1f-\
dc82d2d8e0a6"],

Cell["\<\
The eigenfunctions of a Hermitian function form a complete set, meaning we \
can represent any system using a sum of these eigenfunctions.\
\>", "Item",
 CellChangeTimes->{{3.8080475216678505`*^9, 3.8080476473864756`*^9}, {
  3.808047753094455*^9, 3.8080477752316303`*^9}, {3.808048188360359*^9, 
  3.808048221517561*^9}, {3.9148610933278646`*^9, 
  3.9148611150493417`*^9}},ExpressionUUID->"80fb028d-3dbf-6841-92ac-\
24d00b3ed155"]
}, Open  ]]
}, Open  ]]
}, Open  ]]
},
WindowSize->{812.5714285714286, 470.57142857142856`},
WindowMargins->{{0, Automatic}, {Automatic, 0}},
