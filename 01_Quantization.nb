Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"f1", "[", 
    RowBox[{"yy_", ",", "aa_"}], "]"}], ":=", 
   RowBox[{"GraphicsRow", "[", 
    RowBox[{"{", " ", 
     RowBox[{
      RowBox[{"Plot", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"1", "/", 
          RowBox[{"Sqrt", "[", 
           RowBox[{"2", " ", "aa"}], "]"}]}], " ", 
         RowBox[{"Piecewise", "[", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"0", ",", 
              RowBox[{"yy", "<", 
               RowBox[{"-", "aa"}]}]}], "}"}], ",", 
            RowBox[{"{", 
             RowBox[{"1", ",", 
              RowBox[{
               RowBox[{"yy", ">", 
                RowBox[{"-", "aa"}]}], "&&", 
               RowBox[{"yy", "<", "aa"}]}]}], "}"}], ",", 
            RowBox[{"{", 
             RowBox[{"0", ",", 
              RowBox[{"yy", ">", "aa"}]}], "}"}]}], "}"}], "]"}]}], ",", 
        RowBox[{"{", 
         RowBox[{"yy", ",", 
          RowBox[{"-", "5"}], ",", "5"}], "}"}], ",", "\n", 
        RowBox[{"AxesLabel", "->", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"Style", "[", 
            RowBox[{"\"\<x\>\"", ",", "24", ",", "Italic"}], "]"}], ",", 
           RowBox[{"Style", "[", 
            RowBox[{"\"\<f(x)\>\"", ",", "24", ",", "Italic"}], "]"}]}], 
          "}"}]}], ",", 
        RowBox[{"PlotStyle", "->", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"Thickness", "[", ".008", "]"}], ",", "Black"}], "}"}]}], 
        ",", 
        RowBox[{"PlotRange", "->", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{
             RowBox[{"-", "2.2"}], ",", "2.2"}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"-", ".1"}], ",", "1.1"}], "}"}]}], "}"}]}], ",", 
        RowBox[{"Ticks", "->", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{
             RowBox[{"-", "2"}], ",", 
             RowBox[{"-", "1"}], ",", "0", ",", "1", ",", "2"}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{"0", ",", "0.5", ",", "1"}], "}"}]}], "}"}]}], ",", 
        RowBox[{"TicksStyle", "->", 
         RowBox[{"Directive", "[", 
          RowBox[{"Gray", ",", "20"}], "]"}]}]}], "]"}], ",", "\n", 
      RowBox[{"Plot", "[", 
       RowBox[{
        RowBox[{"-", 
         FractionBox[
          RowBox[{
           RowBox[{"Sin", "[", 
            RowBox[{"aa", " ", "w"}], "]"}], " ", 
           RowBox[{"(", 
            RowBox[{
             RowBox[{"-", "1"}], "+", 
             RowBox[{"UnitStep", "[", 
              RowBox[{"-", "aa"}], "]"}]}], ")"}]}], 
          RowBox[{
           SqrtBox["aa"], " ", 
           SqrtBox["\[Pi]"], " ", "w"}]]}], ",", 
        RowBox[{"{", 
         RowBox[{"w", ",", 
          RowBox[{"-", "15"}], ",", "15"}], "}"}], ",", 
        RowBox[{"AxesLabel", "->", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"Style", "[", 
            RowBox[{"\"\<k\>\"", ",", "24", ",", "Red", ",", "Italic"}], 
            "]"}], ",", 
           RowBox[{"Style", "[", 
            RowBox[{
            "\"\<\!\(\*OverscriptBox[\(f\), \(~\)]\)(k)\>\"", ",", "24", ",", 
             "Italic", ",", "Red"}], "]"}]}], "}"}]}], ",", 
        RowBox[{"PlotStyle", "->", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"Thickness", "[", ".008", "]"}], ",", "Red"}], "}"}]}], 
        ",", 
        RowBox[{"PlotRange", "->", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"-", ".5"}], ",", "1"}], "}"}]}], ",", 
        RowBox[{"Ticks", "->", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{
             RowBox[{"-", "10"}], ",", "0", ",", "10"}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"-", "0.5"}], ",", "0", ",", "0.5", ",", "1"}], "}"}]}], 
          "}"}]}], ",", 
        RowBox[{"TicksStyle", "->", 
         RowBox[{"Directive", "[", 
          RowBox[{"Gray", ",", "20"}], "]"}]}]}], "]"}]}], "}"}], "]"}]}], 
  ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"f2", "[", 
    RowBox[{"yy_", ",", "aa_"}], "]"}], ":=", 
   RowBox[{"GraphicsRow", "[", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"Plot", "[", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"(", 
           RowBox[{"2", " ", 
            RowBox[{"aa", "/", "Pi"}]}], ")"}], "^", 
          RowBox[{"(", 
           RowBox[{"1", "/", "4"}], ")"}]}], " ", 
         RowBox[{"Exp", "[", 
          RowBox[{
           RowBox[{"-", "aa"}], " ", 
           RowBox[{"yy", "^", "2"}]}], "]"}]}], ",", 
        RowBox[{"{", 
         RowBox[{"yy", ",", 
          RowBox[{"-", "3.75"}], ",", "3.75"}], "}"}], ",", 
