Cell[CellGroupData[{

Cell["Why Use Atomic Units?", "Subsection",
 CellChangeTimes->{{3.811944181962739*^9, 
  3.8119441874488707`*^9}},ExpressionUUID->"2f2aef3f-e4d4-1843-8e65-\
ef21dddd68c6"],

Cell["\<\
Atomic units can be a bit annoying if you are used to working in SI units, \
but they do have some utility. Unfortunately, once one moves away from the \
hydrogen atom, most calculations don\[CloseCurlyQuote]t return nice multiple \
values of atomic units. However, they do greatly simplify the form in which \
we write equations. Take, for example, our TISE for the helium atom,\
\>", "Text",
 CellChangeTimes->{{3.8119441899773045`*^9, 
  3.811944271280939*^9}},ExpressionUUID->"82d76ed6-c912-ba4c-a07a-\
af3a4de36a46"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    FractionBox[
     RowBox[{"-", 
      SuperscriptBox["\[HBar]", "2"]}], 
     RowBox[{"2", 
      StyleBox[
       SubscriptBox["m", "e"],
       FontSlant->"Italic"]}]], 
    RowBox[{"(", 
     RowBox[{
      SubsuperscriptBox["\[Del]", "1", "2"], 
      RowBox[{"+", 
       SubsuperscriptBox["\[Del]", "2", "2"]}]}], ")"}], "\[Psi]", 
    RowBox[{"(", 
     RowBox[{
      SubscriptBox[
       StyleBox["r",
        FontWeight->"Bold",
        FontSlant->"Italic"], "1"], ",", " ", 
      SubscriptBox[
       StyleBox["r",
        FontWeight->"Bold",
        FontSlant->"Italic"], "2"]}], ")"}]}], "-", 
   RowBox[{
    FractionBox[
     RowBox[{"2", 
      SuperscriptBox[
       StyleBox["e",
        FontSlant->"Italic"], "2"]}], 
     RowBox[{"4", 
      SubscriptBox["\[Pi]\[Epsilon]", "0"]}]], 
    RowBox[{"(", 
     RowBox[{
      FractionBox["1", 
       SubscriptBox[
        StyleBox["r",
         FontSlant->"Italic"], 
        StyleBox["1",
         FontSlant->"Plain"]]], "+", 
      FractionBox["1", 
       SubscriptBox[
        StyleBox["r",
         FontSlant->"Italic"], 
        StyleBox["2",
         FontSlant->"Plain"]]]}], ")"}], "\[Psi]", 
    RowBox[{"(", 
     RowBox[{
      SubscriptBox[
       StyleBox["r",
        FontWeight->"Bold",
        FontSlant->"Italic"], "1"], ",", 
      SubscriptBox[
       StyleBox["r",
        FontWeight->"Bold",
        FontSlant->"Italic"], "2"]}], ")"}]}], "+", 
   RowBox[{
    FractionBox[
     SuperscriptBox[
      StyleBox["e",
       FontSlant->"Italic"], "2"], 
     RowBox[{"4", 
      SubscriptBox["\[Pi]\[Epsilon]", "0"], 
      RowBox[{"\[LeftBracketingBar]", 
       RowBox[{
        StyleBox[
         SubscriptBox[
          StyleBox["r",
           FontWeight->"Bold",
           FontSlant->"Italic"], 
          StyleBox["1",
           FontSlant->"Plain"]],
         FontWeight->"Bold",
         FontSlant->"Italic"], 
        StyleBox["-",
         FontWeight->"Bold",
         FontSlant->"Italic"], 
        SubscriptBox[
         StyleBox["r",
          FontWeight->"Bold",
          FontSlant->"Italic"], "2"]}], "\[RightBracketingBar]"}]}]], 
    "\[Psi]", 
    RowBox[{"(", 
     RowBox[{
      SubscriptBox[
       StyleBox["r",
        FontWeight->"Bold",
        FontSlant->"Italic"], "1"], ",", 
      SubscriptBox[
       StyleBox["r",
        FontWeight->"Bold",
        FontSlant->"Italic"], "2"]}], ")"}]}]}], "=", 
  RowBox[{
   StyleBox[
    RowBox[{
     StyleBox["E",
      FontSlant->"Italic"], "\[Psi]"}]], 
   RowBox[{"(", 
    RowBox[{
     SubscriptBox[
      StyleBox["r",
       FontWeight->"Bold",
       FontSlant->"Italic"], "1"], ",", 
     SubscriptBox[
      StyleBox["r",
       FontWeight->"Bold",
       FontSlant->"Italic"], "2"]}], ")"}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.810112811439228*^9, 3.8101128248442793`*^9}, {
  3.810479494926491*^9, 3.8104795038498344`*^9}, {3.810479572543576*^9, 
  3.8104796147383184`*^9}, {3.8104802055659895`*^9, 3.8104802433915305`*^9}, {
  3.8104802785189395`*^9, 3.8104802814214115`*^9}, {3.8109915300785556`*^9, 
  3.8109916793993816`*^9}, {3.810991710031681*^9, 3.8109918292023373`*^9}, {
  3.810994488524798*^9, 3.810994499853472*^9}, {3.8109948928195066`*^9, 
  3.8109948950763626`*^9}, {3.8109949491606197`*^9, 3.810995087249513*^9}, {
  3.8109951188614283`*^9, 
  3.8109951226144466`*^9}},ExpressionUUID->"a0a17157-4380-1749-8f70-\
d2f60a8a1cde"],

Cell["\<\
If we write down this same equation in atomic units instead of SI units, we \
obtain\
\>", "Text",
 CellChangeTimes->{{3.8119442924101963`*^9, 
  3.8119443061385326`*^9}},ExpressionUUID->"59544bc3-bbb3-a945-b65d-\
ab71a6324215"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    FractionBox[
     RowBox[{"-", "1"}], "2"], 
    RowBox[{"(", 
     RowBox[{
      SubsuperscriptBox["\[Del]", "1", "2"], 
      RowBox[{"+", 
       SubsuperscriptBox["\[Del]", "2", "2"]}]}], ")"}], "\[Psi]", 
    RowBox[{"(", 
     RowBox[{
      SubscriptBox[
       StyleBox["r",
        FontWeight->"Bold",
        FontSlant->"Italic"], "1"], ",", " ", 
      SubscriptBox[
       StyleBox["r",
        FontWeight->"Bold",
        FontSlant->"Italic"], "2"]}], ")"}]}], "-", 
   RowBox[{"2", 
    RowBox[{"(", 
     RowBox[{
      FractionBox["1", 
       SubscriptBox[
        StyleBox["r",
         FontSlant->"Italic"], 
        StyleBox["1",
         FontSlant->"Plain"]]], "+", 
      FractionBox["1", 
       SubscriptBox[
        StyleBox["r",
         FontSlant->"Italic"], 
        StyleBox["2",
         FontSlant->"Plain"]]]}], ")"}], "\[Psi]", 
    RowBox[{"(", 
     RowBox[{
      SubscriptBox[
       StyleBox["r",
        FontWeight->"Bold",
        FontSlant->"Italic"], "1"], ",", 
      SubscriptBox[
       StyleBox["r",
        FontWeight->"Bold",
        FontSlant->"Italic"], "2"]}], ")"}]}], "+", 
   RowBox[{
    FractionBox["1", 
     RowBox[{"\[LeftBracketingBar]", 
      RowBox[{
       StyleBox[
        SubscriptBox[
         StyleBox["r",
          FontWeight->"Bold",
          FontSlant->"Italic"], 
         StyleBox["1",
          FontSlant->"Plain"]],
        FontWeight->"Bold",
        FontSlant->"Italic"], 
       StyleBox["-",
        FontWeight->"Bold",
        FontSlant->"Italic"], 
       SubscriptBox[
        StyleBox["r",
         FontWeight->"Bold",
         FontSlant->"Italic"], "2"]}], "\[RightBracketingBar]"}]], "\[Psi]", 
    RowBox[{"(", 
     RowBox[{
      SubscriptBox[
       StyleBox["r",
        FontWeight->"Bold",
        FontSlant->"Italic"], "1"], ",", 
      SubscriptBox[
       StyleBox["r",
        FontWeight->"Bold",
        FontSlant->"Italic"], "2"]}], ")"}]}]}], "=", 
  RowBox[{
   StyleBox[
    RowBox[{
     StyleBox["E",
      FontSlant->"Italic"], "\[Psi]"}]], 
   RowBox[{"(", 
    RowBox[{
     SubscriptBox[
      StyleBox["r",
       FontWeight->"Bold",
       FontSlant->"Italic"], "1"], ",", 
     SubscriptBox[
      StyleBox["r",
       FontWeight->"Bold",
       FontSlant->"Italic"], "2"]}], ")"}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.810112811439228*^9, 3.8101128248442793`*^9}, {
  3.810479494926491*^9, 3.8104795038498344`*^9}, {3.810479572543576*^9, 
  3.8104796147383184`*^9}, {3.8104802055659895`*^9, 3.8104802433915305`*^9}, {
  3.8104802785189395`*^9, 3.8104802814214115`*^9}, {3.8109915300785556`*^9, 
  3.8109916793993816`*^9}, {3.810991710031681*^9, 3.8109918292023373`*^9}, {
  3.810994488524798*^9, 3.810994499853472*^9}, {3.8109948928195066`*^9, 
  3.8109948950763626`*^9}, {3.8109949491606197`*^9, 3.810995087249513*^9}, {
  3.8109951188614283`*^9, 3.8109951226144466`*^9}, {3.8119443157332587`*^9, 
  3.8119443519616346`*^9}},ExpressionUUID->"7306a647-80e6-6149-88e6-\
ac1121e6876e"],

Cell["\<\
So you can see that in this form, our TISE doesn\[CloseCurlyQuote]t have \
quite so many constants floating about. Another important advantage (that may \
not effect your day-to-day use) is that the units are independent of the \
value of any constants. So, if the value of a constant changes, it doesn\
\[CloseCurlyQuote]t change the value in atomic units, only the value of its \
conversion to SI units. In any case, atomic units are a standard in \
computational chemistry, so you have to get used to using them and converting \
between SI and atomic units.\
\>", "Text",
 CellChangeTimes->{{3.8119443595936565`*^9, 3.811944397304385*^9}, {
  3.811944433678324*^9, 
  3.811944492183591*^9}},ExpressionUUID->"5943a7f2-e243-b743-a0c2-\
eaf48c20c309"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Finding the Energies and Eigenstates of Multielectron Atoms", "Section",
 CellChangeTimes->{{3.8119462005569816`*^9, 
  3.8119462133352156`*^9}},ExpressionUUID->"4c00b52e-612a-4732-ab55-\
a46c733b29f4"],

Cell[CellGroupData[{

Cell["The Challenge of Multielectron Systems\t", "Subsection",
 CellChangeTimes->{{3.8119460978813057`*^9, 3.8119461141688137`*^9}, {
  3.917699630870773*^9, 
  3.9176996370265675`*^9}},ExpressionUUID->"069519c1-1cee-4695-91a6-\
4090d6e06b56"],

Cell[TextData[{
 "As discussed at the end of the lesson on the hydrogen atom, we immediately \
encounter problems in solving the Hamiltonian for even a two-electron system. \
We usually start with the approximation that the nucleus is in a fixed \
position and solve the time-independent Schr\[ODoubleDot]dinger equation for \
electron position relative to the nucleus. This approximation is valid \
because the mass of the nucleus is much greater than the mass of the \
electrons (",
 Cell[BoxData[
  FormBox[
   RowBox[{
    StyleBox["M",
     FontSlant->"Italic"], ">>", 
    SubscriptBox["m", "e"]}], TraditionalForm]],ExpressionUUID->
  "7e793143-0aae-42a8-9ca7-ccb920591812"],
 "), meaning the center of mass is roughly located at the center of the atom. \
Using this simplification, we can write the time-independent \
Schr\[ODoubleDot]dinger equation for the helium atom (2 electrons) as"
}], "Text",
 CellChangeTimes->{{3.917699640656481*^9, 3.917699800410529*^9}, {
  3.918062271773161*^9, 
  3.9180622732543874`*^9}},ExpressionUUID->"f8a1f6a8-57ab-42f0-897a-\
f9565d861c94"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    FractionBox[
     RowBox[{"-", 
      SuperscriptBox["\[HBar]", "2"]}], 
     RowBox[{"2", 
      StyleBox[
       SubscriptBox["m", "e"],
       FontSlant->"Italic"]}]], 
    RowBox[{"(", 
     RowBox[{
      SubsuperscriptBox["\[Del]", "1", "2"], 
      RowBox[{"+", 
       SubsuperscriptBox["\[Del]", "2", "2"]}]}], ")"}], "\[Psi]", 
    RowBox[{"(", 
     RowBox[{
      SubscriptBox[
       StyleBox["r",
        FontWeight->"Bold",
        FontSlant->"Italic"], "1"], ",", " ", 
      SubscriptBox[
       StyleBox["r",
        FontWeight->"Bold",
        FontSlant->"Italic"], "2"]}], ")"}]}], "-", 
   RowBox[{
    FractionBox[
     RowBox[{"2", 
      SuperscriptBox[
       StyleBox["e",
        FontSlant->"Italic"], "2"]}], 
     RowBox[{"4", 
      SubscriptBox["\[Pi]\[Epsilon]", "0"]}]], 
    RowBox[{"(", 
     RowBox[{
      FractionBox["1", 
       SubscriptBox[
        StyleBox["r",
         FontSlant->"Italic"], 
        StyleBox["1",
         FontSlant->"Plain"]]], "+", 
      FractionBox["1", 
       SubscriptBox[
        StyleBox["r",
         FontSlant->"Italic"], 
        StyleBox["2",
         FontSlant->"Plain"]]]}], ")"}], "\[Psi]", 
    RowBox[{"(", 
     RowBox[{
      SubscriptBox[
       StyleBox["r",
        FontWeight->"Bold",
        FontSlant->"Italic"], "1"], ",", 
      SubscriptBox[
       StyleBox["r",
        FontWeight->"Bold",
        FontSlant->"Italic"], "2"]}], ")"}]}], "+", 
   RowBox[{
    FractionBox[
     SuperscriptBox[
      StyleBox["e",
       FontSlant->"Italic"], "2"], 
     RowBox[{"4", 
      SubscriptBox["\[Pi]\[Epsilon]", "0"], 
      RowBox[{"\[LeftBracketingBar]", 
       RowBox[{
        StyleBox[
         SubscriptBox[
          StyleBox["r",
           FontWeight->"Bold",
           FontSlant->"Italic"], 
          StyleBox["1",
           FontSlant->"Plain"]],
         FontWeight->"Bold",
         FontSlant->"Italic"], 
        StyleBox["-",
         FontWeight->"Bold",
         FontSlant->"Italic"], 
        SubscriptBox[
         StyleBox["r",
          FontWeight->"Bold",
          FontSlant->"Italic"], "2"]}], "\[RightBracketingBar]"}]}]], 
    "\[Psi]", 
    RowBox[{"(", 
     RowBox[{
      SubscriptBox[
       StyleBox["r",
        FontWeight->"Bold",
        FontSlant->"Italic"], "1"], ",", 
      SubscriptBox[
       StyleBox["r",
        FontWeight->"Bold",
        FontSlant->"Italic"], "2"]}], ")"}]}]}], "=", 
  RowBox[{
   StyleBox[
    RowBox[{
     StyleBox["E",
      FontSlant->"Italic"], "\[Psi]"}]], 
   RowBox[{"(", 
    RowBox[{
     SubscriptBox[
      StyleBox["r",
       FontWeight->"Bold",
       FontSlant->"Italic"], "1"], ",", 
