  3.9400769933899937`*^9}},ExpressionUUID->"daf04469-2d4f-4ea9-9cbd-\
61763c97293b"],

Cell[BoxData[
 RowBox[{
  RowBox[{"2", 
   StyleBox["V",
    FontSlant->"Italic"], 
   RowBox[{
    StyleBox["(",
     FontSlant->"Italic"], 
    StyleBox["r",
     FontWeight->"Bold",
     FontSlant->"Italic"], ")"}]}], "=", 
  RowBox[{
   StyleBox["\[Mu]",
    FontWeight->"Bold"], "\[CenterDot]", 
   SubscriptBox[
    StyleBox["E",
     FontWeight->"Bold",
     FontSlant->"Italic"], 
    StyleBox["0",
