Cell[TextData[{
 "Note that these quantities are not equivalent. Finally, we can find the \
most probable speed ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["v", "*"], TraditionalForm]],ExpressionUUID->
  "794bd1b4-4d76-46cb-b932-5975d83f11f0"],
 " by taking the derivative of ",
 StyleBox["F",
  FontSlant->"Italic"],
 "(",
 StyleBox["v",
  FontSlant->"Italic"],
 ") with respect to speed and setting equal to zero to find the maximum value,"
}], "Text",
 CellChangeTimes->{{3.9214944810745125`*^9, 3.921494538661482*^9}, {
  3.9214958553112097`*^9, 
  3.921495869538419*^9}},ExpressionUUID->"ead48300-0e13-43db-8db2-\
bc52cdfc643d"],

Cell[BoxData[
 RowBox[{
  FractionBox[
   RowBox[{
    RowBox[{
     StyleBox["\[DifferentialD]",
      FontSlant->"Plain"], 
     StyleBox["F",
      FontSlant->"Italic"]}], 
    StyleBox[
     RowBox[{"(", "v", ")"}],
     FontSlant->"Italic"]}], 
   RowBox[{"\[DifferentialD]", 
    StyleBox["v",
     FontSlant->"Italic"]}]], "=", 
  RowBox[{
   RowBox[{
    StyleBox["4",
     FontSlant->"Plain"], "\[Pi]", " ", 
    SuperscriptBox[
     RowBox[{"(", 
      FractionBox[
       StyleBox["m",
        FontSlant->"Italic"], 
       RowBox[{"2", "\[Pi]", " ", 
        SubscriptBox[
         StyleBox["k",
          FontSlant->"Italic"], 
         StyleBox["B",
          FontSlant->"Italic"]], 
        StyleBox["T",
         FontSlant->"Italic"]}]], ")"}], 
     RowBox[{"3", "/", "2"}]], 
    RowBox[{
     FractionBox[
      StyleBox["\[DifferentialD]",
       FontSlant->"Plain"], 
      RowBox[{"\[DifferentialD]", 
       StyleBox["v",
        FontSlant->"Italic"]}]], 
     FormBox[
      RowBox[{
       SuperscriptBox[
        StyleBox["v",
         FontSlant->"Italic"], "2"], 
       SuperscriptBox["\[ExponentialE]", 
        RowBox[{
         RowBox[{"-", 
          FractionBox[
           StyleBox["m",
            FontSlant->"Italic"], 
           RowBox[{"2", 
            SubscriptBox[
             StyleBox["k",
              FontSlant->"Italic"], 
             StyleBox["B",
              FontSlant->"Italic"]], 
            StyleBox["T",
             FontSlant->"Italic"]}]]}], 
         SuperscriptBox[
          StyleBox["v",
           FontSlant->"Italic"], "2"]}]]}],
      TraditionalForm]}]}], "=", "0"}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.921494564576727*^9, 
