  3.914412012374081*^9}},ExpressionUUID->"cef79266-1a70-437a-a2ee-\
521baf20e7af"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   StyleBox["m",
    FontSlant->"Italic"], 
   FractionBox[
    RowBox[{
     SuperscriptBox["\[DifferentialD]", "2"], 
     StyleBox["s",
      FontSlant->"Italic"]}], 
    RowBox[{"\[DifferentialD]", 
     SuperscriptBox[
      StyleBox["t",
       FontSlant->"Italic"], "2"]}]]}], "=", 
  RowBox[{
   RowBox[{"-", 
    StyleBox["m",
     FontSlant->"Italic"]}], 
   StyleBox[" ",
    FontSlant->"Italic"], 
   StyleBox["g",
    FontSlant->"Italic"], 
   StyleBox[" ",
    FontSlant->"Italic"], "sin", 
   RowBox[{"(", "\[Theta]", ")"}]}]}]], "DisplayFormulaNumbered",
