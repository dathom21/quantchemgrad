    3.813672319678033*^9}},ExpressionUUID->
  "19cff179-4b09-5b4c-a5e6-3816ae180c01"],
 " (e.g., Slater or Gaussian functions), and ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["r",
    FontWeight->"Bold",
    FontSlant->"Italic"], "1"]],
  CellChangeTimes->{{3.810112811439228*^9, 3.8101128248442793`*^9}, {
    3.810479494926491*^9, 3.8104795038498344`*^9}, {3.810479572543576*^9, 
    3.8104796147383184`*^9}, {3.8104802055659895`*^9, 
    3.8104802433915305`*^9}, {3.8104802785189395`*^9, 
    3.8104802814214115`*^9}, {3.8109915300785556`*^9, 
    3.8109916793993816`*^9}, {3.810991710031681*^9, 3.8109918292023373`*^9}, {
    3.810994488524798*^9, 3.810994499853472*^9}, {3.8109948928195066`*^9, 
    3.8109948950763626`*^9}, {3.8109949491606197`*^9, 3.810995087249513*^9}, {
