Cell[CellGroupData[{

Cell["Solving for the Perturbation Terms ", "Subsection",
 CellChangeTimes->{{3.8119380697016144`*^9, 
  3.8119380943707027`*^9}},ExpressionUUID->"ffa512b9-1df5-2144-a5bd-\
b8d0103fef96"],

Cell["\<\
We have now seen how we can conceptually set up the perturbation method, but \
the question now is how we solve for the perturbation terms in the energy and \
wavefunction. To do so, it is easiest to introduce the dimensionless \
parameter \[Lambda] such that\
\>", "Text",
 CellChangeTimes->{{3.8119380985391955`*^9, 
  3.8119381627586365`*^9}},ExpressionUUID->"92fec6f5-427a-8043-bf11-\
e5ba5c88112a"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"(", " ", 
    RowBox[{
     SuperscriptBox[
      OverscriptBox[
       StyleBox["H",
        FontSlant->"Italic"], "^"], 
      RowBox[{"(", "0", ")"}]], "+", 
     RowBox[{"\[Lambda]", 
      StyleBox[
       SuperscriptBox[
        OverscriptBox[
         StyleBox["H",
          FontSlant->"Italic"], "^"], 
        RowBox[{"(", "1", ")"}]],
       FontSlant->"Italic"]}]}], 
    StyleBox[")",
     FontSlant->"Italic"]}], "\[Psi]"}], "=", 
  RowBox[{
   StyleBox["E",
    FontSlant->"Italic"], 
   StyleBox[" ",
    FontSlant->"Italic"], "\[Psi]"}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8079664251944246`*^9, 3.8079664343142004`*^9}, {
   3.8079689400739555`*^9, 3.8079689680029573`*^9}, {3.807970315263204*^9, 
   3.8079703215316095`*^9}, {3.807970415909548*^9, 3.807970437015459*^9}, {
   3.8079705221296997`*^9, 3.8079705895237727`*^9}, {3.809503913366911*^9, 
   3.809503915415073*^9}, 3.80950418131592*^9, {3.810634811313981*^9, 
   3.8106348242505617`*^9}, {3.8106348784099083`*^9, 
   3.8106348981796308`*^9}, {3.8106349903838186`*^9, 
   3.8106350062466736`*^9}, {3.8106350462927155`*^9, 
   3.8106350558036213`*^9}, {3.810635166709814*^9, 3.8106351767461023`*^9}, {
   3.8106356178156724`*^9, 3.8106356424120965`*^9}, {3.8119381719563165`*^9, 
   3.8119381823242064`*^9}},ExpressionUUID->"ac3046dc-87d3-184c-8562-\
278874d0583a"],

Cell["\<\
Then, we expand our eigenstate and energy as power series in \[Lambda],\
\>", "Text",
 CellChangeTimes->{{3.811938197610754*^9, 
  3.811938226044303*^9}},ExpressionUUID->"cf87e035-7bb8-1d45-8595-\
4b14ce22df74"],

Cell[BoxData[
 RowBox[{
  StyleBox["E",
   FontSlant->"Italic"], "=", 
  RowBox[{
   RowBox[{
    UnderscriptBox[
     OverscriptBox["\[Sum]", 
      StyleBox["N",
       FontSlant->"Italic"]], 
     RowBox[{
      StyleBox["i",
       FontSlant->"Italic"], "=", "0"}]], 
    RowBox[{
     SuperscriptBox["\[Lambda]", 
      StyleBox["i",
       FontSlant->"Italic"]], 
     SuperscriptBox[
      StyleBox["E",
       FontSlant->"Italic"], 
      RowBox[{"(", 
       StyleBox["i",
        FontSlant->"Italic"], ")"}]]}]}], "=", 
   RowBox[{
    RowBox[{
     SuperscriptBox[
      StyleBox["E",
       FontSlant->"Italic"], 
      RowBox[{"(", "0", ")"}]], "+", 
     SuperscriptBox[
      StyleBox[
       RowBox[{"\[Lambda]", 
        StyleBox["E",
         FontSlant->"Italic"]}]], 
      RowBox[{"(", "1", ")"}]], "+", 
     RowBox[{
      SuperscriptBox["\[Lambda]", "2"], 
      SuperscriptBox[
       StyleBox["E",
        FontSlant->"Italic"], 
       RowBox[{"(", "2", ")"}]]}], "+"}], 
    "..."}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8079664251944246`*^9, 3.8079664343142004`*^9}, {
   3.8079689400739555`*^9, 3.8079689680029573`*^9}, {3.807970315263204*^9, 
   3.8079703215316095`*^9}, {3.807970415909548*^9, 3.807970437015459*^9}, {
   3.8079705221296997`*^9, 3.8079705895237727`*^9}, {3.809503913366911*^9, 
   3.809503915415073*^9}, 3.80950418131592*^9, {3.810634811313981*^9, 
   3.8106348242505617`*^9}, {3.8106348784099083`*^9, 
   3.8106348981796308`*^9}, {3.8106349903838186`*^9, 
   3.8106350062466736`*^9}, {3.8106350462927155`*^9, 
   3.8106350558036213`*^9}, {3.810635166709814*^9, 3.8106351767461023`*^9}, {
   3.8106354751099353`*^9, 3.810635507828557*^9}, {3.810635543183937*^9, 
   3.810635543871173*^9}, {3.8106356781556664`*^9, 3.8106356860724473`*^9}, {
   3.811938247609317*^9, 3.8119383428288913`*^9}, {3.811938481283187*^9, 
   3.811938482824316*^9}},ExpressionUUID->"3ed6ccfb-e9d3-de49-9227-\
76fcbd909494"],

Cell[BoxData[
 RowBox[{"\[Psi]", "=", 
  RowBox[{
   RowBox[{
    UnderoverscriptBox["\[Sum]", 
     RowBox[{
      StyleBox["i",
       FontSlant->"Italic"], "=", "0"}], 
     StyleBox["N",
      FontSlant->"Italic"]], 
    RowBox[{
     SuperscriptBox["\[Lambda]", 
      StyleBox["i",
       FontSlant->"Italic"]], 
     SuperscriptBox["\[Psi]", 
      RowBox[{"(", 
       StyleBox["i",
        FontSlant->"Italic"], ")"}]]}]}], "=", 
   RowBox[{
    RowBox[{
     SuperscriptBox["\[Psi]", 
      RowBox[{"(", "0", ")"}]], "+", 
     SuperscriptBox["\[Lambda]\[Psi]", 
      RowBox[{"(", "1", ")"}]], "+", 
     RowBox[{
      SuperscriptBox["\[Lambda]", "2"], 
      SuperscriptBox["\[Psi]", 
       RowBox[{"(", "2", ")"}]]}], "+"}], 
    "..."}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8079664251944246`*^9, 3.8079664343142004`*^9}, {
   3.8079689400739555`*^9, 3.8079689680029573`*^9}, {3.807970315263204*^9, 
   3.8079703215316095`*^9}, {3.807970415909548*^9, 3.807970437015459*^9}, {
   3.8079705221296997`*^9, 3.8079705895237727`*^9}, {3.809503913366911*^9, 
   3.809503915415073*^9}, 3.80950418131592*^9, {3.810634811313981*^9, 
   3.8106348242505617`*^9}, {3.8106348784099083`*^9, 
   3.8106348981796308`*^9}, {3.8106349903838186`*^9, 
   3.8106350062466736`*^9}, {3.8106350462927155`*^9, 
   3.8106350558036213`*^9}, {3.810635166709814*^9, 3.8106351767461023`*^9}, {
   3.8106354751099353`*^9, 3.810635546028044*^9}, {3.810635697370509*^9, 
   3.8106357005160756`*^9}, {3.8119383491709647`*^9, 3.811938353816743*^9}, {
   3.811938488483486*^9, 
   3.811938508035467*^9}},ExpressionUUID->"49075e71-6eb6-864c-ab44-\
f65b0ec06bef"],

Cell[TextData[{
 "where ",
 StyleBox["N",
  FontSlant->"Italic"],
 " gives the number of terms that we are considering. In general, the terms \
become less important as ",
 StyleBox["i",
  FontSlant->"Italic"],
 " increases, so we usually truncate after some number of terms. We can then \
generally write the TISE as"
}], "Text",
 CellChangeTimes->{{3.8119383919191084`*^9, 3.811938404651066*^9}, {
  3.811938519204866*^9, 
  3.8119385485427637`*^9}},ExpressionUUID->"5a7fedc9-66e6-9941-ae64-\
868730ca661c"],

