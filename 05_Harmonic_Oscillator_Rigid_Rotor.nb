 StyleBox["Figure 5.7",
  FontWeight->"Bold"],
 ". Illustration of the defining variables for spherical coordinates, \
Andeggs, Wikimedia, 2019, Public Domain, \
https://commons.wikimedia.org/wiki/File:3D_Spherical.svg"
}], "Affiliation",
 CellChangeTimes->{{3.809435027311596*^9, 3.8094350763900714`*^9}, {
  3.80943583474421*^9, 3.8094358359299717`*^9}, {3.8094472165104203`*^9, 
  3.809447281165168*^9}, {3.810054221304062*^9, 3.8100542409148703`*^9}, {
  3.8101125924447937`*^9, 3.8101126426025887`*^9}, {3.8101127071459217`*^9, 
  3.810112714050138*^9}, {3.810115126505663*^9, 3.810115154403865*^9}, {
  3.8101152097595587`*^9, 3.8101152368678613`*^9}, {3.915801038939829*^9, 
  3.915801041537567*^9}},ExpressionUUID->"4bce7f03-0c00-4ad4-9aa0-\
0b41b0389de0"],

Cell["\<\
The definition of the spherical coordinates in terms of the Cartesian \
coordinates is given by\
\>", "Text",
 CellChangeTimes->{{3.81011530197873*^9, 
  3.810115327503893*^9}},ExpressionUUID->"ba4cbdcb-0e98-497f-9a32-\
7cf00583970c"],

Cell[BoxData[
 RowBox[{
  StyleBox["r",
   FontSlant->"Italic"], "=", 
  SuperscriptBox[
   RowBox[{"(", 
    RowBox[{
     SuperscriptBox[
      StyleBox["x",
       FontSlant->"Italic"], "2"], "+", 
     SuperscriptBox[
      StyleBox["y",
       FontSlant->"Italic"], "2"], "+", 
     SuperscriptBox[
      StyleBox["z",
       FontSlant->"Italic"], "2"]}], ")"}], 
   RowBox[{"1", "/", "2"}]]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8101150577108593`*^9, 3.8101150758002863`*^9}, {
  3.810115342492568*^9, 
  3.8101153595690007`*^9}},ExpressionUUID->"4f5db996-dab0-4142-91d8-\
91b43344c9e7"],

Cell[BoxData[
 RowBox[{
  StyleBox[
   RowBox[{"cos", 
    RowBox[{"(", "\[Theta]", ")"}]}],
   FontSlant->"Plain"], "=", 
  FractionBox[
   StyleBox["z",
    FontSlant->"Italic"], 
   SuperscriptBox[
    RowBox[{"(", 
     RowBox[{
      SuperscriptBox[
       StyleBox["x",
        FontSlant->"Italic"], "2"], "+", 
      SuperscriptBox[
       StyleBox["y",
        FontSlant->"Italic"], "2"], "+", 
      SuperscriptBox[
       StyleBox["z",
        FontSlant->"Italic"], "2"]}], ")"}], 
    RowBox[{"1", "/", "2"}]]]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8101150577108593`*^9, 3.8101150892132025`*^9}, {
  3.810115369368109*^9, 
  3.8101154018170767`*^9}},ExpressionUUID->"1f533ee2-5f86-4f6c-9eac-\
b6ea97bdf423"],

Cell[BoxData[
 RowBox[{
  StyleBox[" ",
   FontSlant->"Italic"], 
  RowBox[{
   RowBox[{"tan", 
    RowBox[{"(", "\[Phi]", ")"}]}], "=", 
   FractionBox[
    StyleBox["y",
     FontSlant->"Italic"], 
    StyleBox["x",
     FontSlant->"Italic"]]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8101150577108593`*^9, 3.810115104810896*^9}, {
  3.81011541510189*^9, 
  3.81011544073394*^9}},ExpressionUUID->"baafe32e-3fd0-46ec-afbb-\
9c75e0db4563"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["The Quantum-Mechanical Rigid Rotor", "Section",
 CellChangeTimes->{{3.810112447236733*^9, 3.810112452701408*^9}, {
  3.810118200686208*^9, 
  3.8101182038324966`*^9}},ExpressionUUID->"33d31e1f-49fe-4a12-9cf6-\
8d0ceeb8f304"],

Cell[CellGroupData[{

Cell["The (Classical) Rigid-Rotor Model", "Subsection",
 CellChangeTimes->{{3.8101124726022263`*^9, 3.810112476509534*^9}, {
  3.9158058805698514`*^9, 
  3.9158058829627237`*^9}},ExpressionUUID->"5057b092-3546-4a1b-ac4a-\
9150226b94eb"],

Cell[TextData[{
 "Let\[CloseCurlyQuote]s think again about two point masses ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["m", "1"], TraditionalForm]],ExpressionUUID->
  "1e720f3b-0f45-41d6-a2e2-42019bfe91d6"],
 " and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["m", "2"], TraditionalForm]],ExpressionUUID->
  "ad7206e5-892e-4716-b3e7-5ab8aeb3fe50"],
 " connected at some set distances ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["r", "1"], TraditionalForm]],ExpressionUUID->
  "7f55d7aa-41bb-4970-9e57-9c9108450a0b"],
 " and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["r", "2"], TraditionalForm]],ExpressionUUID->
  "49c4fbb5-d0f6-4b38-bfd3-fb2bf82d71b3"],
 " from the center of mass, as shown in Figure 5.8. Later, we will use this \
model to describe diatomic molecules."
}], "Text",
 CellChangeTimes->{{3.81011248630342*^9, 3.8101125808230453`*^9}, {
  3.8101151243553724`*^9, 3.8101151244617243`*^9}, {3.915801082793229*^9, 
  3.9158010832370863`*^9}, {3.9158011645096407`*^9, 
  3.9158011838511825`*^9}},ExpressionUUID->"aa020c0e-a21a-4670-bb2c-\
f9d293cd39f3"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Import", "[", 
  "\"\<https://upload.wikimedia.org/wikipedia/commons/thumb/b/be/Rigid_rotor_\
point_masses.svg/500px-Rigid_rotor_point_masses.svg.png\>\"", "]"}]], "Input",
 CellChangeTimes->{{3.81011239628605*^9, 3.8101124102734413`*^9}},
 CellLabel->"In[3]:=",ExpressionUUID->"fc50eb28-fe3c-473b-92f7-6346cd44f036"],

Cell[BoxData[
