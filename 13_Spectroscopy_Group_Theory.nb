        SubscriptBox["\[Omega]", 
         StyleBox["mk",
          FontSlant->"Italic"]], "-", "\[Omega]"}], ")"}], 
      StyleBox[" ",
       FontSlant->"Italic"], 
      RowBox[{
       StyleBox["t",
        FontSlant->"Italic"], "/", "2"}]}]], 
    RowBox[{"2", "[", 
     FractionBox[
      RowBox[{" ", 
       RowBox[{
        SuperscriptBox["\[ExponentialE]", 
         RowBox[{"\[ImaginaryI]", " ", 
          RowBox[{"(", 
           RowBox[{
            SubscriptBox["\[Omega]", 
             StyleBox["mk",
              FontSlant->"Italic"]], "-", "\[Omega]"}], ")"}], 
          StyleBox[" ",
           FontSlant->"Italic"], 
          RowBox[{
           StyleBox["t",
            FontSlant->"Italic"], "/", "2"}]}]], "-", 
