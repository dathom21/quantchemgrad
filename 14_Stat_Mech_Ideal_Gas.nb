  3.9213284087140727`*^9}},ExpressionUUID->"6843e303-f60d-4ff9-903b-\
ad5ff2f7f0e7"],

Cell["or, separating the sum of exponents into a product of terms,", "Text",
 CellChangeTimes->{{3.9212533377835035`*^9, 3.921253337919754*^9}, {
  3.921253402123554*^9, 
  3.9212534170274363`*^9}},ExpressionUUID->"bc7456d2-ed74-43f7-a37f-\
e4f96b791ea0"],

Cell[BoxData[
 RowBox[{
  SubscriptBox[
   StyleBox["Z",
    FontSlant->"Italic"], 
   SubscriptBox["\[CurlyEpsilon]", 
    StyleBox["trans",
     FontSlant->"Italic"]]], "=", 
  RowBox[{
   RowBox[{"(", 
    RowBox[{
     SubscriptBox["\[Sum]", 
      SubscriptBox[
       StyleBox["n",
        FontSlant->"Italic"], "x"]], 
     SuperscriptBox["\[ExponentialE]", 
      RowBox[{
       RowBox[{"-", "\[Beta]"}], 
       FractionBox[
        SuperscriptBox[
         StyleBox["h",
          FontSlant->"Italic"], "2"], 
        RowBox[{"8", 
         SuperscriptBox[
          StyleBox["ma",
           FontSlant->"Italic"], "2"]}]], 
       SubsuperscriptBox[
        StyleBox["n",
         FontSlant->"Italic"], 
        StyleBox["x",
         FontSlant->"Italic"], "2"]}]]}], ")"}], 
   RowBox[{"(", 
    RowBox[{
     SubscriptBox["\[Sum]", 
      SubscriptBox[
       StyleBox["n",
        FontSlant->"Italic"], "y"]], 
     SuperscriptBox["\[ExponentialE]", 
      RowBox[{
       RowBox[{"-", "\[Beta]"}], 
       FractionBox[
        SuperscriptBox[
         StyleBox["h",
          FontSlant->"Italic"], "2"], 
        RowBox[{"8", 
         SuperscriptBox[
          StyleBox["ma",
           FontSlant->"Italic"], "2"]}]], 
       SubsuperscriptBox[
        StyleBox["n",
         FontSlant->"Italic"], 
        StyleBox["y",
         FontSlant->"Italic"], "2"]}]]}], ")"}], 
   RowBox[{"(", 
    RowBox[{
     SubscriptBox["\[Sum]", 
      SubscriptBox[
       StyleBox["n",
        FontSlant->"Italic"], "z"]], 
     SuperscriptBox["\[ExponentialE]", 
      RowBox[{
       RowBox[{"-", "\[Beta]"}], 
       FractionBox[
        SuperscriptBox[
         StyleBox["h",
          FontSlant->"Italic"], "2"], 
        RowBox[{"8", 
         SuperscriptBox[
          StyleBox["ma",
           FontSlant->"Italic"], "2"]}]], 
       SubsuperscriptBox[
        StyleBox["n",
         FontSlant->"Italic"], 
        StyleBox["z",
         FontSlant->"Italic"], "2"]}]]}], ")"}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.816606313917019*^9, 3.816606348170246*^9}, {
  3.8166065472626705`*^9, 3.8166065528425016`*^9}, {3.816607096263274*^9, 
  3.8166071319089766`*^9}, {3.8166082792077055`*^9, 3.816608293099399*^9}, {
  3.816608332410132*^9, 3.8166083462110634`*^9}, {3.8166084113469725`*^9, 
  3.8166084137878127`*^9}, {3.8166085853535995`*^9, 3.8166086653266125`*^9}, {
  3.816608708567449*^9, 3.8166087156576424`*^9}, {3.8166092184739776`*^9, 
  3.8166092268161383`*^9}, {3.8166150630343227`*^9, 3.816615085830597*^9}, {
  3.8166172290084677`*^9, 3.8166172362795367`*^9}, {3.81661726771554*^9, 
  3.8166172792306194`*^9}, {3.921252657969633*^9, 3.921252700157872*^9}, {
  3.921253074652234*^9, 3.921253080819618*^9}, {3.9212531883067007`*^9, 
