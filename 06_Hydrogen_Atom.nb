   3.810115171318349*^9},
 CellLabel->"Out[16]=",ExpressionUUID->"04c2a465-10a8-4f07-9bf2-70c25d78bb6f"]
}, {2}]],

Cell[TextData[{
 StyleBox["Figure 6.1",
  FontWeight->"Bold"],
 ". Illustration of the defining variables for spherical coordinates, \
Andeggs, Wikimedia, 2019, Public Domain, \
https://commons.wikimedia.org/wiki/File:3D_Spherical.svg"
}], "Affiliation",
 CellChangeTimes->{{3.809435027311596*^9, 3.8094350763900714`*^9}, {
  3.80943583474421*^9, 3.8094358359299717`*^9}, {3.8094472165104203`*^9, 
  3.809447281165168*^9}, {3.810054221304062*^9, 3.8100542409148703`*^9}, {
  3.8101125924447937`*^9, 3.8101126426025887`*^9}, {3.8101127071459217`*^9, 
  3.810112714050138*^9}, {3.810115126505663*^9, 3.810115154403865*^9}, {
  3.8101152097595587`*^9, 3.8101152368678613`*^9}, {3.8104844563968916`*^9, 
  3.8104844576598825`*^9}, {3.917100546671296*^9, 
  3.917100547023201*^9}},ExpressionUUID->"1316856e-8dfa-470d-b029-\
d8e0d60eec7b"],

Cell[TextData[{
 "We again include a visualization of these units (Figure 6.1) for a more \
straightforward interpretation. Looking at Figure 6.1, we see that ",
 StyleBox["r",
  FontSlant->"Italic"],
 " gives the distance from the origin, \[Theta] gives the polar angle (angle \
to the ",
 StyleBox["z",
  FontSlant->"Italic"],
 " axis), and \[Phi] gives the azimuthal angle (the angle of the projection \
of ",
 StyleBox["r",
  FontSlant->"Italic"],
 " in the ",
 StyleBox["xy ",
  FontSlant->"Italic"],
 "plane with respect to ",
 StyleBox["x",
  FontSlant->"Italic"],
 "). Note also that \[Theta] can take on values between 0 and \[Pi], whereas \
\[Phi] can take on values between 0 and 2\[Pi]."
}], "Text",
 CellChangeTimes->{{3.8104844660323267`*^9, 3.8104844975393915`*^9}, {
  3.810484535575863*^9, 3.8104845665613146`*^9}, {3.8104846989642415`*^9, 
  3.810484748781432*^9}, {3.8104848053442497`*^9, 3.810484826591069*^9}, {
  3.9171005927290735`*^9, 
  3.917100599280822*^9}},ExpressionUUID->"e350dc58-77d6-49cc-ab2e-\
5a0f68a97bfe"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Separation of Variables - Radial and Angular Components", "Subsection",
 CellChangeTimes->{{3.810480994448596*^9, 
  3.810481018942484*^9}},ExpressionUUID->"588d6ee5-77fc-4211-b1ee-\
9df0ce0db6f0"],

Cell[TextData[{
 "To begin the separation of variables, we first multiply both sides of the \
equation by ",
 Cell[BoxData[
  RowBox[{"2", 
   StyleBox[
    SubscriptBox["m", "e"],
    FontSlant->"Italic"], 
   SuperscriptBox[
    StyleBox["r",
     FontSlant->"Italic"], "2"]}]],
  CellChangeTimes->{{3.810112811439228*^9, 3.8101128248442793`*^9}, {
   3.810479494926491*^9, 3.8104795038498344`*^9}, {3.810479572543576*^9, 
   3.8104796147383184`*^9}, {3.8104802055659895`*^9, 
   3.8104802433915305`*^9}, {3.8104802785189395`*^9, 
   3.8104802814214115`*^9}, {3.810480477782269*^9, 3.8104805471507206`*^9}, {
   3.8104805927965565`*^9, 3.810480633017248*^9}},ExpressionUUID->
  "4cf2565a-ad94-483e-a0c0-c60e54e69340"],
 " and rearrange to obtain"
}], "Text",
 CellChangeTimes->{{3.810480678387041*^9, 3.8104807520559025`*^9}, {
  3.8104809213098087`*^9, 3.8104809229384165`*^9}, {3.8107218954967947`*^9, 
  3.810721904027193*^9}},ExpressionUUID->"8ec8a848-c874-4244-b06a-\
f2592658eb75"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"-", 
    RowBox[{
     SuperscriptBox["\[HBar]", "2"], "[", 
     RowBox[{
      FractionBox["\[PartialD]", 
       RowBox[{"\[PartialD]", 
        StyleBox["r",
         FontSlant->"Italic"]}]], 
      RowBox[{"(", 
       RowBox[{
        SuperscriptBox[
         StyleBox["r",
          FontSlant->"Italic"], "2"], 
        FractionBox[
         RowBox[{"\[PartialD]", "\[Psi]"}], 
         RowBox[{"\[PartialD]", 
          StyleBox["r",
           FontSlant->"Italic"]}]]}], ")"}]}], "]"}]}], "-", 
   RowBox[{
    SuperscriptBox["\[HBar]", "2"], "[", 
    RowBox[{
     RowBox[{
      FractionBox["1", 
       RowBox[{"sin", 
        RowBox[{"(", "\[Theta]", ")"}]}]], 
      RowBox[{
       FractionBox["\[PartialD]", 
        RowBox[{"\[PartialD]", "\[Theta]"}]], 
       RowBox[{"(", 
        RowBox[{"sin", 
         RowBox[{"(", "\[Theta]", ")"}], 
         FractionBox[
          RowBox[{"\[PartialD]", "\[Psi]"}], 
          RowBox[{"\[PartialD]", "\[Theta]"}]]}], ")"}]}]}], "+", 
     RowBox[{
      FractionBox["1", 
       RowBox[{
        SuperscriptBox["sin", "2"], 
        RowBox[{"(", "\[Theta]", ")"}]}]], 
      RowBox[{"(", 
       FractionBox[
        RowBox[{
         SuperscriptBox["\[PartialD]", "2"], "\[Psi]"}], 
        RowBox[{"\[PartialD]", 
         SuperscriptBox["\[Phi]", "2"]}]], ")"}]}]}], "]"}], "-", 
   RowBox[{"2", 
    StyleBox[
     SubscriptBox[
      StyleBox["m",
       FontSlant->"Italic"], "e"],
     FontSlant->"Italic"], 
    RowBox[{
     SuperscriptBox[
      StyleBox["r",
       FontSlant->"Italic"], "2"], "[", 
     RowBox[{
      FractionBox[
       SuperscriptBox[
        StyleBox["e",
         FontSlant->"Italic"], "2"], 
       RowBox[{"4", 
        SubscriptBox["\[Pi]\[Epsilon]", "0"], 
        StyleBox["r",
         FontSlant->"Italic"]}]], "+", 
      StyleBox["E",
       FontSlant->"Italic"]}], "]"}], "\[Psi]"}]}], "=", 
  "0"}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.810112811439228*^9, 3.8101128248442793`*^9}, {
  3.810479494926491*^9, 3.8104795038498344`*^9}, {3.810479572543576*^9, 
  3.8104796147383184`*^9}, {3.8104802055659895`*^9, 3.8104802433915305`*^9}, {
  3.8104802785189395`*^9, 3.8104802814214115`*^9}, {3.810480477782269*^9, 
  3.8104805471507206`*^9}, {3.8104805927965565`*^9, 3.810480633017248*^9}, {
  3.8104807595294323`*^9, 
  3.8104809538100047`*^9}},ExpressionUUID->"8bb1a87f-8db3-462f-a7be-\
4f9fa0caef58"],

Cell["\<\
Next, we attempt to separate our wavefunction into radial and angular \
components,\
\>", "Text",
 CellChangeTimes->{{3.8104810555023108`*^9, 
  3.8104810701602335`*^9}},ExpressionUUID->"60de3844-e7c3-4a92-bb83-\
43991a691b90"],

Cell[BoxData[
 RowBox[{
  RowBox[{"\[Psi]", 
   RowBox[{"(", 
    RowBox[{
     StyleBox["r",
      FontSlant->"Italic"], ",", "\[Theta]", ",", "\[Phi]"}], ")"}]}], "=", 
  RowBox[{
   StyleBox["R",
    FontSlant->"Italic"], 
   RowBox[{"(", 
    StyleBox["r",
     FontSlant->"Italic"], ")"}], 
   StyleBox["Y",
    FontSlant->"Italic"], 
   RowBox[{"(", 
    RowBox[{"\[Theta]", ",", "\[Phi]"}], ")"}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.810112811439228*^9, 3.8101128248442793`*^9}, {
  3.810479494926491*^9, 3.8104795038498344`*^9}, {3.810479572543576*^9, 
  3.8104796147383184`*^9}, {3.8104802055659895`*^9, 3.8104802433915305`*^9}, {
  3.8104802785189395`*^9, 3.8104802814214115`*^9}, {3.810480477782269*^9, 
  3.8104805471507206`*^9}, {3.8104810799278173`*^9, 
  3.810481089668992*^9}},ExpressionUUID->"ac10406c-0bbc-4b1b-8727-\
06b717f24626"],

Cell[TextData[{
 "where the ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    StyleBox["R",
     FontSlant->"Italic"], "(", 
    StyleBox["r",
     FontSlant->"Italic"], 
    StyleBox[")",
     FontSlant->"Italic"]}], TraditionalForm]],ExpressionUUID->
  "45d0338e-1194-40cb-84b1-881efaeeede5"],
 " component specifies the wavefunction of the electron with respect to \
distance from the proton ",
 StyleBox["r",
  FontSlant->"Italic"],
 ", and the angular component specifies the wavefunction of the electron with \
respect to orientation around the proton given by the angles \[Theta] and \
\[Phi]."
}], "Text",
 CellChangeTimes->{{3.8107219270262175`*^9, 
  3.8107220030314713`*^9}},ExpressionUUID->"e3d4bc81-365d-4a83-8bb2-\
bf1f558788a4"],

Cell["\<\
Substituting this candidate wavefunction into equation (13) gives\
\>", "Text",
 CellChangeTimes->{{3.8104811055275884`*^9, 3.8104811215537252`*^9}, {
  3.810484400024565*^9, 
  3.8104844001411514`*^9}},ExpressionUUID->"8c571389-b4bf-43d2-8cac-\
1308b58a4828"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"-", 
    RowBox[{
     SuperscriptBox["\[HBar]", "2"], "[", 
     RowBox[{
      FractionBox["\[PartialD]", 
       RowBox[{"\[PartialD]", 
        StyleBox["r",
         FontSlant->"Italic"]}]], 
      RowBox[{"(", 
       RowBox[{
        SuperscriptBox[
         StyleBox["r",
          FontSlant->"Italic"], "2"], 
        FractionBox[
         RowBox[{
          RowBox[{"\[PartialD]", 
           StyleBox["R",
            FontSlant->"Italic"]}], 
          RowBox[{"(", 
           StyleBox["r",
            FontSlant->"Italic"], ")"}], 
          StyleBox["Y",
           FontSlant->"Italic"], 
          RowBox[{"(", 
           RowBox[{"\[Theta]", ",", "\[Phi]"}], ")"}]}], 
         RowBox[{"\[PartialD]", 
          StyleBox["r",
           FontSlant->"Italic"]}]]}], ")"}]}], "]"}]}], "-", 
   RowBox[{
    SuperscriptBox["\[HBar]", "2"], "[", 
    RowBox[{
     RowBox[{
      FractionBox["1", 
       RowBox[{"sin", 
        RowBox[{"(", "\[Theta]", ")"}]}]], 
      RowBox[{
       FractionBox["\[PartialD]", 
        RowBox[{"\[PartialD]", "\[Theta]"}]], 
       RowBox[{"(", 
        RowBox[{"sin", 
         RowBox[{"(", "\[Theta]", ")"}], 
         FractionBox[
          RowBox[{
           RowBox[{"\[PartialD]", 
