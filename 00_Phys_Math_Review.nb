Cell[TextData[{
 "So now we can represent the complex number ",
 StyleBox["z",
  FontSlant->"Italic"],
 " as"
}], "Text",
 CellChangeTimes->{
  3.9339329363812275`*^9},ExpressionUUID->"dd86aa33-6220-fe4e-a4dc-\
7283338fd370"],

Cell[BoxData[
 RowBox[{
  StyleBox["z",
   FontSlant->"Italic"], "=", 
  RowBox[{
   RowBox[{
    StyleBox["x",
     FontSlant->"Italic"], "+", 
    StyleBox[
     RowBox[{"\[ImaginaryI]", 
      StyleBox["y",
       FontSlant->"Italic"]}]]}], "=", 
   RowBox[{
    StyleBox["r",
     FontSlant->"Italic"], 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"cos", " ", "\[Theta]"}], "+", 
      RowBox[{"\[ImaginaryI]", " ", "sin", " ", "\[Theta]"}]}], 
     ")"}]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8395099506475883`*^9, 
  3.8395099927256355`*^9}},ExpressionUUID->"579e4c70-9459-4bf0-9ef9-\
355a4a1d3e83"],

Cell[TextData[{
 "and we can convert our product ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["z", "1"], 
    SubscriptBox["z", "2"]}], TraditionalForm]],ExpressionUUID->
  "3908800b-27b5-4844-a6a2-7c48fb93b32c"],
 " to a form that is easier to understand"
}], "Text",
 CellChangeTimes->{
  3.8395099396381493`*^9, {3.839510003565816*^9, 
   3.8395100312042947`*^9}},ExpressionUUID->"0b610548-1707-4a97-90fb-\
1e29a970889d"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   SubscriptBox[
    StyleBox["z",
     FontSlant->"Italic"], "1"], 
   SubscriptBox[
    StyleBox["z",
     FontSlant->"Italic"], "2"]}], "=", 
  RowBox[{
   SubscriptBox[
    StyleBox["r",
     FontSlant->"Italic"], "1"], 
   RowBox[{"(", 
    RowBox[{
     RowBox[{"cos", " ", 
      SubscriptBox["\[Theta]", "1"]}], "+", 
     RowBox[{"\[ImaginaryI]", " ", "sin", " ", 
      SubscriptBox["\[Theta]", "1"]}]}], ")"}], 
   SubscriptBox[
    StyleBox["r",
     FontSlant->"Italic"], "2"], 
   RowBox[{"(", 
    RowBox[{
     RowBox[{"cos", " ", 
      SubscriptBox["\[Theta]", "2"]}], "+", 
     RowBox[{"\[ImaginaryI]", " ", "sin", " ", 
      SubscriptBox["\[Theta]", "2"]}]}], ")"}]}]}], "\[IndentingNewLine]", 
 RowBox[{"\t", 
  RowBox[{"=", 
   RowBox[{
    SubscriptBox[
     StyleBox["r",
      FontSlant->"Italic"], "1"], 
    RowBox[{
     SubscriptBox[
      StyleBox["r",
       FontSlant->"Italic"], "2"], "[", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"cos", " ", 
         SubscriptBox["\[Theta]", "1"], "cos", " ", 
         SubscriptBox["\[Theta]", "2"]}], "\[Minus]", " ", 
        RowBox[{"sin", " ", 
         SubscriptBox["\[Theta]", "1"], "sin", " ", 
         SubscriptBox["\[Theta]", "2"]}]}], ")"}], "+", 
      RowBox[{"\[ImaginaryI]", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"sin", " ", 
          SubscriptBox["\[Theta]", "1"], "cos", " ", 
          SubscriptBox["\[Theta]", "2"]}], "+", 
         RowBox[{"cos", " ", 
          SubscriptBox["\[Theta]", "1"], "sin", " ", 
          SubscriptBox["\[Theta]", "2"]}]}], ")"}]}]}], 
     "]"}]}]}]}]}], "DisplayFormulaNumbered",
