    3.8130830511844254`*^9}},ExpressionUUID->
  "58f49b74-419f-4fde-b21b-5678d9541ec9"],
 " for given positions of the nuclei ",
 Cell[BoxData[
  FormBox[
   SubscriptBox[
    StyleBox["R",
     FontWeight->"Bold"], "1"], TraditionalForm]],ExpressionUUID->
  "4f91e821-ce4c-4f48-8a79-d565f14551e9"],
 " and ",
