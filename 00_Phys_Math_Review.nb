Cell[TextData[{
 "Setting the two expressions for ",
 Cell[BoxData[
  FractionBox[
   RowBox[{"\[DifferentialD]", 
    StyleBox["p",
     FontSlant->"Italic"]}], 
   RowBox[{"\[DifferentialD]", 
    StyleBox["t",
     FontSlant->"Italic"]}]]],
