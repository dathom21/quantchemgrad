2036957cb585"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   SubscriptBox[
    StyleBox["z",
     FontSlant->"Italic"], "1"], 
   SubscriptBox[
    StyleBox["z",
     FontSlant->"Italic"], "2"]}], "=", 
  RowBox[{
   SubscriptBox[
    StyleBox["r",
     FontSlant->"Italic"], "1"], 
   RowBox[{
    SubscriptBox[
     StyleBox["r",
      FontSlant->"Italic"], "2"], "[", 
    RowBox[{
     RowBox[{"cos", " ", 
      RowBox[{"(", 
       RowBox[{
        SubscriptBox["\[Theta]", "1"], "+", 
        SubscriptBox["\[Theta]", "2"]}], ")"}]}], "+", 
     RowBox[{"\[ImaginaryI]", " ", "sin", 
      RowBox[{"(", 
       RowBox[{
        SubscriptBox["\[Theta]", "1"], "+", 
        SubscriptBox["\[Theta]", "2"]}], ")"}]}]}], 
    "]"}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8395104241135654`*^9, 3.839510426833166*^9}, {
  3.8395104587051334`*^9, 
  3.8395105044231663`*^9}},ExpressionUUID->"97677b72-ad70-438b-8348-\
9ea8fc80eb44"],

Cell["\<\
so when we multiply complex numbers, we multiply the \
\[OpenCurlyDoubleQuote]radii\[CloseCurlyDoubleQuote] (called the moduli) and \
add the \[OpenCurlyDoubleQuote]angles\[CloseCurlyDoubleQuote] (called the \
phases).\
\>", "Text",
 CellChangeTimes->{
  3.8395104102155795`*^9, {3.8395105079252434`*^9, 
   3.8395105090548725`*^9}},ExpressionUUID->"fd98e2d5-3e5d-4774-a3c1-\
647d30d9178e"]
}, Open  ]],

