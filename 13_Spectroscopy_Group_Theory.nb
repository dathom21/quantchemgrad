Cell[TextData[{
 StyleBox["Figure 13.2",
  FontWeight->"Bold"],
 ". An exemplary internuclear potential for a diatomic molecule (solid line) \
can be approximated by a harmonic oscillator potential ",
 Cell[BoxData[
  FormBox[
   RowBox[{"(", 
    RowBox[{
     SuperscriptBox[
      StyleBox["kr",
       FontSlant->"Italic"], "2"], "/", "2"}], ")"}], TraditionalForm]],
  ExpressionUUID->"b122223d-efa5-c040-914c-f5c26901fca7"],
 " in the region around the equilibrium internuclear distance ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["R", "0"], TraditionalForm]],ExpressionUUID->
  "bc521a53-8c66-aa46-9f37-7160f99d1f35"],
 "."
}], "Affiliation",
 CellChangeTimes->{{3.809435027311596*^9, 3.8094350763900714`*^9}, {
  3.80943583474421*^9, 3.8094358359299717`*^9}, {3.8094472165104203`*^9, 
  3.809447281165168*^9}, {3.809510876137825*^9, 3.809510907739876*^9}, {
  3.809968073566992*^9, 3.8099681536568317`*^9}, {3.8412240859806104`*^9, 
  3.841224086260605*^9}, {3.920646721383264*^9, 3.9206467215821095`*^9}, {
  3.920732604509817*^9, 3.9207326053538723`*^9}, {3.9399004580974903`*^9, 
  3.9399004584271545`*^9}},ExpressionUUID->"581aafbc-9622-fb4a-8135-\
18a9a1f0fdb6"],

Cell[TextData[{
 "The minimum of the potential, marked by ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["R", "0"], TraditionalForm]],ExpressionUUID->
  "bc4edb46-bc79-b842-a31f-3e86a39cbc6f"],
 ", corresponds to the equilibrium internuclear distance, which we would \
typically call the bond length. At lower values of ",
 StyleBox["R",
  FontSlant->"Italic"],
 ", the potential energy rises steeply as the two atoms repel each other. At \
larger values of ",
 StyleBox["R",
  FontSlant->"Italic"],
 ", the potential energy increases more slowly and eventually levels off as \
the two atoms are far enough apart that they no longer interact. In the \
region around ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["R", "0"], TraditionalForm]],ExpressionUUID->
  "cccaa498-ecf4-9646-9dfe-a5593d99fab5"],
 ", the shape of the potential can be approximated as that of a harmonic \
oscillator, as shown by the dashed line in Figure 13.2."
}], "Text",
 CellChangeTimes->{{3.8099680110315523`*^9, 3.8099680492879915`*^9}, {
  3.920646738836053*^9, 3.9206467595589633`*^9}, {3.9207326407321467`*^9, 
  3.9207326707515397`*^9}, {3.939900473303707*^9, 
  3.93990047361924*^9}},ExpressionUUID->"ad9b486c-d67b-e242-b205-\
0416ccb76a5d"],

Cell["\<\
In the case of an internuclear potential similar to that shown in Figure \
13.2, the harmonic approximation can do a fairly good job of predicting the \
energies of the ground state and first excited state. That\[CloseCurlyQuote]s \
because at lower energies, the correspondence between the harmonic \
approximation (dashed line) and the true potential (solid line) is best. The \
eigenstates (wavefunctions) and eigenvalues (energies) for the harmonic \
approximation of the diatomic are plotted in Figure 13.3. \
We\[CloseCurlyQuote]ll talk more about anharmonicity and the failings of the \
harmonic approximation as we go along. \
\>", "Text",
 CellChangeTimes->{{3.809968250191147*^9, 3.809968332426784*^9}, {
  3.8099700669029446`*^9, 3.8099700701884007`*^9}, {3.8099701851278334`*^9, 
  3.8099702816126156`*^9}, {3.920646768133907*^9, 3.9206467881886563`*^9}, {
  3.9207326926093845`*^9, 3.920732695161282*^9}, {3.939900476034836*^9, 
  3.939900478939087*^9}},ExpressionUUID->"07b92420-1f28-834b-b853-\
860a5927b643"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"h", "=", "1"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"\[Mu]", "=", "1"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"k", "=", 
     RowBox[{
      RowBox[{"fit", "[", "\"\<ParameterTableEntries\>\"", "]"}], "[", 
      RowBox[{"[", 
       RowBox[{"1", ",", "1"}], "]"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"\[Nu]", "=", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"1", "/", 
        RowBox[{"(", 
         RowBox[{"2", "*", "\[Pi]"}], ")"}]}], ")"}], 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"k", "/", "\[Mu]"}], ")"}], "^", 
       RowBox[{"(", 
        RowBox[{"1", "/", "2"}], ")"}]}]}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"\[Alpha]", "=", 
     SuperscriptBox[
      RowBox[{"(", 
       FractionBox[
        RowBox[{"4", 
         SuperscriptBox["\[Pi]", "2"], "*", "k", 
         StyleBox["*",
          FontSlant->"Italic"], "\[Mu]"}], 
        SuperscriptBox["h", "2"]], ")"}], 
      RowBox[{"(", 
       RowBox[{"1", "/", "2"}], ")"}]]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"norm", "=", 
     RowBox[{
      FractionBox["1", 
       SuperscriptBox[
        RowBox[{"(", 
         RowBox[{
          SuperscriptBox["2", "n"], 
          RowBox[{"n", "!"}]}], ")"}], 
        RowBox[{"(", 
         RowBox[{"1", "/", "2"}], ")"}]]], 
      SuperscriptBox[
       RowBox[{"(", 
        FractionBox["\[Alpha]", "\[Pi]"], ")"}], 
       RowBox[{"1", "/", "4"}]]}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"energies", "=", "\[IndentingNewLine]", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"h", 
        StyleBox["*",
         FontSlant->"Italic"], 
        StyleBox["\[Nu]",
         FontSlant->"Plain"], 
        StyleBox["*",
         FontSlant->"Plain"], 
        RowBox[{"(", 
         RowBox[{"n", "+", 
          FractionBox["1", "2"]}], ")"}]}], ",", 
       RowBox[{"{", 
        RowBox[{"n", ",", "0", ",", "5"}], "}"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Eplotlabels", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"\"\<(\>\"", "<>", 
        RowBox[{"ToString", "[", 
         RowBox[{"InputForm", "[", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{
             RowBox[{"2", "n"}], "+", "1"}], ")"}], "/", "2"}], "]"}], "]"}], 
        "<>", "\"\<)\>\""}], ",", 
       RowBox[{"{", 
        RowBox[{"n", ",", "0", ",", "5"}], "}"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"energiesplot", "=", "\[IndentingNewLine]", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{
            RowBox[{"-", 
             RowBox[{"(", 
              RowBox[{"1", "/", "6"}], ")"}]}], "*", 
            RowBox[{"(", 
             RowBox[{"n", "+", "1"}], ")"}]}], ",", 
           RowBox[{"energies", "[", 
            RowBox[{"[", 
             RowBox[{"n", "+", "1"}], "]"}], "]"}]}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{
            RowBox[{"(", 
             RowBox[{"1", "/", "6"}], ")"}], "*", 
            RowBox[{"(", 
             RowBox[{"n", "+", "1"}], ")"}]}], ",", 
           RowBox[{"energies", "[", 
            RowBox[{"[", 
             RowBox[{"n", "+", "1"}], "]"}], "]"}]}], "}"}]}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"n", ",", "0", ",", "5"}], "}"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"potential", "=", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"1", "/", "2"}], ")"}], "*", "k", "*", 
      RowBox[{"x", "^", "2"}]}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"wf", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"0.05", "*", "norm", "*", 
         RowBox[{"HermiteH", "[", 
          RowBox[{"n", ",", 
           RowBox[{
            SuperscriptBox["\[Alpha]", 
             RowBox[{"1", "/", "2"}]], "x"}]}], "]"}], "*", 
         RowBox[{"Exp", "[", 
          RowBox[{
           RowBox[{"-", "\[Alpha]"}], "*", 
           RowBox[{
            RowBox[{"x", "^", "2"}], "/", "2"}]}], "]"}]}], "+", 
        RowBox[{"energies", "[", 
         RowBox[{"[", 
          RowBox[{"n", "+", "1"}], "]"}], "]"}]}], ",", 
       RowBox[{"{", 
        RowBox[{"n", ",", "0", ",", "5"}], "}"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"wfsquared", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{"0.25", "*", "norm", "*", 
           RowBox[{"HermiteH", "[", 
            RowBox[{"n", ",", 
             RowBox[{
              SuperscriptBox["\[Alpha]", 
               RowBox[{"1", "/", "2"}]], "x"}]}], "]"}], "*", 
           RowBox[{"Exp", "[", 
            RowBox[{
             RowBox[{"-", "\[Alpha]"}], "*", 
             RowBox[{
              RowBox[{"x", "^", "2"}], "/", "2"}]}], "]"}]}], ")"}], "^", 
         "2"}], "+", 
        RowBox[{"energies", "[", 
         RowBox[{"[", 
          RowBox[{"n", "+", "1"}], "]"}], "]"}]}], ",", 
       RowBox[{"{", 
        RowBox[{"n", ",", "0", ",", "5"}], "}"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{"Show", "[", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"Plot", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{
          RowBox[{"De", "*", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{"1", "-", 
              RowBox[{"Exp", "[", 
               RowBox[{
                RowBox[{"-", "a"}], "*", "x"}], "]"}]}], ")"}], "^", "2"}]}], 
          "/.", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"De", "\[Rule]", "1.5"}], ",", 
            RowBox[{"a", "\[Rule]", "1"}]}], "}"}]}], ",", 
         RowBox[{
          RowBox[{
           RowBox[{"(", 
