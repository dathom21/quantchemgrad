Cell["We can simplify equation (102) to the expression", "Text",
 CellChangeTimes->{{3.8118631831074533`*^9, 3.811863202377535*^9}, {
  3.9362804296693993`*^9, 
  3.9362804299542217`*^9}},ExpressionUUID->"cb8586f8-eba5-f14a-aeba-\
50b758b11493"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    FractionBox[
     RowBox[{"\[PartialD]", 
      SubscriptBox[
       StyleBox["E",
        FontSlant->"Italic"], "\[CapitalPhi]"]}], 
     RowBox[{"\[PartialD]", 
      SubscriptBox[
       StyleBox["a",
        FontSlant->"Italic"], 
       StyleBox["k",
        FontSlant->"Italic"]]}]], 
    RowBox[{
     UnderscriptBox["\[Sum]", 
      StyleBox["n",
       FontSlant->"Italic"]], 
     RowBox[{
      UnderscriptBox["\[Sum]", 
       StyleBox["m",
        FontSlant->"Italic"]], 
      RowBox[{
       SubsuperscriptBox[
        StyleBox["a",
         FontSlant->"Italic"], 
        StyleBox["n",
         FontSlant->"Italic"], "\[Star]"], 
       SubscriptBox[
        StyleBox["a",
         FontSlant->"Italic"], 
        StyleBox["m",
         FontSlant->"Italic"]], " ", 
       SubscriptBox[
        StyleBox["S",
         FontSlant->"Italic"], 
        StyleBox["nm",
         FontSlant->"Italic"]]}]}]}]}], "+", 
   RowBox[{"2", 
    SubscriptBox[
     StyleBox["E",
      FontSlant->"Italic"], "\[CapitalPhi]"], 
    RowBox[{
     UnderscriptBox["\[Sum]", 
      StyleBox["n",
       FontSlant->"Italic"]], 
     RowBox[{
      SubscriptBox[
       StyleBox["a",
        FontSlant->"Italic"], 
       StyleBox["n",
        FontSlant->"Italic"]], " ", 
      SubscriptBox[
       StyleBox["S",
        FontSlant->"Italic"], 
       StyleBox["nk",
        FontSlant->"Italic"]]}]}]}]}], "=", 
  RowBox[{"2", 
   RowBox[{
    UnderscriptBox["\[Sum]", 
     StyleBox["n",
      FontSlant->"Italic"]], 
    RowBox[{
     SubscriptBox[
      StyleBox["a",
       FontSlant->"Italic"], 
      StyleBox["n",
       FontSlant->"Italic"]], " ", 
     SubscriptBox[
      StyleBox["H",
       FontSlant->"Italic"], 
      StyleBox["nk",
       FontSlant->"Italic"]], 
     "                                   "}]}]}]}]], "DisplayFormulaNumbered",
