       StyleBox["i",
        FontSlant->"Italic"]], 
      SuperscriptBox["\[Psi]", 
       RowBox[{"(", 
        StyleBox["i",
         FontSlant->"Italic"], ")"}]]}]}], ")"}]}], "=", 
