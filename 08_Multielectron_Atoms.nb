  3.8109948950763626`*^9}, {3.8109949491606197`*^9, 3.810995087249513*^9}, {
  3.8109951188614283`*^9, 
  3.8109951226144466`*^9}},ExpressionUUID->"77bd6d3c-dc33-4651-9962-\
c4587a7dbcf8"],

Cell["where the 1 and 2 designations refer to electrons 1 and 2.", "Text",
 CellChangeTimes->{{3.917699819087042*^9, 
  3.9176998287899704`*^9}},ExpressionUUID->"d057b92b-bd68-4b65-af4f-\
72bcaa8c8457"],

Cell["\<\
Unfortunately, we cannot solve the time-independent Schr\[ODoubleDot]dinger \
equation of the helium atom because of the interelectronic repulsion term in \
the Hamiltonian,\
\>", "Text",
 CellChangeTimes->{{3.8119462611845474`*^9, 3.811946305927994*^9}, {
   3.9176998663370314`*^9, 3.917699869598976*^9}, 
   3.9180622591504903`*^9},ExpressionUUID->"df5b2494-13e6-4cfe-9bdc-\
c65a6f5b235e"],

Cell[BoxData[
 RowBox[{
  FractionBox["1", 
   RowBox[{"\[LeftBracketingBar]", 
    RowBox[{
     StyleBox[
      SubscriptBox[
       StyleBox["r",
        FontWeight->"Bold",
        FontSlant->"Italic"], 
       StyleBox["1",
        FontSlant->"Plain"]],
      FontWeight->"Bold",
      FontSlant->"Italic"], 
     StyleBox["-",
      FontWeight->"Bold",
      FontSlant->"Italic"], 
     SubscriptBox[
      StyleBox["r",
       FontWeight->"Bold",
       FontSlant->"Italic"], "2"]}], "\[RightBracketingBar]"}]], "=", 
  FractionBox["1", 
   SubscriptBox[
    StyleBox["r",
     FontSlant->"Italic"], "12"]]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.811599416354409*^9, 3.8115994609014688`*^9}, 
   3.8119413960962324`*^9, {3.811941457027553*^9, 3.8119414629200516`*^9}, 
   3.8119463355586376`*^9, {3.8119465710827055`*^9, 
   3.8119465807475123`*^9}},ExpressionUUID->"dd5d4e88-6589-4007-bad8-\
294d7f5938c0"],

Cell[TextData[{
 "which depends simultaneously on the positions of electrons 1 and 2, making \
a separation of variables approach impossible. This term only becomes more \
problematic as we add more and more electrons. In general, we can write the \
Hamiltonian for an atom with ",
 StyleBox["N",
  FontSlant->"Italic"],
 " electrons and atomic number ",
 StyleBox["Z",
  FontSlant->"Italic"],
 " as"
}], "Text",
 CellChangeTimes->{{3.8119463386204414`*^9, 3.8119463809398823`*^9}, {
  3.8119465108070827`*^9, 3.8119465177262573`*^9}, {3.9176999255907784`*^9, 
  3.9176999485826483`*^9}},ExpressionUUID->"c0fd89b3-1c1a-4fa7-9dfe-\
0369f7680b5e"],

Cell[BoxData[
 RowBox[{
  OverscriptBox[
   StyleBox["H",
    FontSlant->"Italic"], "^"], "=", 
  RowBox[{
   RowBox[{
    FractionBox[
     RowBox[{"-", 
      SuperscriptBox["\[HBar]", "2"]}], 
     RowBox[{"2", 
      StyleBox[
       SubscriptBox["m", "e"],
       FontSlant->"Italic"]}]], 
    RowBox[{
     OverscriptBox[
      UnderscriptBox["\[Sum]", 
       RowBox[{
        StyleBox["i",
         FontSlant->"Italic"], "=", "1"}]], 
      StyleBox["N",
       FontSlant->"Italic"]], 
     RowBox[{
      RowBox[{
       SubsuperscriptBox["\[Del]", 
        StyleBox["i",
         FontSlant->"Italic"], "2"], 
       RowBox[{"-", 
        FractionBox[
         SuperscriptBox[
          StyleBox["Ze",
           FontSlant->"Italic"], "2"], 
         RowBox[{"4", 
          SubscriptBox["\[Pi]\[Epsilon]", "0"]}]]}]}], 
      RowBox[{
       OverscriptBox[
        UnderscriptBox["\[Sum]", 
         RowBox[{
          StyleBox["i",
           FontSlant->"Italic"], "=", "1"}]], 
        StyleBox["N",
         FontSlant->"Italic"]], 
       FractionBox["1", 
        StyleBox[
         SubscriptBox["r", "i"],
         FontSlant->"Italic"]]}]}]}]}], "+", 
   RowBox[{
    FractionBox[
     SuperscriptBox[
      StyleBox["e",
       FontSlant->"Italic"], "2"], 
     RowBox[{"4", 
      SubscriptBox["\[Pi]\[Epsilon]", "0"]}]], 
    RowBox[{
     OverscriptBox[
      UnderscriptBox["\[Sum]", 
       RowBox[{
        StyleBox["j",
         FontSlant->"Italic"], "\[NotEqual]", 
        StyleBox["i",
         FontSlant->"Italic"]}]], 
      StyleBox["N",
       FontSlant->"Italic"]], 
     FractionBox["1", 
      SubscriptBox[
       StyleBox["r",
        FontSlant->"Italic"], 
       StyleBox["ij",
        FontSlant->"Italic"]]]}]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.811599416354409*^9, 3.8115994609014688`*^9}, 
   3.8119413960962324`*^9, {3.8119464061273136`*^9, 3.8119465031145*^9}, {
   3.8119465354714055`*^9, 3.8119466054644814`*^9}, {3.811946718904114*^9, 
   3.811946729076827*^9}, 3.812120486791659*^9, {3.917699876296336*^9, 
   3.9176999066209555`*^9}},ExpressionUUID->"06c3e0ae-974e-4328-b22a-\
d609d21f8aff"],

Cell["or in atomic units,", "Text",
 CellChangeTimes->{{3.9361807457689667`*^9, 
  3.9361807489759502`*^9}},ExpressionUUID->"1dfcb307-deb8-ca42-a6d0-\
7874209c3411"],

Cell[BoxData[
 RowBox[{
  OverscriptBox[
   StyleBox["H",
    FontSlant->"Italic"], "^"], "=", 
  RowBox[{
   RowBox[{
    FractionBox[
     RowBox[{"-", "1"}], "2"], 
    RowBox[{
     OverscriptBox[
      UnderscriptBox["\[Sum]", 
       RowBox[{
        StyleBox["i",
         FontSlant->"Italic"], "=", "1"}]], 
      StyleBox["N",
       FontSlant->"Italic"]], 
     RowBox[{
      RowBox[{
       SubsuperscriptBox["\[Del]", 
        StyleBox["i",
         FontSlant->"Italic"], "2"], 
       RowBox[{"-", 
        StyleBox["Z",
         FontSlant->"Italic"]}]}], 
      RowBox[{
       OverscriptBox[
        UnderscriptBox["\[Sum]", 
         RowBox[{
          StyleBox["i",
           FontSlant->"Italic"], "=", "1"}]], 
        StyleBox["N",
         FontSlant->"Italic"]], 
       FractionBox["1", 
        StyleBox[
         SubscriptBox["r", "i"],
         FontSlant->"Italic"]]}]}]}]}], "+", 
   RowBox[{
    OverscriptBox[
     UnderscriptBox["\[Sum]", 
      RowBox[{
       StyleBox["j",
        FontSlant->"Italic"], "\[NotEqual]", 
       StyleBox["i",
        FontSlant->"Italic"]}]], 
     StyleBox["N",
      FontSlant->"Italic"]], 
    FractionBox["1", 
     SubscriptBox[
      StyleBox["r",
       FontSlant->"Italic"], 
      StyleBox["ij",
       FontSlant->"Italic"]]]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.811599416354409*^9, 3.8115994609014688`*^9}, 
   3.8119413960962324`*^9, {3.8119464061273136`*^9, 3.8119465031145*^9}, {
   3.8119465354714055`*^9, 3.8119466054644814`*^9}, {3.811946718904114*^9, 
   3.811946729076827*^9}, 
   3.812120486791659*^9},ExpressionUUID->"52326369-dd9e-f34b-b5ef-\
dbaa66c3b855"],

Cell[TextData[{
 "The first term gives the kinetic energy operator for each electron, the \
second term gives the attractive potential between the nucleus and each \
electron, and the third term gives the interelectronic repulsion between each \
pair of electrons. Note that the final sum is over both ",
 StyleBox["j",
  FontSlant->"Italic"],
 " and ",
 StyleBox["i",
  FontSlant->"Italic"],
 " (when ",
 StyleBox["j ",
  FontSlant->"Italic"],
 "\[NotEqual] ",
 StyleBox["i ",
  FontSlant->"Italic"],
 ")."
}], "Text",
 CellChangeTimes->{{3.8119466173424463`*^9, 3.811946656519788*^9}, {
  3.917699966520379*^9, 3.917699999862392*^9}, {3.9177000524066076`*^9, 
  3.9177001082648525`*^9}},ExpressionUUID->"81ffec4e-5aa5-4e74-a4d8-\
b69c2222fcef"],

Cell["\<\
In short, we need a different strategy to identify the wavefunctions of a \
multielectron atom. We will use approximations that allow us to identify the \
form of solutions in these systems.\
\>", "Text",
 CellChangeTimes->{{3.917700110214507*^9, 3.917700138794489*^9}, {
  3.917700276250469*^9, 
  3.9177003684546804`*^9}},ExpressionUUID->"b4d48a58-1b36-45fb-a053-\
c00613d87c46"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Introduction to the Variational Method", "Subsection",
 CellChangeTimes->{{3.8115932126439705`*^9, 
  3.8115932193766127`*^9}},ExpressionUUID->"e2dedb76-1d9c-a948-bc64-\
734055ae4596"],

Cell["\<\
The variational method represents a relatively simple yet highly effective \
approach to solve for the approximate energies and eigenstates of a system \
that cannot be solved analytically.\
\>", "Text",
 CellChangeTimes->{{3.811593123912007*^9, 
  3.8115932346555758`*^9}},ExpressionUUID->"eb966345-9502-a349-91f3-\
eeb50277a383"],

Cell["\<\
Let\[CloseCurlyQuote]s say we have a system that is described by the \
time-independent Schr\[ODoubleDot]dinger equation,\
\>", "Text",
 CellChangeTimes->{{3.811593237149929*^9, 
  3.811593289401831*^9}},ExpressionUUID->"77884a39-b594-e14f-9049-\
b24a9122feba"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{
       OverscriptBox[
        StyleBox["H",
         FontSlant->"Italic"], "^"], "|", "\[Psi]"}], 
      "\[RightAngleBracket]"}], "=", 
     RowBox[{
      StyleBox["E",
       FontSlant->"Italic"], "|", "\[Psi]"}]}], "\[RightAngleBracket]"}], "                                           ", 
   OverscriptBox[
    StyleBox["H",
     FontSlant->"Italic"], "^"], "\[Psi]"}], "=", 
  StyleBox[
   RowBox[{
    StyleBox["E",
     FontSlant->"Italic"], "\[Psi]"}]], "  "}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.811593312893673*^9, 3.8115933831661987`*^9}, {
  3.811593489620569*^9, 
  3.811593494195689*^9}},ExpressionUUID->"7aaaf1f1-c223-314b-baef-\
9106096bbde2"],

Cell[TextData[{
 "where we are now presenting the equation in both bra-ket and traditional \
forms. We are interested in finding the ground-state energy ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["E", "0"], TraditionalForm]],ExpressionUUID->
  "e42925b1-c865-a74a-bea3-11dfa582d2a4"],
 " and wavefunction ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Psi]", "0"], TraditionalForm]],ExpressionUUID->
  "5cb76898-8f1f-1142-ba42-60ed82fc5d7b"],
 ","
}], "Text",
 CellChangeTimes->{{3.811593385723259*^9, 
  3.811593453793307*^9}},ExpressionUUID->"6c500190-5372-2a42-8913-\
b89af7f43be2"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{
       OverscriptBox[
        StyleBox["H",
         FontSlant->"Italic"], "^"], "|", 
       SubscriptBox["\[Psi]", "0"]}], "\[RightAngleBracket]"}], "=", 
     RowBox[{
      SubscriptBox[
       StyleBox["E",
        FontSlant->"Italic"], "0"], "|", 
      SubscriptBox["\[Psi]", "0"]}]}], "\[RightAngleBracket]"}], "                                      ", 
   OverscriptBox[
    StyleBox["H",
     FontSlant->"Italic"], "^"], 
   SubscriptBox["\[Psi]", "0"]}], "=", 
  RowBox[{
   StyleBox[
    SubscriptBox[
     StyleBox["E",
      FontSlant->"Italic"], 
     StyleBox["0",
      FontSlant->"Plain"]],
    FontSlant->"Italic"], 
   SubscriptBox["\[Psi]", "0"], " "}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.811593312893673*^9, 3.8115933831661987`*^9}, {
  3.811593458953679*^9, 
  3.8115934974178753`*^9}},ExpressionUUID->"9102b3cc-0cee-504b-8c35-\
b8a3ef4e8660"],

Cell[TextData[{
 "but we cannot solve the TISE analytically. First, let\[CloseCurlyQuote]s \
obtain an expression for the energy by multiplying both sides of equation \
(10) by the complex conjugate of the ground-state wavefunction ",
 Cell[BoxData[
  SubsuperscriptBox["\[Psi]", "0", "\[Star]"]],
  CellChangeTimes->{{3.811593312893673*^9, 3.8115933831661987`*^9}, {
   3.811593458953679*^9, 3.8115934974178753`*^9}},ExpressionUUID->
  "faff7d96-a2dd-2544-883e-ded89d4e27dd"],
 " and integrating over all space,"
}], "Text",
 CellChangeTimes->{{3.8115935022592125`*^9, 3.8115936010996904`*^9}, {
  3.936357965773018*^9, 
  3.9363579669454517`*^9}},ExpressionUUID->"4ab71734-437d-c246-a40e-\
fbd4c755bcc4"],

Cell[BoxData[
 RowBox[{
  SubscriptBox[
   StyleBox["E",
    FontSlant->"Italic"], "0"], "=", 
  RowBox[{
   RowBox[{
    FractionBox[
     RowBox[{"\[LeftAngleBracket]", 
      RowBox[{
       SubscriptBox["\[Psi]", "0"], "|", 
       OverscriptBox[
        StyleBox["H",
         FontSlant->"Italic"], "^"], "|", 
       SubscriptBox["\[Psi]", "0"]}], "\[RightAngleBracket]"}], 
     RowBox[{
      RowBox[{"\[LeftAngleBracket]", 
       RowBox[{
        SubscriptBox["\[Psi]", "0"], "|", 
        SubscriptBox["\[Psi]", "0"]}], "\[RightAngleBracket]"}], "  "}]], "                                     ", 
    StyleBox[
     SubscriptBox[
      StyleBox["E",
       FontSlant->"Italic"], 
      StyleBox["0",
       FontSlant->"Plain"]],
     FontSlant->"Italic"]}], "=", 
   FractionBox[
    RowBox[{"\[Integral]", 
     RowBox[{
      SubsuperscriptBox["\[Psi]", "0", "\[Star]"], " ", 
      OverscriptBox[
       StyleBox["H",
        FontSlant->"Italic"], "^"], 
      SubscriptBox["\[Psi]", "0"], "d\[Tau]"}]}], 
    RowBox[{"\[Integral]", 
     RowBox[{
      SubsuperscriptBox["\[Psi]", "0", "\[Star]"], 
      SubscriptBox["\[Psi]", "0"], " ", 
      "d\[Tau]"}]}]]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.811593312893673*^9, 3.8115933831661987`*^9}, {
  3.811593458953679*^9, 3.8115934974178753`*^9}, {3.8115936143121653`*^9, 
  3.811593715195953*^9}, {3.811594208013258*^9, 3.811594210677987*^9}, {
  3.811594342816991*^9, 
  3.8115943434093456`*^9}},ExpressionUUID->"4403e2b8-9994-da45-866d-\
a679404f1cce"],

Cell[TextData[{
 "where d\[Tau] is the volume element in whatever coordinates we might be \
working in. As we said, we cannot solve equations (10) or (11) analytically, \
but let\[CloseCurlyQuote]s say we have a trial solution for ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Psi]", "0"], TraditionalForm]],ExpressionUUID->
  "93fbd9c9-a8d5-834d-a472-ea51a6c39987"],
 " that we will call \[Phi]. We can always represent our trial wavefunction \
as a linear combination of the ",
 StyleBox["true",
  FontSlant->"Italic"],
 " eigenstate wavefunctions ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Psi]", "n"], TraditionalForm]],ExpressionUUID->
  "7e2d78f3-f05f-dc4d-9999-0ecbecc08ce4"],
 ","
}], "Text",
 CellChangeTimes->{{3.8115937205215936`*^9, 3.811593740767644*^9}, {
  3.81159384477176*^9, 3.811593868765522*^9}, {3.811593921908203*^9, 
  3.8115940252173147`*^9}, {3.8115941367283325`*^9, 3.8115941402185783`*^9}, {
  3.9363580340909195`*^9, 
  3.936358038262287*^9}},ExpressionUUID->"cb82a6ca-4591-bc4a-a2f2-\
03dfed9a3cfe"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"|", "\[Phi]"}], "\[RightAngleBracket]"}], "=", 
     RowBox[{
      RowBox[{
       UnderscriptBox["\[Sum]", 
        StyleBox["n",
         FontSlant->"Italic"]], 
       SubscriptBox[
        StyleBox["c",
         FontSlant->"Italic"], 
        StyleBox["n",
         FontSlant->"Italic"]]}], "|", 
      SubscriptBox["\[Psi]", 
       StyleBox["n",
        FontSlant->"Italic"]]}]}], "\[RightAngleBracket]"}], "                                       ",
    "\[Phi]"}], "=", 
  RowBox[{
   UnderscriptBox["\[Sum]", 
    StyleBox["n",
     FontSlant->"Italic"]], 
   RowBox[{
    SubscriptBox[
     StyleBox["c",
      FontSlant->"Italic"], 
     StyleBox["n",
      FontSlant->"Italic"]], 
    SubscriptBox["\[Psi]", 
     StyleBox["n",
      FontSlant->"Italic"]], " "}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.811593312893673*^9, 3.8115933831661987`*^9}, {
   3.811593458953679*^9, 3.8115934974178753`*^9}, {3.811594043422389*^9, 
   3.8115940850450926`*^9}, {3.8115941212928057`*^9, 3.81159413134099*^9}, {
   3.8115942129312763`*^9, 3.811594213576462*^9}, {3.811594345555955*^9, 
   3.8115943458791523`*^9}, 
   3.8115943810138807`*^9},ExpressionUUID->"1c25cb31-009f-e145-9a44-\
3da93c647dd1"],

Cell["which have true energy eigenvalues of ", "Text",
 CellChangeTimes->{{3.811594156161291*^9, 
  3.811594168251949*^9}},ExpressionUUID->"996d26c5-6a5d-6444-9781-\
2335d8c197f4"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{
       OverscriptBox[
        StyleBox["H",
         FontSlant->"Italic"], "^"], "|", 
       SubscriptBox["\[Psi]", 
        StyleBox["n",
         FontSlant->"Italic"]]}], "\[RightAngleBracket]"}], "=", 
     RowBox[{
      SubscriptBox[
       StyleBox["E",
        FontSlant->"Italic"], 
       StyleBox["n",
        FontSlant->"Italic"]], "|", 
      SubscriptBox["\[Psi]", 
       StyleBox["n",
        FontSlant->"Italic"]]}]}], "\[RightAngleBracket]"}], "                                         ", 
   OverscriptBox[
    StyleBox["H",
     FontSlant->"Italic"], "^"], 
   SubscriptBox["\[Psi]", 
    StyleBox["n",
     FontSlant->"Italic"]]}], "=", 
  RowBox[{
   SubscriptBox[
    StyleBox["E",
     FontSlant->"Italic"], 
    StyleBox["n",
     FontSlant->"Italic"]], 
   SubscriptBox["\[Psi]", 
    StyleBox["n",
     FontSlant->"Italic"]], "  "}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.811593312893673*^9, 3.8115933831661987`*^9}, {
  3.811593458953679*^9, 3.8115934974178753`*^9}, {3.811594043422389*^9, 
  3.8115940850450926`*^9}, {3.8115941212928057`*^9, 3.81159413134099*^9}, {
  3.811594181720907*^9, 3.811594235556464*^9}, {3.811594348112458*^9, 
  3.8115943482923613`*^9}},ExpressionUUID->"d80c3eeb-5233-1247-bb12-\
2953d986feee"],

Cell["\<\
Remember that all of the true eigenstate wavefunctions are orthonormal, \
meaning\
\>", "Text",
 CellChangeTimes->{{3.811594259692378*^9, 3.8115942861044073`*^9}, {
  3.8115945027883244`*^9, 
  3.8115945084175205`*^9}},ExpressionUUID->"998bad61-b42f-754b-8515-\
b3df7d47d3ce"],

Cell[BoxData[
 RowBox[{
  RowBox[{"\[LeftAngleBracket]", 
   RowBox[{
    SubscriptBox["\[Psi]", 
     StyleBox["m",
      FontSlant->"Italic"]], "|", 
    SubscriptBox["\[Psi]", 
     StyleBox["n",
      FontSlant->"Italic"]]}], "\[RightAngleBracket]"}], "=", 
  RowBox[{
   RowBox[{
    SubscriptBox["\[Delta]", 
     StyleBox["mn",
      FontSlant->"Italic"]], "                     ", 
    RowBox[{"\[Integral]", 
     RowBox[{
      SubsuperscriptBox["\[Psi]", 
       StyleBox["m",
        FontSlant->"Italic"], "\[Star]"], 
      SubscriptBox["\[Psi]", 
       StyleBox["n",
        FontSlant->"Italic"]], " ", "d\[Tau]"}]}]}], "=", 
   SubscriptBox["\[Delta]", 
    StyleBox["mn",
     FontSlant->"Italic"]]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.811593312893673*^9, 3.8115933831661987`*^9}, {
  3.811593458953679*^9, 3.8115934974178753`*^9}, {3.811594043422389*^9, 
  3.8115940850450926`*^9}, {3.8115941212928057`*^9, 3.81159413134099*^9}, {
  3.811594181720907*^9, 3.811594235556464*^9}, {3.811594295698657*^9, 
  3.8115943609193563`*^9}},ExpressionUUID->"61e61b8d-c438-4446-8b22-\
b52ed6c511e5"],

Cell["Also note that, in accordance with our typical nomenclature,", "Text",
 CellChangeTimes->{{3.811594523579607*^9, 
  3.811594532572073*^9}},ExpressionUUID->"124ee5d5-93f3-184e-94b4-\
65070ec8c4d2"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   SubscriptBox[
    StyleBox["E",
     FontSlant->"Italic"], "0"], "<", 
   SubscriptBox[
    StyleBox["E",
     FontSlant->"Italic"], "1"], "<", 
   SubscriptBox[
    StyleBox["E",
     FontSlant->"Italic"], "2"], "<"}], "..."}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.811593312893673*^9, 3.8115933831661987`*^9}, {
