818d0f460583"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   StyleBox["u",
    FontSlant->"Italic"], 
   RowBox[{"(", 
    RowBox[{
     StyleBox["x",
      FontSlant->"Italic"], ",", 
     StyleBox["t",
      FontSlant->"Italic"]}], ")"}]}], "=", 
  RowBox[{
   RowBox[{
    UnderoverscriptBox["\[Sum]", 
     RowBox[{
      StyleBox["n",
       FontSlant->"Italic"], "=", "1"}], "\[Infinity]"], 
    RowBox[{
     SubscriptBox[
      StyleBox["u",
       FontSlant->"Italic"], 
      StyleBox["n",
       FontSlant->"Italic"]], 
     RowBox[{"(", 
      RowBox[{
       StyleBox["x",
        FontSlant->"Italic"], ",", 
       StyleBox["t",
        FontSlant->"Italic"]}], ")"}]}]}], "=", 
   RowBox[{
    UnderoverscriptBox["\[Sum]", 
     RowBox[{
      StyleBox["n",
       FontSlant->"Italic"], "=", "1"}], "\[Infinity]"], 
    RowBox[{
     SubscriptBox[
      StyleBox["A",
       FontSlant->"Italic"], 
      StyleBox["n",
       FontSlant->"Italic"]], 
     FormBox[
      RowBox[{"cos", "(", 
       RowBox[{
        RowBox[{
         SubscriptBox["\[Omega]", 
          StyleBox["n",
           FontSlant->"Italic"]], 
         StyleBox["t",
          FontSlant->"Italic"]}], "+", 
        SubscriptBox["\[Phi]", "n"]}], ")"}],
      TraditionalForm], "sin", 
     RowBox[{"(", 
      StyleBox[
       FractionBox[
        StyleBox[
         RowBox[{
          StyleBox["n",
           FontSlant->"Italic"], "\[Pi]", 
          StyleBox["x",
           FontSlant->"Italic"]}]], 
        StyleBox["L",
         FontSlant->"Italic"]],
       FontSlant->"Italic"], ")"}]}]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8078941581472354`*^9, 3.8078941889516497`*^9}, {
  3.8078942212544575`*^9, 
  3.8078942560922747`*^9}},ExpressionUUID->"9122e2df-cd96-49cc-bc23-\
3f7f632f8926"],

Cell[TextData[{
 "The specific solutions form a ",
 StyleBox["complete set",
  FontSlant->"Italic"],
 ", meaning we can describe any motion of the vibrating string by a sum of \
the specific solutions. Below in Figure 2.2 is a demonstration of the sum, or \
superposition, of states in a vibrating string. Notice that in superposition \
states, the total displacement of the string from its center position is \
decreased, and this effect is a manifestation of destructive interference, \
meaning the waves are canceling each other out."
}], "Text",
 CellChangeTimes->{{3.807894432415739*^9, 3.8078945608959703`*^9}, {
  3.9146666301840363`*^9, 
  3.9146667386668463`*^9}},ExpressionUUID->"01ded9ce-e7f0-4c55-98e7-\
5ebb3c1471c8"],

Cell["\<\
In quantum mechanics, we will often encounter solutions that are represented \
as a sum of specific solutions, and these will be referred to as \
superposition states. The vibrating string provides a nice introduction to \
these ideas. There are, however, big differences between superpositions on a \
vibrating string and superposition states in quantum mechanics that we\
\[CloseCurlyQuote]ll discuss later.\
\>", "Text",
 CellChangeTimes->{
  3.914666693086627*^9, {3.9146667606947155`*^9, 
   3.914666761054479*^9}},ExpressionUUID->"dc5c47c8-6740-4143-acc7-\
ebfad9e004d0"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"b", "=", "2"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"L", "=", "1"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"\[Mu]", " ", "=", " ", "1"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"F", "=", "1"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"f", "[", "x_", "]"}], ":=", 
  RowBox[{"Piecewise", "[", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"b", " ", "x"}], ",", 
       RowBox[{"x", "<", 
        FractionBox["L", "2"]}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"b", 
        RowBox[{"(", 
         RowBox[{"L", "-", "x"}], ")"}]}], ",", 
       RowBox[{"x", ">=", 
        RowBox[{"L", "/", "2"}]}]}], "}"}]}], "}"}], "]"}]}], "\n", 
 RowBox[{
