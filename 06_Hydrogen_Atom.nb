      FontSlant->"Plain"], 
     StyleBox[" ",
      FontSlant->"Plain"], 
     RowBox[{
      StyleBox["\[DifferentialD]",
       FontSlant->"Plain"], "\[Theta]"}], " ", 
     StyleBox[
      RowBox[{"\[DifferentialD]", "\[Phi]"}],
      FontSlant->"Plain"], 
     StyleBox[" ",
      FontSlant->"Plain"], 
     RowBox[{
      StyleBox["\[DifferentialD]",
       FontSlant->"Plain"], 
      StyleBox["r",
       FontSlant->"Italic"]}]}]}]}]}]], "DisplayFormulaNumbered",
