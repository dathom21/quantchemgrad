Cell[TextData[{
 "We can visualize the orientation of the angular momentum in a vector space \
as shown in Figure 6.2 for ",
 StyleBox["l",
  FontSlant->"Italic"],
 " = 2 and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["m", "l"], TraditionalForm]],ExpressionUUID->
  "721c0170-74d1-4b4a-ab7d-2dbc36153416"],
 " = \[Minus]2, \[Minus]1, 0, 1, and 2. For a given value of ",
 StyleBox["l",
  FontSlant->"Italic"],
 " and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["m", "l"], TraditionalForm]],ExpressionUUID->
  "de18f2ef-8948-4d9a-b227-26434a3f988b"],
 ", the angular momentum vector ",
 StyleBox["L",
  FontWeight->"Bold",
  FontSlant->"Italic"],
 " of magnitude  ",
 Cell[BoxData[
  SuperscriptBox[
   RowBox[{"\[HBar]", "[", 
    RowBox[{
     StyleBox["l",
      FontSlant->"Italic"], 
     RowBox[{
      StyleBox["(",
       FontSlant->"Italic"], 
      RowBox[{
       StyleBox["l",
        FontSlant->"Italic"], "+", "1"}], ")"}]}], "]"}], 
   RowBox[{"1", "/", "2"}]]],
  CellChangeTimes->{{3.810112811439228*^9, 3.8101128248442793`*^9}, {
    3.810479494926491*^9, 3.8104795038498344`*^9}, {3.810479572543576*^9, 
    3.8104796147383184`*^9}, {3.8104802055659895`*^9, 
    3.8104802433915305`*^9}, {3.8104802785189395`*^9, 
    3.8104802814214115`*^9}, {3.810480477782269*^9, 3.8104805471507206`*^9}, {
