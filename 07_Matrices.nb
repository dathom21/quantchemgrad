         FontSlant->"Italic"], "33"]},
      {
       SubscriptBox[
        StyleBox["a",
         FontSlant->"Italic"], "21"], 
       SubscriptBox[
        StyleBox["a",
         FontSlant->"Italic"], "22"], 
       SubscriptBox[
        StyleBox["a",
         FontSlant->"Italic"], "23"]},
      {
       SubscriptBox[
        StyleBox["a",
         FontSlant->"Italic"], "11"], 
       SubscriptBox[
        StyleBox["a",
         FontSlant->"Italic"], "12"], 
       SubscriptBox[
        StyleBox["a",
         FontSlant->"Italic"], "13"]}
     }], "]"}]}]}]], "Input",
 CellChangeTimes->{{3.8113181472109995`*^9, 3.811318156487506*^9}, {
  3.8113190932904644`*^9, 3.811319097465457*^9}},
 CellLabel->"In[14]:=",ExpressionUUID->"802a4d1f-1262-43c3-83a9-6e9b732e80b5"],

