         FontSlant->"Italic"], 
        StyleBox["\[Pi]",
         FontSlant->"Plain"]}]]], ")"}], 
    RowBox[{"(", 
     FractionBox[
      StyleBox[
       RowBox[{
        StyleBox["n",
         FontSlant->"Italic"], "\[Pi]"}]], "2"], ")"}]}], "=", 
   "1"}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8079664251944246`*^9, 3.8079664343142004`*^9}, {
