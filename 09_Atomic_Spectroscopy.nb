 CellLabel->"Out[23]=",ExpressionUUID->"10c5b431-09b8-427f-bf61-319a42bea31e"]
}, {2}]],

Cell[TextData[{
 StyleBox["Figure 8.5",
  FontWeight->"Bold"],
 ". Depiction of the addition of orbital angular momentum vector ",
 StyleBox["L",
  FontWeight->"Bold",
  FontSlant->"Italic"],
 StyleBox[" ",
  FontWeight->"Bold"],
 "and spin angular momentum vector ",
 StyleBox["S",
  FontWeight->"Bold",
  FontSlant->"Italic"],
 " to give the total angular momentum vector ",
 StyleBox["J",
  FontWeight->"Bold",
  FontSlant->"Italic"],
 "."
}], "Affiliation",
 CellChangeTimes->{{3.809435027311596*^9, 3.8094350763900714`*^9}, {
  3.80943583474421*^9, 3.8094358359299717`*^9}, {3.8094472165104203`*^9, 
  3.809447281165168*^9}, {3.810054221304062*^9, 3.8100542409148703`*^9}, {
  3.8101125924447937`*^9, 3.8101126426025887`*^9}, {3.8101127071459217`*^9, 
  3.810112714050138*^9}, {3.810115126505663*^9, 3.810115154403865*^9}, {
  3.8101152097595587`*^9, 3.8101152368678613`*^9}, {3.8104844563968916`*^9, 
  3.8104844576598825`*^9}, {3.810716456400798*^9, 3.8107166740108333`*^9}, {
  3.810716839152422*^9, 3.8107168476612215`*^9}, {3.8107171062759004`*^9, 
  3.8107171338184347`*^9}, {3.8107173818819304`*^9, 3.81071741604937*^9}, {
  3.8127335786160326`*^9, 3.8127335799592395`*^9}, {3.812733619587339*^9, 
  3.812733624639125*^9}, {3.812733931147242*^9, 3.81273398308552*^9}, {
  3.9184049364736953`*^9, 3.918404938561827*^9}, {3.9184054304789867`*^9, 
  3.918405430587735*^9}},ExpressionUUID->"55c2cdc3-ad16-4b8e-8963-\
6d682332a7f1"],

Cell[TextData[{
 "Remember that the angular momentum of the atom results from the interaction \
of ",
 StyleBox["L",
  FontWeight->"Bold",
  FontSlant->"Italic"],
 " and ",
 StyleBox["S",
  FontWeight->"Bold",
  FontSlant->"Italic"],
 ", "
}], "Text",
 CellChangeTimes->{{3.812881328180502*^9, 
  3.812881416672545*^9}},ExpressionUUID->"a2b9eaab-2c72-49c6-9032-\
676fdf885035"],

Cell[BoxData[
 RowBox[{" ", 
  RowBox[{
   StyleBox["J",
    FontWeight->"Bold",
    FontSlant->"Italic"], "=", 
   RowBox[{
    StyleBox["L",
     FontWeight->"Bold",
     FontSlant->"Italic"], "+", 
    StyleBox["S",
     FontWeight->"Bold",
     FontSlant->"Italic"]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.812881449949911*^9, 
  3.812881455960946*^9}},ExpressionUUID->"c31e17c2-3fe6-4cd4-8a6c-\
4988b9901de1"],

Cell[TextData[{
 "This sum is an addition of vectors. Note that in this picture, the ",
 StyleBox["z",
  FontSlant->"Italic"],
 " components of ",
 StyleBox["S",
  FontWeight->"Bold",
  FontSlant->"Italic"],
 " and ",
 StyleBox["L",
  FontWeight->"Bold",
  FontSlant->"Italic"],
 " are not conserved (they change depending on where on the \
\[OpenCurlyDoubleQuote]circle\[CloseCurlyDoubleQuote] of  ",
 StyleBox["S",
  FontWeight->"Bold",
  FontSlant->"Italic"],
 " and ",
 StyleBox["L",
  FontWeight->"Bold",
  FontSlant->"Italic"],
 "  the values lie); only the ",
 StyleBox["z",
  FontSlant->"Italic"],
 " component of ",
 StyleBox["J",
  FontWeight->"Bold",
  FontSlant->"Italic"],
 " is conserved. Because of relativistic effects that we \
won\[CloseCurlyQuote]t discuss further, in the end we have an additional \
spin-orbit term in the Hamiltonian of a multielectron atom,"
}], "Text",
 CellChangeTimes->{{3.812881462408715*^9, 3.8128816421324415`*^9}, {
  3.812881867038513*^9, 3.812881892054226*^9}, {3.8128819891721835`*^9, 
  3.8128819915379314`*^9}, {3.8128827463820615`*^9, 3.8128827474365196`*^9}, {
  3.9184052403742266`*^9, 
  3.9184052830208864`*^9}},ExpressionUUID->"b37ce117-6f98-4a0f-a32a-\
69e1a1f07b8e"],

Cell[BoxData[
 RowBox[{
  OverscriptBox[
   StyleBox["H",
    FontSlant->"Italic"], "^"], "=", 
  RowBox[{
   SuperscriptBox[
    OverscriptBox[
     StyleBox["H",
      FontSlant->"Italic"], "^"], 
    RowBox[{"(", "0", ")"}]], "+", 
   SuperscriptBox[
    SubscriptBox[
     OverscriptBox[
      StyleBox["H",
       FontSlant->"Italic"], "^"], "SO"], 
    RowBox[{"(", "1", ")"}]]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.812881994854436*^9, 
  3.8128820305803022`*^9}},ExpressionUUID->"80d1127d-dc29-43bc-bf6d-\
cf2aa20611f7"],

Cell[TextData[{
 "where ",
 Cell[BoxData[
  SuperscriptBox[
   OverscriptBox[
    StyleBox["H",
     FontSlant->"Italic"], "^"], 
   RowBox[{"(", "0", ")"}]]],
  CellChangeTimes->{{3.812881994854436*^9, 3.8128820305803022`*^9}},
  ExpressionUUID->"47937790-1d97-4dc3-bead-60d863ee7df0"],
 " is the wavefunction without spin-orbit coupling and ",
 Cell[BoxData[
  SuperscriptBox[
   SubscriptBox[
    OverscriptBox[
     StyleBox["H",
      FontSlant->"Italic"], "^"], "SO"], 
   RowBox[{"(", "1", ")"}]]],
  CellChangeTimes->{{3.812881994854436*^9, 3.8128820305803022`*^9}},
  ExpressionUUID->"4f43e0a2-2931-4707-842e-0b009222dbd2"],
 "is the spin orbit term given by"
}], "Text",
 CellChangeTimes->{{3.812882036097887*^9, 
  3.8128820565216527`*^9}},ExpressionUUID->"9c8f76cc-b5b7-4a4e-9a65-\
c72beccdeaf9"],

Cell[BoxData[
 RowBox[{
  SuperscriptBox[
   SubscriptBox[
    OverscriptBox[
     StyleBox["H",
      FontSlant->"Italic"], "^"], "SO"], 
   RowBox[{"(", "1", ")"}]], "=", 
  RowBox[{
   StyleBox["f",
    FontSlant->"Italic"], 
   RowBox[{
    StyleBox["(",
     FontSlant->"Italic"], 
    SubscriptBox[
     StyleBox["r",
      FontSlant->"Italic"], "i"], ")"}], 
   RowBox[{
    StyleBox["L",
     FontWeight->"Bold",
     FontSlant->"Italic"], "\[CenterDot]", 
    StyleBox["S",
     FontWeight->"Bold",
     FontSlant->"Italic"]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.812881994854436*^9, 3.8128820305803022`*^9}, {
  3.812882062784882*^9, 
  3.8128820970395336`*^9}},ExpressionUUID->"7bf8f77a-4327-418c-a3cd-\
d68936c7c0d9"],

Cell[TextData[{
 "The function ",
 Cell[BoxData[
  RowBox[{
   StyleBox["f",
    FontSlant->"Italic"], 
   RowBox[{
    StyleBox["(",
     FontSlant->"Italic"], 
    SubscriptBox[
     StyleBox["r",
      FontSlant->"Italic"], "i"], ")"}]}]],
  CellChangeTimes->{{3.812881994854436*^9, 3.8128820305803022`*^9}, {
   3.812882062784882*^9, 3.8128820970395336`*^9}},ExpressionUUID->
  "418a4367-88ea-4fde-8183-4e2cec31a529"],
 "is a function of the distance from the nucleus for electron",
 StyleBox[" i",
  FontSlant->"Italic"],
 ", but we won\[CloseCurlyQuote]t worry about its form right now. Based on \
this Hamiltonian, we can write an approximation that the change in energy of \
a given state will be given by"
}], "Text",
 CellChangeTimes->{{3.8128820999703903`*^9, 3.8128821441811857`*^9}, {
  3.812882218032731*^9, 3.812882246430559*^9}, {3.918405320544634*^9, 
  3.9184053288876047`*^9}},ExpressionUUID->"6c905db2-b35b-444e-84b5-\
778ccb3be56a"],

Cell[BoxData[
 RowBox[{"\[LeftAngleBracket]", 
  RowBox[{
   SuperscriptBox["\[Psi]", 
    RowBox[{"(", "0", ")"}]], "|", 
   SuperscriptBox[
    SubscriptBox[
     OverscriptBox[
      StyleBox["H",
       FontSlant->"Italic"], "^"], "SO"], 
    RowBox[{"(", "1", ")"}]], "|", 
   SuperscriptBox["\[Psi]", 
    RowBox[{"(", "0", ")"}]]}], 
  "\[RightAngleBracket]"}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.812881994854436*^9, 3.8128820305803022`*^9}, {
   3.812882062784882*^9, 3.8128820970395336`*^9}, {3.8128821538399343`*^9, 
   3.8128821952741175`*^9}, {3.936889252203129*^9, 3.9368892844111233`*^9}, 
   3.936889321329382*^9},ExpressionUUID->"6c27bd6d-3b2a-4678-a994-\
378a11940afb"],

Cell[TextData[{
 "We won\[CloseCurlyQuote]t concern ourselves with evaluating this quantity \
at this point. The takeaway for you is that ",
 StyleBox["as a result of Russell-Saunders coupling, states with different \
values of ",
  FontWeight->"Bold"],
 StyleBox["J",
  FontWeight->"Bold",
  FontSlant->"Italic"],
 StyleBox[" have different energies",
  FontWeight->"Bold"],
 " (there are further splittings between states with the same ",
 StyleBox["J",
  FontSlant->"Italic"],
 " values, but we won\[CloseCurlyQuote]t discuss them for now). These \
splittings are very small compared to those between ",
 StyleBox["n",
  FontSlant->"Italic"],
 " energy levels, for example, but they can still be observed \
spectroscopically."
}], "Text",
 CellChangeTimes->{{3.8128822628263903`*^9, 3.812882298057457*^9}, {
  3.8128823990360217`*^9, 3.81288241981944*^9}, {3.812882589245826*^9, 
  3.812882617442793*^9}, {3.8128826718175306`*^9, 
  3.8128826948243923`*^9}},ExpressionUUID->"3789e502-4b77-4c5d-86db-\
8c9ec67f123d"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Allowed Transitions between States", "Subsection",
 CellChangeTimes->{{3.918405361548031*^9, 
  3.918405365791197*^9}},ExpressionUUID->"9b9a69e4-2f04-4f14-baa0-\
4ae8411bfd8a"],

Cell[TextData[{
 "There are only certain allowed values for the transition between states \
with different values of ",
 StyleBox["S",
  FontSlant->"Italic"],
 ", ",
 StyleBox["L",
  FontSlant->"Italic"],
 ", and ",
 StyleBox["J",
  FontSlant->"Italic"],
 ", which largely arise as a result of the fact that light itself has spin \
angular momentum, and angular momentum must be conserved. \
We\[CloseCurlyQuote]ll perhaps discuss this topic in more detail later, but \
for now, we can just state that the selection rules for atomic transitions are"
}], "Text",
 CellChangeTimes->{{3.812882729699523*^9, 3.8128827360643597`*^9}, {
  3.8128827751737285`*^9, 3.812882859001135*^9}, {3.9184053717866783`*^9, 
  3.91840537355865*^9}},ExpressionUUID->"34d6d661-6998-49a0-a046-\
5dc9aef53ba1"],

Cell[BoxData[{
 RowBox[{
  StyleBox[
   RowBox[{"\[CapitalDelta]", 
    StyleBox["l",
     FontSlant->"Italic"]}]], "=", 
  RowBox[{"\[PlusMinus]", "1"}]}], "\[IndentingNewLine]", 
 RowBox[{
  StyleBox[
   RowBox[{"\[CapitalDelta]", 
    StyleBox["S",
     FontSlant->"Italic"]}]], "=", " ", "0"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   StyleBox[
    RowBox[{"\[CapitalDelta]", 
     StyleBox["L",
      FontSlant->"Italic"]}]], "=", " ", "0"}], ",", 
  RowBox[{"\[PlusMinus]", "1"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   StyleBox[
    RowBox[{"\[CapitalDelta]", 
     StyleBox["J",
      FontSlant->"Italic"]}]], "=", " ", "0"}], ",", 
  RowBox[{"\[PlusMinus]", "1"}]}]}], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8128828703231153`*^9, 3.8128829261756916`*^9}, {
  3.918473773486642*^9, 3.918473797129794*^9}, {3.9184738381570845`*^9, 
  3.918473841287404*^9}, {3.9184741219969206`*^9, 
  3.9184741223301167`*^9}},ExpressionUUID->"4f9f3aa6-9921-4f11-a9af-\
0eac9a128d24"],

Cell[TextData[{
 "The first requirement refers to the orbital angular momentum of an \
individual electron, whereas the final three refer to the overall atom \
angular momenta. In addition, a transition from a state of ",
 StyleBox["J",
  FontSlant->"Italic"],
 " = 0 to different state with ",
 StyleBox["J",
  FontSlant->"Italic"],
 " = 0 is also forbidden. Note that transitions between states with different \
total spin angular momentum (e.g., triplet and singlet states) are forbidden. \
Using the information from selection rules and term symbols, we can rewrite \
the energy level diagram of Figure 8.3 as shown in Figure 8.6. Note that now \
the states are separated and denoted based upon their term symbol. Each line \
marks a transition of a valence electron between the marked states. \nNote \
that overall, these selection rules are only valid for light atoms (atomic \
number approximately less than 40); for heavier elements, the selection rules \
break down due to a phenomenon known as ",
 StyleBox["J, J ",
  FontSlant->"Italic"],
 "coupling, and we have to use a different scheme."
}], "Text",
 CellChangeTimes->{{3.8128829323209763`*^9, 3.812882951199428*^9}, {
  3.8128915605999327`*^9, 3.8128916150128956`*^9}, {3.8128919458674097`*^9, 
  3.812891994159505*^9}, {3.8128920430450726`*^9, 3.8128920619001493`*^9}, {
  3.918405444781274*^9, 3.918405445325751*^9}, {3.918405592906188*^9, 
  3.9184057137886357`*^9}, {3.9184738151339984`*^9, 3.918473872266538*^9}, {
  3.9184741251279964`*^9, 
  3.9184741646089573`*^9}},ExpressionUUID->"53d0dbd1-d14d-475d-bc48-\
a3c9edf5635c"],

