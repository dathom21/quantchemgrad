  3.811867364850176*^9}},ExpressionUUID->"872824b6-0dcc-4846-ab21-\
75d2a972b003"],

Cell[TextData[{
 "Grouping our terms by order of ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["E",
    FontSlant->"Italic"], "\[CapitalPhi]"]],
  CellChangeTimes->{{3.811867187960767*^9, 3.811867203632437*^9}},
  ExpressionUUID->"598827f4-c66f-e04c-91bb-03b952daecd9"],
 " gives"
}], "Text",
 CellChangeTimes->{{3.8118672192391353`*^9, 
  3.8118672347549114`*^9}},ExpressionUUID->"e4caf9b5-cd28-1642-a6a8-\
340366e57e91"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"(", 
     RowBox[{"1", "-", 
      SubsuperscriptBox[
       StyleBox["S",
        FontSlant->"Italic"], "12", "2"]}], ")"}], 
    SubsuperscriptBox[
     StyleBox["E",
      FontSlant->"Italic"], "\[CapitalPhi]", "2"]}], "+", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{"2", 
       SubscriptBox[
        StyleBox["H",
         FontSlant->"Italic"], "12"], 
       SubscriptBox[
        StyleBox["S",
         FontSlant->"Italic"], "12"]}], "-", 
      SubscriptBox[
       StyleBox["H",
        FontSlant->"Italic"], "11"], "-", 
      SubscriptBox[
       StyleBox["H",
        FontSlant->"Italic"], "22"]}], ")"}], 
    SubscriptBox[
     StyleBox["E",
      FontSlant->"Italic"], "\[CapitalPhi]"]}], "+", 
   RowBox[{"(", 
    RowBox[{
     RowBox[{
      SubscriptBox[
       StyleBox["H",
        FontSlant->"Italic"], "11"], 
      SubscriptBox[
       StyleBox["H",
        FontSlant->"Italic"], "22"]}], "-", 
     SubsuperscriptBox[
      StyleBox["H",
       FontSlant->"Italic"], "12", "2"]}], ")"}]}], "=", 
  "0"}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.811867187960767*^9, 3.811867203632437*^9}, {
  3.8118673980508423`*^9, 3.8118674057434216`*^9}, {3.8118675600949745`*^9, 
  3.81186770185857*^9}},ExpressionUUID->"b029ddfd-2cdf-f54f-b0fa-\
8d521fa3666c"],

Cell[TextData[{
 "We can see that this equation is quadratic in ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["E",
    FontSlant->"Italic"], "\[CapitalPhi]"]],
  CellChangeTimes->{{3.811867187960767*^9, 3.811867203632437*^9}, {
   3.8118673980508423`*^9, 3.8118674057434216`*^9}, {3.8118675600949745`*^9, 
   3.81186770185857*^9}},ExpressionUUID->
  "6ecbe57d-96ae-ac46-8f09-7f84581ef266"],
 ", so we will get two solutions for ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["E",
    FontSlant->"Italic"], "\[CapitalPhi]"]],
  CellChangeTimes->{{3.811867187960767*^9, 3.811867203632437*^9}, {
   3.8118673980508423`*^9, 3.8118674057434216`*^9}, {3.8118675600949745`*^9, 
   3.81186770185857*^9}},ExpressionUUID->
  "bc1cba4a-2fce-5244-8750-8093c1011e3c"],
 " given by the quadratic equation, "
}], "Text",
 CellChangeTimes->{{3.8118677558859205`*^9, 
  3.8118677875605655`*^9}},ExpressionUUID->"f78e99b2-0df1-2e44-a092-\
d5720ce2b2f4"],

Cell[BoxData[
 RowBox[{
  SubscriptBox[
   StyleBox["E",
    FontSlant->"Italic"], "\[CapitalPhi]"], "=", 
  FractionBox[
   RowBox[{
    RowBox[{"-", 
     StyleBox["b",
      FontSlant->"Italic"]}], "\[PlusMinus]", 
    SqrtBox[
     RowBox[{
      SuperscriptBox[
       StyleBox["b",
        FontSlant->"Italic"], "2"], "-", 
      RowBox[{"4", 
       StyleBox["a",
        FontSlant->"Italic"], 
       StyleBox[" ",
        FontSlant->"Italic"], 
       StyleBox["c",
        FontSlant->"Italic"]}]}]]}], 
   RowBox[{"2", 
    StyleBox["a",
     FontSlant->"Italic"]}]]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.811867187960767*^9, 3.811867203632437*^9}, {
  3.8118673980508423`*^9, 3.8118674057434216`*^9}, {3.8118675600949745`*^9, 
