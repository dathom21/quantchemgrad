Cell[CellGroupData[{

Cell[TextData[{
 "Reflection through Plane of Symmetry: ",
 Cell[BoxData[
  FormBox[
   OverscriptBox["\[Sigma]", "^"], TraditionalForm]],ExpressionUUID->
  "56e3b5e4-e08e-40d0-9399-a72fa8a30bca"]
}], "Subsubsection",
 CellChangeTimes->{{3.8162565493533583`*^9, 
  3.816256567998787*^9}},ExpressionUUID->"e3f59514-9729-4eac-9ec8-\
4f1d10e712f9"],

Cell[TextData[{
 "In this symmetry operation, reflection of all atom positions through a \
plane leaves the molecule unchanged. The corresponding planes are labeled \
with the symbol \[Sigma]. For molecules that also have an axis of symmetry, \
the plane labels contain an additional subscript that denotes the orientation \
of the plane with respect to the axis of symmetry. If the plane includes the \
axis of symmetry, it is labeled as ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Sigma]", "v"], TraditionalForm]],ExpressionUUID->
  "8818d962-6333-4f35-a947-830d30993952"],
 " for vertical mirror plane, and if it is perpendicular to the axis of \
symmetry, it is labeled ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Sigma]", "h"], TraditionalForm]],ExpressionUUID->
  "bfddaba7-fb49-4412-ae7f-69fcd85580da"],
 " for horizontal mirror plane. There is also a dihedral mirror plane ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Sigma]", "d"], TraditionalForm]],ExpressionUUID->
  "f3c3c581-77ee-4ef4-b3c0-3a2065e8308e"],
 ", which denotes a vertical mirror plane that bisects the angle between \
additional ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["C", "2"], TraditionalForm]],ExpressionUUID->
  "686fad81-6a35-4eb2-9229-4a49f539c247"],
 " rotation axes. The symmetry planes of water and benzene are shown in \
Figure 13.11."
}], "Text",
 CellChangeTimes->{{3.8162566112165833`*^9, 3.816256817266827*^9}, {
   3.816256901378662*^9, 3.8162569654773135`*^9}, {3.816257332640002*^9, 
   3.8162573429597406`*^9}, 3.939895343363636*^9, {3.9400904775321426`*^9, 
   3.9400904789471016`*^9}},ExpressionUUID->"9300f7d7-831b-4883-95e1-\
06637ad46fc5"],

