  3.811862462284094*^9}},ExpressionUUID->"14252039-7f21-3f4d-9c27-\
2cb915282f1c"],

Cell[TextData[{
 "If we differentiate both sides of equation (98) with respect to ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["a",
    FontSlant->"Italic"], 
   StyleBox["k",
    FontSlant->"Italic"]]],
  CellChangeTimes->{{3.811593312893673*^9, 3.8115933831661987`*^9}, {
   3.811593458953679*^9, 3.8115934974178753`*^9}, {3.8115936143121653`*^9, 
   3.811593715195953*^9}, {3.811594208013258*^9, 3.811594210677987*^9}, {
   3.811594342816991*^9, 3.8115943434093456`*^9}, {3.811594623901507*^9, 
   3.811594670874273*^9}, {3.8115948564704037`*^9, 3.8115948589878416`*^9}, {
   3.8115949257053156`*^9, 3.811594926820971*^9}, {3.8118594909971013`*^9, 
   3.8118595100044374`*^9}, {3.811861225074663*^9, 3.8118612380287175`*^9}, {
   3.811861337070103*^9, 3.811861354268696*^9}},ExpressionUUID->
  "6ccf0aee-70e1-0e4a-a4d6-eaf91be2467c"],
 ", we obtain"
}], "Text",
 CellChangeTimes->{{3.8118625026253557`*^9, 3.811862545630536*^9}, {
  3.9362803940595646`*^9, 
  3.936280394170786*^9}},ExpressionUUID->"517e27d3-9e9f-6443-a04a-\
492f40e3662c"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    FractionBox[
     RowBox[{"\[PartialD]", 
      SubscriptBox[
       StyleBox["E",
        FontSlant->"Italic"], "\[CapitalPhi]"]}], 
     RowBox[{"\[PartialD]", 
      SubscriptBox[
       StyleBox["a",
        FontSlant->"Italic"], 
       StyleBox["k",
        FontSlant->"Italic"]]}]], 
    RowBox[{
     UnderscriptBox["\[Sum]", 
      StyleBox["n",
       FontSlant->"Italic"]], 
     RowBox[{
      UnderscriptBox["\[Sum]", 
       StyleBox["m",
        FontSlant->"Italic"]], 
      RowBox[{
       SubsuperscriptBox[
        StyleBox["a",
         FontSlant->"Italic"], 
        StyleBox["n",
         FontSlant->"Italic"], "\[Star]"], 
       SubscriptBox[
        StyleBox["a",
         FontSlant->"Italic"], 
        StyleBox["m",
         FontSlant->"Italic"]], " ", 
       SubscriptBox[
        StyleBox["S",
         FontSlant->"Italic"], 
        StyleBox["nm",
         FontSlant->"Italic"]]}]}]}]}], "+", 
   RowBox[{
    SubscriptBox[
     StyleBox["E",
      FontSlant->"Italic"], "\[CapitalPhi]"], 
    RowBox[{
     UnderscriptBox["\[Sum]", 
      StyleBox["n",
       FontSlant->"Italic"]], 
     RowBox[{
      UnderscriptBox["\[Sum]", 
       StyleBox["m",
        FontSlant->"Italic"]], 
      RowBox[{"[", 
       RowBox[{
        RowBox[{
         FractionBox[
          RowBox[{"\[PartialD]", 
           SubsuperscriptBox[
            StyleBox["a",
             FontSlant->"Italic"], 
            StyleBox["n",
             FontSlant->"Italic"], "\[Star]"]}], 
          RowBox[{"\[PartialD]", 
           SubscriptBox[
            StyleBox["a",
             FontSlant->"Italic"], 
            StyleBox["k",
             FontSlant->"Italic"]]}]], 
         SubscriptBox[
          StyleBox["a",
           FontSlant->"Italic"], 
          StyleBox["m",
           FontSlant->"Italic"]], " ", 
         SubscriptBox[
          StyleBox["S",
           FontSlant->"Italic"], 
          StyleBox["nm",
           FontSlant->"Italic"]]}], "+", 
        RowBox[{
         FractionBox[
          RowBox[{"\[PartialD]", 
           SubscriptBox[
            StyleBox["a",
             FontSlant->"Italic"], 
            StyleBox["m",
             FontSlant->"Italic"]]}], 
          RowBox[{"\[PartialD]", 
           SubscriptBox[
            StyleBox["a",
             FontSlant->"Italic"], 
            StyleBox["k",
             FontSlant->"Italic"]]}]], 
         SubsuperscriptBox[
          StyleBox["a",
           FontSlant->"Italic"], 
          StyleBox["n",
           FontSlant->"Italic"], "\[Star]"], " ", 
         SubscriptBox[
          StyleBox["S",
           FontSlant->"Italic"], 
          StyleBox["nm",
           FontSlant->"Italic"]]}]}], "]"}]}]}]}]}], "=", 
  RowBox[{
   UnderscriptBox["\[Sum]", 
    StyleBox["n",
     FontSlant->"Italic"]], 
   RowBox[{
    UnderscriptBox["\[Sum]", 
     StyleBox["m",
      FontSlant->"Italic"]], 
    RowBox[{
     RowBox[{"[", 
      RowBox[{
       RowBox[{
        FractionBox[
         RowBox[{"\[PartialD]", 
          SubsuperscriptBox[
           StyleBox["a",
            FontSlant->"Italic"], 
           StyleBox["n",
            FontSlant->"Italic"], "\[Star]"]}], 
         RowBox[{"\[PartialD]", 
          SubscriptBox[
           StyleBox["a",
            FontSlant->"Italic"], 
           StyleBox["k",
            FontSlant->"Italic"]]}]], 
        SubscriptBox[
         StyleBox["a",
          FontSlant->"Italic"], 
         StyleBox["m",
          FontSlant->"Italic"]]}], "+", 
       RowBox[{
        FractionBox[
         RowBox[{"\[PartialD]", 
          SubscriptBox[
           StyleBox["a",
            FontSlant->"Italic"], 
           StyleBox["m",
            FontSlant->"Italic"]]}], 
         RowBox[{"\[PartialD]", 
          SubscriptBox[
           StyleBox["a",
            FontSlant->"Italic"], 
           StyleBox["k",
            FontSlant->"Italic"]]}]], 
        SubsuperscriptBox[
         StyleBox["a",
          FontSlant->"Italic"], 
         StyleBox["n",
          FontSlant->"Italic"], "\[Star]"]}]}], "]"}], " ", 
     SubscriptBox[
      StyleBox["H",
       FontSlant->"Italic"], 
      StyleBox["nm",
       FontSlant->"Italic"]], 
     "                                   "}]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.811593312893673*^9, 3.8115933831661987`*^9}, {
