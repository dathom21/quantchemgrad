 RowBox[{
  StyleBox["S",
   FontSlant->"Italic"], "=", 
  RowBox[{
   RowBox[{"\[LeftAngleBracket]", 
    RowBox[{
     SubscriptBox["\[Phi]", 
      RowBox[{"1", 
       SubscriptBox[
        StyleBox["s",
