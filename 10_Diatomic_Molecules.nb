Cell[BoxData[
 RowBox[{
  RowBox[{
   SubscriptBox[
    OverscriptBox[
     StyleBox["T",
      FontSlant->"Italic"], "^"], 
    StyleBox["N",
     FontSlant->"Italic"]], 
   RowBox[{"(", 
    StyleBox["R",
     FontSlant->"Italic"], 
    StyleBox[")",
     FontSlant->"Italic"]}]}], "=", 
  RowBox[{"-", 
   RowBox[{
    UnderscriptBox["\[Sum]", 
     StyleBox["A",
      FontSlant->"Italic"]], 
    RowBox[{
     FractionBox["1", 
      RowBox[{"2", 
       SubscriptBox[
        StyleBox["M",
         FontSlant->"Italic"], 
        StyleBox["A",
         FontSlant->"Italic"]]}]], 
     SubsuperscriptBox["\[Del]", 
      StyleBox["A",
       FontSlant->"Italic"], "2"]}]}]}]}]], "DisplayFormulaNumbered",
