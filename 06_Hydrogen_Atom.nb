Cell["\<\
The results of solving the radial equation also require that the energy be \
quantized to values given by\
\>", "Text",
 CellChangeTimes->{{3.810657719955079*^9, 
  3.8106577604447794`*^9}},ExpressionUUID->"6685d35d-8df0-4abf-a17d-\
0712f58a7945"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   StyleBox[
    SubscriptBox["E", "n"],
    FontSlant->"Italic"], "=", 
   RowBox[{
    RowBox[{"-", 
     FractionBox[
      RowBox[{
       StyleBox[
        SubscriptBox[
         StyleBox["m",
          FontSlant->"Italic"], "e"],
        FontSlant->"Italic"], 
       SuperscriptBox[
        StyleBox["e",
         FontSlant->"Italic"], "4"]}], 
      RowBox[{"32", 
       SuperscriptBox["\[Pi]", "2"], 
       SubsuperscriptBox["\[Epsilon]", "0", "2"], 
       SuperscriptBox["\[HBar]", "2"], 
       SuperscriptBox[
        StyleBox["n",
         FontSlant->"Italic"], "2"]}]]}], "=", 
    RowBox[{
     RowBox[{
      RowBox[{"-", 
       FractionBox[
        SuperscriptBox[
         StyleBox["e",
          FontSlant->"Italic"], "2"], 
        RowBox[{"8", 
         SubscriptBox["\[Pi]\[Epsilon]", "0"], 
         SubscriptBox[
          StyleBox["a",
           FontSlant->"Italic"], "0"], 
         SuperscriptBox[
          StyleBox["n",
           FontSlant->"Italic"], "2"]}]]}], "          ", 
      StyleBox["n",
       FontSlant->"Italic"]}], 
     StyleBox[" ",
      FontSlant->"Italic"], "=", " ", "1"}]}]}], ",", "2", ",", "3", ",", 
  "..."}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.810112811439228*^9, 3.8101128248442793`*^9}, {
   3.810479494926491*^9, 3.8104795038498344`*^9}, {3.810479572543576*^9, 
   3.8104796147383184`*^9}, {3.8104802055659895`*^9, 
   3.8104802433915305`*^9}, {3.8104802785189395`*^9, 
   3.8104802814214115`*^9}, {3.810480477782269*^9, 3.8104805471507206`*^9}, {
   3.8104805927965565`*^9, 3.810480633017248*^9}, {3.8104807595294323`*^9, 
   3.8104809538100047`*^9}, {3.8104811300285854`*^9, 
   3.8104811403007636`*^9}, {3.8104812580010843`*^9, 
   3.8104813317580833`*^9}, {3.81048146789211*^9, 3.8104815557630205`*^9}, {
   3.8104817202872114`*^9, 3.810481734754242*^9}, 3.8104817893244157`*^9, 
   3.8104818340696*^9, {3.810481916620369*^9, 3.8104819219809136`*^9}, {
   3.8106540212534976`*^9, 3.8106540299597287`*^9}, {3.810654713305319*^9, 
   3.8106549124509315`*^9}, {3.810655268685783*^9, 3.810655351286878*^9}, {
   3.8106553862793045`*^9, 3.8106553879372163`*^9}, {3.810656491191622*^9, 
   3.8106564992968655`*^9}, {3.810657787287384*^9, 
   3.8106579309749165`*^9}},ExpressionUUID->"2cde6517-78a5-4442-ba80-\
4c5e0c06004a"],

Cell[TextData[{
 "Note that the energy levels depend only on ",
 StyleBox["n",
  FontSlant->"Italic"],
 ", not on ",
 StyleBox["l",
  FontSlant->"Italic"],
 " or ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["m",
    FontSlant->"Italic"], 
   StyleBox["l",
    FontSlant->"Italic"]]],
  CellChangeTimes->{{3.810483192695999*^9, 3.810483197963916*^9}, {
    3.8106449127367277`*^9, 3.810645017074294*^9}, {3.8106456352739797`*^9, 
    3.8106456520772038`*^9}, 3.810645955559409*^9, {3.917022289909156*^9, 
    3.91702229654428*^9}},ExpressionUUID->
  "9f3c1772-25ae-44d5-9465-6db036e0d444"],
 ", meaning that these different wavefunctions must be degenerate. In other \
words, there are multiple wavefunctions (eigenfunctions) with the same energy \
(eigenvalue)."
}], "Text",
 CellChangeTimes->{{3.810657989078074*^9, 3.8106580432714243`*^9}, {
  3.917022678116788*^9, 
  3.9170226783002214`*^9}},ExpressionUUID->"4d67bda3-09aa-42e5-92a6-\
b6bf3ee10107"],

Cell[TextData[{
 "The radial solutions of equation (70) look quite complex when written out, \
but in the end they are just a collection of polynomials (see the table of \
Laguerre polynomials) multiplying an exponentially decaying function ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[ExponentialE]", 
    RowBox[{
     RowBox[{"-", "r"}], "/", 
     RowBox[{"(", 
      SubscriptBox[
       StyleBox["na",
        FontSlant->"Italic"], "0"], ")"}]}]], TraditionalForm]],
  ExpressionUUID->"002fd3f3-428e-452b-86c9-9f3d22216f2c"],
 ". As written in equation (70), these functions are normalized such that"
}], "Text",
 CellChangeTimes->{{3.8106581026377597`*^9, 3.810658278118537*^9}, {
   3.8420243147293396`*^9, 3.8420243266528416`*^9}, 
   3.916413121652209*^9},ExpressionUUID->"4ceab6c6-92bd-4e1d-80a4-\
e48491f11c59"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   SubsuperscriptBox["\[Integral]", "0", "\[Infinity]"], 
   RowBox[{
    SubsuperscriptBox[
     StyleBox["R",
      FontSlant->"Italic"], 
     StyleBox["nl",
      FontSlant->"Italic"], "\[Star]"], 
    RowBox[{"(", 
     StyleBox["r",
      FontSlant->"Italic"], ")"}], 
    SubscriptBox[
     StyleBox["R",
      FontSlant->"Italic"], 
     StyleBox["nl",
