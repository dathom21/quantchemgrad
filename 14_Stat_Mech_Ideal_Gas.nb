   3.9214920315060596`*^9, 
   3.9214920764371147`*^9}},ExpressionUUID->"ab6420b6-dd09-424d-99fd-\
b8118a1c0979"],

Cell["\<\
Because each coordinate must be equivalent in our gas where properties are \
independent of direction,\
\>", "Text",
 CellChangeTimes->{{3.9214332974472427`*^9, 3.92143332348948*^9}, {
  3.921491767006198*^9, 
  3.9214917870384073`*^9}},ExpressionUUID->"06738ad9-90ca-4461-85c0-\
88f710594757"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   FractionBox["1", "3"], 
   RowBox[{"\[LeftAngleBracket]", 
    SuperscriptBox[
     StyleBox["v",
      FontSlant->"Italic"], "2"], "\[RightAngleBracket]"}]}], "=", 
  RowBox[{
   RowBox[{"\[LeftAngleBracket]", 
    SubsuperscriptBox["v", "x", "2"], "\[RightAngleBracket]"}], "=", 
   RowBox[{
    RowBox[{"\[LeftAngleBracket]", 
     SubsuperscriptBox["v", "y", "2"], "\[RightAngleBracket]"}], "=", 
    RowBox[{
     RowBox[{"\[LeftAngleBracket]", 
      SubsuperscriptBox["v", "z", "2"], "\[RightAngleBracket]"}], "=", 
     FractionBox[
      RowBox[{
       SubscriptBox[
        StyleBox["k",
         FontSlant->"Italic"], 
        StyleBox["B",
         FontSlant->"Italic"]], 
       StyleBox["T",
        FontSlant->"Italic"]}], 
      StyleBox["m",
