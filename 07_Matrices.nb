Cell[TextData[{
 "Thus, the bra-ket notation gives us a simple method for writing the \
integral over all space of the complex conjugate of a wavefunction multiplied \
by another wavefunction. When ",
 Cell[BoxData[
  StyleBox[
   SubscriptBox[
    StyleBox["\[CapitalPsi]",
     FontWeight->"Bold"], "a"],
   FontWeight->"Bold"]],
  CellChangeTimes->{{3.8112559638442764`*^9, 3.8112559741396627`*^9}, {
    3.8113221103126726`*^9, 3.811322130222258*^9}, 3.8113221675383205`*^9, {
    3.811322570897264*^9, 3.811322611416624*^9}, {3.8113228670247326`*^9, 
    3.811322868962326*^9}, 3.8113230721769085`*^9, {3.8113233012632074`*^9, 
    3.811323380796157*^9}, {3.8113234162551765`*^9, 3.8113234396763544`*^9}, {
    3.811324020646849*^9, 3.811324058909622*^9}, {3.8113241032752814`*^9, 
    3.811324173977947*^9}, {3.8113242527124395`*^9, 3.8113243673570013`*^9}, {
    3.8113246331815095`*^9, 3.811324637106286*^9}, {3.8113251052825127`*^9, 
    3.8113251075253*^9}, {3.811325157092647*^9, 3.811325157547997*^9}, {
    3.8113251947951336`*^9, 3.8113252086545453`*^9}, {3.8113271771897645`*^9, 
    3.811327184536927*^9}, {3.811327229827714*^9, 3.811327252666423*^9}, {
    3.8113273026463294`*^9, 3.811327327733873*^9}, {3.8113273817178807`*^9, 
    3.8113273925612955`*^9}, {3.8113274382012477`*^9, 3.811327492034623*^9}, {
    3.8113275253821125`*^9, 3.8113275462381163`*^9}, {3.811329211490376*^9, 
    3.8113292145036054`*^9}, {3.811329455455474*^9, 3.81132950541926*^9}},
  ExpressionUUID->"e8e9818d-aaab-47d9-be34-f2061f16b694"],
 " and ",
 Cell[BoxData[
  StyleBox[
   SubscriptBox[
    StyleBox["\[CapitalPsi]",
     FontWeight->"Bold"], "b"],
   FontWeight->"Bold"]],
  CellChangeTimes->{{3.8112559638442764`*^9, 3.8112559741396627`*^9}, {
    3.8113221103126726`*^9, 3.811322130222258*^9}, 3.8113221675383205`*^9, {
    3.811322570897264*^9, 3.811322611416624*^9}, {3.8113228670247326`*^9, 
    3.811322868962326*^9}, 3.8113230721769085`*^9, {3.8113233012632074`*^9, 
    3.811323380796157*^9}, {3.8113234162551765`*^9, 3.8113234396763544`*^9}, {
    3.811324020646849*^9, 3.811324058909622*^9}, {3.8113241032752814`*^9, 
    3.811324173977947*^9}, {3.8113242527124395`*^9, 3.8113243673570013`*^9}, {
    3.8113246331815095`*^9, 3.811324637106286*^9}, {3.8113251052825127`*^9, 
    3.8113251075253*^9}, {3.811325157092647*^9, 3.811325157547997*^9}, {
    3.8113251947951336`*^9, 3.8113252086545453`*^9}, {3.8113271771897645`*^9, 
    3.811327184536927*^9}, {3.811327229827714*^9, 3.811327252666423*^9}, {
    3.8113273026463294`*^9, 3.811327327733873*^9}, {3.8113273817178807`*^9, 
    3.8113273925612955`*^9}, {3.8113274382012477`*^9, 3.811327492034623*^9}, {
    3.8113275253821125`*^9, 3.8113275462381163`*^9}, {3.811329211490376*^9, 
    3.8113292145036054`*^9}, {3.811329455455474*^9, 3.81132950541926*^9}},
  ExpressionUUID->"a3af9df9-8e1e-4b0e-be61-d98e1334ed85"],
 " are distinct wavefunctions, this equation is known as an overlap integral, \
which will become very important in future work. When  ",
 Cell[BoxData[
  StyleBox[
   SubscriptBox[
    StyleBox["\[CapitalPsi]",
     FontWeight->"Bold"], "a"],
   FontWeight->"Bold"]],
  CellChangeTimes->{{3.8112559638442764`*^9, 3.8112559741396627`*^9}, {
