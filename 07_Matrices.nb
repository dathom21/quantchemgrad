Cell["Remember that we defined ", "Text",
 CellChangeTimes->{{3.8113292279224463`*^9, 3.8113292772476845`*^9}, 
   3.8113293188208513`*^9},ExpressionUUID->"67d7031a-a59f-4a7a-b1e7-\
1df78c0f1c48"],

Cell[BoxData[
 RowBox[{
  StyleBox[
   SubscriptBox[
    StyleBox["\[CapitalPsi]",
     FontWeight->"Bold"], "a"],
   FontWeight->"Bold"], "=", 
  RowBox[{
   UnderscriptBox[
    OverscriptBox["\[Sum]", 
     StyleBox["n",
      FontSlant->"Italic"]], 
    RowBox[{
     StyleBox["i",
      FontSlant->"Italic"], "=", "1"}]], 
   RowBox[{
    SubscriptBox[
     StyleBox["a",
      FontSlant->"Italic"], 
     StyleBox["i",
      FontSlant->"Italic"]], 
    SubscriptBox[
     StyleBox["\[Psi]",
      FontWeight->"Bold"], 
     StyleBox["i",
      FontWeight->"Bold",
      FontSlant->"Italic"]]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8113265575394135`*^9, 3.8113266208341584`*^9}, {
  3.8113268886705112`*^9, 3.8113269031313066`*^9}, {3.8113270136420536`*^9, 
  3.811327061904248*^9}, {3.811329307606151*^9, 
  3.8113293101704955`*^9}},ExpressionUUID->"18d621dd-8325-45b2-9f4e-\
e46d132151e5"],

Cell[TextData[{
 "so that the vector ",
 StyleBox["a",
  FontWeight->"Bold"],
 " simply represents the weighting factors applied to our basis vectors ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["\[Psi]",
    FontWeight->"Bold"], 
   StyleBox["i",
    FontWeight->"Bold",
    FontSlant->"Italic"]]],
  CellChangeTimes->{{3.8113265575394135`*^9, 3.8113266208341584`*^9}, {
   3.8113268886705112`*^9, 3.8113269031313066`*^9}, {3.8113270136420536`*^9, 
   3.811327061904248*^9}, {3.811329307606151*^9, 3.8113293101704955`*^9}},
  ExpressionUUID->"bcb81e8a-30b6-497f-9193-312470044461"],
 ". Let\[CloseCurlyQuote]s say that we choose our basis set of vectors to \
simply be the position ",
 StyleBox["x",
  FontSlant->"Italic"],
 ". In this case, the ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["a",
    FontSlant->"Italic"], 
   StyleBox["i",
    FontSlant->"Italic"]]],
  CellChangeTimes->{{3.8113265575394135`*^9, 3.8113266208341584`*^9}, {
   3.8113268886705112`*^9, 3.8113269031313066`*^9}, {3.8113270136420536`*^9, 
   3.811327061904248*^9}, {3.811329307606151*^9, 3.8113293101704955`*^9}},
  ExpressionUUID->"2e51fca8-99c3-4e57-bdad-0fe86efb7097"],
 " values just become the values at each value of ",
 StyleBox["x",
  FontSlant->"Italic"],
 ", and, since ",
 StyleBox["x",
  FontSlant->"Italic"],
 " is continuous, our sum transforms to an integral. In other words,"
}], "Text",
 CellChangeTimes->{{3.8113293219001293`*^9, 3.811329415257198*^9}, 
   3.811329534449686*^9},ExpressionUUID->"81462370-f5a9-4a44-9f54-\
ffc7dafeb12e"],

Cell[BoxData[
 RowBox[{
  StyleBox[
   SubscriptBox[
    StyleBox["\[CapitalPsi]",
     FontWeight->"Bold"], "a"],
   FontWeight->"Bold"], "=", 
  RowBox[{
   SubscriptBox["\[Psi]", 
    StyleBox["a",
     FontSlant->"Italic"]], 
   RowBox[{"(", 
    StyleBox["x",
     FontSlant->"Italic"], ")"}]}]}]], "DisplayFormulaNumbered",
