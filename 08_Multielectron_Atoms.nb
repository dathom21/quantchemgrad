Cell[TextData[{
 "Note that the off-diagonal elements are symmetric because of the conditions \
",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["S",
     FontSlant->"Italic"], 
    StyleBox["nm",
     FontSlant->"Italic"]], "=", 
   SubscriptBox[
    StyleBox["S",
     FontSlant->"Italic"], 
    StyleBox["mn",
     FontSlant->"Italic"]]}]],
  CellChangeTimes->{{3.811862964175773*^9, 3.8118629705411053`*^9}},
  ExpressionUUID->"b4ff2fc6-75ff-3944-b18a-5c74513a1133"],
 " and ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["H",
     FontSlant->"Italic"], 
    StyleBox["nm",
     FontSlant->"Italic"]], " ", "=", 
   SubscriptBox[
    StyleBox["H",
     FontSlant->"Italic"], 
    StyleBox["mn",
     FontSlant->"Italic"]]}]],
  CellChangeTimes->{{3.811862999624243*^9, 3.811863006656333*^9}},
  ExpressionUUID->"33144347-48c3-3248-8ccd-1d3d9cedee88"],
 "."
}], "Text",
