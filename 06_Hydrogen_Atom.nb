Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"OrbitalModel", "[", 
    RowBox[{"n_", ",", "view_", ",", " ", "label_"}], "]"}], " ", ":=", " ", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "pairs", ",", " ", "fun", ",", " ", "fun1", ",", " ", "fun2", ",", 
       "fun3", ",", "fun4", ",", " ", "a", ",", " ", "b", ",", " ", "l", ",", 
       " ", "m", ",", " ", "y1", ",", " ", "y2", ",", " ", "y3", ",", 
       "\[Theta]", ",", " ", "\[Phi]", ",", "pos", ",", "orbs1", ",", 
       "orbs2"}], "}"}], ",", "\n", "  ", 
     RowBox[{
      RowBox[{"pairs", " ", "=", " ", "\n", "   ", 
       RowBox[{"Flatten", "[", 
        RowBox[{
         RowBox[{"Table", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"i", ",", " ", "j"}], "}"}], ",", " ", 
           RowBox[{"{", 
            RowBox[{"i", ",", " ", "0", ",", " ", "5"}], "}"}], ",", " ", 
           RowBox[{"{", 
            RowBox[{"j", ",", " ", "0", ",", " ", "i"}], "}"}]}], "]"}], ",", 
         " ", "1"}], "]"}]}], ";", "\n", "    ", 
      RowBox[{"fun", " ", "=", " ", 
       RowBox[{"{", "}"}]}], ";", "\n", "    ", 
      RowBox[{"Do", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"l", " ", "=", " ", 
          RowBox[{"pairs", "[", 
           RowBox[{"[", 
            RowBox[{"i", ",", " ", "1"}], "]"}], "]"}]}], ";", "\n", "      ", 
         RowBox[{"m", " ", "=", " ", 
          RowBox[{"pairs", "[", 
           RowBox[{"[", 
            RowBox[{"i", ",", " ", "2"}], "]"}], "]"}]}], ";", "\n", "      ", 
         RowBox[{"a", " ", "=", " ", 
          RowBox[{"SphericalHarmonicY", "[", 
           RowBox[{"l", ",", 
            RowBox[{"-", " ", "m"}], ",", " ", "\[Theta]", ",", " ", 
            "\[Phi]"}], "]"}]}], ";", "\n", "      ", 
         RowBox[{"b", " ", "=", " ", 
          RowBox[{"SphericalHarmonicY", "[", 
           RowBox[{"l", ",", " ", "m", ",", " ", "\[Theta]", ",", "\[Phi]"}], 
           "]"}]}], ";", "\n", "      ", 
         RowBox[{"y1", " ", "=", " ", "b"}], ";", "\n", "      ", 
         RowBox[{"y2", " ", "=", " ", 
          RowBox[{"ExpToTrig", "[", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{"a", " ", "-", "b"}], ")"}], "/", 
            SqrtBox["2"]}], "]"}]}], ";", "\n", "      ", 
         RowBox[{"y3", " ", "=", " ", 
          RowBox[{"ExpToTrig", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"(", 
              RowBox[{"a", " ", "+", " ", "b"}], ")"}], "/", 
             SqrtBox["2"]}], "/", "I"}], "]"}]}], ";", "\n", "      ", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{"m", " ", "==", " ", "0"}], ",", " ", 
