    StyleBox["t",
     FontSlant->"Italic"]}]], "=", 
  FractionBox[
   StyleBox["p",
    FontSlant->"Italic"], 
   SuperscriptBox[
    StyleBox["ml",
     FontSlant->"Italic"], "2"]]}]], "DisplayFormulaNumbered",
