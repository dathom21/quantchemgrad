 RowBox[{
  SubscriptBox["\[CapitalPhi]", 
   SubscriptBox[
    StyleBox["sp",
     FontSlant->"Italic"], 
    StyleBox["i",
     FontSlant->"Italic"]]], "=", 
  RowBox[{
   RowBox[{
    SubscriptBox[
     StyleBox["a",
      FontSlant->"Italic"], "1"], 
    SubscriptBox["\[Phi]", 
     RowBox[{"2", 
      StyleBox["s",
       FontSlant->"Italic"]}]]}], "+", 
   RowBox[{
    SubscriptBox[
     StyleBox["b",
      FontSlant->"Italic"], "1"], 
    SubscriptBox["\[Phi]", 
     RowBox[{"2", 
      SubscriptBox[
       StyleBox["p",
        FontSlant->"Italic"], "z"]}]]}]}]}], "\[IndentingNewLine]", 
 RowBox[{
  SubscriptBox["\[CapitalPhi]", 
   SubscriptBox[
    StyleBox["sp",
     FontSlant->"Italic"], 
    StyleBox["j",
     FontSlant->"Italic"]]], "=", 
  RowBox[{
   RowBox[{
    SubscriptBox[
     StyleBox["a",
      FontSlant->"Italic"], "2"], 
    SubscriptBox["\[Phi]", 
     RowBox[{"2", 
      StyleBox["s",
       FontSlant->"Italic"]}]]}], "+", 
   RowBox[{
    SubscriptBox[
     StyleBox["b",
      FontSlant->"Italic"], "2"], 
    SubscriptBox["\[Phi]", 
     RowBox[{"2", 
      SubscriptBox[
       StyleBox["p",
        FontSlant->"Italic"], "z"]}]]}]}]}]}], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8142715408501225`*^9, 3.8142716264528427`*^9}, {
   3.8142716634962983`*^9, 3.81427166385531*^9}, {3.8142717090653296`*^9, 
   3.814271758882024*^9}, {3.8142767976668887`*^9, 3.8142767986447644`*^9}, 
   3.814277116274558*^9, {3.814277180844843*^9, 3.814277221091382*^9}, {
   3.814277457217991*^9, 
   3.8142774573794937`*^9}},ExpressionUUID->"83d13c7a-0acb-4bcb-b5d7-\
0065d8249785"],

Cell[TextData[{
 "Assuming that the ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Phi]", 
    RowBox[{"2", "s"}]], TraditionalForm]],ExpressionUUID->
  "669f3536-2954-45c1-be93-bf94fb626c0e"],
 " and ",
 Cell[BoxData[
  SubscriptBox["\[Phi]", 
   RowBox[{"2", 
    SubscriptBox[
     StyleBox["p",
      FontSlant->"Italic"], "z"]}]]],
  CellChangeTimes->{{3.8142715408501225`*^9, 3.8142716264528427`*^9}, {
    3.8142716634962983`*^9, 3.81427166385531*^9}, {3.8142717090653296`*^9, 
    3.814271758882024*^9}, {3.8142767976668887`*^9, 3.8142767986447644`*^9}, 
    3.814277116274558*^9, {3.814277180844843*^9, 3.814277221091382*^9}},
  ExpressionUUID->"9f2c831f-c889-4ca8-a4ea-f2d6c6d89ca8"],
 " orbitals are normalized, the conditions for orthonormalization of the two \
new orbitals are"
}], "Text",
 CellChangeTimes->{{3.814277322118623*^9, 3.814277363058121*^9}, {
  3.814277711969093*^9, 
  3.8142777127407084`*^9}},ExpressionUUID->"1847bc00-8fdf-4b1c-8691-\
06ac0820fc4f"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"\[LeftAngleBracket]", 
   RowBox[{
    SubscriptBox["\[CapitalPhi]", 
     SubscriptBox[
      StyleBox["sp",
       FontSlant->"Italic"], 
      StyleBox["i",
       FontSlant->"Italic"]]], "|", 
    SubscriptBox["\[CapitalPhi]", 
     SubscriptBox[
      StyleBox["sp",
       FontSlant->"Italic"], 
      StyleBox["i",
       FontSlant->"Italic"]]]}], "\[RightAngleBracket]"}], "=", 
  RowBox[{
   RowBox[{
    SubsuperscriptBox[
     StyleBox["a",
      FontSlant->"Italic"], "1", "2"], "+", 
    SubsuperscriptBox[
     StyleBox["b",
      FontSlant->"Italic"], "1", "2"]}], "=", "1"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"\[LeftAngleBracket]", 
   RowBox[{
    SubscriptBox["\[CapitalPhi]", 
     SubscriptBox[
      StyleBox["sp",
       FontSlant->"Italic"], 
      StyleBox["j",
       FontSlant->"Italic"]]], "|", 
    SubscriptBox["\[CapitalPhi]", 
     SubscriptBox[
      StyleBox["sp",
       FontSlant->"Italic"], 
      StyleBox["j",
       FontSlant->"Italic"]]]}], "\[RightAngleBracket]"}], "=", 
  RowBox[{
   RowBox[{
    SubsuperscriptBox[
     StyleBox["a",
      FontSlant->"Italic"], "2", "2"], "+", 
    SubsuperscriptBox[
     StyleBox["b",
      FontSlant->"Italic"], "2", "2"]}], "=", "1"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"\[LeftAngleBracket]", 
   RowBox[{
    SubscriptBox["\[CapitalPhi]", 
     SubscriptBox[
      StyleBox["sp",
       FontSlant->"Italic"], "i"]], "|", 
    SubscriptBox["\[CapitalPhi]", 
     SubscriptBox[
      StyleBox["sp",
       FontSlant->"Italic"], 
      StyleBox["j",
       FontSlant->"Italic"]]]}], "\[RightAngleBracket]"}], "=", 
  RowBox[{
   RowBox[{
    RowBox[{
     SubscriptBox[
      StyleBox["a",
       FontSlant->"Italic"], "1"], 
     SubscriptBox[
      StyleBox["a",
       FontSlant->"Italic"], "2"]}], "+", 
    RowBox[{
     SubscriptBox[
      StyleBox["b",
       FontSlant->"Italic"], "1"], 
     SubscriptBox[
      StyleBox["b",
       FontSlant->"Italic"], "2"]}]}], "=", 
   "0"}]}]}], "DisplayFormulaNumbered",
