      RowBox[{"\[Integral]", 
       RowBox[{
        SuperscriptBox["\[CapitalPhi]", "\[Star]"], " ", 
        OverscriptBox[
         StyleBox["H",
          FontSlant->"Italic"], "^"], "\[CapitalPhi]", " ", 
        "d\[Tau]"}]}]}]}]}], "=", 
   RowBox[{
    UnderscriptBox["\[Sum]", 
     StyleBox["n",
      FontSlant->"Italic"]], 
    RowBox[{
     UnderscriptBox["\[Sum]", 
      StyleBox["m",
       FontSlant->"Italic"]], 
     RowBox[{
      SubsuperscriptBox[
       StyleBox["a",
        FontSlant->"Italic"], 
       StyleBox["n",
        FontSlant->"Italic"], "\[Star]"], 
      SubscriptBox[
       StyleBox["a",
        FontSlant->"Italic"], 
       StyleBox["m",
        FontSlant->"Italic"]], 
      SubscriptBox[
       StyleBox["S",
        FontSlant->"Italic"], 
       StyleBox["nm",
        FontSlant->"Italic"]]}]}]}]}]}]], "DisplayFormulaNumbered",
