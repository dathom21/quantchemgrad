Cell[CellGroupData[{

Cell[TextData[{
 "Physical Interpretation of the Overlap Integral ",
 StyleBox["S",
  FontSlant->"Italic"]
}], "Subsubsection",
 CellChangeTimes->{{3.8132342262316236`*^9, 
  3.813234238131178*^9}},ExpressionUUID->"e210c83f-8093-4888-841e-\
02a2c3c0b1ee"],

Cell[TextData[{
 "Let\[CloseCurlyQuote]s take a moment to examine the physical meaning of the \
overlap integral in more detail. In the case of ",
 Cell[BoxData[
  FormBox[
   SubsuperscriptBox[
    StyleBox["H",
     FontSlant->"Plain"], "2", "+"], TraditionalForm]],ExpressionUUID->
  "c88497a0-598c-46ad-857e-26508ddd0e43"],
 ", this overlap integral is the integral over the product of a 1",
 StyleBox["s",
  FontSlant->"Italic"],
 " orbital around nucleus ",
 StyleBox["A",
  FontSlant->"Italic"],
 " and a a 1",
 StyleBox["s",
  FontSlant->"Italic"],
 " orbital around nucleus ",
 StyleBox["B",
  FontSlant->"Italic"],
 ". This product will only be nonzero if the two orbital functions overlap \
(both are nonzero for a given value of ",
 StyleBox["R",
  FontSlant->"Italic"],
 "), which is why this quantity is known as the overlap integral. As the two \
nuclei are brought closer to one another, the value of ",
 StyleBox["S",
  FontSlant->"Italic"],
 " will increase. "
}], "Text",
 CellChangeTimes->{{3.8132342411044035`*^9, 3.8132343273689904`*^9}, {
   3.8132343665872836`*^9, 3.81323445149743*^9}, {3.8132344856367755`*^9, 
   3.813234554069736*^9}, {3.8132351152514796`*^9, 3.813235251512164*^9}, 
   3.8132355103815045`*^9, {3.813235789246578*^9, 3.8132357961369553`*^9}, {
   3.8132358954411325`*^9, 
   3.8132358977655907`*^9}},ExpressionUUID->"50a596ad-7029-445d-9c73-\
7efd0d88eae1"],

