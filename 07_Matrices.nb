78c0632a6218"],

Cell[BoxData[
 RowBox[{
  RowBox[{"\[LeftAngleBracket]", 
   RowBox[{
    StyleBox["a",
     FontWeight->"Bold"], ",", 
    StyleBox["b",
     FontWeight->"Bold"]}], "\[RightAngleBracket]"}], "=", " ", 
  "0"}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8112559638442764`*^9, 3.8112559741396627`*^9}, {
   3.8113221103126726`*^9, 3.811322130222258*^9}, 3.8113221675383205`*^9, {
   3.811322570897264*^9, 3.811322611416624*^9}, {3.8113228670247326`*^9, 
   3.811322868962326*^9}, 3.8113230721769085`*^9, {3.8113233012632074`*^9, 
   3.811323380796157*^9}, {3.8113234162551765`*^9, 3.8113234396763544`*^9}, {
   3.811324020646849*^9, 3.811324058909622*^9}, {3.8113241032752814`*^9, 
   3.811324173977947*^9}, {3.8113242527124395`*^9, 3.8113243673570013`*^9}, {
   3.8113246331815095`*^9, 3.811324637106286*^9}, {3.8113251052825127`*^9, 
   3.8113251075253*^9}},ExpressionUUID->"55a36bde-3482-41b5-a3b4-\
2a31aba66fd1"],

Cell[TextData[{
 "If we have a set of vectors ",
 Cell[BoxData[
  FormBox[
   SubscriptBox[
    StyleBox["a",
     FontWeight->"Bold",
     FontSlant->"Plain"], 
    StyleBox["i",
     FontWeight->"Bold",
     FontSlant->"Plain"]], TraditionalForm]],ExpressionUUID->
  "0cc93f3b-8c38-46d0-a479-badc5c70c5d4"],
 ", which we will call a basis, we can say that the basis is orthonormal if"
}], "Text",
 CellChangeTimes->{{3.8113247415318737`*^9, 3.811324800561268*^9}, {
  3.8113251097312775`*^9, 
  3.811325151297306*^9}},ExpressionUUID->"5ecadd4e-be7f-4513-adfb-\
2efc82022afc"],

Cell[BoxData[
 RowBox[{
  RowBox[{"\[LeftAngleBracket]", 
   RowBox[{
    SubscriptBox[
     StyleBox["a",
      FontWeight->"Bold"], 
     StyleBox["i",
      FontWeight->"Bold",
      FontSlant->"Italic"]], ",", 
    StyleBox[
     SubscriptBox[
      StyleBox["a",
       FontWeight->"Bold"], 
      StyleBox["j",
       FontWeight->"Bold",
       FontSlant->"Italic"]],
     FontWeight->"Bold"]}], "\[RightAngleBracket]"}], "=", " ", 
  SubscriptBox["\[Delta]", 
   StyleBox["ij",
    FontSlant->"Italic"]]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8112559638442764`*^9, 3.8112559741396627`*^9}, {
   3.8113221103126726`*^9, 3.811322130222258*^9}, 3.8113221675383205`*^9, {
   3.811322570897264*^9, 3.811322611416624*^9}, {3.8113228670247326`*^9, 
   3.811322868962326*^9}, 3.8113230721769085`*^9, {3.8113233012632074`*^9, 
   3.811323380796157*^9}, {3.8113234162551765`*^9, 3.8113234396763544`*^9}, {
   3.811324020646849*^9, 3.811324058909622*^9}, {3.8113241032752814`*^9, 
   3.811324173977947*^9}, {3.8113242527124395`*^9, 3.8113243673570013`*^9}, {
   3.8113246331815095`*^9, 3.811324637106286*^9}, {3.8113251052825127`*^9, 
   3.8113251075253*^9}, {3.811325157092647*^9, 3.811325157547997*^9}, {
   3.8113251947951336`*^9, 
   3.8113252086545453`*^9}},ExpressionUUID->"ed0e7280-349f-4832-8ce7-\
2539d17f4293"],

Cell[TextData[{
 "Be careful not to get confused between the subscript denoting the different \
basis vectors ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["a",
    FontWeight->"Bold"], 
   StyleBox["i",
    FontWeight->"Bold",
    FontSlant->"Italic"]]],
  CellChangeTimes->{{3.8112559638442764`*^9, 3.8112559741396627`*^9}, {
    3.8113221103126726`*^9, 3.811322130222258*^9}, 3.8113221675383205`*^9, {
    3.811322570897264*^9, 3.811322611416624*^9}, {3.8113228670247326`*^9, 
    3.811322868962326*^9}, 3.8113230721769085`*^9, {3.8113233012632074`*^9, 
    3.811323380796157*^9}, {3.8113234162551765`*^9, 3.8113234396763544`*^9}, {
    3.811324020646849*^9, 3.811324058909622*^9}, {3.8113241032752814`*^9, 
    3.811324173977947*^9}, {3.8113242527124395`*^9, 3.8113243673570013`*^9}, {
    3.8113246331815095`*^9, 3.811324637106286*^9}, {3.8113251052825127`*^9, 
    3.8113251075253*^9}, {3.811325157092647*^9, 3.811325157547997*^9}, {
    3.8113251947951336`*^9, 3.8113252086545453`*^9}},ExpressionUUID->
  "0d9df460-6227-4f35-8f55-8aadfe6eda20"],
 " and the subscripts denoting the vector elements ",
 Cell[BoxData[
  SubscriptBox["a", 
   StyleBox["i",
    FontSlant->"Italic"]]],
  CellChangeTimes->{{3.8112559638442764`*^9, 3.8112559741396627`*^9}, {
    3.8113221103126726`*^9, 3.811322130222258*^9}, 3.8113221675383205`*^9, {
    3.811322570897264*^9, 3.811322611416624*^9}, {3.8113228670247326`*^9, 
    3.811322868962326*^9}, 3.8113230721769085`*^9, {3.8113233012632074`*^9, 
    3.811323380796157*^9}, {3.8113234162551765`*^9, 3.8113234396763544`*^9}, {
    3.811324020646849*^9, 3.811324058909622*^9}, {3.8113241032752814`*^9, 
    3.811324173977947*^9}, {3.8113242527124395`*^9, 3.8113243673570013`*^9}, {
    3.8113246331815095`*^9, 3.811324637106286*^9}, {3.8113251052825127`*^9, 
    3.8113251075253*^9}, {3.811325157092647*^9, 3.811325157547997*^9}, {
    3.8113251947951336`*^9, 3.8113252086545453`*^9}},ExpressionUUID->
  "086c9963-4bab-4938-a153-1e125b6ee82f"],
 ". Herein we try to always write the vectors in bold."
}], "Text",
 CellChangeTimes->{{3.8113252192538404`*^9, 3.811325266774864*^9}, {
  3.8113268763454003`*^9, 
  3.8113268816081266`*^9}},ExpressionUUID->"00d12ba9-6689-440e-ae89-\
8f4bfa5019a1"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Linear Vector Spaces and Quantum Mechanics", "Subsection",
 CellChangeTimes->{{3.8113254368488307`*^9, 
  3.81132544387422*^9}},ExpressionUUID->"4244e055-30d0-4a42-922e-\
1263d506eb7e"],

Cell["\<\
Now we want to discuss why all of this notation and nomenclature is relevant \
to quantum mechanics. It turns out that it is often convenient to represent \
our wavefunction as a linear combination of basis vectors,\
\>", "Text",
 CellChangeTimes->{{3.811326233080232*^9, 3.811326250646986*^9}, {
   3.811326395329139*^9, 3.8113264546375923`*^9}, 
   3.81132655012327*^9},ExpressionUUID->"1d9d62b9-30c2-477d-8425-\
5b4cc3b34054"],

Cell[BoxData[
 RowBox[{
  SubscriptBox[
   StyleBox["\[CapitalPsi]",
    FontWeight->"Bold"], 
   StyleBox["a",
    FontSlant->"Italic"]], "=", 
  RowBox[{
   UnderscriptBox[
    OverscriptBox["\[Sum]", 
     StyleBox["n",
      FontSlant->"Italic"]], 
    RowBox[{
     StyleBox["i",
      FontSlant->"Italic"], "=", "1"}]], 
   RowBox[{
    SubscriptBox[
     StyleBox["a",
      FontSlant->"Italic"], 
     StyleBox["i",
      FontSlant->"Italic"]], 
    SubscriptBox[
     StyleBox["\[Psi]",
      FontWeight->"Bold"], 
     StyleBox["i",
      FontWeight->"Bold",
      FontSlant->"Italic"]]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8113265575394135`*^9, 3.8113266208341584`*^9}, {
   3.8113268886705112`*^9, 3.8113269031313066`*^9}, 3.8113270406173744`*^9, {
   3.8115162477156334`*^9, 
   3.811516248002746*^9}},ExpressionUUID->"69d2d537-61a1-45d7-b1e5-\
060882072116"],

Cell[TextData[{
 "Typically, we want to choose a set of basis vectors ",
 Cell[BoxData[
  SubscriptBox["\[Psi]", 
   StyleBox["i",
    FontSlant->"Italic"]]],
  CellChangeTimes->{{3.8113265575394135`*^9, 3.8113266208341584`*^9}},
  ExpressionUUID->"f9d6700e-1883-45be-a6a3-045f2033d548"],
 " that satisfies two requirements. First, any arbitrary vector \[CapitalPsi] \
can be represented as a linear combination of the basis vectors ",
 Cell[BoxData[
  SubscriptBox["\[Psi]", 
   StyleBox["i",
    FontSlant->"Italic"]]],
  CellChangeTimes->{{3.8113265575394135`*^9, 3.8113266208341584`*^9}},
  ExpressionUUID->"19791a01-4b2b-4c38-bd17-a9d99ae7c61d"],
 ", meaning the basis vectors cover all of the possible values of \
\[CapitalPsi]. Second, the basis vector set is orthonormal, that is,"
}], "Text",
 CellChangeTimes->{{3.8113266469659243`*^9, 
  3.811326824430315*^9}},ExpressionUUID->"2664351c-aeec-412a-81af-\
3747e9e802e2"],

Cell[BoxData[
 RowBox[{
  RowBox[{"\[LeftAngleBracket]", 
   RowBox[{
    SubscriptBox[
     StyleBox["\[Psi]",
      FontWeight->"Bold"], 
     StyleBox["i",
      FontWeight->"Bold",
      FontSlant->"Italic"]], ",", 
    StyleBox[
     SubscriptBox[
      StyleBox["\[Psi]",
       FontWeight->"Bold"], 
      StyleBox["j",
       FontWeight->"Bold",
       FontSlant->"Italic"]],
     FontWeight->"Bold"]}], "\[RightAngleBracket]"}], "=", " ", 
  SubscriptBox["\[Delta]", 
   StyleBox["ij",
    FontSlant->"Italic"]]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8112559638442764`*^9, 3.8112559741396627`*^9}, {
   3.8113221103126726`*^9, 3.811322130222258*^9}, 3.8113221675383205`*^9, {
   3.811322570897264*^9, 3.811322611416624*^9}, {3.8113228670247326`*^9, 
   3.811322868962326*^9}, 3.8113230721769085`*^9, {3.8113233012632074`*^9, 
   3.811323380796157*^9}, {3.8113234162551765`*^9, 3.8113234396763544`*^9}, {
   3.811324020646849*^9, 3.811324058909622*^9}, {3.8113241032752814`*^9, 
   3.811324173977947*^9}, {3.8113242527124395`*^9, 3.8113243673570013`*^9}, {
   3.8113246331815095`*^9, 3.811324637106286*^9}, {3.8113251052825127`*^9, 
   3.8113251075253*^9}, {3.811325157092647*^9, 3.811325157547997*^9}, {
   3.8113251947951336`*^9, 3.8113252086545453`*^9}, {3.811326934158519*^9, 
   3.8113269401698294`*^9}},ExpressionUUID->"e2aafba8-b85a-4c1d-a5f8-\
f8b0051108a9"],

Cell["\<\
It is important to note that if we represent our wavefunction as a linear \
combination in some vector space, then a linear operator (remember that all \
quantum-mechanical operators representing observables are linear) that acts \
on our wavefunction becomes a matrix (we\[CloseCurlyQuote]ll return to this \
idea later).\
\>", "Text",
 CellChangeTimes->{{3.811328362936474*^9, 3.811328389751217*^9}, {
  3.811328523242874*^9, 
  3.8113285263449845`*^9}},ExpressionUUID->"08fe660d-4131-4234-94fc-\
88d027d44e6a"],

Cell[TextData[{
 "Note that if we have two vectors ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[CapitalPsi]", "a"], TraditionalForm]],
  FontWeight->"Bold",ExpressionUUID->"5a466d14-efa4-4bbb-a633-0d2e6b0db19e"],
 " and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[CapitalPsi]", "b"], TraditionalForm]],
  FontWeight->"Bold",ExpressionUUID->"add4aa84-4cab-4e27-ac23-ccb789514563"],
 ","
}], "Text",
 CellChangeTimes->{{3.8113269790334573`*^9, 
  3.8113270042145147`*^9}},ExpressionUUID->"ae84bab2-28ef-4039-baa8-\
1d0a7a1ce3e6"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   StyleBox[
    SubscriptBox[
     StyleBox["\[CapitalPsi]",
      FontWeight->"Bold"], "a"],
    FontWeight->"Bold"], "+", 
   StyleBox[
    SubscriptBox[
     StyleBox["\[CapitalPsi]",
      FontWeight->"Bold"], "b"],
    FontWeight->"Bold"]}], "=", 
  RowBox[{
   RowBox[{
    UnderscriptBox[
     OverscriptBox["\[Sum]", 
      StyleBox["n",
       FontSlant->"Italic"]], 
     RowBox[{
      StyleBox["i",
       FontSlant->"Italic"], "=", "1"}]], 
    RowBox[{
     SubscriptBox[
      StyleBox["a",
       FontSlant->"Italic"], 
      StyleBox["i",
       FontSlant->"Italic"]], 
     SubscriptBox[
      StyleBox["\[Psi]",
       FontWeight->"Bold"], 
      StyleBox["i",
       FontWeight->"Bold",
       FontSlant->"Italic"]]}]}], "+", 
   RowBox[{
    UnderscriptBox[
     OverscriptBox["\[Sum]", 
      StyleBox["n",
       FontSlant->"Italic"]], 
     RowBox[{
      StyleBox["i",
       FontSlant->"Italic"], "=", "1"}]], 
    RowBox[{
     SubscriptBox[
      StyleBox["b",
       FontSlant->"Italic"], 
      StyleBox["i",
       FontSlant->"Italic"]], 
     SubscriptBox[
      StyleBox["\[Psi]",
       FontWeight->"Bold"], 
      StyleBox["i",
       FontWeight->"Bold",
       FontSlant->"Italic"]]}]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8113265575394135`*^9, 3.8113266208341584`*^9}, {
  3.8113268886705112`*^9, 3.8113269031313066`*^9}, {3.8113270136420536`*^9, 
  3.811327061904248*^9}},ExpressionUUID->"74b24290-6893-4559-b149-\
65d9ede99ca0"],

Cell[BoxData[
 RowBox[{"\t   ", 
  RowBox[{"=", 
   RowBox[{
    UnderscriptBox[
     OverscriptBox["\[Sum]", 
      StyleBox["n",
       FontSlant->"Italic"]], 
     RowBox[{
      StyleBox["i",
       FontSlant->"Italic"], "=", "1"}]], 
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       SubscriptBox[
        StyleBox["a",
         FontSlant->"Italic"], 
        StyleBox["i",
         FontSlant->"Italic"]], "+", 
       SubscriptBox[
        StyleBox["b",
         FontSlant->"Italic"], 
        StyleBox["i",
         FontSlant->"Italic"]]}], ")"}], 
     SubscriptBox[
      StyleBox["\[Psi]",
       FontWeight->"Bold"], 
      StyleBox["i",
       FontWeight->"Bold",
       FontSlant->"Italic"]]}]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8113265575394135`*^9, 3.8113266208341584`*^9}, {
  3.8113268886705112`*^9, 3.8113269031313066`*^9}, {3.8113270136420536`*^9, 
  3.811327097058157*^9}},ExpressionUUID->"6f5051a1-86e0-4bc7-8844-\
00fe2557d66a"],

Cell[TextData[{
 "If we take the inner product of two vectors ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[CapitalPsi]", "a"], TraditionalForm]],
  FontWeight->"Bold",ExpressionUUID->"e387e7f9-a19a-4ec1-8733-3970dc4b5bcd"],
 " and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[CapitalPsi]", "b"], TraditionalForm]],
  FontWeight->"Bold",ExpressionUUID->"d96c9c24-92fb-4fec-a047-ce629de62a7b"],
 ", we obtain"
}], "Text",
 CellChangeTimes->{{3.811327143032788*^9, 3.8113271680220103`*^9}, {
  3.8113272877154045`*^9, 
  3.811327292775964*^9}},ExpressionUUID->"315d24a4-fd4a-4c94-8c80-\
f2c622a84130"],

Cell[BoxData[
 RowBox[{
  RowBox[{"\[LeftAngleBracket]", 
   RowBox[{
    StyleBox[
     SubscriptBox[
      StyleBox["\[CapitalPsi]",
       FontWeight->"Bold"], "a"],
     FontWeight->"Bold"], ",", 
    StyleBox[
     SubscriptBox[
      StyleBox["\[CapitalPsi]",
       FontWeight->"Bold"], "b"],
     FontWeight->"Bold"]}], "\[RightAngleBracket]"}], "=", " ", 
  RowBox[{"\[LeftAngleBracket]", 
   RowBox[{
    RowBox[{
     UnderscriptBox[
      OverscriptBox["\[Sum]", 
       StyleBox["n",
        FontSlant->"Italic"]], 
      RowBox[{
       StyleBox["i",
        FontSlant->"Italic"], "=", "1"}]], 
     RowBox[{
      SubscriptBox[
       StyleBox["a",
        FontSlant->"Italic"], 
       StyleBox["i",
        FontSlant->"Italic"]], 
      SubscriptBox[
       StyleBox["\[Psi]",
        FontWeight->"Bold"], 
       StyleBox["i",
        FontWeight->"Bold",
        FontSlant->"Italic"]]}]}], ",", 
    RowBox[{
     UnderscriptBox[
      OverscriptBox["\[Sum]", 
       StyleBox["n",
        FontSlant->"Italic"]], 
      RowBox[{
       StyleBox["j",
        FontSlant->"Italic"], "=", "1"}]], 
     RowBox[{
      SubscriptBox[
       StyleBox["b",
        FontSlant->"Italic"], 
       StyleBox["j",
        FontSlant->"Italic"]], 
      SubscriptBox[
       StyleBox["\[Psi]",
        FontWeight->"Bold"], 
       StyleBox["j",
        FontWeight->"Bold",
        FontSlant->"Italic"]]}]}]}], 
   "\[RightAngleBracket]"}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8112559638442764`*^9, 3.8112559741396627`*^9}, {
   3.8113221103126726`*^9, 3.811322130222258*^9}, 3.8113221675383205`*^9, {
   3.811322570897264*^9, 3.811322611416624*^9}, {3.8113228670247326`*^9, 
   3.811322868962326*^9}, 3.8113230721769085`*^9, {3.8113233012632074`*^9, 
   3.811323380796157*^9}, {3.8113234162551765`*^9, 3.8113234396763544`*^9}, {
   3.811324020646849*^9, 3.811324058909622*^9}, {3.8113241032752814`*^9, 
   3.811324173977947*^9}, {3.8113242527124395`*^9, 3.8113243673570013`*^9}, {
   3.8113246331815095`*^9, 3.811324637106286*^9}, {3.8113251052825127`*^9, 
   3.8113251075253*^9}, {3.811325157092647*^9, 3.811325157547997*^9}, {
   3.8113251947951336`*^9, 3.8113252086545453`*^9}, {3.8113271771897645`*^9, 
   3.811327184536927*^9}, {3.811327229827714*^9, 
   3.811327252666423*^9}},ExpressionUUID->"211fab1e-22e0-449e-a0a4-\
e11adf7fc60e"],

Cell["\<\
Using the linearity and multiplication definitions we discussed in the last \
section, we can write\
\>", "Text",
 CellChangeTimes->{{3.811327264006201*^9, 
  3.811327311995842*^9}},ExpressionUUID->"702848c2-8d86-44a1-a903-\
ae2b478172de"],

Cell[BoxData[
 RowBox[{
  RowBox[{"\[LeftAngleBracket]", 
   RowBox[{
    StyleBox[
     SubscriptBox[
      StyleBox["\[CapitalPsi]",
       FontWeight->"Bold"], "a"],
     FontWeight->"Bold"], ",", 
    StyleBox[
     SubscriptBox[
      StyleBox["\[CapitalPsi]",
       FontWeight->"Bold"], "b"],
     FontWeight->"Bold"]}], "\[RightAngleBracket]"}], "=", 
  RowBox[{
   UnderscriptBox[
    OverscriptBox["\[Sum]", 
     StyleBox["n",
      FontSlant->"Italic"]], 
    RowBox[{
     StyleBox["i",
      FontSlant->"Italic"], "=", "1"}]], 
   RowBox[{
    UnderscriptBox[
     OverscriptBox["\[Sum]", 
      StyleBox["n",
       FontSlant->"Italic"]], 
     RowBox[{
      StyleBox["j",
       FontSlant->"Italic"], "=", "1"}]], 
    RowBox[{
     SubsuperscriptBox[
      StyleBox["a",
       FontSlant->"Italic"], 
      StyleBox["i",
       FontSlant->"Italic"], "\[Star]"], " ", 
     SubscriptBox[
      StyleBox["b",
       FontSlant->"Italic"], 
      StyleBox["j",
       FontSlant->"Italic"]], 
     RowBox[{"\[LeftAngleBracket]", 
      RowBox[{
       SubscriptBox[
        StyleBox["\[Psi]",
         FontWeight->"Bold"], 
        StyleBox["i",
         FontWeight->"Bold",
         FontSlant->"Italic"]], ",", 
       SubscriptBox[
        StyleBox["\[Psi]",
         FontWeight->"Bold"], 
        StyleBox["j",
         FontWeight->"Bold",
         FontSlant->"Italic"]]}], 
      "\[RightAngleBracket]"}]}]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8112559638442764`*^9, 3.8112559741396627`*^9}, {
   3.8113221103126726`*^9, 3.811322130222258*^9}, 3.8113221675383205`*^9, {
   3.811322570897264*^9, 3.811322611416624*^9}, {3.8113228670247326`*^9, 
   3.811322868962326*^9}, 3.8113230721769085`*^9, {3.8113233012632074`*^9, 
   3.811323380796157*^9}, {3.8113234162551765`*^9, 3.8113234396763544`*^9}, {
   3.811324020646849*^9, 3.811324058909622*^9}, {3.8113241032752814`*^9, 
