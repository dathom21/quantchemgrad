       FontSlant->"Plain"]], 
     StyleBox[
      RowBox[{"(", "t", ")"}],
      FontSlant->"Italic"]}], 
    SuperscriptBox[
     StyleBox["|",
      FontSlant->"Italic"], "2"]}], "    ", "=", 
   RowBox[{
    FractionBox[
     SubsuperscriptBox[
      StyleBox["V",
       FontSlant->"Italic"], 
      StyleBox["mk",
       FontSlant->"Italic"], "2"], 
     SuperscriptBox["\[HBar]", "2"]], 
    FractionBox[
     RowBox[{" ", 
      RowBox[{"4", 
       SuperscriptBox["sin", "2"], 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           SubscriptBox["\[Omega]", 
            StyleBox["mk",
             FontSlant->"Italic"]], "-", "\[Omega]"}], ")"}], 
         StyleBox[" ",
          FontSlant->"Italic"], 
         RowBox[{
          StyleBox["t",
           FontSlant->"Italic"], "/", "2"}]}], ")"}]}]}], 
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{
