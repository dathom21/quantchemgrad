ee4e8494fea2"],

Cell["If we plug equation (18) into equation (19), we obtain", "Text",
 CellChangeTimes->{{3.9144164974259415`*^9, 3.9144165201580286`*^9}, {
  3.933948033535433*^9, 
  3.933948064756466*^9}},ExpressionUUID->"1de0bb0e-438e-433d-8989-\
