80793dde78c5"],

Cell[TextData[{
 "In general, the form of the basis functions is chosen so that ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["H",
    FontSlant->"Italic"], 
   StyleBox["nm",
    FontSlant->"Italic"]]],
  CellChangeTimes->{{3.811867187960767*^9, 3.811867203632437*^9}, {
   3.8118673980508423`*^9, 3.8118674057434216`*^9}, {3.8118675600949745`*^9, 
   3.81186770185857*^9}, {3.811867820889564*^9, 3.811867882486524*^9}},
  ExpressionUUID->"b6b0f094-bf11-6a43-b07e-510160f49531"],
 " and ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["S",
    FontSlant->"Italic"], 
   StyleBox["nm",
    FontSlant->"Italic"]]],
  CellChangeTimes->{{3.811867187960767*^9, 3.811867203632437*^9}, {
   3.8118673980508423`*^9, 3.8118674057434216`*^9}, {3.8118675600949745`*^9, 
   3.81186770185857*^9}, {3.811867820889564*^9, 3.811867882486524*^9}},
  ExpressionUUID->"d3e18d56-a30f-d941-81a6-8fab3c795863"],
 " can be calculated easily by a computer."
}], "Text",
 CellChangeTimes->{{3.811867946115982*^9, 
  3.8118680153119993`*^9}},ExpressionUUID->"e96ef370-af0e-5f47-95e3-\
ece2b6d628e6"],

Cell[TextData[{
 "Once the trial energies ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["E",
    FontSlant->"Italic"], "\[CapitalPhi]"]],
  CellChangeTimes->{{3.811867187960767*^9, 3.811867203632437*^9}, {
   3.8118673980508423`*^9, 3.8118674057434216`*^9}, {3.8118675600949745`*^9, 
   3.81186770185857*^9}, {3.811867820889564*^9, 3.811867859981785*^9}},
  ExpressionUUID->"82ebd62e-0055-f64f-bc38-c18af14f9165"],
 " are known, one can plug a given value of  ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["E",
    FontSlant->"Italic"], "\[CapitalPhi]"]],
  CellChangeTimes->{{3.811867187960767*^9, 3.811867203632437*^9}, {
