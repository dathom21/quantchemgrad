Cell[TextData[{
 StyleBox["Figure 13.14",
  FontWeight->"Bold"],
 ". Point group chart for the classification of molecules. Wikimedia, \
AbdullahAlturki99, CC BY-SA 4.0, \
https://commons.wikimedia.org/wiki/File:Pt_Group_chart_2.png"
}], "Affiliation",
 CellChangeTimes->{{3.809435027311596*^9, 3.8094350763900714`*^9}, {
   3.80943583474421*^9, 3.8094358359299717`*^9}, {3.8094472165104203`*^9, 
   3.809447281165168*^9}, {3.809510876137825*^9, 3.809510907739876*^9}, {
   3.809968073566992*^9, 3.8099681536568317`*^9}, {3.810557260250428*^9, 
   3.8105572606139913`*^9}, {3.8130835305386977`*^9, 
   3.8130836194514275`*^9}, {3.813224407772764*^9, 3.8132244817756805`*^9}, {
   3.8153299652849884`*^9, 3.8153300856368465`*^9}, {3.815486734293851*^9, 
   3.8154867344058456`*^9}, {3.8154879218419533`*^9, 
   3.8154879663632336`*^9}, {3.815923898141548*^9, 3.8159239219760113`*^9}, {
   3.815923956762824*^9, 3.8159240452391195`*^9}, {3.8159247099333353`*^9, 
   3.8159247404817953`*^9}, {3.8159945448318834`*^9, 3.815994713167585*^9}, {
   3.8160028965681047`*^9, 3.8160028965691357`*^9}, {3.8160101507675543`*^9, 
   3.8160103359781947`*^9}, {3.8162547010176077`*^9, 
   3.8162547601720486`*^9}, {3.816256470388248*^9, 3.8162564938155575`*^9}, {
   3.8162573507149153`*^9, 3.8162574489332633`*^9}, {3.8162575055320253`*^9, 
   3.816257507198513*^9}, {3.8162581563329887`*^9, 3.8162581865642414`*^9}, {
   3.8162592800669956`*^9, 3.8162593063362246`*^9}, {3.8162601211201*^9, 
   3.816260169699456*^9}, 3.939895351866993*^9, {3.940090505011732*^9, 
   3.940090505169985*^9}},ExpressionUUID->"250973ea-2cf0-4682-bc3a-\
c0b024e96863"],

Cell["\<\
It is useful to be able to identify point groups quickly and to then assess \
molecular properties without any calculations. However, in modern research, \
many software packages have built-in tools for identifying the molecular \
point group, including Mathematica. \
\>", "Text",
 CellChangeTimes->{{3.816260186037315*^9, 
  3.8162602440010824`*^9}},ExpressionUUID->"93ac6a19-652d-434d-bfee-\
1083ab0dc520"],

Cell[CellGroupData[{

