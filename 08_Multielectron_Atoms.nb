4aa659f4b6fe"],

Cell["\<\
For this system of equations to have a non-trivial solution, the determinant \
of the matrix must equal zero,\
\>", "Text",
 CellChangeTimes->{{3.8118643322636414`*^9, 
  3.811864359551634*^9}},ExpressionUUID->"251a29b8-521a-604e-b8d6-\
394d397bf575"],

Cell[BoxData[
 RowBox[{
  RowBox[{"\[LeftBracketingBar]", "\[NoBreak]", GridBox[{
     {
      RowBox[{
       SubscriptBox[
        StyleBox["H",
         FontSlant->"Italic"], "11"], "-", 
       RowBox[{
        SubscriptBox[
         StyleBox["E",
          FontSlant->"Italic"], "\[CapitalPhi]"], 
        SubscriptBox[
         StyleBox["S",
          FontSlant->"Italic"], "11"]}]}], 
      RowBox[{
       SubscriptBox[
        StyleBox["H",
         FontSlant->"Italic"], "12"], "-", 
       RowBox[{
        SubscriptBox[
         StyleBox["E",
          FontSlant->"Italic"], "\[CapitalPhi]"], 
        SubscriptBox[
         StyleBox["S",
          FontSlant->"Italic"], "12"]}]}], "...", 
