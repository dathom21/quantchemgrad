     StyleBox["R",
      FontWeight->"Bold",
      FontSlant->"Italic"]}], 
    StyleBox[")",
     FontSlant->"Italic"]}]}], "=", 
  RowBox[{
   SubscriptBox[
    StyleBox["E",
