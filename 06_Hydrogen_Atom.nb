Cell[CellGroupData[{

Cell["Solutions to the Radial Equation of the Hydrogen Atom", "Subsection",
 CellChangeTimes->{{3.8106536635216*^9, 3.810653669137967*^9}, {
  3.810653753304446*^9, 
  3.810653756826558*^9}},ExpressionUUID->"b32fc5b4-5ee9-4a53-9f23-\
016e4ae454de"],

Cell[TextData[{
 "Now that we have solved for the angular equation ",
 Cell[BoxData[
  RowBox[{
   SubsuperscriptBox[
    StyleBox["Y",
     FontSlant->"Italic"], 
    StyleBox["l",
     FontSlant->"Italic"], 
    SubscriptBox[
     StyleBox["m",
      FontSlant->"Italic"], 
     StyleBox["l",
      FontSlant->"Italic"]]], 
   RowBox[{"(", 
    RowBox[{"\[Theta]", ",", "\[Phi]"}], ")"}]}]],
  CellChangeTimes->{{3.810112811439228*^9, 3.8101128248442793`*^9}, {
    3.810479494926491*^9, 3.8104795038498344`*^9}, {3.810479572543576*^9, 
    3.8104796147383184`*^9}, {3.8104802055659895`*^9, 
    3.8104802433915305`*^9}, {3.8104802785189395`*^9, 
    3.8104802814214115`*^9}, {3.810480477782269*^9, 3.8104805471507206`*^9}, {
    3.8104805927965565`*^9, 3.810480633017248*^9}, {3.8104807595294323`*^9, 
    3.8104809538100047`*^9}, {3.8104811300285854`*^9, 
    3.8104811403007636`*^9}, {3.8104812580010843`*^9, 
    3.8104813317580833`*^9}, {3.81048146789211*^9, 3.8104815557630205`*^9}, {
    3.8104817202872114`*^9, 3.8104817438715935`*^9}, 3.810481790764664*^9, 
    3.810481836241686*^9, {3.810481926951917*^9, 3.810481935802024*^9}, {
    3.8104820720505495`*^9, 3.8104821860076323`*^9}, {3.810482833577834*^9, 
    3.810482856592573*^9}, {3.810650687465464*^9, 3.8106507334315205`*^9}, 
    3.810651925937356*^9, {3.810652128872187*^9, 3.810652287868311*^9}},
  ExpressionUUID->"1735055e-793c-467b-bdb0-ae8fcf280a4a"],
 "and seen that it depends on the quantum numbers ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["m",
    FontSlant->"Italic"], 
   StyleBox["l",
    FontSlant->"Italic"]]],
  CellChangeTimes->{{3.810483192695999*^9, 3.810483197963916*^9}, {
    3.8106449127367277`*^9, 3.810645017074294*^9}, {3.8106456352739797`*^9, 
    3.8106456520772038`*^9}, 3.810645955559409*^9, {3.917022289909156*^9, 
    3.91702229654428*^9}},ExpressionUUID->
  "362dc12e-86f3-4144-9ae1-09d7b0481539"],
 " and ",
 StyleBox["l",
  FontSlant->"Italic"],
 ", we will now return to the radial equation and find its solutions. These \
radial solutions define the change in the wavefunction of the electron with \
respect to distance from the proton ",
 StyleBox["r",
  FontSlant->"Italic"],
 ". Recall from equation (22) that the differential radial equation takes the \
form"
}], "Text",
 CellChangeTimes->{{3.8106537589528418`*^9, 3.8106538194509106`*^9}, {
  3.8107218098795977`*^9, 3.8107218533933268`*^9}, {3.9170226261350756`*^9, 
  3.9170226299298315`*^9}},ExpressionUUID->"6fe66232-24eb-4387-9010-\
1229704fe2bb"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   FractionBox[
    RowBox[{"-", "1"}], 
    RowBox[{
     StyleBox["R",
      FontSlant->"Italic"], 
     RowBox[{"(", 
      StyleBox["r",
       FontSlant->"Italic"], ")"}]}]], "[", 
   RowBox[{
    RowBox[{
     FractionBox["\[DifferentialD]", 
      RowBox[{
       StyleBox["\[DifferentialD]",
        FontSlant->"Plain"], 
       StyleBox["r",
        FontSlant->"Italic"]}]], 
     RowBox[{"(", 
      RowBox[{
       SuperscriptBox[
        StyleBox["r",
         FontSlant->"Italic"], "2"], 
       FractionBox[
        RowBox[{
         RowBox[{"\[DifferentialD]", "R"}], 
         RowBox[{"(", "r", ")"}]}], 
        RowBox[{"\[DifferentialD]", "r"}]]}], ")"}]}], "+", 
    RowBox[{
     FractionBox[
      RowBox[{"2", 
       StyleBox[
        SubscriptBox[
         StyleBox["m",
          FontSlant->"Italic"], "e"],
        FontSlant->"Italic"], 
       SuperscriptBox[
        StyleBox["r",
         FontSlant->"Italic"], "2"]}], 
      SuperscriptBox["\[HBar]", "2"]], 
     RowBox[{"(", 
      RowBox[{
       FractionBox[
        SuperscriptBox[
         StyleBox["e",
          FontSlant->"Italic"], "2"], 
        RowBox[{"4", 
         SubscriptBox["\[Pi]\[Epsilon]", "0"], 
         StyleBox["r",
          FontSlant->"Italic"]}]], "+", 
       StyleBox["E",
        FontSlant->"Italic"]}], 
      StyleBox[")",
       FontSlant->"Italic"]}], 
     StyleBox["R",
      FontSlant->"Italic"], 
     RowBox[{"(", 
      StyleBox["r",
       FontSlant->"Italic"], ")"}]}]}], "]"}], "=", 
  RowBox[{"-", "\[Beta]"}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.810112811439228*^9, 3.8101128248442793`*^9}, {
