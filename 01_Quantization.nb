a9ad21363e45"],

Cell[BoxData[
 RowBox[{
  StyleBox[
   SubscriptBox["A", "n"],
   FontSlant->"Italic"], 
  StyleBox[" ",
   FontSlant->"Plain"], 
  StyleBox["=",
   FontSlant->"Plain"], 
  StyleBox[" ",
   FontSlant->"Plain"], 
  RowBox[{
   FractionBox["1", 
