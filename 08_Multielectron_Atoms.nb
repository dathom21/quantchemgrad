          StyleBox["S",
           FontSlant->"Italic"], 
          StyleBox["NN",
           FontSlant->"Italic"]]}]}]}
     }], "\[NoBreak]", ")"}], 
   RowBox[{"(", "\[NoBreak]", GridBox[{
      {
       SubscriptBox[
        StyleBox["a",
         FontSlant->"Italic"], "1"]},
      {
       SubscriptBox[
        StyleBox["a",
         FontSlant->"Italic"], "2"]},
      {GridBox[{
         {"..."},
         {
          SubscriptBox[
           StyleBox["a",
            FontSlant->"Italic"], 
           StyleBox["N",
            FontSlant->"Italic"]]}
        }]}
     }], "\[NoBreak]", ")"}]}], "=", " ", 
  RowBox[{"(", "\[NoBreak]", GridBox[{
     {"0"},
     {"0"},
     {GridBox[{
        {"..."},
        {"0"}
       }]}
    }], "\[NoBreak]", ")"}]}]], "DisplayFormulaNumbered",
