   3.9213298798186703`*^9}},ExpressionUUID->"a7d82972-9248-467a-be34-\
54e8cb17324b"],

Cell[TextData[{
 "We can also rewrite this expression using ",
 StyleBox["n",
  FontSlant->"Italic"],
 " moles instead of ",
 StyleBox["N",
  FontSlant->"Italic"],
 " atoms or molecules, using ",
 Cell[BoxData[
  FormBox[
   RowBox[{"N", "=", 
    RowBox[{"n", " ", 
     SubscriptBox["N", "a"]}]}], TraditionalForm]],ExpressionUUID->
  "85dc0be0-48b9-44fd-8127-f54755e197bf"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["N", "a"], "=", 
    RowBox[{"R", "/", 
     SubscriptBox[
      StyleBox["k",
       FontSlant->"Italic"], 
      StyleBox["B",
       FontSlant->"Italic"]]}]}], TraditionalForm]],ExpressionUUID->
  "152cc0c0-eb38-4366-afa0-abaddc89d0de"],
 ","
}], "Text",
 CellChangeTimes->{{3.921329914018309*^9, 
  3.9213300055191965`*^9}},ExpressionUUID->"6b480e8f-5e85-410a-b9b3-\
7c3ca0f2c7e5"],

Cell[BoxData[
 RowBox[{
  RowBox[{"\[LeftAngleBracket]", 
   StyleBox["E",
    FontSlant->"Italic"], "\[RightAngleBracket]"}], 
  StyleBox["=",
   FontSlant->"Plain"], 
  RowBox[{
   FractionBox["3", "2"], 
   StyleBox["nRT",
    FontSlant->"Italic"]}]}]], "DisplayFormulaNumbered",
 InitializationCell->True,
 CellChangeTimes->{{3.9212505192469416`*^9, 3.921250534863843*^9}, {
   3.9212507356598735`*^9, 3.9212507676410656`*^9}, {3.9212508673633738`*^9, 
   3.9212509608799176`*^9}, {3.921251060924367*^9, 3.9212511124818687`*^9}, {
   3.9212511504673223`*^9, 3.921251158794492*^9}, {3.9212512029019794`*^9, 
   3.9212512716665497`*^9}, {3.921251348153563*^9, 3.921251397670518*^9}, {
   3.921328606806888*^9, 3.921328654543107*^9}, 3.9213289776454625`*^9, {
   3.921329302517523*^9, 3.921329306297614*^9}, {3.921329571452891*^9, 
   3.921329578612625*^9}, 3.9213296317732787`*^9, {3.9213298724546156`*^9, 
   3.9213298798186703`*^9}, {3.9213300349738455`*^9, 
   3.9213300480959187`*^9}},ExpressionUUID->"c007b7e9-9a49-4cf0-a538-\
84aaf1551e3e"],

Cell[TextData[{
 "where ",
 StyleBox["R",
  FontSlant->"Italic"],
 " is the gas constant and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["N", "A"], TraditionalForm]],ExpressionUUID->
  "cd959340-f084-494b-8fea-823a1a30e75e"],
 " is Avogadro\[CloseCurlyQuote]s constant. So we see that the average \
translational energy of an ideal gas is given by the average translational \
energy of each particle multiplied by the number of particles."
}], "Text",
 CellChangeTimes->{{3.9213300504019113`*^9, 3.9213300656498537`*^9}, {
   3.9213304259927034`*^9, 3.921330567922275*^9}, 
   3.92133069493606*^9},ExpressionUUID->"3f5b2b40-b4d9-420a-a9d4-\
f95a4995a500"]
}, Open  ]],

