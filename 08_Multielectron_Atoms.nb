  "00443cf3-74b5-4dae-9693-1727f0f4ffbd"],
 " and ",
 Cell[BoxData[
  RowBox[{"\[Phi]", 
   RowBox[{"(", 
    SubscriptBox[
     StyleBox["r",
      FontWeight->"Bold",
      FontSlant->"Italic"], "2"], ")"}]}]],
