Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"P", "[", 
    RowBox[{"v_", ",", "T_", ",", "M_"}], "]"}], ":=", 
   RowBox[{"4", " ", "\[Pi]", " ", 
    SuperscriptBox[
     RowBox[{"(", 
      FractionBox["M", 
       RowBox[{"2", "\[Pi]", " ", "R", " ", "T"}]], ")"}], 
     FractionBox["3", "2"]], 
    SuperscriptBox["v", "2"], " ", 
    SuperscriptBox["E", 
     RowBox[{
      FractionBox[
       RowBox[{"-", "M"}], 
       RowBox[{"2", "R", " ", "T"}]], 
      SuperscriptBox["v", "2"]}]]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"A", "[", 
    RowBox[{"a_", ",", "b_", ",", "T_", ",", "M_"}], "]"}], ":=", 
   RowBox[{
    SubsuperscriptBox["\[Integral]", "a", "b"], 
    RowBox[{
     RowBox[{"P", "[", 
      RowBox[{"v", ",", "T", ",", "M"}], "]"}], 
     RowBox[{"d", "v"}]}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"R", "=", "8.31"}], ";"}]}], "Input",
 CellGroupingRules->{"GroupTogetherGrouping", 7631.},
 CellChangeTimes->{
