  3.8118611062455363`*^9}},ExpressionUUID->"c08cce1f-0d5f-8f41-9d8f-\
974226d73178"],

Cell[BoxData[
 RowBox[{
  RowBox[{"\[LeftAngleBracket]", 
   RowBox[{"\[CapitalPhi]", "|", "\[CapitalPhi]"}], "\[RightAngleBracket]"}], 
  "  ", "=", 
  RowBox[{
   RowBox[{
    UnderscriptBox["\[Sum]", 
     StyleBox["n",
      FontSlant->"Italic"]], 
    RowBox[{
     UnderscriptBox["\[Sum]", 
      StyleBox["m",
       FontSlant->"Italic"]], 
