Cell["\<\
There\[CloseCurlyQuote]s also Fourier series for complex functions! Now we \
are going to use a different basis,\
\>", "Text",
 CellChangeTimes->{
  3.9339518100588436`*^9},ExpressionUUID->"6ab5d88a-7679-4949-9475-\
6686cd0b60e4"],

Cell[BoxData[
 RowBox[{
  RowBox[{"cos", 
   RowBox[{"(", 
    FractionBox[
     RowBox[{"2", 
      StyleBox[
       RowBox[{"\[Pi]", 
        StyleBox["nx",
         FontSlant->"Italic"]}]]}], 
     StyleBox["L",
      FontSlant->"Italic"]], ")"}]}], "+", 
  RowBox[{"\[ImaginaryI]", " ", "sin", 
   RowBox[{"(", 
    FractionBox[
     RowBox[{"2", 
      StyleBox[
       RowBox[{"\[Pi]", 
        StyleBox["nx",
         FontSlant->"Italic"]}]]}], 
     StyleBox["L",
      FontSlant->"Italic"]], ")"}]}]}]], "DisplayFormulaNumbered",
