Cell[TextData[{
 StyleBox["Figure 5.1",
  FontWeight->"Bold"],
 ". Two masses connected by a spring, Cleonis, Wikipedia, 2006, CC-BY-SA 2.5, \
https://upload.wikimedia.org/wikipedia/en/e/ec/Rotational_vibrational_\
coupling.gif"
}], "Affiliation",
 CellChangeTimes->{{3.809435027311596*^9, 3.8094350763900714`*^9}, {
  3.80943583474421*^9, 3.8094358359299717`*^9}, {3.8094472165104203`*^9, 
  3.809447281165168*^9}, {3.8412237611591425`*^9, 3.8412237616401944`*^9}, {
  3.9157971356558566`*^9, 
  3.9157971372027516`*^9}},ExpressionUUID->"642b736d-a8a3-4900-bad3-\
168842fa4354"],

Cell[TextData[{
 "Instead of using the position of each mass we can use the relative position \
",
 StyleBox["x",
  FontSlant->"Italic"],
 " given by"
}], "Text",
 CellChangeTimes->{{3.809447844530136*^9, 3.8094478540331383`*^9}, {
  3.809448147799813*^9, 3.809448150296938*^9}, {3.809448221540519*^9, 
  3.809448228876149*^9}, {3.8094482870300603`*^9, 
  3.8094482921175127`*^9}},ExpressionUUID->"f490713e-146f-4c3b-92eb-\
903897087df6"],

Cell[BoxData[
 RowBox[{
  StyleBox["x",
   FontSlant->"Italic"], "=", 
  RowBox[{
   SubscriptBox[
    StyleBox["x",
     FontSlant->"Italic"], "2"], "-", 
   SubscriptBox[
    StyleBox["x",
     FontSlant->"Italic"], "1"], "-", 
   SubscriptBox[
    StyleBox["l",
     FontSlant->"Italic"], "0"]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.809435322857957*^9, 3.8094353275032787`*^9}, 
   3.809435648810088*^9, {3.809447557080136*^9, 3.8094475932014737`*^9}, {
   3.8094476622075834`*^9, 3.809447695658035*^9}, {3.8094477361073503`*^9, 
   3.809447834445715*^9}, {3.809448240193119*^9, 
   3.8094482447058163`*^9}},ExpressionUUID->"9948d69f-b28b-4c91-8981-\
4c9686dda980"],

Cell["We can also use the reduced mass \[Mu] given by", "Text",
 CellChangeTimes->{
  3.9157974655335274`*^9},ExpressionUUID->"2f2b3010-cd10-4336-b90e-\
d38e9c4ecce8"],

Cell[BoxData[
 RowBox[{
  FractionBox[
   StyleBox["1",
    FontSlant->"Plain"], "\[Mu]"], "=", 
  RowBox[{
   RowBox[{
    StyleBox["(",
     FontSlant->"Italic"], 
    RowBox[{
     FractionBox[
      StyleBox["1",
       FontSlant->"Plain"], 
      SubscriptBox[
       StyleBox["m",
        FontSlant->"Italic"], "1"]], "+", 
     FractionBox["1", 
      SubscriptBox[
       StyleBox["m",
        FontSlant->"Italic"], "2"]]}], 
    StyleBox[")",
     FontSlant->"Italic"]}], "=", 
   FractionBox[
    RowBox[{
     SubscriptBox[
      StyleBox["m",
       FontSlant->"Italic"], "1"], "+", 
     SubscriptBox[
      StyleBox["m",
       FontSlant->"Italic"], "2"]}], 
    RowBox[{
     SubscriptBox[
      StyleBox["m",
       FontSlant->"Italic"], "1"], 
     SubscriptBox[
      StyleBox["m",
       FontSlant->"Italic"], "2"]}]]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.809435322857957*^9, 3.8094353275032787`*^9}, 
   3.809435648810088*^9, {3.809447557080136*^9, 3.8094475932014737`*^9}, {
   3.8094476622075834`*^9, 3.809447695658035*^9}, {3.8094477361073503`*^9, 
   3.809447834445715*^9}, {3.8094482757398853`*^9, 3.8094482789705935`*^9}, {
   3.80944831029372*^9, 3.8094483418557267`*^9}, {3.843124761752486*^9, 
   3.8431247652817907`*^9}, {3.905848499946226*^9, 
   3.905848503311001*^9}},ExpressionUUID->"fdd7511d-2c83-489c-8e75-\
cae3701e4ad2"],

Cell[TextData[{
 "where ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["m",
    FontSlant->"Italic"], "1"]],
  CellChangeTimes->{{3.809435322857957*^9, 3.8094353275032787`*^9}, 
    3.809435648810088*^9, {3.809447557080136*^9, 3.8094475932014737`*^9}, {
    3.8094476622075834`*^9, 3.809447695658035*^9}, {3.8094477361073503`*^9, 
    3.809447834445715*^9}, {3.8094482757398853`*^9, 3.8094482789705935`*^9}, {
    3.80944831029372*^9, 3.8094483418557267`*^9}, {3.843124761752486*^9, 
    3.8431247652817907`*^9}, {3.905848499946226*^9, 3.905848503311001*^9}},
  ExpressionUUID->"9d22a45b-1bdf-4d21-bddb-b023e2e6af9d"],
 " and ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["m",
    FontSlant->"Italic"], "2"]],
  CellChangeTimes->{{3.809435322857957*^9, 3.8094353275032787`*^9}, 
    3.809435648810088*^9, {3.809447557080136*^9, 3.8094475932014737`*^9}, {
    3.8094476622075834`*^9, 3.809447695658035*^9}, {3.8094477361073503`*^9, 
    3.809447834445715*^9}, {3.8094482757398853`*^9, 3.8094482789705935`*^9}, {
    3.80944831029372*^9, 3.8094483418557267`*^9}, {3.843124761752486*^9, 
    3.8431247652817907`*^9}, {3.905848499946226*^9, 3.905848503311001*^9}},
  ExpressionUUID->"e6554a1b-c80c-4467-b7e5-691c7a6e5257"],
 " are the two masses. Finally, noting that ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["l",
    FontSlant->"Italic"], "0"]],
  CellChangeTimes->{{3.809435322857957*^9, 3.8094353275032787`*^9}, 
    3.809435648810088*^9, {3.809447557080136*^9, 3.8094475932014737`*^9}, {
    3.8094476622075834`*^9, 3.809447695658035*^9}, {3.8094477361073503`*^9, 
    3.809447834445715*^9}},ExpressionUUID->
  "caec1377-c5d0-41da-9a6b-f396aeffbf89"],
 " is a constant that doesn\[CloseCurlyQuote]t depend on time, we can write"
}], "Text",
 CellChangeTimes->{{3.8094485271799765`*^9, 3.809448546401684*^9}, {
  3.841223997576003*^9, 3.8412239978139615`*^9}, {3.9157972904151587`*^9, 
  3.9157973256809235`*^9}},ExpressionUUID->"c0412a8d-55c5-4f4f-b210-\
e4d23e075b97"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   StyleBox[
    FractionBox[
     SuperscriptBox[
      StyleBox["\[DifferentialD]",
       FontSlant->"Plain"], "2"], 
     RowBox[{
      StyleBox["\[DifferentialD]",
       FontSlant->"Plain"], 
      SuperscriptBox[
       StyleBox["t",
        FontSlant->"Italic"], "2"]}]],
    FontSlant->"Italic"], 
   RowBox[{
    StyleBox["(",
     FontSlant->"Italic"], 
    RowBox[{
     SubscriptBox[
      StyleBox["x",
       FontSlant->"Italic"], 
      StyleBox["2",
       FontSlant->"Plain"]], 
     StyleBox["-",
      FontSlant->"Italic"], 
     SubscriptBox[
      StyleBox["x",
       FontSlant->"Italic"], 
      StyleBox["1",
       FontSlant->"Plain"]]}], ")"}]}], "=", 
  RowBox[{
   StyleBox[
    FractionBox[
     SuperscriptBox[
      StyleBox["\[DifferentialD]",
       FontSlant->"Plain"], "2"], 
     RowBox[{
      StyleBox["\[DifferentialD]",
       FontSlant->"Plain"], 
      SuperscriptBox[
       StyleBox["t",
        FontSlant->"Italic"], "2"]}]],
    FontSlant->"Italic"], 
   RowBox[{
    StyleBox["(",
     FontSlant->"Italic"], 
    RowBox[{
     SubscriptBox[
      StyleBox["x",
       FontSlant->"Italic"], "2"], "-", 
     SubscriptBox[
      StyleBox["x",
       FontSlant->"Italic"], "1"], "-", 
     SubscriptBox[
      StyleBox["l",
       FontSlant->"Italic"], "0"]}], ")"}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.809435322857957*^9, 3.8094353275032787`*^9}, 
   3.809435648810088*^9, {3.809447557080136*^9, 3.8094475932014737`*^9}, {
   3.8094476622075834`*^9, 3.809447695658035*^9}, {3.8094477361073503`*^9, 
   3.809447834445715*^9}, 3.809448566664138*^9, {3.9351443782860126`*^9, 
   3.9351443904897747`*^9}},ExpressionUUID->"e6bebeba-ed80-450b-af8a-\
4d0e70b37987"],

Cell["\<\
Using these definitions, we can obtain a final equation for the system,\
\>", "Text",
 CellChangeTimes->{{3.809448575193361*^9, 3.809448595278677*^9}, {
  3.916161646814399*^9, 3.916161667757992*^9}, {3.9161617037107916`*^9, 
  3.91616170778119*^9}, {3.9161617498538914`*^9, 3.9161617507273607`*^9}, {
  3.9161619075526123`*^9, 
  3.916161925873099*^9}},ExpressionUUID->"3cca457e-03ac-43b0-8aa7-\
501b3a5c63cc"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   StyleBox[
    FractionBox[
     RowBox[{
      SuperscriptBox[
       StyleBox["\[DifferentialD]",
        FontSlant->"Plain"], "2"], "x"}], 
     RowBox[{
      StyleBox["\[DifferentialD]",
       FontSlant->"Plain"], 
      SuperscriptBox[
       StyleBox["t",
        FontSlant->"Italic"], "2"]}]],
    FontSlant->"Italic"], "+", 
   StyleBox[
    RowBox[{
     FractionBox["k", 
      StyleBox["\[Mu]",
       FontSlant->"Plain"]], "x"}],
    FontSlant->"Italic"]}], 
  StyleBox["=",
   FontSlant->"Plain"], 
  StyleBox["0",
   FontSlant->"Plain"]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.809435322857957*^9, 3.8094353275032787`*^9}, 
   3.809435648810088*^9, {3.809447557080136*^9, 3.8094475932014737`*^9}, {
   3.8094476622075834`*^9, 3.809447695658035*^9}, {3.8094477361073503`*^9, 
   3.809447834445715*^9}, {3.809448607680462*^9, 3.8094486793995843`*^9}, {
   3.9351443922216473`*^9, 
   3.9351443934669113`*^9}},ExpressionUUID->"e4708887-6ace-4d60-96c5-\
baa5853b90ee"],

Cell["\<\
which has the same form as equation (1). Thus, we can represent our unfixed \
mass/spring system in the same form as our fixed mass/spring system by using \
a reduced mass and a relative coordinate system. This result will be very \
important for applying the harmonic oscillator to molecules!\
\>", "Text",
 CellChangeTimes->{{3.809448706389317*^9, 3.8094488050974894`*^9}, {
  3.9157973715479937`*^9, 3.9157973716992617`*^9}, {3.915797520767563*^9, 
  3.915797544291683*^9}},ExpressionUUID->"d946771b-68e3-4f43-9f74-\
da540a37c0e0"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Solving the Schr\[ODoubleDot]dinger Equation", "Subsection",
 CellChangeTimes->{{3.809508122238413*^9, 
  3.8095081352973833`*^9}},ExpressionUUID->"f9581b86-e576-4254-bc91-\
028e7336eca6"],

Cell["\<\
We now want to address the behavior of a quantum-mechanical system with a \
harmonic potential. Instead of Newton\[CloseCurlyQuote]s equations, we must \
now use the time-independent Schr\[ODoubleDot]dinger equation, \
\>", "Text",
 CellChangeTimes->{{3.8095036355147276`*^9, 3.809503870567529*^9}, {
  3.915797650751952*^9, 
  3.9157976515829163`*^9}},ExpressionUUID->"54ef2898-3fde-436f-ab8b-\
ad94edb5f7b6"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"-", 
     FractionBox[
      SuperscriptBox["\[HBar]", "2"], 
      RowBox[{"2", "\[Mu]"}]]}], 
    FractionBox[
     RowBox[{
      RowBox[{
       SuperscriptBox[
        StyleBox["\[DifferentialD]",
         FontSlant->"Plain"], "2"], "\[Psi]"}], 
      RowBox[{"(", 
       StyleBox["x",
        FontSlant->"Italic"], 
       StyleBox[")",
        FontSlant->"Italic"]}]}], 
     RowBox[{
      StyleBox["\[DifferentialD]",
       FontSlant->"Plain"], 
      SuperscriptBox[
       StyleBox["x",
        FontSlant->"Italic"], "2"]}]]}], "+", 
   RowBox[{
    StyleBox["V",
     FontSlant->"Italic"], 
    StyleBox[
     RowBox[{"(", "x", ")"}],
     FontSlant->"Italic"], "\[Psi]", 
    RowBox[{"(", 
     StyleBox["x",
      FontSlant->"Italic"], 
     StyleBox[")",
      FontSlant->"Italic"]}]}]}], "=", 
  RowBox[{
   StyleBox["E",
    FontSlant->"Italic"], 
   StyleBox[" ",
    FontSlant->"Italic"], "\[Psi]", 
   RowBox[{"(", 
    StyleBox["x",
     FontSlant->"Italic"], 
    StyleBox[")",
     FontSlant->"Italic"]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8079664251944246`*^9, 3.8079664343142004`*^9}, {
  3.8079689400739555`*^9, 3.8079689680029573`*^9}, {3.807970315263204*^9, 
  3.8079703215316095`*^9}, {3.807970415909548*^9, 3.807970437015459*^9}, {
  3.8079705221296997`*^9, 3.8079705895237727`*^9}, {3.809503913366911*^9, 
  3.809503915415073*^9}, {3.935144435750864*^9, 
  3.9351444369795322`*^9}},ExpressionUUID->"e8f30510-908e-4f09-bbcd-\
bb46486f3faa"],

Cell["\<\
Note that we were working with time dependence in the case of the classical \
harmonic oscillator, whereas here we are finding the time-independent \
solutions. As mentioned above, we will use a harmonic potential,\
\>", "Text",
 CellChangeTimes->{{3.809503939780018*^9, 3.8095040165575113`*^9}, 
   3.915797589610758*^9, {3.91579766343491*^9, 
   3.9157976718159075`*^9}},ExpressionUUID->"076c1b90-f870-4641-9c7c-\
306b34cf44dc"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   StyleBox["V",
    FontSlant->"Italic"], 
   RowBox[{
    StyleBox["(",
     FontSlant->"Plain"], 
    StyleBox["x",
     FontSlant->"Italic"], ")"}]}], "=", 
  RowBox[{
   FractionBox["1", "2"], 
   SuperscriptBox[
    StyleBox["kx",
     FontSlant->"Italic"], "2"]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8094362093669643`*^9, 3.809436315131312*^9}, {
   3.8094364621225743`*^9, 3.8094364990803995`*^9}, {3.8094365447169914`*^9, 
   3.8094365448488054`*^9}, 3.809504179427325*^9, 
   3.8101200349630404`*^9},ExpressionUUID->"0636f870-ede2-4856-9ad2-\
fa45b00da4b0"],

Cell["\<\
Plugging this into the equation (11), we find that our TISE takes the form\
\>", "Text",
 CellChangeTimes->{{3.8095041397431774`*^9, 3.809504192896226*^9}, {
  3.9157976745319853`*^9, 3.9157976748764567`*^9}, {3.9351445611389675`*^9, 
  3.9351445612644634`*^9}},ExpressionUUID->"efb6e403-f5ba-4354-a5f4-\
a26097804277"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"-", 
     FractionBox[
      SuperscriptBox["\[HBar]", "2"], 
      RowBox[{"2", "\[Mu]"}]]}], 
    FractionBox[
     RowBox[{
      RowBox[{
       SuperscriptBox[
        StyleBox["\[DifferentialD]",
         FontSlant->"Plain"], "2"], "\[Psi]"}], 
      RowBox[{"(", 
       StyleBox["x",
        FontSlant->"Italic"], 
       StyleBox[")",
        FontSlant->"Italic"]}]}], 
     RowBox[{
      StyleBox["\[DifferentialD]",
       FontSlant->"Plain"], 
      SuperscriptBox[
       StyleBox["x",
        FontSlant->"Italic"], "2"]}]]}], "+", 
   RowBox[{
    FractionBox["1", "2"], 
    SuperscriptBox[
     StyleBox["kx",
      FontSlant->"Italic"], "2"], "\[Psi]", 
    RowBox[{"(", 
     StyleBox["x",
      FontSlant->"Italic"], 
     StyleBox[")",
      FontSlant->"Italic"]}]}]}], "=", 
  RowBox[{
   StyleBox["E",
    FontSlant->"Italic"], 
   StyleBox[" ",
    FontSlant->"Italic"], "\[Psi]", 
   RowBox[{"(", 
    StyleBox["x",
     FontSlant->"Italic"], 
    StyleBox[")",
     FontSlant->"Italic"]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8079664251944246`*^9, 3.8079664343142004`*^9}, {
   3.8079689400739555`*^9, 3.8079689680029573`*^9}, {3.807970315263204*^9, 
   3.8079703215316095`*^9}, {3.807970415909548*^9, 3.807970437015459*^9}, {
   3.8079705221296997`*^9, 3.8079705895237727`*^9}, {3.809503913366911*^9, 
   3.809503915415073*^9}, 3.80950418131592*^9, {3.9351445650623016`*^9, 
   3.935144571452099*^9}},ExpressionUUID->"ed0907bd-d60a-4ce8-8e96-\
238b607d09a1"],

Cell["Rearranging, we obtain", "Text",
 CellChangeTimes->{{3.809504194626053*^9, 
  3.809504206654922*^9}},ExpressionUUID->"d1c26cae-f385-490d-98b9-\
b2e1c9653d78"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   FractionBox[
    RowBox[{
     RowBox[{
      SuperscriptBox[
       StyleBox["\[DifferentialD]",
        FontSlant->"Plain"], "2"], "\[Psi]"}], 
     RowBox[{"(", 
      StyleBox["x",
       FontSlant->"Italic"], 
      StyleBox[")",
       FontSlant->"Italic"]}]}], 
    RowBox[{
     StyleBox["\[DifferentialD]",
      FontSlant->"Plain"], 
     SuperscriptBox[
      StyleBox["x",
       FontSlant->"Italic"], "2"]}]], "+", 
   RowBox[{
    FractionBox[
     RowBox[{"2", "\[Mu]"}], 
     SuperscriptBox["\[HBar]", "2"]], 
    RowBox[{"(", 
     RowBox[{
      StyleBox["E",
       FontSlant->"Italic"], "-", 
      RowBox[{
       FractionBox["1", "2"], 
       SuperscriptBox[
        StyleBox["kx",
         FontSlant->"Italic"], "2"]}]}], ")"}], "\[Psi]", 
    RowBox[{"(", 
     StyleBox["x",
      FontSlant->"Italic"], 
     StyleBox[")",
      FontSlant->"Italic"]}]}]}], "=", "0"}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8079664251944246`*^9, 3.8079664343142004`*^9}, {
   3.8079689400739555`*^9, 3.8079689680029573`*^9}, {3.807970315263204*^9, 
   3.8079703215316095`*^9}, {3.807970415909548*^9, 3.807970437015459*^9}, {
   3.8079705221296997`*^9, 3.8079705895237727`*^9}, {3.809503913366911*^9, 
   3.809503915415073*^9}, 3.80950418131592*^9, {3.8095042195187864`*^9, 
   3.809504273273205*^9}, {3.8095043333052673`*^9, 3.809504334470925*^9}, {
   3.8101200292699547`*^9, 3.8101200320961294`*^9}, {3.9351446243986835`*^9, 
   3.9351446334861984`*^9}},ExpressionUUID->"cf049300-4e3b-4ac6-8423-\
a3cd632b5f3f"],

Cell[TextData[{
 "It may seem like we can solve this equation using oscillatory solutions \
(sin(",
 StyleBox["ax",
  FontSlant->"Italic"],
 "), cos(",
 StyleBox["ax",
  FontSlant->"Italic"],
 "), ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[ExponentialE]", 
    RowBox[{
     RowBox[{"\[PlusMinus]", "\[ImaginaryI]"}], " ", "a", " ", "x"}]], 
   TraditionalForm]],ExpressionUUID->"94951e80-9448-4505-b88a-01bef335bd7d"],
 "). In contrast to the case of particle in a box, the coefficient in front \
of \[Psi](",
 StyleBox["x",
  FontSlant->"Italic"],
 "),"
}], "Text",
 CellChangeTimes->{{3.809504317570773*^9, 3.8095044083026485`*^9}, {
  3.9157977171161385`*^9, 3.9157977779031925`*^9}, {3.9157978687097816`*^9, 
  3.915797874337302*^9}},ExpressionUUID->"ef4683d9-375a-4f3c-a672-\
db3ef02d3d57"],

Cell[BoxData[
 RowBox[{
  FractionBox[
   RowBox[{"2", "\[Mu]"}], 
   SuperscriptBox["\[HBar]", "2"]], 
  RowBox[{"(", 
   RowBox[{
    StyleBox["E",
     FontSlant->"Italic"], 
    StyleBox["-",
     FontSlant->"Italic"], 
    RowBox[{
     FractionBox["1", "2"], 
     SuperscriptBox[
      StyleBox["kx",
       FontSlant->"Italic"], "2"]}]}], ")"}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{
  3.8095044157088194`*^9, {3.810120039589723*^9, 
   3.8101200403607197`*^9}},ExpressionUUID->"8b66057c-4f36-4c18-b3c3-\
0bcf3263aafd"],

Cell[TextData[{
 "is not a constant but rather depends on ",
 StyleBox["x",
  FontSlant->"Italic"],
 ". When the coefficients are not constant, there is not a general method to \
find the solution, and we have to solve each case differently. We won\
\[CloseCurlyQuote]t go through all of the details of solving this equation, \
but we\[CloseCurlyQuote]ll explain the overall method briefly. If you want to \
see all of the math worked out, you can check out ",
 ButtonBox["https://quantummechanics.ucsd.edu/ph130a/130_notes/node162.html#\
derive:HOdiffeq",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://quantummechanics.ucsd.edu/ph130a/130_notes/node162.html#\
derive:HOdiffeq"], None},
  ButtonNote->
   "https://quantummechanics.ucsd.edu/ph130a/130_notes/node162.html#derive:\
HOdiffeq"],
 ".  Typically, the equation is rewritten in terms of  ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Omega]", "=", 
    SuperscriptBox[
     RowBox[{"(", 
      RowBox[{
       StyleBox["k",
        FontSlant->"Italic"], 
       StyleBox[" ",
        FontSlant->"Italic"], "/", "\[Mu]"}], ")"}], 
     RowBox[{"1", "/", "2"}]]}], TraditionalForm]],ExpressionUUID->
  "498f2b3d-8d7b-4dde-89d8-e4ccf96fdaaf"],
 "."
}], "Text",
 CellChangeTimes->{{3.809504418423972*^9, 3.809504506169779*^9}, {
  3.809505246552248*^9, 3.809505312536317*^9}, {3.8095055212137756`*^9, 
  3.8095055464639645`*^9}, {3.809505689140374*^9, 3.8095057422110977`*^9}, {
  3.809506033408766*^9, 3.809506033698092*^9}, {3.915797896870717*^9, 
  3.9157979001956453`*^9}, {3.9157979651486483`*^9, 
  3.915797966575937*^9}},ExpressionUUID->"55ae5281-bdde-4d04-9a49-\
22ab76557bcf"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   FractionBox[
    RowBox[{
     RowBox[{
      SuperscriptBox[
       StyleBox["\[DifferentialD]",
        FontSlant->"Plain"], "2"], "\[Psi]"}], 
     RowBox[{"(", 
      StyleBox["x",
       FontSlant->"Italic"], 
      StyleBox[")",
       FontSlant->"Italic"]}]}], 
    RowBox[{
     StyleBox["\[DifferentialD]",
      FontSlant->"Plain"], 
     SuperscriptBox[
      StyleBox["x",
       FontSlant->"Italic"], "2"]}]], "+", 
   RowBox[{
    FractionBox[
     RowBox[{"2", "\[Mu]"}], 
     SuperscriptBox["\[HBar]", "2"]], 
    RowBox[{"(", 
     RowBox[{
      StyleBox["E",
       FontSlant->"Italic"], 
      StyleBox["-",
       FontSlant->"Italic"], 
      RowBox[{
       FractionBox["1", "2"], 
       SuperscriptBox["\[Mu]\[Omega]", "2"], 
       SuperscriptBox[
        StyleBox["x",
         FontSlant->"Italic"], "2"]}]}], ")"}], "\[Psi]", 
    RowBox[{"(", 
     StyleBox["x",
      FontSlant->"Italic"], 
     StyleBox[")",
      FontSlant->"Italic"]}]}]}], "=", "0"}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8079664251944246`*^9, 3.8079664343142004`*^9}, {
   3.8079689400739555`*^9, 3.8079689680029573`*^9}, {3.807970315263204*^9, 
   3.8079703215316095`*^9}, {3.807970415909548*^9, 3.807970437015459*^9}, {
   3.8079705221296997`*^9, 3.8079705895237727`*^9}, {3.809503913366911*^9, 
   3.809503915415073*^9}, 3.80950418131592*^9, {3.8095042195187864`*^9, 
   3.809504273273205*^9}, {3.8095043333052673`*^9, 3.809504334470925*^9}, 
   3.809506045157501*^9, {3.81012004424642*^9, 3.810120044407648*^9}, {
   3.935144724424486*^9, 
   3.9351447287096996`*^9}},ExpressionUUID->"eab4397a-8fea-4295-806f-\
dff1a5c6176a"],

Cell["We use a change of variable to rewrite the constants,", "Text",
 CellChangeTimes->{{3.809505818051176*^9, 3.8095058382021184`*^9}, {
  3.8095059454131646`*^9, 
  3.8095059539666915`*^9}},ExpressionUUID->"2b834be3-8dd3-4259-95bd-\
eed9964962dd"],

Cell[BoxData[
 RowBox[{"\[Epsilon]", "=", 
  FractionBox[
   RowBox[{"2", 
    StyleBox["E",
     FontSlant->"Italic"]}], "\[HBar]\[Omega]"]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.809505848197194*^9, 
  3.8095058724159384`*^9}},ExpressionUUID->"fc93ae6c-fb4f-4e53-beda-\
3888b9ad7173"],

Cell["\<\
and switch to a dimensionless coordinate (one in which the units cancel) using\
\>", "Text",
 CellChangeTimes->{{3.8095059584041986`*^9, 3.8095059650661716`*^9}, {
  3.916161987670184*^9, 
  3.9161619921996765`*^9}},ExpressionUUID->"06fc003e-86c5-4ff7-8498-\
4db65d63ee0e"],

Cell[BoxData[
 RowBox[{
  StyleBox["y",
   FontSlant->"Italic"], "=", 
  RowBox[{
   SqrtBox[
    FractionBox["\[Mu]\[Omega]", "\[HBar]"]], 
   StyleBox["x",
    FontSlant->"Italic"]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.809505848197194*^9, 3.809505928531243*^9}, {
  3.8095060740271916`*^9, 
  3.809506075641164*^9}},ExpressionUUID->"527b0833-3f54-4ba8-b7e9-\
711883bb09de"],

Cell["After a bit of calculus, we can rewrite equation (16) as", "Text",
 CellChangeTimes->{{3.8095059708947573`*^9, 3.809505972515255*^9}, {
  3.8095069156470194`*^9, 3.809506933047699*^9}, {3.9157979301570344`*^9, 
  3.9157979305996695`*^9}, {3.916162001097101*^9, 
  3.9161620014456053`*^9}},ExpressionUUID->"ba3d0bee-774e-422a-a7b7-\
0901b1c29f2d"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   FractionBox[
    RowBox[{
     RowBox[{
      SuperscriptBox[
       StyleBox["\[DifferentialD]",
        FontSlant->"Plain"], "2"], "\[Psi]"}], 
     RowBox[{"(", 
      StyleBox["y",
       FontSlant->"Italic"], ")"}]}], 
    RowBox[{
     StyleBox["\[DifferentialD]",
      FontSlant->"Plain"], 
     SuperscriptBox[
      StyleBox["y",
       FontSlant->"Italic"], "2"]}]], "+", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      StyleBox["\[Epsilon]",
       FontSlant->"Italic"], 
      StyleBox["-",
       FontSlant->"Italic"], 
      SuperscriptBox[
       StyleBox["y",
        FontSlant->"Italic"], "2"]}], ")"}], "\[Psi]", 
    RowBox[{"(", 
     StyleBox["y",
      FontSlant->"Italic"], ")"}]}]}], "=", "0"}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8079664251944246`*^9, 3.8079664343142004`*^9}, {
   3.8079689400739555`*^9, 3.8079689680029573`*^9}, {3.807970315263204*^9, 
   3.8079703215316095`*^9}, {3.807970415909548*^9, 3.807970437015459*^9}, {
   3.8079705221296997`*^9, 3.8079705895237727`*^9}, {3.809503913366911*^9, 
   3.809503915415073*^9}, 3.80950418131592*^9, {3.8095042195187864`*^9, 
   3.809504273273205*^9}, {3.8095043333052673`*^9, 3.809504334470925*^9}, 
   3.809506045157501*^9, {3.8095069405492506`*^9, 3.8095069817355385`*^9}, 
   3.809507085639286*^9, {3.8095071669384413`*^9, 3.8095071699255805`*^9}, {
   3.935144845135309*^9, 
   3.9351448463816967`*^9}},ExpressionUUID->"eb9ee62a-5f9d-4678-8553-\
0737c75490bd"],

Cell["\<\
That\[CloseCurlyQuote]s pretty much as far as we can go without things \
getting really complicated. \
\>", "Text",
 CellChangeTimes->{{3.809507289712483*^9, 3.809507355841031*^9}, {
   3.8095073887352324`*^9, 3.8095074235693154`*^9}, {3.8095076374305067`*^9, 
   3.809507650579379*^9}, {3.8095077030085487`*^9, 3.809507728104512*^9}, {
   3.809508143567611*^9, 3.8095081750806932`*^9}, 
   3.9157979601757717`*^9},ExpressionUUID->"161fe3dd-0159-42e8-a957-\
2fd6e4e3fab0"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Energy Quantization", "Subsection",
 CellChangeTimes->{{3.809508184856538*^9, 
  3.8095081907759533`*^9}},ExpressionUUID->"e5a55bdc-9ed6-4d6d-a34a-\
69c220bc81a3"],

Cell["\<\
In the end, we can only find a solution that is finite (meaning there aren\
\[CloseCurlyQuote]t infinite values as x->\[Infinity]) and well-behaved \
(i.e., smooth) if we stipulate that\
\>", "Text",
 CellChangeTimes->{
  3.8095081930910606`*^9, {3.9351449069498177`*^9, 
   3.935144910337309*^9}},ExpressionUUID->"e9cd4df7-e5da-4e04-ab72-\
344224004859"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   SubscriptBox[
    StyleBox["E",
     FontSlant->"Italic"], 
    StyleBox["n",
     FontSlant->"Italic"]], "=", 
   RowBox[{
    RowBox[{"\[HBar]", 
     SuperscriptBox[
      RowBox[{"(", 
       FractionBox[
        StyleBox["k",
         FontSlant->"Italic"], "\[Mu]"], ")"}], 
      RowBox[{"1", "/", "2"}]], 
     RowBox[{"(", 
      RowBox[{
       StyleBox["n",
        FontSlant->"Italic"], "+", 
       FractionBox["1", "2"]}], ")"}]}], "=", 
    RowBox[{
     RowBox[{"\[HBar]\[Omega]", 
      RowBox[{"(", 
       RowBox[{
        StyleBox["n",
         FontSlant->"Italic"], "+", 
        FractionBox["1", "2"]}], ")"}]}], "=", 
     RowBox[{
      RowBox[{
       StyleBox[
        RowBox[{
         StyleBox["h",
          FontSlant->"Italic"], 
         StyleBox["\[Nu]",
          FontSlant->"Plain"]}]], 
       RowBox[{"(", 
        RowBox[{
         StyleBox["n",
          FontSlant->"Italic"], "+", 
         FractionBox["1", "2"]}], ")"}], "            ", 
       StyleBox["n",
        FontSlant->"Italic"]}], "=", "0"}]}]}]}], ",", "1", ",", 
  RowBox[{"2", "..."}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.809505848197194*^9, 3.8095058724159384`*^9}, {
  3.8095074446596847`*^9, 3.809507500366709*^9}, {3.809507545139214*^9, 
  3.8095075962228546`*^9}, {3.8095078283336425`*^9, 3.8095078363260736`*^9}, {
  3.809507978895641*^9, 
  3.8095080068235674`*^9}},ExpressionUUID->"0a18c4c2-74cd-48a1-985b-\
6e9712fe8005"],

Cell["where", "Text",
 CellChangeTimes->{{3.8095076028627167`*^9, 
  3.8095076133429613`*^9}},ExpressionUUID->"35f6d58c-b47b-4c79-a3df-\
cb9f2e57e87d"],

Cell[BoxData[
 RowBox[{"\[Omega]", "=", 
  SuperscriptBox[
   RowBox[{"(", 
    FractionBox[
     StyleBox["k",
      FontSlant->"Italic"], "\[Mu]"], ")"}], 
   RowBox[{"1", "/", "2"}]]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.809507737640396*^9, 3.809507770269117*^9}, {
  3.916488567948269*^9, 
  3.9164885702899327`*^9}},ExpressionUUID->"ba208936-abe9-4080-a36f-\
1394a80f3d97"],

Cell["and", "Text",
 CellChangeTimes->{{3.9164885842765565`*^9, 
  3.9164885845286436`*^9}},ExpressionUUID->"48d7cdd8-9aec-4da7-8cd6-\
0c1c915f2762"],

Cell[BoxData[
 RowBox[{"\[Nu]", "=", 
  RowBox[{
   FractionBox["1", 
    RowBox[{"2", "\[Pi]"}]], 
   SuperscriptBox[
    RowBox[{"(", 
     FractionBox[
      StyleBox["k",
       FontSlant->"Italic"], "\[Mu]"], ")"}], 
    RowBox[{"1", "/", "2"}]]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.809507737640396*^9, 
  3.809507770269117*^9}},ExpressionUUID->"e0505228-6a57-4436-aed9-\
975502553e36"],

Cell[TextData[{
 "Note that sometimes this equation is written with ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["E",
    FontSlant->"Italic"], 
   StyleBox["v",
    FontSlant->"Italic"]]],
  CellChangeTimes->{{3.809505848197194*^9, 3.8095058724159384`*^9}, {
   3.8095074446596847`*^9, 3.809507500366709*^9}, {3.809507545139214*^9, 
   3.8095075962228546`*^9}, {3.8095078283336425`*^9, 
   3.8095078363260736`*^9}, {3.809507978895641*^9, 3.8095080068235674`*^9}},
  ExpressionUUID->"525e9867-7643-4734-9e09-f20aa7c9de94"],
 " instead of ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["E",
    FontSlant->"Italic"], 
   StyleBox["n",
    FontSlant->"Italic"]]],
  CellChangeTimes->{{3.809505848197194*^9, 3.8095058724159384`*^9}, {
   3.8095074446596847`*^9, 3.809507500366709*^9}, {3.809507545139214*^9, 
   3.8095075962228546`*^9}, {3.8095078283336425`*^9, 
   3.8095078363260736`*^9}, {3.809507978895641*^9, 3.8095080068235674`*^9}},
  ExpressionUUID->"a3d40d68-80d0-4034-abf9-e503ea9330e8"],
 " (using ",
 StyleBox["v",
  FontSlant->"Italic"],
 " as the symbol for the quantum number), but I find it confusing to \
differentiated between ",
 StyleBox["v",
  FontSlant->"Italic"],
 " (latin v) and \[Nu] (greek nu)."
}], "Text",
 CellChangeTimes->{{3.80950784140691*^9, 3.809507844663949*^9}, {
  3.8095080168641195`*^9, 
  3.809508077034024*^9}},ExpressionUUID->"2a4cb5de-c160-48e9-b79d-\
c04df6a3a781"]
}, Open  ]],

