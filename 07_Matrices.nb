   3.811266165339726*^9, 
   3.8112662740754085`*^9}},ExpressionUUID->"bef7249e-df03-4605-bf39-\
8e37fd8b1fe2"],

Cell["\<\
You can expand a square matrix of arbitrary size to be represented in terms \
of cofactors until you get to the easily-evaluated 2\[Cross]2 case. In \
general, though, you could just let a computer calculate the determinant. In \
Mathematica, you can use the command Det[],\
\>", "Text",
 CellChangeTimes->{{3.8112662785644865`*^9, 3.81126629538097*^9}, {
  3.8112663390620503`*^9, 
  3.811266370202342*^9}},ExpressionUUID->"e25f948b-c348-48db-bc2b-\
8b8376c5da18"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Det", "[", 
  RowBox[{"(", "\[NoBreak]", GridBox[{
     {
      SubscriptBox[
       StyleBox["a",
        FontSlant->"Italic"], "11"], 
      SubscriptBox[
       StyleBox["a",
        FontSlant->"Italic"], "12"], 
      SubscriptBox[
       StyleBox["a",
        FontSlant->"Italic"], "13"]},
     {
      SubscriptBox[
       StyleBox["a",
        FontSlant->"Italic"], "21"], 
      SubscriptBox[
       StyleBox["a",
        FontSlant->"Italic"], "22"], 
      SubscriptBox[
       StyleBox["a",
        FontSlant->"Italic"], "23"]},
     {
      SubscriptBox[
       StyleBox["a",
        FontSlant->"Italic"], "31"], 
      SubscriptBox[
       StyleBox["a",
        FontSlant->"Italic"], "32"], 
      SubscriptBox[
       StyleBox["a",
        FontSlant->"Italic"], "33"]}
    }], "\[NoBreak]", ")"}], "]"}]], "Input",
 CellChangeTimes->{{3.8112652621929674`*^9, 3.8112652809935794`*^9}},
 CellLabel->"In[26]:=",ExpressionUUID->"20a6ef9a-8db9-452b-9c80-a776f2977403"],

