Cell["\<\
We are now working in spherical coordinates, where these operators become\
\>", "Text",
 CellChangeTimes->{{3.8107129375274935`*^9, 
  3.810712963748344*^9}},ExpressionUUID->"bf1afc4f-9dfc-4867-8a76-\
1392006c8d49"],

Cell[BoxData[
 RowBox[{
  SubscriptBox[
   OverscriptBox[
    StyleBox["L",
     FontSlant->"Italic"], "^"], 
   StyleBox["x",
    FontSlant->"Italic"]], "=", 
  RowBox[{
   RowBox[{"-", "\[ImaginaryI]\[HBar]"}], 
   RowBox[{"(", 
    RowBox[{
     RowBox[{"-", "sin"}], "\[Theta]", 
     RowBox[{
      FractionBox["\[PartialD]", 
       RowBox[{"\[PartialD]", "\[Theta]"}]], 
      RowBox[{"-", "cot\[Theta]"}]}], " ", "cos\[Phi]", " ", 
     FractionBox["\[PartialD]", 
      RowBox[{"\[PartialD]", "\[Phi]"}]]}], 
    ")"}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8100544880652375`*^9, 3.8100545041200957`*^9}, {
  3.810054632482561*^9, 3.8100546606919527`*^9}, {3.810054738405748*^9, 
  3.810054754160844*^9}, {3.810055496888957*^9, 3.810055644063492*^9}, {
  3.8101099522060614`*^9, 3.8101100508523717`*^9}, {3.8101101194750385`*^9, 
  3.810110136121354*^9}, {3.8107126867697287`*^9, 3.810712741604373*^9}, {
  3.810712809473565*^9, 3.810712872371795*^9}, {3.8107129714133415`*^9, 
  3.8107130201357374`*^9}},ExpressionUUID->"1539925d-4734-4711-b5ca-\
1a3c32b26709"],

Cell[BoxData[
 RowBox[{
  SubscriptBox[
   StyleBox[
    OverscriptBox[
     StyleBox["L",
      FontSlant->"Italic"], "^"],
    FontSlant->"Italic"], 
   StyleBox["y",
    FontSlant->"Italic"]], "=", 
  RowBox[{
   RowBox[{"-", "\[ImaginaryI]\[HBar]"}], 
   RowBox[{"(", 
    RowBox[{"cos\[Phi]", 
     RowBox[{
      FractionBox["\[PartialD]", 
       RowBox[{"\[PartialD]", "\[Theta]"}]], 
      RowBox[{"-", "cot\[Theta]"}]}], " ", "sin\[Phi]", " ", 
     FractionBox["\[PartialD]", 
      RowBox[{"\[PartialD]", "\[Phi]"}]]}], 
    ")"}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8100544880652375`*^9, 3.8100545041200957`*^9}, {
  3.810054632482561*^9, 3.8100546606919527`*^9}, {3.810054738405748*^9, 
