9adb5cb0d9eb"],

Cell["to obtain", "Text",
 CellChangeTimes->{{3.921491748284997*^9, 
  3.9214917492345676`*^9}},ExpressionUUID->"7af28429-4e40-4c87-94d5-\
636caf9ca6d7"],

Cell[BoxData[
 RowBox[{
  RowBox[{"\[LeftAngleBracket]", 
   SuperscriptBox[
    StyleBox["v",
     FontSlant->"Italic"], "2"], "\[RightAngleBracket]"}], "=", 
  RowBox[{
   RowBox[{
    RowBox[{"\[LeftAngleBracket]", 
     SubsuperscriptBox["v", "x", "2"], "\[RightAngleBracket]"}], "+", 
    RowBox[{"\[LeftAngleBracket]", 
     SubsuperscriptBox["v", "y", "2"], "\[RightAngleBracket]"}], "+", 
    RowBox[{"\[LeftAngleBracket]", 
     SubsuperscriptBox["v", "z", "2"], "\[RightAngleBracket]"}]}], "=", 
   RowBox[{"(", 
    FractionBox[
     RowBox[{"3", 
      SubscriptBox[
       StyleBox["k",
        FontSlant->"Italic"], 
       StyleBox["B",
        FontSlant->"Italic"]], 
      StyleBox["T",
       FontSlant->"Italic"]}], 
     StyleBox["m",
      FontSlant->"Italic"]], ")"}]}]}]], "DisplayFormulaNumbered",
 InitializationCell->True,
 CellChangeTimes->{{3.9212505192469416`*^9, 3.921250534863843*^9}, {
   3.9212507356598735`*^9, 3.9212507676410656`*^9}, {3.9212508673633738`*^9, 
   3.9212509608799176`*^9}, {3.921251060924367*^9, 3.9212511124818687`*^9}, {
   3.9212511504673223`*^9, 3.921251158794492*^9}, {3.9212512029019794`*^9, 
