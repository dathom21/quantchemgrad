Cell[TextData[{
 StyleBox["Figure 6.2",
  FontWeight->"Bold"],
 ". Quantization of the angular momentum of the hydrogen atom. Shown are the \
vector representations of ",
 StyleBox["l",
  FontSlant->"Italic"],
 " = 2 and ",
 StyleBox["m",
  FontSlant->"Italic"],
 " = \[Minus]2, \[Minus]1, 0, 1, and 2. For a given value of ",
 StyleBox["l",
  FontSlant->"Italic"],
 " and ",
 StyleBox["m",
  FontSlant->"Italic"],
 ", the angular momentum vector ",
 StyleBox["L",
  FontWeight->"Bold",
  FontSlant->"Italic"],
 " of magnitude  ",
 Cell[BoxData[
  SuperscriptBox[
   RowBox[{"\[HBar]", "[", 
    RowBox[{
     StyleBox["l",
      FontSlant->"Italic"], 
     RowBox[{
      StyleBox["(",
       FontSlant->"Italic"], 
      RowBox[{
       StyleBox["l",
        FontSlant->"Italic"], "+", "1"}], ")"}]}], "]"}], 
   RowBox[{"1", "/", "2"}]]],
  CellChangeTimes->{{3.810112811439228*^9, 3.8101128248442793`*^9}, {
    3.810479494926491*^9, 3.8104795038498344`*^9}, {3.810479572543576*^9, 
    3.8104796147383184`*^9}, {3.8104802055659895`*^9, 
    3.8104802433915305`*^9}, {3.8104802785189395`*^9, 
    3.8104802814214115`*^9}, {3.810480477782269*^9, 3.8104805471507206`*^9}, {
    3.8104805927965565`*^9, 3.810480633017248*^9}, {3.8104807595294323`*^9, 
    3.8104809538100047`*^9}, {3.8104811300285854`*^9, 
    3.8104811403007636`*^9}, {3.8104812580010843`*^9, 
    3.8104813317580833`*^9}, {3.81048146789211*^9, 3.8104815557630205`*^9}, {
    3.8104817202872114`*^9, 3.8104817438715935`*^9}, 3.810481790764664*^9, 
    3.810481836241686*^9, {3.810481926951917*^9, 3.810481935802024*^9}, {
    3.8106609069078913`*^9, 3.81066090872985*^9}, {3.8106610360496655`*^9, 
    3.8106610794321012`*^9}, {3.8106611250786457`*^9, 
    3.8106611896874313`*^9}, {3.810661579097098*^9, 3.8106616142945995`*^9}, {
    3.8107159413646593`*^9, 3.810716006004163*^9}},ExpressionUUID->
  "fcf960ec-432f-4884-ba37-55152269df49"],
 " points somewhere on a circle with a z-component ",
 Cell[BoxData[
  FormBox[
   SubscriptBox[
    StyleBox["L",
     FontWeight->"Bold"], "z"], TraditionalForm]],ExpressionUUID->
  "9de54297-28b4-4d33-9c13-937b78b6e411"],
 " of magnitude m\[HBar]. Maschen, Wikimedia, 2012, Public Domain, \
https://commons.wikimedia.org/wiki/File:Vector_model_of_orbital_angular_\
momentum.svg"
}], "Affiliation",
 CellChangeTimes->{{3.809435027311596*^9, 3.8094350763900714`*^9}, {
  3.80943583474421*^9, 3.8094358359299717`*^9}, {3.8094472165104203`*^9, 
  3.809447281165168*^9}, {3.810054221304062*^9, 3.8100542409148703`*^9}, {
  3.8101125924447937`*^9, 3.8101126426025887`*^9}, {3.8101127071459217`*^9, 
  3.810112714050138*^9}, {3.810115126505663*^9, 3.810115154403865*^9}, {
  3.8101152097595587`*^9, 3.8101152368678613`*^9}, {3.8104844563968916`*^9, 
  3.8104844576598825`*^9}, {3.810716456400798*^9, 3.8107166740108333`*^9}, {
  3.810716839152422*^9, 3.8107168476612215`*^9}, {3.8107171062759004`*^9, 
  3.8107171338184347`*^9}, {3.8107173818819304`*^9, 3.81071741604937*^9}, {
  3.917100556689255*^9, 
  3.9171005577047863`*^9}},ExpressionUUID->"5bfedb46-c6a3-4b4d-b4be-\
006000d0c210"],

Cell[TextData[{
 "It\[CloseCurlyQuote]s worth noting again here that the choice of ",
 Cell[BoxData[
  StyleBox[
   SubscriptBox["L", 
    StyleBox["z",
     FontSlant->"Italic"]],
   FontSlant->"Italic"]],
  CellChangeTimes->{{3.8100544880652375`*^9, 3.8100545041200957`*^9}, {
    3.810054632482561*^9, 3.8100546606919527`*^9}, {3.810054738405748*^9, 
    3.810054754160844*^9}, {3.810055496888957*^9, 3.810055644063492*^9}, {
    3.8101099522060614`*^9, 3.8101100508523717`*^9}, {3.8101101194750385`*^9, 
    3.8101101642963843`*^9}, {3.8107127659519644`*^9, 3.810712781977992*^9}, {
    3.8107128863205147`*^9, 3.8107129246267147`*^9}, 3.810712975971156*^9, 
    3.8107130396874857`*^9, {3.810713072953952*^9, 3.810713077029566*^9}, {
    3.8107138654100857`*^9, 3.810713907959445*^9}, 3.810714092835499*^9, {
    3.8107142057542086`*^9, 3.8107142281878614`*^9}, {3.810716060883625*^9, 
    3.8107160908687468`*^9}},ExpressionUUID->
  "67239c27-15ea-4877-b87f-cf35ef92bfe9"],
 " is arbitrary, and we could specify any axis as the \
\[OpenCurlyDoubleQuote]special\[CloseCurlyDoubleQuote] axis."
}], "Text",
 CellChangeTimes->{{3.8107178348391027`*^9, 
  3.8107178649269342`*^9}},ExpressionUUID->"6e150eba-8460-46c3-bb9b-\
11c2db03d44d"],

Cell[TextData[{
 "In summary, the hydrogen atomic quantum numbers ",
 StyleBox["l",
  FontSlant->"Italic"],
 " and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["m", "l"], TraditionalForm]],ExpressionUUID->
  "b5de993d-66ff-45fe-84d1-1d62d56ec4c3"],
 " tell us about the square of the angular momentum and the axial projection \
of the angular momentum for a given state ",
 Cell[BoxData[
  RowBox[{
   SubsuperscriptBox[
    StyleBox["Y",
     FontSlant->"Italic"], 
    StyleBox["l",
     FontSlant->"Italic"], 
    SubscriptBox[
     StyleBox["m",
      FontSlant->"Italic"], 
     StyleBox["l",
      FontSlant->"Italic"]]], 
   RowBox[{"(", 
    RowBox[{"\[Theta]", ",", "\[Phi]"}], ")"}]}]],
  CellChangeTimes->{{3.8100544880652375`*^9, 3.8100545041200957`*^9}, {
    3.810054632482561*^9, 3.8100546606919527`*^9}, {3.810054738405748*^9, 
    3.810054754160844*^9}, {3.810055496888957*^9, 3.810055644063492*^9}, {
    3.8101099522060614`*^9, 3.8101100508523717`*^9}, {3.8101101194750385`*^9, 
    3.8101101642963843`*^9}, {3.8107127659519644`*^9, 3.810712781977992*^9}, {
    3.8107128863205147`*^9, 3.8107129246267147`*^9}, 3.810712975971156*^9, 
    3.8107130396874857`*^9, {3.810713072953952*^9, 3.810713077029566*^9}, {
    3.8107138654100857`*^9, 3.810713907959445*^9}, 3.810714092835499*^9, {
    3.8107142057542086`*^9, 3.8107142281878614`*^9}, {3.810715311267351*^9, 
    3.810715321066903*^9}},ExpressionUUID->
  "3c33456e-b6ed-42e6-889d-22db90042d3d"],
 ". So far we have only been talking about the spherical harmonics ",
 Cell[BoxData[
  RowBox[{
   SubsuperscriptBox[
    StyleBox["Y",
     FontSlant->"Italic"], 
    StyleBox["l",
     FontSlant->"Italic"], 
    SubscriptBox[
     StyleBox["m",
      FontSlant->"Italic"], 
     StyleBox["l",
      FontSlant->"Italic"]]], 
   RowBox[{"(", 
    RowBox[{"\[Theta]", ",", "\[Phi]"}], ")"}]}]],
  CellChangeTimes->{{3.8100544880652375`*^9, 3.8100545041200957`*^9}, {
    3.810054632482561*^9, 3.8100546606919527`*^9}, {3.810054738405748*^9, 
    3.810054754160844*^9}, {3.810055496888957*^9, 3.810055644063492*^9}, {
    3.8101099522060614`*^9, 3.8101100508523717`*^9}, {3.8101101194750385`*^9, 
    3.8101101642963843`*^9}, {3.8107127659519644`*^9, 3.810712781977992*^9}, {
    3.8107128863205147`*^9, 3.8107129246267147`*^9}, 3.810712975971156*^9, 
    3.8107130396874857`*^9, {3.810713072953952*^9, 3.810713077029566*^9}, {
    3.8107138654100857`*^9, 3.810713907959445*^9}, 3.810714092835499*^9, {
    3.8107142057542086`*^9, 3.8107142281878614`*^9}, {3.810715311267351*^9, 
    3.810715321066903*^9}},ExpressionUUID->
  "d199495b-aac9-4860-91c5-8bb2b40148d7"],
 ", but note that none of the angular momentum operators we have been \
discussing in this section have any radial dependence. Therefore, the \
wavefunctions ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox["\[Psi]", 
    SubscriptBox[
     StyleBox["nlm",
      FontSlant->"Italic"], 
     StyleBox["l",
      FontSlant->"Italic"]]], 
   RowBox[{"(", 
    RowBox[{
     StyleBox["r",
      FontSlant->"Italic"], ",", "\[Theta]", ",", "\[Phi]"}], ")"}]}]],
  CellChangeTimes->{{3.810112811439228*^9, 3.8101128248442793`*^9}, {
    3.810479494926491*^9, 3.8104795038498344`*^9}, {3.810479572543576*^9, 
    3.8104796147383184`*^9}, {3.8104802055659895`*^9, 
    3.8104802433915305`*^9}, {3.8104802785189395`*^9, 
    3.8104802814214115`*^9}, {3.810480477782269*^9, 3.8104805471507206`*^9}, {
    3.8104805927965565`*^9, 3.810480633017248*^9}, {3.8104807595294323`*^9, 
    3.8104809538100047`*^9}, {3.8104811300285854`*^9, 
    3.8104811403007636`*^9}, {3.8104812580010843`*^9, 
    3.8104813317580833`*^9}, {3.81048146789211*^9, 3.8104815557630205`*^9}, {
    3.8104817202872114`*^9, 3.8104817438715935`*^9}, 3.810481790764664*^9, 
    3.810481836241686*^9, {3.810481926951917*^9, 3.810481935802024*^9}, {
    3.8104820720505495`*^9, 3.8104821860076323`*^9}, {3.810482833577834*^9, 
    3.810482856592573*^9}, {3.810650687465464*^9, 3.8106507334315205`*^9}, 
    3.810651925937356*^9, {3.81065862305245*^9, 3.8106586554576225`*^9}},
  ExpressionUUID->"268fc0e4-000a-4ef5-b566-a48d62f7d207"],
 " are also eigenfunctions of the angular momentum operators. In equation \
form, we find that"
}], "Text",
 CellChangeTimes->{{3.810717909234481*^9, 3.810717971100748*^9}, {
  3.8107180709530587`*^9, 3.810718095810789*^9}, {3.810718130973847*^9, 
  3.810718191813285*^9}, {3.810718344088706*^9, 3.8107183736509886`*^9}, {
  3.917087123377655*^9, 3.9170871355025473`*^9}, {3.9171003540656953`*^9, 
  3.9171003553047953`*^9}},ExpressionUUID->"68270ec8-7458-414d-8359-\
d9f46cd9ff9e"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   SuperscriptBox[
    OverscriptBox[
     StyleBox["L",
      FontSlant->"Italic"], "^"], "2"], 
   SubscriptBox["\[Psi]", 
    SubscriptBox[
     StyleBox["nlm",
      FontSlant->"Italic"], 
     StyleBox["l",
      FontSlant->"Italic"]]], 
   RowBox[{"(", 
    RowBox[{
     StyleBox["r",
      FontSlant->"Italic"], ",", "\[Theta]", ",", "\[Phi]"}], ")"}]}], "=", 
  RowBox[{
   RowBox[{
    SubscriptBox[
     StyleBox["R",
      FontSlant->"Italic"], 
     StyleBox["nl",
      FontSlant->"Italic"]], 
    RowBox[{"(", 
     StyleBox["r",
      FontSlant->"Italic"], ")"}], 
    SuperscriptBox[
     OverscriptBox[
      StyleBox["L",
       FontSlant->"Italic"], "^"], "2"], 
    SubsuperscriptBox[
     StyleBox["Y",
      FontSlant->"Italic"], 
     StyleBox["l",
      FontSlant->"Italic"], 
     SubscriptBox["m", 
      StyleBox["l",
       FontSlant->"Italic"]]], 
    RowBox[{"(", 
     RowBox[{"\[Theta]", ",", "\[Phi]"}], ")"}]}], "=", 
   RowBox[{
    SuperscriptBox["\[HBar]", "2"], 
    FormBox[
     RowBox[{"l", "(", 
      RowBox[{"l", "+", "1"}], ")"}],
     TraditionalForm], 
    SubscriptBox["\[Psi]", 
     StyleBox[
      SubscriptBox[
       StyleBox[
        RowBox[{"nl", 
         StyleBox["m",
          FontSlant->"Italic"]}]], 
       StyleBox["l",
        FontSlant->"Italic"]],
      FontSlant->"Italic"]], 
    RowBox[{"(", 
     RowBox[{
      StyleBox["r",
       FontSlant->"Italic"], ",", "\[Theta]", ",", "\[Phi]"}], 
     ")"}]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.810112811439228*^9, 3.8101128248442793`*^9}, {
   3.810479494926491*^9, 3.8104795038498344`*^9}, {3.810479572543576*^9, 
   3.8104796147383184`*^9}, {3.8104802055659895`*^9, 
   3.8104802433915305`*^9}, {3.8104802785189395`*^9, 
   3.8104802814214115`*^9}, {3.810480477782269*^9, 3.8104805471507206`*^9}, {
   3.8104805927965565`*^9, 3.810480633017248*^9}, {3.8104807595294323`*^9, 
   3.8104809538100047`*^9}, {3.8104811300285854`*^9, 
   3.8104811403007636`*^9}, {3.8104812580010843`*^9, 
   3.8104813317580833`*^9}, {3.81048146789211*^9, 3.8104815557630205`*^9}, {
   3.8104817202872114`*^9, 3.8104817438715935`*^9}, 3.810481790764664*^9, 
   3.810481836241686*^9, {3.810481926951917*^9, 3.810481935802024*^9}, {
   3.8106609069078913`*^9, 3.81066090872985*^9}, {3.8106610360496655`*^9, 
   3.8106610794321012`*^9}, {3.8106611250786457`*^9, 
   3.8106611896874313`*^9}, {3.810718226403468*^9, 3.8107182918531866`*^9}, {
   3.917100338409707*^9, 
   3.9171003712266054`*^9}},ExpressionUUID->"61eb17d8-a74d-4b82-bb40-\
20591aa8630e"],

Cell["and", "Text",
 CellChangeTimes->{{3.810718295844208*^9, 
  3.810718296071756*^9}},ExpressionUUID->"ea9c3f76-7481-47d1-b9dc-\
4874a68a60f6"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   SubscriptBox[
    StyleBox[
     OverscriptBox[
      StyleBox["L",
       FontSlant->"Italic"], "^"],
     FontSlant->"Italic"], 
    StyleBox["z",
     FontSlant->"Italic"]], 
   FormBox[
    RowBox[{
     RowBox[{
      SubscriptBox["\[Psi]", 
       StyleBox[
        SubscriptBox[
         StyleBox[
          RowBox[{"nl", 
           StyleBox["m",
            FontSlant->"Italic"]}]], 
         StyleBox["l",
          FontSlant->"Italic"]],
        FontSlant->"Italic"]], "(", 
      RowBox[{
       StyleBox["r",
        FontSlant->"Italic"], ",", "\[Theta]", ",", "\[Phi]"}], ")"}], "=", 
     RowBox[{
      RowBox[{
       SubscriptBox[
        StyleBox["R",
         FontSlant->"Italic"], 
        StyleBox["nl",
         FontSlant->"Italic"]], "(", 
       StyleBox["r",
        FontSlant->"Italic"], ")"}], 
      SubscriptBox[
       StyleBox[
        OverscriptBox[
         StyleBox["L",
          FontSlant->"Italic"], "^"],
        FontSlant->"Italic"], 
       StyleBox["z",
        FontSlant->"Italic"]], 
      RowBox[{
       SubsuperscriptBox[
        StyleBox["Y",
         FontSlant->"Italic"], 
        StyleBox["l",
         FontSlant->"Italic"], 
        SubscriptBox["m", 
         StyleBox["l",
          FontSlant->"Italic"]]], "(", 
       RowBox[{"\[Theta]", ",", "\[Phi]"}], ")"}]}]}],
    TraditionalForm]}], "=", 
  RowBox[{
   StyleBox[
    SubscriptBox[
     StyleBox["m",
      FontSlant->"Italic"], 
     StyleBox["l",
      FontSlant->"Italic"]],
    FontSlant->"Italic"], 
   SubscriptBox[
    StyleBox[
     RowBox[{
      StyleBox["\[HBar]",
       FontSlant->"Plain"], "\[Psi]"}]], 
    StyleBox[
     SubscriptBox[
      StyleBox[
       RowBox[{"nl", 
        StyleBox["m",
         FontSlant->"Italic"]}]], 
      StyleBox["l",
       FontSlant->"Italic"]],
     FontSlant->"Italic"]], 
   RowBox[{"(", 
    RowBox[{
     StyleBox["r",
      FontSlant->"Italic"], ",", "\[Theta]", ",", "\[Phi]"}], 
    ")"}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8100544880652375`*^9, 3.8100545041200957`*^9}, {
   3.810054632482561*^9, 3.8100546606919527`*^9}, {3.810054738405748*^9, 
   3.810054754160844*^9}, {3.810055496888957*^9, 3.810055644063492*^9}, {
   3.8101099522060614`*^9, 3.8101100508523717`*^9}, {3.8101101194750385`*^9, 
   3.8101101642963843`*^9}, {3.8107127659519644`*^9, 3.810712781977992*^9}, {
   3.8107128863205147`*^9, 3.8107129246267147`*^9}, 3.810712975971156*^9, 
   3.8107130396874857`*^9, {3.810713072953952*^9, 3.810713077029566*^9}, {
   3.8107138654100857`*^9, 3.810713907959445*^9}, 3.810714092835499*^9, {
   3.8107142057542086`*^9, 3.8107142281878614`*^9}, {3.810718300253166*^9, 
   3.8107183324677906`*^9}, {3.9171003452216034`*^9, 3.917100346202338*^9}, {
   3.9171003771085787`*^9, 
   3.917100384511202*^9}},ExpressionUUID->"278d0410-0650-4498-9021-\
dc244439c5c6"],

Cell["\<\
So these conclusions are valid for the entire wavefunction, not just the \
spherical harmonics component.\
\>", "Text",
 CellChangeTimes->{{3.8107184233107414`*^9, 
  3.8107184357718477`*^9}},ExpressionUUID->"3cb1598e-51c9-4e88-9752-\
906ab46cba33"]
}, Open  ]],

Cell[CellGroupData[{

Cell["The Hydrogen Atomic Quantum Numbers and Atomic Orbitals", "Subsection",
 CellChangeTimes->{{3.8107185414655523`*^9, 
  3.810718556034485*^9}},ExpressionUUID->"4c3863a1-dd68-4a9a-870f-\
2685e855714f"],

Cell[TextData[{
 "We are now in a position explain the origin of  the atomic orbitals \
typically introduced in general chemistry courses. We will see that the \
different types of orbitals are related to the quantum numbers ",
 StyleBox["n",
  FontSlant->"Italic"],
 ", ",
 StyleBox["l",
  FontSlant->"Italic"],
 ", and ",
 Cell[BoxData[
  StyleBox[
   SubscriptBox[
    StyleBox["m",
     FontSlant->"Italic"], 
    StyleBox["l",
     FontSlant->"Italic"]],
   FontSlant->"Italic"]],
  CellChangeTimes->{{3.810112811439228*^9, 3.8101128248442793`*^9}, {
    3.810479494926491*^9, 3.8104795038498344`*^9}, {3.810479572543576*^9, 
    3.8104796147383184`*^9}, {3.8104802055659895`*^9, 
    3.8104802433915305`*^9}, {3.8104802785189395`*^9, 
    3.8104802814214115`*^9}, {3.810480477782269*^9, 3.8104805471507206`*^9}, {
    3.8104805927965565`*^9, 3.810480633017248*^9}, {3.8104807595294323`*^9, 
    3.8104809538100047`*^9}, {3.8104811300285854`*^9, 
    3.8104811403007636`*^9}, {3.8104812580010843`*^9, 
    3.8104813317580833`*^9}, {3.81048146789211*^9, 3.8104815557630205`*^9}, {
    3.8104817202872114`*^9, 3.8104817438715935`*^9}, 3.810481790764664*^9, 
    3.810481836241686*^9, {3.810481926951917*^9, 3.810481935802024*^9}, {
    3.8104820720505495`*^9, 3.8104821860076323`*^9}, {3.810482900850647*^9, 
    3.8104829123165646`*^9}, {3.8104829752587*^9, 3.8104829860744143`*^9}, {
    3.810483024639452*^9, 3.810483038492651*^9}, {3.8104830702023983`*^9, 
    3.8104830866522465`*^9}, {3.8104831187257876`*^9, 3.810483135292489*^9}, {
    3.8104831732744513`*^9, 3.8104831809128747`*^9}, {3.810646494275571*^9, 
    3.8106466133679247`*^9}, {3.810647155079011*^9, 3.8106472289497843`*^9}, 
    3.9170224764040937`*^9},ExpressionUUID->
  "838e9297-8b04-4db7-b3fb-8dca0cbc8c58"],
 " that arose as we solved the time-independent Schr\[ODoubleDot]dinger \
equation for the hydrogen atom. Specifically, what we often refer to as \
atomic orbitals correspond to different wavefunctions (or eigenfunctions) of \
the electron in the hydrogen atom, each with a specific value of ",
 StyleBox["n",
  FontSlant->"Italic"],
 ", ",
 StyleBox["l",
  FontSlant->"Italic"],
 ", and ",
 Cell[BoxData[
  StyleBox[
   SubscriptBox[
    StyleBox["m",
     FontSlant->"Italic"], 
    StyleBox["l",
     FontSlant->"Italic"]],
   FontSlant->"Italic"]],
  CellChangeTimes->{{3.810112811439228*^9, 3.8101128248442793`*^9}, {
    3.810479494926491*^9, 3.8104795038498344`*^9}, {3.810479572543576*^9, 
    3.8104796147383184`*^9}, {3.8104802055659895`*^9, 
    3.8104802433915305`*^9}, {3.8104802785189395`*^9, 
    3.8104802814214115`*^9}, {3.810480477782269*^9, 3.8104805471507206`*^9}, {
    3.8104805927965565`*^9, 3.810480633017248*^9}, {3.8104807595294323`*^9, 
    3.8104809538100047`*^9}, {3.8104811300285854`*^9, 
    3.8104811403007636`*^9}, {3.8104812580010843`*^9, 
    3.8104813317580833`*^9}, {3.81048146789211*^9, 3.8104815557630205`*^9}, {
    3.8104817202872114`*^9, 3.8104817438715935`*^9}, 3.810481790764664*^9, 
    3.810481836241686*^9, {3.810481926951917*^9, 3.810481935802024*^9}, {
    3.8104820720505495`*^9, 3.8104821860076323`*^9}, {3.810482900850647*^9, 
    3.8104829123165646`*^9}, {3.8104829752587*^9, 3.8104829860744143`*^9}, {
    3.810483024639452*^9, 3.810483038492651*^9}, {3.8104830702023983`*^9, 
    3.8104830866522465`*^9}, {3.8104831187257876`*^9, 3.810483135292489*^9}, {
    3.8104831732744513`*^9, 3.8104831809128747`*^9}, {3.810646494275571*^9, 
    3.8106466133679247`*^9}, {3.810647155079011*^9, 3.8106472289497843`*^9}, 
    3.9170224764040937`*^9},ExpressionUUID->
  "bc11d3e9-d4ef-482b-808a-1b80fdc119df"],
 "."
}], "Text",
 CellChangeTimes->{{3.8107189729333787`*^9, 3.810718976427901*^9}, {
  3.810719025739422*^9, 3.8107191595024567`*^9}, {3.8107196525300317`*^9, 
  3.810719748935833*^9}, {3.8107220152013965`*^9, 3.8107220172533903`*^9}, {
  3.9171003921912203`*^9, 
  3.9171003984840603`*^9}},ExpressionUUID->"048e28ed-e0f5-474f-9c97-\
651143b9a0a8"],

Cell[CellGroupData[{

Cell["The Quantum Numbers and Atomic Orbital Designations", "Subsubsection",
 CellChangeTimes->{{3.8107192356180935`*^9, 3.8107192389984384`*^9}, {
  3.810720092755737*^9, 
  3.81072009754844*^9}},ExpressionUUID->"77617d2c-4247-4853-b837-\
e84e1aa33d6c"],

Cell[TextData[{
 "When solving the radial equation for the wavefunctions of the hydrogen \
atom, we found that we could only find well-behaved solutions if we \
introduced the quantum number ",
 StyleBox["n",
  FontSlant->"Italic"],
 ", which can take on positive integer values. Remember that the energy \
eigenvalues of the hydrogen atom wavefunctions only depend on ",
 StyleBox["n",
  FontSlant->"Italic"],
 ", not on ",
 StyleBox["l",
  FontSlant->"Italic"],
 " or ",
 StyleBox["m",
  FontSlant->"Italic"],
 ", "
}], "Text",
 CellChangeTimes->{{3.810719244082814*^9, 
  3.810719375278818*^9}},ExpressionUUID->"009d0cfd-54db-4ae2-a81b-\
a5e85b857eb8"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   StyleBox[
    SubscriptBox["E", "n"],
    FontSlant->"Italic"], "=", 
   RowBox[{
    RowBox[{
     RowBox[{"-", 
      FractionBox[
       SuperscriptBox[
        StyleBox["e",
         FontSlant->"Italic"], "2"], 
       RowBox[{"8", 
        SubscriptBox["\[Pi]\[Epsilon]", "0"], 
        SubscriptBox[
         StyleBox["a",
          FontSlant->"Italic"], "0"], 
        SuperscriptBox[
         StyleBox["n",
          FontSlant->"Italic"], "2"]}]]}], "          ", 
     StyleBox["n",
      FontSlant->"Italic"]}], 
    StyleBox[" ",
     FontSlant->"Italic"], "=", " ", "1"}]}], ",", "2", ",", "3", ",", 
  "..."}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.810112811439228*^9, 3.8101128248442793`*^9}, {
   3.810479494926491*^9, 3.8104795038498344`*^9}, {3.810479572543576*^9, 
   3.8104796147383184`*^9}, {3.8104802055659895`*^9, 
   3.8104802433915305`*^9}, {3.8104802785189395`*^9, 
   3.8104802814214115`*^9}, {3.810480477782269*^9, 3.8104805471507206`*^9}, {
   3.8104805927965565`*^9, 3.810480633017248*^9}, {3.8104807595294323`*^9, 
   3.8104809538100047`*^9}, {3.8104811300285854`*^9, 
   3.8104811403007636`*^9}, {3.8104812580010843`*^9, 
   3.8104813317580833`*^9}, {3.81048146789211*^9, 3.8104815557630205`*^9}, {
   3.8104817202872114`*^9, 3.810481734754242*^9}, 3.8104817893244157`*^9, 
   3.8104818340696*^9, {3.810481916620369*^9, 3.8104819219809136`*^9}, {
   3.8106540212534976`*^9, 3.8106540299597287`*^9}, {3.810654713305319*^9, 
   3.8106549124509315`*^9}, {3.810655268685783*^9, 3.810655351286878*^9}, {
   3.8106553862793045`*^9, 3.8106553879372163`*^9}, {3.810656491191622*^9, 
   3.8106564992968655`*^9}, {3.810657787287384*^9, 3.8106579309749165`*^9}, {
   3.810719396720689*^9, 
   3.8107193968719635`*^9}},ExpressionUUID->"60c8c29a-79e1-4ada-9122-\
ac5950d8d48d"],

Cell[TextData[{
 "Therefore, ",
 StyleBox["n",
  FontSlant->"Italic"],
 " is called the principal quantum number and tells us the energy of a given \
state (only for the hydrogen atom in the absence of any external electric or \
magnetic fields). In referencing atomic orbitals, the value of ",
 StyleBox["n",
  FontSlant->"Italic"],
 " gives us the prefix in our assignment (e.g., 2",
 StyleBox["s",
  FontSlant->"Italic"],
 " refers to a state with ",
 StyleBox["n",
  FontSlant->"Italic"],
 " = 2)."
}], "Text",
 CellChangeTimes->{{3.8107194531592054`*^9, 3.8107195141641493`*^9}, {
   3.8107197762103605`*^9, 3.8107198165345273`*^9}, 
   3.9171004096286387`*^9},ExpressionUUID->"4958e229-eb70-4825-8a6d-\
3d4e2a988095"],

Cell[TextData[{
 "We have already discussed the physical meaning of ",
 StyleBox["l",
  FontSlant->"Italic"],
 " and ",
 Cell[BoxData[
  StyleBox[
   SubscriptBox[
    StyleBox["m",
     FontSlant->"Italic"], 
    StyleBox["l",
     FontSlant->"Italic"]],
   FontSlant->"Italic"]],
  CellChangeTimes->{{3.810112811439228*^9, 3.8101128248442793`*^9}, {
    3.810479494926491*^9, 3.8104795038498344`*^9}, {3.810479572543576*^9, 
    3.8104796147383184`*^9}, {3.8104802055659895`*^9, 
    3.8104802433915305`*^9}, {3.8104802785189395`*^9, 
    3.8104802814214115`*^9}, {3.810480477782269*^9, 3.8104805471507206`*^9}, {
    3.8104805927965565`*^9, 3.810480633017248*^9}, {3.8104807595294323`*^9, 
    3.8104809538100047`*^9}, {3.8104811300285854`*^9, 
    3.8104811403007636`*^9}, {3.8104812580010843`*^9, 
    3.8104813317580833`*^9}, {3.81048146789211*^9, 3.8104815557630205`*^9}, {
    3.8104817202872114`*^9, 3.8104817438715935`*^9}, 3.810481790764664*^9, 
    3.810481836241686*^9, {3.810481926951917*^9, 3.810481935802024*^9}, {
    3.8104820720505495`*^9, 3.8104821860076323`*^9}, {3.810482900850647*^9, 
    3.8104829123165646`*^9}, {3.8104829752587*^9, 3.8104829860744143`*^9}, {
    3.810483024639452*^9, 3.810483038492651*^9}, {3.8104830702023983`*^9, 
    3.8104830866522465`*^9}, {3.8104831187257876`*^9, 3.810483135292489*^9}, {
    3.8104831732744513`*^9, 3.8104831809128747`*^9}, {3.810646494275571*^9, 
    3.8106466133679247`*^9}, {3.810647155079011*^9, 3.8106472289497843`*^9}, 
    3.9170224764040937`*^9},ExpressionUUID->
  "3a8913c8-4724-4f63-9386-f160cf345c53"],
 " in terms of angular momentum. In atomic orbital notation, the angular \
momentum quantum number ",
 StyleBox["l",
  FontSlant->"Italic"],
 " is typically assigned a letter, with ",
 StyleBox["s",
  FontSlant->"Italic"],
 " corresponding to ",
 StyleBox["l",
  FontSlant->"Italic"],
 " = 0, ",
 StyleBox["p",
  FontSlant->"Italic"],
 " corresponding to  ",
 StyleBox["l",
  FontSlant->"Italic"],
 " = 1, ",
 StyleBox["d",
  FontSlant->"Italic"],
 " corresponding to  ",
 StyleBox["l",
  FontSlant->"Italic"],
 " = 2, ",
 StyleBox["f",
  FontSlant->"Italic"],
 " corresponding to  ",
 StyleBox["l",
  FontSlant->"Italic"],
 " = 3, etc. Notably, the radial component of the wavefunction depends on ",
 StyleBox["l",
  FontSlant->"Italic"],
 " as well as on ",
 StyleBox["n",
  FontSlant->"Italic"],
 ". We can already see that the constraints we derived for the allowed values \
of ",
 StyleBox["l",
  FontSlant->"Italic"],
 " for a given ",
 StyleBox["n",
  FontSlant->"Italic"],
 " tell us why for example there is no 1",
 StyleBox["p",
  FontSlant->"Italic"],
 " orbital (the only allowed value of ",
 StyleBox["l",
  FontSlant->"Italic"],
 " for ",
 StyleBox["n ",
  FontSlant->"Italic"],
 "= 1 is ",
 StyleBox["l",
  FontSlant->"Italic"],
 " = 0)."
}], "Text",
 CellChangeTimes->{{3.810719525479886*^9, 3.8107196426766615`*^9}, {
  3.810719821763285*^9, 3.810720069636024*^9}, {3.917100414434359*^9, 
  3.9171004234327717`*^9}},ExpressionUUID->"51a968e4-7726-49ed-a470-\
599cd7d954fa"],

Cell[TextData[{
 "The value of the quantum number ",
 Cell[BoxData[
  StyleBox[
   SubscriptBox[
    StyleBox["m",
     FontSlant->"Italic"], 
    StyleBox["l",
     FontSlant->"Italic"]],
   FontSlant->"Italic"]],
  CellChangeTimes->{{3.810112811439228*^9, 3.8101128248442793`*^9}, {
    3.810479494926491*^9, 3.8104795038498344`*^9}, {3.810479572543576*^9, 
    3.8104796147383184`*^9}, {3.8104802055659895`*^9, 
    3.8104802433915305`*^9}, {3.8104802785189395`*^9, 
    3.8104802814214115`*^9}, {3.810480477782269*^9, 3.8104805471507206`*^9}, {
    3.8104805927965565`*^9, 3.810480633017248*^9}, {3.8104807595294323`*^9, 
    3.8104809538100047`*^9}, {3.8104811300285854`*^9, 
    3.8104811403007636`*^9}, {3.8104812580010843`*^9, 
    3.8104813317580833`*^9}, {3.81048146789211*^9, 3.8104815557630205`*^9}, {
    3.8104817202872114`*^9, 3.8104817438715935`*^9}, 3.810481790764664*^9, 
    3.810481836241686*^9, {3.810481926951917*^9, 3.810481935802024*^9}, {
    3.8104820720505495`*^9, 3.8104821860076323`*^9}, {3.810482900850647*^9, 
    3.8104829123165646`*^9}, {3.8104829752587*^9, 3.8104829860744143`*^9}, {
    3.810483024639452*^9, 3.810483038492651*^9}, {3.8104830702023983`*^9, 
    3.8104830866522465`*^9}, {3.8104831187257876`*^9, 3.810483135292489*^9}, {
    3.8104831732744513`*^9, 3.8104831809128747`*^9}, {3.810646494275571*^9, 
    3.8106466133679247`*^9}, {3.810647155079011*^9, 3.8106472289497843`*^9}, 
    3.9170224764040937`*^9},ExpressionUUID->
  "8490bbb2-0633-40ff-8aca-37093ebaa1e2"],
 StyleBox[" ",
  FontSlant->"Italic"],
 "does not alter the radial component of the hydrogen atom eigenfunctions. \
Only the angular component ",
 Cell[BoxData[
  RowBox[{
   SubsuperscriptBox[
    StyleBox["Y",
     FontSlant->"Italic"], 
    StyleBox["l",
     FontSlant->"Italic"], 
    SubscriptBox["m", 
     StyleBox["l",
      FontSlant->"Italic"]]], 
   RowBox[{"(", 
    RowBox[{"\[Theta]", ",", "\[Phi]"}], ")"}]}]],
  CellChangeTimes->{{3.810112811439228*^9, 3.8101128248442793`*^9}, {
    3.810479494926491*^9, 3.8104795038498344`*^9}, {3.810479572543576*^9, 
    3.8104796147383184`*^9}, {3.8104802055659895`*^9, 
    3.8104802433915305`*^9}, {3.8104802785189395`*^9, 
    3.8104802814214115`*^9}, {3.810480477782269*^9, 3.8104805471507206`*^9}, {
    3.8104805927965565`*^9, 3.810480633017248*^9}, {3.8104807595294323`*^9, 
    3.8104809538100047`*^9}, {3.8104811300285854`*^9, 
    3.8104811403007636`*^9}, {3.8104812580010843`*^9, 
    3.8104813317580833`*^9}, {3.81048146789211*^9, 3.8104815557630205`*^9}, {
    3.8104817202872114`*^9, 3.8104817438715935`*^9}, 3.810481790764664*^9, 
    3.810481836241686*^9, {3.810481926951917*^9, 3.810481935802024*^9}, {
    3.8106609069078913`*^9, 3.81066090872985*^9}, {3.8106610360496655`*^9, 
    3.8106610794321012`*^9}, {3.8106611250786457`*^9, 
    3.8106611896874313`*^9}, {3.810718226403468*^9, 3.8107182918531866`*^9}},
  ExpressionUUID->"eb7d69c5-4058-4ab3-a25b-93b787a9ec54"],
 "is dependent on the quantum number ",
 Cell[BoxData[
  StyleBox[
   SubscriptBox[
    StyleBox["m",
     FontSlant->"Italic"], 
    StyleBox["l",
     FontSlant->"Italic"]],
   FontSlant->"Italic"]],
  CellChangeTimes->{{3.810112811439228*^9, 3.8101128248442793`*^9}, {
    3.810479494926491*^9, 3.8104795038498344`*^9}, {3.810479572543576*^9, 
    3.8104796147383184`*^9}, {3.8104802055659895`*^9, 
    3.8104802433915305`*^9}, {3.8104802785189395`*^9, 
    3.8104802814214115`*^9}, {3.810480477782269*^9, 3.8104805471507206`*^9}, {
    3.8104805927965565`*^9, 3.810480633017248*^9}, {3.8104807595294323`*^9, 
    3.8104809538100047`*^9}, {3.8104811300285854`*^9, 
    3.8104811403007636`*^9}, {3.8104812580010843`*^9, 
    3.8104813317580833`*^9}, {3.81048146789211*^9, 3.8104815557630205`*^9}, {
    3.8104817202872114`*^9, 3.8104817438715935`*^9}, 3.810481790764664*^9, 
    3.810481836241686*^9, {3.810481926951917*^9, 3.810481935802024*^9}, {
    3.8104820720505495`*^9, 3.8104821860076323`*^9}, {3.810482900850647*^9, 
    3.8104829123165646`*^9}, {3.8104829752587*^9, 3.8104829860744143`*^9}, {
    3.810483024639452*^9, 3.810483038492651*^9}, {3.8104830702023983`*^9, 
    3.8104830866522465`*^9}, {3.8104831187257876`*^9, 3.810483135292489*^9}, {
    3.8104831732744513`*^9, 3.8104831809128747`*^9}, {3.810646494275571*^9, 
    3.8106466133679247`*^9}, {3.810647155079011*^9, 3.8106472289497843`*^9}, 
    3.9170224764040937`*^9},ExpressionUUID->
  "7ace1962-f729-4190-8671-89daf4996907"],
 ". Thus, we can think about ",
 Cell[BoxData[
  StyleBox[
   SubscriptBox[
    StyleBox["m",
     FontSlant->"Italic"], 
    StyleBox["l",
     FontSlant->"Italic"]],
   FontSlant->"Italic"]],
  CellChangeTimes->{{3.810112811439228*^9, 3.8101128248442793`*^9}, {
    3.810479494926491*^9, 3.8104795038498344`*^9}, {3.810479572543576*^9, 
    3.8104796147383184`*^9}, {3.8104802055659895`*^9, 
    3.8104802433915305`*^9}, {3.8104802785189395`*^9, 
    3.8104802814214115`*^9}, {3.810480477782269*^9, 3.8104805471507206`*^9}, {
    3.8104805927965565`*^9, 3.810480633017248*^9}, {3.8104807595294323`*^9, 
    3.8104809538100047`*^9}, {3.8104811300285854`*^9, 
    3.8104811403007636`*^9}, {3.8104812580010843`*^9, 
    3.8104813317580833`*^9}, {3.81048146789211*^9, 3.8104815557630205`*^9}, {
    3.8104817202872114`*^9, 3.8104817438715935`*^9}, 3.810481790764664*^9, 
    3.810481836241686*^9, {3.810481926951917*^9, 3.810481935802024*^9}, {
    3.8104820720505495`*^9, 3.8104821860076323`*^9}, {3.810482900850647*^9, 
    3.8104829123165646`*^9}, {3.8104829752587*^9, 3.8104829860744143`*^9}, {
    3.810483024639452*^9, 3.810483038492651*^9}, {3.8104830702023983`*^9, 
    3.8104830866522465`*^9}, {3.8104831187257876`*^9, 3.810483135292489*^9}, {
    3.8104831732744513`*^9, 3.8104831809128747`*^9}, {3.810646494275571*^9, 
    3.8106466133679247`*^9}, {3.810647155079011*^9, 3.8106472289497843`*^9}, 
    3.9170224764040937`*^9},ExpressionUUID->
  "1a44d011-b06e-418a-9729-326dbf7027b0"],
 " as specifying the relative orientation of an atomic orbital. For example, \
the three values of ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["m", "l"], TraditionalForm]],ExpressionUUID->
  "9f9c8dee-2c73-4e52-a09a-5655316a6888"],
 " for ",
 StyleBox["l",
  FontSlant->"Italic"],
 " = 1, or ",
 StyleBox["p",
  FontSlant->"Italic"],
 " orbitals, inform the different orientations that we label as ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "x"], TraditionalForm]],ExpressionUUID->
  "9243cb64-22b9-417d-bc7f-c1c08dd5928e"],
 ", ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "y"], TraditionalForm]],ExpressionUUID->
  "a8362b67-7277-4dc0-8313-fc1142e61f7a"],
 ", and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "z"], TraditionalForm]],ExpressionUUID->
  "f65a04e7-2685-438e-a92b-7661469807d9"],
 ". Note, however, that there is not a direct correspondence between ",
 StyleBox["x",
  FontSlant->"Italic"],
 ", ",
 StyleBox["y",
  FontSlant->"Italic"],
 ", and ",
 StyleBox["z",
  FontSlant->"Italic"],
 " here and the possible values of ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["m", "l"], TraditionalForm]],ExpressionUUID->
  "659e5c92-a52e-4c1c-81dc-bf3b766a6536"],
 " (\[Minus]1, 0, and 1). Earlier, we referred to ",
 Cell[BoxData[
  StyleBox[
   SubscriptBox[
    StyleBox["m",
     FontSlant->"Italic"], 
    StyleBox["l",
     FontSlant->"Italic"]],
   FontSlant->"Italic"]],
  CellChangeTimes->{{3.810112811439228*^9, 3.8101128248442793`*^9}, {
    3.810479494926491*^9, 3.8104795038498344`*^9}, {3.810479572543576*^9, 
    3.8104796147383184`*^9}, {3.8104802055659895`*^9, 
    3.8104802433915305`*^9}, {3.8104802785189395`*^9, 
    3.8104802814214115`*^9}, {3.810480477782269*^9, 3.8104805471507206`*^9}, {
    3.8104805927965565`*^9, 3.810480633017248*^9}, {3.8104807595294323`*^9, 
    3.8104809538100047`*^9}, {3.8104811300285854`*^9, 
    3.8104811403007636`*^9}, {3.8104812580010843`*^9, 
    3.8104813317580833`*^9}, {3.81048146789211*^9, 3.8104815557630205`*^9}, {
    3.8104817202872114`*^9, 3.8104817438715935`*^9}, 3.810481790764664*^9, 
    3.810481836241686*^9, {3.810481926951917*^9, 3.810481935802024*^9}, {
    3.8104820720505495`*^9, 3.8104821860076323`*^9}, {3.810482900850647*^9, 
    3.8104829123165646`*^9}, {3.8104829752587*^9, 3.8104829860744143`*^9}, {
    3.810483024639452*^9, 3.810483038492651*^9}, {3.8104830702023983`*^9, 
    3.8104830866522465`*^9}, {3.8104831187257876`*^9, 3.810483135292489*^9}, {
    3.8104831732744513`*^9, 3.8104831809128747`*^9}, {3.810646494275571*^9, 
    3.8106466133679247`*^9}, {3.810647155079011*^9, 3.8106472289497843`*^9}, 
    3.9170224764040937`*^9},ExpressionUUID->
  "bc2730e0-d384-4eab-9402-f9934100a2f9"],
 " as the angular momentum projection quantum number, but it is more commonly \
referred to as the magnetic quantum number. This name results from the fact \
that in the presence of a magnetic field, the different ",
 Cell[BoxData[
  StyleBox[
   SubscriptBox[
    StyleBox["m",
     FontSlant->"Italic"], 
    StyleBox["l",
     FontSlant->"Italic"]],
   FontSlant->"Italic"]],
  CellChangeTimes->{{3.810112811439228*^9, 3.8101128248442793`*^9}, {
    3.810479494926491*^9, 3.8104795038498344`*^9}, {3.810479572543576*^9, 
    3.8104796147383184`*^9}, {3.8104802055659895`*^9, 
    3.8104802433915305`*^9}, {3.8104802785189395`*^9, 
    3.8104802814214115`*^9}, {3.810480477782269*^9, 3.8104805471507206`*^9}, {
    3.8104805927965565`*^9, 3.810480633017248*^9}, {3.8104807595294323`*^9, 
    3.8104809538100047`*^9}, {3.8104811300285854`*^9, 
    3.8104811403007636`*^9}, {3.8104812580010843`*^9, 
    3.8104813317580833`*^9}, {3.81048146789211*^9, 3.8104815557630205`*^9}, {
    3.8104817202872114`*^9, 3.8104817438715935`*^9}, 3.810481790764664*^9, 
    3.810481836241686*^9, {3.810481926951917*^9, 3.810481935802024*^9}, {
    3.8104820720505495`*^9, 3.8104821860076323`*^9}, {3.810482900850647*^9, 
    3.8104829123165646`*^9}, {3.8104829752587*^9, 3.8104829860744143`*^9}, {
    3.810483024639452*^9, 3.810483038492651*^9}, {3.8104830702023983`*^9, 
    3.8104830866522465`*^9}, {3.8104831187257876`*^9, 3.810483135292489*^9}, {
    3.8104831732744513`*^9, 3.8104831809128747`*^9}, {3.810646494275571*^9, 
    3.8106466133679247`*^9}, {3.810647155079011*^9, 3.8106472289497843`*^9}, 
    3.9170224764040937`*^9},ExpressionUUID->
  "3c35a783-3164-4458-82e1-da3d2678f618"],
 " states are no longer degenerate but split such that the different ",
 Cell[BoxData[
  StyleBox[
   SubscriptBox[
    StyleBox["m",
     FontSlant->"Italic"], 
    StyleBox["l",
     FontSlant->"Italic"]],
   FontSlant->"Italic"]],
  CellChangeTimes->{{3.810112811439228*^9, 3.8101128248442793`*^9}, {
    3.810479494926491*^9, 3.8104795038498344`*^9}, {3.810479572543576*^9, 
    3.8104796147383184`*^9}, {3.8104802055659895`*^9, 
    3.8104802433915305`*^9}, {3.8104802785189395`*^9, 
    3.8104802814214115`*^9}, {3.810480477782269*^9, 3.8104805471507206`*^9}, {
    3.8104805927965565`*^9, 3.810480633017248*^9}, {3.8104807595294323`*^9, 
    3.8104809538100047`*^9}, {3.8104811300285854`*^9, 
    3.8104811403007636`*^9}, {3.8104812580010843`*^9, 
    3.8104813317580833`*^9}, {3.81048146789211*^9, 3.8104815557630205`*^9}, {
    3.8104817202872114`*^9, 3.8104817438715935`*^9}, 3.810481790764664*^9, 
    3.810481836241686*^9, {3.810481926951917*^9, 3.810481935802024*^9}, {
    3.8104820720505495`*^9, 3.8104821860076323`*^9}, {3.810482900850647*^9, 
    3.8104829123165646`*^9}, {3.8104829752587*^9, 3.8104829860744143`*^9}, {
    3.810483024639452*^9, 3.810483038492651*^9}, {3.8104830702023983`*^9, 
    3.8104830866522465`*^9}, {3.8104831187257876`*^9, 3.810483135292489*^9}, {
    3.8104831732744513`*^9, 3.8104831809128747`*^9}, {3.810646494275571*^9, 
    3.8106466133679247`*^9}, {3.810647155079011*^9, 3.8106472289497843`*^9}, 
    3.9170224764040937`*^9},ExpressionUUID->
  "e9ebc18f-f9db-4be3-96dc-bd4996a1218b"],
 " values have different energies. This phenomenon is known as the Zeeman \
effect."
}], "Text",
 CellChangeTimes->{{3.8107201053770704`*^9, 3.8107203603415756`*^9}, {
  3.810720439720711*^9, 3.810720736421753*^9}, {3.917100433625265*^9, 
  3.9171004807806463`*^9}, {3.917106091605875*^9, 
  3.917106097533863*^9}},ExpressionUUID->"16dd1a7f-2d3a-47fe-8050-\
459106f42718"]
}, Open  ]],

Cell[CellGroupData[{

Cell["The Radial Distribution Functions of Atomic Orbitals", "Subsubsection",
 CellChangeTimes->{{3.8107192356180935`*^9, 3.8107192389984384`*^9}, {
  3.810720092755737*^9, 3.81072009754844*^9}, {3.8107211801768475`*^9, 
  3.810721196999052*^9}},ExpressionUUID->"efbd4e4a-9b09-4e0e-a4d0-\
d0d68b1638ab"],

Cell[TextData[{
 "Because each atomic orbital (i.e., each eigenfunction for the TISE of the \
hydrogen atom ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox["\[Psi]", 
    SubscriptBox[
     StyleBox["nlm",
      FontSlant->"Italic"], 
     StyleBox["l",
      FontSlant->"Italic"]]], 
   RowBox[{"(", 
    RowBox[{
     StyleBox["r",
      FontSlant->"Italic"], ",", "\[Theta]", ",", "\[Phi]"}], ")"}]}]],
  CellChangeTimes->{{3.8100544880652375`*^9, 3.8100545041200957`*^9}, {
    3.810054632482561*^9, 3.8100546606919527`*^9}, {3.810054738405748*^9, 
    3.810054754160844*^9}, {3.810055496888957*^9, 3.810055644063492*^9}, {
    3.8101099522060614`*^9, 3.8101100508523717`*^9}, {3.8101101194750385`*^9, 
    3.8101101642963843`*^9}, {3.8107127659519644`*^9, 3.810712781977992*^9}, {
    3.8107128863205147`*^9, 3.8107129246267147`*^9}, 3.810712975971156*^9, 
    3.8107130396874857`*^9, {3.810713072953952*^9, 3.810713077029566*^9}, {
    3.8107138654100857`*^9, 3.810713907959445*^9}, 3.810714092835499*^9, {
    3.8107142057542086`*^9, 3.8107142281878614`*^9}, {3.810718300253166*^9, 
    3.8107183324677906`*^9}},ExpressionUUID->
  "7564a228-dc79-4bda-a48a-5cc5b9056909"],
 ") depends on three variables, visualizing the results can be challenging. \
Remember that we set up the TISE to describe the wavefunction of the electron \
with respect to the proton position. Let\[CloseCurlyQuote]s first examine the \
radial dependence of the wavefunctions that is given by the solutions to the \
radial equation ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox[
     StyleBox["R",
      FontSlant->"Italic"], 
     StyleBox["nl",
      FontSlant->"Italic"]], "(", 
    StyleBox["r",
     FontSlant->"Italic"], ")"}], TraditionalForm]],
  CellChangeTimes->{{3.8100544880652375`*^9, 3.8100545041200957`*^9}, {
    3.810054632482561*^9, 3.8100546606919527`*^9}, {3.810054738405748*^9, 
    3.810054754160844*^9}, {3.810055496888957*^9, 3.810055644063492*^9}, {
    3.8101099522060614`*^9, 3.8101100508523717`*^9}, {3.8101101194750385`*^9, 
    3.8101101642963843`*^9}, {3.8107127659519644`*^9, 3.810712781977992*^9}, {
    3.8107128863205147`*^9, 3.8107129246267147`*^9}, 3.810712975971156*^9, 
    3.8107130396874857`*^9, {3.810713072953952*^9, 3.810713077029566*^9}, {
    3.8107138654100857`*^9, 3.810713907959445*^9}, 3.810714092835499*^9, {
    3.8107142057542086`*^9, 3.8107142281878614`*^9}, {3.810718300253166*^9, 
    3.8107183324677906`*^9}},ExpressionUUID->
  "83cec29c-fb4f-4bdc-a5dd-bd12633256f9"],
 ". The right graph of Figure 6.3 below provides an interactive plot of ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox[
     StyleBox["R",
      FontSlant->"Italic"], 
     StyleBox["nl",
      FontSlant->"Italic"]], "(", 
    StyleBox["r",
     FontSlant->"Italic"], ")"}], TraditionalForm]],
  CellChangeTimes->{{3.8100544880652375`*^9, 3.8100545041200957`*^9}, {
    3.810054632482561*^9, 3.8100546606919527`*^9}, {3.810054738405748*^9, 
    3.810054754160844*^9}, {3.810055496888957*^9, 3.810055644063492*^9}, {
    3.8101099522060614`*^9, 3.8101100508523717`*^9}, {3.8101101194750385`*^9, 
    3.8101101642963843`*^9}, {3.8107127659519644`*^9, 3.810712781977992*^9}, {
    3.8107128863205147`*^9, 3.8107129246267147`*^9}, 3.810712975971156*^9, 
    3.8107130396874857`*^9, {3.810713072953952*^9, 3.810713077029566*^9}, {
    3.8107138654100857`*^9, 3.810713907959445*^9}, 3.810714092835499*^9, {
    3.8107142057542086`*^9, 3.8107142281878614`*^9}, {3.810718300253166*^9, 
    3.8107183324677906`*^9}},ExpressionUUID->
  "0f492f65-904e-4380-8920-21bc89f264cf"],
 " for different values of ",
 StyleBox["n",
  FontSlant->"Italic"],
 " and ",
 StyleBox["l",
  FontSlant->"Italic"],
 ". However, as we have seen for other systems we have studied, the \
probabilistic interpretation of the wavefunction means that we are not so \
much interested in ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox[
     StyleBox["R",
      FontSlant->"Italic"], 
     StyleBox["nl",
      FontSlant->"Italic"]], "(", 
    StyleBox["r",
     FontSlant->"Italic"], ")"}], TraditionalForm]],
  CellChangeTimes->{{3.8100544880652375`*^9, 3.8100545041200957`*^9}, {
    3.810054632482561*^9, 3.8100546606919527`*^9}, {3.810054738405748*^9, 
    3.810054754160844*^9}, {3.810055496888957*^9, 3.810055644063492*^9}, {
    3.8101099522060614`*^9, 3.8101100508523717`*^9}, {3.8101101194750385`*^9, 
    3.8101101642963843`*^9}, {3.8107127659519644`*^9, 3.810712781977992*^9}, {
    3.8107128863205147`*^9, 3.8107129246267147`*^9}, 3.810712975971156*^9, 
    3.8107130396874857`*^9, {3.810713072953952*^9, 3.810713077029566*^9}, {
    3.8107138654100857`*^9, 3.810713907959445*^9}, 3.810714092835499*^9, {
    3.8107142057542086`*^9, 3.8107142281878614`*^9}, {3.810718300253166*^9, 
    3.8107183324677906`*^9}},ExpressionUUID->
  "bd0de4fc-92f7-49de-9e1b-0cc058d30657"],
 "  but in the probability that the electron will be found in the interval \
between ",
 StyleBox["r",
  FontSlant->"Italic"],
 " and ",
 StyleBox["r",
  FontSlant->"Italic"],
 " + d",
 StyleBox["r",
  FontSlant->"Italic"],
 ". If we look back at the form of our normalization condition for  ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox[
     StyleBox["R",
      FontSlant->"Italic"], 
     StyleBox["nl",
      FontSlant->"Italic"]], "(", 
    StyleBox["r",
     FontSlant->"Italic"], ")"}], TraditionalForm]],
  CellChangeTimes->{{3.8100544880652375`*^9, 3.8100545041200957`*^9}, {
    3.810054632482561*^9, 3.8100546606919527`*^9}, {3.810054738405748*^9, 
    3.810054754160844*^9}, {3.810055496888957*^9, 3.810055644063492*^9}, {
    3.8101099522060614`*^9, 3.8101100508523717`*^9}, {3.8101101194750385`*^9, 
    3.8101101642963843`*^9}, {3.8107127659519644`*^9, 3.810712781977992*^9}, {
    3.8107128863205147`*^9, 3.8107129246267147`*^9}, 3.810712975971156*^9, 
    3.8107130396874857`*^9, {3.810713072953952*^9, 3.810713077029566*^9}, {
    3.8107138654100857`*^9, 3.810713907959445*^9}, 3.810714092835499*^9, {
    3.8107142057542086`*^9, 3.8107142281878614`*^9}, {3.810718300253166*^9, 
    3.8107183324677906`*^9}},ExpressionUUID->
  "7f3a2886-64c1-4924-a0f2-853add698876"],
 " in spherical coordinates, "
}], "Text",
 CellChangeTimes->{{3.8107213093287587`*^9, 3.810721507512433*^9}, {
  3.810721574055809*^9, 3.8107216367394934`*^9}, {3.8107216734501853`*^9, 
  3.810721707946749*^9}, {3.810722042643798*^9, 3.810722261031751*^9}, {
  3.9171004860140495`*^9, 3.9171004873506303`*^9}, {3.917100613108205*^9, 
  3.917100613814818*^9}},ExpressionUUID->"560844a8-e71b-4205-a592-\
e9258f53f191"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   SubsuperscriptBox["\[Integral]", "0", "\[Infinity]"], 
   RowBox[{
    SubsuperscriptBox[
     StyleBox["R",
      FontSlant->"Italic"], 
     StyleBox["nl",
      FontSlant->"Italic"], "\[Star]"], 
    RowBox[{"(", 
     StyleBox["r",
      FontSlant->"Italic"], ")"}], 
    SubscriptBox[
     StyleBox["R",
      FontSlant->"Italic"], 
     StyleBox["nl",
      FontSlant->"Italic"]], 
    RowBox[{"(", 
     StyleBox["r",
      FontSlant->"Italic"], ")"}], 
    SuperscriptBox[
     StyleBox["r",
      FontSlant->"Italic"], "2"], 
    RowBox[{"\[DifferentialD]", 
     StyleBox["r",
      FontSlant->"Italic"]}]}]}], "=", "1"}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.810112811439228*^9, 3.8101128248442793`*^9}, {
   3.810479494926491*^9, 3.8104795038498344`*^9}, {3.810479572543576*^9, 
   3.8104796147383184`*^9}, {3.8104802055659895`*^9, 
   3.8104802433915305`*^9}, {3.8104802785189395`*^9, 
   3.8104802814214115`*^9}, {3.810480477782269*^9, 3.8104805471507206`*^9}, {
   3.8104805927965565`*^9, 3.810480633017248*^9}, {3.8104807595294323`*^9, 
   3.8104809538100047`*^9}, {3.8104811300285854`*^9, 
   3.8104811403007636`*^9}, {3.8104812580010843`*^9, 
   3.8104813317580833`*^9}, {3.81048146789211*^9, 3.8104815557630205`*^9}, {
   3.8104817202872114`*^9, 3.8104817438715935`*^9}, 3.810481790764664*^9, 
   3.810481836241686*^9, {3.810481926951917*^9, 3.810481935802024*^9}, {
   3.8104820720505495`*^9, 3.8104821860076323`*^9}, {3.810482833577834*^9, 
   3.810482856592573*^9}, {3.810650687465464*^9, 3.8106507334315205`*^9}, 
   3.810651925937356*^9, {3.810652128872187*^9, 3.810652287868311*^9}, {
   3.8106583239462414`*^9, 3.8106583833041215`*^9}, {3.91710170992*^9, 
   3.917101710556418*^9}},ExpressionUUID->"a2d7dadc-2693-433b-80a8-\
22b066d609d1"],

Cell[TextData[{
 "we see that the probability that the electron lies between ",
 StyleBox["r",
  FontSlant->"Italic"],
 " and ",
 StyleBox["r",
  FontSlant->"Italic"],
 " + d",
 StyleBox["r",
  FontSlant->"Italic"],
 " is actually given by ",
 Cell[BoxData[
  RowBox[{
   SuperscriptBox[
    RowBox[{"\[LeftBracketingBar]", 
     RowBox[{
      SubscriptBox[
       StyleBox["R",
        FontSlant->"Italic"], 
       StyleBox["nl",
        FontSlant->"Italic"]], 
      RowBox[{"(", 
       StyleBox["r",
        FontSlant->"Italic"], ")"}]}], "\[RightBracketingBar]"}], "2"], 
   SuperscriptBox[
    StyleBox["r",
     FontSlant->"Italic"], "2"], 
   StyleBox[
    RowBox[{"d", 
     StyleBox["r",
      FontSlant->"Italic"]}]]}]],
  CellChangeTimes->{{3.810112811439228*^9, 3.8101128248442793`*^9}, {
    3.810479494926491*^9, 3.8104795038498344`*^9}, {3.810479572543576*^9, 
    3.8104796147383184`*^9}, {3.8104802055659895`*^9, 
    3.8104802433915305`*^9}, {3.8104802785189395`*^9, 
    3.8104802814214115`*^9}, {3.810480477782269*^9, 3.8104805471507206`*^9}, {
    3.8104805927965565`*^9, 3.810480633017248*^9}, {3.8104807595294323`*^9, 
    3.8104809538100047`*^9}, {3.8104811300285854`*^9, 
    3.8104811403007636`*^9}, {3.8104812580010843`*^9, 
    3.8104813317580833`*^9}, {3.81048146789211*^9, 3.8104815557630205`*^9}, {
    3.8104817202872114`*^9, 3.8104817438715935`*^9}, 3.810481790764664*^9, 
    3.810481836241686*^9, {3.810481926951917*^9, 3.810481935802024*^9}, {
    3.8104820720505495`*^9, 3.8104821860076323`*^9}, {3.810482833577834*^9, 
    3.810482856592573*^9}, {3.810650687465464*^9, 3.8106507334315205`*^9}, 
    3.810651925937356*^9, {3.810652128872187*^9, 3.810652287868311*^9}, {
    3.8106583239462414`*^9, 3.8106583833041215`*^9}},ExpressionUUID->
  "db47d71f-979c-43c0-a3f1-b340511a315e"],
 ", not just by ",
 Cell[BoxData[
  RowBox[{
   SuperscriptBox[
    RowBox[{"\[LeftBracketingBar]", 
     RowBox[{
      SubscriptBox[
       StyleBox["R",
        FontSlant->"Italic"], 
       StyleBox["nl",
        FontSlant->"Italic"]], 
      RowBox[{"(", 
       StyleBox["r",
        FontSlant->"Italic"], ")"}]}], "\[RightBracketingBar]"}], "2"], 
   StyleBox[
    RowBox[{"d", 
     StyleBox["r",
      FontSlant->"Italic"]}]]}]],
  CellChangeTimes->{{3.810112811439228*^9, 3.8101128248442793`*^9}, {
    3.810479494926491*^9, 3.8104795038498344`*^9}, {3.810479572543576*^9, 
    3.8104796147383184`*^9}, {3.8104802055659895`*^9, 
    3.8104802433915305`*^9}, {3.8104802785189395`*^9, 
    3.8104802814214115`*^9}, {3.810480477782269*^9, 3.8104805471507206`*^9}, {
    3.8104805927965565`*^9, 3.810480633017248*^9}, {3.8104807595294323`*^9, 
    3.8104809538100047`*^9}, {3.8104811300285854`*^9, 
    3.8104811403007636`*^9}, {3.8104812580010843`*^9, 
    3.8104813317580833`*^9}, {3.81048146789211*^9, 3.8104815557630205`*^9}, {
    3.8104817202872114`*^9, 3.8104817438715935`*^9}, 3.810481790764664*^9, 
    3.810481836241686*^9, {3.810481926951917*^9, 3.810481935802024*^9}, {
    3.8104820720505495`*^9, 3.8104821860076323`*^9}, {3.810482833577834*^9, 
    3.810482856592573*^9}, {3.810650687465464*^9, 3.8106507334315205`*^9}, 
    3.810651925937356*^9, {3.810652128872187*^9, 3.810652287868311*^9}, {
    3.8106583239462414`*^9, 3.8106583833041215`*^9}},ExpressionUUID->
  "96562a18-77fa-447e-ba43-2012ead17d4f"],
 ". These plots for different values of ",
 StyleBox["n",
  FontSlant->"Italic"],
 " and ",
 StyleBox["l",
  FontSlant->"Italic"],
 " are shown on the left of Figure 6.3 below. Notice that for ",
 StyleBox["n",
  FontSlant->"Italic"],
 " = 1 and ",
 StyleBox["l",
  FontSlant->"Italic"],
 " = 0, the maximum in the probability distribution is found at the Bohr \
radius ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["a", "0"], TraditionalForm]],ExpressionUUID->
  "62773dfe-d679-4331-87bf-cdfd2ab68152"],
 ". The average value of the distance of the electron from the proton, or \
nucleus, is also shown in the graphs below."
}], "Text",
 CellChangeTimes->{{3.810722285966329*^9, 3.8107224378808794`*^9}, {
   3.8107224726853385`*^9, 3.8107225679561167`*^9}, 3.81098122252722*^9, {
   3.9171006175296793`*^9, 3.917100618288118*^9}, 
   3.9359138781194954`*^9},ExpressionUUID->"245404a8-1b4b-4f0a-bf9d-\
fef53cbebd60"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Manipulate", "[", "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"If", "[", 
     RowBox[{
      RowBox[{"L", ">=", "n"}], ",", 
      RowBox[{"L", "=", 
       RowBox[{"n", "-", "1"}]}]}], "]"}], ";", "\n", 
    RowBox[{"label", "=", 
     RowBox[{"Which", "[", 
      RowBox[{
       RowBox[{"L", "==", "0"}], ",", 
       RowBox[{"Style", "[", 
        RowBox[{"\"\<s\>\"", ",", "Italic"}], "]"}], ",", 
       RowBox[{"L", "==", "1"}], ",", 
       RowBox[{"Style", "[", 
        RowBox[{"\"\<p\>\"", ",", "Italic"}], "]"}], ",", 
