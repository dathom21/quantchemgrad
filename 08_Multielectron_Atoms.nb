Cell["\<\
We can see that these assignments will work for bosons, because changing the \
position labels won\[CloseCurlyQuote]t change the wavefunction at all. \
However, it won\[CloseCurlyQuote]t work for fermions, because we won\
\[CloseCurlyQuote]t get the required change in the sign of our wavefunction. \
\>", "Text",
 CellChangeTimes->{{3.8126201355893784`*^9, 3.8126202112891455`*^9}, {
  3.8126202853595886`*^9, 
  3.8126202966730504`*^9}},ExpressionUUID->"adb8aec9-2045-4501-9a2d-\
da48abab7536"],

Cell["\<\
The remaining two states involve one particle in each of the spin states. We \
can\[CloseCurlyQuote]t simply assign each labeled particle to a particular \
state, as that approach would certainly violate that the square of the \
wavefunction doesn\[CloseCurlyQuote]t change when we switch the labels. \
Instead, we take two linear combination states, \
\>", "Text",
 CellChangeTimes->{{3.812620298590493*^9, 
  3.812620457078903*^9}},ExpressionUUID->"d14ed8e8-63dd-423e-8256-\
95500ed16ddf"],

Cell[BoxData[
 RowBox[{
  RowBox[{"\[Psi]", 
   RowBox[{"(", 
    RowBox[{
     SubscriptBox[
      StyleBox["r",
       FontWeight->"Bold",
       FontSlant->"Italic"], "1"], ",", 
     SubscriptBox["\[Sigma]", "1"], ",", " ", 
     SubscriptBox[
      StyleBox["r",
       FontWeight->"Bold",
       FontSlant->"Italic"], "2"], ",", 
     SubscriptBox["\[Sigma]", "2"]}], ")"}]}], "=", 
  RowBox[{
   FractionBox["1", 
    SqrtBox["2"]], "\[Phi]", 
   RowBox[{"(", 
    SubscriptBox[
     StyleBox["r",
      FontWeight->"Bold",
      FontSlant->"Italic"], "1"], ")"}], "\[Phi]", 
   RowBox[{
    RowBox[{"(", 
     SubscriptBox[
      StyleBox["r",
       FontWeight->"Bold",
       FontSlant->"Italic"], "2"], ")"}], "[", 
    RowBox[{
     RowBox[{"\[Alpha]", 
      RowBox[{"(", 
       SubscriptBox["\[Sigma]", "1"], ")"}], "\[Beta]", 
      RowBox[{"(", 
       SubscriptBox["\[Sigma]", "2"], ")"}]}], "\[PlusMinus]", 
     RowBox[{"\[Beta]", 
      RowBox[{"(", 
       SubscriptBox["\[Sigma]", "1"], ")"}], "\[Alpha]", 
      RowBox[{"(", 
       SubscriptBox["\[Sigma]", "2"], ")"}]}]}], 
    "]"}]}]}]], "DisplayFormulaNumbered",
