c04de4bee82e"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[{
 "The ",
 StyleBox["s",
  FontSlant->"Italic"],
 " orbitals of the Hydrogen Atom are Spherically Symmetric"
}], "Subsubsection",
 CellChangeTimes->{{3.8107192356180935`*^9, 3.8107192389984384`*^9}, {
  3.810720092755737*^9, 3.81072009754844*^9}, {3.8107211801768475`*^9, 
  3.810721196999052*^9}, {3.810723622437487*^9, 
  3.8107236405152397`*^9}},ExpressionUUID->"83a248a5-a559-4f6e-a35e-\
635d65cf3860"],

Cell[TextData[{
 "Thus far, we have only been discussing the radial component of the \
wavefunctions, and in general we must also account for the angular \
dependence. However, a notable case arises for ",
 StyleBox["l ",
  FontSlant->"Italic"],
 " = 0, ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["m", "l"], TraditionalForm]],ExpressionUUID->
  "634834a0-c776-4a1d-a587-e9cdfd6fbf99"],
 StyleBox[" ",
  FontSlant->"Italic"],
 "= 0, regardless of the value of ",
 StyleBox["n",
  FontSlant->"Italic"],
 ". These quantum numbers correspond to the ",
 StyleBox["s",
  FontSlant->"Italic"],
 " orbitals of any energy level. Since ",
 Cell[BoxData[
  RowBox[{
   SubsuperscriptBox[
    StyleBox["Y",
     FontSlant->"Italic"], 
    StyleBox["l",
     FontSlant->"Italic"], 
    SubscriptBox[
     StyleBox["m",
      FontSlant->"Italic"], 
     StyleBox["l",
      FontSlant->"Italic"]]], 
   RowBox[{"(", 
    RowBox[{"\[Theta]", ",", "\[Phi]"}], ")"}]}]],
  CellChangeTimes->{{3.810112811439228*^9, 3.8101128248442793`*^9}, {
    3.810479494926491*^9, 3.8104795038498344`*^9}, {3.810479572543576*^9, 
    3.8104796147383184`*^9}, {3.8104802055659895`*^9, 
    3.8104802433915305`*^9}, {3.8104802785189395`*^9, 
    3.8104802814214115`*^9}, {3.810480477782269*^9, 3.8104805471507206`*^9}, {
    3.8104805927965565`*^9, 3.810480633017248*^9}, {3.8104807595294323`*^9, 
    3.8104809538100047`*^9}, {3.8104811300285854`*^9, 
    3.8104811403007636`*^9}, {3.8104812580010843`*^9, 
    3.8104813317580833`*^9}, {3.81048146789211*^9, 3.8104815557630205`*^9}, {
    3.8104817202872114`*^9, 3.8104817438715935`*^9}, 3.810481790764664*^9, 
    3.810481836241686*^9, {3.810481926951917*^9, 3.810481935802024*^9}, {
    3.8104820720505495`*^9, 3.8104821860076323`*^9}, {3.810482833577834*^9, 
    3.810482856592573*^9}, {3.810650687465464*^9, 3.8106507334315205`*^9}, 
    3.810651925937356*^9, {3.810652128872187*^9, 3.810652287868311*^9}},
  ExpressionUUID->"7f2c5a19-d9e3-4352-97f8-5b870d10e715"],
 "does not depend on ",
 StyleBox["n",
  FontSlant->"Italic"],
 ", we always have"
}], "Text",
 CellChangeTimes->{{3.81072358023993*^9, 3.810723598482787*^9}, {
  3.8107236425666237`*^9, 3.810723693241151*^9}, {3.8107237298279114`*^9, 
  3.8107238364590387`*^9}, {3.917100650878976*^9, 
  3.9171006567484503`*^9}},ExpressionUUID->"1807be65-8dc1-42e4-b08f-\
a2aaf7f723eb"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   SubsuperscriptBox[
    StyleBox["Y",
     FontSlant->"Italic"], "0", "0"], 
   RowBox[{"(", 
    RowBox[{"\[Theta]", ",", "\[Phi]"}], ")"}]}], "=", 
  FractionBox["1", 
   RowBox[{"2", 
    SqrtBox["\[Pi]"]}]]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8107238778742666`*^9, 3.810723893543601*^9}, {
  3.8107240902680264`*^9, 
  3.8107240973614845`*^9}},ExpressionUUID->"e1fb321d-5875-4934-a359-\
c2bd5059e66e"],

Cell["\<\
Just to confirm that this function is normalized with respect to integration \
over a spherical surface, we must evaluate\
\>", "Text",
 CellChangeTimes->{{3.8107239085133677`*^9, 3.8107239267045345`*^9}, {
  3.8107239589202337`*^9, 
  3.810723961100583*^9}},ExpressionUUID->"5b1c3fc1-efcb-4cc0-a12c-\
4e643692fe70"],

Cell[BoxData[
 RowBox[{
  SubsuperscriptBox["\[Integral]", "0", "\[Pi]"], 
  RowBox[{"d\[Theta]", " ", "sin\[Theta]", " ", 
   RowBox[{
    SubsuperscriptBox["\[Integral]", "0", 
     RowBox[{"2", "\[Pi]"}]], 
    RowBox[{"d\[Phi]", " ", 
     SuperscriptBox[
      RowBox[{"(", 
       FractionBox["1", 
        RowBox[{"2", 
         SqrtBox["\[Pi]"]}]], ")"}], "2"]}]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.810112811439228*^9, 3.8101128248442793`*^9}, {
   3.810479494926491*^9, 3.8104795038498344`*^9}, {3.810479572543576*^9, 
   3.8104796147383184`*^9}, {3.8104802055659895`*^9, 
   3.8104802433915305`*^9}, {3.8104802785189395`*^9, 
   3.8104802814214115`*^9}, {3.810480477782269*^9, 3.8104805471507206`*^9}, {
   3.8104805927965565`*^9, 3.810480633017248*^9}, {3.8104807595294323`*^9, 
   3.8104809538100047`*^9}, {3.8104811300285854`*^9, 
   3.8104811403007636`*^9}, {3.8104812580010843`*^9, 
   3.8104813317580833`*^9}, {3.81048146789211*^9, 3.8104815557630205`*^9}, {
   3.8104817202872114`*^9, 3.8104817438715935`*^9}, 3.810481790764664*^9, 
   3.810481836241686*^9, {3.810481926951917*^9, 3.810481935802024*^9}, {
   3.8104820720505495`*^9, 3.8104821860076323`*^9}, {3.810482833577834*^9, 
   3.810482856592573*^9}, {3.810650687465464*^9, 3.8106507334315205`*^9}, 
   3.810651925937356*^9, {3.810652128872187*^9, 3.810652287868311*^9}, {
   3.8106587990048494`*^9, 3.810658928141844*^9}, {3.810723947273243*^9, 
   3.810723968955229*^9}, {3.810724400459839*^9, 
   3.8107244005422564`*^9}},ExpressionUUID->"d260a430-0b0b-4211-882e-\
4db2520f018a"],

Cell["\<\
Again, using Mathematica, we find that this integral does in fact yield a \
value of 1,\
\>", "Text",
 CellChangeTimes->{{3.810724030046258*^9, 
  3.8107240504959755`*^9}},ExpressionUUID->"48181070-b873-4144-91de-\
79041821a638"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  SubsuperscriptBox["\[Integral]", "0", "\[Pi]"], " ", 
  RowBox[{
   SubsuperscriptBox["\[Integral]", "0", 
    RowBox[{"2", "\[Pi]"}]], 
   RowBox[{
    SuperscriptBox[
     RowBox[{"(", 
      FractionBox["1", 
       RowBox[{"2", 
        SqrtBox["\[Pi]"]}]], ")"}], "2"], 
    RowBox[{"Sin", "[", "\[Theta]", "]"}], 
    RowBox[{"\[DifferentialD]", "\[Phi]"}], 
    RowBox[{"\[DifferentialD]", "\[Theta]", " "}]}]}]}]], "Input",
 CellChangeTimes->{{3.810723979095257*^9, 3.810724024710495*^9}},
 CellLabel->"In[9]:=",ExpressionUUID->"446f8af6-7f13-49c7-b41e-906a14e20b10"],

Cell[BoxData["1"], "Output",
 CellChangeTimes->{3.8107240263983445`*^9},
 CellLabel->"Out[9]=",ExpressionUUID->"01844d95-a7ce-4107-946c-71d38cc18267"]
}, Open  ]],

Cell[TextData[{
 "Again, ",
 Cell[BoxData[
  RowBox[{
   SubsuperscriptBox[
    StyleBox["Y",
     FontSlant->"Italic"], "0", "0"], 
   RowBox[{"(", 
    RowBox[{"\[Theta]", ",", "\[Phi]"}], ")"}]}]],
  CellChangeTimes->{{3.8107238778742666`*^9, 3.810723893543601*^9}, {
   3.8107240902680264`*^9, 3.8107240973614845`*^9}},ExpressionUUID->
  "08d6a45e-fc54-4dd0-97d8-4e7f5c9b1104"],
 "has no angular dependence, so that means that our wavefunction,"
}], "Text",
 CellChangeTimes->{{3.810724077084873*^9, 3.810724119113121*^9}, {
  3.8109812809866505`*^9, 
  3.8109812813248043`*^9}},ExpressionUUID->"9b17fbc6-fdf0-4d34-9a14-\
0da6e10225ca"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   SubscriptBox["\[Psi]", 
    StyleBox[
     RowBox[{
      StyleBox["n",
       FontSlant->"Italic"], "00"}]]], 
   RowBox[{"(", 
    RowBox[{
     StyleBox["r",
      FontSlant->"Italic"], ",", "\[Theta]", ",", "\[Phi]"}], ")"}]}], "=", 
  RowBox[{
   RowBox[{
    SubscriptBox[
     StyleBox["R",
      FontSlant->"Italic"], 
     StyleBox[
      RowBox[{
       StyleBox["n",
        FontSlant->"Italic"], "0"}]]], 
    RowBox[{"(", 
     StyleBox["r",
      FontSlant->"Italic"], ")"}], 
    SubsuperscriptBox[
     StyleBox["Y",
      FontSlant->"Italic"], "0", "0"], 
    RowBox[{"(", 
     RowBox[{"\[Theta]", ",", "\[Phi]"}], ")"}]}], "=", 
   RowBox[{
    FractionBox["1", 
     RowBox[{"2", 
      SqrtBox["\[Pi]"]}]], 
    SubscriptBox[
     StyleBox["R",
      FontSlant->"Italic"], 
     StyleBox[
      RowBox[{
       StyleBox["n",
        FontSlant->"Italic"], "0"}]]], 
    RowBox[{"(", 
     StyleBox["r",
      FontSlant->"Italic"], ")"}]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.810112811439228*^9, 3.8101128248442793`*^9}, {
   3.810479494926491*^9, 3.8104795038498344`*^9}, {3.810479572543576*^9, 
   3.8104796147383184`*^9}, {3.8104802055659895`*^9, 
   3.8104802433915305`*^9}, {3.8104802785189395`*^9, 
   3.8104802814214115`*^9}, {3.810480477782269*^9, 3.8104805471507206`*^9}, {
   3.8104805927965565`*^9, 3.810480633017248*^9}, {3.8104807595294323`*^9, 
   3.8104809538100047`*^9}, {3.8104811300285854`*^9, 
   3.8104811403007636`*^9}, {3.8104812580010843`*^9, 
   3.8104813317580833`*^9}, {3.81048146789211*^9, 3.8104815557630205`*^9}, {
   3.8104817202872114`*^9, 3.8104817438715935`*^9}, 3.810481790764664*^9, 
   3.810481836241686*^9, {3.810481926951917*^9, 3.810481935802024*^9}, {
   3.8106609069078913`*^9, 3.81066090872985*^9}, {3.8106610360496655`*^9, 
   3.8106610794321012`*^9}, {3.8106611250786457`*^9, 
   3.8106611896874313`*^9}, {3.810718226403468*^9, 3.8107182918531866`*^9}, {
   3.8107241335231433`*^9, 
   3.81072417963937*^9}},ExpressionUUID->"4a2942e0-7baa-487a-b7a3-\
b22e06cc1691"],

Cell[TextData[{
 "must be spherically symmetric. In other words, all ",
 StyleBox["s",
  FontSlant->"Italic"],
 " orbitals are spherically symmetric. We can see from Figure 6.3 that as ",
 StyleBox["n",
  FontSlant->"Italic"],
 " increases, multiple local maxima appear in the graph of ",
 Cell[BoxData[
  RowBox[{
   SuperscriptBox[
    RowBox[{"\[LeftBracketingBar]", 
     RowBox[{
      SubscriptBox[
       StyleBox["R",
        FontSlant->"Italic"], 
       StyleBox["nl",
        FontSlant->"Italic"]], 
      RowBox[{"(", 
       StyleBox["r",
        FontSlant->"Italic"], ")"}]}], "\[RightBracketingBar]"}], "2"], 
   SuperscriptBox[
    StyleBox["r",
     FontSlant->"Italic"], "2"], 
   StyleBox[
    RowBox[{"d", 
     StyleBox["r",
      FontSlant->"Italic"]}]]}]],
  CellChangeTimes->{{3.810112811439228*^9, 3.8101128248442793`*^9}, {
    3.810479494926491*^9, 3.8104795038498344`*^9}, {3.810479572543576*^9, 
    3.8104796147383184`*^9}, {3.8104802055659895`*^9, 
    3.8104802433915305`*^9}, {3.8104802785189395`*^9, 
    3.8104802814214115`*^9}, {3.810480477782269*^9, 3.8104805471507206`*^9}, {
    3.8104805927965565`*^9, 3.810480633017248*^9}, {3.8104807595294323`*^9, 
    3.8104809538100047`*^9}, {3.8104811300285854`*^9, 
    3.8104811403007636`*^9}, {3.8104812580010843`*^9, 
    3.8104813317580833`*^9}, {3.81048146789211*^9, 3.8104815557630205`*^9}, {
    3.8104817202872114`*^9, 3.8104817438715935`*^9}, 3.810481790764664*^9, 
    3.810481836241686*^9, {3.810481926951917*^9, 3.810481935802024*^9}, {
    3.8104820720505495`*^9, 3.8104821860076323`*^9}, {3.810482833577834*^9, 
    3.810482856592573*^9}, {3.810650687465464*^9, 3.8106507334315205`*^9}, 
    3.810651925937356*^9, {3.810652128872187*^9, 3.810652287868311*^9}, {
    3.8106583239462414`*^9, 3.8106583833041215`*^9}},ExpressionUUID->
  "587bb2e3-2d70-4a8d-823a-713160e73aa8"],
 ", with the global maximum appearing at increasingly large values of ",
 StyleBox["r",
  FontSlant->"Italic"],
 ". We can also see that the expectation value \[LeftAngleBracket]",
 StyleBox["r",
  FontSlant->"Italic"],
 "\[RightAngleBracket] given by the equation"
}], "Text",
 CellChangeTimes->{{3.8107241823749957`*^9, 3.8107241935835447`*^9}, {
