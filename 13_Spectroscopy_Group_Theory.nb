              OverBar[
               Style["B", Italic]]}]]]}, 1., 25., Appearance -> 
         "Labeled"}, {{$CellContext`J$$, 0, 
          Style[
          "\!\(\*SubscriptBox[\(J\), \(i\)]\)", Italic, FontFamily -> 
           "Times"]}, 0, 9, 1}}, 
      "Options" :> {
       ControlType -> {Slider, SetterBar}, 
        TrackedSymbols :> {$CellContext`ratio$$, $CellContext`J$$}}, 
