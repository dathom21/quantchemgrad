Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"[", 
    RowBox[{
     RowBox[{
      SubscriptBox[
       OverscriptBox[
        StyleBox["T",
         FontSlant->"Italic"], "^"], 
       StyleBox["e",
        FontSlant->"Italic"]], 
      RowBox[{"(", 
       StyleBox["r",
        FontSlant->"Italic"], 
       StyleBox[")",
        FontSlant->"Italic"]}]}], "+", 
     RowBox[{
      SubscriptBox[
       OverscriptBox[
        StyleBox["V",
         FontSlant->"Italic"], "^"], 
       StyleBox["eN",
        FontSlant->"Italic"]], 
      RowBox[{"(", 
       RowBox[{
        StyleBox["r",
         FontSlant->"Italic"], 
        StyleBox[",",
         FontSlant->"Plain"], 
        StyleBox["R",
         FontSlant->"Italic"]}], 
       StyleBox[")",
        FontSlant->"Italic"]}]}], "+", 
     RowBox[{
      SubscriptBox[
       OverscriptBox[
        StyleBox["V",
         FontSlant->"Italic"], "^"], 
       StyleBox["ee",
        FontSlant->"Italic"]], 
      RowBox[{"(", 
       StyleBox["r",
        FontSlant->"Italic"], 
       StyleBox[")",
        FontSlant->"Italic"]}]}], "+", 
     RowBox[{
      SubscriptBox[
       OverscriptBox[
        StyleBox["V",
         FontSlant->"Italic"], "^"], 
       StyleBox["NN",
        FontSlant->"Italic"]], 
      RowBox[{"(", 
       StyleBox["R",
        FontSlant->"Italic"], 
       StyleBox[")",
        FontSlant->"Italic"]}]}]}], 
    StyleBox["]",
     FontSlant->"Italic"]}], 
   SubscriptBox["\[Phi]", 
    StyleBox["e",
     FontSlant->"Italic"]], 
   RowBox[{"(", 
    RowBox[{
     StyleBox["r",
      FontWeight->"Bold",
      FontSlant->"Italic"], ",", 
     StyleBox["R",
      FontWeight->"Bold",
      FontSlant->"Italic"]}], 
    StyleBox[")",
     FontSlant->"Italic"]}]}], "=", 
  RowBox[{
   SubscriptBox[
    StyleBox["E",
     FontSlant->"Italic"], 
    StyleBox["e",
     FontSlant->"Italic"]], 
   SubscriptBox["\[Phi]", 
    StyleBox["e",
     FontSlant->"Italic"]], 
   RowBox[{"(", 
    RowBox[{
     StyleBox["r",
      FontWeight->"Bold",
      FontSlant->"Italic"], ";", " ", 
     StyleBox["R",
      FontWeight->"Bold",
      FontSlant->"Italic"]}], 
    StyleBox[")",
     FontSlant->"Italic"]}]}]}]], "DisplayFormulaNumbered",
