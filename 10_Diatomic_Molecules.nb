Cell[BoxData[
 RowBox[{
  SubscriptBox[
   OverscriptBox[
    StyleBox["h",
     FontSlant->"Italic"], "^"], 
   StyleBox["i",
    FontSlant->"Italic"]], "=", 
  RowBox[{
   RowBox[{
    FractionBox[
     RowBox[{"-", "1"}], "2"], 
    RowBox[{
     SubsuperscriptBox["\[Del]", 
      StyleBox["i",
       FontSlant->"Italic"], "2"], 
     RowBox[{"-", 
      RowBox[{
       UnderscriptBox["\[Sum]", 
        StyleBox[
         RowBox[{"A", ",", "i"}],
         FontSlant->"Italic"]], 
       FractionBox[
        SubscriptBox[
         StyleBox["Z",
          FontSlant->"Italic"], 
         StyleBox["A",
          FontSlant->"Italic"]], 
        SubscriptBox[
         StyleBox["r",
          FontSlant->"Italic"], 
         StyleBox["Ai",
          FontSlant->"Italic"]]]}]}]}]}], "=", 
   RowBox[{
    RowBox[{
     SubscriptBox[
      OverscriptBox[
       StyleBox["T",
        FontSlant->"Italic"], "^"], 
      StyleBox["e",
       FontSlant->"Italic"]], 
     RowBox[{"(", 
      StyleBox["r",
       FontSlant->"Italic"], 
      StyleBox[")",
       FontSlant->"Italic"]}]}], "+", 
    RowBox[{
     SubscriptBox[
      OverscriptBox[
       StyleBox["V",
        FontSlant->"Italic"], "^"], 
      StyleBox["eN",
       FontSlant->"Italic"]], 
     RowBox[{"(", 
      RowBox[{
       StyleBox["r",
        FontSlant->"Italic"], 
       StyleBox[",",
        FontSlant->"Plain"], 
       StyleBox["R",
        FontSlant->"Italic"]}], 
      StyleBox[")",
       FontSlant->"Italic"]}]}]}]}]}]], "DisplayFormulaNumbered",
