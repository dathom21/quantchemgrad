Cell[CellGroupData[{

Cell["Postulate 1: What does the wavefunction tell us?", "Section",
 CellChangeTimes->{{3.8074594324828715`*^9, 3.8074594487922525`*^9}, {
  3.8076177444720974`*^9, 3.8076177502095847`*^9}, {3.8076315419037385`*^9, 
  3.8076315442771745`*^9}, {3.8076317240690165`*^9, 3.8076317343277235`*^9}, {
  3.8079650185938416`*^9, 3.8079650467347217`*^9}, {3.807978762083801*^9, 
  3.8079787666501837`*^9}, {3.80805592367854*^9, 
  3.8080559505599174`*^9}},ExpressionUUID->"2e1244cd-788e-464b-96da-\
235986134f15"],

Cell[CellGroupData[{

Cell["Statement of the Postulate", "Subsection",
 CellChangeTimes->{{3.807978811447527*^9, 3.807978816019908*^9}, {
  3.8080559536556225`*^9, 
  3.808055960167986*^9}},ExpressionUUID->"016bf6cf-9a39-4db7-8be8-\
7a6663b7d0cb"],

Cell[TextData[{
 "The state of a quantum mechanical system is specified by the wavefunction \
\[Psi](",
 StyleBox["r",
  FontWeight->"Bold",
  FontSlant->"Italic"],
 ", ",
 StyleBox["t ",
  FontSlant->"Italic"],
 "), which tells us all of the information that we can know about the system. "
}], "Text",
 CellChangeTimes->{{3.8079789310968227`*^9, 3.8079789840444717`*^9}, {
  3.807979183580311*^9, 3.807979219699624*^9}, {3.808055984894498*^9, 
  3.808056033279106*^9}, {3.808056084752066*^9, 3.80805609515707*^9}, {
  3.8080561497716737`*^9, 3.8080561577292824`*^9}, {3.8080563842673016`*^9, 
  3.8080564428502283`*^9}},ExpressionUUID->"cab121ed-5b17-4798-aa5d-\
7e3f2cc5648c"],

Cell[TextData[{
 "The probability that an object in the state specified by \[Psi](",
 StyleBox["r",
  FontWeight->"Bold",
  FontSlant->"Italic"],
 ", ",
 StyleBox["t ",
  FontSlant->"Italic"],
 ") will be found in the volume element ",
 StyleBox["d",
  FontSlant->"Italic"],
 "\[Tau] located at ",
 StyleBox["r",
  FontWeight->"Bold",
  FontSlant->"Italic"],
 StyleBox[" ",
  FontWeight->"Bold"],
 "at time ",
 StyleBox["t",
  FontSlant->"Italic"],
 " is given by"
}], "Text",
 CellChangeTimes->{{3.8080564580156946`*^9, 3.8080564603652105`*^9}, {
  3.8080565030173244`*^9, 
  3.8080566328771286`*^9}},ExpressionUUID->"251579b0-1141-48ee-bddb-\
da91be402a00"],

Cell[BoxData[
 RowBox[{
  SuperscriptBox["\[Psi]", "\[Star]"], 
  RowBox[{"(", 
   RowBox[{
    StyleBox["r",
     FontWeight->"Bold",
     FontSlant->"Italic"], ",", 
    StyleBox["t",
     FontSlant->"Italic"]}], ")"}], "\[Psi]", 
  RowBox[{"(", 
   RowBox[{
    StyleBox["r",
     FontWeight->"Bold",
     FontSlant->"Italic"], ",", 
    StyleBox["t",
     FontSlant->"Italic"]}], 
   StyleBox[")",
    FontSlant->"Italic"]}], 
  StyleBox[
   RowBox[{
    StyleBox["d",
     FontSlant->"Italic"], "\[Tau]"}]]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8079664251944246`*^9, 3.8079664343142004`*^9}, {
   3.8079689400739555`*^9, 3.8079689680029573`*^9}, {3.807970315263204*^9, 
   3.8079703215316095`*^9}, {3.807970415909548*^9, 3.807970437015459*^9}, {
   3.8079705221296997`*^9, 3.8079705895237727`*^9}, {3.8079740353167067`*^9, 
   3.807974091342613*^9}, {3.8079792460635405`*^9, 3.807979253256398*^9}, {
   3.808056638763859*^9, 3.808056681287653*^9}, 3.808056968998802*^9, {
   3.8080571290891876`*^9, 3.8080571901776743`*^9}, 3.8080573054165645`*^9, {
   3.808062673780108*^9, 
   3.808062685868935*^9}},ExpressionUUID->"e89fdce6-b0a6-4426-9d2d-\
cc727c67b1ad"]
}, Open  ]],

Cell[CellGroupData[{

Cell["The Probabilistic Interpretation of the Wavefunction", "Subsection",
 CellChangeTimes->{{3.8080567252262516`*^9, 
  3.8080567346613283`*^9}},ExpressionUUID->"af4152a5-cb76-455d-8091-\
3fc2160b855f"],

Cell["\<\
The first postulate tells us that we must interpret the wave function (more \
specifically its absolute square) in a probabilistic sense. This statement \
means the wavefunction doesn\[CloseCurlyQuote]t necessarily describe a \
literal wave, but instead it gives us a mathematical tool to make \
probabilistic predictions about the behavior of a system. For a single \
particle, because the total probability has to add up to 1 (you can\
\[CloseCurlyQuote]t have more than 100% total probability), we find that\
\>", "Text",
 CellChangeTimes->{{3.808056751293076*^9, 3.808056946400358*^9}, {
  3.8080573104037123`*^9, 
  3.8080573234877796`*^9}},ExpressionUUID->"c84cf5a1-2a08-4dd1-bc55-\
61c4ebd6c985"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   SubsuperscriptBox["\[Integral]", 
    RowBox[{"-", "\[Infinity]"}], "\[Infinity]"], 
   RowBox[{
    SuperscriptBox["\[Psi]", "\[Star]"], 
    RowBox[{"(", 
     RowBox[{
      StyleBox["r",
       FontWeight->"Bold",
       FontSlant->"Italic"], ",", 
      StyleBox["t",
       FontSlant->"Italic"]}], 
     StyleBox[")",
      FontSlant->"Italic"]}], "\[Psi]", 
    RowBox[{"(", 
     RowBox[{
      StyleBox["r",
       FontWeight->"Bold",
       FontSlant->"Italic"], ",", 
      StyleBox["t",
       FontSlant->"Italic"]}], 
     StyleBox[")",
      FontSlant->"Italic"]}], 
    StyleBox[
     RowBox[{
      StyleBox["d",
       FontSlant->"Italic"], "\[Tau]"}]]}]}], "=", 
  "1"}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.8079664251944246`*^9, 3.8079664343142004`*^9}, {
  3.8079689400739555`*^9, 3.8079689680029573`*^9}, {3.807970315263204*^9, 
  3.8079703215316095`*^9}, {3.807970415909548*^9, 3.807970437015459*^9}, {
  3.8079705221296997`*^9, 3.8079705895237727`*^9}, {3.8079740353167067`*^9, 
  3.807974091342613*^9}, {3.8079792460635405`*^9, 3.807979253256398*^9}, {
  3.808056638763859*^9, 3.808056681287653*^9}, {3.8080569738200073`*^9, 
  3.8080570333706875`*^9}, {3.8080573070857663`*^9, 3.808057330443427*^9}, {
  3.8080626928983736`*^9, 
  3.808062697778472*^9}},ExpressionUUID->"e4aab8e3-7cf2-48b5-bc87-\
7623972f3a65"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Postulate 2: Operators Correspond to Observables", "Section",
 CellChangeTimes->{{3.808057462712994*^9, 3.808057467767089*^9}, {
  3.8080574984583817`*^9, 3.8080575145501785`*^9}, {3.808057567592639*^9, 
  3.8080575742655067`*^9}},ExpressionUUID->"58e20712-4e1c-401b-b1d4-\
6051e7a6e86c"],

Cell[CellGroupData[{

Cell["Statement of the Postulate", "Subsection",
 CellChangeTimes->{{3.8080575861408176`*^9, 
  3.8080575890662727`*^9}},ExpressionUUID->"03791bea-f879-4aba-a957-\
516eb27270fb"],

Cell["\<\
For every physical observable from classical mechanics, there is a \
corresponding linear, Hermitian operator in quantum mechanics.\
\>", "Text",
 CellChangeTimes->{{3.8080576837892413`*^9, 
  3.808057744814022*^9}},ExpressionUUID->"33eab849-b285-459e-804c-\
9d9e3082d6e4"]
}, Open  ]],

