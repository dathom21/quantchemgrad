  3.9146663946757755`*^9}},ExpressionUUID->"9c3ce757-017d-4334-891e-\
66a82002828a"],

Cell["\<\
the reason for this definition will become more clear in the final equation. \
Now we have \
\>", "Text",
 CellChangeTimes->{{3.807891049437363*^9, 
  3.8078910863201914`*^9}},ExpressionUUID->"6f232a2f-6b26-4c6d-b639-\
9c4ed68325bc"],

