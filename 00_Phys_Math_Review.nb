Cell[BoxData[
 TagBox[
  StyleBox[
   DynamicModuleBox[{$CellContext`comp$$ = False, $CellContext`F$$ = 
    False, $CellContext`m$$ = 0.05, $CellContext`R$$ = 
    False, $CellContext`tmax$$ = 0., Typeset`show$$ = True, 
    Typeset`bookmarkList$$ = {}, Typeset`bookmarkMode$$ = "Menu", 
