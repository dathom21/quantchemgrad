Cell["\<\
Once we have the effective potential for electron 1, we can also write the \
corresponding effective Hamiltonian for electron 1,\
\>", "Text",
 CellChangeTimes->{{3.8119476255026193`*^9, 
  3.8119476583570833`*^9}},ExpressionUUID->"c4106275-b8af-4baa-9f10-\
3c9f19641b5a"],

Cell[BoxData[
 RowBox[{
  SubsuperscriptBox[
   StyleBox[
    OverscriptBox[
     StyleBox["H",
      FontSlant->"Italic"], "^"],
    FontSlant->"Italic"], "1", "eff"], "=", 
  RowBox[{
   RowBox[{
    FractionBox[
     RowBox[{"-", 
      SuperscriptBox["\[HBar]", "2"]}], 
     RowBox[{"2", 
      StyleBox[
       SubscriptBox["m", "e"],
       FontSlant->"Italic"]}]], 
    RowBox[{
     SubsuperscriptBox["\[Del]", "1", "2"], 
     RowBox[{"-", 
      FractionBox[
       RowBox[{"2", 
        SuperscriptBox[
         StyleBox["e",
          FontSlant->"Italic"], "2"]}], 
       RowBox[{"4", 
        SubscriptBox["\[Pi]\[Epsilon]", "0"]}]]}]}], 
    FractionBox["1", 
     SubscriptBox[
      StyleBox["r",
       FontSlant->"Italic"], "1"]]}], "+", 
   RowBox[{
    SubsuperscriptBox[
     StyleBox["V",
      FontSlant->"Italic"], "1", "eff"], 
    RowBox[{"(", 
     SubscriptBox[
      StyleBox["r",
       FontSlant->"Italic"], "1"], ")"}]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.810112811439228*^9, 3.8101128248442793`*^9}, {
