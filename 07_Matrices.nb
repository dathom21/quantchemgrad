e79f30d05ea9"],

Cell[TextData[{
 "Rather than \[LeftAngleBracket]",
 StyleBox["a",
  FontWeight->"Bold"],
 ",",
 StyleBox["b",
  FontWeight->"Bold"],
 "\[RightAngleBracket]. Also, sometimes, confusingly, people use the term ",
 Cell[BoxData[
  SuperscriptBox[
   StyleBox["a",
    FontWeight->"Bold",
    FontSlant->"Plain"], 
   StyleBox["T",
    FontWeight->"Bold"]]],
  CellChangeTimes->{{3.8112559638442764`*^9, 3.8112559741396627`*^9}, {
    3.8113221103126726`*^9, 3.811322130222258*^9}, 3.8113221675383205`*^9, {
