Cell[TextData[{
 "we already solved for the values of \[Beta] in the angular solution and \
found that ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Beta]", "=", 
    RowBox[{"l", "(", 
     RowBox[{"l", "+", "1"}], ")"}]}], TraditionalForm]],ExpressionUUID->
  "6e992276-5873-4520-84a2-3d036dce5ea3"],
 ". Substituting into equation (65) and rearranging slightly, we write"
}], "Text",
