Cell[CellGroupData[{

Cell["Basis Functions Can Also Contain a Variational Parameter", \
"Subsubsection",
 CellChangeTimes->{{3.811869919071433*^9, 3.8118699234949207`*^9}, {
  3.8119347390473447`*^9, 3.81193476347209*^9}, {3.811935028288742*^9, 
  3.8119350388111467`*^9}},ExpressionUUID->"80e4ecf2-4e00-0b47-ac7c-\
7aa52b932a6d"],

Cell["\<\
To obtain an even better agreement between the variational calculation and \
the true energies and eigenstates, we could vary both the weights of our \
basis functions and a parameter within each of our basis functions. For \
example, instead of using hydrogen-like orbitals as our basis,\
\>", "Text",
 CellChangeTimes->{{3.8119353669327908`*^9, 3.8119354631953063`*^9}, {
  3.8119355010688066`*^9, 
  3.8119355274122562`*^9}},ExpressionUUID->"655a0286-eba5-3540-88d9-\
fc8b388f45d0"],

Cell[BoxData[
 RowBox[{
  RowBox[{"\[Phi]", 
   RowBox[{"(", 
    StyleBox["r",
     FontSlant->"Italic"], ")"}]}], "=", 
  RowBox[{
   UnderscriptBox["\[Sum]", 
    StyleBox["n",
     FontSlant->"Italic"]], 
   RowBox[{
    SubscriptBox[
     StyleBox["a",
      FontSlant->"Italic"], 
     StyleBox["n",
      FontSlant->"Italic"]], 
    SuperscriptBox["\[ExponentialE]", 
     RowBox[{
      RowBox[{"-", 
       StyleBox["Zr",
        FontSlant->"Italic"]}], 
      StyleBox["/",
       FontSlant->"Italic"], 
      SubscriptBox[
       StyleBox["a",
        FontSlant->"Italic"], "0"]}]]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.811593312893673*^9, 3.8115933831661987`*^9}, {
   3.811593458953679*^9, 3.8115934974178753`*^9}, {3.811594043422389*^9, 
   3.8115940850450926`*^9}, {3.8115941212928057`*^9, 3.81159413134099*^9}, {
   3.8115942129312763`*^9, 3.811594213576462*^9}, {3.811594345555955*^9, 
   3.8115943458791523`*^9}, 3.8115943810138807`*^9, {3.8118583015457077`*^9, 
   3.8118583904266043`*^9}, {3.8118668881127214`*^9, 3.811866985652667*^9}, {
   3.81187008170006*^9, 3.8118700849636593`*^9}, {3.8118701593125334`*^9, 
   3.811870201331394*^9}, {3.81193548880807*^9, 3.8119354974236307`*^9}, {
   3.8119355829323487`*^9, 
   3.8119356210392647`*^9}},ExpressionUUID->"e78a51ae-d500-f54a-adf2-\
0f98ebc0d4d4"],

Cell["\<\
one could imagine that we could obtain a much better fit to wavefunctions of \
multielectron atoms if we allowed the effective nuclear charge \[Zeta] to \
vary as well as the weighting coefficients,\
\>", "Text",
 CellChangeTimes->{
  3.811935530397676*^9, {3.811935630847437*^9, 3.811935653077463*^9}, 
   3.811935729484954*^9},ExpressionUUID->"d9bd1808-6318-8b42-b564-\
a25250072399"],

Cell[BoxData[
 RowBox[{
  RowBox[{"\[Phi]", 
   RowBox[{"(", 
    StyleBox["r",
     FontSlant->"Italic"], ")"}]}], "=", 
  RowBox[{
   UnderscriptBox["\[Sum]", 
    StyleBox["n",
     FontSlant->"Italic"]], 
   RowBox[{
    SubscriptBox[
     StyleBox["a",
      FontSlant->"Italic"], 
     StyleBox["n",
      FontSlant->"Italic"]], 
    SuperscriptBox["\[ExponentialE]", 
     RowBox[{
      RowBox[{"-", 
       SubscriptBox[
        StyleBox["\[Zeta]",
         FontSlant->"Plain"], 
        StyleBox["n",
         FontSlant->"Italic"]]}], 
      RowBox[{
       StyleBox["r",
        FontSlant->"Italic"], 
       StyleBox["/",
        FontSlant->"Italic"], 
       SubscriptBox[
        StyleBox["a",
         FontSlant->"Italic"], "0"]}]}]]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.811593312893673*^9, 3.8115933831661987`*^9}, {
   3.811593458953679*^9, 3.8115934974178753`*^9}, {3.811594043422389*^9, 
   3.8115940850450926`*^9}, {3.8115941212928057`*^9, 3.81159413134099*^9}, {
   3.8115942129312763`*^9, 3.811594213576462*^9}, {3.811594345555955*^9, 
   3.8115943458791523`*^9}, 3.8115943810138807`*^9, {3.8118583015457077`*^9, 
   3.8118583904266043`*^9}, {3.8118668881127214`*^9, 3.811866985652667*^9}, {
   3.81187008170006*^9, 3.8118700849636593`*^9}, {3.8118701593125334`*^9, 
   3.811870201331394*^9}, {3.81193548880807*^9, 3.8119354974236307`*^9}, {
   3.8119355829323487`*^9, 3.8119356210392647`*^9}, {3.8119357383708963`*^9, 
   3.811935750506774*^9}},ExpressionUUID->"09739e54-dd14-344d-b894-\
541ee0a7311a"],

Cell[TextData[{
 "Optimizing this sort of trial wavefunction is known as the nonlinear \
variational method. It is extremely time-intensive ( \
\[OpenCurlyDoubleQuote]expensive\[CloseCurlyDoubleQuote] in the language of \
computational chemistry) to perform this optimization because for each change \
in ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Zeta]", "n"], TraditionalForm]],ExpressionUUID->
  "36400a5f-7b4a-0a46-8cac-670c1c1c24fe"],
 ", the matrices ",
 StyleBox["H",
  FontWeight->"Bold"],
 " and ",
 StyleBox["S",
  FontWeight->"Bold"],
 " must be recalculated. In practice, usually the ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Zeta]", "n"], TraditionalForm]],ExpressionUUID->
  "9fa2bc71-e4ce-974a-805c-1e391e905fef"],
 " parameters are optimized based on a set of relevant atoms or molecules, \
and these optimized basis functions are then employed in a typical linear \
variational method calculation, where we vary only the coefficients  ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["a",
    FontSlant->"Italic"], 
   StyleBox["n",
    FontSlant->"Italic"]]],
  CellChangeTimes->{{3.811593312893673*^9, 3.8115933831661987`*^9}, {
    3.811593458953679*^9, 3.8115934974178753`*^9}, {3.811594043422389*^9, 
    3.8115940850450926`*^9}, {3.8115941212928057`*^9, 3.81159413134099*^9}, {
    3.8115942129312763`*^9, 3.811594213576462*^9}, {3.811594345555955*^9, 
    3.8115943458791523`*^9}, 3.8115943810138807`*^9, {3.8118583015457077`*^9, 
    3.8118583904266043`*^9}, {3.8118668881127214`*^9, 3.811866985652667*^9}, {
    3.81187008170006*^9, 3.8118700849636593`*^9}, {3.8118701593125334`*^9, 
    3.811870201331394*^9}, {3.81193548880807*^9, 3.8119354974236307`*^9}, {
    3.8119355829323487`*^9, 3.8119356210392647`*^9}, {3.8119357383708963`*^9, 
    3.811935750506774*^9}},ExpressionUUID->
  "e5e4d6a1-0fb8-7c42-8d2e-348e7ba8615c"],
 ". For example, when performing a calculation with the slater-type orbitals \
discussed earlier, one uses a set of basis functions with previously \
optimized values of ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Zeta]", "n"], TraditionalForm]],ExpressionUUID->
  "fbf6b578-f0dd-cd4a-a1a2-93028b97bd82"],
 "."
}], "Text",
 CellChangeTimes->{{3.811935769478054*^9, 3.8119358658757114`*^9}, {
  3.811935903709519*^9, 
  3.811936080868362*^9}},ExpressionUUID->"5a639e28-a407-a842-a435-\
6fa3f6aa112b"],

Cell["\<\
We\[CloseCurlyQuote]ll return to these ideas when we discuss computational \
chemistry later in the course.\
\>", "Text",
 CellChangeTimes->{{3.811936112001576*^9, 
  3.8119361228043594`*^9}},ExpressionUUID->"236746e5-08b4-e145-b624-\
a48c7d646ee2"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["\<\
The Hartree-Fock Method with Orbitals as Linear Combination of Basis Functions\
\>", "Subsection",
 CellChangeTimes->{{3.8127062882846355`*^9, 3.8127063047798834`*^9}, {
  3.8127114518702517`*^9, 
  3.8127114883728247`*^9}},ExpressionUUID->"81cf9f87-1e7a-4b97-99a2-\
86f85c1cb424"],

Cell[TextData[{
 "Keep in mind that each of our orbital functions ",
 Cell[BoxData[
  SubscriptBox["\[Phi]", 
   StyleBox["i",
    FontSlant->"Italic"]]],
  CellChangeTimes->{{3.810112811439228*^9, 3.8101128248442793`*^9}, {
    3.810479494926491*^9, 3.8104795038498344`*^9}, {3.810479572543576*^9, 
    3.8104796147383184`*^9}, {3.8104802055659895`*^9, 
    3.8104802433915305`*^9}, {3.8104802785189395`*^9, 
    3.8104802814214115`*^9}, {3.8109915300785556`*^9, 
    3.8109916793993816`*^9}, {3.810991710031681*^9, 3.8109918292023373`*^9}, {
    3.810994488524798*^9, 3.810994499853472*^9}, {3.8109948928195066`*^9, 
    3.8109948950763626`*^9}, {3.8109949491606197`*^9, 3.810995087249513*^9}, {
    3.8109951188614283`*^9, 3.8109951226144466`*^9}, {3.8115998145208507`*^9, 
    3.8115999093225703`*^9}, 3.8119468581508093`*^9, {3.811947243706769*^9, 
    3.811947267020794*^9}, {3.8119474358938656`*^9, 3.8119474621815863`*^9}, {
    3.8119475278172007`*^9, 3.811947554332982*^9}, {3.811947616170298*^9, 
    3.8119476213260345`*^9}, {3.8119476732648582`*^9, 3.811947727174863*^9}, {
    3.811947824453816*^9, 3.8119478644680986`*^9}, {3.8126318891761827`*^9, 
    3.8126319287268906`*^9}, {3.812698643216871*^9, 3.8126986714190135`*^9}, {
    3.8127065219878197`*^9, 3.8127066002469187`*^9}, {3.8127069401179733`*^9, 
    3.8127070269316473`*^9}, {3.8127076858801394`*^9, 3.812707743838921*^9}, {
    3.8127078962878947`*^9, 3.8127078968871737`*^9}, {3.8127079338490696`*^9, 
    3.8127079744320726`*^9}},ExpressionUUID->
  "2992a626-1704-4450-ae18-eefe3799921d"],
 " is typically represented as a linear combination of basis functions,"
}], "Text",
 CellChangeTimes->{{3.8127115288665695`*^9, 
  3.8127115800259175`*^9}},ExpressionUUID->"8ec921d3-b2d3-4091-a0ed-\
2a0257d1e229"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   SubscriptBox["\[Phi]", 
    StyleBox["i",
     FontSlant->"Italic"]], 
   RowBox[{"(", 
    SubscriptBox[
     StyleBox["r",
      FontWeight->"Bold",
      FontSlant->"Italic"], "1"], ")"}]}], "=", 
