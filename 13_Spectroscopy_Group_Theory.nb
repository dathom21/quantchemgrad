 RowBox[{
  RowBox[{"m", "=", 
   RowBox[{"Molecule", "[", "\"\<Naphthalene\>\"", "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{"MoleculePlot3D", "[", "m", "]"}], "\n", 
 RowBox[{"m", "[", "\"\<PointGroupDisplay\>\"", "]"}]}], "Input",
