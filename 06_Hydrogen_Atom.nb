Cell[TextData[{
 "For the remaining two cases of ",
 StyleBox["l",
  FontSlant->"Italic"],
 " = 1, where ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["m", "l"], TraditionalForm]],ExpressionUUID->
  "6f25e0b5-ac84-40db-acca-b528262c5739"],
 " \[NotEqual] 0, the wavefunctions are a bit more complicated because there \
is a dependence on both the polar angle \[Theta] and the equatorial angle \
\[Phi]. "
}], "Text",
