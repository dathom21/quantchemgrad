Cell["\<\
then (in general) only one of the integrals will be nonzero, depending on \
whether the final state is above or below the initial state in energy. Let\
\[CloseCurlyQuote]s look at the case of absorption of radiation,\
\>", "Text",
 CellChangeTimes->{{3.815484363993539*^9, 
  3.815484455452052*^9}},ExpressionUUID->"fb35f378-996a-4fef-b8f0-\
3fb689c86575"],

Cell[BoxData[{
 RowBox[{
  StyleBox[
   RowBox[{
    SubsuperscriptBox["c", 
     StyleBox["m",
      FontSlant->"Italic"], 
     StyleBox[
      RowBox[{"(", "1", ")"}],
      FontSlant->"Plain"]], 
    RowBox[{"(", "t", ")"}]}],
   FontSlant->"Italic"], "=", 
  RowBox[{
   FractionBox[
    RowBox[{"-", "\[ImaginaryI]"}], "\[HBar]"], 
   SubscriptBox[
    StyleBox["V",
     FontSlant->"Italic"], 
    StyleBox["mk",
     FontSlant->"Italic"]], 
   RowBox[{
    SubsuperscriptBox["\[Integral]", "0", 
     StyleBox["t",
      FontSlant->"Italic"]], 
    RowBox[{
     SuperscriptBox["\[ExponentialE]", 
      RowBox[{"\[ImaginaryI]", 
       RowBox[{"(", 
        RowBox[{
         SubscriptBox["\[Omega]", 
          StyleBox["mk",
           FontSlant->"Italic"]], "-", "\[Omega]"}], ")"}], 
       RowBox[{
        StyleBox["t",
         FontSlant->"Italic"], "'"}]}]], 
     RowBox[{"\[DifferentialD]", 
      RowBox[{
       StyleBox["t",
        FontSlant->"Italic"], "'"}]}]}]}]}]}], "\[IndentingNewLine]", 
 RowBox[{"\t       ", 
  RowBox[{"=", 
   RowBox[{
    FractionBox[
     RowBox[{"-", "\[ImaginaryI]"}], "\[HBar]"], 
    SubscriptBox[
     StyleBox["V",
      FontSlant->"Italic"], 
     StyleBox["mk",
      FontSlant->"Italic"]], 
    FractionBox[
     RowBox[{"\[ImaginaryI]", " ", 
      RowBox[{"(", 
       RowBox[{
        SuperscriptBox["\[ExponentialE]", 
         RowBox[{"\[ImaginaryI]", " ", 
          RowBox[{"(", 
           RowBox[{
            SubscriptBox["\[Omega]", 
             StyleBox["mk",
              FontSlant->"Italic"]], "-", "\[Omega]"}], ")"}], 
          StyleBox[" ",
           FontSlant->"Italic"], 
          StyleBox["t",
           FontSlant->"Italic"]}]], "-", "1"}], ")"}]}], 
     RowBox[{"\[Omega]", "-", 
      SubscriptBox["\[Omega]", "mk"]}]]}]}]}], "\[IndentingNewLine]", 
 RowBox[{"\t       ", 
  RowBox[{"=", 
   RowBox[{
    FractionBox[
     RowBox[{"-", "\[ImaginaryI]"}], "\[HBar]"], 
    SubscriptBox[
     StyleBox["V",
      FontSlant->"Italic"], 
     StyleBox["mk",
      FontSlant->"Italic"]], 
    SuperscriptBox["\[ExponentialE]", 
