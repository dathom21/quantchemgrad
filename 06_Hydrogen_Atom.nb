             RowBox[{"Line", "[", 
              RowBox[{"{", 
               RowBox[{
                RowBox[{"{", 
                 RowBox[{
                  RowBox[{"-", 
                   RowBox[{"trio", "[", 
                    RowBox[{"[", "1", "]"}], "]"}]}], ",", "0", ",", "0"}], 
