    Deinitialization:>None,
    DynamicModuleValues:>{},
    Initialization:>({$CellContext`f[
         Pattern[$CellContext`x, 
          Blank[]], 
         Pattern[$CellContext`y, 
          Blank[]]] := 
       Exp[(-0.5) 
         Sqrt[$CellContext`x^2 + $CellContext`y^2]], $CellContext`a$$[0] = 
